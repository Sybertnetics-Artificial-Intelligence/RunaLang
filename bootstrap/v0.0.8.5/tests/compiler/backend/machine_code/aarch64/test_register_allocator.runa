Note:
Unit tests for AArch64 register allocator constraint resolution module.

Validates register constants, constraint type constants, opcode constants,
null-guard behavior on collect_constraints, and move coalescing with null input.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/aarch64/register_allocator.runa" as RegAlloc
Import "compiler/backend/machine_code/aarch64/calling_convention.runa" as CC
Import "compiler/middle/gungnir/lir/lir.runa" as LIR

Note: ============================================================================
Note: Register Constant Tests
Note: ============================================================================

Process called "test_register_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Register Constants")

    Note: GPR constants X0-X18, X29, X30, SP
    T.assert_equal(results, "REG_X0 is 0", CC.A64_REG_X0, 0)
    T.assert_equal(results, "REG_X1 is 1", CC.A64_REG_X1, 1)
    T.assert_equal(results, "REG_X7 is 7", CC.A64_REG_X7, 7)
    T.assert_equal(results, "REG_X8 is 8 (syscall number)", CC.A64_REG_X8, 8)
    T.assert_equal(results, "REG_X16 is 16 (IP0)", CC.A64_REG_X16, 16)
    T.assert_equal(results, "REG_X17 is 17 (IP1)", CC.A64_REG_X17, 17)
    T.assert_equal(results, "REG_X18 is 18 (platform)", CC.A64_REG_X18, 18)
    T.assert_equal(results, "REG_X29 is 29 (FP)", CC.A64_REG_X29, 29)
    T.assert_equal(results, "REG_X30 is 30 (LR)", CC.A64_REG_X30, 30)
    T.assert_equal(results, "REG_SP is 31", CC.A64_REG_SP, 31)

    Return 1
End Process

Note: ============================================================================
Note: Constraint Type Constant Tests
Note: ============================================================================

Process called "test_constraint_types" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Constraint Type Constants")

    T.assert_equal(results, "CONSTRAINT_FIXED_REG is 2", RegAlloc.A64_CONSTRAINT_FIXED_REG, 2)
    T.assert_equal(results, "CONSTRAINT_CLOBBER is 3", RegAlloc.A64_CONSTRAINT_CLOBBER, 3)
    T.assert_equal(results, "CONSTRAINT_SP_RESTRICTED is 6", RegAlloc.A64_CONSTRAINT_SP_RESTRICTED, 6)

    Return 1
End Process

Note: ============================================================================
Note: LIR Opcode Constant Tests
Note: ============================================================================

Process called "test_opcode_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 LIR Opcode Constants")

    T.assert_equal(results, "OP_MOV is 30001", LIR.LIR_MOV, 30001)
    T.assert_equal(results, "OP_ADD is 30100", LIR.LIR_ADD, 30100)
    T.assert_equal(results, "OP_SUB is 30101", LIR.LIR_SUB, 30101)
    T.assert_equal(results, "OP_IMUL is 30102", LIR.LIR_IMUL, 30102)
    T.assert_equal(results, "OP_IDIV is 30103", LIR.LIR_IDIV, 30103)
    T.assert_equal(results, "OP_CALL is 30520", LIR.LIR_CALL, 30520)
    T.assert_equal(results, "OP_SYSCALL is 30523", LIR.LIR_SYSCALL, 30523)
    T.assert_equal(results, "OP_SHL is 30300", LIR.LIR_SHL, 30300)
    T.assert_equal(results, "OP_SAR is 30302", LIR.LIR_SAR, 30302)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Register Allocator Null Guards")

    Note: collect_constraints with null function should return 0
    Let null_result be RegAlloc.collect_constraints(0)
    T.assert_equal(results, "collect_constraints(0) returns 0", null_result, 0)

    Note: insert_register_copy with null block should return 0
    Let copy_result be RegAlloc.insert_register_copy(0, 0, 0, 1, 8)
    T.assert_equal(results, "insert_register_copy(null block) returns 0", copy_result, 0)

    Note: insert_register_copy with same src and dest should return 1 (no-op success)
    Note: We need a non-null block for this, but with null block it returns 0
    Note: Test that finalize with null returns 0
    Let finalize_result be RegAlloc.finalize_aarch64_allocation(0)
    T.assert_equal(results, "finalize_aarch64_allocation(null) returns 0", finalize_result, 0)

    Note: coalesce_moves with null function returns 0
    Let coalesce_result be RegAlloc.coalesce_moves(0)
    T.assert_equal(results, "coalesce_moves(null) returns 0", coalesce_result, 0)

    Note: handle_fixed_reg_constraint with null instruction returns 0
    Let fixed_result be RegAlloc.handle_fixed_reg_constraint(0, 0, 0, 0, 0, 0)
    T.assert_equal(results, "handle_fixed_reg(null instr) returns 0", fixed_result, 0)

    Note: handle_sp_restriction with null instruction returns 0
    Let sp_result be RegAlloc.handle_sp_restriction(0, 0, 0, 0)
    T.assert_equal(results, "handle_sp_restriction(null instr) returns 0", sp_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Architecture Characteristics Tests
Note: ============================================================================

Process called "test_architecture_characteristics" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Architecture Characteristics")

    Note: AArch64 has NO CONSTRAINT_TWO_ADDRESS (no two-address form)
    Note: Verify that CONSTRAINT_FIXED_REG, CONSTRAINT_CLOBBER, and
    Note: CONSTRAINT_SP_RESTRICTED are the only defined constraint types
    Note: by checking they are distinct values
    Let fixed be RegAlloc.A64_CONSTRAINT_FIXED_REG
    Let clobber be RegAlloc.A64_CONSTRAINT_CLOBBER
    Let sp_rest be RegAlloc.A64_CONSTRAINT_SP_RESTRICTED

    T.assert_not_equal(results, "FIXED_REG != CLOBBER", fixed, clobber)
    T.assert_not_equal(results, "FIXED_REG != SP_RESTRICTED", fixed, sp_rest)
    T.assert_not_equal(results, "CLOBBER != SP_RESTRICTED", clobber, sp_rest)

    Note: AArch64 does NOT have CONSTRAINT_TWO_ADDRESS (value 1) or SHIFT_CL (value 4)
    Note: or DIV_RAX_RDX (value 5) - these are x86_64 only
    T.assert_not_equal(results, "FIXED_REG is not 1 (no TWO_ADDRESS)", fixed, 1)
    T.assert_not_equal(results, "CLOBBER is not 4 (no SHIFT_CL)", clobber, 4)
    T.assert_not_equal(results, "SP_RESTRICTED is not 5 (no DIV_RAX_RDX)", sp_rest, 5)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_register_constants(results)
    test_constraint_types(results)
    test_opcode_constants(results)
    test_null_guards(results)
    test_architecture_characteristics(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process

Process called "main" returns Integer:
    Return run_all_tests()
End Process
