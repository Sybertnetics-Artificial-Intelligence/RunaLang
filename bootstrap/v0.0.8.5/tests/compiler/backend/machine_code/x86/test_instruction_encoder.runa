Note:
Unit Tests for x86 (IA-32) Instruction Encoder

Validates register encoding constants (ENC_EAX through ENC_EDI), ModR/M and
SIB byte construction, displacement fitting, encoder context lifecycle,
and binary encoding of MOV, ADD, PUSH, POP, CALL, RET, JMP, Jcc, ALU, shift,
multiply, divide, NOP, CDQ, INT, LEA, and TEST instructions.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/x86/instruction_encoder.runa" as X86Enc
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Register Encoding Constant Tests
Note: ============================================================================

Process called "test_register_encoding_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 instruction_encoder: register encoding constants")

    Note: x86 32-bit uses 3-bit register encoding (0-7)
    T.assert_equal(results, "ENC_EAX is 0", X86Enc.ENC_EAX, 0)
    T.assert_equal(results, "ENC_ECX is 1", X86Enc.ENC_ECX, 1)
    T.assert_equal(results, "ENC_EDX is 2", X86Enc.ENC_EDX, 2)
    T.assert_equal(results, "ENC_EBX is 3", X86Enc.ENC_EBX, 3)
    T.assert_equal(results, "ENC_ESP is 4", X86Enc.ENC_ESP, 4)
    T.assert_equal(results, "ENC_EBP is 5", X86Enc.ENC_EBP, 5)
    T.assert_equal(results, "ENC_ESI is 6", X86Enc.ENC_ESI, 6)
    T.assert_equal(results, "ENC_EDI is 7", X86Enc.ENC_EDI, 7)

    Note: Exactly 8 encodings (3-bit field, no REX prefix on IA-32)
    Note: Verify ModR/M mode constants
    T.assert_equal(results, "MOD_INDIRECT is 0", X86Enc.MOD_INDIRECT, 0)
    T.assert_equal(results, "MOD_DISP8 is 1", X86Enc.MOD_DISP8, 1)
    T.assert_equal(results, "MOD_DISP32 is 2", X86Enc.MOD_DISP32, 2)
    T.assert_equal(results, "MOD_REGISTER is 3", X86Enc.MOD_REGISTER, 3)

    Note: Verify SIB scale constants
    T.assert_equal(results, "SIB_SCALE_1 is 0", X86Enc.SIB_SCALE_1, 0)
    T.assert_equal(results, "SIB_SCALE_2 is 1", X86Enc.SIB_SCALE_2, 1)
    T.assert_equal(results, "SIB_SCALE_4 is 2", X86Enc.SIB_SCALE_4, 2)
    T.assert_equal(results, "SIB_SCALE_8 is 3", X86Enc.SIB_SCALE_8, 3)

    Return 1
End Process

Note: ============================================================================
Note: Encoder Context Tests
Note: ============================================================================

Process called "test_encoder_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 instruction_encoder: encoder context")

    Note: Create a binary output buffer to back the encoder
    Let arena be Layout.allocate(65536)
    T.assert_not_null(results, "arena allocation succeeds", arena)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Note: Create encoder context
    Let ctx be X86Enc.create_encoder_context(output)
    T.assert_not_null(results, "create_encoder_context returns non-null", ctx)

    Note: Verify output pointer stored (offset 0)
    Let stored_output be __load(ctx, 0)
    T.assert_equal(results, "output pointer stored", stored_output, output)

    Note: Verify code_buffer allocated (offset 8)
    Let code_buf be __load(ctx, 8)
    T.assert_not_null(results, "code_buffer allocated", code_buf)

    Note: Verify code_pos starts at 0 (offset 16)
    Let code_pos be __load(ctx, 16)
    T.assert_equal(results, "code_pos starts at 0", code_pos, 0)

    Note: Verify buffer_capacity is 16 (offset 24)
    Let cap be __load(ctx, 24)
    T.assert_equal(results, "buffer_capacity is 16", cap, 16)

    Note: encoder_reset should succeed and reset position
    Let r1 be X86Enc.encoder_reset(ctx)
    T.assert_equal(results, "encoder_reset returns 1", r1, 1)

    Note: encoder_reset with null should return 0
    Let r2 be X86Enc.encoder_reset(0)
    T.assert_equal(results, "encoder_reset(0) returns 0", r2, 0)

    Return 1
End Process

Note: ============================================================================
Note: Register Encoding Function Tests
Note: ============================================================================

Process called "test_encode_register" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 instruction_encoder: encode_register")

    Note: Valid range 0-7 maps 1:1
    T.assert_equal(results, "encode_register(0) is 0", X86Enc.encode_register(0), 0)
    T.assert_equal(results, "encode_register(3) is 3", X86Enc.encode_register(3), 3)
    T.assert_equal(results, "encode_register(7) is 7", X86Enc.encode_register(7), 7)

    Note: Out-of-range returns 0
    T.assert_equal(results, "encode_register(-1) is 0", X86Enc.encode_register(-1), 0)
    T.assert_equal(results, "encode_register(8) is 0", X86Enc.encode_register(8), 0)

    Return 1
End Process

Note: ============================================================================
Note: ModR/M and SIB Construction Tests
Note: ============================================================================

Process called "test_build_modrm" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 instruction_encoder: build_modrm")

    Note: ModR/M = (mod << 6) | (reg << 3) | rm
    Note: mod=3 (register direct), reg=0 (EAX), rm=1 (ECX) => 0xC1 = 193
    Let modrm1 be X86Enc.build_modrm(3, 0, 1)
    T.assert_equal(results, "ModR/M(mod=3,reg=0,rm=1) is 193", modrm1, 193)

    Note: mod=0, reg=0, rm=0 => 0x00 = 0
    Let modrm2 be X86Enc.build_modrm(0, 0, 0)
    T.assert_equal(results, "ModR/M(mod=0,reg=0,rm=0) is 0", modrm2, 0)

    Note: mod=3, reg=7, rm=7 => 0xFF = 255
    Let modrm3 be X86Enc.build_modrm(3, 7, 7)
    T.assert_equal(results, "ModR/M(mod=3,reg=7,rm=7) is 255", modrm3, 255)

    Note: SIB byte: (scale << 6) | (index << 3) | base
    Let sib1 be X86Enc.build_sib(0, 0, 0)
    T.assert_equal(results, "SIB(scale=0,index=0,base=0) is 0", sib1, 0)

    Let sib2 be X86Enc.build_sib(2, 1, 5)
    Note: (2 << 6) | (1 << 3) | 5 = 128 + 8 + 5 = 141
    T.assert_equal(results, "SIB(scale=2,index=1,base=5) is 141", sib2, 141)

    Return 1
End Process

Note: ============================================================================
Note: Displacement Fitting Tests
Note: ============================================================================

Process called "test_fits_in_disp8" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 instruction_encoder: fits_in_disp8")

    T.assert_equal(results, "0 fits in disp8", X86Enc.fits_in_disp8(0), 1)
    T.assert_equal(results, "127 fits in disp8", X86Enc.fits_in_disp8(127), 1)
    T.assert_equal(results, "-128 fits in disp8", X86Enc.fits_in_disp8(-128), 1)
    T.assert_equal(results, "128 does not fit in disp8", X86Enc.fits_in_disp8(128), 0)
    T.assert_equal(results, "-129 does not fit in disp8", X86Enc.fits_in_disp8(-129), 0)
    T.assert_equal(results, "1000 does not fit in disp8", X86Enc.fits_in_disp8(1000), 0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 instruction_encoder: null guards")

    Note: All encoding functions should return 0 when given null context
    T.assert_equal(results, "encode_mov(0,...) returns 0", X86Enc.encode_mov(0, 0, 0), 0)
    T.assert_equal(results, "encode_add(0,...) returns 0", X86Enc.encode_add(0, 0, 0), 0)
    T.assert_equal(results, "encode_push(0,...) returns 0", X86Enc.encode_push(0, 0), 0)
    T.assert_equal(results, "encode_pop(0,...) returns 0", X86Enc.encode_pop(0, 0), 0)
    T.assert_equal(results, "encode_call(0,...) returns 0", X86Enc.encode_call(0, 0), 0)
    T.assert_equal(results, "encode_ret(0) returns 0", X86Enc.encode_ret(0), 0)
    T.assert_equal(results, "encode_jmp(0,...) returns 0", X86Enc.encode_jmp(0, 0), 0)
    T.assert_equal(results, "encode_jcc(0,...) returns 0", X86Enc.encode_jcc(0, 0, 0), 0)
    T.assert_equal(results, "encode_not(0,...) returns 0", X86Enc.encode_not(0, 0), 0)
    T.assert_equal(results, "encode_neg(0,...) returns 0", X86Enc.encode_neg(0, 0), 0)
    T.assert_equal(results, "encode_inc(0,...) returns 0", X86Enc.encode_inc(0, 0), 0)
    T.assert_equal(results, "encode_dec(0,...) returns 0", X86Enc.encode_dec(0, 0), 0)
    T.assert_equal(results, "encode_nop(0) returns 0", X86Enc.encode_nop(0), 0)
    T.assert_equal(results, "encode_cdq(0) returns 0", X86Enc.encode_cdq(0), 0)
    T.assert_equal(results, "encode_int(0,...) returns 0", X86Enc.encode_int(0, 0), 0)
    T.assert_equal(results, "encode_lea(0,...) returns 0", X86Enc.encode_lea(0, 0, 0), 0)
    T.assert_equal(results, "encode_test(0,...) returns 0", X86Enc.encode_test(0, 0, 0), 0)
    T.assert_equal(results, "encoder_emit_byte(0,...) returns 0", X86Enc.encoder_emit_byte(0, 0), 0)
    T.assert_equal(results, "encoder_flush(0) returns 0", X86Enc.encoder_flush(0), 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_register_encoding_constants(results)
    test_encoder_context(results)
    test_encode_register(results)
    test_build_modrm(results)
    test_fits_in_disp8(results)
    test_null_guards(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
