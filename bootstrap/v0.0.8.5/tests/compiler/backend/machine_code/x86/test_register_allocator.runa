Note:
Unit Tests for x86 (IA-32) Register Allocator

Validates the 8-register GPR file (EAX-EDI), cdecl calling convention
classification (callee-saved: EBX, ESI, EDI, EBP; caller-saved: EAX, ECX, EDX),
allocatable register set (6 of 8, excluding EBP and ESP), virtual-to-physical
mapping, constraint constants, and constraint collection for two-address form,
division (EAX:EDX pair), and shift-CL requirements.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/x86/register_allocator.runa" as X86Reg
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Register Constant Tests
Note: ============================================================================

Process called "test_register_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 register_allocator: register constants")

    T.assert_equal(results, "REG_EAX is 0", X86Reg.REG_EAX, 0)
    T.assert_equal(results, "REG_EBX is 1", X86Reg.REG_EBX, 1)
    T.assert_equal(results, "REG_ECX is 2", X86Reg.REG_ECX, 2)
    T.assert_equal(results, "REG_EDX is 3", X86Reg.REG_EDX, 3)
    T.assert_equal(results, "REG_ESI is 4", X86Reg.REG_ESI, 4)
    T.assert_equal(results, "REG_EDI is 5", X86Reg.REG_EDI, 5)
    T.assert_equal(results, "REG_EBP is 6", X86Reg.REG_EBP, 6)
    T.assert_equal(results, "REG_ESP is 7", X86Reg.REG_ESP, 7)
    T.assert_equal(results, "X86_GPR_COUNT is 8", X86Reg.X86_GPR_COUNT, 8)
    T.assert_equal(results, "X86_ALLOCATABLE_COUNT is 6", X86Reg.X86_ALLOCATABLE_COUNT, 6)

    Return 1
End Process

Note: ============================================================================
Note: Constraint Constant Tests
Note: ============================================================================

Process called "test_constraint_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 register_allocator: constraint constants")

    T.assert_equal(results, "CONSTRAINT_TWO_ADDRESS is 1", X86Reg.CONSTRAINT_TWO_ADDRESS, 1)
    T.assert_equal(results, "CONSTRAINT_FIXED_REG is 2", X86Reg.CONSTRAINT_FIXED_REG, 2)
    T.assert_equal(results, "CONSTRAINT_CLOBBER is 3", X86Reg.CONSTRAINT_CLOBBER, 3)
    T.assert_equal(results, "CONSTRAINT_SHIFT_CL is 4", X86Reg.CONSTRAINT_SHIFT_CL, 4)
    T.assert_equal(results, "CONSTRAINT_DIV_EAX_EDX is 5", X86Reg.CONSTRAINT_DIV_EAX_EDX, 5)

    Return 1
End Process

Note: ============================================================================
Note: Allocatable Register Tests
Note: ============================================================================

Process called "test_is_allocatable_register" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 register_allocator: is_allocatable_register")

    Note: EAX(0), EBX(1), ECX(2), EDX(3), ESI(4), EDI(5) are allocatable
    T.assert_equal(results, "EAX(0) is allocatable", X86Reg.is_allocatable_register(0), 1)
    T.assert_equal(results, "EBX(1) is allocatable", X86Reg.is_allocatable_register(1), 1)
    T.assert_equal(results, "ECX(2) is allocatable", X86Reg.is_allocatable_register(2), 1)
    T.assert_equal(results, "EDX(3) is allocatable", X86Reg.is_allocatable_register(3), 1)
    T.assert_equal(results, "ESI(4) is allocatable", X86Reg.is_allocatable_register(4), 1)
    T.assert_equal(results, "EDI(5) is allocatable", X86Reg.is_allocatable_register(5), 1)

    Note: EBP(6) and ESP(7) are reserved
    T.assert_equal(results, "EBP(6) is NOT allocatable", X86Reg.is_allocatable_register(6), 0)
    T.assert_equal(results, "ESP(7) is NOT allocatable", X86Reg.is_allocatable_register(7), 0)

    Note: Out-of-range returns 0
    T.assert_equal(results, "reg -1 is NOT allocatable", X86Reg.is_allocatable_register(-1), 0)
    T.assert_equal(results, "reg 8 is NOT allocatable", X86Reg.is_allocatable_register(8), 0)

    Return 1
End Process

Note: ============================================================================
Note: Calling Convention Tests
Note: ============================================================================

Process called "test_calling_convention" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 register_allocator: cdecl calling convention")

    Note: Callee-saved: EBX(1), ESI(4), EDI(5), EBP(6)
    T.assert_equal(results, "EBX(1) is callee-saved", X86Reg.is_callee_saved(1), 1)
    T.assert_equal(results, "ESI(4) is callee-saved", X86Reg.is_callee_saved(4), 1)
    T.assert_equal(results, "EDI(5) is callee-saved", X86Reg.is_callee_saved(5), 1)
    T.assert_equal(results, "EBP(6) is callee-saved", X86Reg.is_callee_saved(6), 1)

    Note: EAX, ECX, EDX are NOT callee-saved
    T.assert_equal(results, "EAX(0) is NOT callee-saved", X86Reg.is_callee_saved(0), 0)
    T.assert_equal(results, "ECX(2) is NOT callee-saved", X86Reg.is_callee_saved(2), 0)
    T.assert_equal(results, "EDX(3) is NOT callee-saved", X86Reg.is_callee_saved(3), 0)

    Note: Caller-saved: EAX(0), ECX(2), EDX(3)
    T.assert_equal(results, "EAX(0) is caller-saved", X86Reg.is_caller_saved(0), 1)
    T.assert_equal(results, "ECX(2) is caller-saved", X86Reg.is_caller_saved(2), 1)
    T.assert_equal(results, "EDX(3) is caller-saved", X86Reg.is_caller_saved(3), 1)

    Note: EBX, ESI, EDI, EBP are NOT caller-saved
    T.assert_equal(results, "EBX(1) is NOT caller-saved", X86Reg.is_caller_saved(1), 0)
    T.assert_equal(results, "ESI(4) is NOT caller-saved", X86Reg.is_caller_saved(4), 0)

    Return 1
End Process

Note: ============================================================================
Note: Virtual-to-Physical Mapping Tests
Note: ============================================================================

Process called "test_map_virtual_to_physical" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 register_allocator: map_virtual_to_physical")

    Note: Direct mapping for vreg 0-5
    T.assert_equal(results, "vreg 0 -> EAX", X86Reg.map_virtual_to_physical(0), X86Reg.REG_EAX)
    T.assert_equal(results, "vreg 1 -> ECX", X86Reg.map_virtual_to_physical(1), X86Reg.REG_ECX)
    T.assert_equal(results, "vreg 2 -> EDX", X86Reg.map_virtual_to_physical(2), X86Reg.REG_EDX)
    T.assert_equal(results, "vreg 3 -> EBX", X86Reg.map_virtual_to_physical(3), X86Reg.REG_EBX)
    T.assert_equal(results, "vreg 4 -> ESI", X86Reg.map_virtual_to_physical(4), X86Reg.REG_ESI)
    T.assert_equal(results, "vreg 5 -> EDI", X86Reg.map_virtual_to_physical(5), X86Reg.REG_EDI)

    Note: vreg 6+ must spill (returns -1)
    T.assert_equal(results, "vreg 6 spills (-1)", X86Reg.map_virtual_to_physical(6), -1)
    T.assert_equal(results, "vreg 100 spills (-1)", X86Reg.map_virtual_to_physical(100), -1)

    Return 1
End Process

Note: ============================================================================
Note: Get Allocatable Registers Tests
Note: ============================================================================

Process called "test_get_allocatable_registers" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 register_allocator: get_allocatable_registers")

    Let regs be X86Reg.get_allocatable_registers()
    T.assert_not_null(results, "get_allocatable_registers returns non-null", regs)

    Let count be List.list_length(regs)
    T.assert_equal(results, "allocatable register count is 6", count, 6)

    Note: Verify preference order: scratch first (EAX, ECX, EDX), then callee-saved (EBX, ESI, EDI)
    Let r0 be List.list_get(regs, 0)
    T.assert_equal(results, "first allocatable is EAX(0)", r0, X86Reg.REG_EAX)
    Let r1 be List.list_get(regs, 1)
    T.assert_equal(results, "second allocatable is ECX(2)", r1, X86Reg.REG_ECX)
    Let r2 be List.list_get(regs, 2)
    T.assert_equal(results, "third allocatable is EDX(3)", r2, X86Reg.REG_EDX)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 register_allocator: null guards")

    T.assert_equal(results, "collect_x86_constraints(0) returns 0", X86Reg.collect_x86_constraints(0), 0)
    T.assert_equal(results, "resolve_x86_constraints(0) returns 0", X86Reg.resolve_x86_constraints(0), 0)
    T.assert_equal(results, "coalesce_moves(0) returns 0", X86Reg.coalesce_moves(0), 0)
    T.assert_equal(results, "create_constraint returns non-null", X86Reg.create_constraint(0, 1, 0, 0, 0) is not 0, 1)
    T.assert_equal(results, "insert_register_copy(0,...) returns 0", X86Reg.insert_register_copy(0, 0, 0, 0, 4), 0)
    T.assert_equal(results, "handle_two_address_form(0,...) returns 0", X86Reg.handle_two_address_form(0, 0, 0, 0), 0)
    T.assert_equal(results, "handle_division_constraint(0,...) returns 0", X86Reg.handle_division_constraint(0, 0, 0, 0), 0)
    T.assert_equal(results, "handle_shift_cl_constraint(0,...) returns 0", X86Reg.handle_shift_cl_constraint(0, 0, 0, 0), 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_register_constants(results)
    test_constraint_constants(results)
    test_is_allocatable_register(results)
    test_calling_convention(results)
    test_map_virtual_to_physical(results)
    test_get_allocatable_registers(results)
    test_null_guards(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
