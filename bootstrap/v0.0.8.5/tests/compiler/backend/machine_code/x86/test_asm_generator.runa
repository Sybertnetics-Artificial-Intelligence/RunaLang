Note:
Unit Tests for x86 (IA-32) Assembly Generator

Validates AT&T syntax emission, cdecl calling convention prologue/epilogue
generation, register naming (%eax-%edi), operand formatting with size suffixes,
and instruction dispatch for data movement, arithmetic, control flow, and
memory operations on the 32-bit x86 backend.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/x86/asm_generator.runa" as X86Asm
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Register Name Tests
Note: ============================================================================

Process called "test_register_names" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 asm_generator: register names")

    Note: x86 32-bit has 8 GPRs: EAX(0), ECX(1), EDX(2), EBX(3), ESP(4), EBP(5), ESI(6), EDI(7)
    Let name0 be X86Asm.get_register_name(0)
    T.assert_not_null(results, "get_register_name(0) returns non-null", name0)

    Let name1 be X86Asm.get_register_name(1)
    T.assert_not_null(results, "get_register_name(1) returns non-null", name1)

    Let name2 be X86Asm.get_register_name(2)
    T.assert_not_null(results, "get_register_name(2) returns non-null", name2)

    Let name3 be X86Asm.get_register_name(3)
    T.assert_not_null(results, "get_register_name(3) returns non-null", name3)

    Let name4 be X86Asm.get_register_name(4)
    T.assert_not_null(results, "get_register_name(4) returns non-null", name4)

    Let name5 be X86Asm.get_register_name(5)
    T.assert_not_null(results, "get_register_name(5) returns non-null", name5)

    Let name6 be X86Asm.get_register_name(6)
    T.assert_not_null(results, "get_register_name(6) returns non-null", name6)

    Let name7 be X86Asm.get_register_name(7)
    T.assert_not_null(results, "get_register_name(7) returns non-null", name7)

    Note: Out-of-range register ID should still return a valid fallback
    Let name_neg be X86Asm.get_register_name(-1)
    T.assert_not_null(results, "get_register_name(-1) returns non-null fallback", name_neg)

    Let name_oob be X86Asm.get_register_name(99)
    T.assert_not_null(results, "get_register_name(99) returns non-null fallback", name_oob)

    Return 1
End Process

Note: ============================================================================
Note: Context Creation Tests
Note: ============================================================================

Process called "test_create_asm_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 asm_generator: create_asm_context")

    Let arena be Layout.allocate(65536)
    T.assert_not_null(results, "arena allocation succeeds", arena)

    Let config be Layout.allocate(64)
    T.assert_not_null(results, "config allocation succeeds", config)

    Let ctx be X86Asm.create_asm_context(config, arena)
    T.assert_not_null(results, "create_asm_context returns non-null", ctx)

    Note: Verify output buffer was created (offset 0)
    Let output be __load(ctx, 0)
    T.assert_not_null(results, "output buffer stored in context", output)

    Note: Verify config pointer stored (offset 8)
    Let stored_config be __load(ctx, 8)
    T.assert_equal(results, "config pointer stored correctly", stored_config, config)

    Note: Verify current_function starts at 0 (offset 16)
    Let current_func be __load(ctx, 16)
    T.assert_equal(results, "current_function starts at 0", current_func, 0)

    Note: Verify arena stored (offset 24)
    Let stored_arena be __load(ctx, 24)
    T.assert_equal(results, "arena pointer stored correctly", stored_arena, arena)

    Note: Verify error_count starts at 0 (offset 32)
    Let errors be __load(ctx, 32)
    T.assert_equal(results, "error_count starts at 0", errors, 0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 asm_generator: null guards")

    Note: generate_x86_assembly with null module should return 0
    Let r1 be X86Asm.generate_x86_assembly(0, 0)
    T.assert_equal(results, "generate_x86_assembly(0, 0) returns 0", r1, 0)

    Note: emit_function with null context should return 0
    Let r2 be X86Asm.emit_function(0, 0)
    T.assert_equal(results, "emit_function(0, 0) returns 0", r2, 0)

    Note: emit_basic_block with null block should return 0
    Let arena be Layout.allocate(65536)
    Let config be Layout.allocate(64)
    Let ctx be X86Asm.create_asm_context(config, arena)
    Let r3 be X86Asm.emit_basic_block(ctx, 0)
    T.assert_equal(results, "emit_basic_block(ctx, 0) returns 0", r3, 0)

    Note: emit_instruction with null instruction should return 0
    Let r4 be X86Asm.emit_instruction(ctx, 0)
    T.assert_equal(results, "emit_instruction(ctx, 0) returns 0", r4, 0)

    Note: format_operand with null operand should return empty string
    Let r5 be X86Asm.format_operand(0, 4)
    T.assert_not_null(results, "format_operand(0, 4) returns non-null", r5)

    Return 1
End Process

Note: ============================================================================
Note: Operand Formatting Tests
Note: ============================================================================

Process called "test_format_operand" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86 asm_generator: format_operand")

    Note: Create a register operand (type=1, reg_id at offset 8)
    Let reg_op be Layout.allocate(64)
    T.assert_not_null(results, "register operand allocation", reg_op)
    __store(reg_op, 0, 1)
    __store(reg_op, 8, 0)
    Let reg_str be X86Asm.format_operand(reg_op, 4)
    T.assert_not_null(results, "format_operand for register returns non-null", reg_str)

    Note: Create an immediate operand (type=2, value at offset 16)
    Let imm_op be Layout.allocate(64)
    T.assert_not_null(results, "immediate operand allocation", imm_op)
    __store(imm_op, 0, 2)
    __store(imm_op, 16, 42)
    Let imm_str be X86Asm.format_operand(imm_op, 4)
    T.assert_not_null(results, "format_operand for immediate returns non-null", imm_str)

    Note: Create a memory operand (type=3, base_reg at offset 24, disp at offset 48)
    Let mem_op be Layout.allocate(64)
    T.assert_not_null(results, "memory operand allocation", mem_op)
    __store(mem_op, 0, 3)
    __store(mem_op, 24, 5)
    __store(mem_op, 32, 0)
    __store(mem_op, 40, 0)
    __store(mem_op, 48, 8)
    Let mem_str be X86Asm.format_operand(mem_op, 4)
    T.assert_not_null(results, "format_operand for memory returns non-null", mem_str)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_register_names(results)
    test_create_asm_context(results)
    test_null_guards(results)
    test_format_operand(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
