Note:
Unit Tests for PowerPC Instruction Encoder

Validates PowerPC primary opcode constants, D-form/X-form/XO-form/B-form/I-form
instruction format identification, and instruction encoding for the fixed 32-bit
PowerPC ISA. PowerPC uses a 6-bit primary opcode with extended opcodes for
register-register operations.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/powerpc/instruction_encoder.runa" as PPCEnc
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Primary Opcode Constant Tests
Note: ============================================================================

Process called "test_primary_opcode_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "powerpc instruction_encoder: primary opcode constants")

    T.assert_equal(results, "PPC_OP_TWI is 3", PPCEnc.PPC_OP_TWI, 3)
    T.assert_equal(results, "PPC_OP_MULLI is 7", PPCEnc.PPC_OP_MULLI, 7)
    T.assert_equal(results, "PPC_OP_SUBFIC is 8", PPCEnc.PPC_OP_SUBFIC, 8)
    T.assert_equal(results, "PPC_OP_CMPLI is 10", PPCEnc.PPC_OP_CMPLI, 10)
    T.assert_equal(results, "PPC_OP_CMPI is 11", PPCEnc.PPC_OP_CMPI, 11)
    T.assert_equal(results, "PPC_OP_ADDIC is 12", PPCEnc.PPC_OP_ADDIC, 12)
    T.assert_equal(results, "PPC_OP_ADDI is 14", PPCEnc.PPC_OP_ADDI, 14)
    T.assert_equal(results, "PPC_OP_ADDIS is 15", PPCEnc.PPC_OP_ADDIS, 15)
    T.assert_equal(results, "PPC_OP_BC is 16 (conditional branch)", PPCEnc.PPC_OP_BC, 16)
    T.assert_equal(results, "PPC_OP_SC is 17 (system call)", PPCEnc.PPC_OP_SC, 17)
    T.assert_equal(results, "PPC_OP_B is 18 (unconditional branch)", PPCEnc.PPC_OP_B, 18)
    T.assert_equal(results, "PPC_OP_BCLR is 19 (branch to LR/CTR)", PPCEnc.PPC_OP_BCLR, 19)
    T.assert_equal(results, "PPC_OP_RLWIMI is 20", PPCEnc.PPC_OP_RLWIMI, 20)
    T.assert_equal(results, "PPC_OP_RLWINM is 21", PPCEnc.PPC_OP_RLWINM, 21)
    T.assert_equal(results, "PPC_OP_ORI is 24", PPCEnc.PPC_OP_ORI, 24)
    T.assert_equal(results, "PPC_OP_ORIS is 25", PPCEnc.PPC_OP_ORIS, 25)
    T.assert_equal(results, "PPC_OP_XORI is 26", PPCEnc.PPC_OP_XORI, 26)

    Return 1
End Process

Note: ============================================================================
Note: Instruction Format Identification Tests
Note: ============================================================================

Process called "test_format_identification" that takes results as Integer returns Integer:
    T.begin_suite(results, "powerpc instruction_encoder: format identification")

    Note: D-form opcodes (loads, stores, immediate ALU) use opcodes in range 8-55
    Note: Verify typical D-form opcodes
    T.assert_equal(results, "ADDI (14) is D-form range", PPCEnc.PPC_OP_ADDI is greater than or equal to 8, 1)

    Note: B-form: opcode 16
    T.assert_equal(results, "BC (16) is B-form", PPCEnc.PPC_OP_BC, 16)

    Note: I-form: opcode 18
    T.assert_equal(results, "B (18) is I-form", PPCEnc.PPC_OP_B, 18)

    Note: SC: opcode 17
    T.assert_equal(results, "SC (17) is system call", PPCEnc.PPC_OP_SC, 17)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_primary_opcode_constants(results)
    test_format_identification(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
