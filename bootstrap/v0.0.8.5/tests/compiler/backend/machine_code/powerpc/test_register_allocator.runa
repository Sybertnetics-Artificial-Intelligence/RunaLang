Note:
Unit Tests for PowerPC Register Allocator

Validates the 32 GPR + 32 FPR register file, ELF ABI register assignments
(r3-r10 args, r14-r31 callee-saved, r1=SP, r2=TOC, r13=TLS), special-purpose
register pseudo-IDs (LR=64, CTR=65), register status constants, and allocator
state creation/initialization.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/powerpc/register_allocator.runa" as PPCReg
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Register Constant Tests
Note: ============================================================================

Process called "test_register_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "powerpc register_allocator: register constants")

    T.assert_equal(results, "PPC_REG_R0 is 0", PPCReg.PPC_REG_R0, 0)
    T.assert_equal(results, "PPC_REG_SP is 1 (r1)", PPCReg.PPC_REG_SP, 1)
    T.assert_equal(results, "PPC_REG_TOC is 2 (r2)", PPCReg.PPC_REG_TOC, 2)
    T.assert_equal(results, "PPC_REG_R3 is 3 (first arg)", PPCReg.PPC_REG_R3, 3)
    T.assert_equal(results, "PPC_REG_R10 is 10 (last arg)", PPCReg.PPC_REG_R10, 10)
    T.assert_equal(results, "PPC_REG_R11 is 11 (env/scratch)", PPCReg.PPC_REG_R11, 11)
    T.assert_equal(results, "PPC_REG_R12 is 12 (branch target)", PPCReg.PPC_REG_R12, 12)
    T.assert_equal(results, "PPC_REG_R13 is 13 (TLS)", PPCReg.PPC_REG_R13, 13)
    T.assert_equal(results, "PPC_REG_R14 is 14 (first callee-saved)", PPCReg.PPC_REG_R14, 14)
    T.assert_equal(results, "PPC_REG_R31 is 31 (last callee-saved)", PPCReg.PPC_REG_R31, 31)

    Note: Counts
    T.assert_equal(results, "PPC_GPR_COUNT is 32", PPCReg.PPC_GPR_COUNT, 32)
    T.assert_equal(results, "PPC_FPR_COUNT is 32", PPCReg.PPC_FPR_COUNT, 32)

    Note: Special-purpose register pseudo-IDs
    T.assert_equal(results, "PPC_REG_LR is 64", PPCReg.PPC_REG_LR, 64)
    T.assert_equal(results, "PPC_REG_CTR is 65", PPCReg.PPC_REG_CTR, 65)

    Return 1
End Process

Note: ============================================================================
Note: Status Constant Tests
Note: ============================================================================

Process called "test_status_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "powerpc register_allocator: status constants")

    T.assert_equal(results, "REG_STATUS_FREE is 0", PPCReg.PPC_REG_STATUS_FREE, 0)
    T.assert_equal(results, "REG_STATUS_ALLOCATED is 1", PPCReg.PPC_REG_STATUS_ALLOCATED, 1)

    Return 1
End Process

Note: ============================================================================
Note: Allocator State Creation Tests
Note: ============================================================================

Process called "test_create_ppc_reg_alloc_state" that takes results as Integer returns Integer:
    T.begin_suite(results, "powerpc register_allocator: create_ppc_reg_alloc_state")

    Let state be PPCReg.create_ppc_reg_alloc_state()
    T.assert_not_null(results, "create_ppc_reg_alloc_state returns non-null", state)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_register_constants(results)
    test_status_constants(results)
    test_create_ppc_reg_alloc_state(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
