Note:
Unit Tests for PowerPC Assembly Generator

Validates context creation with register allocator state, null guards, and
assembly generation pipeline for the PowerPC ELF ABI backend. PowerPC uses
32 GPRs (r0-r31), 32 FPRs (f0-f31), and special-purpose registers (LR, CTR).
Arguments in r3-r10, callee-saved r14-r31.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/powerpc/asm_generator.runa" as PPCAsm
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/internal/memory_utils.runa" as MemoryUtils

Note: ============================================================================
Note: Context Creation Tests
Note: ============================================================================

Process called "test_create_ppc_asm_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "powerpc asm_generator: create_ppc_asm_context")

    Let arena be MemoryUtils.allocate(65536)
    T.assert_not_null(results, "arena allocation succeeds", arena)

    Let output be MCI.create_assembly_output(arena)
    T.assert_not_null(results, "assembly output created", output)

    Let config be Layout.allocate(64)
    T.assert_not_null(results, "config allocation succeeds", config)

    Let ctx be PPCAsm.create_ppc_asm_context(output, config)
    T.assert_not_null(results, "create_ppc_asm_context returns non-null", ctx)

    Note: Verify output stored (offset 0)
    Let stored_output be __load(ctx, 0)
    T.assert_equal(results, "output stored correctly", stored_output, output)

    Note: Verify config stored (offset 8)
    Let stored_config be __load(ctx, 8)
    T.assert_equal(results, "config stored correctly", stored_config, config)

    Note: Verify current_function starts at 0 (offset 16)
    Let current_func be __load(ctx, 16)
    T.assert_equal(results, "current_function starts at 0", current_func, 0)

    Note: Verify reg_state allocated (offset 24)
    Let reg_state be __load(ctx, 24)
    T.assert_not_null(results, "reg_state allocated", reg_state)

    Note: Verify frame_size starts at 0 (offset 32)
    Let frame_size be __load(ctx, 32)
    T.assert_equal(results, "frame_size starts at 0", frame_size, 0)

    Note: Verify has_calls starts at 0 (offset 40)
    Let has_calls be __load(ctx, 40)
    T.assert_equal(results, "has_calls starts at 0", has_calls, 0)

    Note: Verify error_count starts at 0 (offset 48)
    Let error_count be __load(ctx, 48)
    T.assert_equal(results, "error_count starts at 0", error_count, 0)

    Note: Verify label_counter starts at 0 (offset 56)
    Let label_counter be __load(ctx, 56)
    T.assert_equal(results, "label_counter starts at 0", label_counter, 0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "powerpc asm_generator: null guards")

    Note: Null output may cause internal allocator failure
    Let ctx_null be PPCAsm.create_ppc_asm_context(0, 0)
    Note: May return 0 if internal register state allocation requires non-null deps
    If ctx_null is 0:
        T.assert_equal(results, "create_ppc_asm_context(0,0) returns 0 (expected)", ctx_null, 0)
    Otherwise:
        T.assert_not_null(results, "create_ppc_asm_context(0,0) returns non-null", ctx_null)
    End If

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_create_ppc_asm_context(results)
    test_null_guards(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
