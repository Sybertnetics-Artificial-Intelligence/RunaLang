Note:
Unit tests for x86_64 instruction encoder module.

Validates register encoding mapping, REX prefix computation, ModR/M encoding,
SIB encoding, condition code constants, and opcode constant values.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/x86_64/instruction_encoder.runa" as Enc

Note: ============================================================================
Note: LIR-to-x86 Register Encoding Tests
Note: ============================================================================

Process called "test_register_encoding" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 LIR-to-x86 Register Encoding")

    Note: RAX (LIR 0) -> x86 encoding 0
    T.assert_equal(results, "RAX (LIR 0) encodes to 0", Enc.lir_reg_to_x86_encoding(0), 0)

    Note: RBX (LIR 1) -> x86 encoding 3
    T.assert_equal(results, "RBX (LIR 1) encodes to 3", Enc.lir_reg_to_x86_encoding(1), 3)

    Note: RCX (LIR 2) -> x86 encoding 1
    T.assert_equal(results, "RCX (LIR 2) encodes to 1", Enc.lir_reg_to_x86_encoding(2), 1)

    Note: RDX (LIR 3) -> x86 encoding 2
    T.assert_equal(results, "RDX (LIR 3) encodes to 2", Enc.lir_reg_to_x86_encoding(3), 2)

    Note: RSI (LIR 4) -> x86 encoding 6
    T.assert_equal(results, "RSI (LIR 4) encodes to 6", Enc.lir_reg_to_x86_encoding(4), 6)

    Note: RDI (LIR 5) -> x86 encoding 7
    T.assert_equal(results, "RDI (LIR 5) encodes to 7", Enc.lir_reg_to_x86_encoding(5), 7)

    Note: RBP (LIR 6) -> x86 encoding 5
    T.assert_equal(results, "RBP (LIR 6) encodes to 5", Enc.lir_reg_to_x86_encoding(6), 5)

    Note: RSP (LIR 7) -> x86 encoding 4
    T.assert_equal(results, "RSP (LIR 7) encodes to 4", Enc.lir_reg_to_x86_encoding(7), 4)

    Note: R8 (LIR 8) -> x86 encoding 0 (with REX extension)
    T.assert_equal(results, "R8 (LIR 8) encodes to 0", Enc.lir_reg_to_x86_encoding(8), 0)

    Note: R15 (LIR 15) -> x86 encoding 7 (with REX extension)
    T.assert_equal(results, "R15 (LIR 15) encodes to 7", Enc.lir_reg_to_x86_encoding(15), 7)

    Return 1
End Process

Note: ============================================================================
Note: REX Extension Detection Tests
Note: ============================================================================

Process called "test_needs_rex" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 REX Extension Detection")

    Note: Registers 0-7 do not need REX extension bit
    T.assert_equal(results, "RAX (0) does not need REX", Enc.needs_rex_for_register(0), 0)
    T.assert_equal(results, "RDI (5) does not need REX", Enc.needs_rex_for_register(5), 0)
    T.assert_equal(results, "RSP (7) does not need REX", Enc.needs_rex_for_register(7), 0)

    Note: Registers 8-15 need REX extension bit
    T.assert_equal(results, "R8 (8) needs REX", Enc.needs_rex_for_register(8), 1)
    T.assert_equal(results, "R12 (12) needs REX", Enc.needs_rex_for_register(12), 1)
    T.assert_equal(results, "R15 (15) needs REX", Enc.needs_rex_for_register(15), 1)

    Note: Out-of-range register does not need REX
    T.assert_equal(results, "reg 16 does not need REX", Enc.needs_rex_for_register(16), 0)

    Return 1
End Process

Note: ============================================================================
Note: REX Prefix Computation Tests
Note: ============================================================================

Process called "test_rex_prefix" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 REX Prefix Computation")

    Note: All-zero inputs: no REX prefix needed -> returns 0
    T.assert_equal(results, "no REX when all zero", Enc.compute_rex_prefix(0, 0, 0, 0), 0)

    Note: REX.W only (64-bit operand size): 0x40 | 0x08 = 0x48 = 72
    T.assert_equal(results, "REX.W only is 0x48 (72)", Enc.compute_rex_prefix(1, 0, 0, 0), 72)

    Note: REX.B only (base is R8=8): 0x40 | 0x01 = 0x41 = 65
    T.assert_equal(results, "REX.B only (base R8) is 0x41 (65)", Enc.compute_rex_prefix(0, 0, 0, 8), 65)

    Note: REX.R only (reg is R9=9): 0x40 | 0x04 = 0x44 = 68
    T.assert_equal(results, "REX.R only (reg R9) is 0x44 (68)", Enc.compute_rex_prefix(0, 9, 0, 0), 68)

    Note: REX.W + REX.R + REX.B: 0x40 | 0x08 | 0x04 | 0x01 = 0x4D = 77
    T.assert_equal(results, "REX.WRB is 0x4D (77)", Enc.compute_rex_prefix(1, 10, 0, 12), 77)

    Note: No REX needed for two low registers with no W
    T.assert_equal(results, "RAX,RAX no REX needed", Enc.compute_rex_prefix(0, 0, 0, 0), 0)

    Return 1
End Process

Note: ============================================================================
Note: ModR/M Encoding Tests
Note: ============================================================================

Process called "test_modrm_encoding" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 ModR/M Encoding")

    Note: mod=3, reg=0, rm=0 -> 11|000|000 = 0xC0 = 192
    T.assert_equal(results, "ModRM(3,0,0) is 0xC0 (192)", Enc.encode_modrm(3, 0, 0), 192)

    Note: mod=3, reg=1, rm=3 -> 11|001|011 = 0xCB = 203
    T.assert_equal(results, "ModRM(3,1,3) is 0xCB (203)", Enc.encode_modrm(3, 1, 3), 203)

    Note: mod=0, reg=0, rm=5 -> 00|000|101 = 0x05 = 5 (RIP-relative on x86_64)
    T.assert_equal(results, "ModRM(0,0,5) is 0x05 (5)", Enc.encode_modrm(0, 0, 5), 5)

    Note: mod=1, reg=7, rm=4 -> 01|111|100 = 0x7C = 124 (SIB follows)
    T.assert_equal(results, "ModRM(1,7,4) is 0x7C (124)", Enc.encode_modrm(1, 7, 4), 124)

    Return 1
End Process

Note: ============================================================================
Note: SIB Encoding Tests
Note: ============================================================================

Process called "test_sib_encoding" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 SIB Encoding")

    Note: scale=1(0b00), index=4(no index), base=4(RSP) -> 00|100|100 = 0x24 = 36
    T.assert_equal(results, "SIB(1,4,4) is 0x24 (36)", Enc.encode_sib(1, 4, 4), 36)

    Note: scale=8(0b11), index=0(RAX), base=3(RBX) -> 11|000|011 = 0xC3 = 195
    T.assert_equal(results, "SIB(8,0,3) is 0xC3 (195)", Enc.encode_sib(8, 0, 3), 195)

    Note: scale=4(0b10), index=1(RCX), base=0(RAX) -> 10|001|000 = 0x88 = 136
    T.assert_equal(results, "SIB(4,1,0) is 0x88 (136)", Enc.encode_sib(4, 1, 0), 136)

    Return 1
End Process

Note: ============================================================================
Note: Displacement Fit Tests
Note: ============================================================================

Process called "test_displacement_fits" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Displacement Size Tests")

    T.assert_equal(results, "0 fits in 8 bits", Enc.displacement_fits_in_8_bits(0), 1)
    T.assert_equal(results, "127 fits in 8 bits", Enc.displacement_fits_in_8_bits(127), 1)
    T.assert_equal(results, "-128 fits in 8 bits", Enc.displacement_fits_in_8_bits(-128), 1)
    T.assert_equal(results, "128 does not fit in 8 bits", Enc.displacement_fits_in_8_bits(128), 0)
    T.assert_equal(results, "-129 does not fit in 8 bits", Enc.displacement_fits_in_8_bits(-129), 0)

    Return 1
End Process

Note: ============================================================================
Note: Opcode Constant Tests
Note: ============================================================================

Process called "test_opcode_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Opcode Constants")

    Note: ALU opcodes
    T.assert_equal(results, "X86_OP_ADD_RM is 0x01 (1)", Enc.X86_OP_ADD_RM, 1)
    T.assert_equal(results, "X86_OP_SUB_RM is 0x29 (41)", Enc.X86_OP_SUB_RM, 41)
    T.assert_equal(results, "X86_OP_XOR_RM is 0x31 (49)", Enc.X86_OP_XOR_RM, 49)
    T.assert_equal(results, "X86_OP_CMP_RM is 0x39 (57)", Enc.X86_OP_CMP_RM, 57)

    Note: MOV opcodes
    T.assert_equal(results, "X86_OP_MOV_RM is 0x89 (137)", Enc.X86_OP_MOV_RM, 137)
    T.assert_equal(results, "X86_OP_MOV_MR is 0x8B (139)", Enc.X86_OP_MOV_MR, 139)

    Note: Control flow opcodes
    T.assert_equal(results, "X86_OP_RET is 0xC3 (195)", Enc.X86_OP_RET, 195)
    T.assert_equal(results, "X86_OP_CALL_REL32 is 0xE8 (232)", Enc.X86_OP_CALL_REL32, 232)
    T.assert_equal(results, "X86_OP_JMP_REL32 is 0xE9 (233)", Enc.X86_OP_JMP_REL32, 233)
    T.assert_equal(results, "X86_OP_NOP is 0x90 (144)", Enc.X86_OP_NOP, 144)

    Note: Stack opcodes
    T.assert_equal(results, "X86_OP_PUSH_REG_BASE is 0x50 (80)", Enc.X86_OP_PUSH_REG_BASE, 80)
    T.assert_equal(results, "X86_OP_POP_REG_BASE is 0x58 (88)", Enc.X86_OP_POP_REG_BASE, 88)

    Return 1
End Process

Note: ============================================================================
Note: Condition Code Constant Tests
Note: ============================================================================

Process called "test_condition_codes" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Condition Code Constants")

    T.assert_equal(results, "X86_CC_E is 4", Enc.X86_CC_E, 4)
    T.assert_equal(results, "X86_CC_NE is 5", Enc.X86_CC_NE, 5)
    T.assert_equal(results, "X86_CC_L is 12", Enc.X86_CC_L, 12)
    T.assert_equal(results, "X86_CC_GE is 13", Enc.X86_CC_GE, 13)
    T.assert_equal(results, "X86_CC_LE is 14", Enc.X86_CC_LE, 14)
    T.assert_equal(results, "X86_CC_G is 15", Enc.X86_CC_G, 15)
    T.assert_equal(results, "X86_CC_B is 2", Enc.X86_CC_B, 2)
    T.assert_equal(results, "X86_CC_A is 7", Enc.X86_CC_A, 7)

    Return 1
End Process

Note: ============================================================================
Note: LIR Condition to x86 CC Mapping Tests
Note: ============================================================================

Process called "test_lir_cond_mapping" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 LIR Condition to x86 CC Mapping")

    Note: LIR EQ (0) -> x86 E (4)
    T.assert_equal(results, "LIR EQ(0) maps to x86 E(4)", Enc.lir_cond_to_x86_cc(0), 4)

    Note: LIR NE (1) -> x86 NE (5)
    T.assert_equal(results, "LIR NE(1) maps to x86 NE(5)", Enc.lir_cond_to_x86_cc(1), 5)

    Note: LIR LT (2) -> x86 L (12)
    T.assert_equal(results, "LIR LT(2) maps to x86 L(12)", Enc.lir_cond_to_x86_cc(2), 12)

    Note: LIR LE (3) -> x86 LE (14)
    T.assert_equal(results, "LIR LE(3) maps to x86 LE(14)", Enc.lir_cond_to_x86_cc(3), 14)

    Note: LIR GT (4) -> x86 G (15)
    T.assert_equal(results, "LIR GT(4) maps to x86 G(15)", Enc.lir_cond_to_x86_cc(4), 15)

    Note: LIR GE (5) -> x86 GE (13)
    T.assert_equal(results, "LIR GE(5) maps to x86 GE(13)", Enc.lir_cond_to_x86_cc(5), 13)

    Note: LIR ULT (6) -> x86 B (2)
    T.assert_equal(results, "LIR ULT(6) maps to x86 B(2)", Enc.lir_cond_to_x86_cc(6), 2)

    Note: LIR UGT (8) -> x86 A (7)
    T.assert_equal(results, "LIR UGT(8) maps to x86 A(7)", Enc.lir_cond_to_x86_cc(8), 7)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_register_encoding(results)
    test_needs_rex(results)
    test_rex_prefix(results)
    test_modrm_encoding(results)
    test_sib_encoding(results)
    test_displacement_fits(results)
    test_opcode_constants(results)
    test_condition_codes(results)
    test_lir_cond_mapping(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process

Process called "main" returns Integer:
    Return run_all_tests()
End Process
