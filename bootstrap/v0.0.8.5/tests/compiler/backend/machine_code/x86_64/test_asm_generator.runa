Note:
Unit tests for x86_64 assembly generator module.

Validates GPR name lookups at 64/32/16/8-bit widths, XMM register names,
size suffix generation, and register name selection by operand size.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/x86_64/asm_generator.runa" as AsmGen

Note: ============================================================================
Note: 64-bit GPR Name Tests
Note: ============================================================================

Process called "test_gpr_name_64" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 GPR 64-bit Names")

    T.assert_string_equal(results, "reg 0 is %rax", AsmGen.get_gpr_name_64(0), "%rax")
    T.assert_string_equal(results, "reg 1 is %rbx", AsmGen.get_gpr_name_64(1), "%rbx")
    T.assert_string_equal(results, "reg 2 is %rcx", AsmGen.get_gpr_name_64(2), "%rcx")
    T.assert_string_equal(results, "reg 3 is %rdx", AsmGen.get_gpr_name_64(3), "%rdx")
    T.assert_string_equal(results, "reg 4 is %rsi", AsmGen.get_gpr_name_64(4), "%rsi")
    T.assert_string_equal(results, "reg 5 is %rdi", AsmGen.get_gpr_name_64(5), "%rdi")
    T.assert_string_equal(results, "reg 6 is %rbp", AsmGen.get_gpr_name_64(6), "%rbp")
    T.assert_string_equal(results, "reg 7 is %rsp", AsmGen.get_gpr_name_64(7), "%rsp")
    T.assert_string_equal(results, "reg 8 is %r8", AsmGen.get_gpr_name_64(8), "%r8")
    T.assert_string_equal(results, "reg 9 is %r9", AsmGen.get_gpr_name_64(9), "%r9")
    T.assert_string_equal(results, "reg 10 is %r10", AsmGen.get_gpr_name_64(10), "%r10")
    T.assert_string_equal(results, "reg 11 is %r11", AsmGen.get_gpr_name_64(11), "%r11")
    T.assert_string_equal(results, "reg 12 is %r12", AsmGen.get_gpr_name_64(12), "%r12")
    T.assert_string_equal(results, "reg 13 is %r13", AsmGen.get_gpr_name_64(13), "%r13")
    T.assert_string_equal(results, "reg 14 is %r14", AsmGen.get_gpr_name_64(14), "%r14")
    T.assert_string_equal(results, "reg 15 is %r15", AsmGen.get_gpr_name_64(15), "%r15")

    Note: Out-of-range register should fall back to %rax
    T.assert_string_equal(results, "reg 99 defaults to %rax", AsmGen.get_gpr_name_64(99), "%rax")

    Return 1
End Process

Note: ============================================================================
Note: 32-bit GPR Name Tests
Note: ============================================================================

Process called "test_gpr_name_32" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 GPR 32-bit Names")

    T.assert_string_equal(results, "reg 0 32-bit is %eax", AsmGen.get_gpr_name_32(0), "%eax")
    T.assert_string_equal(results, "reg 2 32-bit is %ecx", AsmGen.get_gpr_name_32(2), "%ecx")
    T.assert_string_equal(results, "reg 8 32-bit is %r8d", AsmGen.get_gpr_name_32(8), "%r8d")
    T.assert_string_equal(results, "reg 15 32-bit is %r15d", AsmGen.get_gpr_name_32(15), "%r15d")

    Return 1
End Process

Note: ============================================================================
Note: 16-bit and 8-bit GPR Name Tests
Note: ============================================================================

Process called "test_gpr_name_small" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 GPR 16-bit and 8-bit Names")

    T.assert_string_equal(results, "reg 0 16-bit is %ax", AsmGen.get_gpr_name_16(0), "%ax")
    T.assert_string_equal(results, "reg 2 16-bit is %cx", AsmGen.get_gpr_name_16(2), "%cx")
    T.assert_string_equal(results, "reg 8 16-bit is %r8w", AsmGen.get_gpr_name_16(8), "%r8w")

    T.assert_string_equal(results, "reg 0 8-bit is %al", AsmGen.get_gpr_name_8(0), "%al")
    T.assert_string_equal(results, "reg 2 8-bit is %cl", AsmGen.get_gpr_name_8(2), "%cl")
    T.assert_string_equal(results, "reg 4 8-bit is %sil", AsmGen.get_gpr_name_8(4), "%sil")
    T.assert_string_equal(results, "reg 8 8-bit is %r8b", AsmGen.get_gpr_name_8(8), "%r8b")

    Return 1
End Process

Note: ============================================================================
Note: XMM Register Name Tests
Note: ============================================================================

Process called "test_xmm_names" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 XMM Register Names")

    T.assert_string_equal(results, "reg 16 is %xmm0", AsmGen.get_xmm_name(16), "%xmm0")
    T.assert_string_equal(results, "reg 17 is %xmm1", AsmGen.get_xmm_name(17), "%xmm1")
    T.assert_string_equal(results, "reg 23 is %xmm7", AsmGen.get_xmm_name(23), "%xmm7")
    T.assert_string_equal(results, "reg 31 is %xmm15", AsmGen.get_xmm_name(31), "%xmm15")

    Return 1
End Process

Note: ============================================================================
Note: Size Suffix Tests
Note: ============================================================================

Process called "test_size_suffix" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Size Suffixes")

    T.assert_string_equal(results, "size 8 suffix is q", AsmGen.get_size_suffix(8), "q")
    T.assert_string_equal(results, "size 4 suffix is l", AsmGen.get_size_suffix(4), "l")
    T.assert_string_equal(results, "size 2 suffix is w", AsmGen.get_size_suffix(2), "w")
    T.assert_string_equal(results, "size 1 suffix is b", AsmGen.get_size_suffix(1), "b")

    Return 1
End Process

Note: ============================================================================
Note: Register Name Selection by Size Tests
Note: ============================================================================

Process called "test_register_name_by_size" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Register Name by Size")

    Note: GPR at different sizes
    T.assert_string_equal(results, "RAX 64-bit", AsmGen.get_register_name(0, 8), "%rax")
    T.assert_string_equal(results, "RAX 32-bit", AsmGen.get_register_name(0, 4), "%eax")
    T.assert_string_equal(results, "RAX 16-bit", AsmGen.get_register_name(0, 2), "%ax")
    T.assert_string_equal(results, "RAX 8-bit", AsmGen.get_register_name(0, 1), "%al")

    Note: XMM registers ignore size and return XMM name
    T.assert_string_equal(results, "XMM0 from reg 16", AsmGen.get_register_name(16, 8), "%xmm0")

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_gpr_name_64(results)
    test_gpr_name_32(results)
    test_gpr_name_small(results)
    test_xmm_names(results)
    test_size_suffix(results)
    test_register_name_by_size(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process
