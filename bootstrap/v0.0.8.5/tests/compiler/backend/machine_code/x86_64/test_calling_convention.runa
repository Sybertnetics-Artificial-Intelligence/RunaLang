Note:
Unit tests for x86_64 calling convention module.

Validates System V AMD64 ABI and Win64 ABI convention creation, argument
classification, register lists, stack alignment, and null-guard behavior.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/x86_64/calling_convention.runa" as CC
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: System V Convention Creation Tests
Note: ============================================================================

Process called "test_systemv_creation" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 System V Convention Creation")

    Let conv be CC.create_systemv_convention()
    T.assert_not_null(results, "create_systemv_convention returns non-null", conv)

    Note: convention_id should be CALLING_CONV_SYSTEMV (0)
    Let conv_id be __load(conv, 0)
    T.assert_equal(results, "convention_id is CALLING_CONV_SYSTEMV (0)", conv_id, 0)

    Note: int_arg_count should be 6
    Let int_arg_count be __load(conv, 24)
    T.assert_equal(results, "integer argument register count is 6", int_arg_count, 6)

    Note: float_arg_count should be 8
    Let float_arg_count be __load(conv, 32)
    T.assert_equal(results, "float argument register count is 8", float_arg_count, 8)

    Note: return_register should be RAX (0)
    Let return_reg be __load(conv, 40)
    T.assert_equal(results, "integer return register is RAX (0)", return_reg, 0)

    Note: float_return_register should be XMM0 (16)
    Let float_ret be __load(conv, 48)
    T.assert_equal(results, "float return register is XMM0 (16)", float_ret, 16)

    Note: stack_alignment should be 16
    Let stack_align be __load(conv, 72)
    T.assert_equal(results, "stack alignment is 16 bytes", stack_align, 16)

    Note: red_zone_size should be 128
    Let red_zone be __load(conv, 80)
    T.assert_equal(results, "red zone size is 128 bytes", red_zone, 128)

    Note: shadow_space_size should be 0
    Let shadow be __load(conv, 88)
    T.assert_equal(results, "shadow space is 0 for System V", shadow, 0)

    Return 1
End Process

Note: ============================================================================
Note: System V Integer Argument Register Order Tests
Note: ============================================================================

Process called "test_systemv_int_arg_registers" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 System V Integer Arg Registers")

    Let conv be CC.create_systemv_convention()
    T.assert_not_null(results, "convention allocated", conv)

    Let int_regs be __load(conv, 8)
    T.assert_not_null(results, "int_arg_registers list non-null", int_regs)

    Let len be List.list_length(int_regs)
    T.assert_equal(results, "int_arg_registers list has 6 entries", len, 6)

    Note: System V order: RDI(5), RSI(4), RDX(3), RCX(2), R8(8), R9(9)
    Let reg0 be List.list_get(int_regs, 0)
    T.assert_equal(results, "arg0 register is RDI (5)", reg0, 5)

    Let reg1 be List.list_get(int_regs, 1)
    T.assert_equal(results, "arg1 register is RSI (4)", reg1, 4)

    Let reg2 be List.list_get(int_regs, 2)
    T.assert_equal(results, "arg2 register is RDX (3)", reg2, 3)

    Let reg3 be List.list_get(int_regs, 3)
    T.assert_equal(results, "arg3 register is RCX (2)", reg3, 2)

    Let reg4 be List.list_get(int_regs, 4)
    T.assert_equal(results, "arg4 register is R8 (8)", reg4, 8)

    Let reg5 be List.list_get(int_regs, 5)
    T.assert_equal(results, "arg5 register is R9 (9)", reg5, 9)

    Return 1
End Process

Note: ============================================================================
Note: System V Callee-Saved Register Tests
Note: ============================================================================

Process called "test_systemv_callee_saved" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 System V Callee-Saved Registers")

    Let conv be CC.create_systemv_convention()
    T.assert_not_null(results, "convention allocated", conv)

    Let callee_saved be __load(conv, 56)
    T.assert_not_null(results, "callee_saved list non-null", callee_saved)

    Let len be List.list_length(callee_saved)
    T.assert_equal(results, "callee_saved list has 6 entries", len, 6)

    Note: Callee-saved: RBX(1), RBP(6), R12(12), R13(13), R14(14), R15(15)
    Let r0 be List.list_get(callee_saved, 0)
    T.assert_equal(results, "callee-saved[0] is RBX (1)", r0, 1)

    Let r1 be List.list_get(callee_saved, 1)
    T.assert_equal(results, "callee-saved[1] is RBP (6)", r1, 6)

    Let r2 be List.list_get(callee_saved, 2)
    T.assert_equal(results, "callee-saved[2] is R12 (12)", r2, 12)

    Let r3 be List.list_get(callee_saved, 3)
    T.assert_equal(results, "callee-saved[3] is R13 (13)", r3, 13)

    Let r4 be List.list_get(callee_saved, 4)
    T.assert_equal(results, "callee-saved[4] is R14 (14)", r4, 14)

    Let r5 be List.list_get(callee_saved, 5)
    T.assert_equal(results, "callee-saved[5] is R15 (15)", r5, 15)

    Return 1
End Process

Note: ============================================================================
Note: Win64 Convention Tests
Note: ============================================================================

Process called "test_win64_convention" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Win64 Convention")

    Let conv be CC.create_win64_convention()
    T.assert_not_null(results, "create_win64_convention returns non-null", conv)

    Let conv_id be __load(conv, 0)
    T.assert_equal(results, "convention_id is CALLING_CONV_WIN64 (1)", conv_id, 1)

    Let int_arg_count be __load(conv, 24)
    T.assert_equal(results, "Win64 has 4 integer arg registers", int_arg_count, 4)

    Let float_arg_count be __load(conv, 32)
    T.assert_equal(results, "Win64 has 4 float arg registers", float_arg_count, 4)

    Let red_zone be __load(conv, 80)
    T.assert_equal(results, "Win64 has no red zone (0)", red_zone, 0)

    Let shadow be __load(conv, 88)
    T.assert_equal(results, "Win64 has 32-byte shadow space", shadow, 32)

    Note: Win64 int arg order: RCX(2), RDX(3), R8(8), R9(9)
    Let int_regs be __load(conv, 8)
    Let r0 be List.list_get(int_regs, 0)
    T.assert_equal(results, "Win64 arg0 is RCX (2)", r0, 2)

    Let r1 be List.list_get(int_regs, 1)
    T.assert_equal(results, "Win64 arg1 is RDX (3)", r1, 3)

    Let r2 be List.list_get(int_regs, 2)
    T.assert_equal(results, "Win64 arg2 is R8 (8)", r2, 8)

    Let r3 be List.list_get(int_regs, 3)
    T.assert_equal(results, "Win64 arg3 is R9 (9)", r3, 9)

    Return 1
End Process

Note: ============================================================================
Note: Argument Classification Tests
Note: ============================================================================

Process called "test_argument_classification" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Argument Classification")

    Note: Null arg_type should return NO_CLASS (3)
    Let null_class be CC.classify_argument(0, 0)
    T.assert_equal(results, "null arg_type returns ARG_CLASS_NO_CLASS (3)", null_class, 3)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_systemv_creation(results)
    test_systemv_int_arg_registers(results)
    test_systemv_callee_saved(results)
    test_win64_convention(results)
    test_argument_classification(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process
