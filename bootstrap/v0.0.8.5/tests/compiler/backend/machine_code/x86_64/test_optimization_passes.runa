Note:
Unit tests for x86_64 peephole optimization passes module.

Validates LIR opcode constants, power-of-two detection, log2 computation,
stats creation, instruction classification helpers, and null-guard behavior.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/x86_64/optimization_passes.runa" as OptPasses

Note: ============================================================================
Note: LIR Opcode Constant Tests
Note: ============================================================================

Process called "test_lir_opcode_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Optimization LIR Opcode Constants")

    T.assert_equal(results, "LIR_NOP is 30000", OptPasses.LIR_NOP, 30000)
    T.assert_equal(results, "LIR_MOV is 30001", OptPasses.LIR_MOV, 30001)
    T.assert_equal(results, "LIR_ADD is 30100", OptPasses.LIR_ADD, 30100)
    T.assert_equal(results, "LIR_SUB is 30101", OptPasses.LIR_SUB, 30101)
    T.assert_equal(results, "LIR_IMUL is 30102", OptPasses.LIR_IMUL, 30102)
    T.assert_equal(results, "LIR_NEG is 30106", OptPasses.LIR_NEG, 30106)
    T.assert_equal(results, "LIR_INC is 30107", OptPasses.LIR_INC, 30107)
    T.assert_equal(results, "LIR_DEC is 30108", OptPasses.LIR_DEC, 30108)
    T.assert_equal(results, "LIR_XOR is 30202", OptPasses.LIR_XOR, 30202)
    T.assert_equal(results, "LIR_SHL is 30300", OptPasses.LIR_SHL, 30300)
    T.assert_equal(results, "LIR_JMP is 30500", OptPasses.LIR_JMP, 30500)

    Return 1
End Process

Note: ============================================================================
Note: Operand Type Constant Tests
Note: ============================================================================

Process called "test_operand_type_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Optimization Operand Type Constants")

    T.assert_equal(results, "OPERAND_REGISTER is 1", OptPasses.OPERAND_REGISTER, 1)
    T.assert_equal(results, "OPERAND_IMMEDIATE is 2", OptPasses.OPERAND_IMMEDIATE, 2)
    T.assert_equal(results, "OPERAND_MEMORY is 3", OptPasses.OPERAND_MEMORY, 3)

    Return 1
End Process

Note: ============================================================================
Note: Power-of-Two Detection Tests
Note: ============================================================================

Process called "test_is_power_of_two" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 is_power_of_two")

    T.assert_equal(results, "1 is power of two", OptPasses.is_power_of_two(1), 1)
    T.assert_equal(results, "2 is power of two", OptPasses.is_power_of_two(2), 1)
    T.assert_equal(results, "4 is power of two", OptPasses.is_power_of_two(4), 1)
    T.assert_equal(results, "8 is power of two", OptPasses.is_power_of_two(8), 1)
    T.assert_equal(results, "16 is power of two", OptPasses.is_power_of_two(16), 1)
    T.assert_equal(results, "64 is power of two", OptPasses.is_power_of_two(64), 1)
    T.assert_equal(results, "256 is power of two", OptPasses.is_power_of_two(256), 1)
    T.assert_equal(results, "1024 is power of two", OptPasses.is_power_of_two(1024), 1)

    T.assert_equal(results, "0 is not power of two", OptPasses.is_power_of_two(0), 0)
    T.assert_equal(results, "-1 is not power of two", OptPasses.is_power_of_two(-1), 0)
    T.assert_equal(results, "3 is not power of two", OptPasses.is_power_of_two(3), 0)
    T.assert_equal(results, "5 is not power of two", OptPasses.is_power_of_two(5), 0)
    T.assert_equal(results, "6 is not power of two", OptPasses.is_power_of_two(6), 0)
    T.assert_equal(results, "7 is not power of two", OptPasses.is_power_of_two(7), 0)
    T.assert_equal(results, "10 is not power of two", OptPasses.is_power_of_two(10), 0)
    T.assert_equal(results, "12 is not power of two", OptPasses.is_power_of_two(12), 0)

    Return 1
End Process

Note: ============================================================================
Note: Log2 Computation Tests
Note: ============================================================================

Process called "test_log2_of_power" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 log2_of_power")

    T.assert_equal(results, "log2(1) is 0", OptPasses.log2_of_power(1), 0)
    T.assert_equal(results, "log2(2) is 1", OptPasses.log2_of_power(2), 1)
    T.assert_equal(results, "log2(4) is 2", OptPasses.log2_of_power(4), 2)
    T.assert_equal(results, "log2(8) is 3", OptPasses.log2_of_power(8), 3)
    T.assert_equal(results, "log2(16) is 4", OptPasses.log2_of_power(16), 4)
    T.assert_equal(results, "log2(32) is 5", OptPasses.log2_of_power(32), 5)
    T.assert_equal(results, "log2(64) is 6", OptPasses.log2_of_power(64), 6)
    T.assert_equal(results, "log2(128) is 7", OptPasses.log2_of_power(128), 7)
    T.assert_equal(results, "log2(256) is 8", OptPasses.log2_of_power(256), 8)
    T.assert_equal(results, "log2(1024) is 10", OptPasses.log2_of_power(1024), 10)

    Note: Edge case: non-positive returns 0
    T.assert_equal(results, "log2(0) returns 0", OptPasses.log2_of_power(0), 0)
    T.assert_equal(results, "log2(-1) returns 0", OptPasses.log2_of_power(-1), 0)

    Return 1
End Process

Note: ============================================================================
Note: Stats Creation Tests
Note: ============================================================================

Process called "test_create_stats" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 OptimizationStats Creation")

    Let stats be OptPasses.create_stats()
    T.assert_not_null(results, "create_stats returns non-null", stats)

    Note: All counters should initialize to zero
    Let redundant be __load(stats, 0)
    T.assert_equal(results, "redundant_moves_eliminated starts at 0", redundant, 0)

    Let strength be __load(stats, 8)
    T.assert_equal(results, "strength_reductions starts at 0", strength, 0)

    Let zeroing be __load(stats, 16)
    T.assert_equal(results, "zeroing_optimizations starts at 0", zeroing, 0)

    Let total be __load(stats, 64)
    T.assert_equal(results, "total_optimizations starts at 0", total, 0)

    Let passes be __load(stats, 72)
    T.assert_equal(results, "passes_run starts at 0", passes, 0)

    Return 1
End Process

Note: ============================================================================
Note: Instruction Classification Tests
Note: ============================================================================

Process called "test_instruction_writes_register" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 instruction_writes_register")

    Note: Arithmetic and data movement instructions write a register
    T.assert_equal(results, "MOV writes register", OptPasses.instruction_writes_register(30001), 1)
    T.assert_equal(results, "ADD writes register", OptPasses.instruction_writes_register(30100), 1)
    T.assert_equal(results, "SUB writes register", OptPasses.instruction_writes_register(30101), 1)
    T.assert_equal(results, "IMUL writes register", OptPasses.instruction_writes_register(30102), 1)
    T.assert_equal(results, "XOR writes register", OptPasses.instruction_writes_register(30202), 1)
    T.assert_equal(results, "SHL writes register", OptPasses.instruction_writes_register(30300), 1)

    Note: Control flow instructions do not write a register
    T.assert_equal(results, "JMP does not write register", OptPasses.instruction_writes_register(30500), 0)
    T.assert_equal(results, "NOP does not write register", OptPasses.instruction_writes_register(30000), 0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Optimization Null Guards")

    Note: instruction_reads_register with null instruction should return 0
    T.assert_equal(results, "reads_register(null,0) returns 0", OptPasses.instruction_reads_register(0, 0), 0)

    Return 1
End Process

Note: ============================================================================
Note: Memory Layout Offset Constant Tests
Note: ============================================================================

Process called "test_memory_layout_offsets" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Memory Layout Offset Constants")

    T.assert_equal(results, "INSTR_OPCODE is 0", OptPasses.INSTR_OPCODE, 0)
    T.assert_equal(results, "INSTR_RESULT is 8", OptPasses.INSTR_RESULT, 8)
    T.assert_equal(results, "INSTR_OP1 is 16", OptPasses.INSTR_OP1, 16)
    T.assert_equal(results, "INSTR_OP2 is 24", OptPasses.INSTR_OP2, 24)
    T.assert_equal(results, "OP_TYPE is 0", OptPasses.OP_TYPE, 0)
    T.assert_equal(results, "OP_REG_ID is 8", OptPasses.OP_REG_ID, 8)
    T.assert_equal(results, "OP_IMM_VALUE is 16", OptPasses.OP_IMM_VALUE, 16)
    T.assert_equal(results, "OP_SIZE is 56", OptPasses.OP_SIZE, 56)
    T.assert_equal(results, "STATS_SIZE is 80", OptPasses.STATS_SIZE, 80)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_lir_opcode_constants(results)
    test_operand_type_constants(results)
    test_is_power_of_two(results)
    test_log2_of_power(results)
    test_create_stats(results)
    test_instruction_writes_register(results)
    test_null_guards(results)
    test_memory_layout_offsets(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process
