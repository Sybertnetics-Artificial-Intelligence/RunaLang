Note:
Unit tests for x86_64 register allocator constraint resolution module.

Validates register constants, constraint type constants, constraint collection
on null functions, and IDIV/shift constraint detection constants.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/x86_64/register_allocator.runa" as RegAlloc

Note: ============================================================================
Note: Register Constant Tests
Note: ============================================================================

Process called "test_register_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Register Constants")

    Note: 16 GPRs: RAX=0 through R15=15, XMM0=16
    T.assert_equal(results, "REG_RAX is 0", RegAlloc.REG_RAX, 0)
    T.assert_equal(results, "REG_RBX is 1", RegAlloc.REG_RBX, 1)
    T.assert_equal(results, "REG_RCX is 2", RegAlloc.REG_RCX, 2)
    T.assert_equal(results, "REG_RDX is 3", RegAlloc.REG_RDX, 3)
    T.assert_equal(results, "REG_RSI is 4", RegAlloc.REG_RSI, 4)
    T.assert_equal(results, "REG_RDI is 5", RegAlloc.REG_RDI, 5)
    T.assert_equal(results, "REG_RBP is 6", RegAlloc.REG_RBP, 6)
    T.assert_equal(results, "REG_RSP is 7", RegAlloc.REG_RSP, 7)
    T.assert_equal(results, "REG_R8 is 8", RegAlloc.REG_R8, 8)
    T.assert_equal(results, "REG_R9 is 9", RegAlloc.REG_R9, 9)
    T.assert_equal(results, "REG_R10 is 10", RegAlloc.REG_R10, 10)
    T.assert_equal(results, "REG_R11 is 11", RegAlloc.REG_R11, 11)
    T.assert_equal(results, "REG_R12 is 12", RegAlloc.REG_R12, 12)
    T.assert_equal(results, "REG_R13 is 13", RegAlloc.REG_R13, 13)
    T.assert_equal(results, "REG_R14 is 14", RegAlloc.REG_R14, 14)
    T.assert_equal(results, "REG_R15 is 15", RegAlloc.REG_R15, 15)
    T.assert_equal(results, "REG_XMM0 is 16", RegAlloc.REG_XMM0, 16)

    Return 1
End Process

Note: ============================================================================
Note: Constraint Type Constant Tests
Note: ============================================================================

Process called "test_constraint_types" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Constraint Type Constants")

    T.assert_equal(results, "CONSTRAINT_TWO_ADDRESS is 1", RegAlloc.CONSTRAINT_TWO_ADDRESS, 1)
    T.assert_equal(results, "CONSTRAINT_FIXED_REG is 2", RegAlloc.CONSTRAINT_FIXED_REG, 2)
    T.assert_equal(results, "CONSTRAINT_CLOBBER is 3", RegAlloc.CONSTRAINT_CLOBBER, 3)
    T.assert_equal(results, "CONSTRAINT_SHIFT_CL is 4", RegAlloc.CONSTRAINT_SHIFT_CL, 4)
    T.assert_equal(results, "CONSTRAINT_DIV_RAX_RDX is 5", RegAlloc.CONSTRAINT_DIV_RAX_RDX, 5)

    Return 1
End Process

Note: ============================================================================
Note: LIR Opcode Constant Tests
Note: ============================================================================

Process called "test_opcode_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 LIR Opcode Constants")

    T.assert_equal(results, "OP_MOV is 30001", RegAlloc.OP_MOV, 30001)
    T.assert_equal(results, "OP_ADD is 30100", RegAlloc.OP_ADD, 30100)
    T.assert_equal(results, "OP_SUB is 30101", RegAlloc.OP_SUB, 30101)
    T.assert_equal(results, "OP_IMUL is 30102", RegAlloc.OP_IMUL, 30102)
    T.assert_equal(results, "OP_IDIV is 30103", RegAlloc.OP_IDIV, 30103)
    T.assert_equal(results, "OP_SHL is 30300", RegAlloc.OP_SHL, 30300)
    T.assert_equal(results, "OP_SHR is 30301", RegAlloc.OP_SHR, 30301)
    T.assert_equal(results, "OP_SAR is 30302", RegAlloc.OP_SAR, 30302)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "x86_64 Register Allocator Null Guards")

    Note: collect_x86_64_constraints with null function should return 0
    Let null_result be RegAlloc.collect_x86_64_constraints(0)
    T.assert_equal(results, "collect_constraints(0) returns 0", null_result, 0)

    Note: insert_register_copy with null block should return 0
    Let copy_result be RegAlloc.insert_register_copy(0, 0, 0, 1, 8)
    T.assert_equal(results, "insert_register_copy(null block) returns 0", copy_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_register_constants(results)
    test_constraint_types(results)
    test_opcode_constants(results)
    test_null_guards(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process
