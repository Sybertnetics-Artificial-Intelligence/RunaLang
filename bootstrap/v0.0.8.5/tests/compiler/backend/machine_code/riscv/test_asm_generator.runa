Note:
Unit Tests for RISC-V Assembly Generator

Validates ABI register naming (zero, ra, sp, gp, tp, t0-t6, s0-s11, a0-a7),
context creation, null guards, operand formatting for the RISC-V RV64GC backend.
RISC-V uses three-address instructions with 32 GPRs where x0 is hardwired zero.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/riscv/asm_generator.runa" as RVAsm
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/internal/memory_utils.runa" as MemoryUtils

Note: ============================================================================
Note: Register Name Tests
Note: ============================================================================

Process called "test_register_names" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv asm_generator: register names")

    Note: RISC-V uses ABI names: zero, ra, sp, gp, tp, t0-t2, s0-s1, a0-a7, s2-s11, t3-t6
    Let name0 be RVAsm.get_register_name(0)
    T.assert_not_null(results, "get_register_name(0)=zero returns non-null", name0)

    Let name1 be RVAsm.get_register_name(1)
    T.assert_not_null(results, "get_register_name(1)=ra returns non-null", name1)

    Let name2 be RVAsm.get_register_name(2)
    T.assert_not_null(results, "get_register_name(2)=sp returns non-null", name2)

    Let name5 be RVAsm.get_register_name(5)
    T.assert_not_null(results, "get_register_name(5)=t0 returns non-null", name5)

    Let name8 be RVAsm.get_register_name(8)
    T.assert_not_null(results, "get_register_name(8)=s0/fp returns non-null", name8)

    Let name10 be RVAsm.get_register_name(10)
    T.assert_not_null(results, "get_register_name(10)=a0 returns non-null", name10)

    Let name17 be RVAsm.get_register_name(17)
    T.assert_not_null(results, "get_register_name(17)=a7 returns non-null", name17)

    Let name31 be RVAsm.get_register_name(31)
    T.assert_not_null(results, "get_register_name(31)=t6 returns non-null", name31)

    Note: Out-of-range fallback
    Let name_oob be RVAsm.get_register_name(99)
    T.assert_not_null(results, "get_register_name(99) returns non-null fallback", name_oob)

    Return 1
End Process

Note: ============================================================================
Note: Context Creation Tests
Note: ============================================================================

Process called "test_create_asm_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv asm_generator: create_asm_context")

    Let arena be MemoryUtils.allocate(65536)
    T.assert_not_null(results, "arena allocation succeeds", arena)

    Let config be Layout.allocate(64)
    T.assert_not_null(results, "config allocation succeeds", config)

    Let ctx be RVAsm.create_asm_context(config, arena)
    T.assert_not_null(results, "create_asm_context returns non-null", ctx)

    Note: Verify output buffer stored (offset 0)
    Let output be __load(ctx, 0)
    T.assert_not_null(results, "output buffer stored", output)

    Note: Verify error_count starts at 0 (offset 32)
    Let errors be __load(ctx, 32)
    T.assert_equal(results, "error_count starts at 0", errors, 0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv asm_generator: null guards")

    Let r1 be RVAsm.generate_riscv_assembly(0, 0)
    T.assert_equal(results, "generate_riscv_assembly(0, 0) returns 0", r1, 0)

    Let r2 be RVAsm.emit_function(0, 0)
    T.assert_equal(results, "emit_function(0, 0) returns 0", r2, 0)

    Let arena be MemoryUtils.allocate(65536)
    Let config be Layout.allocate(64)
    Let ctx be RVAsm.create_asm_context(config, arena)

    Let r3 be RVAsm.emit_basic_block(ctx, 0)
    T.assert_equal(results, "emit_basic_block(ctx, 0) returns 0", r3, 0)

    Let r4 be RVAsm.emit_instruction(ctx, 0)
    T.assert_equal(results, "emit_instruction(ctx, 0) returns 0", r4, 0)

    Let r5 be RVAsm.format_operand(0, 8)
    T.assert_not_null(results, "format_operand(0, 8) returns non-null", r5)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_register_names(results)
    test_create_asm_context(results)
    test_null_guards(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
