Note:
Unit Tests for RISC-V Instruction Encoder

Validates RISC-V opcode constants, funct3/funct7 constants, encoder context
creation, and R/I/S/B/U/J format encoding for the fixed 32-bit instruction
width RISC-V ISA. RISC-V has the cleanest encoding of all supported backends
with six regular instruction formats.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/riscv/instruction_encoder.runa" as RVEnc
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/internal/memory_utils.runa" as MemoryUtils

Note: ============================================================================
Note: Opcode Constant Tests
Note: ============================================================================

Process called "test_opcode_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv instruction_encoder: opcode constants")

    T.assert_equal(results, "OPCODE_LUI is 55", RVEnc.OPCODE_LUI, 55)
    T.assert_equal(results, "OPCODE_AUIPC is 23", RVEnc.OPCODE_AUIPC, 23)
    T.assert_equal(results, "OPCODE_JAL is 111", RVEnc.OPCODE_JAL, 111)
    T.assert_equal(results, "OPCODE_JALR is 103", RVEnc.OPCODE_JALR, 103)
    T.assert_equal(results, "OPCODE_BRANCH is 99", RVEnc.OPCODE_BRANCH, 99)
    T.assert_equal(results, "OPCODE_LOAD is 3", RVEnc.OPCODE_LOAD, 3)
    T.assert_equal(results, "OPCODE_STORE is 35", RVEnc.OPCODE_STORE, 35)
    T.assert_equal(results, "OPCODE_OP_IMM is 19", RVEnc.OPCODE_OP_IMM, 19)
    T.assert_equal(results, "OPCODE_OP is 51", RVEnc.OPCODE_OP, 51)
    T.assert_equal(results, "OPCODE_OP_IMM_32 is 27", RVEnc.OPCODE_OP_IMM_32, 27)
    T.assert_equal(results, "OPCODE_OP_32 is 59", RVEnc.OPCODE_OP_32, 59)
    T.assert_equal(results, "OPCODE_SYSTEM is 115", RVEnc.OPCODE_SYSTEM, 115)

    Return 1
End Process

Note: ============================================================================
Note: Funct3 and Funct7 Constant Tests
Note: ============================================================================

Process called "test_funct_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv instruction_encoder: funct3/funct7 constants")

    Note: ALU funct3
    T.assert_equal(results, "FUNCT3_ADD is 0", RVEnc.FUNCT3_ADD, 0)
    T.assert_equal(results, "FUNCT3_SLL is 1", RVEnc.FUNCT3_SLL, 1)
    T.assert_equal(results, "FUNCT3_SLT is 2", RVEnc.FUNCT3_SLT, 2)
    T.assert_equal(results, "FUNCT3_SLTU is 3", RVEnc.FUNCT3_SLTU, 3)
    T.assert_equal(results, "FUNCT3_XOR is 4", RVEnc.FUNCT3_XOR, 4)
    T.assert_equal(results, "FUNCT3_SRL is 5", RVEnc.FUNCT3_SRL, 5)
    T.assert_equal(results, "FUNCT3_OR is 6", RVEnc.FUNCT3_OR, 6)
    T.assert_equal(results, "FUNCT3_AND is 7", RVEnc.FUNCT3_AND, 7)

    Note: Branch funct3
    T.assert_equal(results, "FUNCT3_BEQ is 0", RVEnc.FUNCT3_BEQ, 0)
    T.assert_equal(results, "FUNCT3_BNE is 1", RVEnc.FUNCT3_BNE, 1)
    T.assert_equal(results, "FUNCT3_BLT is 4", RVEnc.FUNCT3_BLT, 4)
    T.assert_equal(results, "FUNCT3_BGE is 5", RVEnc.FUNCT3_BGE, 5)
    T.assert_equal(results, "FUNCT3_BLTU is 6", RVEnc.FUNCT3_BLTU, 6)
    T.assert_equal(results, "FUNCT3_BGEU is 7", RVEnc.FUNCT3_BGEU, 7)

    Note: Load funct3
    T.assert_equal(results, "FUNCT3_LB is 0", RVEnc.FUNCT3_LB, 0)
    T.assert_equal(results, "FUNCT3_LW is 2", RVEnc.FUNCT3_LW, 2)
    T.assert_equal(results, "FUNCT3_LD is 3", RVEnc.FUNCT3_LD, 3)

    Note: Store funct3
    T.assert_equal(results, "FUNCT3_SB is 0", RVEnc.FUNCT3_SB, 0)
    T.assert_equal(results, "FUNCT3_SW is 2", RVEnc.FUNCT3_SW, 2)
    T.assert_equal(results, "FUNCT3_SD is 3", RVEnc.FUNCT3_SD, 3)

    Note: Funct7
    T.assert_equal(results, "FUNCT7_NORMAL is 0", RVEnc.FUNCT7_NORMAL, 0)
    T.assert_equal(results, "FUNCT7_ALT is 32", RVEnc.FUNCT7_ALT, 32)
    T.assert_equal(results, "FUNCT7_MULDIV is 1", RVEnc.FUNCT7_MULDIV, 1)

    Return 1
End Process

Note: ============================================================================
Note: Encoder Context Tests
Note: ============================================================================

Process called "test_encoder_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv instruction_encoder: encoder context")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Let ctx be RVEnc.create_encoder_context(output)
    T.assert_not_null(results, "create_encoder_context returns non-null", ctx)

    Note: Verify output stored (offset 0)
    Let stored_output be __load(ctx, 0)
    T.assert_equal(results, "output stored correctly", stored_output, output)

    Return 1
End Process

Note: ============================================================================
Note: R-type Encoding Tests
Note: ============================================================================

Process called "test_r_type_encoding" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv instruction_encoder: R-type encoding")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    Let ctx be RVEnc.create_encoder_context(output)

    Note: Encode ADD x1, x2, x3: opcode=0x33, rd=1, funct3=0, rs1=2, rs2=3, funct7=0
    Let r1 be RVEnc.encode_r_type(ctx, 51, 1, 0, 2, 3, 0)
    T.assert_equal(results, "encode_r_type ADD returns 1", r1, 1)

    Note: Null guard
    Let r2 be RVEnc.encode_r_type(0, 0, 0, 0, 0, 0, 0)
    T.assert_equal(results, "encode_r_type(0,...) returns 0", r2, 0)

    Return 1
End Process

Note: ============================================================================
Note: I-type Encoding Tests
Note: ============================================================================

Process called "test_i_type_encoding" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv instruction_encoder: I-type encoding")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    Let ctx be RVEnc.create_encoder_context(output)

    Note: Encode ADDI x1, x2, 42: opcode=0x13, rd=1, funct3=0, rs1=2, imm=42
    Let r1 be RVEnc.encode_i_type(ctx, 19, 1, 0, 2, 42)
    T.assert_equal(results, "encode_i_type ADDI returns 1", r1, 1)

    Note: Null guard
    Let r2 be RVEnc.encode_i_type(0, 0, 0, 0, 0, 0)
    T.assert_equal(results, "encode_i_type(0,...) returns 0", r2, 0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv instruction_encoder: null guards")

    T.assert_equal(results, "emit_word(0,...) returns 0", RVEnc.emit_word(0, 0), 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_opcode_constants(results)
    test_funct_constants(results)
    test_encoder_context(results)
    test_r_type_encoding(results)
    test_i_type_encoding(results)
    test_null_guards(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
