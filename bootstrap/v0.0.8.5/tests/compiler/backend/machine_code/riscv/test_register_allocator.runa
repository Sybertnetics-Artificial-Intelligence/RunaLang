Note:
Unit Tests for RISC-V Register Allocator

Validates the 32-register GPR file (x0-x31) with x0 hardwired to zero,
RISC-V calling convention (a0-a7 args, s0-s11 callee-saved, t0-t6 caller-saved),
allocatable count (27 of 32, excluding x0-x4), constraint types (minimal due
to clean three-address ISA), and virtual-to-physical register mapping.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/riscv/register_allocator.runa" as RVReg
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Register Constant Tests
Note: ============================================================================

Process called "test_register_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv register_allocator: register constants")

    Note: Zero register
    T.assert_equal(results, "REG_ZERO is 0 (x0)", RVReg.RV_REG_ZERO, 0)

    Note: Special registers
    T.assert_equal(results, "REG_RA is 1 (x1)", RVReg.RV_REG_RA, 1)
    T.assert_equal(results, "REG_SP is 2 (x2)", RVReg.RV_REG_SP, 2)
    T.assert_equal(results, "REG_GP is 3 (x3)", RVReg.RV_REG_GP, 3)
    T.assert_equal(results, "REG_TP is 4 (x4)", RVReg.RV_REG_TP, 4)

    Note: Temporaries
    T.assert_equal(results, "REG_T0 is 5 (x5)", RVReg.RV_REG_T0, 5)
    T.assert_equal(results, "REG_T1 is 6 (x6)", RVReg.RV_REG_T1, 6)
    T.assert_equal(results, "REG_T2 is 7 (x7)", RVReg.RV_REG_T2, 7)

    Note: Saved / frame pointer
    T.assert_equal(results, "REG_S0 is 8 (x8/fp)", RVReg.RV_REG_S0, 8)
    T.assert_equal(results, "REG_FP is 8 (alias)", RVReg.RV_REG_FP, 8)
    T.assert_equal(results, "REG_S1 is 9 (x9)", RVReg.RV_REG_S1, 9)

    Note: Argument/return registers
    T.assert_equal(results, "REG_A0 is 10 (x10)", RVReg.RV_REG_A0, 10)
    T.assert_equal(results, "REG_A1 is 11 (x11)", RVReg.RV_REG_A1, 11)
    T.assert_equal(results, "REG_A7 is 17 (x17)", RVReg.RV_REG_A7, 17)

    Note: More saved registers
    T.assert_equal(results, "REG_S2 is 18 (x18)", RVReg.RV_REG_S2, 18)
    T.assert_equal(results, "REG_S11 is 27 (x27)", RVReg.RV_REG_S11, 27)

    Note: More temporaries
    T.assert_equal(results, "REG_T3 is 28 (x28)", RVReg.RV_REG_T3, 28)
    T.assert_equal(results, "REG_T6 is 31 (x31)", RVReg.RV_REG_T6, 31)

    Note: Counts
    T.assert_equal(results, "RISCV_GPR_COUNT is 32", RVReg.RISCV_GPR_COUNT, 32)
    T.assert_equal(results, "RISCV_ALLOCATABLE_COUNT is 27", RVReg.RISCV_ALLOCATABLE_COUNT, 27)

    Return 1
End Process

Note: ============================================================================
Note: Allocatable Register Tests
Note: ============================================================================

Process called "test_is_allocatable_register" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv register_allocator: is_allocatable_register")

    Note: x0-x4 are reserved (zero, ra, sp, gp, tp)
    T.assert_equal(results, "x0 (zero) NOT allocatable", RVReg.is_allocatable_register(0), 0)
    T.assert_equal(results, "x1 (ra) NOT allocatable", RVReg.is_allocatable_register(1), 0)
    T.assert_equal(results, "x2 (sp) NOT allocatable", RVReg.is_allocatable_register(2), 0)
    T.assert_equal(results, "x3 (gp) NOT allocatable", RVReg.is_allocatable_register(3), 0)
    T.assert_equal(results, "x4 (tp) NOT allocatable", RVReg.is_allocatable_register(4), 0)

    Note: x5-x31 are allocatable
    T.assert_equal(results, "x5 (t0) is allocatable", RVReg.is_allocatable_register(5), 1)
    T.assert_equal(results, "x10 (a0) is allocatable", RVReg.is_allocatable_register(10), 1)
    T.assert_equal(results, "x18 (s2) is allocatable", RVReg.is_allocatable_register(18), 1)
    T.assert_equal(results, "x31 (t6) is allocatable", RVReg.is_allocatable_register(31), 1)

    Note: Out-of-range
    T.assert_equal(results, "x32 NOT allocatable", RVReg.is_allocatable_register(32), 0)

    Return 1
End Process

Note: ============================================================================
Note: Calling Convention Tests
Note: ============================================================================

Process called "test_calling_convention" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv register_allocator: calling convention")

    Note: Callee-saved: s0-s1 (x8-x9), s2-s11 (x18-x27)
    T.assert_equal(results, "s0 (x8) is callee-saved", RVReg.is_callee_saved(8), 1)
    T.assert_equal(results, "s1 (x9) is callee-saved", RVReg.is_callee_saved(9), 1)
    T.assert_equal(results, "s2 (x18) is callee-saved", RVReg.is_callee_saved(18), 1)
    T.assert_equal(results, "s11 (x27) is callee-saved", RVReg.is_callee_saved(27), 1)

    Note: Caller-saved (temporaries and arg regs)
    T.assert_equal(results, "t0 (x5) NOT callee-saved", RVReg.is_callee_saved(5), 0)
    T.assert_equal(results, "a0 (x10) NOT callee-saved", RVReg.is_callee_saved(10), 0)
    T.assert_equal(results, "t3 (x28) NOT callee-saved", RVReg.is_callee_saved(28), 0)

    Return 1
End Process

Note: ============================================================================
Note: Constraint Constant Tests
Note: ============================================================================

Process called "test_constraint_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "riscv register_allocator: constraint constants")

    Note: RISC-V has minimal constraints (clean three-address ISA)
    T.assert_equal(results, "CONSTRAINT_FIXED_REG is 1", RVReg.RV_CONSTRAINT_FIXED_REG, 1)
    T.assert_equal(results, "CONSTRAINT_CLOBBER is 2", RVReg.RV_CONSTRAINT_CLOBBER, 2)
    T.assert_equal(results, "CONSTRAINT_CALL_ARGS is 3", RVReg.RV_CONSTRAINT_CALL_ARGS, 3)
    T.assert_equal(results, "CONSTRAINT_CALL_RETURN is 4", RVReg.RV_CONSTRAINT_CALL_RETURN, 4)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_register_constants(results)
    test_is_allocatable_register(results)
    test_calling_convention(results)
    test_constraint_constants(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
