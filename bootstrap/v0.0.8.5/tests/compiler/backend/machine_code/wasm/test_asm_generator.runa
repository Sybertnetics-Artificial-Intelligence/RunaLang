Note:
Unit Tests for WebAssembly Assembly Generator (WAT Text Format)

Validates context creation with local allocation state and optimizer, null guards,
and WAT text generation pipeline. WebAssembly is stack-based with no physical
registers; LIR virtual registers map to indexed local variables. The generator
converts register-based LIR to stack-based Wasm local.get/local.set sequences.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/wasm/asm_generator.runa" as WasmAsm
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Context Creation Tests
Note: ============================================================================

Process called "test_create_wasm_asm_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm asm_generator: create_wasm_asm_context")

    Let arena be Layout.allocate(65536)
    T.assert_not_null(results, "arena allocation succeeds", arena)

    Let output be MCI.create_assembly_output(arena)
    T.assert_not_null(results, "assembly output created", output)

    Let config be Layout.allocate(64)
    T.assert_not_null(results, "config allocation succeeds", config)

    Let ctx be WasmAsm.create_wasm_asm_context(output, config)
    T.assert_not_null(results, "create_wasm_asm_context returns non-null", ctx)

    Note: Verify output stored (offset 0)
    Let stored_output be __load(ctx, 0)
    T.assert_equal(results, "output stored correctly", stored_output, output)

    Note: Verify config stored (offset 8)
    Let stored_config be __load(ctx, 8)
    T.assert_equal(results, "config stored correctly", stored_config, config)

    Note: Verify current_function starts at 0 (offset 16)
    Let current_func be __load(ctx, 16)
    T.assert_equal(results, "current_function starts at 0", current_func, 0)

    Note: Verify local_state allocated (offset 24)
    Let local_state be __load(ctx, 24)
    T.assert_not_null(results, "local_state allocated", local_state)

    Note: Verify indent_level starts at 0 (offset 40)
    Let indent_level be __load(ctx, 40)
    T.assert_equal(results, "indent_level starts at 0", indent_level, 0)

    Note: Verify error_count starts at 0 (offset 48)
    Let error_count be __load(ctx, 48)
    T.assert_equal(results, "error_count starts at 0", error_count, 0)

    Note: Verify label_counter starts at 0 (offset 56)
    Let label_counter be __load(ctx, 56)
    T.assert_equal(results, "label_counter starts at 0", label_counter, 0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm asm_generator: null guards")

    Note: Null output may cause failure in dependent allocator creation
    Let ctx_null be WasmAsm.create_wasm_asm_context(0, 0)
    If ctx_null is 0:
        T.assert_equal(results, "create_wasm_asm_context(0,0) returns 0 (expected)", ctx_null, 0)
    Otherwise:
        T.assert_not_null(results, "create_wasm_asm_context(0,0) returns non-null", ctx_null)
    End If

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_create_wasm_asm_context(results)
    test_null_guards(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
