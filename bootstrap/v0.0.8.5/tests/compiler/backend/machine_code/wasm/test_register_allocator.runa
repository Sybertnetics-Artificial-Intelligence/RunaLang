Note:
Unit Tests for WebAssembly Register Allocator (Local Variable Mapping)

Validates Wasm value type constants (i32=0x7F, i64=0x7E, f32=0x7D, f64=0x7C),
local allocation state creation, parameter registration, local variable
allocation, and LIR virtual register to Wasm local index mapping. WebAssembly
has no physical registers; all values live on the operand stack or in indexed
local variables.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/wasm/register_allocator.runa" as WasmReg
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Value Type Constant Tests
Note: ============================================================================

Process called "test_value_type_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm register_allocator: value type constants")

    T.assert_equal(results, "WASM_TYPE_I32 is 127 (0x7F)", WasmReg.WASM_TYPE_I32, 127)
    T.assert_equal(results, "WASM_TYPE_I64 is 126 (0x7E)", WasmReg.WASM_TYPE_I64, 126)
    T.assert_equal(results, "WASM_TYPE_F32 is 125 (0x7D)", WasmReg.WASM_TYPE_F32, 125)
    T.assert_equal(results, "WASM_TYPE_F64 is 124 (0x7C)", WasmReg.WASM_TYPE_F64, 124)
    T.assert_equal(results, "WASM_TYPE_FUNCREF is 112 (0x70)", WasmReg.WASM_TYPE_FUNCREF, 112)
    T.assert_equal(results, "WASM_TYPE_EXTERNREF is 111 (0x6F)", WasmReg.WASM_TYPE_EXTERNREF, 111)
    T.assert_equal(results, "WASM_TYPE_VOID is 64 (0x40)", WasmReg.WASM_TYPE_VOID, 64)
    T.assert_equal(results, "MAX_WASM_LOCALS is 4096", WasmReg.MAX_WASM_LOCALS, 4096)

    Return 1
End Process

Note: ============================================================================
Note: Local Allocation State Creation Tests
Note: ============================================================================

Process called "test_create_wasm_local_alloc_state" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm register_allocator: create_wasm_local_alloc_state")

    Let state be WasmReg.create_wasm_local_alloc_state(256)
    T.assert_not_null(results, "create_wasm_local_alloc_state(256) returns non-null", state)

    Note: Verify types array allocated (offset 8)
    Let types_array be __load(state, 8)
    T.assert_not_null(results, "types array allocated", types_array)

    Note: Verify mapping array allocated (offset 16)
    Let mapping_array be __load(state, 16)
    T.assert_not_null(results, "mapping array allocated", mapping_array)

    Note: Verify local_count starts at 0 (offset 24)
    Let local_count be __load(state, 24)
    T.assert_equal(results, "local_count starts at 0", local_count, 0)

    Note: Verify param_count starts at 0 (offset 32)
    Let param_count be __load(state, 32)
    T.assert_equal(results, "param_count starts at 0", param_count, 0)

    Note: Verify capacity stored (offset 40)
    Let capacity be __load(state, 40)
    T.assert_equal(results, "capacity is 256", capacity, 256)

    Return 1
End Process

Note: ============================================================================
Note: Default State Creation Tests
Note: ============================================================================

Process called "test_create_default_wasm_local_state" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm register_allocator: create_default_wasm_local_state")

    Let state be WasmReg.create_default_wasm_local_state()
    T.assert_not_null(results, "create_default_wasm_local_state returns non-null", state)

    Note: Default uses MAX_WASM_LOCALS = 4096
    Let capacity be __load(state, 40)
    T.assert_equal(results, "default capacity is 4096", capacity, 4096)

    Return 1
End Process

Note: ============================================================================
Note: Parameter Registration Tests
Note: ============================================================================

Process called "test_register_parameter" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm register_allocator: register_parameter")

    Let state be WasmReg.create_wasm_local_alloc_state(256)
    T.assert_not_null(results, "state created", state)

    Note: Register first parameter: LIR vreg 0, type i32
    Let idx0 be WasmReg.register_parameter(state, 0, WasmReg.WASM_TYPE_I32)
    T.assert_equal(results, "first parameter gets local index 0", idx0, 0)

    Note: Verify local_count incremented
    Let count1 be __load(state, 24)
    T.assert_equal(results, "local_count is 1 after first param", count1, 1)

    Note: Register second parameter: LIR vreg 1, type i64
    Let idx1 be WasmReg.register_parameter(state, 1, WasmReg.WASM_TYPE_I64)
    T.assert_equal(results, "second parameter gets local index 1", idx1, 1)

    Note: Verify local_count is now 2
    Let count2 be __load(state, 24)
    T.assert_equal(results, "local_count is 2 after second param", count2, 2)

    Note: Verify type was stored for first param
    Let types_array be __load(state, 8)
    Let type0 be __load(types_array, 0)
    T.assert_equal(results, "param 0 type is i32", type0, WasmReg.WASM_TYPE_I32)

    Let type1 be __load(types_array, 8)
    T.assert_equal(results, "param 1 type is i64", type1, WasmReg.WASM_TYPE_I64)

    Note: Verify LIR vreg mapping
    Let mapping_array be __load(state, 16)
    Let mapped0 be __load(mapping_array, 0)
    T.assert_equal(results, "LIR vreg 0 maps to local 0", mapped0, 0)

    Let mapped1 be __load(mapping_array, 8)
    T.assert_equal(results, "LIR vreg 1 maps to local 1", mapped1, 1)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_value_type_constants(results)
    test_create_wasm_local_alloc_state(results)
    test_create_default_wasm_local_state(results)
    test_register_parameter(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
