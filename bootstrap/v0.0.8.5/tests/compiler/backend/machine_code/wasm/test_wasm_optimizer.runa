Note:
Unit Tests for WebAssembly Optimizer (Stack Scheduling)

Validates value lifetime classification constants (STACK_RESIDENT, LOCAL_REQUIRED,
DEAD), BlockLifetimeAnalysis creation, and the stack scheduling optimization
pipeline that reduces redundant local.get/local.set instructions by identifying
values that can stay on the Wasm operand stack.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/wasm/wasm_optimizer.runa" as WasmOpt
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Lifetime Classification Constant Tests
Note: ============================================================================

Process called "test_lifetime_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm_optimizer: lifetime classification constants")

    T.assert_equal(results, "LIFETIME_STACK_RESIDENT is 0", WasmOpt.LIFETIME_STACK_RESIDENT, 0)
    T.assert_equal(results, "LIFETIME_LOCAL_REQUIRED is 1", WasmOpt.LIFETIME_LOCAL_REQUIRED, 1)
    T.assert_equal(results, "LIFETIME_DEAD is 2", WasmOpt.LIFETIME_DEAD, 2)

    Return 1
End Process

Note: ============================================================================
Note: Block Lifetime Analysis Creation Tests
Note: ============================================================================

Process called "test_create_block_analysis" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm_optimizer: create_block_analysis")

    Let analysis be WasmOpt.create_block_analysis(128)
    T.assert_not_null(results, "create_block_analysis(128) returns non-null", analysis)

    Note: Verify lifetimes array allocated (offset 0)
    Let lifetimes be __load(analysis, 0)
    T.assert_not_null(results, "lifetimes array allocated", lifetimes)

    Note: Verify lifetime_count starts at 0 (offset 8)
    Let lifetime_count be __load(analysis, 8)
    T.assert_equal(results, "lifetime_count starts at 0", lifetime_count, 0)

    Note: Verify capacity stored (offset 16)
    Let capacity be __load(analysis, 16)
    T.assert_equal(results, "capacity is 128", capacity, 128)

    Note: Verify stack_depth starts at 0 (offset 24)
    Let stack_depth be __load(analysis, 24)
    T.assert_equal(results, "stack_depth starts at 0", stack_depth, 0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm_optimizer: null guards")

    Note: create_block_analysis with zero capacity should still allocate the struct
    Let analysis_zero be WasmOpt.create_block_analysis(0)
    T.assert_not_null(results, "create_block_analysis(0) returns non-null", analysis_zero)

    Note: analyze_value_lifetimes with null block
    Let analysis be WasmOpt.create_block_analysis(64)
    Let r1 be WasmOpt.analyze_value_lifetimes(analysis, 0)
    Note: With null block, instruction count should be 0, so returns immediately
    If r1 is 0:
        T.assert_equal(results, "analyze_value_lifetimes(analysis, 0) returns 0", r1, 0)
    Otherwise:
        T.assert_not_equal(results, "analyze_value_lifetimes handled null block", r1, -1)
    End If

    Return 1
End Process

Note: ============================================================================
Note: ValueLifetime Type Layout Tests
Note: ============================================================================

Process called "test_value_lifetime_layout" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm_optimizer: ValueLifetime type layout")

    Note: Manually create a ValueLifetime entry and verify field access
    Note: ValueLifetime is 40 bytes: lir_vreg(8), def_index(8), last_use_index(8), use_count(8), classification(8)
    Let entry be Layout.allocate(40)
    T.assert_not_null(results, "ValueLifetime entry allocated", entry)

    __store(entry, 0, 42)           Note: lir_vreg = 42
    __store(entry, 8, 5)            Note: def_index = 5
    __store(entry, 16, 10)          Note: last_use_index = 10
    __store(entry, 24, 3)           Note: use_count = 3
    __store(entry, 32, WasmOpt.LIFETIME_LOCAL_REQUIRED)

    Let vreg be __load(entry, 0)
    T.assert_equal(results, "lir_vreg is 42", vreg, 42)

    Let def_idx be __load(entry, 8)
    T.assert_equal(results, "def_index is 5", def_idx, 5)

    Let last_use be __load(entry, 16)
    T.assert_equal(results, "last_use_index is 10", last_use, 10)

    Let use_count be __load(entry, 24)
    T.assert_equal(results, "use_count is 3", use_count, 3)

    Let classification be __load(entry, 32)
    T.assert_equal(results, "classification is LOCAL_REQUIRED", classification, WasmOpt.LIFETIME_LOCAL_REQUIRED)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_lifetime_constants(results)
    test_create_block_analysis(results)
    test_null_guards(results)
    test_value_lifetime_layout(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
