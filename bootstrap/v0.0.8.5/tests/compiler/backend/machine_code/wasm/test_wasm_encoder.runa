Note:
Unit Tests for WebAssembly Binary Module Encoder

Validates section ID constants (Type=1 through Data=11), export kind constants,
function type marker, module state creation with all internal buffer allocations,
and the overall module encoding pipeline for the .wasm binary format.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/wasm/wasm_encoder.runa" as WasmMod
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Section ID Constant Tests
Note: ============================================================================

Process called "test_section_id_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm_encoder: section ID constants")

    T.assert_equal(results, "WASM_SECTION_CUSTOM is 0", WasmMod.WASM_SECTION_CUSTOM, 0)
    T.assert_equal(results, "WASM_SECTION_TYPE is 1", WasmMod.WASM_SECTION_TYPE, 1)
    T.assert_equal(results, "WASM_SECTION_IMPORT is 2", WasmMod.WASM_SECTION_IMPORT, 2)
    T.assert_equal(results, "WASM_SECTION_FUNCTION is 3", WasmMod.WASM_SECTION_FUNCTION, 3)
    T.assert_equal(results, "WASM_SECTION_TABLE is 4", WasmMod.WASM_SECTION_TABLE, 4)
    T.assert_equal(results, "WASM_SECTION_MEMORY is 5", WasmMod.WASM_SECTION_MEMORY, 5)
    T.assert_equal(results, "WASM_SECTION_GLOBAL is 6", WasmMod.WASM_SECTION_GLOBAL, 6)
    T.assert_equal(results, "WASM_SECTION_EXPORT is 7", WasmMod.WASM_SECTION_EXPORT, 7)
    T.assert_equal(results, "WASM_SECTION_START is 8", WasmMod.WASM_SECTION_START, 8)
    T.assert_equal(results, "WASM_SECTION_ELEMENT is 9", WasmMod.WASM_SECTION_ELEMENT, 9)
    T.assert_equal(results, "WASM_SECTION_CODE is 10", WasmMod.WASM_SECTION_CODE, 10)
    T.assert_equal(results, "WASM_SECTION_DATA is 11", WasmMod.WASM_SECTION_DATA, 11)

    Return 1
End Process

Note: ============================================================================
Note: Export Kind and Type Constant Tests
Note: ============================================================================

Process called "test_export_kind_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm_encoder: export kind constants")

    T.assert_equal(results, "WASM_EXPORT_FUNC is 0", WasmMod.WASM_EXPORT_FUNC, 0)
    T.assert_equal(results, "WASM_EXPORT_TABLE is 1", WasmMod.WASM_EXPORT_TABLE, 1)
    T.assert_equal(results, "WASM_EXPORT_MEMORY is 2", WasmMod.WASM_EXPORT_MEMORY, 2)
    T.assert_equal(results, "WASM_EXPORT_GLOBAL is 3", WasmMod.WASM_EXPORT_GLOBAL, 3)

    Note: Function type marker
    T.assert_equal(results, "WASM_FUNCTYPE is 96 (0x60)", WasmMod.WASM_FUNCTYPE, 96)

    Return 1
End Process

Note: ============================================================================
Note: Section ID Ordering Tests
Note: ============================================================================

Process called "test_section_id_ordering" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm_encoder: section ID ordering")

    Note: Wasm spec requires sections to appear in order by ID
    T.assert_equal(results, "CUSTOM < TYPE", WasmMod.WASM_SECTION_CUSTOM is less than WasmMod.WASM_SECTION_TYPE, 1)
    T.assert_equal(results, "TYPE < IMPORT", WasmMod.WASM_SECTION_TYPE is less than WasmMod.WASM_SECTION_IMPORT, 1)
    T.assert_equal(results, "IMPORT < FUNCTION", WasmMod.WASM_SECTION_IMPORT is less than WasmMod.WASM_SECTION_FUNCTION, 1)
    T.assert_equal(results, "FUNCTION < TABLE", WasmMod.WASM_SECTION_FUNCTION is less than WasmMod.WASM_SECTION_TABLE, 1)
    T.assert_equal(results, "TABLE < MEMORY", WasmMod.WASM_SECTION_TABLE is less than WasmMod.WASM_SECTION_MEMORY, 1)
    T.assert_equal(results, "MEMORY < GLOBAL", WasmMod.WASM_SECTION_MEMORY is less than WasmMod.WASM_SECTION_GLOBAL, 1)
    T.assert_equal(results, "GLOBAL < EXPORT", WasmMod.WASM_SECTION_GLOBAL is less than WasmMod.WASM_SECTION_EXPORT, 1)
    T.assert_equal(results, "EXPORT < START", WasmMod.WASM_SECTION_EXPORT is less than WasmMod.WASM_SECTION_START, 1)
    T.assert_equal(results, "START < ELEMENT", WasmMod.WASM_SECTION_START is less than WasmMod.WASM_SECTION_ELEMENT, 1)
    T.assert_equal(results, "ELEMENT < CODE", WasmMod.WASM_SECTION_ELEMENT is less than WasmMod.WASM_SECTION_CODE, 1)
    T.assert_equal(results, "CODE < DATA", WasmMod.WASM_SECTION_CODE is less than WasmMod.WASM_SECTION_DATA, 1)

    Return 1
End Process

Note: ============================================================================
Note: Module State Creation Tests
Note: ============================================================================

Process called "test_create_wasm_module" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm_encoder: create_wasm_module")

    Let arena be Layout.allocate(131072)
    T.assert_not_null(results, "arena allocation succeeds", arena)

    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Let module_state be WasmMod.create_wasm_module(output)
    T.assert_not_null(results, "create_wasm_module returns non-null", module_state)

    Note: Verify output stored (offset 0)
    Let stored_output be __load(module_state, 0)
    T.assert_equal(results, "output stored correctly", stored_output, output)

    Note: Verify type_entries allocated (offset 8)
    Let type_entries be __load(module_state, 8)
    T.assert_not_null(results, "type_entries allocated", type_entries)

    Note: Verify type_count starts at 0 (offset 16)
    Let type_count be __load(module_state, 16)
    T.assert_equal(results, "type_count starts at 0", type_count, 0)

    Note: Verify func_count starts at 0 (offset 32)
    Let func_count be __load(module_state, 32)
    T.assert_equal(results, "func_count starts at 0", func_count, 0)

    Note: Verify export_count starts at 0 (offset 48)
    Let export_count be __load(module_state, 48)
    T.assert_equal(results, "export_count starts at 0", export_count, 0)

    Note: Verify temp_buffer allocated (offset 104)
    Let temp_buf be __load(module_state, 104)
    T.assert_not_null(results, "temp_buffer allocated", temp_buf)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_section_id_constants(results)
    test_export_kind_constants(results)
    test_section_id_ordering(results)
    test_create_wasm_module(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
