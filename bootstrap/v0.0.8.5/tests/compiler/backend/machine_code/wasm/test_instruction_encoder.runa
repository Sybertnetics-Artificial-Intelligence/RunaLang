Note:
Unit Tests for WebAssembly Instruction Encoder

Validates all Wasm MVP single-byte opcode constants for control flow, call,
parametric, local variable, global variable, memory load/store, i32 arithmetic,
i32 comparison, and constant opcodes. Also validates LEB128 encoding which is
the fundamental encoding format for all multi-byte operands in Wasm binary.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/wasm/instruction_encoder.runa" as WasmEnc
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Control Flow Opcode Tests
Note: ============================================================================

Process called "test_control_flow_opcodes" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm instruction_encoder: control flow opcodes")

    T.assert_equal(results, "WASM_OP_UNREACHABLE is 0", WasmEnc.WASM_OP_UNREACHABLE, 0)
    T.assert_equal(results, "WASM_OP_NOP is 1", WasmEnc.WASM_OP_NOP, 1)
    T.assert_equal(results, "WASM_OP_BLOCK is 2", WasmEnc.WASM_OP_BLOCK, 2)
    T.assert_equal(results, "WASM_OP_LOOP is 3", WasmEnc.WASM_OP_LOOP, 3)
    T.assert_equal(results, "WASM_OP_IF is 4", WasmEnc.WASM_OP_IF, 4)
    T.assert_equal(results, "WASM_OP_ELSE is 5", WasmEnc.WASM_OP_ELSE, 5)
    T.assert_equal(results, "WASM_OP_END is 11 (0x0B)", WasmEnc.WASM_OP_END, 11)
    T.assert_equal(results, "WASM_OP_BR is 12 (0x0C)", WasmEnc.WASM_OP_BR, 12)
    T.assert_equal(results, "WASM_OP_BR_IF is 13 (0x0D)", WasmEnc.WASM_OP_BR_IF, 13)
    T.assert_equal(results, "WASM_OP_BR_TABLE is 14 (0x0E)", WasmEnc.WASM_OP_BR_TABLE, 14)
    T.assert_equal(results, "WASM_OP_RETURN is 15 (0x0F)", WasmEnc.WASM_OP_RETURN, 15)

    Return 1
End Process

Note: ============================================================================
Note: Call and Parametric Opcode Tests
Note: ============================================================================

Process called "test_call_parametric_opcodes" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm instruction_encoder: call and parametric opcodes")

    T.assert_equal(results, "WASM_OP_CALL is 16 (0x10)", WasmEnc.WASM_OP_CALL, 16)
    T.assert_equal(results, "WASM_OP_CALL_INDIRECT is 17 (0x11)", WasmEnc.WASM_OP_CALL_INDIRECT, 17)
    T.assert_equal(results, "WASM_OP_DROP is 26 (0x1A)", WasmEnc.WASM_OP_DROP, 26)
    T.assert_equal(results, "WASM_OP_SELECT is 27 (0x1B)", WasmEnc.WASM_OP_SELECT, 27)

    Return 1
End Process

Note: ============================================================================
Note: Local and Global Variable Opcode Tests
Note: ============================================================================

Process called "test_variable_opcodes" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm instruction_encoder: local/global variable opcodes")

    T.assert_equal(results, "WASM_OP_LOCAL_GET is 32 (0x20)", WasmEnc.WASM_OP_LOCAL_GET, 32)
    T.assert_equal(results, "WASM_OP_LOCAL_SET is 33 (0x21)", WasmEnc.WASM_OP_LOCAL_SET, 33)
    T.assert_equal(results, "WASM_OP_LOCAL_TEE is 34 (0x22)", WasmEnc.WASM_OP_LOCAL_TEE, 34)
    T.assert_equal(results, "WASM_OP_GLOBAL_GET is 35 (0x23)", WasmEnc.WASM_OP_GLOBAL_GET, 35)
    T.assert_equal(results, "WASM_OP_GLOBAL_SET is 36 (0x24)", WasmEnc.WASM_OP_GLOBAL_SET, 36)

    Return 1
End Process

Note: ============================================================================
Note: Memory Opcode Tests
Note: ============================================================================

Process called "test_memory_opcodes" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm instruction_encoder: memory opcodes")

    T.assert_equal(results, "WASM_OP_I32_LOAD is 40 (0x28)", WasmEnc.WASM_OP_I32_LOAD, 40)
    T.assert_equal(results, "WASM_OP_I64_LOAD is 41 (0x29)", WasmEnc.WASM_OP_I64_LOAD, 41)
    T.assert_equal(results, "WASM_OP_F32_LOAD is 42 (0x2A)", WasmEnc.WASM_OP_F32_LOAD, 42)
    T.assert_equal(results, "WASM_OP_F64_LOAD is 43 (0x2B)", WasmEnc.WASM_OP_F64_LOAD, 43)

    Return 1
End Process

Note: ============================================================================
Note: Opcode Ordering Verification
Note: ============================================================================

Process called "test_opcode_ordering" that takes results as Integer returns Integer:
    T.begin_suite(results, "wasm instruction_encoder: opcode ordering")

    Note: Verify opcodes are in ascending order within groups
    T.assert_equal(results, "BLOCK < LOOP", WasmEnc.WASM_OP_BLOCK is less than WasmEnc.WASM_OP_LOOP, 1)
    T.assert_equal(results, "LOOP < IF", WasmEnc.WASM_OP_LOOP is less than WasmEnc.WASM_OP_IF, 1)
    T.assert_equal(results, "IF < ELSE", WasmEnc.WASM_OP_IF is less than WasmEnc.WASM_OP_ELSE, 1)
    T.assert_equal(results, "END < BR", WasmEnc.WASM_OP_END is less than WasmEnc.WASM_OP_BR, 1)
    T.assert_equal(results, "LOCAL_GET < LOCAL_SET", WasmEnc.WASM_OP_LOCAL_GET is less than WasmEnc.WASM_OP_LOCAL_SET, 1)
    T.assert_equal(results, "LOCAL_SET < LOCAL_TEE", WasmEnc.WASM_OP_LOCAL_SET is less than WasmEnc.WASM_OP_LOCAL_TEE, 1)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_control_flow_opcodes(results)
    test_call_parametric_opcodes(results)
    test_variable_opcodes(results)
    test_memory_opcodes(results)
    test_opcode_ordering(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
