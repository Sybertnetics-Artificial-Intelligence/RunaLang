Process called "test_create_backend_interface" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_backend_interface")

    Let iface be MCI.create_backend_interface()
    T.assert_not_null(results, "create_backend_interface returns non-null", iface)

    Note: All 10 function pointers should be initialized to 0 (null)
    Let generate_asm be __load(iface, 0)
    T.assert_equal(results, "generate_assembly is null", generate_asm, 0)

    Let generate_bin be __load(iface, 8)
    T.assert_equal(results, "generate_binary is null", generate_bin, 0)

    Let emit_pro be __load(iface, 16)
    T.assert_equal(results, "emit_prologue is null", emit_pro, 0)

    Let emit_epi be __load(iface, 24)
    T.assert_equal(results, "emit_epilogue is null", emit_epi, 0)

    Let emit_instr be __load(iface, 32)
    T.assert_equal(results, "emit_instruction is null", emit_instr, 0)

    Let format_op be __load(iface, 40)
    T.assert_equal(results, "format_operand is null", format_op, 0)

    Let format_reg be __load(iface, 48)
    T.assert_equal(results, "format_register is null", format_reg, 0)

    Let get_reg_name be __load(iface, 56)
    T.assert_equal(results, "get_register_name is null", get_reg_name, 0)

    Let get_arch be __load(iface, 64)
    T.assert_equal(results, "get_arch_name is null", get_arch, 0)

    Let supports_feat be __load(iface, 72)
    T.assert_equal(results, "supports_feature is null", supports_feat, 0)

    Return 1
End Process

Note: ============================================================================
Note: Constants Verification Tests
Note: ============================================================================

Process called "test_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "constants verification")

    Note: Verify architecture constants are distinct
    T.assert_equal(results, "TARGET_ARCH_X86_64 is 1", MCI.TARGET_ARCH_X86_64, 1)
    T.assert_equal(results, "TARGET_ARCH_AARCH64 is 2", MCI.TARGET_ARCH_AARCH64, 2)
    T.assert_equal(results, "TARGET_ARCH_ARM32 is 3", MCI.TARGET_ARCH_ARM32, 3)
    T.assert_equal(results, "TARGET_ARCH_WASM32 is 10", MCI.TARGET_ARCH_WASM32, 10)

    Note: Verify OS constants
    T.assert_equal(results, "TARGET_OS_LINUX is 1", MCI.TARGET_OS_LINUX, 1)
    T.assert_equal(results, "TARGET_OS_DARWIN is 2", MCI.TARGET_OS_DARWIN, 2)
    T.assert_equal(results, "TARGET_OS_WINDOWS is 3", MCI.TARGET_OS_WINDOWS, 3)

    Note: Verify section constants
    T.assert_equal(results, "SECTION_TEXT is 1", MCI.SECTION_TEXT, 1)
    T.assert_equal(results, "SECTION_DATA is 2", MCI.SECTION_DATA, 2)
    T.assert_equal(results, "SECTION_RODATA is 3", MCI.SECTION_RODATA, 3)
    T.assert_equal(results, "SECTION_BSS is 4", MCI.SECTION_BSS, 4)

    Note: Verify relocation type constants
    T.assert_equal(results, "RELOC_TYPE_ABSOLUTE is 1", MCI.RELOC_TYPE_ABSOLUTE, 1)
    T.assert_equal(results, "RELOC_TYPE_PC_RELATIVE is 2", MCI.RELOC_TYPE_PC_RELATIVE, 2)

    Note: Verify symbol binding constants
    T.assert_equal(results, "SYMBOL_BIND_LOCAL is 0", MCI.SYMBOL_BIND_LOCAL, 0)
    T.assert_equal(results, "SYMBOL_BIND_GLOBAL is 1", MCI.SYMBOL_BIND_GLOBAL, 1)
    T.assert_equal(results, "SYMBOL_BIND_WEAK is 2", MCI.SYMBOL_BIND_WEAK, 2)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to allocate test results"
        Return 1
    End If

    test_create_assembly_output(results)
    test_create_assembly_output_null_arena(results)
    test_asm_emit_to_section(results)
    test_asm_emit_line(results)
    test_asm_get_unique_label(results)
    test_asm_register_string_literal(results)
    test_asm_add_global_symbol(results)
    test_asm_add_external_symbol(results)
    test_create_binary_output(results)
    test_binary_emit_byte(results)
    test_binary_emit_word(results)
    test_binary_emit_dword(results)
    test_binary_emit_qword(results)
    test_binary_add_relocation(results)
    test_binary_add_symbol(results)
    test_create_backend_config(results)
    test_create_backend_config_win64(results)
    test_create_backend_config_arm32(results)
    test_create_backend_config_wasm(results)
    test_config_enable_pic(results)
    test_config_enable_debug(results)
    test_config_set_output_format(results)
    test_create_backend_interface(results)
    test_constants(results)

    T.print_summary(results)

    If T.all_passed(results) is 1:
        T.destroy_test_results(results)
        Return 0
    End If

    T.destroy_test_results(results)
    Return 1
End Process
