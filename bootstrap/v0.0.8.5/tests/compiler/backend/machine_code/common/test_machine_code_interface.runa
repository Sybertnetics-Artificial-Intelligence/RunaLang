Process called "test_create_binary_output" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_binary_output")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "create_binary_output returns non-null", output)

    Note: Verify code buffer allocated (offset 0)
    Let code_buf be __load(output, 0)
    T.assert_not_null(results, "code_buffer is non-null", code_buf)

    Note: Verify code_size starts at 0 (offset 8)
    Let code_size be __load(output, 8)
    T.assert_equal(results, "code_size starts at 0", code_size, 0)

    Note: Verify code_capacity is 8192 (offset 16)
    Let code_cap be __load(output, 16)
    T.assert_equal(results, "code_capacity is 8192", code_cap, 8192)

    Note: Verify data buffer allocated (offset 24)
    Let data_buf be __load(output, 24)
    T.assert_not_null(results, "data_buffer is non-null", data_buf)

    Note: Verify data_size starts at 0 (offset 32)
    Let data_size be __load(output, 32)
    T.assert_equal(results, "data_size starts at 0", data_size, 0)

    Note: Verify data_capacity is 4096 (offset 40)
    Let data_cap be __load(output, 40)
    T.assert_equal(results, "data_capacity is 4096", data_cap, 4096)

    Note: Verify rodata buffer allocated (offset 48)
    Let rodata_buf be __load(output, 48)
    T.assert_not_null(results, "rodata_buffer is non-null", rodata_buf)

    Note: Verify rodata_size starts at 0 (offset 56)
    Let rodata_size be __load(output, 56)
    T.assert_equal(results, "rodata_size starts at 0", rodata_size, 0)

    Note: Verify rodata_capacity is 4096 (offset 64)
    Let rodata_cap be __load(output, 64)
    T.assert_equal(results, "rodata_capacity is 4096", rodata_cap, 4096)

    Note: Verify relocations list (offset 72)
    Let relocs be __load(output, 72)
    T.assert_not_null(results, "relocations list is non-null", relocs)

    Note: Verify relocation_count starts at 0 (offset 80)
    Let reloc_count be __load(output, 80)
    T.assert_equal(results, "relocation_count starts at 0", reloc_count, 0)

    Note: Verify symbols list (offset 88)
    Let syms be __load(output, 88)
    T.assert_not_null(results, "symbols list is non-null", syms)

    Note: Verify symbol_count starts at 0 (offset 96)
    Let sym_count be __load(output, 96)
    T.assert_equal(results, "symbol_count starts at 0", sym_count, 0)

    Note: Verify arena stored (offset 104)
    Let stored_arena be __load(output, 104)
    T.assert_equal(results, "arena stored correctly", stored_arena, arena)

    Return 1
End Process

Process called "test_binary_emit_byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "binary_emit_byte")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Note: Emit a single byte
    Let r1 be MCI.binary_emit_byte(output, 144)
    T.assert_equal(results, "emit byte 0x90 returns 1", r1, 1)

    Note: Verify code_size incremented to 1
    Let size1 be __load(output, 8)
    T.assert_equal(results, "code_size is 1 after first byte", size1, 1)

    Note: Verify the byte value was written correctly
    Let code_buf be __load(output, 0)
    Let byte_val be __load8(code_buf, 0)
    T.assert_equal(results, "first byte value is 144 (0x90 NOP)", byte_val, 144)

    Note: Emit several more bytes and verify size
    MCI.binary_emit_byte(output, 195)
    MCI.binary_emit_byte(output, 204)
    Let size3 be __load(output, 8)
    T.assert_equal(results, "code_size is 3 after 3 bytes", size3, 3)

    Note: Verify second and third bytes
    Let byte2 be __load8(code_buf, 1)
    T.assert_equal(results, "second byte value is 195 (0xC3 RET)", byte2, 195)
    Let byte3 be __load8(code_buf, 2)
    T.assert_equal(results, "third byte value is 204 (0xCC INT3)", byte3, 204)

    Note: Null output should fail
    Let r2 be MCI.binary_emit_byte(0, 144)
    T.assert_equal(results, "emit byte to null output returns 0", r2, 0)

    Return 1
End Process

Process called "test_binary_emit_word" that takes results as Integer returns Integer:
    T.begin_suite(results, "binary_emit_word")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Note: Emit a 16-bit word (0x1234) in little-endian
    Let r1 be MCI.binary_emit_word(output, 4660)
    T.assert_equal(results, "emit word 0x1234 returns 1", r1, 1)

    Note: Verify code_size is 2
    Let size be __load(output, 8)
    T.assert_equal(results, "code_size is 2 after word emit", size, 2)

    Note: Verify little-endian byte order
    Let code_buf be __load(output, 0)
    Let low_byte be __load8(code_buf, 0)
    Let high_byte be __load8(code_buf, 1)
    T.assert_equal(results, "low byte is 0x34", low_byte, 52)
    T.assert_equal(results, "high byte is 0x12", high_byte, 18)

    Return 1
End Process

Process called "test_binary_emit_dword" that takes results as Integer returns Integer:
    T.begin_suite(results, "binary_emit_dword")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Note: Emit a 32-bit dword (0xDEADBEEF = 3735928559) in little-endian
    Let r1 be MCI.binary_emit_dword(output, 3735928559)
    T.assert_equal(results, "emit dword 0xDEADBEEF returns 1", r1, 1)

    Note: Verify code_size is 4
    Let size be __load(output, 8)
    T.assert_equal(results, "code_size is 4 after dword emit", size, 4)

    Note: Verify little-endian byte order: EF BE AD DE
    Let code_buf be __load(output, 0)
    Let b0 be __load8(code_buf, 0)
    Let b1 be __load8(code_buf, 1)
    Let b2 be __load8(code_buf, 2)
    Let b3 be __load8(code_buf, 3)
    T.assert_equal(results, "byte 0 is 0xEF (239)", b0, 239)
    T.assert_equal(results, "byte 1 is 0xBE (190)", b1, 190)
    T.assert_equal(results, "byte 2 is 0xAD (173)", b2, 173)
    T.assert_equal(results, "byte 3 is 0xDE (222)", b3, 222)

    Return 1
End Process

Process called "test_binary_emit_qword" that takes results as Integer returns Integer:
    T.begin_suite(results, "binary_emit_qword")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Note: Emit a 64-bit qword (0x0000000000400000 = 4194304) in little-endian
    Let r1 be MCI.binary_emit_qword(output, 4194304)
    T.assert_equal(results, "emit qword returns 1", r1, 1)

    Note: Verify code_size is 8
    Let size be __load(output, 8)
    T.assert_equal(results, "code_size is 8 after qword emit", size, 8)

    Note: Verify the value: 0x400000 = 00 00 40 00 00 00 00 00 in LE
    Let code_buf be __load(output, 0)
    Let b0 be __load8(code_buf, 0)
    Let b1 be __load8(code_buf, 1)
    Let b2 be __load8(code_buf, 2)
    Let b3 be __load8(code_buf, 3)
    T.assert_equal(results, "byte 0 is 0x00", b0, 0)
    T.assert_equal(results, "byte 1 is 0x00", b1, 0)
    T.assert_equal(results, "byte 2 is 0x40 (64)", b2, 64)
    T.assert_equal(results, "byte 3 is 0x00", b3, 0)

    Return 1
End Process

Process called "test_binary_add_relocation" that takes results as Integer returns Integer:
    T.begin_suite(results, "binary_add_relocation")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Note: Add a relocation entry
    Let r1 be MCI.binary_add_relocation(output, 16, 0, MCI.RELOC_TYPE_PC_RELATIVE, -4)
    T.assert_equal(results, "add relocation returns 1", r1, 1)

    Note: Verify relocation_count incremented to 1
    Let count be __load(output, 80)
    T.assert_equal(results, "relocation_count is 1", count, 1)

    Note: Add second relocation
    Let r2 be MCI.binary_add_relocation(output, 32, 1, MCI.RELOC_TYPE_ABSOLUTE, 0)
    T.assert_equal(results, "add second relocation returns 1", r2, 1)

    Let count2 be __load(output, 80)
    T.assert_equal(results, "relocation_count is 2", count2, 2)

    Note: Null output should fail
    Let r3 be MCI.binary_add_relocation(0, 0, 0, MCI.RELOC_TYPE_ABSOLUTE, 0)
    T.assert_equal(results, "add relocation to null returns 0", r3, 0)

    Return 1
End Process

Process called "test_binary_add_symbol" that takes results as Integer returns Integer:
    T.begin_suite(results, "binary_add_symbol")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Note: Add a symbol entry
    Let name_ptr be Layout.allocate(16)
    __store8(name_ptr, 0, 109)
    __store8(name_ptr, 1, 97)
    __store8(name_ptr, 2, 105)
    __store8(name_ptr, 3, 110)
    __store8(name_ptr, 4, 0)

    Let r1 be MCI.binary_add_symbol(output, name_ptr, 0, 64, MCI.SECTION_TEXT, MCI.SYMBOL_BIND_GLOBAL, MCI.SYMBOL_TYPE_FUNC)
    T.assert_equal(results, "add symbol returns 1", r1, 1)

    Note: Verify symbol_count incremented to 1
    Let count be __load(output, 96)
    T.assert_equal(results, "symbol_count is 1", count, 1)

    Note: Add a second symbol
    Let r2 be MCI.binary_add_symbol(output, name_ptr, 64, 32, MCI.SECTION_DATA, MCI.SYMBOL_BIND_LOCAL, MCI.SYMBOL_TYPE_OBJECT)
    T.assert_equal(results, "add second symbol returns 1", r2, 1)

    Let count2 be __load(output, 96)
    T.assert_equal(results, "symbol_count is 2", count2, 2)

    Note: Null output should fail
    Let r3 be MCI.binary_add_symbol(0, name_ptr, 0, 0, 0, 0, 0)
    T.assert_equal(results, "add symbol to null returns 0", r3, 0)

    Return 1
End Process

Note: ============================================================================
Note: Backend Configuration Tests
Note: ============================================================================

Process called "test_create_backend_config" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_backend_config")

    Note: Create a config for x86_64 Linux with standard optimization
    Let config be MCI.create_backend_config(MCI.TARGET_ARCH_X86_64, MCI.TARGET_OS_LINUX, MCI.OPT_LEVEL_STANDARD)
    T.assert_not_null(results, "config created for x86_64 Linux", config)

    Note: Verify stored arch (offset 0)
    Let arch be __load(config, 0)
    T.assert_equal(results, "arch is TARGET_ARCH_X86_64", arch, MCI.TARGET_ARCH_X86_64)

    Note: Verify stored OS (offset 8)
    Let os be __load(config, 8)
    T.assert_equal(results, "os is TARGET_OS_LINUX", os, MCI.TARGET_OS_LINUX)

    Note: Verify optimization level (offset 16)
    Let opt_level be __load(config, 16)
    T.assert_equal(results, "opt_level is OPT_LEVEL_STANDARD", opt_level, MCI.OPT_LEVEL_STANDARD)

    Note: Verify default output format is ASM (offset 24)
    Let output_fmt be __load(config, 24)
    T.assert_equal(results, "output_format defaults to ASM", output_fmt, MCI.OUTPUT_FORMAT_ASM)

    Note: Verify ASM syntax is ATT for x86_64 (offset 32)
    Let syntax be __load(config, 32)
    T.assert_equal(results, "asm_syntax is ATT for x86_64", syntax, MCI.ASM_SYNTAX_ATT)

    Note: Verify PIC disabled by default (offset 40)
    Let pic be __load(config, 40)
    T.assert_equal(results, "PIC disabled by default", pic, 0)

    Note: Verify debug info disabled by default (offset 48)
    Let debug be __load(config, 48)
    T.assert_equal(results, "debug info disabled by default", debug, 0)

    Note: Verify frame pointer enabled by default (offset 56)
    Let fp be __load(config, 56)
    T.assert_equal(results, "frame pointer enabled by default", fp, 1)

    Note: Verify pointer size is 8 for x86_64 (offset 64)
    Let ptr_size be __load(config, 64)
    T.assert_equal(results, "pointer_size is 8 for x86_64", ptr_size, 8)

    Note: Verify stack alignment is 16 for x86_64 (offset 72)
    Let stack_align be __load(config, 72)
    T.assert_equal(results, "stack_alignment is 16 for x86_64", stack_align, 16)

    Note: Verify red zone is 128 for Linux x86_64 (offset 80)
    Let red_zone be __load(config, 80)
    T.assert_equal(results, "red_zone_size is 128 for System V x86_64", red_zone, 128)

    Return 1
End Process

Process called "test_create_backend_config_win64" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_backend_config - Win64")

    Note: Windows x86_64 should have red zone = 0
    Let config be MCI.create_backend_config(MCI.TARGET_ARCH_X86_64, MCI.TARGET_OS_WINDOWS, MCI.OPT_LEVEL_NONE)
    T.assert_not_null(results, "config created for Win64", config)

    Let red_zone be __load(config, 80)
    T.assert_equal(results, "red_zone_size is 0 for Win64", red_zone, 0)

    Let ptr_size be __load(config, 64)
    T.assert_equal(results, "pointer_size is 8 for Win64", ptr_size, 8)

    Return 1
End Process

Process called "test_create_backend_config_arm32" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_backend_config - ARM32")

    Let config be MCI.create_backend_config(MCI.TARGET_ARCH_ARM32, MCI.TARGET_OS_LINUX, MCI.OPT_LEVEL_BASIC)
    T.assert_not_null(results, "config created for ARM32 Linux", config)

    Note: ARM32 should use ARM syntax
    Let syntax be __load(config, 32)
    T.assert_equal(results, "asm_syntax is ARM for ARM32", syntax, MCI.ASM_SYNTAX_ARM)

    Note: ARM32 pointer size is 4
    Let ptr_size be __load(config, 64)
    T.assert_equal(results, "pointer_size is 4 for ARM32", ptr_size, 4)

    Note: ARM32 stack alignment is 8
    Let stack_align be __load(config, 72)
    T.assert_equal(results, "stack_alignment is 8 for ARM32", stack_align, 8)

    Note: ARM32 has no red zone
    Let red_zone be __load(config, 80)
    T.assert_equal(results, "red_zone_size is 0 for ARM32", red_zone, 0)

    Return 1
End Process

Process called "test_create_backend_config_wasm" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_backend_config - WASM32")

    Let config be MCI.create_backend_config(MCI.TARGET_ARCH_WASM32, MCI.TARGET_OS_WASI, MCI.OPT_LEVEL_SIZE)
    T.assert_not_null(results, "config created for WASM32", config)

    Note: WASM32 should use WAT syntax
    Let syntax be __load(config, 32)
    T.assert_equal(results, "asm_syntax is WAT for WASM32", syntax, MCI.ASM_SYNTAX_WAT)

    Note: WASM32 pointer size is 4
    Let ptr_size be __load(config, 64)
    T.assert_equal(results, "pointer_size is 4 for WASM32", ptr_size, 4)

    Note: WASM has no stack alignment
    Let stack_align be __load(config, 72)
    T.assert_equal(results, "stack_alignment is 0 for WASM32", stack_align, 0)

    Return 1
End Process

Process called "test_config_enable_pic" that takes results as Integer returns Integer:
    T.begin_suite(results, "config_enable_pic")

    Let config be MCI.create_backend_config(MCI.TARGET_ARCH_X86_64, MCI.TARGET_OS_LINUX, MCI.OPT_LEVEL_STANDARD)
    T.assert_not_null(results, "config created", config)

    Note: PIC should be 0 initially
    Let pic_before be __load(config, 40)
    T.assert_equal(results, "PIC is 0 before enable", pic_before, 0)

    Note: Enable PIC
    Let r1 be MCI.config_enable_pic(config)
    T.assert_equal(results, "config_enable_pic returns 1", r1, 1)

    Note: PIC should now be 1
    Let pic_after be __load(config, 40)
    T.assert_equal(results, "PIC is 1 after enable", pic_after, 1)

    Note: Null config should fail
    Let r2 be MCI.config_enable_pic(0)
    T.assert_equal(results, "config_enable_pic on null returns 0", r2, 0)

    Return 1
End Process

Process called "test_config_enable_debug" that takes results as Integer returns Integer:
    T.begin_suite(results, "config_enable_debug")

    Let config be MCI.create_backend_config(MCI.TARGET_ARCH_X86_64, MCI.TARGET_OS_LINUX, MCI.OPT_LEVEL_NONE)
    T.assert_not_null(results, "config created", config)

    Let debug_before be __load(config, 48)
    T.assert_equal(results, "debug is 0 before enable", debug_before, 0)

    Let r1 be MCI.config_enable_debug(config)
    T.assert_equal(results, "config_enable_debug returns 1", r1, 1)

    Let debug_after be __load(config, 48)
    T.assert_equal(results, "debug is 1 after enable", debug_after, 1)

    Return 1
End Process

Process called "test_config_set_output_format" that takes results as Integer returns Integer:
    T.begin_suite(results, "config_set_output_format")

    Let config be MCI.create_backend_config(MCI.TARGET_ARCH_X86_64, MCI.TARGET_OS_LINUX, MCI.OPT_LEVEL_STANDARD)
    T.assert_not_null(results, "config created", config)

    Note: Default is ASM
    Let fmt_before be __load(config, 24)
    T.assert_equal(results, "default format is ASM", fmt_before, MCI.OUTPUT_FORMAT_ASM)

    Note: Change to EXECUTABLE
    Let r1 be MCI.config_set_output_format(config, MCI.OUTPUT_FORMAT_EXECUTABLE)
    T.assert_equal(results, "config_set_output_format returns 1", r1, 1)

    Let fmt_after be __load(config, 24)
    T.assert_equal(results, "format changed to EXECUTABLE", fmt_after, MCI.OUTPUT_FORMAT_EXECUTABLE)

    Note: Change to OBJECT
    MCI.config_set_output_format(config, MCI.OUTPUT_FORMAT_OBJECT)
    Let fmt_obj be __load(config, 24)
    T.assert_equal(results, "format changed to OBJECT", fmt_obj, MCI.OUTPUT_FORMAT_OBJECT)

    Note: Null config should fail
    Let r2 be MCI.config_set_output_format(0, MCI.OUTPUT_FORMAT_ASM)
    T.assert_equal(results, "set_output_format on null returns 0", r2, 0)

    Return 1
End Process

