Note:
Unit Tests for machine_code_interface.runa

Exercises the 23 processes that make up the architecture abstraction layer:
assembly output creation, section-aware emission, unique label generation,
string literal deduplication, binary output operations, backend configuration,
and backend interface creation.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/internal/memory_utils.runa" as MemoryUtils

Note: ============================================================================
Note: Assembly Output Tests
Note: ============================================================================

Process called "test_create_assembly_output" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_assembly_output")

    Note: Create an arena for allocation
    Let arena be MemoryUtils.allocate(65536)
    T.assert_not_null(results, "arena allocation succeeds", arena)

    Note: Create assembly output
    Let output be MCI.create_assembly_output(arena)
    T.assert_not_null(results, "create_assembly_output returns non-null", output)

    Note: Verify text_section buffer was created (offset 0)
    Let text_buf be __load(output, 0)
    T.assert_not_null(results, "text_section buffer is non-null", text_buf)

    Note: Verify data_section buffer was created (offset 8)
    Let data_buf be __load(output, 8)
    T.assert_not_null(results, "data_section buffer is non-null", data_buf)

    Note: Verify rodata_section buffer was created (offset 16)
    Let rodata_buf be __load(output, 16)
    T.assert_not_null(results, "rodata_section buffer is non-null", rodata_buf)

    Note: Verify bss_section buffer was created (offset 24)
    Let bss_buf be __load(output, 24)
    T.assert_not_null(results, "bss_section buffer is non-null", bss_buf)

    Note: Verify string literal dictionary was created (offset 32)
    Let str_dict be __load(output, 32)
    T.assert_not_null(results, "string_literals dictionary is non-null", str_dict)

    Note: Verify string_literal_count starts at 0 (offset 40)
    Let str_count be __load(output, 40)
    T.assert_equal(results, "string_literal_count starts at 0", str_count, 0)

    Note: Verify label_counter starts at 0 (offset 64)
    Let label_counter be __load(output, 64)
    T.assert_equal(results, "label_counter starts at 0", label_counter, 0)

    Note: Verify current_section defaults to SECTION_TEXT (offset 72)
    Let current_section be __load(output, 72)
    T.assert_equal(results, "current_section defaults to SECTION_TEXT", current_section, MCI.SECTION_TEXT)

    Note: Verify total_lines starts at 0 (offset 80)
    Let total_lines be __load(output, 80)
    T.assert_equal(results, "total_lines starts at 0", total_lines, 0)

    Note: Verify arena pointer stored (offset 88)
    Let stored_arena be __load(output, 88)
    T.assert_equal(results, "arena pointer stored correctly", stored_arena, arena)

    Note: Verify global_symbols list created (offset 48)
    Let globals be __load(output, 48)
    T.assert_not_null(results, "global_symbols list is non-null", globals)

    Note: Verify external_symbols list created (offset 56)
    Let externals be __load(output, 56)
    T.assert_not_null(results, "external_symbols list is non-null", externals)

    Return 1
End Process

Process called "test_create_assembly_output_null_arena" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_assembly_output with null arena")

    Note: Passing 0 as arena should still work (the arena is stored, not used for main alloc)
    Let output be MCI.create_assembly_output(0)
    Note: The function stores the arena pointer but uses Layout.allocate for the struct
    Note: So it should still return non-null if Layout.allocate succeeds
    T.assert_not_null(results, "create_assembly_output with arena=0 returns non-null", output)

    Return 1
End Process

Process called "test_asm_emit_to_section" that takes results as Integer returns Integer:
    T.begin_suite(results, "asm_emit_to_section")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_assembly_output(arena)
    T.assert_not_null(results, "assembly output created", output)

    Note: Emit to TEXT section
    Let r1 be MCI.asm_emit_to_section(output, MCI.SECTION_TEXT, "mov %rax, %rbx")
    T.assert_equal(results, "emit to TEXT returns 1", r1, 1)

    Note: Emit to DATA section
    Let r2 be MCI.asm_emit_to_section(output, MCI.SECTION_DATA, ".long 42")
    T.assert_equal(results, "emit to DATA returns 1", r2, 1)

    Note: Emit to RODATA section
    Let r3 be MCI.asm_emit_to_section(output, MCI.SECTION_RODATA, ".string \"hello\"")
    T.assert_equal(results, "emit to RODATA returns 1", r3, 1)

    Note: Emit to BSS section
    Let r4 be MCI.asm_emit_to_section(output, MCI.SECTION_BSS, ".comm buffer,4096")
    T.assert_equal(results, "emit to BSS returns 1", r4, 1)

    Note: Verify total_lines incremented (one per emit call)
    Let total_lines be __load(output, 80)
    T.assert_equal(results, "total_lines is 4 after 4 emits", total_lines, 4)

    Note: Emit to null output should return 0
    Let r5 be MCI.asm_emit_to_section(0, MCI.SECTION_TEXT, "nop")
    T.assert_equal(results, "emit to null output returns 0", r5, 0)

    Note: Emit to invalid section should return 0 (buffer will be 0)
    Let r6 be MCI.asm_emit_to_section(output, 99, "nop")
    T.assert_equal(results, "emit to invalid section returns 0", r6, 0)

    Return 1
End Process

Process called "test_asm_emit_line" that takes results as Integer returns Integer:
    T.begin_suite(results, "asm_emit_line")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_assembly_output(arena)
    T.assert_not_null(results, "assembly output created", output)

    Note: Emit a line to TEXT section (should append text + newline)
    Let r1 be MCI.asm_emit_line(output, MCI.SECTION_TEXT, "\tpushq %rbp")
    T.assert_equal(results, "asm_emit_line to TEXT returns 1", r1, 1)

    Note: Emit a line to DATA section
    Let r2 be MCI.asm_emit_line(output, MCI.SECTION_DATA, "myvar:")
    T.assert_equal(results, "asm_emit_line to DATA returns 1", r2, 1)

    Note: Emit a line to RODATA section
    Let r3 be MCI.asm_emit_line(output, MCI.SECTION_RODATA, ".align 8")
    T.assert_equal(results, "asm_emit_line to RODATA returns 1", r3, 1)

    Note: Emit a line to BSS section
    Let r4 be MCI.asm_emit_line(output, MCI.SECTION_BSS, ".lcomm scratch,256")
    T.assert_equal(results, "asm_emit_line to BSS returns 1", r4, 1)

    Note: Null output should fail
    Let r5 be MCI.asm_emit_line(0, MCI.SECTION_TEXT, "nop")
    T.assert_equal(results, "asm_emit_line with null output returns 0", r5, 0)

    Return 1
End Process

Process called "test_asm_get_unique_label" that takes results as Integer returns Integer:
    T.begin_suite(results, "asm_get_unique_label")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_assembly_output(arena)
    T.assert_not_null(results, "assembly output created", output)

    Note: First label should be 0
    Let label0 be MCI.asm_get_unique_label(output)
    T.assert_equal(results, "first unique label is 0", label0, 0)

    Note: Second label should be 1
    Let label1 be MCI.asm_get_unique_label(output)
    T.assert_equal(results, "second unique label is 1", label1, 1)

    Note: Third label should be 2
    Let label2 be MCI.asm_get_unique_label(output)
    T.assert_equal(results, "third unique label is 2", label2, 2)

    Note: Counter stored at offset 64 should now be 3
    Let counter be __load(output, 64)
    T.assert_equal(results, "label_counter is 3 after 3 calls", counter, 3)

    Note: Generate several more and verify monotonic increase
    Let label3 be MCI.asm_get_unique_label(output)
    Let label4 be MCI.asm_get_unique_label(output)
    T.assert_equal(results, "fourth label is 3", label3, 3)
    T.assert_equal(results, "fifth label is 4", label4, 4)

    Note: Null output should return 0
    Let label_null be MCI.asm_get_unique_label(0)
    T.assert_equal(results, "unique_label with null output returns 0", label_null, 0)

    Return 1
End Process

Process called "test_asm_register_string_literal" that takes results as Integer returns Integer:
    T.begin_suite(results, "asm_register_string_literal")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_assembly_output(arena)
    T.assert_not_null(results, "assembly output created", output)

    Note: Register first string literal
    Let label1 be MCI.asm_register_string_literal(output, "Hello, world!")
    T.assert_not_null(results, "first string literal label is non-null", label1)

    Note: Register second string literal (different content)
    Let label2 be MCI.asm_register_string_literal(output, "Goodbye!")
    T.assert_not_null(results, "second string literal label is non-null", label2)

    Note: Register duplicate string (same as first) - should return same label
    Let label_dup be MCI.asm_register_string_literal(output, "Hello, world!")
    T.assert_equal(results, "duplicate string returns same label", label_dup, label1)

    Note: Verify string_literal_count (offset 40) is 2 (not 3, because of dedup)
    Let str_count be __load(output, 40)
    T.assert_equal(results, "string_literal_count is 2 after dedup", str_count, 2)

    Note: Register a third unique string
    Let label3 be MCI.asm_register_string_literal(output, "Third string")
    T.assert_not_null(results, "third unique string label is non-null", label3)

    Note: Count should now be 3
    Let str_count2 be __load(output, 40)
    T.assert_equal(results, "string_literal_count is 3 after third unique", str_count2, 3)

    Note: Null output should return 0
    Let label_null be MCI.asm_register_string_literal(0, "test")
    T.assert_equal(results, "register with null output returns 0", label_null, 0)

    Return 1
End Process

Process called "test_asm_add_global_symbol" that takes results as Integer returns Integer:
    T.begin_suite(results, "asm_add_global_symbol")

    Let arena be MemoryUtils.allocate(65536)
    Let output be MCI.create_assembly_output(arena)
