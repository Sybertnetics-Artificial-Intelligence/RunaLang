Process called "test_linker_set_entry_point" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker_set_entry_point and linker_get_entry_address")

    Let ctx be Linker.create_linker_context()
    T.assert_not_null(results, "linker context created", ctx)

    Note: Set entry point
    Let r1 be Linker.linker_set_entry_point(ctx, "_start")
    T.assert_equal(results, "linker_set_entry_point returns LINKER_OK", r1, Linker.LINKER_OK)

    Note: Verify entry_point_name stored (offset 104)
    Let stored_name be __load(ctx, 104)
    T.assert_not_null(results, "entry_point_name is non-null", stored_name)

    Note: Null context should fail
    Let r2 be Linker.linker_set_entry_point(0, "_start")
    T.assert_equal(results, "set_entry_point on null context returns error", r2, Linker.LINKER_ERROR)

    Note: Null name should fail
    Let r3 be Linker.linker_set_entry_point(ctx, 0)
    T.assert_equal(results, "set_entry_point with null name returns error", r3, Linker.LINKER_ERROR)

    Return 1
End Process

Process called "test_linker_get_unresolved_count" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker_get_unresolved_count")

    Let ctx be Linker.create_linker_context()
    T.assert_not_null(results, "linker context created", ctx)

    Note: Initially 0 unresolved symbols
    Let count0 be Linker.linker_get_unresolved_count(ctx)
    T.assert_equal(results, "initial unresolved count is 0", count0, 0)

    Note: Null context should return 0
    Let null_count be Linker.linker_get_unresolved_count(0)
    T.assert_equal(results, "null context returns 0", null_count, 0)

    Return 1
End Process

Process called "test_linker_set_text_base" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker_set_text_base_address")

    Let ctx be Linker.create_linker_context()
    T.assert_not_null(results, "linker context created", ctx)

    Note: Default is 0x400000
    Let default_base be __load(ctx, 96)
    T.assert_equal(results, "default text_base is 0x400000", default_base, 4194304)

    Note: Change to a different base
    Let r1 be Linker.linker_set_text_base_address(ctx, 8388608)
    T.assert_equal(results, "set_text_base_address returns LINKER_OK", r1, Linker.LINKER_OK)

    Let new_base be __load(ctx, 96)
    T.assert_equal(results, "text_base changed to 0x800000", new_base, 8388608)

    Note: Null context should fail
    Let r2 be Linker.linker_set_text_base_address(0, 4194304)
    T.assert_equal(results, "set_text_base on null returns error", r2, Linker.LINKER_ERROR)

    Return 1
End Process

Note: ============================================================================
Note: Full Linking Pipeline Test
Note: ============================================================================

Process called "test_linker_link" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker_link - full pipeline")

    Let ctx be Linker.create_linker_context()
    T.assert_not_null(results, "linker context created", ctx)

    Note: Create an object file with code and a global symbol
    Let obj be Linker.create_object_file("complete.o")

    Note: 8 bytes of code (NOP NOP NOP NOP NOP NOP NOP RET)
    Let code_buf be Layout.allocate(32)
    __store8(code_buf, 0, 144)
    __store8(code_buf, 1, 144)
    __store8(code_buf, 2, 144)
    __store8(code_buf, 3, 144)
    __store8(code_buf, 4, 144)
    __store8(code_buf, 5, 144)
    __store8(code_buf, 6, 144)
    __store8(code_buf, 7, 195)
    Linker.object_file_set_text(obj, code_buf, 8)

    Note: Add a global symbol for the function
    Let sym be make_symbol("_start", 0, 8, Linker.LINKER_SECTION_TEXT, MCI.SYMBOL_BIND_GLOBAL, MCI.SYMBOL_TYPE_FUNC, 1)
    Linker.object_file_add_symbol(obj, sym)

    Linker.linker_add_object(ctx, obj)
    Linker.linker_set_entry_point(ctx, "_start")

    Note: Run the full link pipeline
    Let link_result be Linker.linker_link(ctx)
    T.assert_equal(results, "linker_link returns LINKER_OK", link_result, Linker.LINKER_OK)

    Note: Verify merged text
    Let merged_text_size be Linker.linker_get_merged_text_size(ctx)
    T.assert_equal(results, "merged text size is 8", merged_text_size, 8)

    Note: Verify symbol resolved
    Let has_start be Linker.linker_has_symbol(ctx, "_start")
    T.assert_equal(results, "has_symbol('_start') after link", has_start, 1)

    Note: Verify entry address
    Let entry_addr be Linker.linker_get_entry_address(ctx)
    T.assert_equal(results, "entry address is 0x400000", entry_addr, 4194304)

    Note: Verify no unresolved symbols
    Let unresolved be Linker.linker_get_unresolved_count(ctx)
    T.assert_equal(results, "0 unresolved symbols after link", unresolved, 0)

    Layout.deallocate(code_buf)

    Return 1
End Process

Process called "test_linker_link_null_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker_link - null context")

    Let result be Linker.linker_link(0)
    T.assert_equal(results, "linker_link with null returns error", result, Linker.LINKER_ERROR)

    Return 1
End Process

