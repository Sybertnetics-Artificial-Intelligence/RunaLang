Note:
Unit Tests for linker.runa

Exercises the 26 processes of the static linker: context creation, object file
creation, section setting, object addition, section merging, symbol collection,
symbol resolution, relocation application, full linking pipeline, and accessor/
diagnostic functions.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/common/linker.runa" as Linker
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dictionary

Note: ============================================================================
Note: Helper: Create a SymbolEntry for testing
Note: ============================================================================

Process called "make_symbol" that takes name as Integer, value as Integer, size as Integer, section as Integer, binding as Integer, sym_type as Integer, is_defined as Integer returns Integer:
    Note: Allocates and fills a SymbolEntry (64 bytes, 8 fields)
    Let entry be Layout.allocate(64)
    If entry is 0:
        Return 0
    End If
    __store(entry, 0, name)
    __store(entry, 8, value)
    __store(entry, 16, size)
    __store(entry, 24, section)
    __store(entry, 32, binding)
    __store(entry, 40, sym_type)
    __store(entry, 48, is_defined)
    __store(entry, 56, 0)
    Return entry
End Process

Note: ============================================================================
Note: LinkerContext Creation Tests
Note: ============================================================================

Process called "test_create_linker_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_linker_context")

    Let ctx be Linker.create_linker_context()
    T.assert_not_null(results, "create_linker_context returns non-null", ctx)

    Note: Verify objects list created (offset 0)
    Let objects be __load(ctx, 0)
    T.assert_not_null(results, "objects list is non-null", objects)

    Note: Verify merged_text buffer allocated (offset 8)
    Let text_buf be __load(ctx, 8)
    T.assert_not_null(results, "merged_text buffer is non-null", text_buf)

    Note: Verify merged_text_size starts at 0 (offset 16)
    Let text_size be __load(ctx, 16)
    T.assert_equal(results, "merged_text_size starts at 0", text_size, 0)

    Note: Verify merged_text_capacity is 16384 (offset 24)
    Let text_cap be __load(ctx, 24)
    T.assert_equal(results, "merged_text_capacity is 16384", text_cap, 16384)

    Note: Verify merged_data buffer allocated (offset 32)
    Let data_buf be __load(ctx, 32)
    T.assert_not_null(results, "merged_data buffer is non-null", data_buf)

    Note: Verify merged_data_size starts at 0 (offset 40)
    Let data_size be __load(ctx, 40)
    T.assert_equal(results, "merged_data_size starts at 0", data_size, 0)

    Note: Verify merged_data_capacity (offset 48)
    Let data_cap be __load(ctx, 48)
    T.assert_equal(results, "merged_data_capacity is 16384", data_cap, 16384)

    Note: Verify merged_rodata buffer allocated (offset 56)
    Let rodata_buf be __load(ctx, 56)
    T.assert_not_null(results, "merged_rodata buffer is non-null", rodata_buf)

    Note: Verify global_symbol_table created (offset 80)
    Let sym_table be __load(ctx, 80)
    T.assert_not_null(results, "global_symbol_table is non-null", sym_table)

    Note: Verify unresolved_symbols list created (offset 88)
    Let unresolved be __load(ctx, 88)
    T.assert_not_null(results, "unresolved_symbols list is non-null", unresolved)

    Note: Verify text_base_address defaults to 0x400000 (offset 96)
    Let text_base be __load(ctx, 96)
    T.assert_equal(results, "text_base_address defaults to 0x400000", text_base, 4194304)

    Note: Verify entry_point_name is 0 (offset 104)
    Let entry_name be __load(ctx, 104)
    T.assert_equal(results, "entry_point_name defaults to 0", entry_name, 0)

    Return 1
End Process

Note: ============================================================================
Note: ObjectFile Creation Tests
Note: ============================================================================

Process called "test_create_object_file" that takes results as Integer returns Integer:
    T.begin_suite(results, "create_object_file")

    Let obj be Linker.create_object_file("test_module.o")
    T.assert_not_null(results, "create_object_file returns non-null", obj)

    Note: Verify name stored (offset 0)
    Let name be __load(obj, 0)
    T.assert_not_null(results, "object name is non-null", name)

    Note: Verify all section buffers start at 0
    Let text_buf be __load(obj, 8)
    T.assert_equal(results, "text_buffer starts at 0", text_buf, 0)

    Let text_size be __load(obj, 16)
    T.assert_equal(results, "text_size starts at 0", text_size, 0)

    Let data_buf be __load(obj, 24)
    T.assert_equal(results, "data_buffer starts at 0", data_buf, 0)

    Let rodata_buf be __load(obj, 40)
    T.assert_equal(results, "rodata_buffer starts at 0", rodata_buf, 0)

    Note: Verify symbol list created (offset 56)
    Let sym_list be __load(obj, 56)
    T.assert_not_null(results, "symbols list is non-null", sym_list)

    Note: Verify relocation list created (offset 64)
    Let reloc_list be __load(obj, 64)
    T.assert_not_null(results, "relocations list is non-null", reloc_list)

    Note: Verify base offsets start at 0
    Let text_base be __load(obj, 72)
    T.assert_equal(results, "text_base_offset starts at 0", text_base, 0)

    Let sym_count be __load(obj, 96)
    T.assert_equal(results, "symbol_count starts at 0", sym_count, 0)

    Return 1
End Process

Note: ============================================================================
Note: ObjectFile Section Setting Tests
Note: ============================================================================

Process called "test_object_file_set_sections" that takes results as Integer returns Integer:
    T.begin_suite(results, "object_file_set_text/data/rodata")

    Let obj be Linker.create_object_file("sections.o")
    T.assert_not_null(results, "object file created", obj)

    Note: Create a text buffer with 8 bytes
    Let text_buf be Layout.allocate(64)
    __store8(text_buf, 0, 144)
    __store8(text_buf, 1, 195)

    Let r1 be Linker.object_file_set_text(obj, text_buf, 8)
    T.assert_equal(results, "object_file_set_text returns 1", r1, Linker.LINKER_OK)

    Note: Verify text_buffer stored (offset 8)
    Let stored_text be __load(obj, 8)
    T.assert_equal(results, "text_buffer stored correctly", stored_text, text_buf)

    Note: Verify text_size stored (offset 16)
    Let stored_text_size be __load(obj, 16)
    T.assert_equal(results, "text_size is 8", stored_text_size, 8)

    Note: Create and set data buffer
    Let data_buf be Layout.allocate(32)
    __store8(data_buf, 0, 42)

    Let r2 be Linker.object_file_set_data(obj, data_buf, 16)
    T.assert_equal(results, "object_file_set_data returns 1", r2, Linker.LINKER_OK)

    Let stored_data be __load(obj, 24)
    T.assert_equal(results, "data_buffer stored correctly", stored_data, data_buf)

    Let stored_data_size be __load(obj, 32)
    T.assert_equal(results, "data_size is 16", stored_data_size, 16)

    Note: Create and set rodata buffer
    Let rodata_buf be Layout.allocate(32)
    __store8(rodata_buf, 0, 72)

    Let r3 be Linker.object_file_set_rodata(obj, rodata_buf, 4)
    T.assert_equal(results, "object_file_set_rodata returns 1", r3, Linker.LINKER_OK)

    Let stored_rodata be __load(obj, 40)
    T.assert_equal(results, "rodata_buffer stored correctly", stored_rodata, rodata_buf)

    Let stored_rodata_size be __load(obj, 48)
    T.assert_equal(results, "rodata_size is 4", stored_rodata_size, 4)

    Note: Null object should fail
    Let r4 be Linker.object_file_set_text(0, text_buf, 8)
    T.assert_equal(results, "set_text on null returns error", r4, Linker.LINKER_ERROR)

    Layout.deallocate(text_buf)
    Layout.deallocate(data_buf)
    Layout.deallocate(rodata_buf)

    Return 1
End Process

Note: ============================================================================
Note: Linker Add Object Tests
Note: ============================================================================

Process called "test_linker_add_object" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker_add_object")

    Let ctx be Linker.create_linker_context()
    T.assert_not_null(results, "linker context created", ctx)

    Note: Initial object count should be 0
    Let count0 be Linker.linker_get_object_count(ctx)
    T.assert_equal(results, "initial object count is 0", count0, 0)

    Note: Add first object
    Let obj1 be Linker.create_object_file("first.o")
    Let r1 be Linker.linker_add_object(ctx, obj1)
    T.assert_equal(results, "add first object returns LINKER_OK", r1, Linker.LINKER_OK)

    Let count1 be Linker.linker_get_object_count(ctx)
    T.assert_equal(results, "object count is 1 after first add", count1, 1)

    Note: Add second object
    Let obj2 be Linker.create_object_file("second.o")
    Let r2 be Linker.linker_add_object(ctx, obj2)
    T.assert_equal(results, "add second object returns LINKER_OK", r2, Linker.LINKER_OK)

    Let count2 be Linker.linker_get_object_count(ctx)
    T.assert_equal(results, "object count is 2 after second add", count2, 2)

    Note: Add third object
    Let obj3 be Linker.create_object_file("third.o")
    Linker.linker_add_object(ctx, obj3)

    Let count3 be Linker.linker_get_object_count(ctx)
    T.assert_equal(results, "object count is 3 after third add", count3, 3)

    Note: Null context should fail
    Let r_null_ctx be Linker.linker_add_object(0, obj1)
    T.assert_equal(results, "add to null context returns error", r_null_ctx, Linker.LINKER_ERROR)

    Note: Null object should fail
    Let r_null_obj be Linker.linker_add_object(ctx, 0)
    T.assert_equal(results, "add null object returns error", r_null_obj, Linker.LINKER_ERROR)

    Return 1
End Process

Note: ============================================================================
Note: Section Merging Tests
Note: ============================================================================

Process called "test_linker_merge_sections" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker_merge_sections")

    Let ctx be Linker.create_linker_context()
    T.assert_not_null(results, "linker context created", ctx)

    Note: Create first object with 4 bytes of text
    Let obj1 be Linker.create_object_file("a.o")
    Let text1 be Layout.allocate(16)
    __store8(text1, 0, 10)
    __store8(text1, 1, 20)
    __store8(text1, 2, 30)
    __store8(text1, 3, 40)
    Linker.object_file_set_text(obj1, text1, 4)

    Note: Create second object with 3 bytes of text
    Let obj2 be Linker.create_object_file("b.o")
    Let text2 be Layout.allocate(16)
    __store8(text2, 0, 50)
    __store8(text2, 1, 60)
    __store8(text2, 2, 70)
    Linker.object_file_set_text(obj2, text2, 3)

    Linker.linker_add_object(ctx, obj1)
    Linker.linker_add_object(ctx, obj2)

    Note: Merge sections
    Let merge_result be Linker.linker_merge_sections(ctx)
    T.assert_equal(results, "merge_sections returns LINKER_OK", merge_result, Linker.LINKER_OK)

    Note: Verify merged text size is 7 (4 + 3)
    Let merged_text_size be Linker.linker_get_merged_text_size(ctx)
    T.assert_equal(results, "merged text size is 7", merged_text_size, 7)

    Note: Verify merged text content
    Let merged_text be Linker.linker_get_merged_text(ctx)
    T.assert_not_null(results, "merged text buffer is non-null", merged_text)

    Let mb0 be __load8(merged_text, 0)
    T.assert_equal(results, "merged byte 0 is 10", mb0, 10)

    Let mb3 be __load8(merged_text, 3)
    T.assert_equal(results, "merged byte 3 is 40", mb3, 40)

    Let mb4 be __load8(merged_text, 4)
    T.assert_equal(results, "merged byte 4 is 50 (from second object)", mb4, 50)

    Let mb6 be __load8(merged_text, 6)
    T.assert_equal(results, "merged byte 6 is 70", mb6, 70)

    Note: Verify object base offsets were recorded
    Note: obj1 text_base_offset should be 0 (first object)
    Let obj1_text_base be __load(obj1, 72)
    T.assert_equal(results, "obj1 text_base_offset is 0", obj1_text_base, 0)

    Note: obj2 text_base_offset should be 4 (after obj1's 4 bytes)
    Let obj2_text_base be __load(obj2, 72)
    T.assert_equal(results, "obj2 text_base_offset is 4", obj2_text_base, 4)

    Note: Verify data and rodata are still 0 (no data sections in test objects)
    Let merged_data_size be Linker.linker_get_merged_data_size(ctx)
    T.assert_equal(results, "merged data size is 0", merged_data_size, 0)

    Let merged_rodata_size be Linker.linker_get_merged_rodata_size(ctx)
    T.assert_equal(results, "merged rodata size is 0", merged_rodata_size, 0)

    Layout.deallocate(text1)
    Layout.deallocate(text2)

    Return 1
End Process

Note: ============================================================================
Note: Symbol Collection Tests
Note: ============================================================================

Process called "test_linker_collect_symbols" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker_collect_symbols")

    Let ctx be Linker.create_linker_context()
    T.assert_not_null(results, "linker context created", ctx)

    Note: Create an object with a global "main" symbol
    Let obj be Linker.create_object_file("main.o")
    Let text_buf be Layout.allocate(32)
    __store8(text_buf, 0, 195)
    Linker.object_file_set_text(obj, text_buf, 16)

    Note: Create a global function symbol at offset 0 in .text
    Let sym be make_symbol("main", 0, 16, Linker.LINKER_SECTION_TEXT, MCI.SYMBOL_BIND_GLOBAL, MCI.SYMBOL_TYPE_FUNC, 1)
    Linker.object_file_add_symbol(obj, sym)

    Linker.linker_add_object(ctx, obj)

    Note: Merge sections first (required before collect)
    Linker.linker_merge_sections(ctx)

    Note: Collect symbols
    Let collect_result be Linker.linker_collect_symbols(ctx)
    T.assert_equal(results, "collect_symbols returns LINKER_OK", collect_result, Linker.LINKER_OK)

    Note: Verify "main" is in the global symbol table
    Let has_main be Linker.linker_has_symbol(ctx, "main")
    T.assert_equal(results, "has_symbol('main') returns 1", has_main, 1)

    Note: Verify the resolved address
    Note: Address = text_base (0x400000) + section_base (0) + symbol_value (0)
    Let main_addr be Linker.linker_get_symbol_address(ctx, "main")
    T.assert_equal(results, "main address is 0x400000", main_addr, 4194304)

    Note: Verify a non-existent symbol is not found
    Let has_foo be Linker.linker_has_symbol(ctx, "nonexistent_func")
    T.assert_equal(results, "has_symbol('nonexistent_func') returns 0", has_foo, 0)

    Layout.deallocate(text_buf)

    Return 1
End Process

