Process called "test_linker_accessors" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker accessor functions")

    Let ctx be Linker.create_linker_context()
    T.assert_not_null(results, "linker context created", ctx)

    Note: Merged text should start empty
    Let text_ptr be Linker.linker_get_merged_text(ctx)
    T.assert_not_null(results, "merged_text pointer is non-null", text_ptr)

    Let text_size be Linker.linker_get_merged_text_size(ctx)
    T.assert_equal(results, "merged_text_size starts at 0", text_size, 0)

    Note: Merged data should start empty
    Let data_ptr be Linker.linker_get_merged_data(ctx)
    T.assert_not_null(results, "merged_data pointer is non-null", data_ptr)

    Let data_size be Linker.linker_get_merged_data_size(ctx)
    T.assert_equal(results, "merged_data_size starts at 0", data_size, 0)

    Note: Merged rodata should start empty
    Let rodata_ptr be Linker.linker_get_merged_rodata(ctx)
    T.assert_not_null(results, "merged_rodata pointer is non-null", rodata_ptr)

    Let rodata_size be Linker.linker_get_merged_rodata_size(ctx)
    T.assert_equal(results, "merged_rodata_size starts at 0", rodata_size, 0)

    Note: Null context should return 0 for all accessors
    Let null_text be Linker.linker_get_merged_text(0)
    T.assert_equal(results, "get_merged_text(null) returns 0", null_text, 0)

    Let null_text_size be Linker.linker_get_merged_text_size(0)
    T.assert_equal(results, "get_merged_text_size(null) returns 0", null_text_size, 0)

    Let null_data be Linker.linker_get_merged_data(0)
    T.assert_equal(results, "get_merged_data(null) returns 0", null_data, 0)

    Let null_rodata be Linker.linker_get_merged_rodata(0)
    T.assert_equal(results, "get_merged_rodata(null) returns 0", null_rodata, 0)

    Return 1
End Process

Note: ============================================================================
Note: Constants Verification
Note: ============================================================================

Process called "test_linker_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "linker constants")

    T.assert_equal(results, "LINKER_OK is 1", Linker.LINKER_OK, 1)
    T.assert_equal(results, "LINKER_ERROR is 0", Linker.LINKER_ERROR, 0)
    T.assert_equal(results, "LINKER_ERROR_DUPLICATE_SYMBOL is -1", Linker.LINKER_ERROR_DUPLICATE_SYMBOL, -1)
    T.assert_equal(results, "LINKER_ERROR_UNRESOLVED_SYMBOL is -2", Linker.LINKER_ERROR_UNRESOLVED_SYMBOL, -2)
    T.assert_equal(results, "LINKER_ERROR_ALLOC_FAILED is -3", Linker.LINKER_ERROR_ALLOC_FAILED, -3)
    T.assert_equal(results, "LINKER_ERROR_INVALID_RELOC is -4", Linker.LINKER_ERROR_INVALID_RELOC, -4)
    T.assert_equal(results, "OBJECT_FILE_SIZE is 104", Linker.OBJECT_FILE_SIZE, 104)
    T.assert_equal(results, "LINKER_CONTEXT_SIZE is 112", Linker.LINKER_CONTEXT_SIZE, 112)
    T.assert_equal(results, "INITIAL_SECTION_CAPACITY is 16384", Linker.INITIAL_SECTION_CAPACITY, 16384)
    T.assert_equal(results, "LINKER_SECTION_TEXT is 1", Linker.LINKER_SECTION_TEXT, 1)
    T.assert_equal(results, "LINKER_SECTION_DATA is 2", Linker.LINKER_SECTION_DATA, 2)
    T.assert_equal(results, "LINKER_SECTION_RODATA is 3", Linker.LINKER_SECTION_RODATA, 3)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to allocate test results"
        Return 1
    End If

    test_create_linker_context(results)
    test_create_object_file(results)
    test_object_file_set_sections(results)
    test_linker_add_object(results)
    test_linker_merge_sections(results)
    test_linker_collect_symbols(results)
    test_linker_has_symbol(results)
    test_linker_set_entry_point(results)
    test_linker_get_unresolved_count(results)
    test_linker_set_text_base(results)
    test_linker_link(results)
    test_linker_link_null_context(results)
    test_linker_accessors(results)
    test_linker_constants(results)

    T.print_summary(results)

    If T.all_passed(results) is 1:
        T.destroy_test_results(results)
        Return 0
    End If

    T.destroy_test_results(results)
    Return 1
End Process

Process called "main" returns Integer:
    Return run_all_tests()
End Process
