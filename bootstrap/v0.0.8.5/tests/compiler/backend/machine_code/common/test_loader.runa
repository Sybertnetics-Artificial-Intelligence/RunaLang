Note: Constants Verification
Note: ============================================================================

Process called "test_loader_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "loader constants")

    T.assert_equal(results, "PLT_ENTRY_STRUCT_SIZE is 24", Loader.PLT_ENTRY_STRUCT_SIZE, 24)
    T.assert_equal(results, "GOT_ENTRY_STRUCT_SIZE is 32", Loader.GOT_ENTRY_STRUCT_SIZE, 32)
    T.assert_equal(results, "DYNAMIC_LINKER_CONTEXT_SIZE is 72", Loader.DYNAMIC_LINKER_CONTEXT_SIZE, 72)
    T.assert_equal(results, "GOT_ENTRY_SIZE is 8", Loader.GOT_ENTRY_SIZE, 8)
    T.assert_equal(results, "GOT_RESERVED_ENTRIES is 3", Loader.GOT_RESERVED_ENTRIES, 3)
    T.assert_equal(results, "PLT_STUB_SIZE is 16", Loader.PLT_STUB_SIZE, 16)
    T.assert_equal(results, "PLT0_SIZE is 16", Loader.PLT0_SIZE, 16)
    T.assert_equal(results, "LOADER_OK is 1", Loader.LOADER_OK, 1)
    T.assert_equal(results, "LOADER_ERROR is 0", Loader.LOADER_ERROR, 0)
    T.assert_equal(results, "LOADER_ERROR_ALLOC is -1", Loader.LOADER_ERROR_ALLOC, -1)
    T.assert_equal(results, "LOADER_ERROR_NOT_FOUND is -2", Loader.LOADER_ERROR_NOT_FOUND, -2)
    T.assert_equal(results, "DT_NULL is 0", Loader.DT_NULL, 0)
    T.assert_equal(results, "DT_NEEDED is 1", Loader.DT_NEEDED, 1)
    T.assert_equal(results, "DT_RELA is 7", Loader.DT_RELA, 7)
    T.assert_equal(results, "DYNAMIC_ENTRY_SIZE is 16", Loader.DYNAMIC_ENTRY_SIZE, 16)
    T.assert_equal(results, "PLT_PUSH_OPCODE is 0x68 (104)", Loader.PLT_PUSH_OPCODE, 104)
    T.assert_equal(results, "PLT_JMP_REL32_OPCODE is 0xE9 (233)", Loader.PLT_JMP_REL32_OPCODE, 233)

    Return 1
End Process

