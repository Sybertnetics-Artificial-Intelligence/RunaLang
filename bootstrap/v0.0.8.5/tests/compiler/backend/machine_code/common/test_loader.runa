Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to allocate test results"
        Return 1
    End If

    test_create_dynamic_linker(results)
    test_dynamic_add_shared_library(results)
    test_dynamic_add_symbol(results)
    test_plt_got_counts(results)
    test_dynamic_generate_got(results)
    test_dynamic_generate_plt(results)
    test_dynamic_offset_lookup(results)
    test_dynamic_resolve_symbol(results)
    test_dynamic_set_bases(results)
    test_dynamic_generate_dynamic_section(results)
    test_loader_constants(results)

    T.print_summary(results)

    If T.all_passed(results) is 1:
        T.destroy_test_results(results)
        Return 0
    End If

    T.destroy_test_results(results)
    Return 1
End Process
