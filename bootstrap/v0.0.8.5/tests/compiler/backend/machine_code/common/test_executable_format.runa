Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to allocate test results"
        Return 1
    End If

    Note: ELF64 Tests
    test_create_elf64_builder(results)
    test_elf64_emit_byte_increments_position(results)
    test_elf64_emit_word_dword_qword(results)
    test_elf64_write_header_produces_64_bytes(results)
    test_align_up(results)
    test_elf64_build_executable(results)
    test_elf64_build_code_only(results)
    test_elf64_destroy_builder(results)
    test_elf64_patch_operations(results)
    test_elf64_output_align_to(results)
    test_elf64_string_table(results)
    test_elf64_add_program_header(results)
    test_elf64_add_section_header(results)
    test_elf64_constants(results)

    Note: PE Tests
    test_create_pe_builder(results)
    test_pe_write_dos_stub(results)
    test_pe_build_executable(results)

    Note: Mach-O Tests
    test_create_macho_builder(results)
    test_macho_write_header(results)
    test_macho_build_executable(results)

    Note: Dispatcher Test
    test_build_executable_for_target(results)

    T.print_summary(results)

    If T.all_passed(results) is 1:
        T.destroy_test_results(results)
        Return 0
    End If

    T.destroy_test_results(results)
    Return 1
End Process
