Note: ============================================================================
Note: build_executable_for_target Dispatch Tests
Note: ============================================================================

Process called "test_build_executable_for_target" that takes results as Integer returns Integer:
    T.begin_suite(results, "build_executable_for_target")

    Let code_buf be MemoryUtils.allocate(16)
    __store8(code_buf, 0, 195)

    Note: Linux target should produce ELF64
    Let linux_builder be ExeFormat.build_executable_for_target(MCI.TARGET_OS_LINUX, code_buf, 1, 0, 0, 0, 0)
    T.assert_not_null(results, "Linux target returns non-null builder", linux_builder)

    Note: Verify ELF magic in the Linux output
    Let linux_tracker be __load(linux_builder, 0)
    Let linux_buf be __load(linux_tracker, 0)
    Let linux_m0 be __load8(linux_buf, 0)
    T.assert_equal(results, "Linux output has ELF magic byte 0 (0x7F)", linux_m0, 127)

    Note: Windows target should produce PE
    Let win_builder be ExeFormat.build_executable_for_target(MCI.TARGET_OS_WINDOWS, code_buf, 1, 0, 0, 0, 0)
    T.assert_not_null(results, "Windows target returns non-null builder", win_builder)

    Note: Verify MZ signature in Windows output
    Let win_tracker be __load(win_builder, 0)
    Let win_buf be __load(win_tracker, 0)
    Let win_m0 be __load8(win_buf, 0)
    Let win_m1 be __load8(win_buf, 1)
    T.assert_equal(results, "Windows output has MZ byte 0 (M=77)", win_m0, 77)
    T.assert_equal(results, "Windows output has MZ byte 1 (Z=90)", win_m1, 90)

    Note: Darwin target should produce Mach-O
    Let darwin_builder be ExeFormat.build_executable_for_target(MCI.TARGET_OS_DARWIN, code_buf, 1, 0, 0, 0, 0)
    T.assert_not_null(results, "Darwin target returns non-null builder", darwin_builder)

    Note: Verify Mach-O magic in Darwin output
    Let darwin_tracker be __load(darwin_builder, 0)
    Let darwin_buf be __load(darwin_tracker, 0)
    Let darwin_m0 be __load8(darwin_buf, 0)
    T.assert_equal(results, "Darwin output has Mach-O magic byte 0 (0xCF=207)", darwin_m0, 207)

    Note: FreeBSD target should produce ELF64 (same format as Linux)
    Let freebsd_builder be ExeFormat.build_executable_for_target(MCI.TARGET_OS_FREEBSD, code_buf, 1, 0, 0, 0, 0)
    T.assert_not_null(results, "FreeBSD target returns non-null builder", freebsd_builder)

    Note: Unsupported OS should return 0
    Let unsupported be ExeFormat.build_executable_for_target(99, code_buf, 1, 0, 0, 0, 0)
    T.assert_equal(results, "unsupported OS returns 0", unsupported, 0)

    MemoryUtils.deallocate(code_buf)
    Return 1
End Process

