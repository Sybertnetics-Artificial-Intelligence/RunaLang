Process called "test_elf64_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "ELF64 constants")

    T.assert_equal(results, "ELF_MAGIC_0 is 127", ExeFormat.ELF_MAGIC_0, 127)
    T.assert_equal(results, "ELF_MAGIC_1 is 69 (E)", ExeFormat.ELF_MAGIC_1, 69)
    T.assert_equal(results, "ELF_MAGIC_2 is 76 (L)", ExeFormat.ELF_MAGIC_2, 76)
    T.assert_equal(results, "ELF_MAGIC_3 is 70 (F)", ExeFormat.ELF_MAGIC_3, 70)
    T.assert_equal(results, "ELF64_HEADER_SIZE is 64", ExeFormat.ELF64_HEADER_SIZE, 64)
    T.assert_equal(results, "ELF64_PHDR_SIZE is 56", ExeFormat.ELF64_PHDR_SIZE, 56)
    T.assert_equal(results, "ELF64_SHDR_SIZE is 64", ExeFormat.ELF64_SHDR_SIZE, 64)
    T.assert_equal(results, "ET_EXEC is 2", ExeFormat.ET_EXEC, 2)
    T.assert_equal(results, "EM_X86_64 is 62", ExeFormat.EM_X86_64, 62)
    T.assert_equal(results, "PT_LOAD is 1", ExeFormat.PT_LOAD, 1)
    T.assert_equal(results, "PF_R is 4", ExeFormat.PF_R, 4)
    T.assert_equal(results, "PF_W is 2", ExeFormat.PF_W, 2)
    T.assert_equal(results, "PF_X is 1", ExeFormat.PF_X, 1)
    T.assert_equal(results, "SHT_PROGBITS is 1", ExeFormat.SHT_PROGBITS, 1)
    T.assert_equal(results, "SHF_ALLOC is 2", ExeFormat.SHF_ALLOC, 2)
    T.assert_equal(results, "SHF_EXECINSTR is 4", ExeFormat.SHF_EXECINSTR, 4)
    T.assert_equal(results, "ELF64_DEFAULT_BASE is 0x400000", ExeFormat.ELF64_DEFAULT_BASE, 4194304)
    T.assert_equal(results, "ELF64_PAGE_SIZE is 4096", ExeFormat.ELF64_PAGE_SIZE, 4096)

    Return 1
End Process

