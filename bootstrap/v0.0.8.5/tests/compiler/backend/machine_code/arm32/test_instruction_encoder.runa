Note:
Unit Tests for ARM32 Instruction Encoder

Validates condition code constants (COND_EQ through COND_NV), data processing
opcode constants (DP_AND through DP_MVN), shift type constants, encoder context
lifecycle, ARM rotated immediate encoding, data processing instruction
construction, load/store encoding, branch encoding, MUL/MLA encoding,
push/pop (LDM/STM) with register bitmask construction, and LIR condition
mapping.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/arm32/instruction_encoder.runa" as ARM32Enc
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Condition Code Constant Tests
Note: ============================================================================

Process called "test_condition_code_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 instruction_encoder: condition code constants")

    T.assert_equal(results, "COND_EQ is 0", ARM32Enc.A32_COND_EQ, 0)
    T.assert_equal(results, "COND_NE is 1", ARM32Enc.A32_COND_NE, 1)
    T.assert_equal(results, "COND_CS is 2", ARM32Enc.A32_COND_CS, 2)
    T.assert_equal(results, "COND_CC is 3", ARM32Enc.A32_COND_CC, 3)
    T.assert_equal(results, "COND_MI is 4", ARM32Enc.A32_COND_MI, 4)
    T.assert_equal(results, "COND_PL is 5", ARM32Enc.A32_COND_PL, 5)
    T.assert_equal(results, "COND_VS is 6", ARM32Enc.A32_COND_VS, 6)
    T.assert_equal(results, "COND_VC is 7", ARM32Enc.A32_COND_VC, 7)
    T.assert_equal(results, "COND_HI is 8", ARM32Enc.A32_COND_HI, 8)
    T.assert_equal(results, "COND_LS is 9", ARM32Enc.A32_COND_LS, 9)
    T.assert_equal(results, "COND_GE is 10", ARM32Enc.A32_COND_GE, 10)
    T.assert_equal(results, "COND_LT is 11", ARM32Enc.A32_COND_LT, 11)
    T.assert_equal(results, "COND_GT is 12", ARM32Enc.A32_COND_GT, 12)
    T.assert_equal(results, "COND_LE is 13", ARM32Enc.A32_COND_LE, 13)
    T.assert_equal(results, "COND_AL is 14", ARM32Enc.A32_COND_AL, 14)
    T.assert_equal(results, "COND_NV is 15", ARM32Enc.A32_COND_NV, 15)

    Return 1
End Process

Note: ============================================================================
Note: Data Processing Opcode Constant Tests
Note: ============================================================================

Process called "test_dp_opcode_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 instruction_encoder: DP opcode constants")

    T.assert_equal(results, "DP_AND is 0", ARM32Enc.DP_AND, 0)
    T.assert_equal(results, "DP_EOR is 1", ARM32Enc.DP_EOR, 1)
    T.assert_equal(results, "DP_SUB is 2", ARM32Enc.DP_SUB, 2)
    T.assert_equal(results, "DP_RSB is 3", ARM32Enc.DP_RSB, 3)
    T.assert_equal(results, "DP_ADD is 4", ARM32Enc.DP_ADD, 4)
    T.assert_equal(results, "DP_ADC is 5", ARM32Enc.DP_ADC, 5)
    T.assert_equal(results, "DP_SBC is 6", ARM32Enc.DP_SBC, 6)
    T.assert_equal(results, "DP_RSC is 7", ARM32Enc.DP_RSC, 7)
    T.assert_equal(results, "DP_TST is 8", ARM32Enc.DP_TST, 8)
    T.assert_equal(results, "DP_TEQ is 9", ARM32Enc.DP_TEQ, 9)
    T.assert_equal(results, "DP_CMP is 10", ARM32Enc.DP_CMP, 10)
    T.assert_equal(results, "DP_CMN is 11", ARM32Enc.DP_CMN, 11)
    T.assert_equal(results, "DP_ORR is 12", ARM32Enc.DP_ORR, 12)
    T.assert_equal(results, "DP_MOV is 13", ARM32Enc.DP_MOV, 13)
    T.assert_equal(results, "DP_BIC is 14", ARM32Enc.DP_BIC, 14)
    T.assert_equal(results, "DP_MVN is 15", ARM32Enc.DP_MVN, 15)

    Note: Shift type constants
    T.assert_equal(results, "SHIFT_LSL is 0", ARM32Enc.SHIFT_LSL, 0)
    T.assert_equal(results, "SHIFT_LSR is 1", ARM32Enc.SHIFT_LSR, 1)
    T.assert_equal(results, "SHIFT_ASR is 2", ARM32Enc.SHIFT_ASR, 2)
    T.assert_equal(results, "SHIFT_ROR is 3", ARM32Enc.SHIFT_ROR, 3)

    Return 1
End Process

Note: ============================================================================
Note: Encoder Context Tests
Note: ============================================================================

Process called "test_encoder_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 instruction_encoder: encoder context")

    Let arena be Layout.allocate(65536)
    Let output be MCI.create_binary_output(arena)
    T.assert_not_null(results, "binary output created", output)

    Let ctx be ARM32Enc.create_encoder_context(output)
    T.assert_not_null(results, "create_encoder_context returns non-null", ctx)

    Note: Verify output stored (offset 0)
    Let stored_output be __load(ctx, 0)
    T.assert_equal(results, "output stored correctly", stored_output, output)

    Note: Verify default condition is AL (14) at offset 8
    Let default_cond be __load(ctx, 8)
    T.assert_equal(results, "default condition is COND_AL (14)", default_cond, 14)

    Note: set_condition should work
    Let r1 be ARM32Enc.set_condition(ctx, ARM32Enc.A32_COND_EQ)
    T.assert_equal(results, "set_condition returns 1", r1, 1)
    Let new_cond be __load(ctx, 8)
    T.assert_equal(results, "condition updated to COND_EQ", new_cond, 0)

    Note: set_condition null guard
    Let r2 be ARM32Enc.set_condition(0, 0)
    T.assert_equal(results, "set_condition(0, 0) returns 0", r2, 0)

    Return 1
End Process

Note: ============================================================================
Note: ARM Immediate Encoding Tests
Note: ============================================================================

Process called "test_encode_arm_immediate" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 instruction_encoder: encode_arm_immediate")

    Note: Zero encodes directly
    Let r0 be ARM32Enc.encode_arm_immediate(0)
    T.assert_equal(results, "encode_arm_immediate(0) is 0", r0, 0)

    Note: Small values (0-255) encode with rotation 0
    Let r1 be ARM32Enc.encode_arm_immediate(1)
    T.assert_not_equal(results, "encode_arm_immediate(1) is not -1", r1, -1)

    Let r255 be ARM32Enc.encode_arm_immediate(255)
    T.assert_not_equal(results, "encode_arm_immediate(255) is not -1", r255, -1)

    Return 1
End Process

Note: ============================================================================
Note: LIR Condition Mapping Tests
Note: ============================================================================

Process called "test_lir_condition_to_arm" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 instruction_encoder: lir_condition_to_arm")

    T.assert_equal(results, "LIR cond 0 -> COND_EQ", ARM32Enc.lir_condition_to_arm(0), ARM32Enc.A32_COND_EQ)
    T.assert_equal(results, "LIR cond 1 -> COND_NE", ARM32Enc.lir_condition_to_arm(1), ARM32Enc.A32_COND_NE)
    T.assert_equal(results, "LIR cond 2 -> COND_LT", ARM32Enc.lir_condition_to_arm(2), ARM32Enc.A32_COND_LT)
    T.assert_equal(results, "LIR cond 3 -> COND_LE", ARM32Enc.lir_condition_to_arm(3), ARM32Enc.A32_COND_LE)
    T.assert_equal(results, "LIR cond 4 -> COND_GT", ARM32Enc.lir_condition_to_arm(4), ARM32Enc.A32_COND_GT)
    T.assert_equal(results, "LIR cond 5 -> COND_GE", ARM32Enc.lir_condition_to_arm(5), ARM32Enc.A32_COND_GE)

    Note: Unknown LIR condition defaults to COND_AL
    T.assert_equal(results, "LIR cond 99 -> COND_AL", ARM32Enc.lir_condition_to_arm(99), ARM32Enc.A32_COND_AL)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 instruction_encoder: null guards")

    T.assert_equal(results, "emit_word(0,...) returns 0", ARM32Enc.emit_word(0, 0), 0)
    T.assert_equal(results, "encode_data_processing(0,...) returns 0", ARM32Enc.encode_data_processing(0, 0, 0, 0, 0, 0, 0), 0)
    Let _enc_ls_null_result be proc encode_load_store from ARM32Enc with 0, 0, 0, 0, 0, 0, 0, 0, 0
    T.assert_equal(results, "encode_load_store(0,...) returns 0", _enc_ls_null_result, 0)
    T.assert_equal(results, "encode_branch(0,...) returns 0", ARM32Enc.encode_branch(0, 0, 0), 0)
    T.assert_equal(results, "encode_mul(0,...) returns 0", ARM32Enc.encode_mul(0, 0, 0, 0, 0), 0)
    T.assert_equal(results, "encode_mla(0,...) returns 0", ARM32Enc.encode_mla(0, 0, 0, 0, 0, 0), 0)
    T.assert_equal(results, "encode_push(0,...) returns 0", ARM32Enc.encode_push(0, 0), 0)
    T.assert_equal(results, "encode_pop(0,...) returns 0", ARM32Enc.encode_pop(0, 0), 0)
    T.assert_equal(results, "encode_swi(0,...) returns 0", ARM32Enc.encode_swi(0, 0), 0)
    T.assert_equal(results, "encode_bx(0,...) returns 0", ARM32Enc.encode_bx(0, 0), 0)

    Return 1
End Process

Note: ============================================================================
Note: Register Bitmask Tests
Note: ============================================================================

Process called "test_build_register_mask" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 instruction_encoder: build_register_mask")

    Note: Null list should return 0
    Let mask0 be ARM32Enc.build_register_mask(0)
    T.assert_equal(results, "build_register_mask(0) returns 0", mask0, 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_condition_code_constants(results)
    test_dp_opcode_constants(results)
    test_encoder_context(results)
    test_encode_arm_immediate(results)
    test_lir_condition_to_arm(results)
    test_null_guards(results)
    test_build_register_mask(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
