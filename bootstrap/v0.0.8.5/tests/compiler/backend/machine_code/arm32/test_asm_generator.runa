Note:
Unit Tests for ARM32 Assembly Generator

Validates register naming (r0-r15 with aliases fp, ip, sp, lr, pc), AAPCS
prologue/epilogue generation (push/pop with lr/pc), three-address instruction
emission, operand formatting (register, immediate with #, memory with brackets),
and instruction dispatch for MOV, arithmetic, branch, load/store, and type
conversion operations on the ARM32 backend.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/arm32/asm_generator.runa" as ARM32Asm
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MCI
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/internal/memory_utils.runa" as MemoryUtils

Note: ============================================================================
Note: Register Name Tests
Note: ============================================================================

Process called "test_register_names" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 asm_generator: register names")

    Note: ARM32 has 16 GPRs (r0-r15) with aliases for special registers
    Let name0 be ARM32Asm.get_register_name(0)
    T.assert_not_null(results, "get_register_name(0) returns non-null", name0)

    Let name7 be ARM32Asm.get_register_name(7)
    T.assert_not_null(results, "get_register_name(7) returns non-null", name7)

    Let name10 be ARM32Asm.get_register_name(10)
    T.assert_not_null(results, "get_register_name(10) returns non-null", name10)

    Note: Special register aliases
    Let name11 be ARM32Asm.get_register_name(11)
    T.assert_not_null(results, "get_register_name(11)=fp returns non-null", name11)

    Let name12 be ARM32Asm.get_register_name(12)
    T.assert_not_null(results, "get_register_name(12)=ip returns non-null", name12)

    Let name13 be ARM32Asm.get_register_name(13)
    T.assert_not_null(results, "get_register_name(13)=sp returns non-null", name13)

    Let name14 be ARM32Asm.get_register_name(14)
    T.assert_not_null(results, "get_register_name(14)=lr returns non-null", name14)

    Let name15 be ARM32Asm.get_register_name(15)
    T.assert_not_null(results, "get_register_name(15)=pc returns non-null", name15)

    Note: Out-of-range should return a fallback
    Let name_oob be ARM32Asm.get_register_name(99)
    T.assert_not_null(results, "get_register_name(99) returns non-null fallback", name_oob)

    Return 1
End Process

Note: ============================================================================
Note: Context Creation Tests
Note: ============================================================================

Process called "test_create_asm_context" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 asm_generator: create_asm_context")

    Let arena be MemoryUtils.allocate(65536)
    T.assert_not_null(results, "arena allocation succeeds", arena)

    Let config be Layout.allocate(64)
    T.assert_not_null(results, "config allocation succeeds", config)

    Let ctx be ARM32Asm.create_asm_context(config, arena)
    T.assert_not_null(results, "create_asm_context returns non-null", ctx)

    Note: Verify output stored (offset 0)
    Let output be __load(ctx, 0)
    T.assert_not_null(results, "output buffer stored", output)

    Note: Verify config stored (offset 8)
    Let stored_config be __load(ctx, 8)
    T.assert_equal(results, "config stored correctly", stored_config, config)

    Note: Verify current_function starts at 0 (offset 16)
    Let current_func be __load(ctx, 16)
    T.assert_equal(results, "current_function starts at 0", current_func, 0)

    Note: Verify error_count starts at 0 (offset 32)
    Let errors be __load(ctx, 32)
    T.assert_equal(results, "error_count starts at 0", errors, 0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 asm_generator: null guards")

    Let r1 be ARM32Asm.generate_arm32_assembly(0, 0)
    T.assert_equal(results, "generate_arm32_assembly(0, 0) returns 0", r1, 0)

    Let r2 be ARM32Asm.emit_function(0, 0)
    T.assert_equal(results, "emit_function(0, 0) returns 0", r2, 0)

    Let arena be MemoryUtils.allocate(65536)
    Let config be Layout.allocate(64)
    Let ctx be ARM32Asm.create_asm_context(config, arena)

    Let r3 be ARM32Asm.emit_basic_block(ctx, 0)
    T.assert_equal(results, "emit_basic_block(ctx, 0) returns 0", r3, 0)

    Let r4 be ARM32Asm.emit_instruction(ctx, 0)
    T.assert_equal(results, "emit_instruction(ctx, 0) returns 0", r4, 0)

    Let r5 be ARM32Asm.format_operand(0, 4)
    T.assert_not_null(results, "format_operand(0, 4) returns non-null", r5)

    Return 1
End Process

Note: ============================================================================
Note: Operand Formatting Tests
Note: ============================================================================

Process called "test_format_operand" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 asm_generator: format_operand")

    Note: Register operand (type=1)
    Let reg_op be Layout.allocate(64)
    __store(reg_op, 0, 1)
    __store(reg_op, 8, 3)
    Let reg_str be ARM32Asm.format_operand(reg_op, 4)
    T.assert_not_null(results, "format_operand register returns non-null", reg_str)

    Note: Immediate operand (type=2) should produce #value
    Let imm_op be Layout.allocate(64)
    __store(imm_op, 0, 2)
    __store(imm_op, 16, 100)
    Let imm_str be ARM32Asm.format_operand(imm_op, 4)
    T.assert_not_null(results, "format_operand immediate returns non-null", imm_str)

    Note: Memory operand (type=3) should produce [base, #offset]
    Let mem_op be Layout.allocate(64)
    __store(mem_op, 0, 3)
    __store(mem_op, 24, 13)
    __store(mem_op, 48, 16)
    Let mem_str be ARM32Asm.format_operand(mem_op, 4)
    T.assert_not_null(results, "format_operand memory returns non-null", mem_str)

    Note: Memory with zero displacement
    Let mem_op2 be Layout.allocate(64)
    __store(mem_op2, 0, 3)
    __store(mem_op2, 24, 0)
    __store(mem_op2, 48, 0)
    Let mem_str2 be ARM32Asm.format_operand(mem_op2, 4)
    T.assert_not_null(results, "format_operand memory zero-disp returns non-null", mem_str2)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_register_names(results)
    test_create_asm_context(results)
    test_null_guards(results)
    test_format_operand(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
