Note:
Unit Tests for ARM32 Register Allocator

Validates the 16-register GPR file (R0-R15), AAPCS calling convention
classification (R0-R3 args, R4-R11 callee-saved, R12 IP scratch, R13-R15
reserved), allocatable register set (R0-R12 = 13 registers), virtual-to-physical
mapping, constraint constants (MUL distinct, CALL args, fixed reg), and
constraint collection for MUL, division (library call), and CALL instructions.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/arm32/register_allocator.runa" as ARM32Reg
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Register Constant Tests
Note: ============================================================================

Process called "test_register_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 register_allocator: register constants")

    T.assert_equal(results, "REG_R0 is 0", ARM32Reg.A32_REG_R0, 0)
    T.assert_equal(results, "REG_R1 is 1", ARM32Reg.A32_REG_R1, 1)
    T.assert_equal(results, "REG_R2 is 2", ARM32Reg.A32_REG_R2, 2)
    T.assert_equal(results, "REG_R3 is 3", ARM32Reg.A32_REG_R3, 3)
    T.assert_equal(results, "REG_R4 is 4", ARM32Reg.A32_REG_R4, 4)
    T.assert_equal(results, "REG_R10 is 10", ARM32Reg.A32_REG_R10, 10)
    T.assert_equal(results, "REG_R11 is 11", ARM32Reg.A32_REG_R11, 11)
    T.assert_equal(results, "REG_R12 is 12", ARM32Reg.A32_REG_R12, 12)
    T.assert_equal(results, "REG_SP is 13", ARM32Reg.A32_REG_SP, 13)
    T.assert_equal(results, "REG_LR is 14", ARM32Reg.A32_REG_LR, 14)
    T.assert_equal(results, "REG_PC is 15", ARM32Reg.A32_REG_PC, 15)

    Note: Aliases
    T.assert_equal(results, "REG_FP is 11", ARM32Reg.A32_REG_FP, 11)
    T.assert_equal(results, "REG_IP is 12", ARM32Reg.A32_REG_IP, 12)

    T.assert_equal(results, "ARM32_GPR_COUNT is 16", ARM32Reg.ARM32_GPR_COUNT, 16)
    T.assert_equal(results, "ARM32_ALLOCATABLE_COUNT is 13", ARM32Reg.ARM32_ALLOCATABLE_COUNT, 13)

    Return 1
End Process

Note: ============================================================================
Note: Constraint Constant Tests
Note: ============================================================================

Process called "test_constraint_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 register_allocator: constraint constants")

    T.assert_equal(results, "CONSTRAINT_FIXED_REG is 1", ARM32Reg.A32_CONSTRAINT_FIXED_REG, 1)
    T.assert_equal(results, "CONSTRAINT_CLOBBER is 2", ARM32Reg.A32_CONSTRAINT_CLOBBER, 2)
    T.assert_equal(results, "CONSTRAINT_MUL_DISTINCT is 3", ARM32Reg.A32_CONSTRAINT_MUL_DISTINCT, 3)
    T.assert_equal(results, "CONSTRAINT_CALL_ARGS is 4", ARM32Reg.A32_CONSTRAINT_CALL_ARGS, 4)
    T.assert_equal(results, "CONSTRAINT_CALL_RETURN is 5", ARM32Reg.A32_CONSTRAINT_CALL_RETURN, 5)

    Return 1
End Process

Note: ============================================================================
Note: Allocatable Register Tests
Note: ============================================================================

Process called "test_is_allocatable_register" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 register_allocator: is_allocatable_register")

    Note: R0-R12 are allocatable
    T.assert_equal(results, "R0 is allocatable", ARM32Reg.is_allocatable_register(0), 1)
    T.assert_equal(results, "R3 is allocatable", ARM32Reg.is_allocatable_register(3), 1)
    T.assert_equal(results, "R7 is allocatable", ARM32Reg.is_allocatable_register(7), 1)
    T.assert_equal(results, "R12 is allocatable", ARM32Reg.is_allocatable_register(12), 1)

    Note: R13 (SP), R14 (LR), R15 (PC) are NOT allocatable
    T.assert_equal(results, "R13/SP NOT allocatable", ARM32Reg.is_allocatable_register(13), 0)
    T.assert_equal(results, "R14/LR NOT allocatable", ARM32Reg.is_allocatable_register(14), 0)
    T.assert_equal(results, "R15/PC NOT allocatable", ARM32Reg.is_allocatable_register(15), 0)

    Note: Out-of-range
    T.assert_equal(results, "reg -1 NOT allocatable", ARM32Reg.is_allocatable_register(-1), 0)

    Return 1
End Process

Note: ============================================================================
Note: Calling Convention Tests
Note: ============================================================================

Process called "test_calling_convention" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 register_allocator: AAPCS calling convention")

    Note: Callee-saved: R4-R11
    T.assert_equal(results, "R4 is callee-saved", ARM32Reg.is_callee_saved(4), 1)
    T.assert_equal(results, "R11 is callee-saved", ARM32Reg.is_callee_saved(11), 1)
    T.assert_equal(results, "R0 NOT callee-saved", ARM32Reg.is_callee_saved(0), 0)
    T.assert_equal(results, "R3 NOT callee-saved", ARM32Reg.is_callee_saved(3), 0)
    T.assert_equal(results, "R12 NOT callee-saved", ARM32Reg.is_callee_saved(12), 0)

    Note: Caller-saved: R0-R3, R12
    T.assert_equal(results, "R0 is caller-saved", ARM32Reg.is_caller_saved(0), 1)
    T.assert_equal(results, "R3 is caller-saved", ARM32Reg.is_caller_saved(3), 1)
    T.assert_equal(results, "R12 is caller-saved", ARM32Reg.is_caller_saved(12), 1)
    T.assert_equal(results, "R4 NOT caller-saved", ARM32Reg.is_caller_saved(4), 0)

    Note: Argument registers: R0-R3
    T.assert_equal(results, "R0 is argument reg", ARM32Reg.is_argument_register(0), 1)
    T.assert_equal(results, "R3 is argument reg", ARM32Reg.is_argument_register(3), 1)
    T.assert_equal(results, "R4 NOT argument reg", ARM32Reg.is_argument_register(4), 0)

    Return 1
End Process

Note: ============================================================================
Note: Virtual-to-Physical Mapping Tests
Note: ============================================================================

Process called "test_map_virtual_to_physical" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 register_allocator: map_virtual_to_physical")

    Note: Direct mapping for vreg 0-12
    T.assert_equal(results, "vreg 0 -> R0", ARM32Reg.map_virtual_to_physical(0), 0)
    T.assert_equal(results, "vreg 5 -> R5", ARM32Reg.map_virtual_to_physical(5), 5)
    T.assert_equal(results, "vreg 12 -> R12", ARM32Reg.map_virtual_to_physical(12), 12)

    Note: vreg 13+ must spill
    T.assert_equal(results, "vreg 13 spills (-1)", ARM32Reg.map_virtual_to_physical(13), -1)
    T.assert_equal(results, "vreg -1 spills (-1)", ARM32Reg.map_virtual_to_physical(-1), -1)

    Return 1
End Process

Note: ============================================================================
Note: Get Allocatable Registers Tests
Note: ============================================================================

Process called "test_get_allocatable_registers" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 register_allocator: get_allocatable_registers")

    Let regs be ARM32Reg.get_allocatable_registers()
    T.assert_not_null(results, "get_allocatable_registers returns non-null", regs)

    Let count be List.list_length(regs)
    T.assert_equal(results, "allocatable register count is 13", count, 13)

    Note: Scratch first: R0, R1, R2, R3, R12
    Let r0 be List.list_get(regs, 0)
    T.assert_equal(results, "first allocatable is R0", r0, ARM32Reg.A32_REG_R0)

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "arm32 register_allocator: null guards")

    T.assert_equal(results, "collect_arm32_constraints(0) returns 0", ARM32Reg.collect_arm32_constraints(0), 0)
    T.assert_equal(results, "resolve_arm32_constraints(0) returns 0", ARM32Reg.resolve_arm32_constraints(0), 0)
    T.assert_equal(results, "coalesce_moves(0) returns 0", ARM32Reg.coalesce_moves(0), 0)
    T.assert_equal(results, "insert_register_copy(0,...) returns 0", ARM32Reg.insert_register_copy(0, 0, 0, 0, 4), 0)
    T.assert_equal(results, "handle_mul_distinct(0,...) returns 0", ARM32Reg.handle_mul_distinct(0, 0, 0, 0), 0)
    T.assert_equal(results, "handle_division_constraint(0,...) returns 0", ARM32Reg.handle_division_constraint(0, 0, 0, 0), 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_register_constants(results)
    test_constraint_constants(results)
    test_is_allocatable_register(results)
    test_calling_convention(results)
    test_map_virtual_to_physical(results)
    test_get_allocatable_registers(results)
    test_null_guards(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
