Note:
Unit Tests for MIPS Instruction Encoder

Validates MIPS opcode and function code constants, R/I/J format encoding,
bit manipulation helpers (mask_bits, shift_left), and NOP encoding for the
MIPS32 ISA. All MIPS instructions are exactly 32 bits wide in three formats.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/mips/instruction_encoder.runa" as MIPSEnc
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: R-format Function Code Constant Tests
Note: ============================================================================

Process called "test_r_format_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "mips instruction_encoder: R-format function codes")

    T.assert_equal(results, "MIPS_OP_SPECIAL is 0", MIPSEnc.MIPS_OP_SPECIAL, 0)
    T.assert_equal(results, "MIPS_FUNCT_SLL is 0", MIPSEnc.MIPS_FUNCT_SLL, 0)
    T.assert_equal(results, "MIPS_FUNCT_SRL is 2", MIPSEnc.MIPS_FUNCT_SRL, 2)
    T.assert_equal(results, "MIPS_FUNCT_SRA is 3", MIPSEnc.MIPS_FUNCT_SRA, 3)
    T.assert_equal(results, "MIPS_FUNCT_SLLV is 4", MIPSEnc.MIPS_FUNCT_SLLV, 4)
    T.assert_equal(results, "MIPS_FUNCT_SRLV is 6", MIPSEnc.MIPS_FUNCT_SRLV, 6)
    T.assert_equal(results, "MIPS_FUNCT_SRAV is 7", MIPSEnc.MIPS_FUNCT_SRAV, 7)
    T.assert_equal(results, "MIPS_FUNCT_JR is 8", MIPSEnc.MIPS_FUNCT_JR, 8)
    T.assert_equal(results, "MIPS_FUNCT_JALR is 9", MIPSEnc.MIPS_FUNCT_JALR, 9)
    T.assert_equal(results, "MIPS_FUNCT_SYSCALL is 12", MIPSEnc.MIPS_FUNCT_SYSCALL, 12)
    T.assert_equal(results, "MIPS_FUNCT_BREAK is 13", MIPSEnc.MIPS_FUNCT_BREAK, 13)
    T.assert_equal(results, "MIPS_FUNCT_MFHI is 16", MIPSEnc.MIPS_FUNCT_MFHI, 16)
    T.assert_equal(results, "MIPS_FUNCT_MFLO is 18", MIPSEnc.MIPS_FUNCT_MFLO, 18)
    T.assert_equal(results, "MIPS_FUNCT_MULT is 24", MIPSEnc.MIPS_FUNCT_MULT, 24)
    T.assert_equal(results, "MIPS_FUNCT_MULTU is 25", MIPSEnc.MIPS_FUNCT_MULTU, 25)
    T.assert_equal(results, "MIPS_FUNCT_DIV is 26", MIPSEnc.MIPS_FUNCT_DIV, 26)
    T.assert_equal(results, "MIPS_FUNCT_DIVU is 27", MIPSEnc.MIPS_FUNCT_DIVU, 27)
    T.assert_equal(results, "MIPS_FUNCT_ADD is 32", MIPSEnc.MIPS_FUNCT_ADD, 32)
    T.assert_equal(results, "MIPS_FUNCT_ADDU is 33", MIPSEnc.MIPS_FUNCT_ADDU, 33)
    T.assert_equal(results, "MIPS_FUNCT_SUB is 34", MIPSEnc.MIPS_FUNCT_SUB, 34)
    T.assert_equal(results, "MIPS_FUNCT_SUBU is 35", MIPSEnc.MIPS_FUNCT_SUBU, 35)
    T.assert_equal(results, "MIPS_FUNCT_AND is 36", MIPSEnc.MIPS_FUNCT_AND, 36)
    T.assert_equal(results, "MIPS_FUNCT_OR is 37", MIPSEnc.MIPS_FUNCT_OR, 37)
    T.assert_equal(results, "MIPS_FUNCT_XOR is 38", MIPSEnc.MIPS_FUNCT_XOR, 38)
    T.assert_equal(results, "MIPS_FUNCT_NOR is 39", MIPSEnc.MIPS_FUNCT_NOR, 39)
    T.assert_equal(results, "MIPS_FUNCT_SLT is 42", MIPSEnc.MIPS_FUNCT_SLT, 42)
    T.assert_equal(results, "MIPS_FUNCT_SLTU is 43", MIPSEnc.MIPS_FUNCT_SLTU, 43)

    Return 1
End Process

Note: ============================================================================
Note: I-format and J-format Opcode Tests
Note: ============================================================================

Process called "test_ij_format_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "mips instruction_encoder: I/J-format opcodes")

    T.assert_equal(results, "MIPS_OP_BEQ is 4", MIPSEnc.MIPS_OP_BEQ, 4)
    T.assert_equal(results, "MIPS_OP_BNE is 5", MIPSEnc.MIPS_OP_BNE, 5)
    T.assert_equal(results, "MIPS_OP_ADDIU is 9", MIPSEnc.MIPS_OP_ADDIU, 9)
    T.assert_equal(results, "MIPS_OP_ANDI is 12", MIPSEnc.MIPS_OP_ANDI, 12)
    T.assert_equal(results, "MIPS_OP_ORI is 13", MIPSEnc.MIPS_OP_ORI, 13)
    T.assert_equal(results, "MIPS_OP_XORI is 14", MIPSEnc.MIPS_OP_XORI, 14)
    T.assert_equal(results, "MIPS_OP_LUI is 15", MIPSEnc.MIPS_OP_LUI, 15)
    T.assert_equal(results, "MIPS_OP_LW is 35", MIPSEnc.MIPS_OP_LW, 35)
    T.assert_equal(results, "MIPS_OP_SW is 43", MIPSEnc.MIPS_OP_SW, 43)

    Note: J-format
    T.assert_equal(results, "MIPS_OP_J is 2", MIPSEnc.MIPS_OP_J, 2)
    T.assert_equal(results, "MIPS_OP_JAL is 3", MIPSEnc.MIPS_OP_JAL, 3)

    Note: NOP
    T.assert_equal(results, "MIPS_NOP is 0", MIPSEnc.MIPS_NOP, 0)

    Note: REGIMM
    T.assert_equal(results, "MIPS_OP_REGIMM is 1", MIPSEnc.MIPS_OP_REGIMM, 1)
    T.assert_equal(results, "MIPS_RT_BLTZ is 0", MIPSEnc.MIPS_RT_BLTZ, 0)
    T.assert_equal(results, "MIPS_RT_BGEZ is 1", MIPSEnc.MIPS_RT_BGEZ, 1)

    Return 1
End Process

Note: ============================================================================
Note: Bit Manipulation Helper Tests
Note: ============================================================================

Process called "test_bit_helpers" that takes results as Integer returns Integer:
    T.begin_suite(results, "mips instruction_encoder: bit manipulation helpers")

    Note: mask_bits(value, bits) masks to low N bits
    T.assert_equal(results, "mask_bits(0xFF, 5) = 31", MIPSEnc.mask_bits(255, 5), 31)
    T.assert_equal(results, "mask_bits(0, 5) = 0", MIPSEnc.mask_bits(0, 5), 0)
    T.assert_equal(results, "mask_bits(7, 3) = 7", MIPSEnc.mask_bits(7, 3), 7)
    T.assert_equal(results, "mask_bits(8, 3) = 0", MIPSEnc.mask_bits(8, 3), 0)
    T.assert_equal(results, "mask_bits(255, 8) = 255", MIPSEnc.mask_bits(255, 8), 255)

    Note: shift_left(value, amount) = value << amount
    T.assert_equal(results, "shift_left(1, 0) = 1", MIPSEnc.shift_left(1, 0), 1)
    T.assert_equal(results, "shift_left(1, 1) = 2", MIPSEnc.shift_left(1, 1), 2)
    T.assert_equal(results, "shift_left(1, 5) = 32", MIPSEnc.shift_left(1, 5), 32)
    T.assert_equal(results, "shift_left(3, 4) = 48", MIPSEnc.shift_left(3, 4), 48)

    Return 1
End Process

Note: ============================================================================
Note: R-type Encoding Tests
Note: ============================================================================

Process called "test_r_type_encoding" that takes results as Integer returns Integer:
    T.begin_suite(results, "mips instruction_encoder: R-type encoding")

    Note: NOP = SLL $zero, $zero, 0 = all zeros
    Let nop_val be MIPSEnc.encode_r_type(0, 0, 0, 0, 0, 0)
    T.assert_equal(results, "R-type NOP encodes to 0", nop_val, 0)

    Note: ADD $t0, $t1, $t2 = R-type: op=0, rs=9, rt=10, rd=8, shamt=0, funct=32
    Note: Result should be non-zero since funct=32
    Let add_val be MIPSEnc.encode_r_type(0, 9, 10, 8, 0, 32)
    T.assert_not_equal(results, "R-type ADD encodes to non-zero", add_val, 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_r_format_constants(results)
    test_ij_format_constants(results)
    test_bit_helpers(results)
    test_r_type_encoding(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
