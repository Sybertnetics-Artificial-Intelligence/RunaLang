Note:
Unit Tests for MIPS Register Allocator

Validates the 32-register GPR file ($0-$31) with $0 hardwired to zero, O32 ABI
register assignments ($a0-$a3 args, $v0-$v1 return, $s0-$s7 callee-saved,
$t0-$t9 caller-saved), HI/LO special registers for multiply/divide, register
allocator state creation/initialization, and reserved register marking
($zero, $at, $k0, $k1, $gp, $sp, $ra).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/mips/register_allocator.runa" as MIPSReg
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Register Constant Tests
Note: ============================================================================

Process called "test_register_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "mips register_allocator: register constants")

    T.assert_equal(results, "MIPS_REG_ZERO is 0", MIPSReg.MIPS_REG_ZERO, 0)
    T.assert_equal(results, "MIPS_REG_AT is 1", MIPSReg.MIPS_REG_AT, 1)
    T.assert_equal(results, "MIPS_REG_V0 is 2", MIPSReg.MIPS_REG_V0, 2)
    T.assert_equal(results, "MIPS_REG_V1 is 3", MIPSReg.MIPS_REG_V1, 3)
    T.assert_equal(results, "MIPS_REG_A0 is 4", MIPSReg.MIPS_REG_A0, 4)
    T.assert_equal(results, "MIPS_REG_A1 is 5", MIPSReg.MIPS_REG_A1, 5)
    T.assert_equal(results, "MIPS_REG_A2 is 6", MIPSReg.MIPS_REG_A2, 6)
    T.assert_equal(results, "MIPS_REG_A3 is 7", MIPSReg.MIPS_REG_A3, 7)
    T.assert_equal(results, "MIPS_REG_T0 is 8", MIPSReg.MIPS_REG_T0, 8)
    T.assert_equal(results, "MIPS_REG_T7 is 15", MIPSReg.MIPS_REG_T7, 15)
    T.assert_equal(results, "MIPS_REG_S0 is 16", MIPSReg.MIPS_REG_S0, 16)
    T.assert_equal(results, "MIPS_REG_S7 is 23", MIPSReg.MIPS_REG_S7, 23)
    T.assert_equal(results, "MIPS_REG_T8 is 24", MIPSReg.MIPS_REG_T8, 24)
    T.assert_equal(results, "MIPS_REG_T9 is 25", MIPSReg.MIPS_REG_T9, 25)
    T.assert_equal(results, "MIPS_REG_K0 is 26", MIPSReg.MIPS_REG_K0, 26)
    T.assert_equal(results, "MIPS_REG_K1 is 27", MIPSReg.MIPS_REG_K1, 27)
    T.assert_equal(results, "MIPS_REG_GP is 28", MIPSReg.MIPS_REG_GP, 28)
    T.assert_equal(results, "MIPS_REG_SP is 29", MIPSReg.MIPS_REG_SP, 29)
    T.assert_equal(results, "MIPS_REG_FP is 30", MIPSReg.MIPS_REG_FP, 30)
    T.assert_equal(results, "MIPS_REG_RA is 31", MIPSReg.MIPS_REG_RA, 31)

    Note: HI/LO pseudo-registers
    T.assert_equal(results, "MIPS_REG_HI is 32", MIPSReg.MIPS_REG_HI, 32)
    T.assert_equal(results, "MIPS_REG_LO is 33", MIPSReg.MIPS_REG_LO, 33)

    Note: Counts
    T.assert_equal(results, "MIPS_GPR_COUNT is 32", MIPSReg.MIPS_GPR_COUNT, 32)
    T.assert_equal(results, "MIPS_ALLOCATABLE_COUNT is 25", MIPSReg.MIPS_ALLOCATABLE_COUNT, 25)

    Return 1
End Process

Note: ============================================================================
Note: Register Status Constant Tests
Note: ============================================================================

Process called "test_status_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "mips register_allocator: status constants")

    T.assert_equal(results, "REG_STATUS_FREE is 0", MIPSReg.MIPS_REG_STATUS_FREE, 0)
    T.assert_equal(results, "REG_STATUS_ALLOCATED is 1", MIPSReg.MIPS_REG_STATUS_ALLOCATED, 1)
    T.assert_equal(results, "REG_STATUS_RESERVED is 2", MIPSReg.MIPS_REG_STATUS_RESERVED, 2)
    T.assert_equal(results, "REG_STATUS_SPILLED is 3", MIPSReg.MIPS_REG_STATUS_SPILLED, 3)

    Return 1
End Process

Note: ============================================================================
Note: Allocator State Creation Tests
Note: ============================================================================

Process called "test_create_mips_reg_alloc_state" that takes results as Integer returns Integer:
    T.begin_suite(results, "mips register_allocator: create_mips_reg_alloc_state")

    Let state be MIPSReg.create_mips_reg_alloc_state()
    T.assert_not_null(results, "create_mips_reg_alloc_state returns non-null", state)

    Note: Verify reg_status array allocated (offset 0)
    Let status_array be __load(state, 0)
    T.assert_not_null(results, "reg_status array allocated", status_array)

    Note: Verify lir_mapping array allocated (offset 8)
    Let mapping_array be __load(state, 8)
    T.assert_not_null(results, "lir_mapping array allocated", mapping_array)

    Note: Verify spill_count starts at 0 (offset 16)
    Let spill_count be __load(state, 16)
    T.assert_equal(results, "spill_count starts at 0", spill_count, 0)

    Note: Verify spill_offset starts at 0 (offset 24)
    Let spill_offset be __load(state, 24)
    T.assert_equal(results, "spill_offset starts at 0", spill_offset, 0)

    Note: Verify hi_in_use starts at 0 (offset 40)
    Let hi_in_use be __load(state, 40)
    T.assert_equal(results, "hi_in_use starts at 0", hi_in_use, 0)

    Note: Verify lo_in_use starts at 0 (offset 48)
    Let lo_in_use be __load(state, 48)
    T.assert_equal(results, "lo_in_use starts at 0", lo_in_use, 0)

    Note: Verify reserved registers are marked RESERVED (status = 2)
    Note: $zero(0), $at(1), $k0(26), $k1(27), $gp(28), $sp(29), $ra(31)
    Let zero_status be __load(status_array, 0)
    T.assert_equal(results, "$zero is RESERVED", zero_status, MIPSReg.MIPS_REG_STATUS_RESERVED)

    Let at_status be __load(status_array, 8)
    T.assert_equal(results, "$at is RESERVED", at_status, MIPSReg.MIPS_REG_STATUS_RESERVED)

    Let k0_status be __load(status_array, 208)
    T.assert_equal(results, "$k0 is RESERVED", k0_status, MIPSReg.MIPS_REG_STATUS_RESERVED)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    T.assert_not_null(results, "test results created", results)

    test_register_constants(results)
    test_status_constants(results)
    test_create_mips_reg_alloc_state(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
