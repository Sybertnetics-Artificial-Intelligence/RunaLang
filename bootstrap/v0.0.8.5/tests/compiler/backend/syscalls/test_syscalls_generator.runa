Note:
Unit Tests for SyscallsGenerator

Validates the inline syscall code generation module that produces instruction
sequences for syscall invocation. Tests cover instruction creation, sequence
generation, error check sequences, instruction type constants, and the
optimization pass.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/syscalls/syscalls_generator.runa" as Generator
Import "compiler/backend/syscalls/platforms/platform_interface.runa" as PlatformInterface
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Test: instruction type constants
Note: ============================================================================

Process called "test_instruction_type_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallsGenerator - instruction type constants")

    Note: Verify all instruction type constants are defined and distinct
    T.assert_equal(results, "INST_MOVE_IMM is 1", Generator.INST_MOVE_IMM, 1)
    T.assert_equal(results, "INST_MOVE_REG is 2", Generator.INST_MOVE_REG, 2)
    T.assert_equal(results, "INST_SYSCALL is 3", Generator.INST_SYSCALL, 3)
    T.assert_equal(results, "INST_COMPARE is 4", Generator.INST_COMPARE, 4)
    T.assert_equal(results, "INST_BRANCH is 5", Generator.INST_BRANCH, 5)
    T.assert_equal(results, "INST_NEGATE is 6", Generator.INST_NEGATE, 6)
    T.assert_equal(results, "INST_TEST_CARRY is 7", Generator.INST_TEST_CARRY, 7)
    T.assert_equal(results, "INST_TEST_CR0_SO is 8", Generator.INST_TEST_CR0_SO, 8)
    T.assert_equal(results, "INST_LOAD_STACK is 9", Generator.INST_LOAD_STACK, 9)
    T.assert_equal(results, "INST_STORE_STACK is 10", Generator.INST_STORE_STACK, 10)

    Note: Verify all constants are positive
    T.assert_greater_than(results, "INST_MOVE_IMM is positive", Generator.INST_MOVE_IMM, 0)
    T.assert_greater_than(results, "INST_STORE_STACK is positive", Generator.INST_STORE_STACK, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: create_instruction
Note: ============================================================================

Process called "test_create_instruction" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallsGenerator - create_instruction")

    Note: Create a MOVE_IMM instruction: load value 42 into register 5
    Let inst be Generator.create_instruction(Generator.INST_MOVE_IMM, 5, -1, 42)
    T.assert_not_null(results, "create_instruction returns non-null", inst)

    Note: Verify instruction fields
    Let inst_type be __load(inst, 0)
    T.assert_equal(results, "inst_type is INST_MOVE_IMM", inst_type, Generator.INST_MOVE_IMM)

    Let dst_reg be __load(inst, 8)
    T.assert_equal(results, "dst_reg is 5", dst_reg, 5)

    Let src_reg be __load(inst, 16)
    T.assert_equal(results, "src_reg is -1 (not applicable)", src_reg, -1)

    Let immediate be __load(inst, 24)
    T.assert_equal(results, "immediate is 42", immediate, 42)

    Let label be __load(inst, 32)
    T.assert_equal(results, "label is 0 (no label)", label, 0)

    Note: Create a MOVE_REG instruction: move register 3 to register 7
    Let inst_reg be Generator.create_instruction(Generator.INST_MOVE_REG, 7, 3, 0)
    T.assert_not_null(results, "MOVE_REG instruction created", inst_reg)

    Let inst_type_2 be __load(inst_reg, 0)
    T.assert_equal(results, "inst_type is INST_MOVE_REG", inst_type_2, Generator.INST_MOVE_REG)

    Note: Create a SYSCALL instruction
    Let inst_sc be Generator.create_instruction(Generator.INST_SYSCALL, -1, -1, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_not_null(results, "SYSCALL instruction created", inst_sc)
    Let sc_type be __load(inst_sc, 0)
    T.assert_equal(results, "inst_type is INST_SYSCALL", sc_type, Generator.INST_SYSCALL)

    Return 1
End Process

Note: ============================================================================
Note: Test: generate_syscall_sequence (via generate_syscall_inline)
Note: ============================================================================

Process called "test_generate_syscall_sequence" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallsGenerator - generate_syscall_inline")

    Note: Create a convention for Linux x86_64
    Let conv be PlatformInterface.create_syscall_convention(PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_not_null(results, "convention created", conv)

    Note: Create argument values (register IDs representing the arg sources)
    Let arg_values be List.list_create(3)
    List.list_append(arg_values, 5)   Note: arg0 in register 5 (RDI)
    List.list_append(arg_values, 4)   Note: arg1 in register 4 (RSI)
    List.list_append(arg_values, 3)   Note: arg2 in register 3 (RDX)

    Note: Generate inline syscall for write (syscall number 1) on Linux x86_64
    Let sequence be Generator.generate_syscall_inline(PlatformInterface.PLATFORM_LINUX_X86_64, conv, 1, arg_values, 3)
    T.assert_not_null(results, "generate_syscall_inline returns non-null", sequence)

    Note: Sequence should contain at least 2 instructions:
    Note: 1 for loading syscall number + 1 for the syscall instruction + error check
    Let length be List.list_length(sequence)
    T.assert_greater_than(results, "sequence has at least 2 instructions", length, 1)

    Note: First instruction should be MOVE_IMM (loading syscall number into RAX)
    Let first_inst be List.list_get(sequence, 0)
    T.assert_not_null(results, "first instruction is non-null", first_inst)
    Let first_type be __load(first_inst, 0)
    T.assert_equal(results, "first instruction is MOVE_IMM", first_type, Generator.INST_MOVE_IMM)

    Note: Null convention should return 0
    Let null_result be Generator.generate_syscall_inline(PlatformInterface.PLATFORM_LINUX_X86_64, 0, 1, arg_values, 3)
    T.assert_equal(results, "null convention returns 0", null_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: generate_error_check_sequence
Note: ============================================================================

Process called "test_generate_error_check_sequence" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallsGenerator - generate_error_check_sequence")

    Note: Test Linux x86_64 error check (negative return value method)
    Let conv_linux be PlatformInterface.create_syscall_convention(PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_not_null(results, "linux convention created", conv_linux)

    Let err_seq_linux be Generator.generate_error_check_sequence(PlatformInterface.PLATFORM_LINUX_X86_64, conv_linux)
    T.assert_not_null(results, "linux error check sequence returned", err_seq_linux)

    Let linux_len be List.list_length(err_seq_linux)
    T.assert_greater_than(results, "linux error sequence has instructions", linux_len, 0)

    Note: Linux x86_64 uses COMPARE instruction for error checking
    Let linux_first be List.list_get(err_seq_linux, 0)
    T.assert_not_null(results, "linux first error instruction non-null", linux_first)
    Let linux_first_type be __load(linux_first, 0)
    T.assert_equal(results, "linux error check uses COMPARE", linux_first_type, Generator.INST_COMPARE)

    Note: Test Darwin x86_64 error check (carry flag method)
    Let conv_darwin be PlatformInterface.create_syscall_convention(PlatformInterface.PLATFORM_DARWIN_X86_64)
    T.assert_not_null(results, "darwin convention created", conv_darwin)

    Let err_seq_darwin be Generator.generate_error_check_sequence(PlatformInterface.PLATFORM_DARWIN_X86_64, conv_darwin)
    T.assert_not_null(results, "darwin error check sequence returned", err_seq_darwin)

    Let darwin_first be List.list_get(err_seq_darwin, 0)
    T.assert_not_null(results, "darwin first error instruction non-null", darwin_first)
    Let darwin_first_type be __load(darwin_first, 0)
    T.assert_equal(results, "darwin error check uses TEST_CARRY", darwin_first_type, Generator.INST_TEST_CARRY)

    Note: Null convention should return 0
    Let null_result be Generator.generate_error_check_sequence(PlatformInterface.PLATFORM_LINUX_X86_64, 0)
    T.assert_equal(results, "null convention returns 0", null_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: optimize_syscall_sequence
Note: ============================================================================

Process called "test_optimize_syscall_sequence" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallsGenerator - optimize_syscall_sequence")

    Note: Create a sequence with a self-move (src == dst) that should be eliminated
    Let sequence be List.list_create(8)

    Note: Instruction 1: MOVE_REG from reg 5 to reg 5 (self-move, should be eliminated)
    Let self_move be Generator.create_instruction(Generator.INST_MOVE_REG, 5, 5, 0)
    List.list_append(sequence, self_move)

    Note: Instruction 2: MOVE_IMM of value 1 into register 0 (should be kept)
    Let load_num be Generator.create_instruction(Generator.INST_MOVE_IMM, 0, -1, 1)
    List.list_append(sequence, load_num)

    Note: Instruction 3: SYSCALL (should be kept)
    Let syscall_inst be Generator.create_instruction(Generator.INST_SYSCALL, -1, -1, 1)
    List.list_append(sequence, syscall_inst)

    Note: Run the optimizer
    Let removed be Generator.optimize_syscall_sequence(sequence)
    T.assert_greater_than_or_equal(results, "optimizer removed at least 1 instruction", removed, 1)

    Note: Null sequence returns -1
    Let null_result be Generator.optimize_syscall_sequence(0)
    T.assert_equal(results, "null sequence returns -1", null_result, -1)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()

    test_instruction_type_constants(results)
    test_create_instruction(results)
    test_generate_syscall_sequence(results)
    test_generate_error_check_sequence(results)
    test_optimize_syscall_sequence(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
