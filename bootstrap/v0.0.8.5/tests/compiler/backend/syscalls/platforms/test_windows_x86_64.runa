Note:
Unit Tests for Windows x86_64 NT Syscall Platform Module
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/syscalls/platforms/windows_x86_64.runa" as Platform
Import "compiler/backend/syscalls/platforms/platform_interface.runa" as PlatformInterface
Import "compiler/backend/syscalls/syscall_registry.runa" as Registry

Process called "test_create_platform_info" that takes results as Integer returns Integer:
    T.begin_suite(results, "windows_x86_64 - create_platform_info")

    Let info be Platform.create_windows_x86_64_platform_info()
    T.assert_not_null(results, "platform info is non-null", info)

    Let platform_id be __load(info, 0)
    T.assert_equal(results, "platform_id is PLATFORM_WINDOWS_X86_64", platform_id, PlatformInterface.PLATFORM_WINDOWS_X86_64)

    Let pointer_size be PlatformInterface.platform_get_pointer_size(info)
    T.assert_equal(results, "pointer_size is 8", pointer_size, 8)

    Let is_le be PlatformInterface.platform_is_little_endian(info)
    T.assert_equal(results, "is little-endian", is_le, 1)

    Return 1
End Process

Process called "test_register_syscalls" that takes results as Integer returns Integer:
    T.begin_suite(results, "windows_x86_64 - register_syscalls")

    Let reg be Registry.create_registry()
    T.assert_not_null(results, "registry created", reg)

    Let result be Platform.register_windows_x86_64_syscalls(reg)
    T.assert_equal(results, "registration returns 1", result, 1)

    Let is_registered be Registry.is_platform_registered(reg, PlatformInterface.PLATFORM_WINDOWS_X86_64)
    T.assert_equal(results, "platform is registered", is_registered, 1)

    Let count be Registry.get_platform_syscall_count(reg, PlatformInterface.PLATFORM_WINDOWS_X86_64)
    T.assert_greater_than(results, "syscall count is positive", count, 0)

    Let null_result be Platform.register_windows_x86_64_syscalls(0)
    T.assert_equal(results, "null registry returns 0", null_result, 0)

    Return 1
End Process

Process called "test_get_syscall_number" that takes results as Integer returns Integer:
    T.begin_suite(results, "windows_x86_64 - get_syscall_number")

    Let read_num be Platform.get_windows_x86_64_syscall_number("read")
    T.assert_greater_than_or_equal(results, "read syscall number is non-negative", read_num, 0)

    Let write_num be Platform.get_windows_x86_64_syscall_number("write")
    T.assert_greater_than_or_equal(results, "write syscall number is non-negative", write_num, 0)

    Let exit_num be Platform.get_windows_x86_64_syscall_number("exit")
    T.assert_greater_than_or_equal(results, "exit syscall number is non-negative", exit_num, 0)

    T.assert_not_equal(results, "read and write have different numbers", read_num, write_num)

    Return 1
End Process

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    test_create_platform_info(results)
    test_register_syscalls(results)
    test_get_syscall_number(results)
    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
