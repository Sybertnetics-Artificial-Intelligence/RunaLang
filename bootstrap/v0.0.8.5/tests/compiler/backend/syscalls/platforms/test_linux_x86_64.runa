Note:
Unit Tests for Linux x86_64 Syscall Platform Module

Validates the Linux x86_64 platform definition including platform info
creation, syscall registration, and name-to-number lookup for the primary
compilation target.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/syscalls/platforms/linux_x86_64.runa" as LinuxX86
Import "compiler/backend/syscalls/platforms/platform_interface.runa" as PlatformInterface
Import "compiler/backend/syscalls/syscall_registry.runa" as Registry

Note: ============================================================================
Note: Test: create_linux_x86_64_platform_info
Note: ============================================================================

Process called "test_create_platform_info" that takes results as Integer returns Integer:
    T.begin_suite(results, "linux_x86_64 - create_platform_info")

    Let info be LinuxX86.create_linux_x86_64_platform_info()
    T.assert_not_null(results, "platform info is non-null", info)

    Note: Verify platform_id
    Let platform_id be __load(info, 0)
    T.assert_equal(results, "platform_id is PLATFORM_LINUX_X86_64 (1)", platform_id, PlatformInterface.PLATFORM_LINUX_X86_64)

    Note: Verify pointer_size is 8 bytes (64-bit)
    Let pointer_size be PlatformInterface.platform_get_pointer_size(info)
    T.assert_equal(results, "pointer_size is 8", pointer_size, 8)

    Note: Verify little-endian
    Let is_le be PlatformInterface.platform_is_little_endian(info)
    T.assert_equal(results, "is little-endian", is_le, 1)

    Return 1
End Process

Note: ============================================================================
Note: Test: register_linux_x86_64_syscalls
Note: ============================================================================

Process called "test_register_syscalls" that takes results as Integer returns Integer:
    T.begin_suite(results, "linux_x86_64 - register_syscalls")

    Let reg be Registry.create_registry()
    T.assert_not_null(results, "registry created", reg)

    Let result be LinuxX86.register_linux_x86_64_syscalls(reg)
    T.assert_equal(results, "registration returns 1", result, 1)

    Note: Verify the platform is registered
    Let is_registered be Registry.is_platform_registered(reg, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "platform is registered", is_registered, 1)

    Note: Verify syscall count is greater than 0
    Let count be Registry.get_platform_syscall_count(reg, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_greater_than(results, "syscall count is positive", count, 0)

    Note: Null registry should fail
    Let null_result be LinuxX86.register_linux_x86_64_syscalls(0)
    T.assert_equal(results, "null registry returns 0", null_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: get_linux_x86_64_syscall_number
Note: ============================================================================

Process called "test_get_syscall_number" that takes results as Integer returns Integer:
    T.begin_suite(results, "linux_x86_64 - get_syscall_number")

    Note: Verify key syscall numbers from Linux kernel syscall_64.tbl
    Let read_num be LinuxX86.get_linux_x86_64_syscall_number("read")
    T.assert_equal(results, "read is syscall 0", read_num, 0)

    Let write_num be LinuxX86.get_linux_x86_64_syscall_number("write")
    T.assert_equal(results, "write is syscall 1", write_num, 1)

    Let exit_num be LinuxX86.get_linux_x86_64_syscall_number("exit")
    T.assert_equal(results, "exit is syscall 60", exit_num, 60)

    Let open_num be LinuxX86.get_linux_x86_64_syscall_number("open")
    T.assert_equal(results, "open is syscall 2", open_num, 2)

    Let close_num be LinuxX86.get_linux_x86_64_syscall_number("close")
    T.assert_equal(results, "close is syscall 3", close_num, 3)

    Note: All returned numbers should be non-negative
    T.assert_greater_than_or_equal(results, "read number is non-negative", read_num, 0)
    T.assert_greater_than_or_equal(results, "write number is non-negative", write_num, 0)
    T.assert_greater_than_or_equal(results, "exit number is non-negative", exit_num, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: syscall number constants
Note: ============================================================================

Process called "test_syscall_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "linux_x86_64 - syscall number constants")

    T.assert_equal(results, "SYS_X64_READ is 0", LinuxX86.SYS_X64_READ, 0)
    T.assert_equal(results, "SYS_X64_WRITE is 1", LinuxX86.SYS_X64_WRITE, 1)
    T.assert_equal(results, "SYS_X64_OPEN is 2", LinuxX86.SYS_X64_OPEN, 2)
    T.assert_equal(results, "SYS_X64_CLOSE is 3", LinuxX86.SYS_X64_CLOSE, 3)
    T.assert_equal(results, "SYS_X64_MMAP is 9", LinuxX86.SYS_X64_MMAP, 9)
    T.assert_equal(results, "SYS_X64_MUNMAP is 11", LinuxX86.SYS_X64_MUNMAP, 11)
    T.assert_equal(results, "SYS_X64_BRK is 12", LinuxX86.SYS_X64_BRK, 12)
    T.assert_equal(results, "SYS_X64_EXIT is 60", LinuxX86.SYS_X64_EXIT, 60)

    Note: All constants should be non-negative
    T.assert_greater_than_or_equal(results, "SYS_X64_READ non-negative", LinuxX86.SYS_X64_READ, 0)
    T.assert_greater_than_or_equal(results, "SYS_X64_MMAP non-negative", LinuxX86.SYS_X64_MMAP, 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()

    test_create_platform_info(results)
    test_register_syscalls(results)
    test_get_syscall_number(results)
    test_syscall_constants(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
