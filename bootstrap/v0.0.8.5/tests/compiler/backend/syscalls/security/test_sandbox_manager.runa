Note:
Unit Tests for Syscall Sandbox Manager

Validates the compile-time sandbox policy enforcement that restricts which
syscalls a compiled module may use. Tests cover sandbox creation, profile
application (MINIMAL, STANDARD, FULL), syscall allowance checking, sandbox
locking, and custom permission modification.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/syscalls/security/sandbox_manager.runa" as Sandbox
Import "compiler/backend/syscalls/security/permission_checker.runa" as Perms

Note: ============================================================================
Note: Test: create_sandbox
Note: ============================================================================

Process called "test_create_sandbox" that takes results as Integer returns Integer:
    T.begin_suite(results, "SandboxManager - create_sandbox")

    Let sb be Sandbox.create_sandbox("test_sandbox")
    T.assert_not_null(results, "sandbox is non-null", sb)

    Note: Profile should default to CUSTOM
    Let profile be Sandbox.get_sandbox_profile(sb)
    T.assert_equal(results, "default profile is CUSTOM", profile, Sandbox.PROFILE_CUSTOM)

    Note: Should not be locked
    Let is_locked be Sandbox.is_sandbox_locked(sb)
    T.assert_equal(results, "sandbox is not locked by default", is_locked, 0)

    Note: Name should match
    Let name be Sandbox.get_sandbox_name(sb)
    T.assert_string_equal(results, "sandbox name is 'test_sandbox'", name, "test_sandbox")

    Note: Permission set should be allocated
    Let pset be Sandbox.get_sandbox_permission_set(sb)
    T.assert_not_null(results, "permission set is non-null", pset)

    Return 1
End Process

Note: ============================================================================
Note: Test: apply_profile MINIMAL
Note: ============================================================================

Process called "test_apply_minimal_profile" that takes results as Integer returns Integer:
    T.begin_suite(results, "SandboxManager - apply_profile MINIMAL")

    Let sb be Sandbox.create_sandbox("minimal_test")
    T.assert_not_null(results, "sandbox created", sb)

    Let result be Sandbox.apply_profile(sb, Sandbox.PROFILE_MINIMAL)
    T.assert_equal(results, "apply_profile MINIMAL returns 1", result, 1)

    Let profile be Sandbox.get_sandbox_profile(sb)
    T.assert_equal(results, "profile is MINIMAL", profile, Sandbox.PROFILE_MINIMAL)

    Note: MINIMAL: FILESYSTEM=READ_WRITE, MEMORY=READ_WRITE, PROCESS=READ_ONLY
    Note: NETWORK=NONE, SYSTEM=NONE, IPC=NONE
    Let pset be Sandbox.get_sandbox_permission_set(sb)

    Let fs be Perms.get_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "FILESYSTEM is READ_WRITE", fs, Perms.PERM_READ_WRITE)

    Let mem be Perms.get_permission(pset, Perms.CAT_MEMORY)
    T.assert_equal(results, "MEMORY is READ_WRITE", mem, Perms.PERM_READ_WRITE)

    Let proc_p be Perms.get_permission(pset, Perms.CAT_PROCESS)
    T.assert_equal(results, "PROCESS is READ_ONLY", proc_p, Perms.PERM_READ_ONLY)

    Let net be Perms.get_permission(pset, Perms.CAT_NETWORK)
    T.assert_equal(results, "NETWORK is NONE", net, Perms.PERM_NONE)

    Let sys_p be Perms.get_permission(pset, Perms.CAT_SYSTEM)
    T.assert_equal(results, "SYSTEM is NONE", sys_p, Perms.PERM_NONE)

    Let ipc be Perms.get_permission(pset, Perms.CAT_IPC)
    T.assert_equal(results, "IPC is NONE", ipc, Perms.PERM_NONE)

    Return 1
End Process

Note: ============================================================================
Note: Test: apply_profile STANDARD
Note: ============================================================================

Process called "test_apply_standard_profile" that takes results as Integer returns Integer:
    T.begin_suite(results, "SandboxManager - apply_profile STANDARD")

    Let sb be Sandbox.create_sandbox("standard_test")
    Sandbox.apply_profile(sb, Sandbox.PROFILE_STANDARD)

    Let profile be Sandbox.get_sandbox_profile(sb)
    T.assert_equal(results, "profile is STANDARD", profile, Sandbox.PROFILE_STANDARD)

    Let pset be Sandbox.get_sandbox_permission_set(sb)

    Let fs be Perms.get_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "FILESYSTEM is READ_WRITE", fs, Perms.PERM_READ_WRITE)

    Let mem be Perms.get_permission(pset, Perms.CAT_MEMORY)
    T.assert_equal(results, "MEMORY is READ_WRITE", mem, Perms.PERM_READ_WRITE)

    Let proc_p be Perms.get_permission(pset, Perms.CAT_PROCESS)
    T.assert_equal(results, "PROCESS is READ_ONLY", proc_p, Perms.PERM_READ_ONLY)

    Let sys_p be Perms.get_permission(pset, Perms.CAT_SYSTEM)
    T.assert_equal(results, "SYSTEM is READ_ONLY", sys_p, Perms.PERM_READ_ONLY)

    Let net be Perms.get_permission(pset, Perms.CAT_NETWORK)
    T.assert_equal(results, "NETWORK is NONE", net, Perms.PERM_NONE)

    Let ipc be Perms.get_permission(pset, Perms.CAT_IPC)
    T.assert_equal(results, "IPC is READ_ONLY", ipc, Perms.PERM_READ_ONLY)

    Return 1
End Process

Note: ============================================================================
Note: Test: apply_profile FULL
Note: ============================================================================

Process called "test_apply_full_profile" that takes results as Integer returns Integer:
    T.begin_suite(results, "SandboxManager - apply_profile FULL")

    Let sb be Sandbox.create_sandbox("full_test")
    Sandbox.apply_profile(sb, Sandbox.PROFILE_FULL)

    Let profile be Sandbox.get_sandbox_profile(sb)
    T.assert_equal(results, "profile is FULL", profile, Sandbox.PROFILE_FULL)

    Let pset be Sandbox.get_sandbox_permission_set(sb)

    Note: All categories should be FULL
    Let fs be Perms.get_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "FILESYSTEM is FULL", fs, Perms.PERM_FULL)

    Let net be Perms.get_permission(pset, Perms.CAT_NETWORK)
    T.assert_equal(results, "NETWORK is FULL", net, Perms.PERM_FULL)

    Let proc_p be Perms.get_permission(pset, Perms.CAT_PROCESS)
    T.assert_equal(results, "PROCESS is FULL", proc_p, Perms.PERM_FULL)

    Let mem be Perms.get_permission(pset, Perms.CAT_MEMORY)
    T.assert_equal(results, "MEMORY is FULL", mem, Perms.PERM_FULL)

    Let sys_p be Perms.get_permission(pset, Perms.CAT_SYSTEM)
    T.assert_equal(results, "SYSTEM is FULL", sys_p, Perms.PERM_FULL)

    Let ipc be Perms.get_permission(pset, Perms.CAT_IPC)
    T.assert_equal(results, "IPC is FULL", ipc, Perms.PERM_FULL)

    Return 1
End Process

Note: ============================================================================
Note: Test: is_syscall_allowed
Note: ============================================================================

Process called "test_is_syscall_allowed" that takes results as Integer returns Integer:
    T.begin_suite(results, "SandboxManager - is_syscall_allowed")

    Note: MINIMAL profile: filesystem RW, memory RW, process RO
    Let sb be Sandbox.create_sandbox_with_profile("allow_test", Sandbox.PROFILE_MINIMAL)
    T.assert_not_null(results, "sandbox with profile created", sb)

    Note: read (0) - FILESYSTEM, READ_ONLY - allowed
    Let read_ok be Sandbox.is_syscall_allowed(sb, 0)
    T.assert_equal(results, "read is allowed in MINIMAL", read_ok, 1)

    Note: write (1) - FILESYSTEM, READ_WRITE - allowed
    Let write_ok be Sandbox.is_syscall_allowed(sb, 1)
    T.assert_equal(results, "write is allowed in MINIMAL", write_ok, 1)

    Note: exit (60) - PROCESS, READ_ONLY - allowed
    Let exit_ok be Sandbox.is_syscall_allowed(sb, 60)
    T.assert_equal(results, "exit is allowed in MINIMAL", exit_ok, 1)

    Note: mmap (9) - MEMORY, READ_WRITE - allowed
    Let mmap_ok be Sandbox.is_syscall_allowed(sb, 9)
    T.assert_equal(results, "mmap is allowed in MINIMAL", mmap_ok, 1)

    Note: socket (41) - NETWORK, READ_WRITE - denied (NETWORK is NONE)
    Let socket_denied be Sandbox.is_syscall_allowed(sb, 41)
    T.assert_equal(results, "socket is denied in MINIMAL", socket_denied, 0)

    Note: fork (57) - PROCESS, FULL - denied (PROCESS is READ_ONLY)
    Let fork_denied be Sandbox.is_syscall_allowed(sb, 57)
    T.assert_equal(results, "fork is denied in MINIMAL", fork_denied, 0)

    Note: FULL profile should allow everything
    Let sb_full be Sandbox.create_sandbox_with_profile("full_allow", Sandbox.PROFILE_FULL)
    Let fork_full be Sandbox.is_syscall_allowed(sb_full, 57)
    T.assert_equal(results, "fork is allowed in FULL", fork_full, 1)

    Let socket_full be Sandbox.is_syscall_allowed(sb_full, 41)
    T.assert_equal(results, "socket is allowed in FULL", socket_full, 1)

    Return 1
End Process

Note: ============================================================================
Note: Test: lock_sandbox
Note: ============================================================================

Process called "test_lock_sandbox" that takes results as Integer returns Integer:
    T.begin_suite(results, "SandboxManager - lock_sandbox")

    Let sb be Sandbox.create_sandbox("lock_test")
    Sandbox.apply_profile(sb, Sandbox.PROFILE_STANDARD)

    Note: Not locked initially
    Let before_lock be Sandbox.is_sandbox_locked(sb)
    T.assert_equal(results, "sandbox not locked initially", before_lock, 0)

    Note: Lock the sandbox
    Let lock_result be Sandbox.lock_sandbox(sb)
    T.assert_equal(results, "lock_sandbox returns 1", lock_result, 1)

    Let after_lock be Sandbox.is_sandbox_locked(sb)
    T.assert_equal(results, "sandbox is locked after lock_sandbox", after_lock, 1)

    Note: apply_profile should fail on locked sandbox
    Let profile_result be Sandbox.apply_profile(sb, Sandbox.PROFILE_FULL)
    T.assert_equal(results, "apply_profile fails on locked sandbox", profile_result, 0)

    Note: Profile should still be STANDARD (not changed to FULL)
    Let profile be Sandbox.get_sandbox_profile(sb)
    T.assert_equal(results, "profile remains STANDARD after failed apply", profile, Sandbox.PROFILE_STANDARD)

    Note: grant_sandbox_permission should fail on locked sandbox
    Let grant_result be Sandbox.grant_sandbox_permission(sb, Perms.CAT_NETWORK, Perms.PERM_FULL)
    T.assert_equal(results, "grant fails on locked sandbox", grant_result, 0)

    Note: revoke_sandbox_permission should fail on locked sandbox
    Let revoke_result be Sandbox.revoke_sandbox_permission(sb, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "revoke fails on locked sandbox", revoke_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: profile name helpers
Note: ============================================================================

Process called "test_profile_names" that takes results as Integer returns Integer:
    T.begin_suite(results, "SandboxManager - profile names")

    T.assert_string_equal(results, "MINIMAL name", Sandbox.get_profile_name(Sandbox.PROFILE_MINIMAL), "MINIMAL")
    T.assert_string_equal(results, "STANDARD name", Sandbox.get_profile_name(Sandbox.PROFILE_STANDARD), "STANDARD")
    T.assert_string_equal(results, "FULL name", Sandbox.get_profile_name(Sandbox.PROFILE_FULL), "FULL")
    T.assert_string_equal(results, "CUSTOM name", Sandbox.get_profile_name(Sandbox.PROFILE_CUSTOM), "CUSTOM")

    Return 1
End Process

Note: ============================================================================
Note: Test: custom permission modification
Note: ============================================================================

Process called "test_custom_permissions" that takes results as Integer returns Integer:
    T.begin_suite(results, "SandboxManager - custom permissions")

    Let sb be Sandbox.create_sandbox("custom_test")
    Sandbox.apply_profile(sb, Sandbox.PROFILE_MINIMAL)

    Note: Grant network access
    Let grant_result be Sandbox.grant_sandbox_permission(sb, Perms.CAT_NETWORK, Perms.PERM_READ_WRITE)
    T.assert_equal(results, "grant returns 1", grant_result, 1)

    Note: Profile should change to CUSTOM
    Let profile be Sandbox.get_sandbox_profile(sb)
    T.assert_equal(results, "profile changed to CUSTOM", profile, Sandbox.PROFILE_CUSTOM)

    Note: Socket should now be allowed
    Let socket_ok be Sandbox.is_syscall_allowed(sb, 41)
    T.assert_equal(results, "socket now allowed after grant", socket_ok, 1)

    Note: Revoke network
    Sandbox.revoke_sandbox_permission(sb, Perms.CAT_NETWORK)
    Let socket_denied be Sandbox.is_syscall_allowed(sb, 41)
    T.assert_equal(results, "socket denied after revoke", socket_denied, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: violation tracking through sandbox
Note: ============================================================================

Process called "test_sandbox_violations" that takes results as Integer returns Integer:
    T.begin_suite(results, "SandboxManager - violations")

    Let sb be Sandbox.create_sandbox_with_profile("violation_test", Sandbox.PROFILE_MINIMAL)

    Note: Trigger violations
    Sandbox.is_syscall_allowed(sb, 41)  Note: socket - denied
    Sandbox.is_syscall_allowed(sb, 57)  Note: fork - denied

    Let count be Sandbox.get_violation_count(sb)
    T.assert_equal(results, "violation count is 2", count, 2)

    Note: Clear violations
    Sandbox.clear_violations(sb)
    Let after_clear be Sandbox.get_violation_count(sb)
    T.assert_equal(results, "violation count is 0 after clear", after_clear, 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()

    test_create_sandbox(results)
    test_apply_minimal_profile(results)
    test_apply_standard_profile(results)
    test_apply_full_profile(results)
    test_is_syscall_allowed(results)
    test_lock_sandbox(results)
    test_profile_names(results)
    test_custom_permissions(results)
    test_sandbox_violations(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
