Note:
Unit Tests for Syscall Permission Checker

Validates the capability-based permission model that controls which syscalls
a compiled Runa module may invoke. Tests cover permission set creation,
granting and revoking permissions, checking individual syscalls against
permission levels, and violation tracking.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/syscalls/security/permission_checker.runa" as Perms
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Test: create_permission_set
Note: ============================================================================

Process called "test_create_permission_set" that takes results as Integer returns Integer:
    T.begin_suite(results, "PermissionChecker - create_permission_set")

    Let pset be Perms.create_permission_set()
    T.assert_not_null(results, "permission set is non-null", pset)

    Note: All categories should default to PERM_NONE
    Let fs_perm be Perms.get_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "FILESYSTEM defaults to NONE", fs_perm, Perms.PERM_NONE)

    Let net_perm be Perms.get_permission(pset, Perms.CAT_NETWORK)
    T.assert_equal(results, "NETWORK defaults to NONE", net_perm, Perms.PERM_NONE)

    Let proc_perm be Perms.get_permission(pset, Perms.CAT_PROCESS)
    T.assert_equal(results, "PROCESS defaults to NONE", proc_perm, Perms.PERM_NONE)

    Let mem_perm be Perms.get_permission(pset, Perms.CAT_MEMORY)
    T.assert_equal(results, "MEMORY defaults to NONE", mem_perm, Perms.PERM_NONE)

    Let sys_perm be Perms.get_permission(pset, Perms.CAT_SYSTEM)
    T.assert_equal(results, "SYSTEM defaults to NONE", sys_perm, Perms.PERM_NONE)

    Let ipc_perm be Perms.get_permission(pset, Perms.CAT_IPC)
    T.assert_equal(results, "IPC defaults to NONE", ipc_perm, Perms.PERM_NONE)

    Note: Violation count should be 0
    Let violations be Perms.get_violation_count(pset)
    T.assert_equal(results, "initial violation count is 0", violations, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: set_permission and get_permission
Note: ============================================================================

Process called "test_set_and_get_permission" that takes results as Integer returns Integer:
    T.begin_suite(results, "PermissionChecker - set_permission / get_permission")

    Let pset be Perms.create_permission_set()

    Note: Set filesystem to READ_WRITE
    Let result be Perms.set_permission(pset, Perms.CAT_FILESYSTEM, Perms.PERM_READ_WRITE)
    T.assert_equal(results, "set_permission returns 1", result, 1)

    Let fs_perm be Perms.get_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "FILESYSTEM is READ_WRITE", fs_perm, Perms.PERM_READ_WRITE)

    Note: Set network to FULL
    Perms.set_permission(pset, Perms.CAT_NETWORK, Perms.PERM_FULL)
    Let net_perm be Perms.get_permission(pset, Perms.CAT_NETWORK)
    T.assert_equal(results, "NETWORK is FULL", net_perm, Perms.PERM_FULL)

    Note: Set memory to READ_ONLY
    Perms.set_permission(pset, Perms.CAT_MEMORY, Perms.PERM_READ_ONLY)
    Let mem_perm be Perms.get_permission(pset, Perms.CAT_MEMORY)
    T.assert_equal(results, "MEMORY is READ_ONLY", mem_perm, Perms.PERM_READ_ONLY)

    Note: set_permission can downgrade (unlike grant_permission)
    Perms.set_permission(pset, Perms.CAT_NETWORK, Perms.PERM_READ_ONLY)
    Let net_perm_2 be Perms.get_permission(pset, Perms.CAT_NETWORK)
    T.assert_equal(results, "NETWORK downgraded to READ_ONLY", net_perm_2, Perms.PERM_READ_ONLY)

    Note: Invalid category returns PERM_NONE
    Let bad_perm be Perms.get_permission(pset, -1)
    T.assert_equal(results, "invalid category returns NONE", bad_perm, Perms.PERM_NONE)

    Let high_cat be Perms.get_permission(pset, 99)
    T.assert_equal(results, "out-of-range category returns NONE", high_cat, Perms.PERM_NONE)

    Note: Invalid category set returns 0
    Let bad_set be Perms.set_permission(pset, -1, Perms.PERM_FULL)
    T.assert_equal(results, "set on invalid category returns 0", bad_set, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: grant_permission (additive, never downgrades)
Note: ============================================================================

Process called "test_grant_permission" that takes results as Integer returns Integer:
    T.begin_suite(results, "PermissionChecker - grant_permission")

    Let pset be Perms.create_permission_set()

    Note: Grant READ_ONLY to filesystem
    Perms.grant_permission(pset, Perms.CAT_FILESYSTEM, Perms.PERM_READ_ONLY)
    Let fs_1 be Perms.get_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "FILESYSTEM granted READ_ONLY", fs_1, Perms.PERM_READ_ONLY)

    Note: Grant READ_WRITE to filesystem (upgrade)
    Perms.grant_permission(pset, Perms.CAT_FILESYSTEM, Perms.PERM_READ_WRITE)
    Let fs_2 be Perms.get_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "FILESYSTEM upgraded to READ_WRITE", fs_2, Perms.PERM_READ_WRITE)

    Note: Try to grant READ_ONLY again (should NOT downgrade)
    Perms.grant_permission(pset, Perms.CAT_FILESYSTEM, Perms.PERM_READ_ONLY)
    Let fs_3 be Perms.get_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "FILESYSTEM stays at READ_WRITE (no downgrade)", fs_3, Perms.PERM_READ_WRITE)

    Return 1
End Process

Note: ============================================================================
Note: Test: revoke_permission
Note: ============================================================================

Process called "test_revoke_permission" that takes results as Integer returns Integer:
    T.begin_suite(results, "PermissionChecker - revoke_permission")

    Let pset be Perms.create_permission_set()
    Perms.set_permission(pset, Perms.CAT_FILESYSTEM, Perms.PERM_FULL)

    Note: Revoke filesystem permissions
    Let result be Perms.revoke_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "revoke returns 1", result, 1)

    Let fs_perm be Perms.get_permission(pset, Perms.CAT_FILESYSTEM)
    T.assert_equal(results, "FILESYSTEM revoked to NONE", fs_perm, Perms.PERM_NONE)

    Note: Revoke on invalid category returns 0
    Let bad_revoke be Perms.revoke_permission(pset, -1)
    T.assert_equal(results, "invalid category revoke returns 0", bad_revoke, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: check_permission for different categories and levels
Note: ============================================================================

Process called "test_check_permission" that takes results as Integer returns Integer:
    T.begin_suite(results, "PermissionChecker - check_permission")

    Let pset be Perms.create_permission_set()

    Note: With all NONE, all syscalls should be denied
    Let denied_read be Perms.check_permission(pset, 0)
    T.assert_equal(results, "read denied with NONE permissions", denied_read, 0)

    Note: Grant FILESYSTEM READ_ONLY and check
    Perms.set_permission(pset, Perms.CAT_FILESYSTEM, Perms.PERM_READ_ONLY)

    Note: read (0) requires READ_ONLY in FILESYSTEM - should be allowed
    Let read_allowed be Perms.check_permission(pset, 0)
    T.assert_equal(results, "read allowed with FILESYSTEM READ_ONLY", read_allowed, 1)

    Note: write (1) requires READ_WRITE in FILESYSTEM - should be denied
    Let write_denied be Perms.check_permission(pset, 1)
    T.assert_equal(results, "write denied with FILESYSTEM READ_ONLY", write_denied, 0)

    Note: Upgrade to READ_WRITE
    Perms.set_permission(pset, Perms.CAT_FILESYSTEM, Perms.PERM_READ_WRITE)

    Note: write (1) should now be allowed
    Let write_allowed be Perms.check_permission(pset, 1)
    T.assert_equal(results, "write allowed with FILESYSTEM READ_WRITE", write_allowed, 1)

    Note: Grant PROCESS READ_ONLY for exit
    Perms.set_permission(pset, Perms.CAT_PROCESS, Perms.PERM_READ_ONLY)

    Note: exit (60) requires READ_ONLY in PROCESS - should be allowed
    Let exit_allowed be Perms.check_permission(pset, 60)
    T.assert_equal(results, "exit allowed with PROCESS READ_ONLY", exit_allowed, 1)

    Note: fork (57) requires FULL in PROCESS - should be denied
    Let fork_denied be Perms.check_permission(pset, 57)
    T.assert_equal(results, "fork denied with PROCESS READ_ONLY", fork_denied, 0)

    Note: Grant MEMORY READ_WRITE
    Perms.set_permission(pset, Perms.CAT_MEMORY, Perms.PERM_READ_WRITE)

    Note: mmap (9) requires READ_WRITE in MEMORY - should be allowed
    Let mmap_allowed be Perms.check_permission(pset, 9)
    T.assert_equal(results, "mmap allowed with MEMORY READ_WRITE", mmap_allowed, 1)

    Note: mprotect (10) requires FULL in MEMORY - should be denied
    Let mprotect_denied be Perms.check_permission(pset, 10)
    T.assert_equal(results, "mprotect denied with MEMORY READ_WRITE", mprotect_denied, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: violation logging
Note: ============================================================================

Process called "test_violation_logging" that takes results as Integer returns Integer:
    T.begin_suite(results, "PermissionChecker - violation logging")

    Let pset be Perms.create_permission_set()

    Note: Initial violation count is 0
    Let initial_count be Perms.get_violation_count(pset)
    T.assert_equal(results, "initial violation count is 0", initial_count, 0)

    Note: Trigger a violation by checking a denied syscall
    Perms.check_permission(pset, 1)   Note: write, denied because FILESYSTEM is NONE

    Let after_one be Perms.get_violation_count(pset)
    T.assert_equal(results, "violation count is 1 after denied write", after_one, 1)

    Note: Trigger more violations
    Perms.check_permission(pset, 57)  Note: fork, denied because PROCESS is NONE
    Perms.check_permission(pset, 41)  Note: socket, denied because NETWORK is NONE

    Let after_three be Perms.get_violation_count(pset)
    T.assert_equal(results, "violation count is 3 after three denials", after_three, 3)

    Note: Clear violations
    Perms.clear_violations(pset)
    Let after_clear be Perms.get_violation_count(pset)
    T.assert_equal(results, "violation count is 0 after clear", after_clear, 0)

    Note: Allowed syscalls should not increment violation count
    Perms.set_permission(pset, Perms.CAT_FILESYSTEM, Perms.PERM_READ_ONLY)
    Perms.check_permission(pset, 0)   Note: read, allowed
    Let after_allowed be Perms.get_violation_count(pset)
    T.assert_equal(results, "allowed syscall does not increment violations", after_allowed, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: get_violation retrieval
Note: ============================================================================

Process called "test_get_violation" that takes results as Integer returns Integer:
    T.begin_suite(results, "PermissionChecker - get_violation")

    Let pset be Perms.create_permission_set()

    Note: Trigger a violation for write (syscall 1)
    Perms.check_permission(pset, 1)

    Note: Allocate output pointers
    Let out_syscall be Layout.allocate(8)
    Let out_category be Layout.allocate(8)
    Let out_level be Layout.allocate(8)

    Note: Retrieve violation at index 0
    Let result be Perms.get_violation(pset, 0, out_syscall, out_category, out_level)
    T.assert_equal(results, "get_violation returns 1", result, 1)

    Let viol_syscall be __load(out_syscall, 0)
    T.assert_equal(results, "violation syscall is 1 (write)", viol_syscall, 1)

    Let viol_category be __load(out_category, 0)
    T.assert_equal(results, "violation category is FILESYSTEM (0)", viol_category, Perms.CAT_FILESYSTEM)

    Let viol_level be __load(out_level, 0)
    T.assert_equal(results, "violation required level is READ_WRITE", viol_level, Perms.PERM_READ_WRITE)

    Note: Out-of-range index returns 0
    Let bad_result be Perms.get_violation(pset, 99, out_syscall, out_category, out_level)
    T.assert_equal(results, "out-of-range index returns 0", bad_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: category and level name helpers
Note: ============================================================================

Process called "test_name_helpers" that takes results as Integer returns Integer:
    T.begin_suite(results, "PermissionChecker - name helpers")

    T.assert_string_equal(results, "CAT_FILESYSTEM name", Perms.get_category_name(Perms.CAT_FILESYSTEM), "FILESYSTEM")
    T.assert_string_equal(results, "CAT_NETWORK name", Perms.get_category_name(Perms.CAT_NETWORK), "NETWORK")
    T.assert_string_equal(results, "CAT_PROCESS name", Perms.get_category_name(Perms.CAT_PROCESS), "PROCESS")
    T.assert_string_equal(results, "CAT_MEMORY name", Perms.get_category_name(Perms.CAT_MEMORY), "MEMORY")
    T.assert_string_equal(results, "CAT_SYSTEM name", Perms.get_category_name(Perms.CAT_SYSTEM), "SYSTEM")
    T.assert_string_equal(results, "CAT_IPC name", Perms.get_category_name(Perms.CAT_IPC), "IPC")

    T.assert_string_equal(results, "PERM_NONE name", Perms.get_level_name(Perms.PERM_NONE), "NONE")
    T.assert_string_equal(results, "PERM_READ_ONLY name", Perms.get_level_name(Perms.PERM_READ_ONLY), "READ_ONLY")
    T.assert_string_equal(results, "PERM_READ_WRITE name", Perms.get_level_name(Perms.PERM_READ_WRITE), "READ_WRITE")
    T.assert_string_equal(results, "PERM_FULL name", Perms.get_level_name(Perms.PERM_FULL), "FULL")

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()

    test_create_permission_set(results)
    test_set_and_get_permission(results)
    test_grant_permission(results)
    test_revoke_permission(results)
    test_check_permission(results)
    test_violation_logging(results)
    test_get_violation(results)
    test_name_helpers(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
