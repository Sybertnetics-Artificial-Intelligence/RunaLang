Note:
Unit Tests for CompilerSyscalls

Validates the abstract compiler syscall layer that defines the 12 required
syscalls and provides platform-independent emission helpers. Tests cover
the required syscall name list, platform validation, and assembly emission
for write and exit syscalls.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/syscalls/compiler_syscalls.runa" as CompilerSyscalls
Import "compiler/backend/syscalls/syscall_registry.runa" as Registry
Import "compiler/backend/syscalls/platforms/platform_interface.runa" as PlatformInterface
Import "compiler/backend/syscalls/platforms/linux_x86_64.runa" as LinuxX86
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MachineCode
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "runtime/core/memory/chained_arena.runa" as ChainedArena

Note: ============================================================================
Note: Test: get_required_syscall_names
Note: ============================================================================

Process called "test_get_required_syscall_names" that takes results as Integer returns Integer:
    T.begin_suite(results, "CompilerSyscalls - get_required_syscall_names")

    Let names be CompilerSyscalls.get_required_syscall_names()
    T.assert_not_null(results, "get_required_syscall_names returns non-null", names)

    Note: There should be exactly 12 required syscall names
    Let count be List.list_length(names)
    T.assert_equal(results, "required syscall count is 12", count, 12)

    Note: Verify the first entry is "read"
    Let first be List.list_get(names, 0)
    T.assert_string_equal(results, "first required syscall is 'read'", first, "read")

    Note: Verify "write" is the second entry
    Let second be List.list_get(names, 1)
    T.assert_string_equal(results, "second required syscall is 'write'", second, "write")

    Note: Verify "open" is the third entry
    Let third be List.list_get(names, 2)
    T.assert_string_equal(results, "third required syscall is 'open'", third, "open")

    Note: Verify "close" is the fourth entry
    Let fourth be List.list_get(names, 3)
    T.assert_string_equal(results, "fourth required syscall is 'close'", fourth, "close")

    Note: Verify "exit" is the eighth entry
    Let eighth be List.list_get(names, 7)
    T.assert_string_equal(results, "eighth required syscall is 'exit'", eighth, "exit")

    Note: Verify "exit_group" is the twelfth (last) entry
    Let twelfth be List.list_get(names, 11)
    T.assert_string_equal(results, "twelfth required syscall is 'exit_group'", twelfth, "exit_group")

    Return 1
End Process

Note: ============================================================================
Note: Test: validate_platform_support
Note: ============================================================================

Process called "test_validate_platform_support" that takes results as Integer returns Integer:
    T.begin_suite(results, "CompilerSyscalls - validate_platform_support")

    Note: Create a registry and register Linux x86_64 with all its syscalls
    Let reg be Registry.create_registry()
    T.assert_not_null(results, "registry created", reg)

    Let reg_result be LinuxX86.register_linux_x86_64_syscalls(reg)
    T.assert_equal(results, "linux x86_64 syscalls registered", reg_result, 1)

    Note: Validate platform support - should pass since Linux x86_64 has all 12
    Let valid be CompilerSyscalls.validate_platform_support(reg, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "linux x86_64 has all required syscalls", valid, 1)

    Note: An unregistered platform should fail validation
    Let invalid be CompilerSyscalls.validate_platform_support(reg, PlatformInterface.PLATFORM_DARWIN_ARM64)
    T.assert_equal(results, "unregistered platform fails validation", invalid, 0)

    Note: Null registry should fail
    Let null_result be CompilerSyscalls.validate_platform_support(0, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "null registry fails validation", null_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: emit_syscall_sequence
Note: ============================================================================

Process called "test_emit_syscall_sequence" that takes results as Integer returns Integer:
    T.begin_suite(results, "CompilerSyscalls - emit_syscall_sequence")

    Note: Create and populate a full registry for Linux x86_64
    Let reg be Registry.create_registry()
    LinuxX86.register_linux_x86_64_syscalls(reg)

    Note: Register the convention
    Let conv be PlatformInterface.create_syscall_convention(PlatformInterface.PLATFORM_LINUX_X86_64)
    Registry.register_convention(reg, PlatformInterface.PLATFORM_LINUX_X86_64, conv)

    Note: Create a mock output buffer (using MachineCode assembly output)
    Let arena be ChainedArena.chained_arena_create(65536, 8)
    Let output be MachineCode.create_assembly_output(arena)
    T.assert_not_null(results, "assembly output created", output)

    Note: Create argument values for a write syscall: write(1, buf, 13)
    Let args be List.list_create(3)
    List.list_append(args, "$1")
    List.list_append(args, "%rsi")
    List.list_append(args, "$13")

    Note: Emit a write syscall sequence
    Let emit_result be CompilerSyscalls.emit_syscall_sequence(output, reg, PlatformInterface.PLATFORM_LINUX_X86_64, "write", args, 3)
    T.assert_equal(results, "emit_syscall_sequence returns 1 on success", emit_result, 1)

    Note: Emit for non-existent syscall should fail
    Let bad_result be CompilerSyscalls.emit_syscall_sequence(output, reg, PlatformInterface.PLATFORM_LINUX_X86_64, "nonexistent", args, 3)
    T.assert_equal(results, "emit for nonexistent syscall returns 0", bad_result, 0)

    Note: Null output should fail
    Let null_output be CompilerSyscalls.emit_syscall_sequence(0, reg, PlatformInterface.PLATFORM_LINUX_X86_64, "write", args, 3)
    T.assert_equal(results, "null output returns 0", null_output, 0)

    Note: Null registry should fail
    Let null_reg be CompilerSyscalls.emit_syscall_sequence(output, 0, PlatformInterface.PLATFORM_LINUX_X86_64, "write", args, 3)
    T.assert_equal(results, "null registry returns 0", null_reg, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: emit_exit_syscall
Note: ============================================================================

Process called "test_emit_exit_syscall" that takes results as Integer returns Integer:
    T.begin_suite(results, "CompilerSyscalls - emit_exit_syscall")

    Let reg be Registry.create_registry()
    LinuxX86.register_linux_x86_64_syscalls(reg)
    Let conv be PlatformInterface.create_syscall_convention(PlatformInterface.PLATFORM_LINUX_X86_64)
    Registry.register_convention(reg, PlatformInterface.PLATFORM_LINUX_X86_64, conv)

    Let arena be ChainedArena.chained_arena_create(65536, 8)
    Let output be MachineCode.create_assembly_output(arena)
    T.assert_not_null(results, "assembly output created for exit test", output)

    Note: Emit exit(0)
    Let result be CompilerSyscalls.emit_exit_syscall(output, reg, PlatformInterface.PLATFORM_LINUX_X86_64, "$0")
    T.assert_equal(results, "emit_exit_syscall returns 1", result, 1)

    Return 1
End Process

Note: ============================================================================
Note: Test: emit_write_syscall
Note: ============================================================================

Process called "test_emit_write_syscall" that takes results as Integer returns Integer:
    T.begin_suite(results, "CompilerSyscalls - emit_write_syscall")

    Let reg be Registry.create_registry()
    LinuxX86.register_linux_x86_64_syscalls(reg)
    Let conv be PlatformInterface.create_syscall_convention(PlatformInterface.PLATFORM_LINUX_X86_64)
    Registry.register_convention(reg, PlatformInterface.PLATFORM_LINUX_X86_64, conv)

    Let arena be ChainedArena.chained_arena_create(65536, 8)
    Let output be MachineCode.create_assembly_output(arena)
    T.assert_not_null(results, "assembly output created for write test", output)

    Note: Emit write(1, buf_ptr, 32)
    Let result be CompilerSyscalls.emit_write_syscall(output, reg, PlatformInterface.PLATFORM_LINUX_X86_64, "$1", "%rsi", "$32")
    T.assert_equal(results, "emit_write_syscall returns 1", result, 1)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()

    test_get_required_syscall_names(results)
    test_validate_platform_support(results)
    test_emit_syscall_sequence(results)
    test_emit_exit_syscall(results)
    test_emit_write_syscall(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process

Process called "main" returns Integer:
    If run_all_tests() is equal to 1:
        Return 0
    End If
    Return 1
End Process
