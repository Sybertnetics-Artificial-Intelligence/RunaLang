Note:
Unit Tests for SyscallRegistry

Validates the centralized syscall registry that maps platform IDs to their
available syscall definitions. Tests cover registry creation, platform
registration, syscall registration, name and number lookup, convention
storage, and cross-platform query operations.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/syscalls/syscall_registry.runa" as Registry
Import "compiler/backend/syscalls/platforms/platform_interface.runa" as PlatformInterface
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MachineCode
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Test: create_registry
Note: ============================================================================

Process called "test_create_registry" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallRegistry - create_registry")

    Note: A newly created registry should be non-null
    Let reg be Registry.create_registry()
    T.assert_not_null(results, "create_registry returns non-null pointer", reg)

    Note: A fresh registry should have zero platform count
    Let platform_count be __load(reg, 8)
    T.assert_equal(results, "initial platform_count is 0", platform_count, 0)

    Note: A fresh registry should have zero convention count
    Let convention_count be __load(reg, 24)
    T.assert_equal(results, "initial convention_count is 0", convention_count, 0)

    Note: The platforms dictionary should be allocated
    Let platforms_dict be __load(reg, 0)
    T.assert_not_null(results, "platforms dictionary is allocated", platforms_dict)

    Note: The conventions dictionary should be allocated
    Let conventions_dict be __load(reg, 16)
    T.assert_not_null(results, "conventions dictionary is allocated", conventions_dict)

    Return 1
End Process

Note: ============================================================================
Note: Test: registry_register_platform
Note: ============================================================================

Process called "test_registry_register_platform" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallRegistry - registry_register_platform")

    Let reg be Registry.create_registry()
    T.assert_not_null(results, "registry created for platform test", reg)

    Note: Create a mock platform info
    Let platform_info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_LINUX_X86_64, MachineCode.TARGET_ARCH_X86_64, MachineCode.TARGET_OS_LINUX, 8, PlatformInterface.ENDIAN_LITTLE)
    T.assert_not_null(results, "platform_info created", platform_info)

    Note: Register the platform
    Let result be Registry.registry_register_platform(reg, PlatformInterface.PLATFORM_LINUX_X86_64, platform_info)
    T.assert_equal(results, "register platform returns 1 on success", result, 1)

    Note: Platform count should be 1
    Let platform_count be __load(reg, 8)
    T.assert_equal(results, "platform_count is 1 after registration", platform_count, 1)

    Note: Registering the same platform again should fail (duplicate)
    Let dup_result be Registry.registry_register_platform(reg, PlatformInterface.PLATFORM_LINUX_X86_64, platform_info)
    T.assert_equal(results, "duplicate registration returns 0", dup_result, 0)

    Note: Platform count should still be 1
    Let platform_count_after be __load(reg, 8)
    T.assert_equal(results, "platform_count still 1 after duplicate", platform_count_after, 1)

    Note: Register a second platform
    Let platform_info_2 be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_LINUX_ARM64, MachineCode.TARGET_ARCH_AARCH64, MachineCode.TARGET_OS_LINUX, 8, PlatformInterface.ENDIAN_LITTLE)
    Let result_2 be Registry.registry_register_platform(reg, PlatformInterface.PLATFORM_LINUX_ARM64, platform_info_2)
    T.assert_equal(results, "register second platform returns 1", result_2, 1)

    Let platform_count_2 be __load(reg, 8)
    T.assert_equal(results, "platform_count is 2 after second registration", platform_count_2, 2)

    Note: Null registry should return 0
    Let null_result be Registry.registry_register_platform(0, PlatformInterface.PLATFORM_LINUX_X86_64, platform_info)
    T.assert_equal(results, "null registry returns 0", null_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: register_syscall
Note: ============================================================================

Process called "test_register_syscall" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallRegistry - register_syscall")

    Let reg be Registry.create_registry()
    Let platform_info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_LINUX_X86_64, MachineCode.TARGET_ARCH_X86_64, MachineCode.TARGET_OS_LINUX, 8, PlatformInterface.ENDIAN_LITTLE)
    Registry.registry_register_platform(reg, PlatformInterface.PLATFORM_LINUX_X86_64, platform_info)

    Note: Create a syscall definition for "read"
    Let read_def be PlatformInterface.create_syscall_definition(0, "read", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_not_null(results, "read syscall definition created", read_def)

    Note: Register the syscall
    Let result be Registry.register_syscall(reg, PlatformInterface.PLATFORM_LINUX_X86_64, read_def)
    T.assert_equal(results, "register_syscall returns 1", result, 1)

    Note: Verify syscall count is now 1
    Let count be Registry.get_platform_syscall_count(reg, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "platform syscall count is 1", count, 1)

    Note: Register a second syscall "write"
    Let write_def be PlatformInterface.create_syscall_definition(1, "write", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, PlatformInterface.PLATFORM_LINUX_X86_64)
    Registry.register_syscall(reg, PlatformInterface.PLATFORM_LINUX_X86_64, write_def)
    Let count_2 be Registry.get_platform_syscall_count(reg, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "platform syscall count is 2 after second", count_2, 2)

    Note: Null syscall definition should fail
    Let null_result be Registry.register_syscall(reg, PlatformInterface.PLATFORM_LINUX_X86_64, 0)
    T.assert_equal(results, "null syscall_def returns 0", null_result, 0)

    Note: Unregistered platform should fail
    Let bad_plat be Registry.register_syscall(reg, PlatformInterface.PLATFORM_DARWIN_X86_64, read_def)
    T.assert_equal(results, "unregistered platform returns 0", bad_plat, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: register_convention
Note: ============================================================================

Process called "test_register_convention" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallRegistry - register_convention")

    Let reg be Registry.create_registry()

    Note: Create a convention for Linux x86_64
    Let conv be PlatformInterface.create_syscall_convention(PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_not_null(results, "convention created", conv)

    Note: Register the convention
    Let result be Registry.register_convention(reg, PlatformInterface.PLATFORM_LINUX_X86_64, conv)
    T.assert_equal(results, "register_convention returns 1", result, 1)

    Note: Convention count should be 1
    Let conv_count be __load(reg, 24)
    T.assert_equal(results, "convention_count is 1", conv_count, 1)

    Note: Null convention should fail
    Let null_result be Registry.register_convention(reg, PlatformInterface.PLATFORM_LINUX_X86_64, 0)
    T.assert_equal(results, "null convention returns 0", null_result, 0)

    Note: Null registry should fail
    Let null_reg be Registry.register_convention(0, PlatformInterface.PLATFORM_LINUX_X86_64, conv)
    T.assert_equal(results, "null registry returns 0", null_reg, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: lookup_syscall_by_name
Note: ============================================================================

Process called "test_lookup_syscall_by_name" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallRegistry - lookup_syscall_by_name")

    Let reg be Registry.create_registry()
    Let platform_info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_LINUX_X86_64, MachineCode.TARGET_ARCH_X86_64, MachineCode.TARGET_OS_LINUX, 8, PlatformInterface.ENDIAN_LITTLE)
    Registry.registry_register_platform(reg, PlatformInterface.PLATFORM_LINUX_X86_64, platform_info)

    Note: Register two syscalls
    Let read_def be PlatformInterface.create_syscall_definition(0, "read", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, PlatformInterface.PLATFORM_LINUX_X86_64)
    Let write_def be PlatformInterface.create_syscall_definition(1, "write", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, PlatformInterface.PLATFORM_LINUX_X86_64)
    Registry.register_syscall(reg, PlatformInterface.PLATFORM_LINUX_X86_64, read_def)
    Registry.register_syscall(reg, PlatformInterface.PLATFORM_LINUX_X86_64, write_def)

    Note: Look up by name
    Let found_read be Registry.lookup_syscall_by_name(reg, PlatformInterface.PLATFORM_LINUX_X86_64, "read")
    T.assert_not_null(results, "lookup 'read' returns non-null", found_read)

    Let found_write be Registry.lookup_syscall_by_name(reg, PlatformInterface.PLATFORM_LINUX_X86_64, "write")
    T.assert_not_null(results, "lookup 'write' returns non-null", found_write)

    Note: Verify the found definition has correct syscall number
    Let read_num be PlatformInterface.syscall_def_get_number(found_read)
    T.assert_equal(results, "read syscall number is 0", read_num, 0)

    Let write_num be PlatformInterface.syscall_def_get_number(found_write)
    T.assert_equal(results, "write syscall number is 1", write_num, 1)

    Note: Look up non-existent name
    Let not_found be Registry.lookup_syscall_by_name(reg, PlatformInterface.PLATFORM_LINUX_X86_64, "nonexistent")
    T.assert_equal(results, "nonexistent name returns 0", not_found, 0)

    Note: Null registry returns 0
    Let null_result be Registry.lookup_syscall_by_name(0, PlatformInterface.PLATFORM_LINUX_X86_64, "read")
    T.assert_equal(results, "null registry returns 0", null_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: lookup_syscall_by_number
Note: ============================================================================

Process called "test_lookup_syscall_by_number" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallRegistry - lookup_syscall_by_number")

    Let reg be Registry.create_registry()
    Let platform_info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_LINUX_X86_64, MachineCode.TARGET_ARCH_X86_64, MachineCode.TARGET_OS_LINUX, 8, PlatformInterface.ENDIAN_LITTLE)
    Registry.registry_register_platform(reg, PlatformInterface.PLATFORM_LINUX_X86_64, platform_info)

    Let exit_def be PlatformInterface.create_syscall_definition(60, "exit", 1, PlatformInterface.SYSCALL_CAT_PROCESS, PlatformInterface.PLATFORM_LINUX_X86_64)
    Registry.register_syscall(reg, PlatformInterface.PLATFORM_LINUX_X86_64, exit_def)

    Note: Look up by number
    Let found be Registry.lookup_syscall_by_number(reg, PlatformInterface.PLATFORM_LINUX_X86_64, 60)
    T.assert_not_null(results, "lookup number 60 returns non-null", found)

    Note: Verify name of found definition
    Let name be PlatformInterface.syscall_def_get_name(found)
    T.assert_string_equal(results, "number 60 maps to 'exit'", name, "exit")

    Note: Non-existent number
    Let not_found be Registry.lookup_syscall_by_number(reg, PlatformInterface.PLATFORM_LINUX_X86_64, 9999)
    T.assert_equal(results, "nonexistent number returns 0", not_found, 0)

    Note: Null registry
    Let null_result be Registry.lookup_syscall_by_number(0, PlatformInterface.PLATFORM_LINUX_X86_64, 60)
    T.assert_equal(results, "null registry returns 0", null_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: get_convention
Note: ============================================================================

Process called "test_get_convention" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallRegistry - get_convention")

    Let reg be Registry.create_registry()

    Note: Register a convention
    Let conv be PlatformInterface.create_syscall_convention(PlatformInterface.PLATFORM_LINUX_X86_64)
    Registry.register_convention(reg, PlatformInterface.PLATFORM_LINUX_X86_64, conv)

    Note: Retrieve the convention
    Let retrieved be Registry.get_convention(reg, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_not_null(results, "get_convention returns non-null", retrieved)
    T.assert_equal(results, "retrieved convention matches registered", retrieved, conv)

    Note: Non-registered platform returns 0
    Let not_found be Registry.get_convention(reg, PlatformInterface.PLATFORM_DARWIN_ARM64)
    T.assert_equal(results, "non-registered platform returns 0", not_found, 0)

    Note: Null registry
    Let null_result be Registry.get_convention(0, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "null registry returns 0", null_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: get_platform_info
Note: ============================================================================

Process called "test_get_platform_info" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallRegistry - get_platform_info")

    Let reg be Registry.create_registry()
    Let platform_info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_LINUX_X86_64, MachineCode.TARGET_ARCH_X86_64, MachineCode.TARGET_OS_LINUX, 8, PlatformInterface.ENDIAN_LITTLE)
    Registry.registry_register_platform(reg, PlatformInterface.PLATFORM_LINUX_X86_64, platform_info)

    Note: Retrieve the platform info
    Let retrieved be Registry.get_platform_info(reg, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_not_null(results, "get_platform_info returns non-null", retrieved)
    T.assert_equal(results, "retrieved platform_info matches registered", retrieved, platform_info)

    Note: Verify pointer size
    Let ptr_size be PlatformInterface.platform_get_pointer_size(retrieved)
    T.assert_equal(results, "pointer size is 8 for x86_64", ptr_size, 8)

    Note: Verify endianness
    Let is_le be PlatformInterface.platform_is_little_endian(retrieved)
    T.assert_equal(results, "x86_64 is little-endian", is_le, 1)

    Note: Non-registered platform returns 0
    Let not_found be Registry.get_platform_info(reg, PlatformInterface.PLATFORM_DARWIN_ARM64)
    T.assert_equal(results, "non-registered platform returns 0", not_found, 0)

    Note: Null registry
    Let null_result be Registry.get_platform_info(0, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "null registry returns 0", null_result, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test: get_platform_syscall_count
Note: ============================================================================

Process called "test_get_platform_syscall_count" that takes results as Integer returns Integer:
    T.begin_suite(results, "SyscallRegistry - get_platform_syscall_count")

    Let reg be Registry.create_registry()
    Let platform_info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_LINUX_X86_64, MachineCode.TARGET_ARCH_X86_64, MachineCode.TARGET_OS_LINUX, 8, PlatformInterface.ENDIAN_LITTLE)
    Registry.registry_register_platform(reg, PlatformInterface.PLATFORM_LINUX_X86_64, platform_info)

    Note: Initially zero syscalls
    Let count_0 be Registry.get_platform_syscall_count(reg, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "initial syscall count is 0", count_0, 0)

    Note: Register some syscalls
    Let read_def be PlatformInterface.create_syscall_definition(0, "read", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, PlatformInterface.PLATFORM_LINUX_X86_64)
    Let write_def be PlatformInterface.create_syscall_definition(1, "write", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, PlatformInterface.PLATFORM_LINUX_X86_64)
    Let exit_def be PlatformInterface.create_syscall_definition(60, "exit", 1, PlatformInterface.SYSCALL_CAT_PROCESS, PlatformInterface.PLATFORM_LINUX_X86_64)
    Registry.register_syscall(reg, PlatformInterface.PLATFORM_LINUX_X86_64, read_def)
    Registry.register_syscall(reg, PlatformInterface.PLATFORM_LINUX_X86_64, write_def)
    Registry.register_syscall(reg, PlatformInterface.PLATFORM_LINUX_X86_64, exit_def)

    Let count_3 be Registry.get_platform_syscall_count(reg, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "syscall count is 3 after registrations", count_3, 3)

    Note: Non-registered platform returns 0
    Let count_none be Registry.get_platform_syscall_count(reg, PlatformInterface.PLATFORM_DARWIN_ARM64)
    T.assert_equal(results, "non-registered platform returns 0", count_none, 0)

    Note: Null registry returns 0
    Let count_null be Registry.get_platform_syscall_count(0, PlatformInterface.PLATFORM_LINUX_X86_64)
    T.assert_equal(results, "null registry returns 0", count_null, 0)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()

    test_create_registry(results)
    test_registry_register_platform(results)
    test_register_syscall(results)
    test_register_convention(results)
    test_lookup_syscall_by_name(results)
    test_lookup_syscall_by_number(results)
    test_get_convention(results)
    test_get_platform_info(results)
    test_get_platform_syscall_count(results)

    T.print_summary(results)
    Return T.all_passed(results)
End Process
