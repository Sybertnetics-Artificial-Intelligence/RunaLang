Note:
Syscall Test Suite Runner

Runs all 26 syscall test files covering:
- 3 core modules (registry, compiler_syscalls, generator)
- 19 platform modules (one per supported target)
- 2 security modules (permission_checker, sandbox_manager)

Reports aggregate pass/fail results across all test suites.
:End Note

Import "tests/test_utils.runa" as T

Note: Core module tests
Import "tests/compiler/backend/syscalls/test_syscall_registry.runa" as TestRegistry
Import "tests/compiler/backend/syscalls/test_compiler_syscalls.runa" as TestCompilerSyscalls
Import "tests/compiler/backend/syscalls/test_syscalls_generator.runa" as TestGenerator

Note: Platform tests
Import "tests/compiler/backend/syscalls/platforms/test_linux_x86_64.runa" as TestLinuxX86
Import "tests/compiler/backend/syscalls/platforms/test_linux_arm64.runa" as TestLinuxARM64
Import "tests/compiler/backend/syscalls/platforms/test_linux_arm32.runa" as TestLinuxARM32
Import "tests/compiler/backend/syscalls/platforms/test_darwin_x86_64.runa" as TestDarwinX86
Import "tests/compiler/backend/syscalls/platforms/test_darwin_arm64.runa" as TestDarwinARM64
Import "tests/compiler/backend/syscalls/platforms/test_windows_x86_64.runa" as TestWindowsX86
Import "tests/compiler/backend/syscalls/platforms/test_windows_arm64.runa" as TestWindowsARM64
Import "tests/compiler/backend/syscalls/platforms/test_freebsd_x86_64.runa" as TestFreeBSDX86
Import "tests/compiler/backend/syscalls/platforms/test_freebsd_arm64.runa" as TestFreeBSDARM64
Import "tests/compiler/backend/syscalls/platforms/test_openbsd_x86_64.runa" as TestOpenBSDX86
Import "tests/compiler/backend/syscalls/platforms/test_openbsd_arm64.runa" as TestOpenBSDARM64
Import "tests/compiler/backend/syscalls/platforms/test_netbsd_x86_64.runa" as TestNetBSDX86
Import "tests/compiler/backend/syscalls/platforms/test_netbsd_arm64.runa" as TestNetBSDARM64
Import "tests/compiler/backend/syscalls/platforms/test_mips32.runa" as TestMIPS32
Import "tests/compiler/backend/syscalls/platforms/test_mips64.runa" as TestMIPS64
Import "tests/compiler/backend/syscalls/platforms/test_powerpc.runa" as TestPowerPC
Import "tests/compiler/backend/syscalls/platforms/test_riscv32.runa" as TestRISCV32
Import "tests/compiler/backend/syscalls/platforms/test_riscv64.runa" as TestRISCV64
Import "tests/compiler/backend/syscalls/platforms/test_wasm_wasi.runa" as TestWasmWASI

Note: Security tests
Import "tests/compiler/backend/syscalls/security/test_permission_checker.runa" as TestPermissions
Import "tests/compiler/backend/syscalls/security/test_sandbox_manager.runa" as TestSandbox

Note: ============================================================================
Note: Suite Runner
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let all_passed be 1

    Display "========================================================"
    Display "  SYSCALL TEST SUITE - Running all 26 test files"
    Display "========================================================"
    Display ""

    Note: ----------------------------------------------------------------
    Note: Core Module Tests (3)
    Note: ----------------------------------------------------------------

    Display "--- Core Module Tests ---"

    Let r1 be TestRegistry.run_all_tests()
    If r1 is 0:
        Set all_passed to 0
    End If

    Let r2 be TestCompilerSyscalls.run_all_tests()
    If r2 is 0:
        Set all_passed to 0
    End If

    Let r3 be TestGenerator.run_all_tests()
    If r3 is 0:
        Set all_passed to 0
    End If

    Note: ----------------------------------------------------------------
    Note: Platform Tests (19)
    Note: ----------------------------------------------------------------

    Display ""
    Display "--- Platform Tests ---"

    Let p1 be TestLinuxX86.run_all_tests()
    If p1 is 0:
        Set all_passed to 0
    End If

    Let p2 be TestLinuxARM64.run_all_tests()
    If p2 is 0:
        Set all_passed to 0
    End If

    Let p3 be TestLinuxARM32.run_all_tests()
    If p3 is 0:
        Set all_passed to 0
    End If

    Let p4 be TestDarwinX86.run_all_tests()
    If p4 is 0:
        Set all_passed to 0
    End If

    Let p5 be TestDarwinARM64.run_all_tests()
    If p5 is 0:
        Set all_passed to 0
    End If

    Let p6 be TestWindowsX86.run_all_tests()
    If p6 is 0:
        Set all_passed to 0
    End If

    Let p7 be TestWindowsARM64.run_all_tests()
    If p7 is 0:
        Set all_passed to 0
    End If

    Let p8 be TestFreeBSDX86.run_all_tests()
    If p8 is 0:
        Set all_passed to 0
    End If

    Let p9 be TestFreeBSDARM64.run_all_tests()
    If p9 is 0:
        Set all_passed to 0
    End If

    Let p10 be TestOpenBSDX86.run_all_tests()
    If p10 is 0:
        Set all_passed to 0
    End If

    Let p11 be TestOpenBSDARM64.run_all_tests()
    If p11 is 0:
        Set all_passed to 0
    End If

    Let p12 be TestNetBSDX86.run_all_tests()
    If p12 is 0:
        Set all_passed to 0
    End If

    Let p13 be TestNetBSDARM64.run_all_tests()
    If p13 is 0:
        Set all_passed to 0
    End If

    Let p14 be TestMIPS32.run_all_tests()
    If p14 is 0:
        Set all_passed to 0
    End If

    Let p15 be TestMIPS64.run_all_tests()
    If p15 is 0:
        Set all_passed to 0
    End If

    Let p16 be TestPowerPC.run_all_tests()
    If p16 is 0:
        Set all_passed to 0
    End If

    Let p17 be TestRISCV32.run_all_tests()
    If p17 is 0:
        Set all_passed to 0
    End If

    Let p18 be TestRISCV64.run_all_tests()
    If p18 is 0:
        Set all_passed to 0
    End If

    Let p19 be TestWasmWASI.run_all_tests()
    If p19 is 0:
        Set all_passed to 0
    End If

    Note: ----------------------------------------------------------------
    Note: Security Tests (2)
    Note: ----------------------------------------------------------------

    Display ""
    Display "--- Security Tests ---"

    Let s1 be TestPermissions.run_all_tests()
    If s1 is 0:
        Set all_passed to 0
    End If

    Let s2 be TestSandbox.run_all_tests()
    If s2 is 0:
        Set all_passed to 0
    End If

    Note: ----------------------------------------------------------------
    Note: Final Summary
    Note: ----------------------------------------------------------------

    Display ""
    Display "========================================================"
    If all_passed is 1:
        Display "  SYSCALL TEST SUITE: ALL 26 TEST FILES PASSED"
    Otherwise:
        Display "  SYSCALL TEST SUITE: SOME TEST FILES FAILED"
    End If
    Display "========================================================"
    Display ""

    Return all_passed
End Process
