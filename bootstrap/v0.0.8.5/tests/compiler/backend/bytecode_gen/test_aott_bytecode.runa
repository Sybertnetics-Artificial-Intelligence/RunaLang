Note:
Unit Tests for AOTT Bytecode Generator

Comprehensive test suite for compiler/backend/bytecode_gen/aott_bytecode.runa.
Exercises all 20 public processes: module creation, constant pool management,
function table management, bytecode instruction encoding, LIR opcode mapping,
byte emission helpers, and complete module encoding.

Each test process operates on freshly created module instances to ensure
isolation between tests. Tests verify return values, internal state mutations
(constant counts, function counts, bytecode sizes), and byte-level output
correctness.

Dependencies:
- tests/test_utils.runa for assertion library and result tracking
- compiler/backend/bytecode_gen/aott_bytecode.runa as the unit under test
- compiler/backend/machine_code/common/machine_code_interface.runa for BinaryOutput creation
- compiler/frontend/primitives/memory/layout.runa for raw memory allocation
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/bytecode_gen/aott_bytecode.runa" as AOTT
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MachineCode
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Helper: Create a BinaryOutput for use as the module's output buffer
Note: ============================================================================

Process called "create_test_output" returns Integer:
    Note: Allocates a minimal BinaryOutput structure that AOTT can emit bytes into.
    Note: BinaryOutput layout: code_buf(8), code_size(8), code_cap(8), ...
    Note: We use MachineCode.create_binary_output for a properly initialized buffer.
    Let output be MachineCode.create_binary_output(0)
    Return output
End Process

Note: ============================================================================
Note: Test 1: create_bytecode_module returns non-null with zeroed counters
Note: ============================================================================

Process called "test_create_module" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_create_module")

    Let output be create_test_output()
    T.assert_not_null(results, "output buffer allocated", output)

    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module pointer is non-null", module)

    Note: Verify all counters start at zero
    Let const_count be AOTT.get_constant_count(module)
    T.assert_equal(results, "initial constant count is 0", const_count, 0)

    Let func_count be AOTT.get_function_count(module)
    T.assert_equal(results, "initial function count is 0", func_count, 0)

    Let bc_size be AOTT.get_bytecode_size(module)
    T.assert_equal(results, "initial bytecode size is 0", bc_size, 0)

    Note: Verify entry point is -1 (none set)
    Let entry be __load(module, 64)
    T.assert_equal(results, "initial entry point is -1", entry, -1)

    Note: Verify flags are 0
    Let flags be __load(module, 72)
    T.assert_equal(results, "initial flags are 0", flags, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test 2: set_entry_point and set_module_flags store values correctly
Note: ============================================================================

Process called "test_set_entry_and_flags" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_set_entry_and_flags")

    Let output be create_test_output()
    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module created for entry/flags test", module)

    Note: Set entry point to function index 5
    Let ret1 be AOTT.set_entry_point(module, 5)
    T.assert_equal(results, "set_entry_point returns 1", ret1, 1)

    Let entry be __load(module, 64)
    T.assert_equal(results, "entry point stored as 5", entry, 5)

    Note: Overwrite entry point to function index 0
    AOTT.set_entry_point(module, 0)
    Let entry2 be __load(module, 64)
    T.assert_equal(results, "entry point updated to 0", entry2, 0)

    Note: Set module flags to DEBUG | OPTIMIZE (1 | 2 = 3)
    Let ret2 be AOTT.set_module_flags(module, 3)
    T.assert_equal(results, "set_module_flags returns 1", ret2, 1)

    Let flags be __load(module, 72)
    T.assert_equal(results, "flags stored as 3", flags, 3)

    Note: Overwrite flags to CHECKED only (4)
    AOTT.set_module_flags(module, 4)
    Let flags2 be __load(module, 72)
    T.assert_equal(results, "flags updated to 4", flags2, 4)

    Return 1
End Process

Note: ============================================================================
Note: Test 3: add_integer_constant returns sequential indices
Note: ============================================================================

Process called "test_add_integer_constant" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_add_integer_constant")

    Let output be create_test_output()
    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module created for int constant test", module)

    Note: First constant gets index 0
    Let idx0 be AOTT.add_integer_constant(module, 42)
    T.assert_equal(results, "first integer constant index is 0", idx0, 0)

    Note: Second constant gets index 1
    Let idx1 be AOTT.add_integer_constant(module, 100)
    T.assert_equal(results, "second integer constant index is 1", idx1, 1)

    Note: Third constant gets index 2
    Let idx2 be AOTT.add_integer_constant(module, -7)
    T.assert_equal(results, "third integer constant index is 2", idx2, 2)

    Note: Verify constant count matches
    Let count be AOTT.get_constant_count(module)
    T.assert_equal(results, "constant count is 3 after adding 3 integers", count, 3)

    Note: Verify constant pool size:
    Note: Each integer entry is tag(1) + value(8) = 9 bytes
    Note: 3 entries = 27 bytes
    Let pool_size be __load(module, 24)
    T.assert_equal(results, "constant pool size is 27 bytes", pool_size, 27)

    Note: Verify the tag byte of the first entry is CONST_TAG_INTEGER (0)
    Let const_pool be __load(module, 8)
    Let tag0 be __load8(const_pool, 0)
    T.assert_equal(results, "first entry tag is INTEGER (0)", tag0, 0)

    Note: Verify the stored value of the first entry (at offset 1, 8 bytes LE)
    Let val0 be __load(const_pool, 1)
    T.assert_equal(results, "first entry value is 42", val0, 42)

    Return 1
End Process

Note: ============================================================================
Note: Test 4: add_float_constant returns correct index
Note: ============================================================================

Process called "test_add_float_constant" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_add_float_constant")

    Let output be create_test_output()
    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module created for float constant test", module)

    Note: Add a float constant (bit representation passed as integer)
    Note: IEEE 754 double for 3.14 is approximately 0x40091EB851EB851F
    Note: We pass any integer as the bit pattern
    Let idx0 be AOTT.add_float_constant(module, 4614253070214989087)
    T.assert_equal(results, "first float constant index is 0", idx0, 0)

    Let idx1 be AOTT.add_float_constant(module, 0)
    T.assert_equal(results, "second float constant index is 1", idx1, 1)

    Let count be AOTT.get_constant_count(module)
    T.assert_equal(results, "constant count is 2 after adding 2 floats", count, 2)

    Note: Verify constant pool size:
    Note: Each float entry is tag(1) + value(8) = 9 bytes
    Note: 2 entries = 18 bytes
    Let pool_size be __load(module, 24)
    T.assert_equal(results, "constant pool size is 18 bytes", pool_size, 18)

    Note: Verify the tag byte of first entry is CONST_TAG_FLOAT (1)
    Let const_pool be __load(module, 8)
    Let tag0 be __load8(const_pool, 0)
    T.assert_equal(results, "first entry tag is FLOAT (1)", tag0, 1)

    Return 1
End Process

Note: ============================================================================
Note: Test 5: add_string_constant returns correct index and increments count
Note: ============================================================================

Process called "test_add_string_constant" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_add_string_constant")

    Let output be create_test_output()
    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module created for string constant test", module)

    Note: Create a string "hello" in memory: 5 bytes
    Let str_buf be Layout.allocate(8)
    T.assert_not_null(results, "string buffer allocated", str_buf)
    __store8(str_buf, 0, 104)   Note: 'h'
    __store8(str_buf, 1, 101)   Note: 'e'
    __store8(str_buf, 2, 108)   Note: 'l'
    __store8(str_buf, 3, 108)   Note: 'l'
    __store8(str_buf, 4, 111)   Note: 'o'

    Let idx0 be AOTT.add_string_constant(module, str_buf, 5)
    T.assert_equal(results, "first string constant index is 0", idx0, 0)

    Note: Add a second string "ab": 2 bytes
    Let str2_buf be Layout.allocate(4)
    __store8(str2_buf, 0, 97)   Note: 'a'
    __store8(str2_buf, 1, 98)   Note: 'b'

    Let idx1 be AOTT.add_string_constant(module, str2_buf, 2)
    T.assert_equal(results, "second string constant index is 1", idx1, 1)

    Let count be AOTT.get_constant_count(module)
    T.assert_equal(results, "constant count is 2 after adding 2 strings", count, 2)

    Note: Verify constant pool size:
    Note: String entry format: tag(1) + length(4) + bytes(str_len)
    Note: Entry 0: 1 + 4 + 5 = 10 bytes
    Note: Entry 1: 1 + 4 + 2 = 7 bytes
    Note: Total = 17 bytes
    Let pool_size be __load(module, 24)
    T.assert_equal(results, "constant pool size is 17 bytes", pool_size, 17)

    Note: Verify the tag byte of the first entry is CONST_TAG_STRING (2)
    Let const_pool be __load(module, 8)
    Let tag0 be __load8(const_pool, 0)
    T.assert_equal(results, "first entry tag is STRING (2)", tag0, 2)

    Note: Verify the length field of the first entry (4 bytes LE at offset 1)
    Note: Length should be 5 for "hello"
    Let len_byte0 be __load8(const_pool, 1)
    T.assert_equal(results, "first entry length byte0 is 5", len_byte0, 5)
    Let len_byte1 be __load8(const_pool, 2)
    T.assert_equal(results, "first entry length byte1 is 0", len_byte1, 0)

    Note: Verify the first character of the string data (offset 5)
    Let first_char be __load8(const_pool, 5)
    T.assert_equal(results, "first string byte is 'h' (104)", first_char, 104)

    Return 1
End Process

Note: ============================================================================
Note: Test 6: add_function_entry returns incrementing indices
Note: ============================================================================

Process called "test_add_function_entry" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_add_function_entry")

    Let output be create_test_output()
    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module created for function entry test", module)

    Note: Add first function entry
    Note: name_idx=0, bytecode_off=0, bytecode_len=10, local_count=3, arg_count=2, flags=EXPORT(1)
    Let fidx0 be AOTT.add_function_entry(module, 0, 0, 10, 3, 2, 1)
    T.assert_equal(results, "first function index is 0", fidx0, 0)

    Note: Add second function entry
    Note: name_idx=1, bytecode_off=10, bytecode_len=20, local_count=5, arg_count=1, flags=INLINE(2)
    Let fidx1 be AOTT.add_function_entry(module, 1, 10, 20, 5, 1, 2)
    T.assert_equal(results, "second function index is 1", fidx1, 1)

    Note: Add third function entry
    Let fidx2 be AOTT.add_function_entry(module, 2, 30, 15, 0, 0, 8)
    T.assert_equal(results, "third function index is 2", fidx2, 2)

    Note: Verify function count
    Let fcount be AOTT.get_function_count(module)
    T.assert_equal(results, "function count is 3", fcount, 3)

    Note: Verify function table data for first entry
    Note: Each entry is 24 bytes: name_idx(4) + bc_off(4) + bc_len(4) +
    Note: local_count(4) + arg_count(4) + flags(4)
    Let func_table be __load(module, 32)

    Note: First entry at offset 0
    Let name0 be __load(func_table, 0)
    T.assert_equal(results, "entry 0 name_idx is 0", name0, 0)
    Let bcoff0 be __load(func_table, 4)
    T.assert_equal(results, "entry 0 bytecode_off is 0", bcoff0, 0)
    Let bclen0 be __load(func_table, 8)
    T.assert_equal(results, "entry 0 bytecode_len is 10", bclen0, 10)
    Let locals0 be __load(func_table, 12)
    T.assert_equal(results, "entry 0 local_count is 3", locals0, 3)
    Let args0 be __load(func_table, 16)
    T.assert_equal(results, "entry 0 arg_count is 2", args0, 2)
    Let flags0 be __load(func_table, 20)
    T.assert_equal(results, "entry 0 flags is EXPORT (1)", flags0, 1)

    Note: Second entry at offset 24
    Let name1 be __load(func_table, 24)
    T.assert_equal(results, "entry 1 name_idx is 1", name1, 1)
    Let flags1 be __load(func_table, 44)
    T.assert_equal(results, "entry 1 flags is INLINE (2)", flags1, 2)

    Return 1
End Process

Note: ============================================================================
Note: Test 7: encode_bytecode_instruction returns offset 0, size becomes 1
Note: ============================================================================

Process called "test_encode_single_byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_encode_single_byte")

    Let output be create_test_output()
    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module created for single byte encoding test", module)

    Note: Encode a NOP instruction (opcode 0)
    Let offset0 be AOTT.encode_bytecode_instruction(module, 0)
    T.assert_equal(results, "first instruction offset is 0", offset0, 0)

    Let size1 be AOTT.get_bytecode_size(module)
    T.assert_equal(results, "bytecode size is 1 after one instruction", size1, 1)

    Note: Verify the byte was written correctly in the bytecode buffer
    Let bytecode_buf be __load(module, 48)
    Let byte0 be __load8(bytecode_buf, 0)
    T.assert_equal(results, "NOP opcode byte is 0", byte0, 0)

    Note: Encode a HALT instruction (opcode 1)
    Let offset1 be AOTT.encode_bytecode_instruction(module, 1)
    T.assert_equal(results, "second instruction offset is 1", offset1, 1)

    Let size2 be AOTT.get_bytecode_size(module)
    T.assert_equal(results, "bytecode size is 2 after two instructions", size2, 2)

    Note: Encode a RET instruction (opcode 2)
    Let offset2 be AOTT.encode_bytecode_instruction(module, 2)
    T.assert_equal(results, "third instruction offset is 2", offset2, 2)

    Let size3 be AOTT.get_bytecode_size(module)
    T.assert_equal(results, "bytecode size is 3 after three instructions", size3, 3)

    Note: Verify HALT byte in buffer
    Let byte1 be __load8(bytecode_buf, 1)
    T.assert_equal(results, "HALT opcode byte is 1", byte1, 1)

    Note: Verify RET byte in buffer
    Let byte2 be __load8(bytecode_buf, 2)
    T.assert_equal(results, "RET opcode byte is 2", byte2, 2)

    Return 1
End Process

Note: ============================================================================
Note: Test 8: encode_bytecode_with_u32 increments bytecode size by 5
Note: ============================================================================

Process called "test_encode_with_u32" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_encode_with_u32")

    Let output be create_test_output()
    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module created for u32 encoding test", module)

    Note: Encode CALL instruction with function index 7
    Note: AOTT_OP_CALL = 3, operand = 7
    Let offset0 be AOTT.encode_bytecode_with_u32(module, 3, 7)
    T.assert_equal(results, "first u32 instruction offset is 0", offset0, 0)

    Let size1 be AOTT.get_bytecode_size(module)
    T.assert_equal(results, "bytecode size is 5 after one u32 instruction", size1, 5)

    Note: Verify the opcode byte
    Let bytecode_buf be __load(module, 48)
    Let op_byte be __load8(bytecode_buf, 0)
    T.assert_equal(results, "CALL opcode byte is 3", op_byte, 3)

    Note: Verify the operand bytes (7 in little-endian = 07 00 00 00)
    Let operand_byte0 be __load8(bytecode_buf, 1)
    T.assert_equal(results, "operand byte0 is 7", operand_byte0, 7)
    Let operand_byte1 be __load8(bytecode_buf, 2)
    T.assert_equal(results, "operand byte1 is 0", operand_byte1, 0)
    Let operand_byte2 be __load8(bytecode_buf, 3)
    T.assert_equal(results, "operand byte2 is 0", operand_byte2, 0)
    Let operand_byte3 be __load8(bytecode_buf, 4)
    T.assert_equal(results, "operand byte3 is 0", operand_byte3, 0)

    Note: Encode a second instruction with a larger operand
    Note: CONST_I32 = 128, value = 0x01020304 = 16909060
    Let offset1 be AOTT.encode_bytecode_with_u32(module, 128, 16909060)
    T.assert_equal(results, "second u32 instruction offset is 5", offset1, 5)

    Let size2 be AOTT.get_bytecode_size(module)
    T.assert_equal(results, "bytecode size is 10 after two u32 instructions", size2, 10)

    Note: Verify multi-byte operand in little-endian
    Note: 16909060 = 0x01020304
    Note: LE bytes: 04, 03, 02, 01
    Let op2_byte be __load8(bytecode_buf, 5)
    T.assert_equal(results, "second opcode byte is 128", op2_byte, 128)

    Let val_byte0 be __load8(bytecode_buf, 6)
    T.assert_equal(results, "16909060 LE byte0 is 4", val_byte0, 4)
    Let val_byte1 be __load8(bytecode_buf, 7)
    T.assert_equal(results, "16909060 LE byte1 is 3", val_byte1, 3)
    Let val_byte2 be __load8(bytecode_buf, 8)
    T.assert_equal(results, "16909060 LE byte2 is 2", val_byte2, 2)
    Let val_byte3 be __load8(bytecode_buf, 9)
    T.assert_equal(results, "16909060 LE byte3 is 1", val_byte3, 1)

    Return 1
End Process

Note: ============================================================================
Note: Test 9: encode_bytecode_with_u16 increments bytecode size by 3
Note: ============================================================================

Process called "test_encode_with_u16" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_encode_with_u16")

    Let output be create_test_output()
    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module created for u16 encoding test", module)

    Note: Encode LOAD_LOCAL with local index 5
    Note: AOTT_OP_LOAD_LOCAL = 32, operand = 5
    Let offset0 be AOTT.encode_bytecode_with_u16(module, 32, 5)
    T.assert_equal(results, "first u16 instruction offset is 0", offset0, 0)

    Let size1 be AOTT.get_bytecode_size(module)
    T.assert_equal(results, "bytecode size is 3 after one u16 instruction", size1, 3)

    Note: Verify the bytes in buffer
    Let bytecode_buf be __load(module, 48)
    Let op_byte be __load8(bytecode_buf, 0)
    T.assert_equal(results, "LOAD_LOCAL opcode byte is 32", op_byte, 32)

    Note: Operand 5 in little-endian u16 = 05 00
    Let lo_byte be __load8(bytecode_buf, 1)
    T.assert_equal(results, "operand lo byte is 5", lo_byte, 5)
    Let hi_byte be __load8(bytecode_buf, 2)
    T.assert_equal(results, "operand hi byte is 0", hi_byte, 0)

    Note: Encode STORE_LOCAL with local index 258 (0x0102)
    Note: AOTT_OP_STORE_LOCAL = 33, operand = 258
    Let offset1 be AOTT.encode_bytecode_with_u16(module, 33, 258)
    T.assert_equal(results, "second u16 instruction offset is 3", offset1, 3)

    Let size2 be AOTT.get_bytecode_size(module)
    T.assert_equal(results, "bytecode size is 6 after two u16 instructions", size2, 6)

    Note: Verify operand bytes for 258 = 0x0102 LE: 02 01
    Let lo2 be __load8(bytecode_buf, 4)
    T.assert_equal(results, "258 LE lo byte is 2", lo2, 2)
    Let hi2 be __load8(bytecode_buf, 5)
    T.assert_equal(results, "258 LE hi byte is 1", hi2, 1)

    Return 1
End Process

Note: ============================================================================
Note: Test 10: lir_opcode_to_aott maps known opcodes, -1 for unknown
Note: ============================================================================

Process called "test_lir_opcode_mapping" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_lir_opcode_mapping")

    Note: Test arithmetic opcode mappings
    Note: LIR_OP_ADD = 30001 -> AOTT_OP_ADD = 64
    Let add_op be AOTT.lir_opcode_to_aott(30001)
    T.assert_equal(results, "LIR_OP_ADD maps to AOTT_OP_ADD (64)", add_op, 64)

    Note: LIR_OP_SUB = 30002 -> AOTT_OP_SUB = 65
    Let sub_op be AOTT.lir_opcode_to_aott(30002)
    T.assert_equal(results, "LIR_OP_SUB maps to AOTT_OP_SUB (65)", sub_op, 65)

    Note: LIR_OP_MUL = 30003 -> AOTT_OP_MUL = 66
    Let mul_op be AOTT.lir_opcode_to_aott(30003)
    T.assert_equal(results, "LIR_OP_MUL maps to AOTT_OP_MUL (66)", mul_op, 66)

    Note: LIR_OP_DIV = 30004 -> AOTT_OP_DIV = 67
    Let div_op be AOTT.lir_opcode_to_aott(30004)
    T.assert_equal(results, "LIR_OP_DIV maps to AOTT_OP_DIV (67)", div_op, 67)

    Note: LIR_OP_MOD = 30005 -> AOTT_OP_MOD = 68
    Let mod_op be AOTT.lir_opcode_to_aott(30005)
    T.assert_equal(results, "LIR_OP_MOD maps to AOTT_OP_MOD (68)", mod_op, 68)

    Note: Test bitwise opcode mappings
    Note: LIR_OP_AND = 30006 -> AOTT_OP_AND = 96
    Let and_op be AOTT.lir_opcode_to_aott(30006)
    T.assert_equal(results, "LIR_OP_AND maps to AOTT_OP_AND (96)", and_op, 96)

    Note: LIR_OP_OR = 30007 -> AOTT_OP_OR = 97
    Let or_op be AOTT.lir_opcode_to_aott(30007)
    T.assert_equal(results, "LIR_OP_OR maps to AOTT_OP_OR (97)", or_op, 97)

    Note: LIR_OP_XOR = 30008 -> AOTT_OP_XOR = 98
    Let xor_op be AOTT.lir_opcode_to_aott(30008)
    T.assert_equal(results, "LIR_OP_XOR maps to AOTT_OP_XOR (98)", xor_op, 98)

    Note: LIR_OP_SHL = 30009 -> AOTT_OP_SHL = 99
    Let shl_op be AOTT.lir_opcode_to_aott(30009)
    T.assert_equal(results, "LIR_OP_SHL maps to AOTT_OP_SHL (99)", shl_op, 99)

    Note: LIR_OP_SHR = 30010 -> AOTT_OP_SHR = 100
    Let shr_op be AOTT.lir_opcode_to_aott(30010)
    T.assert_equal(results, "LIR_OP_SHR maps to AOTT_OP_SHR (100)", shr_op, 100)

    Note: LIR_OP_SAR = 30011 -> AOTT_OP_SAR = 101
    Let sar_op be AOTT.lir_opcode_to_aott(30011)
    T.assert_equal(results, "LIR_OP_SAR maps to AOTT_OP_SAR (101)", sar_op, 101)

    Note: Test memory opcode mappings
    Note: LIR_OP_LOAD = 30020 -> AOTT_OP_LOAD_MEM = 48
    Let load_op be AOTT.lir_opcode_to_aott(30020)
    T.assert_equal(results, "LIR_OP_LOAD maps to AOTT_OP_LOAD_MEM (48)", load_op, 48)

    Note: LIR_OP_STORE = 30021 -> AOTT_OP_STORE_MEM = 49
    Let store_op be AOTT.lir_opcode_to_aott(30021)
    T.assert_equal(results, "LIR_OP_STORE maps to AOTT_OP_STORE_MEM (49)", store_op, 49)

    Note: Test MOV and immediate loading
    Note: LIR_OP_MOV = 30030 -> AOTT_OP_MOV = 144
    Let mov_op be AOTT.lir_opcode_to_aott(30030)
    T.assert_equal(results, "LIR_OP_MOV maps to AOTT_OP_MOV (144)", mov_op, 144)

    Note: LIR_OP_LOAD_IMM = 30031 -> AOTT_OP_CONST_I32 = 128
    Let imm_op be AOTT.lir_opcode_to_aott(30031)
    T.assert_equal(results, "LIR_OP_LOAD_IMM maps to AOTT_OP_CONST_I32 (128)", imm_op, 128)

    Note: Test comparison opcode mappings
    Note: LIR_OP_CMP_EQ = 30040 -> AOTT_OP_EQ = 112
    Let eq_op be AOTT.lir_opcode_to_aott(30040)
    T.assert_equal(results, "LIR_OP_CMP_EQ maps to AOTT_OP_EQ (112)", eq_op, 112)

    Note: LIR_OP_CMP_NE = 30041 -> AOTT_OP_NE = 113
    Let ne_op be AOTT.lir_opcode_to_aott(30041)
    T.assert_equal(results, "LIR_OP_CMP_NE maps to AOTT_OP_NE (113)", ne_op, 113)

    Note: LIR_OP_CMP_LT = 30042 -> AOTT_OP_LT = 114
    Let lt_op be AOTT.lir_opcode_to_aott(30042)
    T.assert_equal(results, "LIR_OP_CMP_LT maps to AOTT_OP_LT (114)", lt_op, 114)

    Note: LIR_OP_CMP_LE = 30043 -> AOTT_OP_LE = 115
    Let le_op be AOTT.lir_opcode_to_aott(30043)
    T.assert_equal(results, "LIR_OP_CMP_LE maps to AOTT_OP_LE (115)", le_op, 115)

    Note: LIR_OP_CMP_GT = 30044 -> AOTT_OP_GT = 116
    Let gt_op be AOTT.lir_opcode_to_aott(30044)
    T.assert_equal(results, "LIR_OP_CMP_GT maps to AOTT_OP_GT (116)", gt_op, 116)

    Note: LIR_OP_CMP_GE = 30045 -> AOTT_OP_GE = 117
    Let ge_op be AOTT.lir_opcode_to_aott(30045)
    T.assert_equal(results, "LIR_OP_CMP_GE maps to AOTT_OP_GE (117)", ge_op, 117)

    Note: Test control flow opcode mappings
    Note: LIR_OP_JUMP = 30050 -> AOTT_OP_BR = 4
    Let br_op be AOTT.lir_opcode_to_aott(30050)
    T.assert_equal(results, "LIR_OP_JUMP maps to AOTT_OP_BR (4)", br_op, 4)

    Note: LIR_OP_CALL = 30060 -> AOTT_OP_CALL = 3
    Let call_op be AOTT.lir_opcode_to_aott(30060)
    T.assert_equal(results, "LIR_OP_CALL maps to AOTT_OP_CALL (3)", call_op, 3)

    Note: LIR_OP_RET = 30070 -> AOTT_OP_RET = 2
    Let ret_op be AOTT.lir_opcode_to_aott(30070)
    T.assert_equal(results, "LIR_OP_RET maps to AOTT_OP_RET (2)", ret_op, 2)

    Note: LIR_OP_SYSCALL = 30080 -> AOTT_OP_SYSCALL = 7
    Let sys_op be AOTT.lir_opcode_to_aott(30080)
    T.assert_equal(results, "LIR_OP_SYSCALL maps to AOTT_OP_SYSCALL (7)", sys_op, 7)

    Note: LIR_OP_NOP = 30090 -> AOTT_OP_NOP = 0
    Let nop_op be AOTT.lir_opcode_to_aott(30090)
    T.assert_equal(results, "LIR_OP_NOP maps to AOTT_OP_NOP (0)", nop_op, 0)

    Note: Test unknown opcode returns -1
    Let unknown1 be AOTT.lir_opcode_to_aott(0)
    T.assert_equal(results, "unknown opcode 0 returns -1", unknown1, -1)

    Let unknown2 be AOTT.lir_opcode_to_aott(99999)
    T.assert_equal(results, "unknown opcode 99999 returns -1", unknown2, -1)

    Let unknown3 be AOTT.lir_opcode_to_aott(-1)
    T.assert_equal(results, "unknown opcode -1 returns -1", unknown3, -1)

    Let unknown4 be AOTT.lir_opcode_to_aott(30099)
    T.assert_equal(results, "unknown opcode 30099 returns -1", unknown4, -1)

    Return 1
End Process

Note: ============================================================================
Note: Test 11: encode_complete_module produces output starting with AOTT magic
Note: ============================================================================

Process called "test_encode_complete_module" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_encode_complete_module")

    Let output be create_test_output()
    T.assert_not_null(results, "output buffer allocated", output)

    Let module be AOTT.create_bytecode_module(output)
    T.assert_not_null(results, "module created for complete encoding test", module)

    Note: Add one integer constant
    AOTT.add_integer_constant(module, 42)

    Note: Add one function entry
    AOTT.add_function_entry(module, 0, 0, 2, 1, 0, 1)

    Note: Add two bytecode instructions: NOP + HALT
    AOTT.encode_bytecode_instruction(module, 0)
    AOTT.encode_bytecode_instruction(module, 1)

    Note: Set entry point and flags
    AOTT.set_entry_point(module, 0)
    AOTT.set_module_flags(module, 3)

    Note: Encode the complete module to the output buffer
    Let ret be AOTT.encode_complete_module(module)
    T.assert_equal(results, "encode_complete_module returns 1", ret, 1)

    Note: Read the output buffer's code_buf and verify the AOTT magic bytes
    Note: BinaryOutput: code_buf at offset 0, code_size at offset 8
    Let code_buf be __load(output, 0)
    T.assert_not_null(results, "code buffer is non-null", code_buf)

    Let code_size be __load(output, 8)
    T.assert_greater_than(results, "encoded output size is greater than 32", code_size, 32)

    Note: Verify magic bytes: 'A' (65), 'O' (79), 'T' (84), 'T' (84)
    Let magic0 be __load8(code_buf, 0)
    T.assert_equal(results, "magic byte 0 is 'A' (65)", magic0, 65)

    Let magic1 be __load8(code_buf, 1)
    T.assert_equal(results, "magic byte 1 is 'O' (79)", magic1, 79)

    Let magic2 be __load8(code_buf, 2)
    T.assert_equal(results, "magic byte 2 is 'T' (84)", magic2, 84)

    Let magic3 be __load8(code_buf, 3)
    T.assert_equal(results, "magic byte 3 is 'T' (84)", magic3, 84)

    Note: Verify version field (bytes 4-7): AOTT_VERSION = 10000 in LE
    Note: 10000 = 0x00002710 -> LE bytes: 10, 27, 00, 00
    Let ver0 be __load8(code_buf, 4)
    T.assert_equal(results, "version byte 0 is 0x10 (16)", ver0, 16)
    Let ver1 be __load8(code_buf, 5)
    T.assert_equal(results, "version byte 1 is 0x27 (39)", ver1, 39)
    Let ver2 be __load8(code_buf, 6)
    T.assert_equal(results, "version byte 2 is 0x00 (0)", ver2, 0)
    Let ver3 be __load8(code_buf, 7)
    T.assert_equal(results, "version byte 3 is 0x00 (0)", ver3, 0)

    Note: Verify constant pool offset field (bytes 8-11): should be HEADER_SIZE = 32
    Note: 32 = 0x00000020 -> LE bytes: 20, 00, 00, 00
    Let cpoff0 be __load8(code_buf, 8)
    T.assert_equal(results, "const pool offset byte 0 is 32", cpoff0, 32)
    Let cpoff1 be __load8(code_buf, 9)
    T.assert_equal(results, "const pool offset byte 1 is 0", cpoff1, 0)

    Note: Verify entry point field (bytes 20-23): should be 0
    Note: 0 = 0x00000000 -> LE bytes: 00, 00, 00, 00
    Let ep0 be __load8(code_buf, 20)
    T.assert_equal(results, "entry point byte 0 is 0", ep0, 0)

    Note: Verify flags field (bytes 24-27): should be 3 (DEBUG | OPTIMIZE)
    Note: 3 = 0x00000003 -> LE bytes: 03, 00, 00, 00
    Let fl0 be __load8(code_buf, 24)
    T.assert_equal(results, "flags byte 0 is 3", fl0, 3)
    Let fl1 be __load8(code_buf, 25)
    T.assert_equal(results, "flags byte 1 is 0", fl1, 0)

    Return 1
End Process

Note: ============================================================================
Note: Test 12: emit_u32_le and emit_u16_le produce correct byte sequences
Note: ============================================================================

Process called "test_emit_helpers" that takes results as Integer returns Integer:
    T.begin_suite(results, "test_emit_helpers")

    Note: Create a fresh BinaryOutput to emit bytes into
    Let output be create_test_output()
    T.assert_not_null(results, "output buffer allocated for emit helpers test", output)

    Note: Test emit_u32_le with value 0 (all zero bytes)
    AOTT.emit_u32_le(output, 0)
    Let code_buf be __load(output, 0)
    Let size_after_0 be __load(output, 8)
    T.assert_equal(results, "emit_u32_le(0) wrote 4 bytes", size_after_0, 4)
    Let z0 be __load8(code_buf, 0)
    T.assert_equal(results, "u32_le(0) byte 0 is 0", z0, 0)
    Let z1 be __load8(code_buf, 1)
    T.assert_equal(results, "u32_le(0) byte 1 is 0", z1, 0)
    Let z2 be __load8(code_buf, 2)
    T.assert_equal(results, "u32_le(0) byte 2 is 0", z2, 0)
    Let z3 be __load8(code_buf, 3)
    T.assert_equal(results, "u32_le(0) byte 3 is 0", z3, 0)

    Note: Test emit_u32_le with value 255 (0x000000FF -> LE: FF 00 00 00)
    AOTT.emit_u32_le(output, 255)
    Let size_after_255 be __load(output, 8)
    T.assert_equal(results, "emit_u32_le(255) wrote 4 more bytes (total 8)", size_after_255, 8)
    Let b4 be __load8(code_buf, 4)
    T.assert_equal(results, "u32_le(255) byte 0 is 255", b4, 255)
    Let b5 be __load8(code_buf, 5)
    T.assert_equal(results, "u32_le(255) byte 1 is 0", b5, 0)

    Note: Test emit_u32_le with value 256 (0x00000100 -> LE: 00 01 00 00)
    AOTT.emit_u32_le(output, 256)
    Let b8 be __load8(code_buf, 8)
    T.assert_equal(results, "u32_le(256) byte 0 is 0", b8, 0)
    Let b9 be __load8(code_buf, 9)
    T.assert_equal(results, "u32_le(256) byte 1 is 1", b9, 1)

    Note: Test emit_u32_le with value 305419896 (0x12345678)
    Note: LE: 78 56 34 12 = 120 86 52 18
    AOTT.emit_u32_le(output, 305419896)
    Let b12 be __load8(code_buf, 12)
    T.assert_equal(results, "u32_le(0x12345678) byte 0 is 0x78 (120)", b12, 120)
    Let b13 be __load8(code_buf, 13)
    T.assert_equal(results, "u32_le(0x12345678) byte 1 is 0x56 (86)", b13, 86)
    Let b14 be __load8(code_buf, 14)
    T.assert_equal(results, "u32_le(0x12345678) byte 2 is 0x34 (52)", b14, 52)
    Let b15 be __load8(code_buf, 15)
    T.assert_equal(results, "u32_le(0x12345678) byte 3 is 0x12 (18)", b15, 18)

    Note: Test emit_u16_le with a fresh output buffer
    Let output2 be create_test_output()
    T.assert_not_null(results, "second output buffer allocated", output2)

    Note: emit_u16_le with value 0
    AOTT.emit_u16_le(output2, 0)
    Let code_buf2 be __load(output2, 0)
    Let s1 be __load(output2, 8)
    T.assert_equal(results, "emit_u16_le(0) wrote 2 bytes", s1, 2)
    Let u16_z0 be __load8(code_buf2, 0)
    T.assert_equal(results, "u16_le(0) byte 0 is 0", u16_z0, 0)
    Let u16_z1 be __load8(code_buf2, 1)
    T.assert_equal(results, "u16_le(0) byte 1 is 0", u16_z1, 0)

    Note: emit_u16_le with value 513 (0x0201 -> LE: 01 02)
    AOTT.emit_u16_le(output2, 513)
    Let s2 be __load(output2, 8)
    T.assert_equal(results, "emit_u16_le(513) wrote 2 more bytes (total 4)", s2, 4)
    Let u16_b2 be __load8(code_buf2, 2)
    T.assert_equal(results, "u16_le(513) byte 0 is 1", u16_b2, 1)
    Let u16_b3 be __load8(code_buf2, 3)
    T.assert_equal(results, "u16_le(513) byte 1 is 2", u16_b3, 2)

    Note: emit_u16_le with value 65535 (0xFFFF -> LE: FF FF)
    AOTT.emit_u16_le(output2, 65535)
    Let u16_max0 be __load8(code_buf2, 4)
    T.assert_equal(results, "u16_le(65535) byte 0 is 255", u16_max0, 255)
    Let u16_max1 be __load8(code_buf2, 5)
    T.assert_equal(results, "u16_le(65535) byte 1 is 255", u16_max1, 255)

    Return 1
End Process

Note: ============================================================================
Note: Test Runner: Calls all test processes and reports aggregate results
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "FATAL: Could not allocate test results"
        Return 1
    End If

    Display ""
    Display "================================================================"
    Display "  AOTT Bytecode Generator - Unit Test Suite"
    Display "================================================================"

    test_create_module(results)
    test_set_entry_and_flags(results)
    test_add_integer_constant(results)
    test_add_float_constant(results)
    test_add_string_constant(results)
    test_add_function_entry(results)
    test_encode_single_byte(results)
    test_encode_with_u32(results)
    test_encode_with_u16(results)
    test_lir_opcode_mapping(results)
    test_encode_complete_module(results)
    test_emit_helpers(results)

    T.print_summary(results)

    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process
