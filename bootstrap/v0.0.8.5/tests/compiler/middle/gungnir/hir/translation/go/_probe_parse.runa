Import "compiler/middle/gungnir/hir/translation/frontends/go/go_lexer.runa" as GoLexer
Import "compiler/middle/gungnir/hir/translation/frontends/go/go_parser.runa" as GoParser
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Process called "main" returns Integer:
    Let source be "package main\nfunc f() int {\n}\n"
    Let length be proc string_length from StringCore with source
    Let lexer be proc create_go_lexer from GoLexer with source, length
    Let parser be proc create_go_parser from GoParser with lexer
    Let ast be proc parse_program from GoParser with parser
    If ast is equal to 0:
        Return 2
    End If
    Return 0
End Process
