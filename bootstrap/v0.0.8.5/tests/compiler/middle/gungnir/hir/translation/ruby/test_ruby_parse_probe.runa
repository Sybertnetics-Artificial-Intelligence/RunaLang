Note:
Phase-1 pipeline probe for the Ruby translation frontend
(compiler/middle/gungnir/hir/translation/frontends/ruby/).

Proves the lexer and parser produce a REAL AST (not a skeleton):
  - Lexer: keywords, identifiers, instance vars, integers, strings, symbols,
    operators, the def/if/each-do shapes.
  - Parser: method declaration (name + param count + return), if/elsif/else
    control-flow node kinds, a .each do |x| ... end block, a multiple
    assignment, a method call target, an array literal element count, and a
    hash literal pair count.
Returns the failed-assertion count as the process exit code (0 = all pass).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/middle/gungnir/hir/translation/frontends/ruby/ruby_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/ruby/ruby_parser.runa" as Parser
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: PIPELINE HELPERS
Note: ============================================================================

Process called "parse_source" that takes source as String returns Integer:
    Let lexer be Lexer.create_ruby_lexer(source)
    Let parser be Parser.create_ruby_parser(lexer)
    Return Parser.parse_ruby(parser)
End Process

Note: An AST_PROGRAM child statement is wrapped in AST_EXPR_STMT for expression
Note: statements; this unwraps to the underlying expression when present.
Process called "stmt_expr" that takes stmt as Integer returns Integer:
    Let k be Parser.ast_node_type(stmt)
    Let expr_stmt_kind be AST_EXPR_STMT from Parser
    If k is equal to expr_stmt_kind:
        Return Parser.ast_node_child(stmt, 0)
    End If
    Return stmt
End Process

Note: ============================================================================
Note: LEXER SUITE
Note: ============================================================================

Process called "test_lexer_basics" that takes results as Integer returns Integer:
    T.begin_suite(results, "ruby_lexer basics: def greet(name) ... end")

    Let lx be Lexer.create_ruby_lexer("def greet(name)")
    T.assert_not_equal(results, "L1 lexer created", lx, 0)

    Let tok1 be Lexer.next_token(lx, 0)
    Let t1 be Layout.memory_get_int64(tok1, 0)
    Let e1 be TOKEN_DEF from Lexer
    T.assert_equal(results, "L1 def keyword", t1, e1)

    Let tok2 be Lexer.next_token(lx, t1)
    Let t2 be Layout.memory_get_int64(tok2, 0)
    Let e2 be TOKEN_IDENTIFIER from Lexer
    T.assert_equal(results, "L1 method name identifier", t2, e2)
    Let lex2 be Layout.memory_get_int64(tok2, 8)
    Let eq2 be StringCore.string_equals(lex2, "greet")
    T.assert_equal(results, "L1 method name greet", eq2, 1)

    Let tok3 be Lexer.next_token(lx, t2)
    Let t3 be Layout.memory_get_int64(tok3, 0)
    Let e3 be TOKEN_LPAREN from Lexer
    T.assert_equal(results, "L1 left paren", t3, e3)

    Let tok4 be Lexer.next_token(lx, t3)
    Let t4 be Layout.memory_get_int64(tok4, 0)
    T.assert_equal(results, "L1 param identifier", t4, e2)

    Let tok5 be Lexer.next_token(lx, t4)
    Let t5 be Layout.memory_get_int64(tok5, 0)
    Let e5 be TOKEN_RPAREN from Lexer
    T.assert_equal(results, "L1 right paren", t5, e5)

    Return 1
End Process

Process called "test_lexer_literals_and_ops" that takes results as Integer returns Integer:
    T.begin_suite(results, "ruby_lexer literals, ivar, symbol, operators")

    Note: Source chosen so each token is in a context-correct position:
    Note: ":name" leads (no preceding value), then the operator family, then a
    Note: trailing instance var. This exercises the lexer's regex/symbol
    Note: value-context disambiguation as well as the operators.
    Let lx be Lexer.create_ruby_lexer(":name <=> x ||= y &. @count")

    Let tok1 be Lexer.next_token(lx, 0)
    Let t1 be Layout.memory_get_int64(tok1, 0)
    Let e1 be TOKEN_SYMBOL from Lexer
    T.assert_equal(results, "L2 symbol literal", t1, e1)
    Let lex1 be Layout.memory_get_int64(tok1, 8)
    Let eq1 be StringCore.string_equals(lex1, ":name")
    T.assert_equal(results, "L2 symbol spelling", eq1, 1)

    Let tok2 be Lexer.next_token(lx, t1)
    Let t2 be Layout.memory_get_int64(tok2, 0)
    Let e2 be TOKEN_SPACESHIP from Lexer
    T.assert_equal(results, "L2 spaceship operator", t2, e2)

    Let tok3 be Lexer.next_token(lx, t2)
    Let t3 be Layout.memory_get_int64(tok3, 0)
    Let e3 be TOKEN_IDENTIFIER from Lexer
    T.assert_equal(results, "L2 identifier x", t3, e3)

    Let tok4 be Lexer.next_token(lx, t3)
    Let t4 be Layout.memory_get_int64(tok4, 0)
    Let e4 be TOKEN_OR_ASSIGN from Lexer
    T.assert_equal(results, "L2 or-assign operator", t4, e4)

    Let tok5 be Lexer.next_token(lx, t4)
    Let t5 be Layout.memory_get_int64(tok5, 0)
    Let e5 be TOKEN_IDENTIFIER from Lexer
    T.assert_equal(results, "L2 identifier y", t5, e5)

    Let tok6 be Lexer.next_token(lx, t5)
    Let t6 be Layout.memory_get_int64(tok6, 0)
    Let e6 be TOKEN_SAFE_NAV from Lexer
    T.assert_equal(results, "L2 safe navigation operator", t6, e6)

    Let tok7 be Lexer.next_token(lx, t6)
    Let t7 be Layout.memory_get_int64(tok7, 0)
    Let e7 be TOKEN_INSTANCE_VAR from Lexer
    T.assert_equal(results, "L2 instance var", t7, e7)
    Let lex7 be Layout.memory_get_int64(tok7, 8)
    Let eq7 be StringCore.string_equals(lex7, "@count")
    T.assert_equal(results, "L2 instance var spelling", eq7, 1)

    Return 1
End Process

Note: ============================================================================
Note: PARSER SUITES
Note: ============================================================================

Process called "test_parser_method" that takes results as Integer returns Integer:
    T.begin_suite(results, "ruby_parser method declaration")

    Let program be parse_source("def add(a, b)\n  return a + b\nend")
    T.assert_not_equal(results, "P1 program parsed", program, 0)

    Let pk be Parser.ast_node_type(program)
    Let pe be AST_PROGRAM from Parser
    T.assert_equal(results, "P1 program node kind", pk, pe)

    Let method be Parser.ast_node_child(program, 0)
    Let mk be Parser.ast_node_type(method)
    Let me_kind be AST_METHOD from Parser
    T.assert_equal(results, "P1 top decl is method", mk, me_kind)

    Let mv be Parser.ast_node_value(method)
    Let mve be StringCore.string_equals(mv, "add")
    T.assert_equal(results, "P1 method name add", mve, 1)

    Let params be Parser.ast_node_child(method, 0)
    Let pk2 be Parser.ast_node_type(params)
    Let pe2 be AST_PARAM_LIST from Parser
    T.assert_equal(results, "P1 first child is param list", pk2, pe2)

    Let pcount be Parser.ast_node_child_count(params)
    T.assert_equal(results, "P1 two parameters", pcount, 2)

    Let p0 be Parser.ast_node_child(params, 0)
    Let p0v be Parser.ast_node_value(p0)
    Let p0e be StringCore.string_equals(p0v, "a")
    T.assert_equal(results, "P1 first param name a", p0e, 1)

    Note: body holds the return statement after the param-list child
    Let body_stmt be Parser.ast_node_child(method, 1)
    Let bk be Parser.ast_node_type(body_stmt)
    Let ret_kind be AST_RETURN from Parser
    T.assert_equal(results, "P1 body has return stmt", bk, ret_kind)

    Let ret_val be Parser.ast_node_child(body_stmt, 0)
    Let rvk be Parser.ast_node_type(ret_val)
    Let bin_kind be AST_BINARY_OP from Parser
    T.assert_equal(results, "P1 return value is binary op", rvk, bin_kind)

    Let op be Parser.ast_node_value(ret_val)
    Let ope be StringCore.string_equals(op, "+")
    T.assert_equal(results, "P1 return op is plus", ope, 1)

    Return 1
End Process

Process called "test_parser_if_chain" that takes results as Integer returns Integer:
    T.begin_suite(results, "ruby_parser if/elsif/else")

    Let program be parse_source("if x\n  a\nelsif y\n  b\nelse\n  c\nend")

    Let if_stmt be Parser.ast_node_child(program, 0)
    Let ik be Parser.ast_node_type(if_stmt)
    Let ie be AST_IF from Parser
    T.assert_equal(results, "P2 top decl is if", ik, ie)

    Let cond be Parser.ast_node_child(if_stmt, 0)
    Let ck be Parser.ast_node_type(cond)
    Let id_kind be AST_IDENTIFIER from Parser
    T.assert_equal(results, "P2 condition is identifier", ck, id_kind)

    Let then_block be Parser.ast_node_child(if_stmt, 1)
    Let tk be Parser.ast_node_type(then_block)
    Let then_kind be AST_THEN_BLOCK from Parser
    T.assert_equal(results, "P2 then block kind", tk, then_kind)

    Let elsif_node be Parser.ast_node_child(if_stmt, 2)
    Let ek be Parser.ast_node_type(elsif_node)
    Let elsif_kind be AST_ELSIF from Parser
    T.assert_equal(results, "P2 elsif node kind", ek, elsif_kind)

    Note: the elsif carries its own else block as a tail child
    Let elsif_else be Parser.ast_node_child(elsif_node, 2)
    Let eek be Parser.ast_node_type(elsif_else)
    Let else_kind be AST_ELSE_BLOCK from Parser
    T.assert_equal(results, "P2 else block under elsif", eek, else_kind)

    Return 1
End Process

Process called "test_parser_each_block" that takes results as Integer returns Integer:
    T.begin_suite(results, "ruby_parser .each do |x| ... end block")

    Let program be parse_source("items.each do |x|\n  puts x\nend")

    Let stmt be Parser.ast_node_child(program, 0)
    Let call be stmt_expr(stmt)
    Let ck be Parser.ast_node_type(call)
    Let call_kind be AST_METHOD_CALL from Parser
    T.assert_equal(results, "P3 each is a method call", ck, call_kind)

    Let cv be Parser.ast_node_value(call)
    Let cve be StringCore.string_equals(cv, "each")
    T.assert_equal(results, "P3 call target each", cve, 1)

    Let receiver be Parser.ast_node_child(call, 0)
    Let rv be Parser.ast_node_value(receiver)
    Let rve be StringCore.string_equals(rv, "items")
    T.assert_equal(results, "P3 receiver items", rve, 1)

    Note: child[0]=receiver, child[1]=arg list, child[2]=block
    Let block be Parser.ast_node_child(call, 2)
    Let bk be Parser.ast_node_type(block)
    Let block_kind be AST_BLOCK from Parser
    T.assert_equal(results, "P3 trailing block present", bk, block_kind)

    Let blk_params be Parser.ast_node_child(block, 0)
    Let bpcount be Parser.ast_node_child_count(blk_params)
    T.assert_equal(results, "P3 block has one param", bpcount, 1)

    Let bp0 be Parser.ast_node_child(blk_params, 0)
    Let bp0v be Parser.ast_node_value(bp0)
    Let bp0e be StringCore.string_equals(bp0v, "x")
    T.assert_equal(results, "P3 block param name x", bp0e, 1)

    Return 1
End Process

Process called "test_parser_multiple_assignment" that takes results as Integer returns Integer:
    T.begin_suite(results, "ruby_parser multiple assignment")

    Let program be parse_source("a, b = 1, 2")

    Let stmt be Parser.ast_node_child(program, 0)
    Let inner be stmt_expr(stmt)
    Let ik be Parser.ast_node_type(inner)
    Let masgn_kind be AST_MULTIPLE_ASSIGN from Parser
    T.assert_equal(results, "P4 multiple assignment node", ik, masgn_kind)

    Let targets be Parser.ast_node_child(inner, 0)
    Let tk be Parser.ast_node_type(targets)
    Let tlist_kind be AST_TARGET_LIST from Parser
    T.assert_equal(results, "P4 target list kind", tk, tlist_kind)
    Let tcount be Parser.ast_node_child_count(targets)
    T.assert_equal(results, "P4 two targets", tcount, 2)

    Let values be Parser.ast_node_child(inner, 1)
    Let vk be Parser.ast_node_type(values)
    Let vlist_kind be AST_VALUE_LIST from Parser
    T.assert_equal(results, "P4 value list kind", vk, vlist_kind)
    Let vcount be Parser.ast_node_child_count(values)
    T.assert_equal(results, "P4 two values", vcount, 2)

    Return 1
End Process

Process called "test_parser_method_call" that takes results as Integer returns Integer:
    T.begin_suite(results, "ruby_parser method call with args")

    Let program be parse_source("foo(1, 2, 3)")

    Let stmt be Parser.ast_node_child(program, 0)
    Let call be stmt_expr(stmt)
    Let ck be Parser.ast_node_type(call)
    Let call_kind be AST_METHOD_CALL from Parser
    T.assert_equal(results, "P5 method call node", ck, call_kind)

    Let cv be Parser.ast_node_value(call)
    Let cve be StringCore.string_equals(cv, "foo")
    T.assert_equal(results, "P5 call target foo", cve, 1)

    Let args be Parser.ast_node_child(call, 1)
    Let ak be Parser.ast_node_type(args)
    Let arglist_kind be AST_ARG_LIST from Parser
    T.assert_equal(results, "P5 arg list kind", ak, arglist_kind)
    Let acount be Parser.ast_node_child_count(args)
    T.assert_equal(results, "P5 three arguments", acount, 3)

    Let arg0 be Parser.ast_node_child(args, 0)
    Let arg0k be Parser.ast_node_type(arg0)
    Let arg_kind be AST_ARG from Parser
    T.assert_equal(results, "P5 first arg kind", arg0k, arg_kind)

    Return 1
End Process

Process called "test_parser_array_and_hash" that takes results as Integer returns Integer:
    T.begin_suite(results, "ruby_parser array and hash literals")

    Let prog_arr be parse_source("[10, 20, 30]")
    Let s_arr be Parser.ast_node_child(prog_arr, 0)
    Let arr be stmt_expr(s_arr)
    Let ak be Parser.ast_node_type(arr)
    Let array_kind be AST_ARRAY from Parser
    T.assert_equal(results, "P6 array literal node", ak, array_kind)
    Let acount be Parser.ast_node_child_count(arr)
    T.assert_equal(results, "P6 three array elements", acount, 3)

    Let el0 be Parser.ast_node_child(arr, 0)
    Let el0k be Parser.ast_node_type(el0)
    Let int_kind be AST_INTEGER from Parser
    T.assert_equal(results, "P6 first element integer", el0k, int_kind)

    Let prog_hash be parse_source("{ :a => 1, :b => 2 }")
    Let s_hash be Parser.ast_node_child(prog_hash, 0)
    Let hash be stmt_expr(s_hash)
    Let hk be Parser.ast_node_type(hash)
    Let hash_kind be AST_HASH from Parser
    T.assert_equal(results, "P6 hash literal node", hk, hash_kind)
    Let hcount be Parser.ast_node_child_count(hash)
    T.assert_equal(results, "P6 two hash pairs", hcount, 2)

    Let pair0 be Parser.ast_node_child(hash, 0)
    Let pair0k be Parser.ast_node_type(pair0)
    Let pair_kind be AST_HASH_PAIR from Parser
    T.assert_equal(results, "P6 first entry is hash pair", pair0k, pair_kind)

    Let key0 be Parser.ast_node_child(pair0, 0)
    Let key0k be Parser.ast_node_type(key0)
    Let sym_kind be AST_SYMBOL from Parser
    T.assert_equal(results, "P6 first key is symbol", key0k, sym_kind)

    Return 1
End Process

Note: ============================================================================
Note: MAIN
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_lexer_basics(results)
    test_lexer_literals_and_ops(results)

    test_parser_method(results)
    test_parser_if_chain(results)
    test_parser_each_block(results)
    test_parser_multiple_assignment(results)
    test_parser_method_call(results)
    test_parser_array_and_hash(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
