Note:
Unit tests for compiler/middle/gungnir/hir/translation/backends/emitter_common.runa.
Tests focus on observable output strings + error counts rather than internal
state so they survive the bootstrap stage's selective import handling.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/middle/gungnir/hir/translation/backends/emitter_common.runa" as Emit
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: OUTPUT BEHAVIOR
Note: ============================================================================

Process called "test_empty_output" that takes results as Integer returns Integer:
    T.begin_suite(results, "emitter_common.empty context produces empty output")
    Let ctx be Emit.create_emitter_context()
    Let out be Emit.emitter_get_output(ctx)
    Let eq be StringCore.string_equals(out, "")
    T.assert_equal(results, "empty output", eq, 1)
    T.assert_equal(results, "no errors", Emit.emitter_has_errors(ctx), 0)
    Return 1
End Process

Process called "test_basic_emit" that takes results as Integer returns Integer:
    T.begin_suite(results, "emitter_common.emit concatenates")
    Let ctx be Emit.create_emitter_context()
    Emit.emitter_emit(ctx, "hello")
    Emit.emitter_emit(ctx, " ")
    Emit.emitter_emit(ctx, "world")
    Let out be Emit.emitter_get_output(ctx)
    Let eq be StringCore.string_equals(out, "hello world")
    T.assert_equal(results, "produces 'hello world'", eq, 1)
    Return 1
End Process

Process called "test_emit_line_format" that takes results as Integer returns Integer:
    T.begin_suite(results, "emitter_common.emit_line appends newline")
    Let ctx be Emit.create_emitter_context()
    Emit.emitter_emit_line(ctx, "first")
    Emit.emitter_emit_line(ctx, "second")
    Let out be Emit.emitter_get_output(ctx)
    Let eq be StringCore.string_equals(out, "first\nsecond\n")
    T.assert_equal(results, "two newline-terminated lines", eq, 1)
    Return 1
End Process

Process called "test_indent_spaces" that takes results as Integer returns Integer:
    T.begin_suite(results, "emitter_common.4-space indentation by default")
    Let ctx be Emit.create_emitter_context()
    Emit.emitter_indent(ctx)
    Emit.emitter_emit(ctx, "x")
    Let out be Emit.emitter_get_output(ctx)
    Let eq be StringCore.string_equals(out, "    x")
    T.assert_equal(results, "4 spaces precede text", eq, 1)
    Return 1
End Process

Process called "test_nested_indent" that takes results as Integer returns Integer:
    T.begin_suite(results, "emitter_common.nested indentation compounds")
    Let ctx be Emit.create_emitter_context()
    Emit.emitter_indent(ctx)
    Emit.emitter_indent(ctx)
    Emit.emitter_emit(ctx, "y")
    Let out be Emit.emitter_get_output(ctx)
    Let eq be StringCore.string_equals(out, "        y")
    T.assert_equal(results, "8 spaces (level 2 x 4)", eq, 1)
    Return 1
End Process

Process called "test_dedent_pairs" that takes results as Integer returns Integer:
    T.begin_suite(results, "emitter_common.dedent restores indent")
    Let ctx be Emit.create_emitter_context()
    Emit.emitter_indent(ctx)
    Emit.emitter_emit_line(ctx, "inside")
    Emit.emitter_dedent(ctx)
    Emit.emitter_emit(ctx, "outside")
    Let out be Emit.emitter_get_output(ctx)
    Let eq be StringCore.string_equals(out, "    inside\noutside")
    T.assert_equal(results, "indent + dedent restores level", eq, 1)
    Return 1
End Process

Process called "test_error_recorded" that takes results as Integer returns Integer:
    T.begin_suite(results, "emitter_common.error sets has_errors")
    Let ctx be Emit.create_emitter_context()
    T.assert_equal(results, "starts clean", Emit.emitter_has_errors(ctx), 0)
    Emit.emitter_error(ctx, "fail")
    T.assert_equal(results, "errors recorded", Emit.emitter_has_errors(ctx), 1)
    Return 1
End Process

Process called "test_warning_not_error" that takes results as Integer returns Integer:
    T.begin_suite(results, "emitter_common.warning does not set has_errors")
    Let ctx be Emit.create_emitter_context()
    Emit.emitter_warning(ctx, "watch out")
    T.assert_equal(results, "warning is not error", Emit.emitter_has_errors(ctx), 0)
    Return 1
End Process

Process called "test_reset_clears" that takes results as Integer returns Integer:
    T.begin_suite(results, "emitter_common.reset clears output and errors")
    Let ctx be Emit.create_emitter_context()
    Emit.emitter_emit(ctx, "polluted")
    Emit.emitter_error(ctx, "bad")
    Emit.emitter_reset(ctx)

    Let out be Emit.emitter_get_output(ctx)
    Let empty be StringCore.string_equals(out, "")
    T.assert_equal(results, "output empty", empty, 1)
    T.assert_equal(results, "errors cleared", Emit.emitter_has_errors(ctx), 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_empty_output(results)
    test_basic_emit(results)
    test_emit_line_format(results)
    test_indent_spaces(results)
    test_nested_indent(results)
    test_dedent_pairs(results)
    test_error_recorded(results)
    test_warning_not_error(results)
    test_reset_clears(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
