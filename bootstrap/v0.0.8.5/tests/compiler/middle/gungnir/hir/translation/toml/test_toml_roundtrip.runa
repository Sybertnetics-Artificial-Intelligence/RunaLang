Note:
TOML Translation Round-Trip Probe

End-to-end proof that the TOML translation pipeline is REAL, not a skeleton:

    TOML source
      -> toml_lexer    (tokenize)
      -> toml_parser   (build nested TOML AST: tables, arrays-of-tables, scalars)
      -> toml_semantic (validate: duplicate keys, depth, structure)
      -> toml_to_hir   (lower TOML AST to the canonical HIR literal model)
      -> hir_to_toml   (emit HIR back to well-formed TOML text)

The probe feeds a representative TOML document containing a [table], an
[[array-of-tables]], string / integer / float / boolean / datetime scalars,
an inline table, and an array. It then:

  1. Parses + semantically validates the source, and asserts the semantic pass
     rejects a document with a duplicate key.
  2. Translates the source to HIR and asserts the HIR root is a dictionary
     literal with the expected structure, walking into the nested table, the
     array-of-tables, and the inline table to prove nesting was preserved.
  3. Emits the HIR back to TOML text and asserts the text is non-empty.
  4. Re-parses the emitted TOML back into HIR and asserts the two HIR trees are
     STRUCTURALLY EQUAL via a recursive comparator. Structural equality (rather
     than byte equality) is the correct semantic-equivalence check because the
     emitter reorders entries (scalars before sections) and the byte form
     differs from the input while the meaning is identical.

Exit code: number of failed assertions (0 == all passed). No exit_with_code.
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/toml/toml_to_hir.runa" as TomlFrontend
Import "compiler/middle/gungnir/hir/translation/frontends/toml/toml_parser.runa" as TomlParser
Import "compiler/middle/gungnir/hir/translation/frontends/toml/toml_semantic.runa" as TomlSemantic
Import "compiler/middle/gungnir/hir/translation/backends/toml/hir_to_toml.runa" as TomlBackend
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "tests/test_utils.runa" as TestUtils

Note: ============================================================================
Note: Structural HIR equality (semantic equivalence of two TOML-derived trees)
Note: ============================================================================

@Reasoning:
Two TOML documents are semantically equal when their HIR projections are
structurally equal: same node kind at every position, same scalar payloads,
same key/value pairing for dictionaries, and same element ordering for arrays.
Comparing the HIR trees rather than the raw text is whitespace- and
ordering-insensitive at the leaf level, proving round-trip fidelity without
being fooled by the emitter's scalars-before-sections layout. Dictionary entry
order is preserved by both the parser and the emitter's two-phase walk, so the
comparator can pair entries by index.
@End Reasoning

Process called "hir_equal" takes a as Integer, b as Integer returns Integer:
    If a is equal to 0:
        If b is equal to 0:
            Return 1
        End If
        Return 0
    End If

    If b is equal to 0:
        Return 0
    End If

    Let kind_a be proc get_hir_node_type from HIR with a
    Let kind_b be proc get_hir_node_type from HIR with b

    If kind_a is not equal to kind_b:
        Return 0
    End If

    If kind_a is equal to HIR_DICTIONARY_LITERAL from HIR:
        Let entries_a be proc get_dictionary_entries from HIR with a
        Let entries_b be proc get_dictionary_entries from HIR with b

        If entries_a is equal to 0:
            If entries_b is equal to 0:
                Return 1
            End If
            Return 0
        End If

        If entries_b is equal to 0:
            Return 0
        End If

        Let count_a be proc size from List with entries_a
        Let count_b be proc size from List with entries_b

        If count_a is not equal to count_b:
            Return 0
        End If

        Let i be 0
        While i is less than count_a:
            Let entry_a be proc get_at from List with entries_a, i
            Let entry_b be proc get_at from List with entries_b, i

            Let key_a be proc memory_get_int64 from Layout with entry_a, 0
            Let key_b be proc memory_get_int64 from Layout with entry_b, 0
            Let keys_match be proc string_equals from StringCore with key_a, key_b

            If keys_match is not equal to 1:
                Return 0
            End If

            Let val_a be proc memory_get_int64 from Layout with entry_a, 8
            Let val_b be proc memory_get_int64 from Layout with entry_b, 8
            Let vals_match be proc hir_equal with val_a, val_b

            If vals_match is not equal to 1:
                Return 0
            End If

            Set i to i plus 1
        End While

        Return 1
    End If

    If kind_a is equal to HIR_ARRAY_LITERAL from HIR:
        Let elems_a be proc get_list_elements from HIR with a
        Let elems_b be proc get_list_elements from HIR with b

        If elems_a is equal to 0:
            If elems_b is equal to 0:
                Return 1
            End If
            Return 0
        End If

        If elems_b is equal to 0:
            Return 0
        End If

        Let ecount_a be proc size from List with elems_a
        Let ecount_b be proc size from List with elems_b

        If ecount_a is not equal to ecount_b:
            Return 0
        End If

        Let j be 0
        While j is less than ecount_a:
            Let el_a be proc get_at from List with elems_a, j
            Let el_b be proc get_at from List with elems_b, j
            Let el_match be proc hir_equal with el_a, el_b

            If el_match is not equal to 1:
                Return 0
            End If

            Set j to j plus 1
        End While

        Return 1
    End If

    If kind_a is equal to HIR_LITERAL from HIR:
        Let tag_a be proc memory_get_int64 from Layout with a, 48
        Let tag_b be proc memory_get_int64 from Layout with b, 48

        If tag_a is not equal to tag_b:
            Return 0
        End If

        Let payload_a be proc memory_get_int64 from Layout with a, 40
        Let payload_b be proc memory_get_int64 from Layout with b, 40

        Note: String and float payloads are string pointers; compare by content
        If tag_a is equal to HIR_LITERAL_KIND_STRING from HIR:
            Return proc string_equals from StringCore with payload_a, payload_b
        End If

        If tag_a is equal to HIR_LITERAL_KIND_FLOAT from HIR:
            Return proc string_equals from StringCore with payload_a, payload_b
        End If

        Note: Integer/boolean/null payloads are compared by raw value
        If payload_a is equal to payload_b:
            Return 1
        End If
        Return 0
    End If

    Return 0
End Process

Note: ============================================================================
Note: Probe entry point
Note: ============================================================================

Process called "main" returns Integer:
    Let results be proc create_test_results from TestUtils
    proc begin_suite from TestUtils with results, "TOML translation round-trip"

    Note:
    Representative document:
      - root scalars: title (string), version (integer), ratio (float),
        enabled (boolean), created (offset datetime)
      - root array of scalars: ports
      - root inline table: point
      - a [server] table with a nested scalar
      - an [[products]] array-of-tables with two elements
    :End Note
    Let source be "title = \"Demo\"\nversion = 42\nratio = 3.14\nenabled = true\ncreated = 1979-05-27T07:32:00Z\nports = [80, 443]\npoint = { x = 1, y = 2 }\n\n[server]\nhost = \"localhost\"\n\n[[products]]\nname = \"hammer\"\nsku = 738594937\n\n[[products]]\nname = \"nail\"\nsku = 284758393\n"

    Note: --- Stage 0: parse + semantic validation ---
    Let ast be proc parse_toml from TomlParser with source
    proc assert_not_null from TestUtils with results, "parser produced TOML AST", ast

    Let valid be proc validate_toml_ast_default from TomlSemantic with ast
    proc assert_equal from TestUtils with results, "semantic pass accepts valid document", valid, 1

    Note: Semantic pass / parser must REJECT a duplicate key (parser rejects at build time)
    Let dup_source be "a = 1\na = 2\n"
    Let dup_ast be proc parse_toml from TomlParser with dup_source
    proc assert_null from TestUtils with results, "parser rejects duplicate root key", dup_ast

    Note: --- Stage 1: source -> HIR ---
    Let hir1 be proc toml_to_hir_from_source from TomlFrontend with source
    proc assert_not_null from TestUtils with results, "frontend produced HIR root", hir1

    Let root_kind be proc get_hir_node_type from HIR with hir1
    proc assert_equal from TestUtils with results, "HIR root is dictionary literal", root_kind, HIR_DICTIONARY_LITERAL from HIR

    Let entries be proc get_dictionary_entries from HIR with hir1
    proc assert_not_null from TestUtils with results, "dictionary has entries list", entries

    Note: Root keys: title, version, ratio, enabled, created, ports, point, server, products
    Let entry_count be proc size from List with entries
    proc assert_equal from TestUtils with results, "dictionary has 9 top-level keys", entry_count, 9

    Note: title scalar string
    Let title_entry be proc get_at from List with entries, 0
    Let title_key be proc memory_get_int64 from Layout with title_entry, 0
    proc assert_string_equal from TestUtils with results, "1st key is 'title'", title_key, "title"
    Let title_val be proc memory_get_int64 from Layout with title_entry, 8
    Let title_str be proc get_string_literal_value from HIR with title_val
    proc assert_string_equal from TestUtils with results, "title value is 'Demo'", title_str, "Demo"

    Note: version integer
    Let version_entry be proc get_at from List with entries, 1
    Let version_val be proc memory_get_int64 from Layout with version_entry, 8
    Let version_int be proc get_integer_literal_value from HIR with version_val
    proc assert_equal from TestUtils with results, "version integer is 42", version_int, 42

    Note: created datetime preserved as a string literal lexeme
    Let created_entry be proc get_at from List with entries, 4
    Let created_val be proc memory_get_int64 from Layout with created_entry, 8
    Let created_str be proc get_string_literal_value from HIR with created_val
    proc assert_string_equal from TestUtils with results, "created datetime lexeme preserved", created_str, "1979-05-27T07:32:00Z"

    Note: ports array of two integers
    Let ports_entry be proc get_at from List with entries, 5
    Let ports_val be proc memory_get_int64 from Layout with ports_entry, 8
    Let ports_kind be proc get_hir_node_type from HIR with ports_val
    proc assert_equal from TestUtils with results, "ports value is array literal", ports_kind, HIR_ARRAY_LITERAL from HIR
    Let ports_elems be proc get_list_elements from HIR with ports_val
    Let ports_count be proc size from List with ports_elems
    proc assert_equal from TestUtils with results, "ports array has 2 elements", ports_count, 2

    Note: point inline table -> nested dictionary with 2 entries
    Let point_entry be proc get_at from List with entries, 6
    Let point_val be proc memory_get_int64 from Layout with point_entry, 8
    Let point_kind be proc get_hir_node_type from HIR with point_val
    proc assert_equal from TestUtils with results, "point value is dictionary literal", point_kind, HIR_DICTIONARY_LITERAL from HIR
    Let point_entries be proc get_dictionary_entries from HIR with point_val
    Let point_count be proc size from List with point_entries
    proc assert_equal from TestUtils with results, "point inline table has 2 entries", point_count, 2

    Note: [server] table -> nested dictionary; server.host == "localhost"
    Let server_entry be proc get_at from List with entries, 7
    Let server_key be proc memory_get_int64 from Layout with server_entry, 0
    proc assert_string_equal from TestUtils with results, "8th key is 'server'", server_key, "server"
    Let server_val be proc memory_get_int64 from Layout with server_entry, 8
    Let server_kind be proc get_hir_node_type from HIR with server_val
    proc assert_equal from TestUtils with results, "server value is dictionary literal", server_kind, HIR_DICTIONARY_LITERAL from HIR
    Let server_entries be proc get_dictionary_entries from HIR with server_val
    Let host_entry be proc get_at from List with server_entries, 0
    Let host_val be proc memory_get_int64 from Layout with host_entry, 8
    Let host_str be proc get_string_literal_value from HIR with host_val
    proc assert_string_equal from TestUtils with results, "server.host is 'localhost'", host_str, "localhost"

    Note: [[products]] array-of-tables -> array literal of 2 dictionaries
    Let products_entry be proc get_at from List with entries, 8
    Let products_key be proc memory_get_int64 from Layout with products_entry, 0
    proc assert_string_equal from TestUtils with results, "9th key is 'products'", products_key, "products"
    Let products_val be proc memory_get_int64 from Layout with products_entry, 8
    Let products_kind be proc get_hir_node_type from HIR with products_val
    proc assert_equal from TestUtils with results, "products value is array literal", products_kind, HIR_ARRAY_LITERAL from HIR
    Let products_elems be proc get_list_elements from HIR with products_val
    Let products_count be proc size from List with products_elems
    proc assert_equal from TestUtils with results, "products array-of-tables has 2 elements", products_count, 2
    Let product0 be proc get_at from List with products_elems, 0
    Let product0_kind be proc get_hir_node_type from HIR with product0
    proc assert_equal from TestUtils with results, "first product is dictionary literal", product0_kind, HIR_DICTIONARY_LITERAL from HIR

    Note: --- Stage 2: HIR -> TOML text ---
    Let emitted be proc translate_hir_to_toml from TomlBackend with hir1
    proc assert_not_null from TestUtils with results, "backend produced TOML text", emitted
    Let emitted_len be proc string_length from StringCore with emitted
    proc assert_greater_than from TestUtils with results, "emitted TOML is non-empty", emitted_len, 0

    Note: --- Stage 3: re-parse emitted TOML -> HIR, assert structurally equal ---
    Let hir2 be proc toml_to_hir_from_source from TomlFrontend with emitted
    proc assert_not_null from TestUtils with results, "re-parse of emitted TOML produced HIR", hir2

    Let structurally_equal be proc hir_equal with hir1, hir2
    proc assert_equal from TestUtils with results, "round-trip HIR is structurally equal", structurally_equal, 1

    proc print_summary from TestUtils with results
    Let failed be proc get_failed from TestUtils with results
    proc destroy_test_results from TestUtils with results

    Return failed
End Process
