Note:
MATLAB parse-only smoke probe. Builds the lexer + parser on a representative
MATLAB program exercising function defs (single + multiple return), if/elseif/
else, for, while, switch/case/otherwise, try/catch, matrix literals (row + col),
ranges, cell arrays, struct field access, anonymous functions, transpose,
elementwise operators, and comments. Asserts the parser produces a non-empty
AST and TERMINATES (the CPU cap catches any non-advancing loop). Exit code is
the number of failed assertions.
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/matlab/matlab_lexer.runa" as MatlabLexer
Import "compiler/middle/gungnir/hir/translation/frontends/matlab/matlab_parser.runa" as MatlabParser
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "tests/test_utils.runa" as TestUtils

Process called "parse_source" takes source as Integer returns Integer:
    Let lexer be proc matlab_lexer_create from MatlabLexer with source
    If lexer is equal to 0:
        Return 0
    End If
    Let parser be proc matlab_parser_create from MatlabParser with lexer
    If parser is equal to 0:
        Return 0
    End If
    Return proc parse_program from MatlabParser with parser
End Process

Process called "main" returns Integer:
    Let results be proc create_test_results from TestUtils
    proc begin_suite from TestUtils with results, "MATLAB parse smoke"

    Let prog be "function [a, b] = swap(x, y)\n% swap two values\na = y;\nb = x;\nend\n\nfunction y = sq(x)\ny = x .* x;\nend\n\nfunction r = pick(n)\nif n > 10\nr = 1;\nelseif n > 5\nr = 2;\nelse\nr = 3;\nend\nend\n\nfunction s = total(v)\ns = 0;\nfor i = 1:10\ns = s + i;\nend\nwhile s > 100\ns = s - 1;\nend\nend\n\nfunction t = classify(k)\nswitch k\ncase 1\nt = 'one';\ncase 2\nt = 'two';\notherwise\nt = 'many';\nend\nend\n\nfunction z = safe(x)\ntry\nz = 1 / x;\ncatch err\nz = 0;\nend\nM = [1 2; 3 4];\nrng = 1:2:9;\nc = {1, 'two', [3 4]};\nf = @(p) p + 1;\nv = M';\nfld = s.value;\nend\n"

    Let ast be proc parse_source with prog
    proc assert_not_null from TestUtils with results, "parser produced an AST", ast

    Let prog_type be proc ast_node_type from MatlabParser with ast
    proc assert_equal from TestUtils with results, "root is a MATLAB program", prog_type, MatlabParser.MATLAB_PROGRAM

    Let func_count be proc ast_node_child_count from MatlabParser with ast
    proc assert_greater_than_or_equal from TestUtils with results, "program parsed all six functions", func_count, 6

    proc print_summary from TestUtils with results
    Let failed be proc get_failed from TestUtils with results
    proc destroy_test_results from TestUtils with results
    Return failed
End Process
