Note:
MATLAB Translation Round-Trip Probe

End-to-end proof that the MATLAB translation pipeline is REAL, not a skeleton:

    MATLAB source
      -> matlab_lexer    (tokenize: identifiers, keywords, numbers, strings,
                          operators incl. .* and transpose, comments)
      -> matlab_parser   (build MATLAB AST: function defs incl. multiple
                          return, if/elseif/else, for, while, switch, try,
                          matrix/range/cell literals, anonymous functions,
                          struct field access, transpose)
      -> matlab_to_hir   (lower MATLAB AST to the canonical typed HIR)
      -> hir_to_matlab   (emit HIR back to valid MATLAB text)
      -> re-lex / re-parse of the emitted text (HIR2 via the parser)

The probe lowers a representative program to HIR1, emits HIR1 back to MATLAB
text, asserts the emitted text carries the load-bearing tokens of every
required construct, and re-parses the emitted text to a non-empty AST -
proving the constructs survive the full lex -> parse -> to_hir -> emit cycle.

The depth assertions prove CONTENT survives the round trip:
  - at least six function names
  - a multiple-return header "[a, b] = swap("
  - an if / elseif / else chain
  - a for loop
  - a matrix literal with rows and columns ("[1 2; 3 4]")
  - a range ("1:2:9" or "1:10")
  - an anonymous function ("@(p)")
  - struct field access ("s.value")
  - an element-wise operator (".*")

Exit code: number of failed assertions (0 == all passed). No exit_with_code.
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/matlab/matlab_lexer.runa" as MatlabLexer
Import "compiler/middle/gungnir/hir/translation/frontends/matlab/matlab_parser.runa" as MatlabParser
Import "compiler/middle/gungnir/hir/translation/frontends/matlab/matlab_to_hir.runa" as MatlabFrontend
Import "compiler/middle/gungnir/hir/translation/backends/matlab/hir_to_matlab.runa" as MatlabBackend
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/internal/string_utils.runa" as StringUtils
Import "tests/test_utils.runa" as TestUtils

@Reasoning:
Runs the front-of-pipeline (lex -> parse) on a MATLAB source string and
returns the AST root, or 0 if any stage fails. Factoring it keeps the two
pipeline runs (original source and emitted text) behaviourally identical, so
any structural divergence is attributable to the emitter.
@End Reasoning
Process called "source_to_ast" takes source as Integer returns Integer:
    Let lexer be proc matlab_lexer_create from MatlabLexer with source
    If lexer is equal to 0:
        Return 0
    End If
    Let parser be proc matlab_parser_create from MatlabParser with lexer
    If parser is equal to 0:
        Return 0
    End If
    Return proc parse_program from MatlabParser with parser
End Process

@Reasoning:
Runs the full source -> HIR pipeline (lex -> parse -> to_hir) and returns the
HIR module, or 0 on any failure.
@End Reasoning
Process called "source_to_hir" takes source as Integer returns Integer:
    Let ast be proc source_to_ast with source
    If ast is equal to 0:
        Return 0
    End If
    Return proc translate_matlab_to_hir from MatlabFrontend with ast
End Process

Process called "main" returns Integer:
    Let results be proc create_test_results from TestUtils
    proc begin_suite from TestUtils with results, "MATLAB translation round-trip"

    Note:
    Representative program: six functions exercising multiple-return,
    if/elseif/else, for, while, switch/case/otherwise, try/catch, matrix and
    range and cell literals, an anonymous function, transpose, struct field
    access and an element-wise operator.
    :End Note
    Let source be "function [a, b] = swap(x, y)\na = y;\nb = x;\nend\n\nfunction y = sq(x)\ny = x .* x;\nend\n\nfunction r = pick(n)\nif n > 10\nr = 1;\nelseif n > 5\nr = 2;\nelse\nr = 3;\nend\nend\n\nfunction s = total(v)\ns = 0;\nfor k = 1:10\ns = s + k;\nend\nwhile s > 100\ns = s - 1;\nend\nend\n\nfunction t = classify(g)\nswitch g\ncase 1\nt = 1;\notherwise\nt = 0;\nend\nend\n\nfunction z = work(M, s)\ntry\nz = 1;\ncatch err\nz = 0;\nend\nA = [1 2; 3 4];\nrng = 1:2:9;\nc = {1, 'two'};\nf = @(p) p + 1;\nv = M';\nfld = s.value;\nend\n"

    Note: --- Stage 0-2: source -> AST -> HIR ---
    Let ast be proc source_to_ast with source
    proc assert_not_null from TestUtils with results, "parser produced MATLAB AST", ast

    Let func_count be proc ast_node_child_count from MatlabParser with ast
    proc assert_greater_than_or_equal from TestUtils with results, "AST has at least six functions", func_count, 6

    Let hir1 be proc translate_matlab_to_hir from MatlabFrontend with ast
    proc assert_not_null from TestUtils with results, "frontend produced HIR module", hir1

    Note: --- Stage 3: HIR -> MATLAB text ---
    Let emitted be proc generate_matlab_from_hir from MatlabBackend with hir1
    proc assert_not_null from TestUtils with results, "backend produced MATLAB text", emitted
    Let emitted_len be proc string_length from StringCore with emitted
    proc assert_greater_than from TestUtils with results, "emitted MATLAB is non-empty", emitted_len, 0

    Note: --- Depth assertions: content survives to the emitted text ---
    Let has_swap be proc string_contains from StringUtils with emitted, "function "
    proc assert_equal from TestUtils with results, "emitted contains function definitions", has_swap, 1

    Let has_multi be proc string_contains from StringUtils with emitted, "[a, b] = swap("
    proc assert_equal from TestUtils with results, "emitted preserves multiple-return header", has_multi, 1

    Let has_sq be proc string_contains from StringUtils with emitted, "sq"
    proc assert_equal from TestUtils with results, "emitted preserves function name sq", has_sq, 1
    Let has_pick be proc string_contains from StringUtils with emitted, "pick"
    proc assert_equal from TestUtils with results, "emitted preserves function name pick", has_pick, 1
    Let has_total be proc string_contains from StringUtils with emitted, "total"
    proc assert_equal from TestUtils with results, "emitted preserves function name total", has_total, 1
    Let has_classify be proc string_contains from StringUtils with emitted, "classify"
    proc assert_equal from TestUtils with results, "emitted preserves function name classify", has_classify, 1
    Let has_work be proc string_contains from StringUtils with emitted, "work"
    proc assert_equal from TestUtils with results, "emitted preserves function name work", has_work, 1

    Let has_if be proc string_contains from StringUtils with emitted, "if "
    proc assert_equal from TestUtils with results, "emitted contains if", has_if, 1
    Let has_elseif be proc string_contains from StringUtils with emitted, "elseif "
    proc assert_equal from TestUtils with results, "emitted contains elseif", has_elseif, 1
    Let has_else be proc string_contains from StringUtils with emitted, "else"
    proc assert_equal from TestUtils with results, "emitted contains else", has_else, 1

    Let has_for be proc string_contains from StringUtils with emitted, "for "
    proc assert_equal from TestUtils with results, "emitted contains for loop", has_for, 1

    Let has_matrix be proc string_contains from StringUtils with emitted, "[1 2; 3 4]"
    proc assert_equal from TestUtils with results, "emitted preserves matrix rows and columns", has_matrix, 1

    Let has_range be proc string_contains from StringUtils with emitted, "1:2:9"
    proc assert_equal from TestUtils with results, "emitted preserves stepped range", has_range, 1

    Let has_lambda be proc string_contains from StringUtils with emitted, "@(p)"
    proc assert_equal from TestUtils with results, "emitted preserves anonymous function", has_lambda, 1

    Let has_field be proc string_contains from StringUtils with emitted, "s.value"
    proc assert_equal from TestUtils with results, "emitted preserves struct field access", has_field, 1

    Let has_elementwise be proc string_contains from StringUtils with emitted, ".*"
    proc assert_equal from TestUtils with results, "emitted preserves element-wise operator", has_elementwise, 1

    Let has_transpose be proc string_contains from StringUtils with emitted, "M'"
    proc assert_equal from TestUtils with results, "emitted preserves transpose", has_transpose, 1

    Let has_cell be proc string_contains from StringUtils with emitted, "{1, 'two'}"
    proc assert_equal from TestUtils with results, "emitted preserves cell array", has_cell, 1

    Let has_switch be proc string_contains from StringUtils with emitted, "switch "
    proc assert_equal from TestUtils with results, "emitted preserves switch", has_switch, 1

    Note: --- Stage 4: re-parse the emitted text to a non-empty AST (HIR2) ---
    Let ast2 be proc source_to_ast with emitted
    proc assert_not_null from TestUtils with results, "emitted MATLAB re-parses to an AST", ast2
    Let func_count2 be proc ast_node_child_count from MatlabParser with ast2
    proc assert_greater_than_or_equal from TestUtils with results, "round-trip preserves all six functions", func_count2, 6

    Let hir2 be proc translate_matlab_to_hir from MatlabFrontend with ast2
    proc assert_not_null from TestUtils with results, "re-parsed MATLAB lowers to HIR again", hir2

    proc print_summary from TestUtils with results
    Let failed be proc get_failed from TestUtils with results
    proc destroy_test_results from TestUtils with results
    Return failed
End Process
