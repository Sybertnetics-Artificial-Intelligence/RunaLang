Note:
Pipeline probe for the Scala translation frontend
(compiler/middle/gungnir/hir/translation/frontends/scala/).

Covers the full lex -> parse -> semantic pipeline:
  - Lexer: keywords, identifiers, operators, literals, lexeme capture.
  - Parser: every shape the semantic accessors decode - class
    declarations with extends/with clauses and bodies, postfix method
    calls with argument and type-argument containers, postfix match
    expressions with case clauses, prefix unary operators, lambda
    parameter lists (lookahead-disambiguated from parenthesised
    expressions), tuple literals, and import paths with the recorded
    member segment.
  - Semantic positive and negative: literal/binary inference, lambda
    function-type construction with parameter extraction, least upper
    bounds (numeric widening, AnyVal/AnyRef families, Nothing bottom,
    cross-family Any), undefined-symbol diagnostics with stdlib and
    import suppression, duplicate-definition detection, Boolean match
    exhaustiveness (positive and negative), builtin-method overload
    resolution by arity and compatibility (substring 1-arg vs 2-arg),
    val annotation conformance including numeric weak conformance,
    abstract-method implementation enforcement, non-trait mixin
    rejection, and type-parameter unification with the occurs check.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/middle/gungnir/hir/translation/frontends/scala/scala_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/scala/scala_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/scala/scala_semantic.runa" as Semantic
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: PIPELINE HELPERS
Note: ============================================================================

Process called "parse_source" that takes source as String returns Integer:
    Let parser be Parser.create_scala_parser(source)
    Return Parser.parse_scala_compilation_unit(parser)
End Process

Process called "analyze_source" that takes source as String returns Integer:
    Let program be parse_source(source)
    Let analyzer be Semantic.create_scala_semantic_analyzer()
    Semantic.analyze_scala_ast(analyzer, program)
    Return analyzer
End Process

Process called "errs_of" that takes source as String returns Integer:
    Let analyzer be analyze_source(source)
    Let errors be Semantic.get_semantic_errors(analyzer)
    Return List.size(errors)
End Process

Note: ============================================================================
Note: LEXER SUITES
Note: ============================================================================

Process called "test_lexer_basics" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_lexer basics: class Foo { val x = 1 }")

    Let lx be Lexer.create_scala_lexer("class Foo { val x = 1 }")
    T.assert_not_equal(results, "L1 lexer created", lx, 0)

    Let t1 be Lexer.next_scala_token(lx)
    Let e1 be TOKEN_CLASS from Lexer
    T.assert_equal(results, "L1 class keyword", t1, e1)

    Let t2 be Lexer.next_scala_token(lx)
    Let e2 be TOKEN_IDENTIFIER from Lexer
    T.assert_equal(results, "L1 identifier token", t2, e2)
    Let lex2 be Lexer.get_lexer_lexeme(lx)
    Let eq2 be StringCore.string_equals(lex2, "Foo")
    T.assert_equal(results, "L1 identifier lexeme Foo", eq2, 1)

    Let t3 be Lexer.next_scala_token(lx)
    Let e3 be TOKEN_LEFT_BRACE from Lexer
    T.assert_equal(results, "L1 left brace", t3, e3)

    Let t4 be Lexer.next_scala_token(lx)
    Let e4 be TOKEN_VAL from Lexer
    T.assert_equal(results, "L1 val keyword", t4, e4)

    Let t5 be Lexer.next_scala_token(lx)
    Let e5 be TOKEN_IDENTIFIER from Lexer
    T.assert_equal(results, "L1 identifier x", t5, e5)

    Let t6 be Lexer.next_scala_token(lx)
    Let e6 be TOKEN_ASSIGN from Lexer
    T.assert_equal(results, "L1 assign", t6, e6)

    Let t7 be Lexer.next_scala_token(lx)
    Let e7 be TOKEN_INTEGER_LITERAL from Lexer
    T.assert_equal(results, "L1 integer literal", t7, e7)

    Let t8 be Lexer.next_scala_token(lx)
    Let e8 be TOKEN_RIGHT_BRACE from Lexer
    T.assert_equal(results, "L1 right brace", t8, e8)

    Let t9 be Lexer.next_scala_token(lx)
    Let e9 be TOKEN_EOF from Lexer
    T.assert_equal(results, "L1 eof", t9, e9)

    Return 1
End Process

Process called "test_lexer_operators" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_lexer operators and arrows")

    Let lx be Lexer.create_scala_lexer("+ . => match ( )")

    Let t1 be Lexer.next_scala_token(lx)
    Let e1 be TOKEN_PLUS from Lexer
    T.assert_equal(results, "L2 plus", t1, e1)

    Let t2 be Lexer.next_scala_token(lx)
    Let e2 be TOKEN_DOT from Lexer
    T.assert_equal(results, "L2 dot", t2, e2)

    Let t3 be Lexer.next_scala_token(lx)
    Let e3 be TOKEN_DOUBLE_ARROW from Lexer
    T.assert_equal(results, "L2 double arrow", t3, e3)

    Let t4 be Lexer.next_scala_token(lx)
    Let e4 be TOKEN_MATCH from Lexer
    T.assert_equal(results, "L2 match keyword", t4, e4)

    Let t5 be Lexer.next_scala_token(lx)
    Let e5 be TOKEN_LEFT_PAREN from Lexer
    T.assert_equal(results, "L2 left paren", t5, e5)

    Let t6 be Lexer.next_scala_token(lx)
    Let e6 be TOKEN_RIGHT_PAREN from Lexer
    T.assert_equal(results, "L2 right paren", t6, e6)

    Return 1
End Process

Note: ============================================================================
Note: PARSER SUITES
Note: ============================================================================

Process called "test_parser_class_shape" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_parser class declaration shape")

    Let program be parse_source("class Foo extends Bar with Baz { def m(a: Int): Int = a }")
    T.assert_not_equal(results, "P1 program parsed", program, 0)

    Let pk be Parser.get_ast_node_type(program)
    Let pe be AST_PROGRAM from Parser
    T.assert_equal(results, "P1 program node kind", pk, pe)

    Let cls be Parser.get_ast_child(program, 0)
    Let ck be Parser.get_ast_node_type(cls)
    Let ce be AST_CLASS from Parser
    T.assert_equal(results, "P1 class decl kind", ck, ce)

    Let cname be Semantic.get_class_name(cls)
    T.assert_string_equal(results, "P1 class name Foo", cname, "Foo")

    Let super_node be Semantic.get_class_superclass(cls)
    T.assert_not_equal(results, "P1 extends clause present", super_node, 0)
    Let super_name be Parser.get_ast_node_value(super_node)
    T.assert_string_equal(results, "P1 extends base Bar", super_name, "Bar")

    Let traits be Semantic.get_class_traits(cls)
    Let trait_count be List.size(traits)
    T.assert_equal(results, "P1 one mixin", trait_count, 1)
    Let mixin be List.get(traits, 0)
    Let mixin_name be Parser.get_ast_node_value(mixin)
    T.assert_string_equal(results, "P1 mixin Baz", mixin_name, "Baz")

    Let members be Semantic.get_class_members(cls)
    Let member_count be List.size(members)
    T.assert_equal(results, "P1 one member", member_count, 1)

    Let m be List.get(members, 0)
    Let mk be Parser.get_ast_node_type(m)
    Let me be AST_FUNCTION from Parser
    T.assert_equal(results, "P1 member is def", mk, me)
    Let m_name be Parser.get_ast_node_value(m)
    T.assert_string_equal(results, "P1 method name m", m_name, "m")

    Let params be Semantic.get_function_parameters(m)
    Let param_count be List.size(params)
    T.assert_equal(results, "P1 one parameter", param_count, 1)
    Let p0 be List.get(params, 0)
    Let p0_name be Parser.get_ast_node_value(p0)
    T.assert_string_equal(results, "P1 parameter a", p0_name, "a")
    Let p0_type be Semantic.get_parameter_type(p0)
    Let int_kind be TYPE_INT from Semantic
    T.assert_equal(results, "P1 parameter type Int", p0_type, int_kind)

    Return 1
End Process

Process called "test_parser_match_shape" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_parser postfix match shape")

    Let program be parse_source("object M { def f(b: Boolean): Int = b match { case true => 1 case false => 0 } }")
    Let obj be Parser.get_ast_child(program, 0)
    Let ok be Parser.get_ast_node_type(obj)
    Let oe be AST_OBJECT from Parser
    T.assert_equal(results, "P2 object kind", ok, oe)

    Let members be Semantic.get_class_members(obj)
    Let f be List.get(members, 0)
    Let f_child_count be Parser.get_ast_child_count(f)
    Let body be Parser.get_ast_child(f, f_child_count minus 1)
    Let bk be Parser.get_ast_node_type(body)
    Let be_kind be AST_MATCH_EXPRESSION from Parser
    T.assert_equal(results, "P2 body is match", bk, be_kind)

    Let scrutinee be Semantic.get_match_scrutinee(body)
    Let sk be Parser.get_ast_node_type(scrutinee)
    Let se be AST_IDENTIFIER from Parser
    T.assert_equal(results, "P2 scrutinee identifier", sk, se)
    Let s_name be Parser.get_ast_node_value(scrutinee)
    T.assert_string_equal(results, "P2 scrutinee b", s_name, "b")

    Let cases be Semantic.get_match_cases(body)
    Let case_count be List.size(cases)
    T.assert_equal(results, "P2 two cases", case_count, 2)

    Let case0 be List.get(cases, 0)
    Let pat0 be Semantic.get_case_pattern(case0)
    Let pk0 be Parser.get_ast_node_type(pat0)
    Let pe0 be AST_LITERAL_PATTERN from Parser
    T.assert_equal(results, "P2 case0 literal pattern", pk0, pe0)
    Let pv0 be Parser.get_ast_node_value(pat0)
    T.assert_string_equal(results, "P2 case0 pattern true", pv0, "true")

    Let body0 be Semantic.get_case_body(case0)
    Let bk0 be Parser.get_ast_node_type(body0)
    Let be0 be AST_LITERAL from Parser
    T.assert_equal(results, "P2 case0 body literal", bk0, be0)
    Let bv0 be Parser.get_ast_node_value(body0)
    T.assert_string_equal(results, "P2 case0 body 1", bv0, "1")

    Return 1
End Process

Process called "test_parser_method_call_shape" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_parser postfix method call shape")

    Let program be parse_source("val y = s.substring(1, 2)")
    Let val_node be Parser.get_ast_child(program, 0)
    Let init be Semantic.get_val_initializer(val_node)
    Let ik be Parser.get_ast_node_type(init)
    Let ie be AST_METHOD_CALL from Parser
    T.assert_equal(results, "P3 initializer method call", ik, ie)

    Let m_name be Semantic.get_method_name(init)
    T.assert_string_equal(results, "P3 method substring", m_name, "substring")

    Let receiver be Semantic.get_method_receiver(init)
    Let r_name be Parser.get_ast_node_value(receiver)
    T.assert_string_equal(results, "P3 receiver s", r_name, "s")

    Let args be Semantic.get_method_arguments(init)
    Let arg_count be List.size(args)
    T.assert_equal(results, "P3 two arguments", arg_count, 2)

    Note: Field-style selection carries the field_access marker and no args
    Let program2 be parse_source("val z = s.length")
    Let val2 be Parser.get_ast_child(program2, 0)
    Let init2 be Semantic.get_val_initializer(val2)
    Let i2k be Parser.get_ast_node_type(init2)
    T.assert_equal(results, "P3 selection is method call", i2k, ie)
    Let fa be Parser.get_node_attribute(init2, "field_access")
    Let fa_set be StringCore.string_equals(fa, "true")
    T.assert_equal(results, "P3 field access marker", fa_set, 1)
    Let args2 be Semantic.get_method_arguments(init2)
    Let arg2_count be List.size(args2)
    T.assert_equal(results, "P3 selection zero args", arg2_count, 0)

    Return 1
End Process

Process called "test_parser_unary_shape" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_parser prefix unary shape")

    Let program be parse_source("val n = !flag")
    Let val_node be Parser.get_ast_child(program, 0)
    Let init be Semantic.get_val_initializer(val_node)
    Let ik be Parser.get_ast_node_type(init)
    Let ie be AST_UNARY_OP from Parser
    T.assert_equal(results, "P4 unary node", ik, ie)

    Let op be Semantic.get_unary_operator(init)
    T.assert_string_equal(results, "P4 operator !", op, "!")

    Let operand be Semantic.get_unary_operand(init)
    Let opk be Parser.get_ast_node_type(operand)
    Let ope be AST_IDENTIFIER from Parser
    T.assert_equal(results, "P4 operand identifier", opk, ope)
    Let op_name be Parser.get_ast_node_value(operand)
    T.assert_string_equal(results, "P4 operand flag", op_name, "flag")

    Return 1
End Process

Process called "test_parser_lambda_and_tuple" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_parser lambda lookahead and tuple shape")

    Let program be parse_source("val f = (a: Int) => a + 1")
    Let val_node be Parser.get_ast_child(program, 0)
    Let init be Semantic.get_val_initializer(val_node)
    Let ik be Parser.get_ast_node_type(init)
    Let ie be AST_LAMBDA from Parser
    T.assert_equal(results, "P5 lambda node", ik, ie)

    Let params be Semantic.get_lambda_parameters(init)
    Let param_count be List.size(params)
    T.assert_equal(results, "P5 one lambda parameter", param_count, 1)
    Let p0 be List.get(params, 0)
    Let p0_name be Parser.get_ast_node_value(p0)
    T.assert_string_equal(results, "P5 lambda parameter a", p0_name, "a")

    Let body be Semantic.get_lambda_body(init)
    Let bk be Parser.get_ast_node_type(body)
    Let be_kind be AST_BINARY_OP from Parser
    T.assert_equal(results, "P5 lambda body binary op", bk, be_kind)

    Note: Parenthesised comma list is a tuple, not a lambda
    Let program2 be parse_source("val t = (1, 2)")
    Let val2 be Parser.get_ast_child(program2, 0)
    Let init2 be Semantic.get_val_initializer(val2)
    Let i2k be Parser.get_ast_node_type(init2)
    Let i2e be AST_TUPLE from Parser
    T.assert_equal(results, "P5 tuple node", i2k, i2e)
    Let tuple_count be Parser.get_ast_child_count(init2)
    T.assert_equal(results, "P5 tuple two elements", tuple_count, 2)

    Return 1
End Process

Process called "test_parser_import_shape" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_parser import path shape")

    Let program be parse_source("import a.b.C")
    Let import_node be Parser.get_ast_child(program, 0)
    Let ik be Parser.get_ast_node_type(import_node)
    Let ie be AST_IMPORT from Parser
    T.assert_equal(results, "P6 import kind", ik, ie)

    Let qualified be Parser.get_ast_child(import_node, 0)
    Let full be Parser.get_node_attribute(qualified, "name")
    T.assert_string_equal(results, "P6 full path", full, "a.b.C")
    Let member be Parser.get_node_attribute(qualified, "member")
    T.assert_string_equal(results, "P6 member segment", member, "C")

    Return 1
End Process

Note: ============================================================================
Note: SEMANTIC SUITES
Note: ============================================================================

Process called "test_semantic_inference" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_semantic literal/binary/lambda inference")

    Let program be parse_source("val x = 1 + 2")
    Let analyzer be Semantic.create_scala_semantic_analyzer()
    Semantic.analyze_scala_ast(analyzer, program)
    Let errors be Semantic.get_semantic_errors(analyzer)
    Let err_count be List.size(errors)
    T.assert_equal(results, "S1 arithmetic clean", err_count, 0)

    Let val_node be Parser.get_ast_child(program, 0)
    Let init be Semantic.get_val_initializer(val_node)
    Let init_type be Semantic.infer_expression_type(analyzer, init)
    Let int_kind be TYPE_INT from Semantic
    T.assert_equal(results, "S1 1 + 2 is Int", init_type, int_kind)

    Note: Lambda builds a function-type record with extractable params
    Let program2 be parse_source("val f = (a: Int) => a + 1")
    Let analyzer2 be Semantic.create_scala_semantic_analyzer()
    Semantic.analyze_scala_ast(analyzer2, program2)
    Let errors2 be Semantic.get_semantic_errors(analyzer2)
    Let err2 be List.size(errors2)
    T.assert_equal(results, "S1 lambda clean", err2, 0)

    Let val2 be Parser.get_ast_child(program2, 0)
    Let lam be Semantic.get_val_initializer(val2)
    Let lam_type be Semantic.infer_expression_type(analyzer2, lam)
    T.assert_greater_than(results, "S1 lambda type is record", lam_type, 65535)
    Let param0 be Semantic.extract_function_param_type(lam_type, 0)
    T.assert_equal(results, "S1 lambda param type Int", param0, int_kind)

    Return 1
End Process

Process called "test_semantic_lub" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_semantic least upper bounds")

    Let analyzer be Semantic.create_scala_semantic_analyzer()
    Let int_kind be TYPE_INT from Semantic
    Let double_kind be TYPE_DOUBLE from Semantic
    Let string_kind be TYPE_STRING from Semantic
    Let boolean_kind be TYPE_BOOLEAN from Semantic
    Let list_kind be TYPE_LIST from Semantic
    Let nothing_kind be TYPE_NOTHING from Semantic
    Let any_kind be TYPE_ANY from Semantic
    Let anyval_kind be TYPE_ANYVAL from Semantic
    Let anyref_kind be TYPE_ANYREF from Semantic

    Let lub1 be Semantic.find_least_upper_bound(analyzer, int_kind, double_kind)
    T.assert_equal(results, "S2 Int/Double widens to Double", lub1, double_kind)

    Let lub2 be Semantic.find_least_upper_bound(analyzer, int_kind, string_kind)
    T.assert_equal(results, "S2 Int/String bounds at Any", lub2, any_kind)

    Let lub3 be Semantic.find_least_upper_bound(analyzer, boolean_kind, int_kind)
    T.assert_equal(results, "S2 Boolean/Int bounds at AnyVal", lub3, anyval_kind)

    Let lub4 be Semantic.find_least_upper_bound(analyzer, string_kind, list_kind)
    T.assert_equal(results, "S2 String/List bounds at AnyRef", lub4, anyref_kind)

    Let lub5 be Semantic.find_least_upper_bound(analyzer, nothing_kind, int_kind)
    T.assert_equal(results, "S2 Nothing absorbs into Int", lub5, int_kind)

    Let lub6 be Semantic.find_least_upper_bound(analyzer, int_kind, int_kind)
    T.assert_equal(results, "S2 identity", lub6, int_kind)

    Return 1
End Process

Process called "test_semantic_undefined_symbols" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_semantic undefined symbols and suppression")

    Let e1 be errs_of("object Main { def f(): Int = unknownValue }")
    T.assert_equal(results, "S3 undefined identifier errors once", e1, 1)

    Let e2 be errs_of("object Main { def go(): Unit = println(42) }")
    T.assert_equal(results, "S3 stdlib println clean", e2, 0)

    Let e3 be errs_of("import scala.util.Random object Main { def f(): Unit = Random }")
    T.assert_equal(results, "S3 imported name suppressed", e3, 0)

    Let e4 be errs_of("object Main { def f(): Unit = Random }")
    T.assert_equal(results, "S3 unimported name errors", e4, 1)

    Return 1
End Process

Process called "test_semantic_duplicates" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_semantic duplicate definitions")

    Let e1 be errs_of("class A {} class B {}")
    T.assert_equal(results, "S4 distinct classes clean", e1, 0)

    Let e2 be errs_of("class A {} class A {}")
    T.assert_equal(results, "S4 duplicate class", e2, 1)

    Return 1
End Process

Process called "test_semantic_exhaustiveness" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_semantic match exhaustiveness")

    Let e1 be errs_of("object M { def f(b: Boolean): Int = b match { case true => 1 case false => 0 } }")
    T.assert_equal(results, "S5 covered Boolean clean", e1, 0)

    Let e2 be errs_of("object M { def f(b: Boolean): Int = b match { case true => 1 } }")
    T.assert_equal(results, "S5 missing false flagged", e2, 1)

    Let e3 be errs_of("object M { def f(b: Boolean): Int = b match { case true => 1 case other => 0 } }")
    T.assert_equal(results, "S5 lowercase binder is catch-all", e3, 0)

    Return 1
End Process

Process called "test_semantic_overloads" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_semantic builtin overload resolution")

    Let e1 be errs_of("object M { def f(s: String): Int = s.substring(1).length }")
    T.assert_equal(results, "S6 substring(Int) resolves", e1, 0)

    Let e2 be errs_of("object M { def f(s: String): String = s.substring(1, 2) }")
    T.assert_equal(results, "S6 substring(Int,Int) resolves", e2, 0)

    Let e3 be errs_of("object M { def g(s: String): Int = s.substring(true).length }")
    T.assert_equal(results, "S6 Boolean argument rejected", e3, 1)

    Let e4 be errs_of("object M { def h(s: String): Int = s.missingMethod() }")
    T.assert_equal(results, "S6 unknown method flagged", e4, 1)

    Return 1
End Process

Process called "test_semantic_val_conformance" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_semantic val annotation conformance")

    Let e1 be errs_of("object M { val x: Int = 1 }")
    T.assert_equal(results, "S7 exact annotation clean", e1, 0)

    Let e2 be errs_of("object M { val y: Double = 1 }")
    T.assert_equal(results, "S7 numeric weak conformance clean", e2, 0)

    Let e3 be errs_of("object M { val z: Int = \"hi\" }")
    T.assert_equal(results, "S7 String into Int rejected", e3, 1)

    Return 1
End Process

Process called "test_semantic_inheritance" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_semantic abstract members and mixins")

    Let e1 be errs_of("trait T { def m(): Int } class C extends T { def m(): Int = 1 }")
    T.assert_equal(results, "S8 implemented abstract clean", e1, 0)

    Let e2 be errs_of("trait T { def m(): Int } class C extends T {}")
    T.assert_equal(results, "S8 missing implementation flagged", e2, 1)

    Let e3 be errs_of("class A {} class B {} class C extends A with B {}")
    T.assert_equal(results, "S8 non-trait mixin rejected", e3, 1)

    Let e4 be errs_of("class A {} trait T2 {} class C extends A with T2 {}")
    T.assert_equal(results, "S8 trait mixin clean", e4, 0)

    Return 1
End Process

Process called "test_semantic_unification" that takes results as Integer returns Integer:
    T.begin_suite(results, "scala_semantic type-parameter unification")

    Let analyzer be Semantic.create_scala_semantic_analyzer()
    Let int_kind be TYPE_INT from Semantic

    Let tp be Semantic.create_type_parameter("T")
    Let is_param be Semantic.is_type_parameter(tp)
    T.assert_equal(results, "S9 fresh parameter recognised", is_param, 1)

    Let bound be Semantic.unify_type_parameter(analyzer, tp, int_kind)
    T.assert_equal(results, "S9 binding succeeds", bound, 1)

    Let after be Semantic.is_type_parameter(tp)
    T.assert_equal(results, "S9 bound parameter is concrete", after, 0)

    Let canonical be Semantic.resolve_type_alias(analyzer, tp)
    T.assert_equal(results, "S9 binding resolves to Int", canonical, int_kind)

    Note: Occurs check - binding U := Function(U) -> Int must fail
    Let tp2 be Semantic.create_type_parameter("U")
    Let occurs_params be List.list_create()
    List.list_append(occurs_params, tp2)
    Let fn_type be Semantic.create_function_type(occurs_params, int_kind)
    Let occurs_result be Semantic.unify_type_parameter(analyzer, tp2, fn_type)
    T.assert_equal(results, "S9 occurs check rejects", occurs_result, 0)

    Let errors be Semantic.get_semantic_errors(analyzer)
    Let err_count be List.size(errors)
    T.assert_equal(results, "S9 occurs check diagnosed", err_count, 1)

    Return 1
End Process

