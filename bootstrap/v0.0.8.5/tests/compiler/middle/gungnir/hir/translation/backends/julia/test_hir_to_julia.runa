Note:
Unit tests for compiler/middle/gungnir/hir/translation/backends/julia/hir_to_julia.runa.
Tests focus on the pure mapping helpers (Runa-type and Runa-operator to Julia
equivalents). The full HIR-walking generators are exercised by integration
tests with hand-built HIRNode trees.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/middle/gungnir/hir/translation/backends/julia/hir_to_julia.runa" as J
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: TYPE-NAME MAPPING
Note: ============================================================================

Process called "test_map_basic_type_integer" that takes results as Integer returns Integer:
    T.begin_suite(results, "hir_to_julia.julia_map_basic_type Integer family")

    Let r1 be J.julia_map_basic_type("Integer")
    Let eq1 be StringCore.string_equals(r1, "Int64")
    T.assert_equal(results, "Integer -> Int64", eq1, 1)

    Let r2 be J.julia_map_basic_type("Integer8")
    Let eq2 be StringCore.string_equals(r2, "Int8")
    T.assert_equal(results, "Integer8 -> Int8", eq2, 1)

    Let r3 be J.julia_map_basic_type("Integer16")
    Let eq3 be StringCore.string_equals(r3, "Int16")
    T.assert_equal(results, "Integer16 -> Int16", eq3, 1)

    Let r4 be J.julia_map_basic_type("Integer32")
    Let eq4 be StringCore.string_equals(r4, "Int32")
    T.assert_equal(results, "Integer32 -> Int32", eq4, 1)

    Let r5 be J.julia_map_basic_type("Integer64")
    Let eq5 be StringCore.string_equals(r5, "Int64")
    T.assert_equal(results, "Integer64 -> Int64", eq5, 1)

    Return 1
End Process

Process called "test_map_basic_type_floats" that takes results as Integer returns Integer:
    T.begin_suite(results, "hir_to_julia.julia_map_basic_type Float family")

    Let r1 be J.julia_map_basic_type("Float")
    Let eq1 be StringCore.string_equals(r1, "Float64")
    T.assert_equal(results, "Float -> Float64", eq1, 1)

    Let r2 be J.julia_map_basic_type("Float32")
    Let eq2 be StringCore.string_equals(r2, "Float32")
    T.assert_equal(results, "Float32 -> Float32", eq2, 1)

    Let r3 be J.julia_map_basic_type("Float64")
    Let eq3 be StringCore.string_equals(r3, "Float64")
    T.assert_equal(results, "Float64 -> Float64", eq3, 1)

    Return 1
End Process

Process called "test_map_basic_type_others" that takes results as Integer returns Integer:
    T.begin_suite(results, "hir_to_julia.julia_map_basic_type primitives")

    Let r1 be J.julia_map_basic_type("String")
    Let eq1 be StringCore.string_equals(r1, "String")
    T.assert_equal(results, "String -> String", eq1, 1)

    Let r2 be J.julia_map_basic_type("Boolean")
    Let eq2 be StringCore.string_equals(r2, "Bool")
    T.assert_equal(results, "Boolean -> Bool", eq2, 1)

    Let r3 be J.julia_map_basic_type("Character")
    Let eq3 be StringCore.string_equals(r3, "Char")
    T.assert_equal(results, "Character -> Char", eq3, 1)

    Let r4 be J.julia_map_basic_type("Nothing")
    Let eq4 be StringCore.string_equals(r4, "Nothing")
    T.assert_equal(results, "Nothing -> Nothing", eq4, 1)

    Let r5 be J.julia_map_basic_type("MyCustomType")
    Let eq5 be StringCore.string_equals(r5, "MyCustomType")
    T.assert_equal(results, "user types pass through unchanged", eq5, 1)

    Return 1
End Process

Note: ============================================================================
Note: BINARY OPERATOR MAPPING
Note: ============================================================================

Process called "test_map_binary_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "hir_to_julia.julia_map_binary_op arithmetic")

    Let r1 be J.julia_map_binary_op("plus")
    Let eq1 be StringCore.string_equals(r1, "+")
    T.assert_equal(results, "plus -> +", eq1, 1)

    Let r2 be J.julia_map_binary_op("minus")
    Let eq2 be StringCore.string_equals(r2, "-")
    T.assert_equal(results, "minus -> -", eq2, 1)

    Let r3 be J.julia_map_binary_op("multiplied by")
    Let eq3 be StringCore.string_equals(r3, "*")
    T.assert_equal(results, "multiplied by -> *", eq3, 1)

    Let r4 be J.julia_map_binary_op("divided by")
    Let eq4 be StringCore.string_equals(r4, "/")
    T.assert_equal(results, "divided by -> /", eq4, 1)

    Let r5 be J.julia_map_binary_op("modulo")
    Let eq5 be StringCore.string_equals(r5, "%")
    T.assert_equal(results, "modulo -> %", eq5, 1)

    Return 1
End Process

Process called "test_map_binary_comparison" that takes results as Integer returns Integer:
    T.begin_suite(results, "hir_to_julia.julia_map_binary_op comparison")

    Let r1 be J.julia_map_binary_op("is equal to")
    Let eq1 be StringCore.string_equals(r1, "==")
    T.assert_equal(results, "is equal to -> ==", eq1, 1)

    Let r2 be J.julia_map_binary_op("is not equal to")
    Let eq2 be StringCore.string_equals(r2, "!=")
    T.assert_equal(results, "is not equal to -> !=", eq2, 1)

    Let r3 be J.julia_map_binary_op("is less than")
    Let eq3 be StringCore.string_equals(r3, "<")
    T.assert_equal(results, "is less than -> <", eq3, 1)

    Let r4 be J.julia_map_binary_op("is greater than")
    Let eq4 be StringCore.string_equals(r4, ">")
    T.assert_equal(results, "is greater than -> >", eq4, 1)

    Let r5 be J.julia_map_binary_op("is less than or equal to")
    Let eq5 be StringCore.string_equals(r5, "<=")
    T.assert_equal(results, "is less than or equal to -> <=", eq5, 1)

    Let r6 be J.julia_map_binary_op("is greater than or equal to")
    Let eq6 be StringCore.string_equals(r6, ">=")
    T.assert_equal(results, "is greater than or equal to -> >=", eq6, 1)

    Return 1
End Process

Process called "test_map_binary_logical" that takes results as Integer returns Integer:
    T.begin_suite(results, "hir_to_julia.julia_map_binary_op logical/bitwise")

    Let r1 be J.julia_map_binary_op("and")
    Let eq1 be StringCore.string_equals(r1, "&&")
    T.assert_equal(results, "and -> &&", eq1, 1)

    Let r2 be J.julia_map_binary_op("or")
    Let eq2 be StringCore.string_equals(r2, "||")
    T.assert_equal(results, "or -> ||", eq2, 1)

    Let r3 be J.julia_map_binary_op("bitwise and")
    Let eq3 be StringCore.string_equals(r3, "&")
    T.assert_equal(results, "bitwise and -> &", eq3, 1)

    Let r4 be J.julia_map_binary_op("bitwise or")
    Let eq4 be StringCore.string_equals(r4, "|")
    T.assert_equal(results, "bitwise or -> |", eq4, 1)

    Let r5 be J.julia_map_binary_op("bitwise xor")
    Let eq5 be StringCore.string_equals(r5, "^")
    T.assert_equal(results, "bitwise xor -> ^", eq5, 1)

    Let r6 be J.julia_map_binary_op("shifted left by")
    Let eq6 be StringCore.string_equals(r6, "<<")
    T.assert_equal(results, "shifted left by -> <<", eq6, 1)

    Let r7 be J.julia_map_binary_op("shifted right by")
    Let eq7 be StringCore.string_equals(r7, ">>")
    T.assert_equal(results, "shifted right by -> >>", eq7, 1)

    Return 1
End Process

Note: ============================================================================
Note: UNARY OPERATOR MAPPING
Note: ============================================================================

Process called "test_map_unary" that takes results as Integer returns Integer:
    T.begin_suite(results, "hir_to_julia.julia_map_unary_op")

    Let r1 be J.julia_map_unary_op("negate")
    Let eq1 be StringCore.string_equals(r1, "-")
    T.assert_equal(results, "negate -> -", eq1, 1)

    Let r2 be J.julia_map_unary_op("minus")
    Let eq2 be StringCore.string_equals(r2, "-")
    T.assert_equal(results, "minus -> -", eq2, 1)

    Let r3 be J.julia_map_unary_op("not")
    Let eq3 be StringCore.string_equals(r3, "!")
    T.assert_equal(results, "not -> !", eq3, 1)

    Let r4 be J.julia_map_unary_op("bitwise not")
    Let eq4 be StringCore.string_equals(r4, "~")
    T.assert_equal(results, "bitwise not -> ~", eq4, 1)

    Return 1
End Process

Note: ============================================================================
Note: MAIN
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_map_basic_type_integer(results)
    test_map_basic_type_floats(results)
    test_map_basic_type_others(results)
    test_map_binary_arithmetic(results)
    test_map_binary_comparison(results)
    test_map_binary_logical(results)
    test_map_unary(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
