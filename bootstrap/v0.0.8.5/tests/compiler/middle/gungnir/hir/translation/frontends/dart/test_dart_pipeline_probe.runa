    test_scoped_local_functions(results)
    test_scoped_method_receivers(results)
    test_scoped_function_typed_values(results)

    test_wrapper_type_arguments_future(results)
    test_wrapper_type_arguments_generators(results)

    test_typedef_expansion(results)
