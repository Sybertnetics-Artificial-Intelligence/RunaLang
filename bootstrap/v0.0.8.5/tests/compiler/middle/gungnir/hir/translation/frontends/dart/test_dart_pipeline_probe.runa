Process called "test_scoped_local_functions" that takes results as Integer returns Integer:
    T.begin_suite(results, "residual 1a: local function callees")

    Let e1 be errs_of("void main() { void local(Iterable<int> Function() cb) {} local(() sync* { yield 1; }); }")
    T.assert_equal(results, "R1 local fn Iterable context clean", e1, 0)

    Let e2 be errs_of("void main() { void local(int Function() cb) {} local(() sync* { yield 1; }); }")
    T.assert_equal(results, "R1 local fn non-Iterable context", e2, 1)

    Let e3 be errs_of("void main() { void outer() { void inner(Future<int> Function() cb) {} inner(() async => 1); } }")
    T.assert_equal(results, "R1 nested local fn clean", e3, 0)

    Let e4 be errs_of("void main() { void outer() { void inner(int Function() cb) {} inner(() async => 1); } }")
    T.assert_equal(results, "R1 nested local fn mismatch", e4, 1)

    Let e5 be errs_of("void run(int Function() cb) {} void main() { void run(Future<int> Function() cb) {} run(() async => 1); }")
    T.assert_equal(results, "R1 local fn shadows top level", e5, 0)

    Return 1
End Process

Process called "test_scoped_method_receivers" that takes results as Integer returns Integer:
    T.begin_suite(results, "residual 1b: method receiver callees")

    Let e1 be errs_of("class Runner { void go(Future<int> Function() job) {} } void main() { Runner r = Runner(); r.go(() async => 1); }")
    T.assert_equal(results, "R2 declared receiver clean", e1, 0)

    Let e2 be errs_of("class Runner { void go(Future<int> Function() job) {} } void main() { Runner r = Runner(); r.go(() sync* { yield 1; }); }")
    T.assert_equal(results, "R2 declared receiver mismatch", e2, 1)

    Let e3 be errs_of("class Runner { void go(Stream<int> Function() job) {} } void main() { var r = Runner(); r.go(() async* { yield 1; }); }")
    T.assert_equal(results, "R2 inferred receiver clean", e3, 0)

    Let e4 be errs_of("class Runner { void go(Stream<int> Function() job) {} } void main() { var r = Runner(); r.go(() async => 1); }")
    T.assert_equal(results, "R2 inferred receiver mismatch", e4, 1)

    Let e5 be errs_of("class Base { void go(Iterable<int> Function() job) {} } class Sub extends Base {} void main() { Sub s = Sub(); s.go(() sync* { yield 1; }); }")
    T.assert_equal(results, "R2 inherited method clean", e5, 0)

    Let e6 be errs_of("class Base { void go(Iterable<int> Function() job) {} } class Sub extends Base {} void main() { Sub s = Sub(); s.go(() async => 1); }")
    T.assert_equal(results, "R2 inherited method mismatch", e6, 1)

    Let e7 be errs_of("class K { void Function(Future<int> Function()) hook = (cb) {}; } void main() { K k = K(); k.hook(() async => 1); }")
    T.assert_equal(results, "R2 function-typed field clean", e7, 0)

    Let e8 be errs_of("class K { void Function(Future<int> Function()) hook = (cb) {}; } void main() { K k = K(); k.hook(() sync* { yield 1; }); }")
    T.assert_equal(results, "R2 function-typed field mismatch", e8, 1)

    Return 1
End Process

Process called "test_scoped_function_typed_values" that takes results as Integer returns Integer:
    T.begin_suite(results, "residual 1c: function-typed variable callees")

    Let e1 be errs_of("void main() { void Function(Future<int> Function()) h = (cb) {}; h(() async => 1); }")
    T.assert_equal(results, "R3 fn-typed local var clean", e1, 0)

    Let e2 be errs_of("void main() { void Function(Future<int> Function()) h = (cb) {}; h(() sync* { yield 1; }); }")
