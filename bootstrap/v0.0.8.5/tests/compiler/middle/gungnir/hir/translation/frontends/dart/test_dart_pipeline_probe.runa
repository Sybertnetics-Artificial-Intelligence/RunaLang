    test_lexer_keywords_and_literals(results)

    test_parser_class_shape(results)
    test_parser_function_and_lambda(results)
    test_parser_typedef_shapes(results)
    test_parser_calls_and_members(results)
    test_parser_type_nodes(results)

    test_semantic_duplicates(results)
    test_semantic_type_resolution(results)
    test_semantic_null_safety(results)
    test_semantic_async_contracts(results)
    test_semantic_lambda_contexts(results)
    test_semantic_call_arg_contexts(results)
