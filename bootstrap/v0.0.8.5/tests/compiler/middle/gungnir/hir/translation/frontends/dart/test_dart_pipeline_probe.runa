Process called "test_typedef_expansion" that takes results as Integer returns Integer:
    T.begin_suite(results, "residual 3: typedef-named function-type contexts")

    Let e1 be errs_of("typedef Cb = Future<int> Function(); void main() { Cb f = () async => 1; }")
    T.assert_equal(results, "R5 typedef Future context clean", e1, 0)

    Let e2 be errs_of("typedef Bad = int Function(); void main() { Bad g = () async => 1; }")
    T.assert_equal(results, "R5 typedef non-Future context", e2, 1)

    Let e3 be errs_of("typedef SCb = Future<String> Function(); void main() { SCb h = () async => 1; }")
    T.assert_equal(results, "R5 typedef element mismatch", e3, 1)

    Let e4 be errs_of("typedef Cb = Future<int> Function(); typedef Alias = Cb; void main() { Alias k = () async => 1; }")
    T.assert_equal(results, "R5 typedef of typedef clean", e4, 0)

    Let e5 be errs_of("typedef Bad = int Function(); typedef Alias = Bad; void main() { Alias m = () async => 1; }")
    T.assert_equal(results, "R5 typedef of typedef mismatch", e5, 1)

    Let e6 be errs_of("typedef X1 = Y1; typedef Y1 = X1; void main() { X1 v = () async => 1; }")
    T.assert_equal(results, "R5 typedef cycle terminates silently", e6, 0)

    Let e7 be errs_of("typedef JCb = Future<int> Function(); void run(JCb job) {} void main() { run(() async => 1); }")
    T.assert_equal(results, "R5 typedef parameter context clean", e7, 0)

    Let e8 be errs_of("typedef JCb = Future<int> Function(); void run(JCb job) {} void main() { run(() sync* { yield 1; }); }")
    T.assert_equal(results, "R5 typedef parameter context mismatch", e8, 1)

    Let e9 be errs_of("typedef int LegacyCb(); void main() { LegacyCb v = () async => 1; }")
    T.assert_equal(results, "R5 legacy typedef context mismatch", e9, 1)

    Let e10 be errs_of("typedef int LegacyCb(); void main() { LegacyCb v = () => 1; }")
    T.assert_equal(results, "R5 legacy typedef unflagged lambda clean", e10, 0)

    Let e11 be errs_of("typedef Cb = int Function(); Cb x;")
    T.assert_equal(results, "R5 typedef name resolves as type", e11, 0)

    Let e12 be errs_of("typedef A1 = int Function(); typedef A1 = int Function();")
    T.assert_equal(results, "R5 duplicate typedef", e12, 1)

    Return 1
End Process

Process called "test_return_type_contexts" that takes results as Integer returns Integer:
    T.begin_suite(results, "residual 3: return-type lambda contexts")

    Let e1 be errs_of("Future<int> Function() make() { return () async => 1; }")
    T.assert_equal(results, "R6 returned lambda Future context clean", e1, 0)

    Let e2 be errs_of("int Function() make() { return () async => 1; }")
    T.assert_equal(results, "R6 returned lambda non-Future context", e2, 1)

    Let e3 be errs_of("Stream<int> Function() make() { return () sync* { yield 1; }; }")
    T.assert_equal(results, "R6 returned sync* needs Iterable", e3, 1)

    Let e4 be errs_of("typedef RCb = Stream<int> Function(); RCb make() { return () async* { yield 1; }; }")
    T.assert_equal(results, "R6 typedef return context clean", e4, 0)

    Let e5 be errs_of("typedef RCb = Stream<int> Function(); RCb make() { return () async => 1; }")
    T.assert_equal(results, "R6 typedef return context mismatch", e5, 1)

    Let e6 be errs_of("Future<String> Function() make() { return () async => 1; }")
    T.assert_equal(results, "R6 returned lambda element mismatch", e6, 1)

    Let e7 be errs_of("Future<int> Function() make() => () async => 1;")
    T.assert_equal(results, "R6 arrow-bodied maker clean", e7, 0)

    Return 1
End Process

