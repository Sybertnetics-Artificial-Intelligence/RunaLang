Note: RESIDUAL 2 - WRAPPER TYPE-ARGUMENT CHECKING
Note: ============================================================================

Process called "test_wrapper_type_arguments_future" that takes results as Integer returns Integer:
    T.begin_suite(results, "residual 2: Future element assignability")

    Let e1 be errs_of("void main() { Future<String> Function() f = () async => 1; }")
    T.assert_equal(results, "R4 Future<String> rejects int", e1, 1)

    Let e2 be errs_of("void main() { Future<String> Function() f = () async => 'x'; }")
    T.assert_equal(results, "R4 Future<String> accepts String", e2, 0)

    Let e3 be errs_of("void main() { Future<int> Function() f = () async => 1.5; }")
    T.assert_equal(results, "R4 Future<int> rejects double", e3, 1)

    Let e4 be errs_of("void main() { Future<double> Function() f = () async => 1; }")
    T.assert_equal(results, "R4 Future<double> demotes int literal", e4, 0)

    Let e5 be errs_of("void main() { Future<double> Function() f = () async => 'x'; }")
    T.assert_equal(results, "R4 Future<double> rejects String", e5, 1)

    Let e6 be errs_of("void main() { Future<num> Function() f = () async => 1; }")
    T.assert_equal(results, "R4 Future<num> accepts int", e6, 0)

    Let e7 be errs_of("void main() { Future<dynamic> Function() f = () async => 1; }")
    T.assert_equal(results, "R4 Future<dynamic> accepts all", e7, 0)

    Let e8 be errs_of("void main() { Future<Object> Function() f = () async => 1; }")
    T.assert_equal(results, "R4 Future<Object> accepts int", e8, 0)

    Let e9 be errs_of("void main() { Future<void> Function() f = () async => 1; }")
    T.assert_equal(results, "R4 Future<void> accepts value", e9, 0)

    Let e10 be errs_of("void main() { Future<String> Function() f = () async { return 1; }; }")
    T.assert_equal(results, "R4 block body return rejected", e10, 1)

    Let e11 be errs_of("void main() { Future<String> Function() f = () async { return 'x'; }; }")
    T.assert_equal(results, "R4 block body return accepted", e11, 0)

    Let e12 be errs_of("class A {} class B extends A {} void main() { Future<A> Function() f = () async => B(); }")
    T.assert_equal(results, "R4 subtype element accepted", e12, 0)

    Let e13 be errs_of("class A {} class B extends A {} void main() { Future<B> Function() f = () async => A(); }")
    T.assert_equal(results, "R4 supertype element rejected", e13, 1)

    Let e14 be errs_of("Future<int> fetch() async { return 1; } void main() { Future<int> Function() g = () async => fetch(); }")
    T.assert_equal(results, "R4 Future flattening accepted", e14, 0)

    Let e15 be errs_of("Future<int> fetch() async { return 1; } void main() { Future<String> Function() g = () async => fetch(); }")
    T.assert_equal(results, "R4 Future flattening rejected", e15, 1)

    Let e16 be errs_of("void main() { Future<int> Function(int) f = (int x) async => x; }")
    T.assert_equal(results, "R4 lambda parameter element accepted", e16, 0)

    Let e17 be errs_of("void main() { Future<String> Function(int) f = (int x) async => x; }")
    T.assert_equal(results, "R4 lambda parameter element rejected", e17, 1)

    Let e18 be errs_of("void run(Future<String> Function() job) {} void main() { run(() async => 1); }")
    T.assert_equal(results, "R4 call-arg element rejected", e18, 1)

    Return 1
End Process

Process called "test_wrapper_type_arguments_generators" that takes results as Integer returns Integer:
    T.begin_suite(results, "residual 2: Stream/Iterable element assignability")

    Let e1 be errs_of("void main() { Stream<String> Function() s = () async* { yield 1; }; }")
    T.assert_equal(results, "R4 Stream<String> rejects int yield", e1, 1)

    Let e2 be errs_of("void main() { Stream<int> Function() s = () async* { yield 1; }; }")
    T.assert_equal(results, "R4 Stream<int> accepts int yield", e2, 0)

    Let e3 be errs_of("void main() { Iterable<String> Function() i = () sync* { yield 1; }; }")
    T.assert_equal(results, "R4 Iterable<String> rejects int yield", e3, 1)

    Let e4 be errs_of("void main() { Iterable<int> Function() i = () sync* { yield 1; }; }")
    T.assert_equal(results, "R4 Iterable<int> accepts int yield", e4, 0)

    Let e5 be errs_of("Stream<int> demo() async* { yield 1; } void main() { Stream<int> Function() s = () async* { yield* demo(); }; }")
    T.assert_equal(results, "R4 yield* matching element clean", e5, 0)

    Let e6 be errs_of("Stream<int> demo() async* { yield 1; } void main() { Stream<String> Function() s = () async* { yield* demo(); }; }")
    T.assert_equal(results, "R4 yield* mismatched element", e6, 1)

    Return 1
End Process

