Note:
Wave 1 gate probe for the canonical MIR layout contract (MIR
reconciliation #432, MIR_RECONCILIATION_PLAN.md Part 1).

Builds a small three-block MIRFunction by hand through the canonical
constructors and then exercises the EXACT access patterns that the live
optimization pipeline (compiler/middle/transformations/optimization.runa)
relies on after its Wave 1 retarget:

  b0 (entry):
    v1 = CONST 7 (20001)
    v2 = CONST 5 (20001)
    v3 = ADD v1, v2 (20002)
    v4 = ALLOCA (20202)
    STORE *(v4 + 16) = v3 (20201)
    v5 = LOAD *(v4 + 16) (20200)
    v6 = LT v5, v2 (20102)
    BRANCH v6 ? b1 : b2 (20301)
  b1:
    JUMP b2 (20302)
  b2 (exit):
    RETURN v5 (20303)

Verified access patterns:
  - function -> cfg walk (MIRFunction cfg at offset 8 via accessor)
  - cfg -> blocks walk (MIRCFG blocks List at offset 16 + cached count)
  - block -> instructions walk (instructions List at offset 16 + count)
  - opcode at header offset 0, value_id at 8, operands at 16/24
  - STORE extended fields (address@72, value@80, offset@88) and the
    operand-role duplication into header slots 1/2
  - LOAD extended fields (address@80, offset@88) and operand1 duplication
  - BRANCH/JUMP block-ID targets in the extended region (80/88 and 72)
  - RETURN value duplication (ext 72 and header operand1)
  - add_cfg_edge id-list wiring + cached pred/succ counts +
    get_block_by_id_from_cfg resolution
  - entry/exit block slots
  - register_value_definition / lookup_defining_instruction round trip
  - get_instruction_used_values operand collection
  - OD-6 clone_instruction (sized copy, detached parent)
  - is_terminator / is_terminator_opcode dispatch

Conventions: canonical tests/test_utils.runa harness; PASS = the
"ALL TESTS PASSED" summary plus exit 0; the process exit code is the
failed-assertion count.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/middle/gungnir/mir/mir.runa" as MIR
Import "compiler/middle/gungnir/mir/mir_nodes.runa" as MIRNodes
Import "compiler/middle/gungnir/mir/cfg.runa" as MirCFG
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List

@Reasoning
Builds the probe function described in the file header using ONLY the
canonical creators (MIR.create_mir_function, MIR.create_mir_basic_block,
MIRNodes.create_mir_*) and canonical wiring (MIR.add_block_to_cfg,
MIR.set_cfg_entry_block / set_cfg_exit_block, MIR.add_cfg_edge,
MirCFG.add_instruction_to_block). Instruction and block pointers needed by
the assertions are written into the caller-provided out buffer:
  0  b0    8  b1    16  b2    24  add    32  store    40  load
  48 branch    56 jump    64 ret    72 const1
Returns the MIRFunction pointer, or 0 on any construction failure.
@End Reasoning

Process called "build_layout_probe" that takes out_slots as Integer returns Integer:
    Let func be proc create_mir_function from MIR with "layout_probe_fn", 0, 0
    If func is equal to 0:
        Return 0
    End If

    Let cfg be proc get_mir_function_cfg from MIR with func
    If cfg is equal to 0:
        Return 0
    End If

    Note: Three blocks with canonically allocated ids (0, 1, 2)
    Let id0 be proc allocate_block_id from MIR with cfg
    Let b0 be proc create_mir_basic_block from MIR with id0, 0
    Let id1 be proc allocate_block_id from MIR with cfg
    Let b1 be proc create_mir_basic_block from MIR with id1, 0
    Let id2 be proc allocate_block_id from MIR with cfg
    Let b2 be proc create_mir_basic_block from MIR with id2, 0
    If b0 is equal to 0 or b1 is equal to 0 or b2 is equal to 0:
        Return 0
    End If

    proc add_block_to_cfg from MIR with cfg, b0
    proc add_block_to_cfg from MIR with cfg, b1
    proc add_block_to_cfg from MIR with cfg, b2
    proc set_cfg_entry_block from MIR with cfg, b0
    proc set_cfg_exit_block from MIR with cfg, b2

    proc memory_set_int64 from Layout with out_slots, 0, b0
    proc memory_set_int64 from Layout with out_slots, 8, b1
    proc memory_set_int64 from Layout with out_slots, 16, b2

    Note: v1 = CONST 7, v2 = CONST 5 (numeric, no string payload)
    Let const1 be proc create_mir_const from MIRNodes with 1, 7, 0, 0, 0
    proc add_instruction_to_block from MirCFG with b0, const1
    proc memory_set_int64 from Layout with out_slots, 72, const1
    Let const2 be proc create_mir_const from MIRNodes with 2, 5, 0, 0, 0
    proc add_instruction_to_block from MirCFG with b0, const2

    Note: v3 = ADD v1, v2
    Let add_inst be proc create_mir_binary_op from MIRNodes with 20002, 3, 1, 2, 0
    proc add_instruction_to_block from MirCFG with b0, add_inst
    proc memory_set_int64 from Layout with out_slots, 24, add_inst

    Note: v4 = ALLOCA (scalar slot, alignment 8)
    Let alloca_inst be proc create_mir_alloca from MIRNodes with 4, 0, 0, 8
    proc add_instruction_to_block from MirCFG with b0, alloca_inst

    Note: STORE *(v4 + 16) = v3 (non-volatile)
    Let store_inst be proc create_mir_store from MIRNodes with 4, 3, 16, 0, 0
    proc add_instruction_to_block from MirCFG with b0, store_inst
    proc memory_set_int64 from Layout with out_slots, 32, store_inst

    Note: v5 = LOAD *(v4 + 16) (non-volatile)
    Let load_inst be proc create_mir_load from MIRNodes with 5, 4, 16, 0, 0
    proc add_instruction_to_block from MirCFG with b0, load_inst
    proc memory_set_int64 from Layout with out_slots, 40, load_inst

    Note: v6 = LT v5, v2
    Let cmp_inst be proc create_mir_binary_op from MIRNodes with 20102, 6, 5, 2, 0
    proc add_instruction_to_block from MirCFG with b0, cmp_inst

    Note: BRANCH v6 ? b1 : b2 (block IDs, weights 50/50)
    Let branch_inst be proc create_mir_branch from MIRNodes with 6, id1, id2, 50, 50
    proc add_instruction_to_block from MirCFG with b0, branch_inst
    proc memory_set_int64 from Layout with out_slots, 48, branch_inst

    Note: b1: JUMP b2
    Let jump_inst be proc create_mir_jump from MIRNodes with id2
    proc add_instruction_to_block from MirCFG with b1, jump_inst
    proc memory_set_int64 from Layout with out_slots, 56, jump_inst

    Note: b2: RETURN v5
    Let ret_inst be proc create_mir_return from MIRNodes with 5, 0
    proc add_instruction_to_block from MirCFG with b2, ret_inst
    proc memory_set_int64 from Layout with out_slots, 64, ret_inst

    Note: CFG edges through the canonical id-keyed wiring
    proc add_cfg_edge from MIR with cfg, id0, id1
    proc add_cfg_edge from MIR with cfg, id0, id2
    proc add_cfg_edge from MIR with cfg, id1, id2

    Note: Register the SSA definitions the lookup assertions exercise
    proc register_value_definition from MIR with func, 1, const1
    proc register_value_definition from MIR with func, 2, const2
    proc register_value_definition from MIR with func, 3, add_inst
    proc register_value_definition from MIR with func, 4, alloca_inst
    proc register_value_definition from MIR with func, 5, load_inst
    proc register_value_definition from MIR with func, 6, cmp_inst

    Return func
End Process

Process called "main" returns Integer:
    Let results be proc create_test_results from T
    proc begin_suite from T with results, "mir_layout_probe (Wave 1 gate)"

    Note: Out buffer: b0/b1/b2, add, store, load, branch, jump, ret, const1
    Let out_slots be proc allocate from Layout with 80
    Let zi be 0
    While zi is less than 80:
        proc memory_set_int64 from Layout with out_slots, zi, 0
        Set zi to zi plus 8
    End While

    Let func be build_layout_probe(out_slots)
    proc assert_not_null from T with results, "probe MIR function built", func

    Let b0 be proc memory_get_int64 from Layout with out_slots, 0
    Let b1 be proc memory_get_int64 from Layout with out_slots, 8
    Let b2 be proc memory_get_int64 from Layout with out_slots, 16
    Let add_inst be proc memory_get_int64 from Layout with out_slots, 24
    Let store_inst be proc memory_get_int64 from Layout with out_slots, 32
    Let load_inst be proc memory_get_int64 from Layout with out_slots, 40
    Let branch_inst be proc memory_get_int64 from Layout with out_slots, 48
    Let jump_inst be proc memory_get_int64 from Layout with out_slots, 56
    Let ret_inst be proc memory_get_int64 from Layout with out_slots, 64
    Let const1 be proc memory_get_int64 from Layout with out_slots, 72

    Note: --- function -> cfg walk (canonical slot at offset 8) ---
    Let cfg be proc get_mir_function_cfg from MIR with func
    proc assert_not_null from T with results, "get_mir_function_cfg returns the CFG", cfg
    Let raw_cfg be proc memory_get_int64 from Layout with func, 8
    proc assert_equal from T with results, "cfg accessor matches MIRFunction offset 8", cfg, raw_cfg

    Note: MIRFunction offset 0 is the NAME pointer, never an id (OD-4)
    Let func_name be proc memory_get_int64 from Layout with func, 0
    proc assert_not_null from T with results, "MIRFunction offset 0 holds the name pointer", func_name

    Note: --- cfg -> blocks walk (blocks List at 16, cached count at 24) ---
    Let blocks be proc get_mir_cfg_blocks from MirCFG with cfg
    proc assert_not_null from T with results, "get_mir_cfg_blocks returns the block list", blocks
    Let block_total be proc length from List with blocks
    proc assert_equal from T with results, "three blocks registered", block_total, 3
    Let cached_block_count be proc memory_get_int64 from Layout with cfg, 24
    proc assert_equal from T with results, "cfg cached block_count is 3", cached_block_count, 3

    Note: --- entry / exit slots ---
    Let entry be proc get_cfg_entry_block from MIR with cfg
    proc assert_equal from T with results, "entry block is b0", entry, b0
    Let exit_blk be proc get_cfg_exit_block from MIR with cfg
    proc assert_equal from T with results, "exit block is b2", exit_blk, b2

    Note: --- block ids ---
    Let b0_id be proc get_mir_basic_block_id from MirCFG with b0
    proc assert_equal from T with results, "b0 id is 0", b0_id, 0
    Let b1_id be proc get_mir_basic_block_id from MirCFG with b1
    proc assert_equal from T with results, "b1 id is 1", b1_id, 1
    Let b2_id be proc get_mir_basic_block_id from MirCFG with b2
    proc assert_equal from T with results, "b2 id is 2", b2_id, 2

    Note: --- block -> instructions walk (List at 16, count cache at 24) ---
    Let b0_insts be proc get_block_instructions from MIR with b0
    proc assert_not_null from T with results, "b0 instruction list present", b0_insts
    Let b0_len be proc length from List with b0_insts
    proc assert_equal from T with results, "b0 holds 8 instructions", b0_len, 8
    Let b0_count_cache be proc get_block_instruction_count from MIR with b0
    proc assert_equal from T with results, "b0 cached instruction_count is 8", b0_count_cache, 8
    Let b1_insts be proc get_block_instructions from MIR with b1
    Let b1_len be proc length from List with b1_insts
    proc assert_equal from T with results, "b1 holds 1 instruction", b1_len, 1
    Let b2_insts be proc get_block_instructions from MIR with b2
    Let b2_len be proc length from List with b2_insts
    proc assert_equal from T with results, "b2 holds 1 instruction", b2_len, 1

    Note: --- CONST: opcode at 0, value_id at 8, payload at ext 80 ---
    Let c1_opcode be proc get_mir_node_opcode from MIR with const1
    proc assert_equal from T with results, "const opcode is 20001", c1_opcode, 20001
    Let c1_result be proc get_mir_node_value_id from MIR with const1
    proc assert_equal from T with results, "const result id is 1", c1_result, 1
    Let c1_value be proc get_const_value from MIRNodes with const1
    proc assert_equal from T with results, "const payload is 7 (ext offset 80)", c1_value, 7

    Note: --- ADD: opcode / value_id / operand reads ---
    Let add_opcode be proc get_mir_node_opcode from MIR with add_inst
    proc assert_equal from T with results, "add opcode is 20002", add_opcode, 20002
    Let add_result be proc get_mir_node_value_id from MIR with add_inst
    proc assert_equal from T with results, "add result id is 3", add_result, 3
    Let add_op1 be proc get_mir_node_operand from MIR with add_inst, 1
    proc assert_equal from T with results, "add operand1 is v1", add_op1, 1
    Let add_op2 be proc get_mir_node_operand from MIR with add_inst, 2
    proc assert_equal from T with results, "add operand2 is v2", add_op2, 2

    Note: --- STORE: ext fields 72/80/88 + operand-role duplication ---
    Let store_opcode be proc get_mir_node_opcode from MIR with store_inst
    proc assert_equal from T with results, "store opcode is 20201", store_opcode, 20201
    Let store_result be proc get_mir_node_value_id from MIR with store_inst
    proc assert_equal from T with results, "store produces no value", store_result, 0
    Let store_addr_ext be proc get_store_address from MIRNodes with store_inst
    proc assert_equal from T with results, "store address ext (72) is v4", store_addr_ext, 4
    Let store_value_ext be proc get_store_value from MIRNodes with store_inst
    proc assert_equal from T with results, "store value ext (80) is v3", store_value_ext, 3
    Let store_offset_ext be proc get_store_offset from MIRNodes with store_inst
    proc assert_equal from T with results, "store offset ext (88) is 16", store_offset_ext, 16
    Let store_op1 be proc get_mir_node_operand from MIR with store_inst, 1
    proc assert_equal from T with results, "store header operand1 is the address", store_op1, 4
    Let store_op2 be proc get_mir_node_operand from MIR with store_inst, 2
    proc assert_equal from T with results, "store header operand2 is the value", store_op2, 3

    Note: --- LOAD: ext fields 80/88 + operand-role duplication ---
    Let load_opcode be proc get_mir_node_opcode from MIR with load_inst
    proc assert_equal from T with results, "load opcode is 20200", load_opcode, 20200
    Let load_result be proc get_mir_node_value_id from MIR with load_inst
    proc assert_equal from T with results, "load result id is 5", load_result, 5
    Let load_addr_ext be proc get_load_address from MIRNodes with load_inst
    proc assert_equal from T with results, "load address ext (80) is v4", load_addr_ext, 4
    Let load_offset_ext be proc get_load_offset from MIRNodes with load_inst
    proc assert_equal from T with results, "load offset ext (88) is 16", load_offset_ext, 16
    Let load_op1 be proc get_mir_node_operand from MIR with load_inst, 1
    proc assert_equal from T with results, "load header operand1 is the address", load_op1, 4

    Note: --- BRANCH: condition use + block-ID targets in ext region ---
    Let branch_opcode be proc get_mir_node_opcode from MIR with branch_inst
    proc assert_equal from T with results, "branch opcode is 20301", branch_opcode, 20301
    Let branch_cond be proc get_mir_node_operand from MIR with branch_inst, 1
    proc assert_equal from T with results, "branch condition operand is v6", branch_cond, 6
    Let branch_true be proc get_branch_true_target from MIRNodes with branch_inst
    proc assert_equal from T with results, "branch true target is b1 id", branch_true, 1
    Let branch_false be proc get_branch_false_target from MIRNodes with branch_inst
    proc assert_equal from T with results, "branch false target is b2 id", branch_false, 2

    Note: --- JUMP / RETURN ---
    Let jump_target be proc get_jump_target from MIRNodes with jump_inst
    proc assert_equal from T with results, "jump target is b2 id (ext 72)", jump_target, 2
    Let ret_value be proc get_return_value from MIRNodes with ret_inst
    proc assert_equal from T with results, "return value ext (72) is v5", ret_value, 5
    Let ret_op1 be proc get_mir_node_operand from MIR with ret_inst, 1
    proc assert_equal from T with results, "return header operand1 is v5", ret_op1, 5

    Note: --- terminator dispatch ---
    Let branch_is_term be proc is_terminator from MIR with branch_inst
    proc assert_equal from T with results, "branch is a terminator (pointer form)", branch_is_term, 1
    Let const_is_term be proc is_terminator from MIR with const1
    proc assert_equal from T with results, "const is not a terminator", const_is_term, 0
    Let opcode_term be proc is_terminator_opcode from MIR with 20302
    proc assert_equal from T with results, "20302 is a terminator opcode", opcode_term, 1
    Let opcode_not_term be proc is_terminator_opcode from MIR with 20002
    proc assert_equal from T with results, "20002 is not a terminator opcode", opcode_not_term, 0

    Note: --- edge wiring: id lists + cached counts + id resolution ---
    Let b0_succs be proc get_block_successors from MIR with b0
    proc assert_not_null from T with results, "b0 successor list present", b0_succs
    Let b0_succ_len be proc length from List with b0_succs
    proc assert_equal from T with results, "b0 has 2 successors", b0_succ_len, 2
    Let b0_succ0 be proc list_get from List with b0_succs, 0
    proc assert_equal from T with results, "b0 successor 0 is b1 id", b0_succ0, 1
    Let b0_succ1 be proc list_get from List with b0_succs, 1
    proc assert_equal from T with results, "b0 successor 1 is b2 id", b0_succ1, 2
    Let b0_succ_count be proc get_block_successor_count from MIR with b0
    proc assert_equal from T with results, "b0 cached successor_count is 2", b0_succ_count, 2

    Let b2_preds be proc get_block_predecessors from MIR with b2
    proc assert_not_null from T with results, "b2 predecessor list present", b2_preds
    Let b2_pred_len be proc length from List with b2_preds
    proc assert_equal from T with results, "b2 has 2 predecessors", b2_pred_len, 2
    Let b2_pred_count be proc get_block_predecessor_count from MIR with b2
    proc assert_equal from T with results, "b2 cached predecessor_count is 2", b2_pred_count, 2

    Let resolved_b1 be proc get_block_by_id_from_cfg from MirCFG with cfg, 1
    proc assert_equal from T with results, "id 1 resolves to b1", resolved_b1, b1
    Let resolved_b2 be proc get_block_by_id_from_cfg from MirCFG with cfg, 2
    proc assert_equal from T with results, "id 2 resolves to b2", resolved_b2, b2

    Note: --- definition map round trip ---
    Let def_v3 be proc lookup_defining_instruction from MIR with func, 3
    proc assert_equal from T with results, "v3 definition is the add", def_v3, add_inst
    Let def_v5 be proc lookup_defining_instruction from MIR with func, 5
    proc assert_equal from T with results, "v5 definition is the load", def_v5, load_inst

    Note: --- used-value collection (store uses address + value) ---
    Let store_uses be proc get_instruction_used_values from MirCFG with store_inst
    proc assert_not_null from T with results, "store used-value list present", store_uses
    Let store_use_len be proc length from List with store_uses
    proc assert_equal from T with results, "store uses exactly 2 values", store_use_len, 2
    Let store_use0 be proc list_get from List with store_uses, 0
    proc assert_equal from T with results, "store use 0 is the address v4", store_use0, 4
    Let store_use1 be proc list_get from List with store_uses, 1
    proc assert_equal from T with results, "store use 1 is the value v3", store_use1, 3
    proc list_destroy from List with store_uses

    Note: --- OD-6 clone: sized copy, detached, payload intact ---
    Let store_clone be proc clone_instruction from MIR with store_inst
    proc assert_not_null from T with results, "store clone allocated", store_clone
    proc assert_not_equal from T with results, "clone is a fresh record", store_clone, store_inst
    Let clone_opcode be proc get_mir_node_opcode from MIR with store_clone
    proc assert_equal from T with results, "clone opcode is 20201", clone_opcode, 20201
    Let clone_addr be proc get_store_address from MIRNodes with store_clone
    proc assert_equal from T with results, "clone address ext is v4", clone_addr, 4
    Let clone_value be proc get_store_value from MIRNodes with store_clone
    proc assert_equal from T with results, "clone value ext is v3", clone_value, 3
    Let clone_offset be proc get_store_offset from MIRNodes with store_clone
    proc assert_equal from T with results, "clone offset ext is 16", clone_offset, 16
    Let clone_parent be proc get_mir_node_parent_block from MIR with store_clone
    proc assert_equal from T with results, "clone parent_block detached", clone_parent, 0

    proc print_summary from T with results

    Let failed be proc get_failed from T with results
    proc destroy_test_results from T with results
    Return failed
End Process
