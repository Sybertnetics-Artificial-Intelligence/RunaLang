Note:
Date primitive KAT.

Coverage:
- Gregorian leap-year rule: 1900 (false), 2000 (true), 2100 (false),
  2400 (true), 2024 (true), 2023 (false).
- date_days_in_month boundaries.
- days_from_civil / civil_from_days round-trip on representative
  dates (epoch, century boundaries, AD 1, BC 1).
- ISO weekday: 1970-01-01 = Thursday (4), 2000-01-01 = Saturday (6),
  2024-01-01 = Monday (1).
- date_day_of_year on a leap year (Feb 29) and a non-leap year.
- date_add_days / diff_days symmetry.
- date_add_months clamping: 2024-01-31 + 1 month = 2024-02-29.
- date_add_years clamping: 2024-02-29 + 1 year = 2025-02-28.
- ISO 8601 formatting "YYYY-MM-DD".
- ISO 8601 parsing round-trip.

Exit code legend:
  0   All assertions passed.
  40  Leap-year rule wrong on 1900.
  41  Leap-year rule wrong on 2000.
  42  Leap-year rule wrong on 2100.
  43  Leap-year rule wrong on 2400.
  44  date_days_in_month wrong.
  45  days_from_civil round-trip failed on epoch.
  46  days_from_civil round-trip failed on AD 1.
  47  Weekday wrong on 1970-01-01.
  48  Weekday wrong on 2000-01-01.
  49  Weekday wrong on 2024-01-01.
  50  Day-of-year wrong on 2024-02-29.
  51  Day-of-year wrong on 2023-12-31.
  52  date_add_days asymmetric with date_diff_days.
  53  date_add_months end-of-month clamp failed.
  54  date_add_years Feb-29 clamp failed.
  55  date_to_iso_8601 wrong length or content.
  56  date_parse_iso_8601 round-trip failed.
:End Note

Import "compiler/frontend/primitives/time/date.runa" as DateModule
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore

Process called "main" returns Integer:
    Note: ----- Case 40-43: Leap-year rule -----
    Let leap_1900 be proc date_is_leap_year from DateModule with 1900
    If leap_1900 is not equal to 0:
        Return 40
    End If
    Let leap_2000 be proc date_is_leap_year from DateModule with 2000
    If leap_2000 is not equal to 1:
        Return 41
    End If
    Let leap_2100 be proc date_is_leap_year from DateModule with 2100
    If leap_2100 is not equal to 0:
        Return 42
    End If
    Let leap_2400 be proc date_is_leap_year from DateModule with 2400
    If leap_2400 is not equal to 1:
        Return 43
    End If

    Note: ----- Case 44: days_in_month -----
    Let dim_feb_leap be proc date_days_in_month from DateModule with 2024, 2
    If dim_feb_leap is not equal to 29:
        Return 44
    End If
    Let dim_feb_norm be proc date_days_in_month from DateModule with 2023, 2
    If dim_feb_norm is not equal to 28:
        Return 44
    End If
    Let dim_jan be proc date_days_in_month from DateModule with 2024, 1
    If dim_jan is not equal to 31:
        Return 44
    End If
    Let dim_apr be proc date_days_in_month from DateModule with 2024, 4
    If dim_apr is not equal to 30:
        Return 44
    End If

    Note: ----- Case 45: round-trip on epoch (1970-01-01) -----
    Let z_epoch be proc days_from_civil from DateModule with 1970, 1, 1
    If z_epoch is not equal to 0:
        Return 45
    End If
    Let buf24 be proc allocate from Layout with 24
    If buf24 is equal to 0:
        Return 45
    End If
    Let rc_civ be proc civil_from_days from DateModule with 0, buf24
    Let y_back be proc memory_get_int64 from MemoryCore with buf24, 0
    Let m_back be proc memory_get_int64 from MemoryCore with buf24, 8
    Let d_back be proc memory_get_int64 from MemoryCore with buf24, 16
    If y_back is not equal to 1970:
        Return 45
    End If
    If m_back is not equal to 1:
        Return 45
    End If
    If d_back is not equal to 1:
        Return 45
    End If

    Note: ----- Case 46: round-trip on AD 1 (year 1) -----
    Let z_ad1 be proc days_from_civil from DateModule with 1, 1, 1
    Let rc_civ2 be proc civil_from_days from DateModule with z_ad1, buf24
    Let y2 be proc memory_get_int64 from MemoryCore with buf24, 0
    Let m2 be proc memory_get_int64 from MemoryCore with buf24, 8
    Let d2 be proc memory_get_int64 from MemoryCore with buf24, 16
    If y2 is not equal to 1:
        Return 46
    End If
    If m2 is not equal to 1:
        Return 46
    End If
    If d2 is not equal to 1:
        Return 46
    End If

    Note: ----- Case 47: weekday on 1970-01-01 (Thursday = 4) -----
    Let wd_1970 be proc date_day_of_week from DateModule with 1970, 1, 1
    If wd_1970 is not equal to 4:
        Return 47
    End If

    Note: ----- Case 48: weekday on 2000-01-01 (Saturday = 6) -----
    Let wd_2000 be proc date_day_of_week from DateModule with 2000, 1, 1
    If wd_2000 is not equal to 6:
        Return 48
    End If

    Note: ----- Case 49: weekday on 2024-01-01 (Monday = 1) -----
    Let wd_2024 be proc date_day_of_week from DateModule with 2024, 1, 1
    If wd_2024 is not equal to 1:
        Return 49
    End If

    Note: ----- Case 50: day-of-year for 2024-02-29 = day 60 -----
    Let doy_feb29 be proc date_day_of_year from DateModule with 2024, 2, 29
    If doy_feb29 is not equal to 60:
        Return 50
    End If

    Note: ----- Case 51: day-of-year for 2023-12-31 = day 365 -----
    Let doy_dec31 be proc date_day_of_year from DateModule with 2023, 12, 31
    If doy_dec31 is not equal to 365:
        Return 51
    End If
    Let doy_leap_dec31 be proc date_day_of_year from DateModule with 2024, 12, 31
    If doy_leap_dec31 is not equal to 366:
        Return 51
    End If

    Note: ----- Case 52: add_days / diff_days symmetry -----
    Let d_a be proc date_create from DateModule with 2024, 6, 1
    If d_a is less than 0:
        Return 52
    End If
    Let d_b be proc date_add_days from DateModule with d_a, 100
    If d_b is less than 0:
        Return 52
    End If
    Let diff_back be proc date_diff_days from DateModule with d_b, d_a
    If diff_back is not equal to 100:
        Return 52
    End If

    Note: ----- Case 53: add_months clamp 2024-01-31 + 1 month -----
    Let d_jan31 be proc date_create from DateModule with 2024, 1, 31
    Let d_after be proc date_add_months from DateModule with d_jan31, 1
    Let y_after be proc date_get_year from DateModule with d_after
    Let m_after be proc date_get_month from DateModule with d_after
    Let d_after_day be proc date_get_day from DateModule with d_after
    If y_after is not equal to 2024:
        Return 53
    End If
    If m_after is not equal to 2:
        Return 53
    End If
    If d_after_day is not equal to 29:
        Return 53
    End If

    Note: ----- Case 54: add_years clamp 2024-02-29 + 1 year = 2025-02-28 -----
    Let d_feb29 be proc date_create from DateModule with 2024, 2, 29
    Let d_year_after be proc date_add_years from DateModule with d_feb29, 1
    Let y_y be proc date_get_year from DateModule with d_year_after
    Let m_y be proc date_get_month from DateModule with d_year_after
    Let d_y be proc date_get_day from DateModule with d_year_after
    If y_y is not equal to 2025:
        Return 54
    End If
    If m_y is not equal to 2:
        Return 54
    End If
    If d_y is not equal to 28:
        Return 54
    End If

    Note: ----- Case 55: ISO formatting of 2026-06-03 -----
    Let d_test be proc date_create from DateModule with 2026, 6, 3
    Let out_buf be proc allocate from Layout with 16
    If out_buf is equal to 0:
        Return 55
    End If
    Let written be proc date_to_iso_8601 from DateModule with d_test, out_buf, 16
    If written is not equal to 10:
        Return 55
    End If
    Let cv0 be proc memory_get_int8 from MemoryCore with out_buf, 0
    Let cv1 be proc memory_get_int8 from MemoryCore with out_buf, 1
    Let cv2 be proc memory_get_int8 from MemoryCore with out_buf, 2
    Let cv3 be proc memory_get_int8 from MemoryCore with out_buf, 3
    Let cv4 be proc memory_get_int8 from MemoryCore with out_buf, 4
    Let cv5 be proc memory_get_int8 from MemoryCore with out_buf, 5
    Let cv6 be proc memory_get_int8 from MemoryCore with out_buf, 6
    Let cv7 be proc memory_get_int8 from MemoryCore with out_buf, 7
    Let cv8 be proc memory_get_int8 from MemoryCore with out_buf, 8
    Let cv9 be proc memory_get_int8 from MemoryCore with out_buf, 9
    Note: "2026-06-03"
    If cv0 is not equal to 50:
        Return 55
    End If
    If cv1 is not equal to 48:
        Return 55
    End If
    If cv2 is not equal to 50:
        Return 55
    End If
    If cv3 is not equal to 54:
        Return 55
    End If
    If cv4 is not equal to 45:
        Return 55
    End If
    If cv5 is not equal to 48:
        Return 55
    End If
    If cv6 is not equal to 54:
        Return 55
    End If
    If cv7 is not equal to 45:
        Return 55
    End If
    If cv8 is not equal to 48:
        Return 55
    End If
    If cv9 is not equal to 51:
        Return 55
    End If

    Note: ----- Case 56: ISO parse round-trip -----
    Let parsed be proc date_parse_iso_8601 from DateModule with out_buf
    If parsed is less than 0:
        Return 56
    End If
    Let y_p be proc date_get_year from DateModule with parsed
    Let m_p be proc date_get_month from DateModule with parsed
    Let d_p be proc date_get_day from DateModule with parsed
    If y_p is not equal to 2026:
        Return 56
    End If
    If m_p is not equal to 6:
        Return 56
    End If
    If d_p is not equal to 3:
        Return 56
    End If

    Return 0
End Process
