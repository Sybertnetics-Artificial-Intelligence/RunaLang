Note:
DateTime primitive KAT.

Coverage:
- datetime_from_unix_epoch_seconds at epoch returns 1970-01-01 00:00:00 UTC.
- datetime_from_components reverse: 2024-03-10 13:30:00 UTC -> 1710077400.
- Unix epoch -> nanoseconds round-trip with sub-second precision.
- datetime_add_duration: epoch + 1 hour = epoch_seconds + 3600.
- datetime_compare returns -1 / 0 / +1.
- datetime_in_scale: UTC -> TAI adds 37 leap seconds in 2024.

Exit code legend:
  0   All assertions passed.
  70  datetime_from_unix_epoch_seconds(0) accessors wrong.
  71  datetime_from_components round-trip failed.
  72  datetime_to_unix_epoch_nanos round-trip with sub-second failed.
  73  datetime_add_duration wrong result.
  74  datetime_compare wrong sign.
  75  datetime_in_scale UTC -> TAI for 2024 didn't add 37 leap seconds.
:End Note

Import "compiler/frontend/primitives/time/datetime.runa" as DT
Import "compiler/frontend/primitives/time/duration.runa" as Duration
Import "compiler/frontend/primitives/time/time_reference.runa" as TimeRef

Process called "main" returns Integer:
    Note: ----- Case 70: epoch -----
    Let dt_epoch be proc datetime_from_unix_epoch_seconds from DT with 0
    If dt_epoch is less than 0:
        Return 70
    End If
    Let y_e be proc datetime_get_year from DT with dt_epoch
    Let m_e be proc datetime_get_month from DT with dt_epoch
    Let d_e be proc datetime_get_day from DT with dt_epoch
    Let h_e be proc datetime_get_hour from DT with dt_epoch
    If y_e is not equal to 1970:
        Return 70
    End If
    If m_e is not equal to 1:
        Return 70
    End If
    If d_e is not equal to 1:
        Return 70
    End If
    If h_e is not equal to 0:
        Return 70
    End If

    Note: ----- Case 71: 2024-03-10 13:30:00 UTC = 1_710_077_400 -----
    Let dt_known be proc datetime_from_components from DT with 2024, 3, 10, 13, 30, 0, 0, 0
    If dt_known is less than 0:
        Return 71
    End If
    Let unix_known be proc datetime_to_unix_epoch_seconds from DT with dt_known
    If unix_known is not equal to 1710077400:
        Return 71
    End If

    Note: ----- Case 72: nanosecond precision round-trip -----
    Let dt_ns be proc datetime_from_unix_epoch_nanos from DT with 1710077400000000123
    Let ns_back be proc datetime_to_unix_epoch_nanos from DT with dt_ns
    If ns_back is not equal to 1710077400000000123:
        Return 72
    End If

    Note: ----- Case 73: add Duration(1 hour) -----
    Let dur_hr be proc duration_from_hours from Duration with 1
    Let dt_plus_hr be proc datetime_add_duration from DT with dt_known, dur_hr
    Let unix_after be proc datetime_to_unix_epoch_seconds from DT with dt_plus_hr
    If unix_after is not equal to 1710081000:
        Return 73
    End If

    Note: ----- Case 74: compare -----
    Let cmp1 be proc datetime_compare from DT with dt_known, dt_plus_hr
    If cmp1 is not equal to -1:
        Return 74
    End If
    Let cmp2 be proc datetime_compare from DT with dt_plus_hr, dt_known
    If cmp2 is not equal to 1:
        Return 74
    End If
    Let cmp3 be proc datetime_compare from DT with dt_known, dt_known
    If cmp3 is not equal to 0:
        Return 74
    End If

    Note: ----- Case 75: in_scale UTC -> TAI in 2024 -----
    Let tai_ref be proc TIME_REF_TAI from TimeRef
    Let dt_tai be proc datetime_in_scale from DT with dt_known, tai_ref
    If dt_tai is less than 0:
        Return 75
    End If
    Let s_tai be proc datetime_to_unix_epoch_seconds from DT with dt_tai
    Note: As of 2024, TAI - UTC = 37 s.
    If s_tai is not equal to 1710077437:
        Return 75
    End If

    Return 0
End Process
