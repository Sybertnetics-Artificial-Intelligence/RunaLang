Note:
TimeReference primitive KAT.

Coverage:
- Leap-second table lookups at GPS epoch and at 2024.
- TAI = UTC + leap_seconds(UTC).
- GPS = TAI - 19.
- GPS epoch 1980-01-06 00:00:00 UTC = TAI - 19 s = 315964800 GPS-Unix
  seconds. With TAI - UTC = 19 at that instant we expect:
    tai_from_utc(315964800) = 315964819
    gps_from_tai(315964819) = 315964800
- Comparability matrix: UTC vs TAI is comparable; Monotonic vs UTC is not.

Exit code legend:
  0   All assertions passed.
  100 leap_seconds_at_unix_time wrong for 2024 (should be 37).
  101 leap_seconds_at_unix_time wrong for GPS epoch (should be 19).
  102 leap_seconds_at_unix_time wrong for pre-1972 (should be 10).
  103 tai_from_utc wrong at GPS epoch.
  104 gps_from_tai wrong at GPS epoch.
  105 utc_from_tai inverse of tai_from_utc failed.
  106 utc_from_gps inverse of gps_from_utc failed.
  107 Comparability matrix wrong.
:End Note

Import "compiler/frontend/primitives/time/time_reference.runa" as TimeRef

Process called "main" returns Integer:
    Note: ----- Case 100: 2024 -> 37 leap seconds -----
    Note: 2024-06-01 00:00:00 UTC = 1717200000.
    Let leap_2024 be proc leap_seconds_at_unix_time from TimeRef with 1717200000
    If leap_2024 is not equal to 37:
        Return 100
    End If

    Note: ----- Case 101: GPS epoch 1980-01-06 -> 19 leap seconds -----
    Let leap_gps be proc leap_seconds_at_unix_time from TimeRef with 315964800
    If leap_gps is not equal to 19:
        Return 101
    End If

    Note: ----- Case 102: pre-1972 -> 10 leap seconds (baseline) -----
    Let leap_1965 be proc leap_seconds_at_unix_time from TimeRef with -157766400
    If leap_1965 is not equal to 10:
        Return 102
    End If

    Note: ----- Case 103: tai_from_utc at GPS epoch -----
    Let tai_at_gps_epoch be proc tai_from_utc from TimeRef with 315964800
    If tai_at_gps_epoch is not equal to 315964819:
        Return 103
    End If

    Note: ----- Case 104: gps_from_tai -----
    Let gps_back be proc gps_from_tai from TimeRef with 315964819
    If gps_back is not equal to 315964800:
        Return 104
    End If

    Note: ----- Case 105: utc_from_tai inverse -----
    Let utc_back be proc utc_from_tai from TimeRef with tai_at_gps_epoch
    If utc_back is not equal to 315964800:
        Return 105
    End If

    Note: ----- Case 106: gps_from_utc / utc_from_gps -----
    Let gps_secs be proc gps_from_utc from TimeRef with 1717200000
    Let utc_via_gps be proc utc_from_gps from TimeRef with gps_secs
    If utc_via_gps is not equal to 1717200000:
        Return 106
    End If

    Note: ----- Case 107: Comparability matrix -----
    Let utc_ref be proc TIME_REF_UTC from TimeRef
    Let tai_ref be proc TIME_REF_TAI from TimeRef
    Let mono_ref be proc TIME_REF_MONOTONIC from TimeRef
    Let cmp_utc_tai be proc time_reference_is_comparable from TimeRef with utc_ref, tai_ref
    If cmp_utc_tai is not equal to 1:
        Return 107
    End If
    Let cmp_utc_mono be proc time_reference_is_comparable from TimeRef with utc_ref, mono_ref
    If cmp_utc_mono is not equal to 0:
        Return 107
    End If
    Let cmp_mono_mono be proc time_reference_is_comparable from TimeRef with mono_ref, mono_ref
    If cmp_mono_mono is not equal to 1:
        Return 107
    End If

    Return 0
End Process
