Note:
TimeSpan primitive KAT.

time_span.runa is a domain-friendly alias for duration.runa - every
proc is a thin re-export of its duration_* counterpart, and the bit
patterns of time_span values match those of duration values byte for
byte. This test exercises:

- Lifecycle: allocate / free returns a usable buffer.
- Construction from each supported unit (ns, us, ms, s, min, hr, day).
- Conversion symmetry: from_seconds(60) == from_minutes(1) under
  time_span_compare.
- Conversion to each smaller unit returns the correct truncated count.
- Arithmetic (add, sub, negate, abs, multiply_by_integer, divide_by_
  integer) produces values that match the duration_* equivalents.
- Comparison: three-way compare across negative, zero, positive values.
- Predicates: is_zero / is_negative / is_positive flip correctly.
- ISO 8601 formatting: zero -> "PT0S" and 3600s -> "PT1H".
- Cross-module parity: time_span_from_seconds(1) and
  duration_from_seconds(1) produce values that compare equal.

Exit code legend:
   0  All assertions passed.
  10  time_span_allocate returned NULL.
  11  time_span_free of NULL is not safe.
  20  time_span_from_seconds(1) -> to_nanoseconds wrong.
  21  time_span_from_milliseconds(2000) -> to_seconds wrong.
  22  time_span_from_minutes(1) != time_span_from_seconds(60).
  23  time_span_from_hours(1) != time_span_from_seconds(3600).
  24  time_span_from_days(1) -> to_seconds wrong.
  25  time_span_from_microseconds(2_500_000) -> to_milliseconds wrong.
  30  time_span_add(1s + 2s) != 3s.
  31  time_span_sub(5s - 3s) != 2s.
  32  time_span_negate(1s) != -1s.
  33  time_span_abs(-3s) != 3s.
  34  time_span_multiply_by_integer(3s, 7) != 21s.
  35  time_span_divide_by_integer(21s, 7) != 3s.
  40  ordering: negative < zero < positive failed.
  41  time_span_equals returned 0 for equal values.
  42  time_span_equals returned 1 for distinct values.
  50  is_zero / is_negative / is_positive predicate wrong.
  60  ISO 8601 formatting of zero TimeSpan != "PT0S".
  61  ISO 8601 formatting of 3600 s != "PT1H".
  70  cross-module parity: time_span and duration values diverge.
:End Note

Import "compiler/frontend/primitives/time/time_span.runa" as TS
Import "compiler/frontend/primitives/time/duration.runa" as Dur
Import "compiler/frontend/primitives/core/string_core.runa" as Str
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore

Process called "main" returns Integer:
    Note: ----- Case 10: allocate -----
    Let t_alloc be proc time_span_allocate from TS
    If t_alloc is equal to 0:
        Return 10
    End If
    proc time_span_free from TS with t_alloc

    Note: ----- Case 11: free NULL is safe -----
    Let free_null_rc be proc time_span_free from TS with 0
    Note: A NULL free must not crash; we don't constrain the return code
    Note: shape here since duration_free's contract is "no-op on 0".

    Note: ----- Case 20: from_seconds(1) -> 1_000_000_000 ns -----
    Let s1 be proc time_span_from_seconds from TS with 1
    If s1 is equal to 0:
        Return 20
    End If
    Let s1_ns be proc time_span_to_nanoseconds from TS with s1
    If s1_ns is not equal to 1000000000:
        Return 20
    End If

    Note: ----- Case 21: from_milliseconds(2000) -> to_seconds = 2 -----
    Let ms2k be proc time_span_from_milliseconds from TS with 2000
    Let ms2k_s be proc time_span_to_seconds from TS with ms2k
    If ms2k_s is not equal to 2:
        Return 21
    End If

    Note: ----- Case 22: from_minutes(1) == from_seconds(60) -----
    Let one_min be proc time_span_from_minutes from TS with 1
    Let sixty_sec be proc time_span_from_seconds from TS with 60
    Let cmp_22 be proc time_span_compare from TS with one_min, sixty_sec
    If cmp_22 is not equal to 0:
        Return 22
    End If

    Note: ----- Case 23: from_hours(1) == from_seconds(3600) -----
    Let one_hr be proc time_span_from_hours from TS with 1
    Let thirtysix_hundred_sec be proc time_span_from_seconds from TS with 3600
    Let cmp_23 be proc time_span_compare from TS with one_hr, thirtysix_hundred_sec
    If cmp_23 is not equal to 0:
        Return 23
    End If

    Note: ----- Case 24: from_days(1) -> 86400 s -----
    Let one_day be proc time_span_from_days from TS with 1
    Let one_day_s be proc time_span_to_seconds from TS with one_day
    If one_day_s is not equal to 86400:
        Return 24
    End If

    Note: ----- Case 25: from_microseconds(2_500_000) -> to_milliseconds = 2500 -----
    Let us2_5m be proc time_span_from_microseconds from TS with 2500000
    Let us_ms be proc time_span_to_seconds from TS with us2_5m
    If us_ms is not equal to 2:
        Return 25
    End If

    Note: ----- Case 30: addition -----
    Let two_s be proc time_span_from_seconds from TS with 2
    Let three_s be proc time_span_from_seconds from TS with 3
    Let add_buf be proc time_span_allocate from TS
    Let rc_add be proc time_span_add from TS with s1, two_s, add_buf
    If rc_add is not equal to 0:
        Return 30
    End If
    Let cmp_add be proc time_span_compare from TS with add_buf, three_s
    If cmp_add is not equal to 0:
        Return 30
    End If

    Note: ----- Case 31: subtraction -----
    Let five_s be proc time_span_from_seconds from TS with 5
    Let sub_buf be proc time_span_allocate from TS
    Let rc_sub be proc time_span_sub from TS with five_s, three_s, sub_buf
    If rc_sub is not equal to 0:
        Return 31
    End If
    Let cmp_sub be proc time_span_compare from TS with sub_buf, two_s
    If cmp_sub is not equal to 0:
        Return 31
    End If

    Note: ----- Case 32: negation -----
    Let neg_buf be proc time_span_allocate from TS
    Let rc_neg be proc time_span_negate from TS with s1, neg_buf
    If rc_neg is not equal to 0:
        Return 32
    End If
    Let minus_one_s be proc time_span_from_nanoseconds from TS with -1000000000
    Let cmp_neg be proc time_span_compare from TS with neg_buf, minus_one_s
    If cmp_neg is not equal to 0:
        Return 32
    End If

    Note: ----- Case 33: abs -----
    Let minus_three_s be proc time_span_from_nanoseconds from TS with -3000000000
    Let abs_buf be proc time_span_allocate from TS
    Let rc_abs be proc time_span_abs from TS with minus_three_s, abs_buf
    If rc_abs is not equal to 0:
        Return 33
    End If
    Let cmp_abs be proc time_span_compare from TS with abs_buf, three_s
    If cmp_abs is not equal to 0:
        Return 33
    End If

    Note: ----- Case 34: multiply_by_integer 3s * 7 = 21s -----
    Let mul_buf be proc time_span_allocate from TS
    Let rc_mul be proc time_span_multiply_by_integer from TS with three_s, 7, mul_buf
    If rc_mul is not equal to 0:
        Return 34
    End If
    Let twentyone_s be proc time_span_from_seconds from TS with 21
    Let cmp_mul be proc time_span_compare from TS with mul_buf, twentyone_s
    If cmp_mul is not equal to 0:
        Return 34
    End If

    Note: ----- Case 35: divide_by_integer 21s / 7 = 3s -----
    Let div_buf be proc time_span_allocate from TS
    Let rc_div be proc time_span_divide_by_integer from TS with twentyone_s, 7, div_buf
    If rc_div is not equal to 0:
        Return 35
    End If
    Let cmp_div be proc time_span_compare from TS with div_buf, three_s
    If cmp_div is not equal to 0:
        Return 35
    End If

    Note: ----- Case 40: ordering negative < zero < positive -----
    Let zero_ts be proc time_span_from_nanoseconds from TS with 0
    Let cmp_neg_zero be proc time_span_compare from TS with minus_three_s, zero_ts
    If cmp_neg_zero is not equal to -1:
        Return 40
    End If
    Let cmp_zero_pos be proc time_span_compare from TS with zero_ts, three_s
    If cmp_zero_pos is not equal to -1:
        Return 40
    End If
    Let cmp_pos_neg be proc time_span_compare from TS with three_s, minus_three_s
    If cmp_pos_neg is not equal to 1:
        Return 40
    End If

    Note: ----- Case 41: equals on equal values -----
    Let eq_same be proc time_span_equals from TS with one_min, sixty_sec
    If eq_same is not equal to 1:
        Return 41
    End If

    Note: ----- Case 42: equals on distinct values -----
    Let eq_diff be proc time_span_equals from TS with one_min, three_s
    If eq_diff is not equal to 0:
        Return 42
    End If

    Note: ----- Case 50: predicates -----
    Let pred_iz be proc time_span_is_zero from TS with zero_ts
    If pred_iz is not equal to 1:
        Return 50
    End If
    Let pred_neg be proc time_span_is_negative from TS with minus_three_s
    If pred_neg is not equal to 1:
        Return 50
    End If
    Let pred_pos be proc time_span_is_positive from TS with three_s
    If pred_pos is not equal to 1:
        Return 50
    End If
    Note: A zero value must not be positive or negative.
    Let pred_zero_pos be proc time_span_is_positive from TS with zero_ts
    If pred_zero_pos is not equal to 0:
        Return 50
    End If
    Let pred_zero_neg be proc time_span_is_negative from TS with zero_ts
    If pred_zero_neg is not equal to 0:
        Return 50
    End If

    Note: ----- Case 60: ISO 8601 of zero -> "PT0S" -----
    Let iso_buf be proc allocate from Layout with 32
    proc time_span_to_iso_8601 from TS with zero_ts, iso_buf, 32
    Let eq_zero_iso be proc string_equals from Str with iso_buf, "PT0S"
    If eq_zero_iso is not equal to 1:
        Return 60
    End If
    proc deallocate from Layout with iso_buf

    Note: ----- Case 61: ISO 8601 of 3600s -> "PT1H" -----
    Let iso_buf2 be proc allocate from Layout with 32
    proc time_span_to_iso_8601 from TS with thirtysix_hundred_sec, iso_buf2, 32
    Let eq_hr_iso be proc string_equals from Str with iso_buf2, "PT1H"
    If eq_hr_iso is not equal to 1:
        Return 61
    End If
    proc deallocate from Layout with iso_buf2

    Note: ----- Case 70: cross-module parity -----
    Note: time_span.runa is a re-export of duration.runa, so a
    Note: time_span value should compare equal to its duration twin
    Note: under either compare proc.
    Let dur_one_s be proc duration_from_seconds from Dur with 1
    Let cross_cmp be proc duration_compare from Dur with s1, dur_one_s
    If cross_cmp is not equal to 0:
        Return 70
    End If
    Let cross_cmp_ts be proc time_span_compare from TS with s1, dur_one_s
    If cross_cmp_ts is not equal to 0:
        Return 70
    End If

    Note: ============================================================================
    Note: Allen's Interval Algebra - 13 Base Relations
    Note: ============================================================================
    Note: Each case uses concrete Instant nanosecond values for clarity. Anchors
    Note: are 100, 200, 300, 400, 500 spaced widely enough that no two relations
    Note: collide on endpoint values.
    Note: ============================================================================

    Note: ----- Case 100: span_before -----
    Note: A = [100, 200), B = [300, 400) -> A.end (200) < B.start (300) -> before.
    Let a100 be proc time_span_create from TS with 100, 200
    Let b100 be proc time_span_create from TS with 300, 400
    Let r_before be proc span_before from TS with a100, b100
    If r_before is not equal to 1:
        Return 100
    End If
    Note: Negative case: not before in reverse.
    Let r_before_neg be proc span_before from TS with b100, a100
    If r_before_neg is not equal to 0:
        Return 100
    End If

    Note: ----- Case 101: span_meets -----
    Note: A = [100, 200), B = [200, 300) -> A.end == B.start -> meets.
    Let a101 be proc time_span_create from TS with 100, 200
    Let b101 be proc time_span_create from TS with 200, 300
    Let r_meets be proc span_meets from TS with a101, b101
    If r_meets is not equal to 1:
        Return 101
    End If

    Note: ----- Case 102: span_overlaps -----
    Note: A = [100, 250), B = [200, 400). A.start(100)<B.start(200), A.end(250)>B.start(200), A.end(250)<B.end(400) -> overlaps.
    Let a102 be proc time_span_create from TS with 100, 250
    Let b102 be proc time_span_create from TS with 200, 400
    Let r_overlaps be proc span_overlaps from TS with a102, b102
    If r_overlaps is not equal to 1:
        Return 102
    End If

    Note: ----- Case 103: span_finished_by -----
    Note: A = [100, 400), B = [200, 400). A.start(100)<B.start(200), A.end(400)==B.end(400) -> finished_by.
    Let a103 be proc time_span_create from TS with 100, 400
    Let b103 be proc time_span_create from TS with 200, 400
    Let r_fin_by be proc span_finished_by from TS with a103, b103
    If r_fin_by is not equal to 1:
        Return 103
    End If

    Note: ----- Case 104: span_contains -----
    Note: A = [100, 500), B = [200, 400). A.start<B.start, A.end>B.end -> contains.
    Let a104 be proc time_span_create from TS with 100, 500
    Let b104 be proc time_span_create from TS with 200, 400
    Let r_contains be proc span_contains from TS with a104, b104
    If r_contains is not equal to 1:
        Return 104
    End If

    Note: ----- Case 105: span_starts -----
    Note: A = [100, 200), B = [100, 400). Shared start, A is shorter.
    Let a105 be proc time_span_create from TS with 100, 200
    Let b105 be proc time_span_create from TS with 100, 400
    Let r_starts be proc span_starts from TS with a105, b105
    If r_starts is not equal to 1:
        Return 105
    End If

    Note: ----- Case 106: span_equals -----
    Note: A = [100, 200), B = [100, 200). Identical endpoints.
    Let a106 be proc time_span_create from TS with 100, 200
    Let b106 be proc time_span_create from TS with 100, 200
    Let r_seq be proc span_equals from TS with a106, b106
    If r_seq is not equal to 1:
        Return 106
    End If

    Note: ----- Case 107: span_started_by -----
    Note: A = [100, 400), B = [100, 200). Shared start, A is longer.
    Let a107 be proc time_span_create from TS with 100, 400
    Let b107 be proc time_span_create from TS with 100, 200
    Let r_st_by be proc span_started_by from TS with a107, b107
    If r_st_by is not equal to 1:
        Return 107
    End If

    Note: ----- Case 108: span_during -----
    Note: A = [200, 300), B = [100, 400). A strictly inside B.
    Let a108 be proc time_span_create from TS with 200, 300
    Let b108 be proc time_span_create from TS with 100, 400
    Let r_during be proc span_during from TS with a108, b108
    If r_during is not equal to 1:
        Return 108
    End If

    Note: ----- Case 109: span_finishes -----
    Note: A = [300, 400), B = [100, 400). Shared end, A shorter.
    Let a109 be proc time_span_create from TS with 300, 400
    Let b109 be proc time_span_create from TS with 100, 400
    Let r_finishes be proc span_finishes from TS with a109, b109
    If r_finishes is not equal to 1:
        Return 109
    End If

    Note: ----- Case 110: span_overlapped_by -----
    Note: A = [200, 400), B = [100, 300). A.start(200)>B.start(100), A.start(200)<B.end(300), A.end(400)>B.end(300) -> overlapped_by.
    Let a110 be proc time_span_create from TS with 200, 400
    Let b110 be proc time_span_create from TS with 100, 300
    Let r_ov_by be proc span_overlapped_by from TS with a110, b110
    If r_ov_by is not equal to 1:
        Return 110
    End If

    Note: ----- Case 111: span_met_by -----
    Note: A = [200, 300), B = [100, 200). B ends when A begins.
    Let a111 be proc time_span_create from TS with 200, 300
    Let b111 be proc time_span_create from TS with 100, 200
    Let r_met_by be proc span_met_by from TS with a111, b111
    If r_met_by is not equal to 1:
        Return 111
    End If

    Note: ----- Case 112: span_after -----
    Note: A = [300, 400), B = [100, 200). A.start(300)>B.end(200) -> after.
    Let a112 be proc time_span_create from TS with 300, 400
    Let b112 be proc time_span_create from TS with 100, 200
    Let r_after be proc span_after from TS with a112, b112
    If r_after is not equal to 1:
        Return 112
    End If

    Note: ----- Case 120: span_contains_instant - closed interval -----
    Note: Closed [100, 200]: 100 in, 150 in, 200 in, 99 out, 201 out.
    Let closed_span be proc time_span_create_closed from TS with 100, 200
    Let ci_100 be proc span_contains_instant from TS with closed_span, 100
    If ci_100 is not equal to 1:
        Return 120
    End If
    Let ci_150 be proc span_contains_instant from TS with closed_span, 150
    If ci_150 is not equal to 1:
        Return 120
    End If
    Let ci_200 be proc span_contains_instant from TS with closed_span, 200
    If ci_200 is not equal to 1:
        Return 120
    End If
    Let ci_99 be proc span_contains_instant from TS with closed_span, 99
    If ci_99 is not equal to 0:
        Return 120
    End If
    Let ci_201 be proc span_contains_instant from TS with closed_span, 201
    If ci_201 is not equal to 0:
        Return 120
    End If

    Note: ----- Case 121: span_contains_instant - half-open interval -----
    Note: Half-open [100, 200): 100 in, 200 OUT (right boundary excluded).
    Let ho_span be proc time_span_create from TS with 100, 200
    Let ho_100 be proc span_contains_instant from TS with ho_span, 100
    If ho_100 is not equal to 1:
        Return 121
    End If
    Let ho_200 be proc span_contains_instant from TS with ho_span, 200
    If ho_200 is not equal to 0:
        Return 121
    End If
    Let ho_199 be proc span_contains_instant from TS with ho_span, 199
    If ho_199 is not equal to 1:
        Return 121
    End If

    Note: ----- Case 122: span_contains_instant - open interval -----
    Note: Open (100, 200): both boundaries excluded.
    Let open_span be proc time_span_create_open from TS with 100, 200
    Let op_100 be proc span_contains_instant from TS with open_span, 100
    If op_100 is not equal to 0:
        Return 122
    End If
    Let op_200 be proc span_contains_instant from TS with open_span, 200
    If op_200 is not equal to 0:
        Return 122
    End If
    Let op_150 be proc span_contains_instant from TS with open_span, 150
    If op_150 is not equal to 1:
        Return 122
    End If

    Note: ----- Case 130: span_overlaps_any - overlapping pair -----
    Let oa_a be proc time_span_create from TS with 100, 300
    Let oa_b be proc time_span_create from TS with 200, 400
    Let oa_overlap be proc span_overlaps_any from TS with oa_a, oa_b
    If oa_overlap is not equal to 1:
        Return 130
    End If

    Note: ----- Case 131: span_overlaps_any - adjacent half-open (meets but not overlapping) -----
    Note: [100, 200) and [200, 300) share only the excluded boundary -> NOT overlapping.
    Let ad_a be proc time_span_create from TS with 100, 200
    Let ad_b be proc time_span_create from TS with 200, 300
    Let ad_overlap be proc span_overlaps_any from TS with ad_a, ad_b
    If ad_overlap is not equal to 0:
        Return 131
    End If

    Note: ----- Case 132: span_overlaps_any - disjoint -----
    Let dj_a be proc time_span_create from TS with 100, 200
    Let dj_b be proc time_span_create from TS with 300, 400
    Let dj_overlap be proc span_overlaps_any from TS with dj_a, dj_b
    If dj_overlap is not equal to 0:
        Return 132
    End If

    Note: ----- Case 140: span_intersect - overlapping -----
    Note: [100, 300) intersect [200, 400) = [200, 300).
    Let int_a be proc time_span_create from TS with 100, 300
    Let int_b be proc time_span_create from TS with 200, 400
    Let int_result be proc span_intersect from TS with int_a, int_b
    If int_result is equal to 0:
        Return 140
    End If
    Let int_start be proc time_span_start from TS with int_result
    If int_start is not equal to 200:
        Return 140
    End If
    Let int_end be proc time_span_end from TS with int_result
    If int_end is not equal to 300:
        Return 140
    End If
    proc time_span_destroy from TS with int_result

    Note: ----- Case 141: span_intersect - disjoint returns 0 -----
    Let djx_a be proc time_span_create from TS with 100, 200
    Let djx_b be proc time_span_create from TS with 300, 400
    Let djx_result be proc span_intersect from TS with djx_a, djx_b
    If djx_result is not equal to 0:
        Return 141
    End If

    Note: ----- Case 150: span_union - adjacent half-open with closed-right left interval -----
    Note: [100, 200] and [200, 300) share point 200 (left is closed-right) -> union [100, 300).
    Let un_a be proc time_span_create_closed from TS with 100, 200
    Let un_b be proc time_span_create from TS with 200, 300
    Let un_result be proc span_union from TS with un_a, un_b
    If un_result is equal to 0:
        Return 150
    End If
    Let un_start be proc time_span_start from TS with un_result
    If un_start is not equal to 100:
        Return 150
    End If
    Let un_end be proc time_span_end from TS with un_result
    If un_end is not equal to 300:
        Return 150
    End If
    proc time_span_destroy from TS with un_result

    Note: ----- Case 151: span_union - overlapping -----
    Note: [100, 300) union [200, 400) = [100, 400).
    Let uo_a be proc time_span_create from TS with 100, 300
    Let uo_b be proc time_span_create from TS with 200, 400
    Let uo_result be proc span_union from TS with uo_a, uo_b
    If uo_result is equal to 0:
        Return 151
    End If
    Let uo_start be proc time_span_start from TS with uo_result
    If uo_start is not equal to 100:
        Return 151
    End If
    Let uo_end be proc time_span_end from TS with uo_result
    If uo_end is not equal to 400:
        Return 151
    End If
    proc time_span_destroy from TS with uo_result

    Note: ----- Case 152: span_union - disjoint returns 0 -----
    Let ud_a be proc time_span_create from TS with 100, 200
    Let ud_b be proc time_span_create from TS with 300, 400
    Let ud_result be proc span_union from TS with ud_a, ud_b
    If ud_result is not equal to 0:
        Return 152
    End If

    Note: ----- Case 160: span_complement - A strictly inside universe -> 2 fragments -----
    Note: A = [200, 300) inside U = [100, 400) -> prefix [100, 200) and suffix [300, 400).
    Let comp_a be proc time_span_create from TS with 200, 300
    Let comp_u be proc time_span_create from TS with 100, 400
    Let out_buf be proc allocate from Layout with 16
    Let out_buf_second be out_buf plus 8
    Let frag_count be proc span_complement from TS with comp_a, comp_u, out_buf, out_buf_second
    If frag_count is not equal to 2:
        Return 160
    End If
    Let frag1 be proc memory_get_int64 from MemoryCore with out_buf, 0
    Let frag2 be proc memory_get_int64 from MemoryCore with out_buf, 8
    If frag1 is equal to 0:
        Return 160
    End If
    If frag2 is equal to 0:
        Return 160
    End If
    Let frag1_start be proc time_span_start from TS with frag1
    If frag1_start is not equal to 100:
        Return 160
    End If
    Let frag1_end be proc time_span_end from TS with frag1
    If frag1_end is not equal to 200:
        Return 160
    End If
    Let frag2_start be proc time_span_start from TS with frag2
    If frag2_start is not equal to 300:
        Return 160
    End If
    Let frag2_end be proc time_span_end from TS with frag2
    If frag2_end is not equal to 400:
        Return 160
    End If
    proc time_span_destroy from TS with frag1
    proc time_span_destroy from TS with frag2
    proc deallocate from Layout with out_buf

    Note: ----- Case 170: time_span_from_duration -----
    Note: start = 1000, duration = 500 ns -> [1000, 1500).
    Let fd_span be proc time_span_from_duration from TS with 1000, 500
    Let fd_start be proc time_span_start from TS with fd_span
    If fd_start is not equal to 1000:
        Return 170
    End If
    Let fd_end be proc time_span_end from TS with fd_span
    If fd_end is not equal to 1500:
        Return 170
    End If
    Let fd_dur be proc time_span_duration from TS with fd_span
    If fd_dur is not equal to 500:
        Return 170
    End If
    proc time_span_destroy from TS with fd_span

    Note: ----- Case 180: time_span_is_empty -----
    Note: Half-open [100, 100) -> empty.
    Let emp_span be proc time_span_create from TS with 100, 100
    Let emp_result be proc time_span_is_empty from TS with emp_span
    If emp_result is not equal to 1:
        Return 180
    End If
    Note: Closed [100, 100] -> NOT empty (single point).
    Let pt_span be proc time_span_create_closed from TS with 100, 100
    Let pt_result be proc time_span_is_empty from TS with pt_span
    If pt_result is not equal to 0:
        Return 180
    End If

    Return 0
End Process
