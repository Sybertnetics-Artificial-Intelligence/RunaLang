Note:
CalendarSystem primitive KAT.

Coverage:
- JDN of 1970-01-01 Gregorian = 2440588 (Unix epoch).
- JDN of 1582-10-15 Gregorian = 2299161 (Gregorian reform day; the
  reform meaningfully introduced this calendar on this date).
- Julian-from-JDN inverse: JDN 2299161 -> 1582-10-05 Julian (the same
  day on the Julian calendar that the Gregorian reform skipped).
- Islamic civil: AH 1 Muharram 1 = JDN 1948440 (tabular variant per
  Reingold & Dershowitz §6).
- Coptic: AM 1 Thout 1 = JDN 1825029.
- Ethiopian: AM 1 Meskerem 1 = JDN 1724221.
- Hebrew leap rule: AM 5784 is not leap (2023-24); AM 5785 is leap.
- Japanese era: 2019-05-01 -> Reiwa (index 5); 1988-12-31 -> Showa
  (index 3); 1990-06-01 -> Heisei (index 4).
- Generic Gregorian <-> Julian round-trip via calendar_convert_via_jdn.
- Hebrew round-trip via JDN (15 Shevat 5784, 1 Adar I 5784 leap year).
- Persian round-trip via JDN (1 Shahrivar 1402, 29 Esfand 1403 leap).
- Indian National round-trip via JDN (1 Chaitra Saka 1946, 15 Asvina).
- Cross-calendar Gregorian -> Hebrew -> Gregorian round-trip via
  dispatcher (recovers the original Gregorian triple).
- Cross-calendar Gregorian -> Persian -> Gregorian round-trip via
  dispatcher (recovers the original Gregorian triple).
- Cross-calendar Gregorian -> Indian National -> Gregorian round-trip
  via dispatcher (recovers the original Gregorian triple).

Exit code legend:
  0   All assertions passed.
  110 JDN of 1970-01-01 Gregorian wrong.
  111 JDN of 1582-10-15 Gregorian wrong.
  112 Julian-from-JDN inverse wrong on 2299161.
  113 Islamic civil epoch JDN wrong.
  114 Coptic epoch JDN wrong.
  115 Ethiopian epoch JDN wrong.
  116 Hebrew leap rule wrong on 5784 / 5785.
  117 Japanese era wrong on Reiwa boundary.
  118 Generic Gregorian -> Julian -> Gregorian round-trip failed.
  119 Hebrew round-trip via JDN failed (15 Shevat 5784).
  120 Hebrew leap-year round-trip via JDN failed (1 Adar I 5784).
  121 Persian round-trip via JDN failed (1 Shahrivar 1402).
  122 Persian last-month round-trip via JDN failed (29 Esfand 1403).
  123 Indian National round-trip via JDN failed (1 Chaitra Saka 1946).
  124 Indian National mid-year round-trip via JDN failed.
  125 Cross-calendar Gregorian <-> Hebrew round-trip failed.
  126 Cross-calendar Gregorian <-> Persian round-trip failed.
  127 Cross-calendar Gregorian <-> Indian National round-trip failed.
:End Note

Import "compiler/frontend/primitives/time/calendar_system.runa" as Cal
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore

Process called "main" returns Integer:
    Note: ----- Case 110: Unix epoch JDN -----
    Let jdn_epoch be proc jdn_from_gregorian from Cal with 1970, 1, 1
    If jdn_epoch is not equal to 2440588:
        Return 110
    End If

    Note: ----- Case 111: Gregorian reform JDN -----
    Let jdn_reform be proc jdn_from_gregorian from Cal with 1582, 10, 15
    If jdn_reform is not equal to 2299161:
        Return 111
    End If

    Note: ----- Case 112: Julian inverse of JDN 2299161 = 1582-10-05 -----
    Let buf24 be proc allocate from Layout with 24
    If buf24 is equal to 0:
        Return 112
    End If
    Let rc_j be proc julian_from_jdn from Cal with 2299161, buf24
    Let jy be proc memory_get_int64 from MemoryCore with buf24, 0
    Let jm be proc memory_get_int64 from MemoryCore with buf24, 8
    Let jd be proc memory_get_int64 from MemoryCore with buf24, 16
    If jy is not equal to 1582:
        Return 112
    End If
    If jm is not equal to 10:
        Return 112
    End If
    If jd is not equal to 5:
        Return 112
    End If

    Note: ----- Case 113: Islamic civil epoch JDN -----
    Let jdn_isl_epoch be proc jdn_from_islamic_civil from Cal with 1, 1, 1
    If jdn_isl_epoch is not equal to 1948440:
        Return 113
    End If

    Note: ----- Case 114: Coptic epoch JDN -----
    Let jdn_copt_epoch be proc jdn_from_coptic from Cal with 1, 1, 1
    If jdn_copt_epoch is not equal to 1825029:
        Return 114
    End If

    Note: ----- Case 115: Ethiopian epoch JDN -----
    Let jdn_eth_epoch be proc jdn_from_ethiopian from Cal with 1, 1, 1
    If jdn_eth_epoch is not equal to 1724221:
        Return 115
    End If

    Note: ----- Case 116: Hebrew leap rule -----
    Let leap_5784 be proc hebrew_is_leap_year from Cal with 5784
    If leap_5784 is not equal to 1:
        Note: 5784 IS leap by (7Y+1) mod 19 < 7: (7*5784+1) = 40489; 40489 mod 19 = 1; 1 < 7 -> leap. Confirmed leap.
        Return 116
    End If
    Let leap_5785 be proc hebrew_is_leap_year from Cal with 5785
    If leap_5785 is not equal to 0:
        Note: 5785: (7*5785+1) = 40496; 40496 mod 19 = 8; not < 7 -> not leap.
        Return 116
    End If

    Note: ----- Case 117: Japanese era boundaries -----
    Let era_reiwa be proc japanese_era_index from Cal with 2019, 5, 1
    If era_reiwa is not equal to 5:
        Return 117
    End If
    Let era_heisei_last be proc japanese_era_index from Cal with 2019, 4, 30
    If era_heisei_last is not equal to 4:
        Return 117
    End If
    Let era_showa_last be proc japanese_era_index from Cal with 1989, 1, 7
    If era_showa_last is not equal to 3:
        Return 117
    End If
    Let era_heisei_first be proc japanese_era_index from Cal with 1989, 1, 8
    If era_heisei_first is not equal to 4:
        Return 117
    End If

    Note: ----- Case 118: Generic Gregorian -> Julian -> Gregorian round trip -----
    Let rc_to_julian be proc calendar_convert_via_jdn from Cal with 0, 2, 2024, 6, 3, buf24
    If rc_to_julian is less than 0:
        Return 118
    End If
    Let j_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let j_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let j_d be proc memory_get_int64 from MemoryCore with buf24, 16
    Note: 2024-06-03 Gregorian = 2024-05-21 Julian (13-day offset).
    If j_y is not equal to 2024:
        Return 118
    End If
    If j_m is not equal to 5:
        Return 118
    End If
    If j_d is not equal to 21:
        Return 118
    End If
    Let rc_back be proc calendar_convert_via_jdn from Cal with 2, 0, j_y, j_m, j_d, buf24
    Let bg_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let bg_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let bg_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If bg_y is not equal to 2024:
        Return 118
    End If
    If bg_m is not equal to 6:
        Return 118
    End If
    If bg_d is not equal to 3:
        Return 118
    End If

    Note: ----- Case 119: Hebrew round-trip via JDN -----
    Note: 1 Tishri AM 5784 = Sep 16 2023 Gregorian; Hebrew month 1 = Nisan, month 7 = Tishri.
    Note: Test 15 Shevat 5784 (Tu BiShvat 2024) = month 11, day 15.
    Let jdn_heb be proc jdn_from_hebrew from Cal with 5784, 11, 15
    Let rc_heb be proc hebrew_from_jdn from Cal with jdn_heb, buf24
    If rc_heb is not equal to 0:
        Return 119
    End If
    Let heb_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let heb_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let heb_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If heb_y is not equal to 5784:
        Return 119
    End If
    If heb_m is not equal to 11:
        Return 119
    End If
    If heb_d is not equal to 15:
        Return 119
    End If

    Note: ----- Case 120: Hebrew leap-year round-trip (Adar I) -----
    Note: AM 5784 is a leap year (verified Case 116). Test 1 Adar I = month 12, day 1.
    Let jdn_adari be proc jdn_from_hebrew from Cal with 5784, 12, 1
    Let rc_adari be proc hebrew_from_jdn from Cal with jdn_adari, buf24
    If rc_adari is not equal to 0:
        Return 120
    End If
    Let adari_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let adari_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let adari_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If adari_y is not equal to 5784:
        Return 120
    End If
    If adari_m is not equal to 12:
        Return 120
    End If
    If adari_d is not equal to 1:
        Return 120
    End If

    Note: ----- Case 121: Persian round-trip via JDN -----
    Note: 1 Shahrivar 1402 = month 6, day 1 in the Iranian National calendar.
    Let jdn_per be proc jdn_from_persian from Cal with 1402, 6, 1
    Let rc_per be proc persian_from_jdn from Cal with jdn_per, buf24
    If rc_per is not equal to 0:
        Return 121
    End If
    Let per_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let per_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let per_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If per_y is not equal to 1402:
        Return 121
    End If
    If per_m is not equal to 6:
        Return 121
    End If
    If per_d is not equal to 1:
        Return 121
    End If

    Note: ----- Case 122: Persian last-month round-trip -----
    Note: 29 Esfand 1403 = month 12, day 29 (1403 AP is a Birashk leap year).
    Let jdn_per2 be proc jdn_from_persian from Cal with 1403, 12, 29
    Let rc_per2 be proc persian_from_jdn from Cal with jdn_per2, buf24
    If rc_per2 is not equal to 0:
        Return 122
    End If
    Let per2_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let per2_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let per2_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If per2_y is not equal to 1403:
        Return 122
    End If
    If per2_m is not equal to 12:
        Return 122
    End If
    If per2_d is not equal to 29:
        Return 122
    End If

    Note: ----- Case 123: Indian National round-trip -----
    Note: 1 Chaitra Saka 1946 = month 1, day 1 (March 22, 2024 Gregorian).
    Let jdn_ind be proc jdn_from_indian_national from Cal with 1946, 1, 1
    Let rc_ind be proc indian_national_from_jdn from Cal with jdn_ind, buf24
    If rc_ind is not equal to 0:
        Return 123
    End If
    Let ind_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let ind_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let ind_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If ind_y is not equal to 1946:
        Return 123
    End If
    If ind_m is not equal to 1:
        Return 123
    End If
    If ind_d is not equal to 1:
        Return 123
    End If

    Note: ----- Case 124: Indian National mid-year round-trip -----
    Note: 15 Asvina Saka 1946 = month 7, day 15.
    Let jdn_ind2 be proc jdn_from_indian_national from Cal with 1946, 7, 15
    Let rc_ind2 be proc indian_national_from_jdn from Cal with jdn_ind2, buf24
    If rc_ind2 is not equal to 0:
        Return 124
    End If
    Let ind2_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let ind2_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let ind2_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If ind2_y is not equal to 1946:
        Return 124
    End If
    If ind2_m is not equal to 7:
        Return 124
    End If
    If ind2_d is not equal to 15:
        Return 124
    End If

    Note: ----- Case 125: Cross-calendar round-trip Gregorian -> Hebrew -> Gregorian -----
    Note: The cross-calendar round-trip exercises the dispatcher in both
    Note: directions. Start from a Gregorian date, route through the
    Note: dispatcher to Hebrew, then back to Gregorian. The recovered
    Note: triple must match the original Gregorian triple exactly; the
    Note: intermediate Hebrew triple is reported here so the per-pair
    Note: agreement of the forward and reverse converters is visible.
    Let rc_g_to_h be proc calendar_convert_via_jdn from Cal with 0, 3, 2024, 1, 25, buf24
    If rc_g_to_h is less than 0:
        Return 125
    End If
    Let xh_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let xh_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let xh_d be proc memory_get_int64 from MemoryCore with buf24, 16
    Let rc_h_to_g be proc calendar_convert_via_jdn from Cal with 3, 0, xh_y, xh_m, xh_d, buf24
    If rc_h_to_g is less than 0:
        Return 125
    End If
    Let bg2_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let bg2_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let bg2_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If bg2_y is not equal to 2024:
        Return 125
    End If
    If bg2_m is not equal to 1:
        Return 125
    End If
    If bg2_d is not equal to 25:
        Return 125
    End If

    Note: ----- Case 126: Cross-calendar round-trip Gregorian -> Persian -> Gregorian -----
    Let rc_g_to_p be proc calendar_convert_via_jdn from Cal with 0, 10, 2024, 3, 21, buf24
    If rc_g_to_p is less than 0:
        Return 126
    End If
    Let xp_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let xp_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let xp_d be proc memory_get_int64 from MemoryCore with buf24, 16
    Let rc_p_to_g be proc calendar_convert_via_jdn from Cal with 10, 0, xp_y, xp_m, xp_d, buf24
    If rc_p_to_g is less than 0:
        Return 126
    End If
    Let bg3_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let bg3_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let bg3_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If bg3_y is not equal to 2024:
        Return 126
    End If
    If bg3_m is not equal to 3:
        Return 126
    End If
    If bg3_d is not equal to 21:
        Return 126
    End If

    Note: ----- Case 127: Cross-calendar round-trip Gregorian -> Indian National -> Gregorian -----
    Let rc_g_to_i be proc calendar_convert_via_jdn from Cal with 0, 6, 2024, 3, 22, buf24
    If rc_g_to_i is less than 0:
        Return 127
    End If
    Let xi_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let xi_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let xi_d be proc memory_get_int64 from MemoryCore with buf24, 16
    Let rc_i_to_g be proc calendar_convert_via_jdn from Cal with 6, 0, xi_y, xi_m, xi_d, buf24
    If rc_i_to_g is less than 0:
        Return 127
    End If
    Let bg4_y be proc memory_get_int64 from MemoryCore with buf24, 0
    Let bg4_m be proc memory_get_int64 from MemoryCore with buf24, 8
    Let bg4_d be proc memory_get_int64 from MemoryCore with buf24, 16
    If bg4_y is not equal to 2024:
        Return 127
    End If
    If bg4_m is not equal to 3:
        Return 127
    End If
    If bg4_d is not equal to 22:
        Return 127
    End If

    Return 0
End Process
