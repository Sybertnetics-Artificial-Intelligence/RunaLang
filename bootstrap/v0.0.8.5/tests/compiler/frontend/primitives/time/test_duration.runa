Note:
Duration primitive KAT.

Coverage:
- Construction from each supported unit (ns, us, ms, s, min, hr, day, week, julian year).
- Conversion to each smaller unit (truncating).
- 128-bit signed addition / subtraction.
- Negation; abs.
- Multiplication / division by scalars.
- Three-way compare across positive, negative, and equal values.
- ISO 8601 duration formatting for representative inputs.

Exit code legend:
  0   All assertions passed.
  20  duration_from_seconds(1) wrong representation.
  21  duration_to_milliseconds(2 s) != 2000.
  22  duration_from_minutes(1) inconsistent with duration_from_seconds(60).
  23  add of 1 s + 2 s != 3 s.
  24  sub of 5 s - 3 s != 2 s.
  25  negate(1 s) != -1 s.
  26  abs(-3 s) != 3 s.
  27  multiply_by_integer: 3 s * 7 != 21 s.
  28  divide_by_integer: 21 s / 7 != 3 s.
  29  compare ordering wrong (negative < zero < positive).
  30  is_zero / is_negative / is_positive predicate wrong.
  31  Julian-year ratio mismatch (31_557_600 s/yr).
  32  duration_to_iso_8601("3600 s") != "PT1H".
  33  ISO formatter zero output != "PT0S".
:End Note

Import "compiler/frontend/primitives/time/duration.runa" as Duration
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore

Process called "main" returns Integer:
    Note: ----- Case 20: from_seconds(1) -> low limb = 1_000_000_000 -----
    Let d_1s be proc duration_from_seconds from Duration with 1
    If d_1s is equal to 0:
        Return 20
    End If
    Let ns_1s be proc duration_to_nanoseconds from Duration with d_1s
    If ns_1s is not equal to 1000000000:
        Return 20
    End If

    Note: ----- Case 21: to_milliseconds -----
    Let d_2s be proc duration_from_seconds from Duration with 2
    Let ms_2s be proc duration_to_milliseconds from Duration with d_2s
    If ms_2s is not equal to 2000:
        Return 21
    End If

    Note: ----- Case 22: from_minutes(1) == from_seconds(60) -----
    Let d_1min be proc duration_from_minutes from Duration with 1
    Let d_60s be proc duration_from_seconds from Duration with 60
    Let cmp_min_eq_60s be proc duration_compare from Duration with d_1min, d_60s
    If cmp_min_eq_60s is not equal to 0:
        Return 22
    End If

    Note: ----- Case 23: addition -----
    Let result_add be proc duration_allocate from Duration
    If result_add is equal to 0:
        Return 23
    End If
    Let rc_add be proc duration_add from Duration with d_1s, d_2s, result_add
    If rc_add is not equal to 0:
        Return 23
    End If
    Let expected_3s be proc duration_from_seconds from Duration with 3
    Let cmp_add be proc duration_compare from Duration with result_add, expected_3s
    If cmp_add is not equal to 0:
        Return 23
    End If

    Note: ----- Case 24: subtraction -----
    Let d_5s be proc duration_from_seconds from Duration with 5
    Let d_3s be proc duration_from_seconds from Duration with 3
    Let result_sub be proc duration_allocate from Duration
    Let rc_sub be proc duration_sub from Duration with d_5s, d_3s, result_sub
    If rc_sub is not equal to 0:
        Return 24
    End If
    Let expected_2s be proc duration_from_seconds from Duration with 2
    Let cmp_sub be proc duration_compare from Duration with result_sub, expected_2s
    If cmp_sub is not equal to 0:
        Return 24
    End If

    Note: ----- Case 25: negation -----
    Let result_neg be proc duration_allocate from Duration
    Let rc_neg be proc duration_negate from Duration with d_1s, result_neg
    If rc_neg is not equal to 0:
        Return 25
    End If
    Let neg_one_s be proc duration_from_nanoseconds from Duration with -1000000000
    Let cmp_neg be proc duration_compare from Duration with result_neg, neg_one_s
    If cmp_neg is not equal to 0:
        Return 25
    End If

    Note: ----- Case 26: abs -----
    Let d_neg_3s be proc duration_from_nanoseconds from Duration with -3000000000
    Let result_abs be proc duration_allocate from Duration
    Let rc_abs be proc duration_abs from Duration with d_neg_3s, result_abs
    If rc_abs is not equal to 0:
        Return 26
    End If
    Let cmp_abs be proc duration_compare from Duration with result_abs, d_3s
    If cmp_abs is not equal to 0:
        Return 26
    End If

    Note: ----- Case 27: multiply_by_integer 3s * 7 = 21s -----
    Let result_mul be proc duration_allocate from Duration
    Let rc_mul be proc duration_multiply_by_integer from Duration with d_3s, 7, result_mul
    If rc_mul is not equal to 0:
        Return 27
    End If
    Let expected_21s be proc duration_from_seconds from Duration with 21
    Let cmp_mul be proc duration_compare from Duration with result_mul, expected_21s
    If cmp_mul is not equal to 0:
        Return 27
    End If

    Note: ----- Case 28: divide_by_integer 21s / 7 = 3s -----
    Let result_div be proc duration_allocate from Duration
    Let rc_div be proc duration_divide_by_integer from Duration with expected_21s, 7, result_div
    If rc_div is not equal to 0:
        Return 28
    End If
    Let cmp_div be proc duration_compare from Duration with result_div, d_3s
    If cmp_div is not equal to 0:
        Return 28
    End If

    Note: ----- Case 29: ordering -----
    Let cmp_neg_zero be proc duration_compare from Duration with d_neg_3s, expected_3s
    If cmp_neg_zero is not equal to -1:
        Return 29
    End If
    Let cmp_zero_pos be proc duration_compare from Duration with expected_3s, d_neg_3s
    If cmp_zero_pos is not equal to 1:
        Return 29
    End If

    Note: ----- Case 30: predicates -----
    Let zero_dur be proc duration_from_nanoseconds from Duration with 0
    Let pred_iz be proc duration_is_zero from Duration with zero_dur
    If pred_iz is not equal to 1:
        Return 30
    End If
    Let pred_neg be proc duration_is_negative from Duration with d_neg_3s
    If pred_neg is not equal to 1:
        Return 30
    End If
    Let pred_pos be proc duration_is_positive from Duration with d_3s
    If pred_pos is not equal to 1:
        Return 30
    End If

    Note: ----- Case 31: Julian year ratio -----
    Let d_1y be proc duration_from_years_julian from Duration with 1
    Let s_1y be proc duration_to_seconds from Duration with d_1y
    If s_1y is not equal to 31557600:
        Return 31
    End If

    Note: ----- Case 32: ISO 8601 formatting of 1h -----
    Let d_3600s be proc duration_from_seconds from Duration with 3600
    Let buf32 be proc allocate from Layout with 32
    If buf32 is equal to 0:
        Return 32
    End If
    Let n_iso be proc duration_to_iso_8601 from Duration with d_3600s, buf32, 32
    Note: Expected: "PT1H" (4 characters).
    If n_iso is not equal to 4:
        Return 32
    End If
    Let c0 be proc memory_get_int8 from MemoryCore with buf32, 0
    Let c1 be proc memory_get_int8 from MemoryCore with buf32, 1
    Let c2 be proc memory_get_int8 from MemoryCore with buf32, 2
    Let c3 be proc memory_get_int8 from MemoryCore with buf32, 3
    If c0 is not equal to 80:
        Return 32
    End If
    If c1 is not equal to 84:
        Return 32
    End If
    If c2 is not equal to 49:
        Return 32
    End If
    If c3 is not equal to 72:
        Return 32
    End If

    Note: ----- Case 33: ISO 8601 of zero duration -----
    Let n_iso_zero be proc duration_to_iso_8601 from Duration with zero_dur, buf32, 32
    Note: Expected: "PT0S" (4 characters).
    If n_iso_zero is not equal to 4:
        Return 33
    End If
    Let z0 be proc memory_get_int8 from MemoryCore with buf32, 0
    Let z1 be proc memory_get_int8 from MemoryCore with buf32, 1
    Let z2 be proc memory_get_int8 from MemoryCore with buf32, 2
    Let z3 be proc memory_get_int8 from MemoryCore with buf32, 3
    If z0 is not equal to 80:
        Return 33
    End If
    If z1 is not equal to 84:
        Return 33
    End If
    If z2 is not equal to 48:
        Return 33
    End If
    If z3 is not equal to 83:
        Return 33
    End If

    Return 0
End Process
