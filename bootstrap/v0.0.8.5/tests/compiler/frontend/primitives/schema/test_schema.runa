Process called "test_validate_ref_defs" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate $ref / $defs")

    Note: Build a root schema that has $defs.foo = integer>=0, and root = $ref(#/$defs/foo)
    Let foo_schema be proc schema_create from S with 4, proc integer_constraints_create from S with 1, 0, 0, 0, 0
    Let root_node be proc schema_create_reference from S with "#/$defs/foo"
    proc schema_add_definition from S with root_node, "foo", foo_schema

    Let v5 be proc config_value_integer from Cfg with 5
    Let issues_ok be proc schema_validate from S with v5, root_node
    T.assert_equal(results, "$ref accepts 5", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Let vneg be proc config_value_integer from Cfg with 0 minus 1
    Let issues_lo be proc schema_validate from S with vneg, root_node
    T.assert_greater_than(results, "$ref rejects -1", proc length from List with issues_lo, 0)
    proc validation_issues_destroy from S with issues_lo

    Let vstr be proc config_value_string from Cfg with "five"
    Let issues_bad be proc schema_validate from S with vstr, root_node
    T.assert_greater_than(results, "$ref rejects string", proc length from List with issues_bad, 0)
    proc validation_issues_destroy from S with issues_bad

    proc config_value_destroy from Cfg with v5
    proc config_value_destroy from Cfg with vneg
    proc config_value_destroy from Cfg with vstr
    proc schema_destroy from S with root_node
    Return 1
End Process

Process called "test_validate_prefix_items" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate prefixItems + items")

    Let int_schema be proc schema_create_integer_any from S
    Let str_schema be proc schema_create_string_any from S
    Let bool_schema be proc schema_create_boolean from S
    Let arr be proc schema_create_array from S with bool_schema, 0 minus 1, 0 minus 1, 0
    proc schema_array_add_prefix_item from S with arr, int_schema
    proc schema_array_add_prefix_item from S with arr, str_schema

    Note: [1, "two", true, false] -> 1 matches integer, "two" matches string, rest matches boolean
    Let lst_ok be proc list_create from List
    proc list_append from List with lst_ok, proc config_value_integer from Cfg with 1
    proc list_append from List with lst_ok, proc config_value_string from Cfg with "two"
    proc list_append from List with lst_ok, proc config_value_bool from Cfg with 1
    proc list_append from List with lst_ok, proc config_value_bool from Cfg with 0
    Let v_ok be proc config_value_list from Cfg with lst_ok
    Let issues_ok be proc schema_validate from S with v_ok, arr
    T.assert_equal(results, "prefixItems [int,str,bool,bool] accepted", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Note: [1, 2, true] -> position 1 is integer not string, must reject
    Let lst_bad be proc list_create from List
    proc list_append from List with lst_bad, proc config_value_integer from Cfg with 1
    proc list_append from List with lst_bad, proc config_value_integer from Cfg with 2
    proc list_append from List with lst_bad, proc config_value_bool from Cfg with 1
    Let v_bad be proc config_value_list from Cfg with lst_bad
    Let issues_bad be proc schema_validate from S with v_bad, arr
    T.assert_greater_than(results, "prefixItems rejects [1,2,true]", proc length from List with issues_bad, 0)
    proc validation_issues_destroy from S with issues_bad

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_bad
    proc schema_destroy from S with arr
    Return 1
End Process

Process called "test_validate_contains" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate contains")

    Let any_item be proc schema_create_any from S
    Let arr be proc schema_create_array from S with any_item, 0 minus 1, 0 minus 1, 0
    Let contains_sub be proc schema_create from S with 4, proc integer_constraints_create from S with 1, 100, 0, 0, 0
    proc schema_array_set_contains from S with arr, contains_sub

    Note: [50, 200, 10] contains 200 >= 100 -> accept
    Let lst_ok be proc list_create from List
    proc list_append from List with lst_ok, proc config_value_integer from Cfg with 50
    proc list_append from List with lst_ok, proc config_value_integer from Cfg with 200
    proc list_append from List with lst_ok, proc config_value_integer from Cfg with 10
    Let v_ok be proc config_value_list from Cfg with lst_ok
    Let issues_ok be proc schema_validate from S with v_ok, arr
    T.assert_equal(results, "contains accepts [50,200,10]", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Note: [10, 20, 30] no element >= 100 -> reject
    Let lst_bad be proc list_create from List
    proc list_append from List with lst_bad, proc config_value_integer from Cfg with 10
    proc list_append from List with lst_bad, proc config_value_integer from Cfg with 20
    proc list_append from List with lst_bad, proc config_value_integer from Cfg with 30
    Let v_bad be proc config_value_list from Cfg with lst_bad
    Let issues_bad be proc schema_validate from S with v_bad, arr
    T.assert_greater_than(results, "contains rejects [10,20,30]", proc length from List with issues_bad, 0)
    proc validation_issues_destroy from S with issues_bad

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_bad
    proc schema_destroy from S with arr
    Return 1
End Process

Process called "test_validate_dependent_required" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate dependentRequired")

    Let obj_schema be proc schema_create_object from S
    Let cc_field_schema be proc schema_create_string_any from S
    Let f_cc be proc object_field_create from S with "credit_card", cc_field_schema, 0
    proc schema_object_add_field from S with obj_schema, f_cc
    Let ba_field_schema be proc schema_create_string_any from S
    Let f_ba be proc object_field_create from S with "billing_address", ba_field_schema, 0
    proc schema_object_add_field from S with obj_schema, f_ba

    Let needed_list be proc list_create from List
    Let ba_dep be proc string_duplicate from StringPrim with "billing_address"
    proc list_push from List with needed_list, ba_dep
    proc schema_object_add_dependent_required from S with obj_schema, "credit_card", needed_list

    Let inner_ok be proc create from Dict
    proc set from Dict with inner_ok, "credit_card", proc config_value_string from Cfg with "1234"
    proc set from Dict with inner_ok, "billing_address", proc config_value_string from Cfg with "1 Main St"
    Let v_ok be proc config_value_map from Cfg with inner_ok
    Let issues_ok be proc schema_validate from S with v_ok, obj_schema
    T.assert_equal(results, "dependentRequired accepts pair", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Let inner_bad be proc create from Dict
    proc set from Dict with inner_bad, "credit_card", proc config_value_string from Cfg with "1234"
    Let v_bad be proc config_value_map from Cfg with inner_bad
    Let issues_bad be proc schema_validate from S with v_bad, obj_schema
    T.assert_greater_than(results, "dependentRequired rejects orphan trigger", proc length from List with issues_bad, 0)
    proc validation_issues_destroy from S with issues_bad

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_bad
    proc schema_destroy from S with obj_schema
    Return 1
End Process

Process called "test_validate_additional_properties_false" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate additionalProperties=false")

