    proc validation_issues_destroy from S with issues_eq

    Let v_neg be proc config_value_integer from Cfg with 0 minus 1
    Let issues_lo be proc schema_validate from S with v_neg, int_node
    T.assert_greater_than(results, "exMin=0 rejects -1", proc length from List with issues_lo, 0)
    proc validation_issues_destroy from S with issues_lo

    proc config_value_destroy from Cfg with v1
    proc config_value_destroy from Cfg with v0
    proc config_value_destroy from Cfg with v_neg
    proc schema_destroy from S with int_node
    Return 1
End Process

