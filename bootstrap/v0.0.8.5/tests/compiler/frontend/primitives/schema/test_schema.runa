    Let issues_bad be proc schema_validate from S with v_bad, str_schema
    T.assert_greater_than(results, "ipv4 rejects 999.999.999.999", proc length from List with issues_bad, 0)
    proc validation_issues_destroy from S with issues_bad

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_bad
    proc schema_destroy from S with str_schema
    Return 1
End Process

Process called "test_compose_and" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.compose AND")

    Note: int with minimum 0
    Let ic_min0 be proc integer_constraints_create from S with 1, 0, 0, 0, 0
    Let s_min0 be proc schema_create from S with 4, ic_min0

    Note: int with maximum 100
    Let ic_max100 be proc integer_constraints_create from S with 0, 0, 1, 100, 0
    Let s_max100 be proc schema_create from S with 4, ic_max100

    Let composed be proc schema_compose from S with s_min0, s_max100, 1
    T.assert_not_null(results, "AND composed not null", composed)
    T.assert_equal(results, "compose AND returns SCHEMA_AND kind", proc schema_kind from S with composed, 12)

    Let v50 be proc config_value_integer from Cfg with 50
    Let issues_ok be proc schema_validate from S with v50, composed
    T.assert_equal(results, "AND accepts 50 (in both ranges)", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Let v_neg be proc config_value_integer from Cfg with 0 minus 1
    Let issues_lo be proc schema_validate from S with v_neg, composed
    T.assert_greater_than(results, "AND rejects -1 (fails min=0)", proc length from List with issues_lo, 0)
    proc validation_issues_destroy from S with issues_lo

    Let v200 be proc config_value_integer from Cfg with 200
    Let issues_hi be proc schema_validate from S with v200, composed
    T.assert_greater_than(results, "AND rejects 200 (fails max=100)", proc length from List with issues_hi, 0)
    proc validation_issues_destroy from S with issues_hi

    proc config_value_destroy from Cfg with v50
    proc config_value_destroy from Cfg with v_neg
    proc config_value_destroy from Cfg with v200
    proc schema_destroy from S with composed
    Return 1
End Process

Process called "test_compose_not" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.compose NOT")

    Note: int with minimum 0 - NOT-of-this rejects non-negative integers
    Let ic_min0 be proc integer_constraints_create from S with 1, 0, 0, 0, 0
    Let s_min0 be proc schema_create from S with 4, ic_min0

    Let composed be proc schema_compose from S with s_min0, 0, 3
    T.assert_not_null(results, "NOT composed not null", composed)
    T.assert_equal(results, "compose NOT returns SCHEMA_NOT kind", proc schema_kind from S with composed, 13)

    Let v50 be proc config_value_integer from Cfg with 50
    Let issues_pos be proc schema_validate from S with v50, composed
    T.assert_greater_than(results, "NOT rejects 50 (inner accepts)", proc length from List with issues_pos, 0)
    proc validation_issues_destroy from S with issues_pos

    Let v_neg be proc config_value_integer from Cfg with 0 minus 1
    Let issues_neg be proc schema_validate from S with v_neg, composed
    T.assert_equal(results, "NOT accepts -1 (inner rejects)", proc length from List with issues_neg, 0)
    proc validation_issues_destroy from S with issues_neg

    proc config_value_destroy from Cfg with v50
    proc config_value_destroy from Cfg with v_neg
    proc schema_destroy from S with composed
    Return 1
End Process

Process called "test_to_runa_native_scalar" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.to_runa_native scalar")

    Let s be proc schema_create_integer_any from S
    Let txt be proc schema_to_runa_native_format from S with s
    T.assert_not_null(results, "integer serialized", txt)
    proc schema_destroy from S with s

    Let s2 be proc schema_create_string_any from S
    Let txt2 be proc schema_to_runa_native_format from S with s2
    T.assert_not_null(results, "string serialized", txt2)
    proc schema_destroy from S with s2

    Return 1
End Process

Process called "test_validate_all_of" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate allOf")

    Let s_min0 be proc schema_create from S with 4, proc integer_constraints_create from S with 1, 0, 0, 0, 0
    Let s_max100 be proc schema_create from S with 4, proc integer_constraints_create from S with 0, 0, 1, 100, 0
    Let allof_node be proc schema_create_all_of from S
    proc schema_composite_add_subschema from S with allof_node, s_min0
    proc schema_composite_add_subschema from S with allof_node, s_max100

    Let v50 be proc config_value_integer from Cfg with 50
    Let issues_ok be proc schema_validate from S with v50, allof_node
    T.assert_equal(results, "allOf accepts 50", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Let v_neg be proc config_value_integer from Cfg with 0 minus 1
    Let issues_lo be proc schema_validate from S with v_neg, allof_node
    T.assert_greater_than(results, "allOf rejects -1", proc length from List with issues_lo, 0)
    proc validation_issues_destroy from S with issues_lo

    Let v200 be proc config_value_integer from Cfg with 200
    Let issues_hi be proc schema_validate from S with v200, allof_node
    T.assert_greater_than(results, "allOf rejects 200", proc length from List with issues_hi, 0)
    proc validation_issues_destroy from S with issues_hi

    proc config_value_destroy from Cfg with v50
    proc config_value_destroy from Cfg with v_neg
    proc config_value_destroy from Cfg with v200
    proc schema_destroy from S with allof_node
    Return 1
End Process

