Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_schema_kinds(results)
    test_validate_integer_bounds(results)
    test_validate_string_bounds(results)
    test_validate_object(results)
    test_validate_enum(results)
    test_compose_or(results)
    test_compose_and(results)
    test_compose_not(results)
    test_validate_array_cardinality(results)
    test_validate_string_pattern(results)
    test_validate_string_format_email(results)
    test_validate_string_format_ipv4(results)
    test_to_runa_native_scalar(results)
    test_validate_all_of(results)
    test_validate_not(results)
    test_validate_const(results)
    test_validate_ref_defs(results)
    test_validate_prefix_items(results)
    test_validate_contains(results)
    test_validate_dependent_required(results)
    test_validate_additional_properties_false(results)
    test_validate_additional_properties_schema(results)
    test_validate_one_of(results)
    test_validate_exclusive_minimum(results)
    test_validate_exclusive_maximum(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
