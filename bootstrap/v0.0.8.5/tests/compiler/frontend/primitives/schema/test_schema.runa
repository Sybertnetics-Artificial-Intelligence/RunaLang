    proc validation_issues_destroy from S with issues_bad

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_extra
    proc schema_destroy from S with obj_schema
    Return 1
End Process

Process called "test_validate_additional_properties_schema" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate additionalProperties=schema")

    Let obj_schema be proc schema_create_object from S
    Let name_sub be proc schema_create_string_any from S
    Let f_name be proc object_field_create from S with "name", name_sub, 0
    proc schema_object_add_field from S with obj_schema, f_name
    Let ap_int_sub be proc schema_create_integer_any from S
    proc schema_object_set_additional_properties_schema from S with obj_schema, ap_int_sub

    Let inner_ok be proc create from Dict
    proc set from Dict with inner_ok, "name", proc config_value_string from Cfg with "Alice"
    proc set from Dict with inner_ok, "count", proc config_value_integer from Cfg with 5
    Let v_ok be proc config_value_map from Cfg with inner_ok
    Let issues_ok be proc schema_validate from S with v_ok, obj_schema
    T.assert_equal(results, "AP-schema accepts integer extras", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Let inner_bad be proc create from Dict
    proc set from Dict with inner_bad, "name", proc config_value_string from Cfg with "Alice"
    proc set from Dict with inner_bad, "count", proc config_value_string from Cfg with "five"
    Let v_bad be proc config_value_map from Cfg with inner_bad
    Let issues_bad be proc schema_validate from S with v_bad, obj_schema
    T.assert_greater_than(results, "AP-schema rejects string extra", proc length from List with issues_bad, 0)
    proc validation_issues_destroy from S with issues_bad

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_bad
    proc schema_destroy from S with obj_schema
    Return 1
End Process

Process called "test_validate_one_of" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate oneOf XOR")

    Let s_min0 be proc schema_create from S with 4, proc integer_constraints_create from S with 1, 0, 0, 0, 0
    Let s_max100 be proc schema_create from S with 4, proc integer_constraints_create from S with 0, 0, 1, 100, 0
    Let oneof_node be proc schema_create_one_of from S
    proc schema_composite_add_subschema from S with oneof_node, s_min0
    proc schema_composite_add_subschema from S with oneof_node, s_max100

    Note: 50 matches BOTH min>=0 and max<=100 -> oneOf must reject (XOR fails)
    Let v50 be proc config_value_integer from Cfg with 50
    Let issues_both be proc schema_validate from S with v50, oneof_node
    T.assert_greater_than(results, "oneOf rejects 50 (matches both)", proc length from List with issues_both, 0)
    proc validation_issues_destroy from S with issues_both

    Note: -1 matches only max<=100 -> accept
    Let v_neg be proc config_value_integer from Cfg with 0 minus 1
    Let issues_lo be proc schema_validate from S with v_neg, oneof_node
    T.assert_equal(results, "oneOf accepts -1 (one match)", proc length from List with issues_lo, 0)
    proc validation_issues_destroy from S with issues_lo

    Note: 200 matches only min>=0 -> accept
    Let v200 be proc config_value_integer from Cfg with 200
    Let issues_hi be proc schema_validate from S with v200, oneof_node
    T.assert_equal(results, "oneOf accepts 200 (one match)", proc length from List with issues_hi, 0)
    proc validation_issues_destroy from S with issues_hi

    proc config_value_destroy from Cfg with v50
    proc config_value_destroy from Cfg with v_neg
    proc config_value_destroy from Cfg with v200
    proc schema_destroy from S with oneof_node
    Return 1
End Process

