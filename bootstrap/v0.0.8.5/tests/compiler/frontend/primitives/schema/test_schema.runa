Note:
Unit tests for compiler/frontend/primitives/schema/schema.runa.

Covers:
  - schema_create / schema_destroy for every kind
  - validation against ConfigValue (integer bounds, string bounds,
    object required fields, enum, array element type, union)
  - schema_compose AND/OR/NOT
  - runa-native textual round-trip for scalar kinds
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/schema/schema.runa" as S
Import "compiler/frontend/primitives/config/config.runa" as Cfg
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim

Process called "test_schema_kinds" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.kinds")

    Let any_s be proc schema_create_any from S
    T.assert_not_null(results, "create any", any_s)
    T.assert_equal(results, "any kind", proc schema_kind from S with any_s, 11)
    proc schema_destroy from S with any_s

    Let null_s be proc schema_create_null from S
    T.assert_equal(results, "null kind", proc schema_kind from S with null_s, 7)
    proc schema_destroy from S with null_s

    Let bool_s be proc schema_create_boolean from S
    T.assert_equal(results, "bool kind", proc schema_kind from S with bool_s, 6)
    proc schema_destroy from S with bool_s

    Let str_s be proc schema_create_string_any from S
    T.assert_equal(results, "string kind", proc schema_kind from S with str_s, 3)
    proc schema_destroy from S with str_s

    Let int_s be proc schema_create_integer_any from S
    T.assert_equal(results, "integer kind", proc schema_kind from S with int_s, 4)
    proc schema_destroy from S with int_s

    Let flt_s be proc schema_create_float_any from S
    T.assert_equal(results, "float kind", proc schema_kind from S with flt_s, 5)
    proc schema_destroy from S with flt_s
    Return 1
End Process

Process called "test_validate_integer_bounds" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate integer bounds")

    Let ic be proc integer_constraints_create from S with 1, 0, 0, 0, 0
    Let int_schema be proc schema_create from S with 4, ic

    Let v5 be proc config_value_integer from Cfg with 5
    Let issues be proc schema_validate from S with v5, int_schema
    T.assert_equal(results, "5 accepted by min=0", proc length from List with issues, 0)
    proc validation_issues_destroy from S with issues

    Let vneg be proc config_value_integer from Cfg with 0 minus 1
    Let issues2 be proc schema_validate from S with vneg, int_schema
    T.assert_greater_than(results, "-1 rejected by min=0", proc length from List with issues2, 0)
    proc validation_issues_destroy from S with issues2

    Let vstr be proc config_value_string from Cfg with "5"
    Let issues3 be proc schema_validate from S with vstr, int_schema
    T.assert_greater_than(results, "string \"5\" rejected", proc length from List with issues3, 0)
    proc validation_issues_destroy from S with issues3

    proc config_value_destroy from Cfg with v5
    proc config_value_destroy from Cfg with vneg
    proc config_value_destroy from Cfg with vstr
    proc schema_destroy from S with int_schema
    Return 1
End Process

Process called "test_validate_string_bounds" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate string bounds")

    Let sc be proc string_constraints_create from S with 3, 10, 0, 0
    Let str_schema be proc schema_create from S with 3, sc

    Let v_ok be proc config_value_string from Cfg with "hello"
    Let issues be proc schema_validate from S with v_ok, str_schema
    T.assert_equal(results, "len 5 accepted", proc length from List with issues, 0)
    proc validation_issues_destroy from S with issues

    Let v_short be proc config_value_string from Cfg with "hi"
    Let issues2 be proc schema_validate from S with v_short, str_schema
    T.assert_greater_than(results, "len 2 rejected", proc length from List with issues2, 0)
    proc validation_issues_destroy from S with issues2

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_short
    proc schema_destroy from S with str_schema
    Return 1
End Process

Process called "test_validate_object" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate object")

    Let obj_schema be proc schema_create_object from S
    Let name_str be proc schema_create_string_any from S
    Let f1 be proc object_field_create from S with "name", name_str, 1
    proc schema_object_add_field from S with obj_schema, f1
    Let age_int be proc schema_create_integer_any from S
    Let f2 be proc object_field_create from S with "age", age_int, 0
    proc schema_object_add_field from S with obj_schema, f2

    Let inner be proc create from Dict
    Let name_v be proc config_value_string from Cfg with "Alice"
    proc set from Dict with inner, "name", name_v
    Let obj_v be proc config_value_map from Cfg with inner

    Let issues be proc schema_validate from S with obj_v, obj_schema
    T.assert_equal(results, "name present accepted", proc length from List with issues, 0)
    proc validation_issues_destroy from S with issues

    Let empty_inner be proc create from Dict
    Let empty_v be proc config_value_map from Cfg with empty_inner
    Let issues2 be proc schema_validate from S with empty_v, obj_schema
    T.assert_greater_than(results, "missing name rejected", proc length from List with issues2, 0)
    proc validation_issues_destroy from S with issues2

    proc config_value_destroy from Cfg with obj_v
    proc config_value_destroy from Cfg with empty_v
    proc schema_destroy from S with obj_schema
    Return 1
End Process

Process called "test_validate_enum" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate enum")

    Let en be proc schema_create_enum from S
    proc schema_enum_add_value from S with en, "red"
    proc schema_enum_add_value from S with en, "green"
    proc schema_enum_add_value from S with en, "blue"

    Let v_red be proc config_value_string from Cfg with "red"
    Let issues be proc schema_validate from S with v_red, en
    T.assert_equal(results, "red accepted", proc length from List with issues, 0)
    proc validation_issues_destroy from S with issues

    Let v_purple be proc config_value_string from Cfg with "purple"
    Let issues2 be proc schema_validate from S with v_purple, en
    T.assert_greater_than(results, "purple rejected", proc length from List with issues2, 0)
    proc validation_issues_destroy from S with issues2

    proc config_value_destroy from Cfg with v_red
    proc config_value_destroy from Cfg with v_purple
    proc schema_destroy from S with en
    Return 1
End Process

Process called "test_compose_or" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.compose OR")

    Let s_int be proc schema_create_integer_any from S
    Let s_str be proc schema_create_string_any from S
    Let composed be proc schema_compose from S with s_int, s_str, 2
    T.assert_not_null(results, "composed not null", composed)
    T.assert_equal(results, "compose OR returns union", proc schema_kind from S with composed, 8)

    Let v_int be proc config_value_integer from Cfg with 42
    Let issues be proc schema_validate from S with v_int, composed
    T.assert_equal(results, "integer 42 matches union", proc length from List with issues, 0)
    proc validation_issues_destroy from S with issues

    Let v_str be proc config_value_string from Cfg with "hello"
    Let issues2 be proc schema_validate from S with v_str, composed
    T.assert_equal(results, "string hello matches union", proc length from List with issues2, 0)
    proc validation_issues_destroy from S with issues2

    Let v_bool be proc config_value_bool from Cfg with 1
    Let issues3 be proc schema_validate from S with v_bool, composed
    T.assert_greater_than(results, "boolean rejected by union", proc length from List with issues3, 0)
    proc validation_issues_destroy from S with issues3

    proc config_value_destroy from Cfg with v_int
    proc config_value_destroy from Cfg with v_str
    proc config_value_destroy from Cfg with v_bool
    proc schema_destroy from S with composed
    Return 1
End Process

Process called "test_validate_array_cardinality" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate array cardinality")

    Note: array with minItems=2
    Let item_s be proc schema_create_integer_any from S
    Let arr_min2 be proc schema_create_array from S with item_s, 2, 0 minus 1, 0

    Let lst_ok be proc list_create from List
    proc list_append from List with lst_ok, proc config_value_integer from Cfg with 1
    proc list_append from List with lst_ok, proc config_value_integer from Cfg with 2
    proc list_append from List with lst_ok, proc config_value_integer from Cfg with 3
    Let v_ok be proc config_value_list from Cfg with lst_ok
    Let issues_ok be proc schema_validate from S with v_ok, arr_min2
    T.assert_equal(results, "minItems=2 accepts [1,2,3]", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Let lst_bad be proc list_create from List
    proc list_append from List with lst_bad, proc config_value_integer from Cfg with 1
    Let v_bad be proc config_value_list from Cfg with lst_bad
    Let issues_bad be proc schema_validate from S with v_bad, arr_min2
    T.assert_greater_than(results, "minItems=2 rejects [1]", proc length from List with issues_bad, 0)
    proc validation_issues_destroy from S with issues_bad

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_bad
    proc schema_destroy from S with arr_min2

    Note: array with maxItems=3
    Let item_s2 be proc schema_create_integer_any from S
    Let arr_max3 be proc schema_create_array from S with item_s2, 0 minus 1, 3, 0

    Let lst_ok2 be proc list_create from List
    proc list_append from List with lst_ok2, proc config_value_integer from Cfg with 1
    proc list_append from List with lst_ok2, proc config_value_integer from Cfg with 2
    proc list_append from List with lst_ok2, proc config_value_integer from Cfg with 3
    Let v_ok2 be proc config_value_list from Cfg with lst_ok2
    Let issues_ok2 be proc schema_validate from S with v_ok2, arr_max3
    T.assert_equal(results, "maxItems=3 accepts [1,2,3]", proc length from List with issues_ok2, 0)
    proc validation_issues_destroy from S with issues_ok2

    Let lst_bad2 be proc list_create from List
    proc list_append from List with lst_bad2, proc config_value_integer from Cfg with 1
    proc list_append from List with lst_bad2, proc config_value_integer from Cfg with 2
    proc list_append from List with lst_bad2, proc config_value_integer from Cfg with 3
    proc list_append from List with lst_bad2, proc config_value_integer from Cfg with 4
    Let v_bad2 be proc config_value_list from Cfg with lst_bad2
    Let issues_bad2 be proc schema_validate from S with v_bad2, arr_max3
    T.assert_greater_than(results, "maxItems=3 rejects [1,2,3,4]", proc length from List with issues_bad2, 0)
    proc validation_issues_destroy from S with issues_bad2

    proc config_value_destroy from Cfg with v_ok2
    proc config_value_destroy from Cfg with v_bad2
    proc schema_destroy from S with arr_max3

    Note: array with uniqueItems
    Let item_s3 be proc schema_create_integer_any from S
    Let arr_uniq be proc schema_create_array from S with item_s3, 0 minus 1, 0 minus 1, 1

    Let lst_uniq_ok be proc list_create from List
    proc list_append from List with lst_uniq_ok, proc config_value_integer from Cfg with 1
    proc list_append from List with lst_uniq_ok, proc config_value_integer from Cfg with 2
    proc list_append from List with lst_uniq_ok, proc config_value_integer from Cfg with 3
    Let v_uniq_ok be proc config_value_list from Cfg with lst_uniq_ok
    Let issues_uniq_ok be proc schema_validate from S with v_uniq_ok, arr_uniq
    T.assert_equal(results, "uniqueItems accepts [1,2,3]", proc length from List with issues_uniq_ok, 0)
    proc validation_issues_destroy from S with issues_uniq_ok

    Let lst_dup be proc list_create from List
    proc list_append from List with lst_dup, proc config_value_integer from Cfg with 1
    proc list_append from List with lst_dup, proc config_value_integer from Cfg with 2
    proc list_append from List with lst_dup, proc config_value_integer from Cfg with 1
    Let v_dup be proc config_value_list from Cfg with lst_dup
    Let issues_dup be proc schema_validate from S with v_dup, arr_uniq
    T.assert_greater_than(results, "uniqueItems rejects [1,2,1]", proc length from List with issues_dup, 0)
    proc validation_issues_destroy from S with issues_dup

    proc config_value_destroy from Cfg with v_uniq_ok
    proc config_value_destroy from Cfg with v_dup
    proc schema_destroy from S with arr_uniq
    Return 1
End Process

Process called "test_validate_string_pattern" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate string pattern")

    Note: pattern only constraint (no length, no format)
    Let sc be proc string_constraints_create from S with 0 minus 1, 0 minus 1, "^[a-z]+$", 0
    Let str_schema be proc schema_create from S with 3, sc

    Let v_ok be proc config_value_string from Cfg with "abc"
    Let issues_ok be proc schema_validate from S with v_ok, str_schema
    T.assert_equal(results, "pattern accepts lowercase abc", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Let v_upper be proc config_value_string from Cfg with "ABC"
    Let issues_up be proc schema_validate from S with v_upper, str_schema
    T.assert_greater_than(results, "pattern rejects ABC", proc length from List with issues_up, 0)
    proc validation_issues_destroy from S with issues_up

    Let v_mixed be proc config_value_string from Cfg with "abc123"
    Let issues_mx be proc schema_validate from S with v_mixed, str_schema
    T.assert_greater_than(results, "pattern rejects abc123", proc length from List with issues_mx, 0)
    proc validation_issues_destroy from S with issues_mx

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_upper
    proc config_value_destroy from Cfg with v_mixed
    proc schema_destroy from S with str_schema
    Return 1
End Process

Process called "test_validate_string_format_email" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate string format email")

    Note: FORMAT_EMAIL = 1
    Let sc be proc string_constraints_create from S with 0 minus 1, 0 minus 1, 0, 1
    Let str_schema be proc schema_create from S with 3, sc

    Let v_ok be proc config_value_string from Cfg with "user@example.com"
    Let issues_ok be proc schema_validate from S with v_ok, str_schema
    T.assert_equal(results, "email accepts user@example.com", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok

    Let v_bad be proc config_value_string from Cfg with "not-an-email"
    Let issues_bad be proc schema_validate from S with v_bad, str_schema
    T.assert_greater_than(results, "email rejects not-an-email", proc length from List with issues_bad, 0)
    proc validation_issues_destroy from S with issues_bad

    proc config_value_destroy from Cfg with v_ok
    proc config_value_destroy from Cfg with v_bad
    proc schema_destroy from S with str_schema
    Return 1
End Process

Process called "test_validate_string_format_ipv4" that takes results as Integer returns Integer:
    T.begin_suite(results, "schema.validate string format ipv4")

    Note: FORMAT_IPV4 = 8
    Let sc be proc string_constraints_create from S with 0 minus 1, 0 minus 1, 0, 8
