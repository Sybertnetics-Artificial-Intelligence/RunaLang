Note:
Unit tests for compiler/frontend/primitives/schema/openapi.runa.

KAT: Parse a minimal Petstore-equivalent JSON document and inspect.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/schema/openapi.runa" as OA
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_info_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.info_create")
    Let info be proc info_create from OA with "Petstore", "1.0.0"
    T.assert_not_null(results, "info_create non-null", info)
    Let t be proc info_title from OA with info
    T.assert_equal(results, "title match", (proc string_equals from StringCore with t, "Petstore"), 1)
    Let v be proc info_version from OA with info
    T.assert_equal(results, "version match", (proc string_equals from StringCore with v, "1.0.0"), 1)
    proc info_destroy from OA with info
    Return 1
End Process

Process called "test_spec_create_and_paths" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.spec create + paths")

    Let info be proc info_create from OA with "API", "1.0.0"
    Let spec be proc openapi_spec_create from OA with "3.1.0", info
    T.assert_not_null(results, "spec non-null", spec)

    Let pi be proc path_item_create from OA
    Let op be proc operation_create from OA
    proc operation_set_id from OA with op, "getPets"
    proc path_item_set_operation from OA with pi, 1, op
    proc openapi_spec_add_path from OA with spec, "/pets", pi

    Let retrieved be proc path_item_get_operation from OA with pi, 1
    T.assert_not_null(results, "retrieved get op", retrieved)
    Let oid be proc operation_id from OA with retrieved
    T.assert_equal(results, "operation id", (proc string_equals from StringCore with oid, "getPets"), 1)

    proc openapi_spec_destroy from OA with spec
    Return 1
End Process

Process called "test_parse_minimal" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.parse minimal")

    Let petstore_json be "{\"openapi\":\"3.1.0\",\"info\":{\"title\":\"Petstore\",\"version\":\"1.0.0\"},\"paths\":{\"/pets\":{\"get\":{\"operationId\":\"listPets\",\"responses\":{\"200\":{\"type\":\"array\"}}}}}}"
    Let spec be proc openapi_parse from OA with petstore_json
    T.assert_not_null(results, "parsed", spec)
    If spec is not equal to 0:
        Let ver be proc openapi_spec_version from OA with spec
        T.assert_equal(results, "version 3.1.0", (proc string_equals from StringCore with ver, "3.1.0"), 1)
        Let info be proc openapi_spec_info from OA with spec
        T.assert_not_null(results, "info present", info)
        proc openapi_spec_destroy from OA with spec
    End If
    Return 1
End Process

Process called "test_validate" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.validate")

    Let info be proc info_create from OA with "Test", "1.0"
    Let spec be proc openapi_spec_create from OA with "3.1.0", info
    Let pi be proc path_item_create from OA
    Let op be proc operation_create from OA
    proc operation_set_id from OA with op, "testOp"
    Let response_schema be 0
    proc path_item_set_operation from OA with pi, 1, op
    proc openapi_spec_add_path from OA with spec, "/test", pi

    Let issues be proc openapi_validate from OA with spec
    T.assert_not_null(results, "issues list non-null", issues)
    Let icount be proc length from List with issues
    T.assert_greater_than(results, "no responses -> at least 1 issue", icount, 0)
    proc list_destroy from List with issues
    proc openapi_spec_destroy from OA with spec
    Return 1
End Process

Process called "test_in_name_to_constant" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.in_name_to_constant")
    T.assert_equal(results, "query -> 1", (proc in_name_to_constant from OA with "query"),1)
    T.assert_equal(results, "header -> 2", (proc in_name_to_constant from OA with "header"),2)
    T.assert_equal(results, "path -> 3", (proc in_name_to_constant from OA with "path"),3)
    T.assert_equal(results, "cookie -> 4", (proc in_name_to_constant from OA with "cookie"),4)
    Return 1
End Process

Process called "test_client_stub_generation" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.openapi_to_typed_client_stub")
    Let info be proc info_create from OA with "T", "0.1"
    Let spec be proc openapi_spec_create from OA with "3.1.0", info
    Let pi be proc path_item_create from OA
    Let op be proc operation_create from OA
    proc operation_set_id from OA with op, "fetchAll"
    proc path_item_set_operation from OA with pi, 1, op
    proc openapi_spec_add_path from OA with spec, "/items", pi

    Let stub be proc openapi_to_typed_client_stub from OA with spec
    T.assert_not_null(results, "stub non-null", stub)
    proc openapi_spec_destroy from OA with spec
    Return 1
End Process

Process called "test_parse_complete_petstore" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.parse complete petstore (info+components+security+tags+externalDocs)")

    Let json_text be "{\"openapi\":\"3.1.0\",\"info\":{\"title\":\"Pet Store\",\"version\":\"1.0.0\",\"description\":\"Pet store sample API\",\"termsOfService\":\"https://example.com/tos\",\"contact\":{\"name\":\"API Team\",\"url\":\"https://example.com/team\",\"email\":\"team@example.com\"},\"license\":{\"name\":\"Apache 2.0\",\"url\":\"https://www.apache.org/licenses/LICENSE-2.0.html\"},\"summary\":\"PS\"},\"servers\":[{\"url\":\"https://api.example.com\"}],\"paths\":{\"/pets\":{\"get\":{\"operationId\":\"listPets\",\"summary\":\"List pets\",\"description\":\"Return all pets\",\"deprecated\":false,\"tags\":[\"pets\"],\"responses\":{\"200\":{\"type\":\"array\"}}}}},\"components\":{\"schemas\":{\"Pet\":{\"type\":\"object\"}}},\"security\":[{\"api_key\":[]}],\"tags\":[{\"name\":\"pets\",\"description\":\"Pet operations\"}],\"externalDocs\":{\"description\":\"Find more info\",\"url\":\"https://example.com/docs\"}}"

    Let spec be proc openapi_parse from OA with json_text
    T.assert_not_null(results, "parse spec non-null", spec)
    If spec is equal to 0:
        Return 0
    End If

    Note: Verify openapi version
    Let ver be proc openapi_spec_version from OA with spec
    T.assert_equal(results, "openapi 3.1.0", (proc string_equals from StringCore with ver, "3.1.0"), 1)

    Note: Verify info section completions
    Let info be proc openapi_spec_info from OA with spec
    T.assert_not_null(results, "info populated", info)
    Let info_desc be proc info_description from OA with info
    T.assert_not_null(results, "info.description present", info_desc)
    T.assert_equal(results, "info.description value", (proc string_equals from StringCore with info_desc, "Pet store sample API"), 1)
    Let info_tos be proc info_terms_of_service from OA with info
    T.assert_not_null(results, "info.termsOfService present", info_tos)
    T.assert_equal(results, "info.termsOfService value", (proc string_equals from StringCore with info_tos, "https://example.com/tos"), 1)
    Let info_sum be proc info_summary from OA with info
    T.assert_not_null(results, "info.summary present", info_sum)

    Note: Contact
    Let contact be proc info_contact from OA with info
    T.assert_not_null(results, "info.contact present", contact)
    If contact is not equal to 0:
        Let cn be proc contact_name from OA with contact
        T.assert_equal(results, "contact.name", (proc string_equals from StringCore with cn, "API Team"), 1)
        Let ce be proc contact_email from OA with contact
        T.assert_equal(results, "contact.email", (proc string_equals from StringCore with ce, "team@example.com"), 1)
    End If

    Note: License
    Let license be proc info_license from OA with info
    T.assert_not_null(results, "info.license present", license)
    If license is not equal to 0:
        Let ln be proc license_name from OA with license
        T.assert_equal(results, "license.name", (proc string_equals from StringCore with ln, "Apache 2.0"), 1)
        Let lu be proc license_url from OA with license
        T.assert_not_null(results, "license.url present", lu)
    End If

    Note: Components
    Let components be proc openapi_spec_components from OA with spec
    T.assert_not_null(results, "components populated", components)

    Note: Security
    Let security be proc openapi_spec_security from OA with spec
    T.assert_not_null(results, "security populated", security)
    If security is not equal to 0:
        Let sec_count be proc length from List with security
        T.assert_equal(results, "security count = 1", sec_count, 1)
    End If

    Note: Tags
    Let tags be proc openapi_spec_tags from OA with spec
    T.assert_not_null(results, "tags populated", tags)
    If tags is not equal to 0:
        Let tag_count be proc length from List with tags
        T.assert_equal(results, "tags count = 1", tag_count, 1)
        Let first_tag be proc list_get from List with tags, 0
        T.assert_not_null(results, "first tag present", first_tag)
        If first_tag is not equal to 0:
            Let tn be proc tag_name from OA with first_tag
            T.assert_equal(results, "tag.name = pets", (proc string_equals from StringCore with tn, "pets"), 1)
            Let td be proc tag_description from OA with first_tag
            T.assert_equal(results, "tag.description = Pet operations", (proc string_equals from StringCore with td, "Pet operations"), 1)
        End If
    End If

    Note: ExternalDocs
    Let ed be proc openapi_spec_external_docs from OA with spec
    T.assert_not_null(results, "externalDocs populated", ed)
    If ed is not equal to 0:
        Let eu be proc external_docs_url from OA with ed
        T.assert_equal(results, "externalDocs.url", (proc string_equals from StringCore with eu, "https://example.com/docs"), 1)
        Let edesc be proc external_docs_description from OA with ed
        T.assert_equal(results, "externalDocs.description", (proc string_equals from StringCore with edesc, "Find more info"), 1)
    End If

    Note: Operation completions on /pets get
    Let paths_dict be proc openapi_spec_paths from OA with spec
    Let pi be proc get from Dict with paths_dict, "/pets"
    T.assert_not_null(results, "path /pets present", pi)
    If pi is not equal to 0:
        Let get_op be proc path_item_get_operation from OA with pi, 1
        T.assert_not_null(results, "GET /pets present", get_op)
        If get_op is not equal to 0:
            Let opsum be proc operation_summary from OA with get_op
            T.assert_equal(results, "op.summary = List pets", (proc string_equals from StringCore with opsum, "List pets"), 1)
            Let opdesc be proc operation_description from OA with get_op
            T.assert_equal(results, "op.description = Return all pets", (proc string_equals from StringCore with opdesc, "Return all pets"), 1)
            Let optags be proc operation_tags from OA with get_op
            T.assert_not_null(results, "op.tags present", optags)
            If optags is not equal to 0:
                Let otc be proc length from List with optags
                T.assert_equal(results, "op.tags count = 1", otc, 1)
            End If
        End If
    End If

    proc openapi_spec_destroy from OA with spec
    Return 1
End Process

Process called "test_contact_create_destroy" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.contact create/destroy")
    Let c be proc contact_create from OA with "Alice", "https://x/", "alice@x"
    T.assert_not_null(results, "contact non-null", c)
    Let n be proc contact_name from OA with c
    T.assert_equal(results, "contact.name", (proc string_equals from StringCore with n, "Alice"), 1)
    Let u be proc contact_url from OA with c
    T.assert_equal(results, "contact.url", (proc string_equals from StringCore with u, "https://x/"), 1)
    Let e be proc contact_email from OA with c
    T.assert_equal(results, "contact.email", (proc string_equals from StringCore with e, "alice@x"), 1)
    proc contact_destroy from OA with c
    Return 1
End Process

Process called "test_license_requires_name" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.license requires name")
    Let l_ok be proc license_create from OA with "MIT", 0, 0
    T.assert_not_null(results, "license with just name", l_ok)
    proc license_destroy from OA with l_ok
    Let l_bad be proc license_create from OA with 0, 0, 0
    T.assert_equal(results, "license with no name returns 0", l_bad, 0)
    Return 1
End Process

Process called "test_external_docs_requires_url" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.external_docs requires url")
    Let ed be proc external_docs_create from OA with "doc", "https://docs.example/"
    T.assert_not_null(results, "external_docs with url+desc", ed)
    Let u be proc external_docs_url from OA with ed
    T.assert_equal(results, "ed.url match", (proc string_equals from StringCore with u, "https://docs.example/"), 1)
    proc external_docs_destroy from OA with ed
    Let bad be proc external_docs_create from OA with "doc", 0
    T.assert_equal(results, "external_docs with no url returns 0", bad, 0)
    Return 1
End Process

Process called "test_tag_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.tag create")
    Let ed be proc external_docs_create from OA with "tag docs", "https://docs/"
    Let t be proc tag_create from OA with "users", "User operations", ed
    T.assert_not_null(results, "tag non-null", t)
    Let n be proc tag_name from OA with t
    T.assert_equal(results, "tag.name", (proc string_equals from StringCore with n, "users"), 1)
    Let d be proc tag_description from OA with t
    T.assert_equal(results, "tag.description", (proc string_equals from StringCore with d, "User operations"), 1)
    Let edr be proc tag_external_docs from OA with t
    T.assert_not_null(results, "tag.externalDocs", edr)
    proc tag_destroy from OA with t
    Return 1
End Process

Process called "test_components_categories" that takes results as Integer returns Integer:
    T.begin_suite(results, "openapi.components category dicts")
    Let c be proc components_create from OA
    T.assert_not_null(results, "components non-null", c)
    T.assert_not_null(results, "schemas dict", proc components_schemas from OA with c)
    T.assert_not_null(results, "responses dict", proc components_responses from OA with c)
    T.assert_not_null(results, "parameters dict", proc components_parameters from OA with c)
    T.assert_not_null(results, "examples dict", proc components_examples from OA with c)
    T.assert_not_null(results, "request_bodies dict", proc components_request_bodies from OA with c)
    T.assert_not_null(results, "headers dict", proc components_headers from OA with c)
    T.assert_not_null(results, "security_schemes dict", proc components_security_schemes from OA with c)
    T.assert_not_null(results, "links dict", proc components_links from OA with c)
    T.assert_not_null(results, "callbacks dict", proc components_callbacks from OA with c)
    T.assert_not_null(results, "path_items dict", proc components_path_items from OA with c)
    proc components_destroy from OA with c
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_info_create(results)
    test_spec_create_and_paths(results)
    test_parse_minimal(results)
    test_validate(results)
    test_in_name_to_constant(results)
    test_client_stub_generation(results)
    test_contact_create_destroy(results)
    test_license_requires_name(results)
    test_external_docs_requires_url(results)
    test_tag_create(results)
    test_components_categories(results)
    test_parse_complete_petstore(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
