Note:
Unit tests for compiler/frontend/primitives/schema/idl.runa.

KAT: protobuf "message Foo { int32 x = 1; string s = 2; }" round-trip.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/schema/idl.runa" as IDL
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_document_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "idl.document_create")
    Let d be proc idl_document_create from IDL
    T.assert_not_null(results, "doc not null", d)
    Let ms be proc idl_document_messages from IDL with d
    T.assert_not_null(results, "messages list", ms)
    T.assert_equal(results, "empty messages", (proc length from List with ms),0)
    proc idl_document_destroy from IDL with d
    Return 1
End Process

Process called "test_message_and_field" that takes results as Integer returns Integer:
    T.begin_suite(results, "idl.message_create / field_create")
    Let m be proc idl_message_create from IDL with "Foo"
    T.assert_not_null(results, "msg created", m)
    Let f1 be proc idl_field_create from IDL with "x", "int32", 1, 1
    Let f2 be proc idl_field_create from IDL with "s", "string", 2, 1
    proc idl_message_add_field from IDL with m, f1
    proc idl_message_add_field from IDL with m, f2
    Let fields be proc idl_message_fields from IDL with m
    T.assert_equal(results, "two fields", (proc length from List with fields),2)
    T.assert_equal(results, "f1 tag = 1", (proc idl_field_tag from IDL with f1),1)
    T.assert_equal(results, "f2 tag = 2", (proc idl_field_tag from IDL with f2),2)
    proc idl_message_destroy from IDL with m
    Return 1
End Process

Process called "test_protobuf_parse_message" that takes results as Integer returns Integer:
    T.begin_suite(results, "idl.parse_protobuf message")
    Let source be "message Foo { int32 x = 1; string s = 2; }"
    Let doc be proc idl_parse_protobuf from IDL with source
    T.assert_not_null(results, "parsed doc", doc)
    Let ms be proc idl_document_messages from IDL with doc
    T.assert_equal(results, "1 message", (proc length from List with ms),1)
    Let m be proc list_get from List with ms, 0
    T.assert_not_null(results, "Foo message exists", m)
    Let nm be proc idl_message_name from IDL with m
    T.assert_equal(results, "name Foo", (proc string_equals from StringCore with nm, "Foo"), 1)
    Let fields be proc idl_message_fields from IDL with m
    T.assert_equal(results, "2 fields", (proc length from List with fields),2)
    proc idl_document_destroy from IDL with doc
    Return 1
End Process

Process called "test_protobuf_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "idl.parse + serialize protobuf round-trip")
    Let source be "message Foo { int32 x = 1; string s = 2; }"
    Let doc be proc idl_parse_protobuf from IDL with source
    T.assert_not_null(results, "parsed", doc)
    Let out be proc idl_serialize_protobuf from IDL with doc
    T.assert_not_null(results, "serialized", out)
    Let doc2 be proc idl_parse_protobuf from IDL with out
    T.assert_not_null(results, "re-parsed", doc2)
    Let ms2 be proc idl_document_messages from IDL with doc2
    T.assert_equal(results, "still 1 message", (proc length from List with ms2),1)
    proc idl_document_destroy from IDL with doc
    proc idl_document_destroy from IDL with doc2
    Return 1
End Process

Process called "test_protobuf_enum" that takes results as Integer returns Integer:
    T.begin_suite(results, "idl.parse_protobuf enum")
    Let source be "enum Color { RED = 0; GREEN = 1; BLUE = 2; }"
    Let doc be proc idl_parse_protobuf from IDL with source
    T.assert_not_null(results, "parsed", doc)
    Let es be proc idl_document_enums from IDL with doc
    T.assert_equal(results, "1 enum", (proc length from List with es),1)
    Let e be proc list_get from List with es, 0
    Let vs be proc idl_enum_values from IDL with e
    T.assert_equal(results, "3 enum values", (proc length from List with vs),3)
    proc idl_document_destroy from IDL with doc
    Return 1
End Process

Process called "test_protobuf_service" that takes results as Integer returns Integer:
    T.begin_suite(results, "idl.parse_protobuf service")
    Let source be "service Greeter { rpc SayHello (HelloRequest) returns (HelloReply); }"
    Let doc be proc idl_parse_protobuf from IDL with source
    T.assert_not_null(results, "parsed", doc)
    Let ss be proc idl_document_services from IDL with doc
    T.assert_equal(results, "1 service", (proc length from List with ss),1)
    proc idl_document_destroy from IDL with doc
    Return 1
End Process

Process called "test_type_map" that takes results as Integer returns Integer:
    T.begin_suite(results, "idl.map_idl_type_to_runa")
    Let r1 be proc map_idl_type_to_runa from IDL with "int32"
    T.assert_equal(results, "int32->Integer", (proc string_equals from StringCore with r1, "Integer"), 1)
    Let r2 be proc map_idl_type_to_runa from IDL with "string"
    T.assert_equal(results, "string->String", (proc string_equals from StringCore with r2, "String"), 1)
    Let r3 be proc map_idl_type_to_runa from IDL with "bool"
    T.assert_equal(results, "bool->Boolean", (proc string_equals from StringCore with r3, "Boolean"), 1)
    Let r4 be proc map_idl_type_to_runa from IDL with "float"
    T.assert_equal(results, "float->Float", (proc string_equals from StringCore with r4, "Float"), 1)
    Return 1
End Process

Process called "test_to_runa_types" that takes results as Integer returns Integer:
    T.begin_suite(results, "idl.idl_to_runa_types")
    Let doc be proc idl_parse_protobuf from IDL with "message Foo { int32 x = 1; }"
    Let runa_text be proc idl_to_runa_types from IDL with doc
    T.assert_not_null(results, "non-null output", runa_text)
    proc idl_document_destroy from IDL with doc
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_document_create(results)
    test_message_and_field(results)
    test_protobuf_parse_message(results)
    test_protobuf_roundtrip(results)
    test_protobuf_enum(results)
    test_protobuf_service(results)
    test_type_map(results)
    test_to_runa_types(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
