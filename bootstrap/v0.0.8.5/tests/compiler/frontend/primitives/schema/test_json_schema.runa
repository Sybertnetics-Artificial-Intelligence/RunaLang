Note:
Unit tests for compiler/frontend/primitives/schema/json_schema.runa.

KAT: {"type":"integer","minimum":0} accepts 5, rejects -1, rejects "5".
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/schema/json_schema.runa" as JS
Import "compiler/frontend/primitives/schema/schema.runa" as S
Import "compiler/frontend/primitives/config/config.runa" as Cfg
Import "compiler/frontend/primitives/collections/list.runa" as List

Process called "test_json_to_cv_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "json_schema.json_to_config_value basic")

    Let cv be proc json_to_config_value from JS with "42"
    T.assert_not_null(results, "parse 42", cv)
    T.assert_equal(results, "kind integer", proc config_value_kind from Cfg with cv, 2)
    T.assert_equal(results, "value 42", proc config_value_as_integer from Cfg with cv, 42)
    proc config_value_destroy from Cfg with cv

    Let cv2 be proc json_to_config_value from JS with "true"
    T.assert_not_null(results, "parse true", cv2)
    T.assert_equal(results, "kind bool", proc config_value_kind from Cfg with cv2, 4)
    T.assert_equal(results, "value true", proc config_value_as_bool from Cfg with cv2, 1)
    proc config_value_destroy from Cfg with cv2

    Let cv3 be proc json_to_config_value from JS with "\"hello\""
    T.assert_not_null(results, "parse string", cv3)
    T.assert_equal(results, "kind string", proc config_value_kind from Cfg with cv3, 1)
    proc config_value_destroy from Cfg with cv3

    Let cv4 be proc json_to_config_value from JS with "null"
    T.assert_not_null(results, "parse null", cv4)
    T.assert_equal(results, "kind null", proc config_value_kind from Cfg with cv4, 0)
    proc config_value_destroy from Cfg with cv4

    Return 1
End Process

Process called "test_json_to_cv_array_object" that takes results as Integer returns Integer:
    T.begin_suite(results, "json_schema.json_to_config_value arrays and objects")

    Let cv be proc json_to_config_value from JS with "[1,2,3]"
    T.assert_not_null(results, "parse [1,2,3]", cv)
    T.assert_equal(results, "kind list", proc config_value_kind from Cfg with cv, 5)
    Let lst be proc config_value_as_list from Cfg with cv
    T.assert_equal(results, "length 3", proc length from List with lst, 3)
    proc config_value_destroy from Cfg with cv

    Let cv2 be proc json_to_config_value from JS with "{\"a\":1,\"b\":2}"
    T.assert_not_null(results, "parse {a:1,b:2}", cv2)
    T.assert_equal(results, "kind map", proc config_value_kind from Cfg with cv2, 6)
    proc config_value_destroy from Cfg with cv2

    Return 1
End Process

Process called "test_json_schema_parse_simple" that takes results as Integer returns Integer:
    T.begin_suite(results, "json_schema.json_schema_parse simple")

    Let schema be proc json_schema_parse from JS with "{\"type\":\"integer\",\"minimum\":0}"
    T.assert_not_null(results, "parse integer schema", schema)
    T.assert_equal(results, "schema kind integer", proc schema_kind from S with schema, 4)
    proc schema_destroy from S with schema

    Let s2 be proc json_schema_parse from JS with "{\"type\":\"string\"}"
    T.assert_not_null(results, "parse string schema", s2)
    T.assert_equal(results, "schema kind string", proc schema_kind from S with s2, 3)
    proc schema_destroy from S with s2

    Let s3 be proc json_schema_parse from JS with "{\"type\":\"boolean\"}"
    T.assert_not_null(results, "parse boolean schema", s3)
    T.assert_equal(results, "schema kind boolean", proc schema_kind from S with s3, 6)
    proc schema_destroy from S with s3

    Return 1
End Process

Process called "test_kat_integer_minimum" that takes results as Integer returns Integer:
    T.begin_suite(results, "json_schema KAT: integer minimum=0")

    Let schema be proc json_schema_parse from JS with "{\"type\":\"integer\",\"minimum\":0}"
    T.assert_not_null(results, "schema parsed", schema)

    Let v5 be proc json_to_config_value from JS with "5"
    Let issues_5 be proc schema_validate from S with v5, schema
    T.assert_equal(results, "5 accepted", proc length from List with issues_5, 0)
    proc validation_issues_destroy from S with issues_5
    proc config_value_destroy from Cfg with v5

    Let vneg be proc json_to_config_value from JS with "-1"
    Let issues_neg be proc schema_validate from S with vneg, schema
    T.assert_greater_than(results, "-1 rejected", proc length from List with issues_neg, 0)
    proc validation_issues_destroy from S with issues_neg
    proc config_value_destroy from Cfg with vneg

    Let vstr be proc json_to_config_value from JS with "\"5\""
    Let issues_str be proc schema_validate from S with vstr, schema
    T.assert_greater_than(results, "string \"5\" rejected", proc length from List with issues_str, 0)
    proc validation_issues_destroy from S with issues_str
    proc config_value_destroy from Cfg with vstr

    proc schema_destroy from S with schema
    Return 1
End Process

Process called "test_json_schema_serialize" that takes results as Integer returns Integer:
    T.begin_suite(results, "json_schema.json_schema_serialize")

    Let s be proc json_schema_parse from JS with "{\"type\":\"integer\"}"
    Let out be proc json_schema_serialize from JS with s
    T.assert_not_null(results, "integer serialize non-null", out)
    proc schema_destroy from S with s

    Let s2 be proc json_schema_parse from JS with "{\"type\":\"string\"}"
    Let out2 be proc json_schema_serialize from JS with s2
    T.assert_not_null(results, "string serialize non-null", out2)
    proc schema_destroy from S with s2

    Return 1
End Process

Process called "test_json_object_with_required" that takes results as Integer returns Integer:
    T.begin_suite(results, "json_schema object with required")

    Let schema_text be "{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"},\"age\":{\"type\":\"integer\"}},\"required\":[\"name\"]}"
    Let schema be proc json_schema_parse from JS with schema_text
    T.assert_not_null(results, "schema parsed", schema)
    T.assert_equal(results, "kind object", proc schema_kind from S with schema, 1)

    Let v_full be proc json_to_config_value from JS with "{\"name\":\"Alice\",\"age\":30}"
    Let issues_ok be proc schema_validate from S with v_full, schema
    T.assert_equal(results, "complete obj accepted", proc length from List with issues_ok, 0)
    proc validation_issues_destroy from S with issues_ok
    proc config_value_destroy from Cfg with v_full

    Let v_partial be proc json_to_config_value from JS with "{\"age\":30}"
    Let issues_partial be proc schema_validate from S with v_partial, schema
    T.assert_greater_than(results, "missing name rejected", proc length from List with issues_partial, 0)
    proc validation_issues_destroy from S with issues_partial
    proc config_value_destroy from Cfg with v_partial

    proc schema_destroy from S with schema
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_json_to_cv_basic(results)
    test_json_to_cv_array_object(results)
    test_json_schema_parse_simple(results)
    test_kat_integer_minimum(results)
    test_json_schema_serialize(results)
    test_json_object_with_required(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
