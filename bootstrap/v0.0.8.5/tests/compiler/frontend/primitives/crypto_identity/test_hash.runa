Note:
Known-answer tests for crypto_identity/hash.runa.

SHA-256 of "abc" (per FIPS 180-4 Appendix B.1):
  ba7816bf 8f01cfea 414140de 5dae2223
  b00361a3 96177a9c b410ff61 f20015ad

SHA-512 of "abc" (per FIPS 180-4 Appendix C.1):
  ddaf35a193617aba cc417349ae204131 12e6fa4e89a97ea2 0a9eeee64b55d39a
  2192992a274fc1a8 36ba3c23a3feebbd 454d4423643ce80e 2a9ac94fa54ca49f

Cross-algorithm equality rejection: a SHA-256 hash and a SHA3-256 hash
of identical bytes must compare unequal because their algorithm tags
differ.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/crypto_algorithm.runa" as Alg
Import "compiler/frontend/primitives/crypto_identity/hash.runa" as Hash

Process called "set_abc_message" takes buf as Integer returns Integer:
    Memory.memory_set_byte(buf, 0, 97)
    Memory.memory_set_byte(buf, 1, 98)
    Memory.memory_set_byte(buf, 2, 99)
    Return 1
End Process

Process called "test_sha256_known_answer" takes results as Integer returns Integer:
    T.begin_suite(results, "hash_compute: SHA-256 of abc (FIPS 180-4 B.1)")
    Let arena be Arena.arena_create(1048576)
    Let msg be Arena.arena_allocate(arena, 3)
    set_abc_message(msg)
    Let h be Hash.hash_compute(arena, Alg.ALG_SHA2_256, msg, 3)
    T.assert_not_null(results, "hash_compute returns non-null", h)
    T.assert_equal(results, "hash carries SHA2_256 tag", Hash.hash_algorithm(h), Alg.ALG_SHA2_256)
    T.assert_equal(results, "digest length is 32", Hash.hash_digest_byte_length(h), 32)
    Let dig be Hash.hash_digest_bytes(h)
    Note: First byte: 0xba = 186.
    T.assert_equal(results, "digest[0] = 0xba", Memory.memory_get_byte(dig, 0), 186)
    Note: Second byte: 0x78 = 120.
    T.assert_equal(results, "digest[1] = 0x78", Memory.memory_get_byte(dig, 1), 120)
    Note: Last byte: 0xad = 173.
    T.assert_equal(results, "digest[31] = 0xad", Memory.memory_get_byte(dig, 31), 173)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_sha512_known_answer" takes results as Integer returns Integer:
    T.begin_suite(results, "hash_compute: SHA-512 of abc (FIPS 180-4 C.1)")
    Let arena be Arena.arena_create(2097152)
    Let msg be Arena.arena_allocate(arena, 3)
    set_abc_message(msg)
    Let h be Hash.hash_compute(arena, Alg.ALG_SHA2_512, msg, 3)
    T.assert_not_null(results, "hash_compute returns non-null", h)
    T.assert_equal(results, "digest length is 64", Hash.hash_digest_byte_length(h), 64)
    Let dig be Hash.hash_digest_bytes(h)
    Note: First byte: 0xdd = 221.
    T.assert_equal(results, "digest[0] = 0xdd", Memory.memory_get_byte(dig, 0), 221)
    Note: Last byte: 0x9f = 159.
    T.assert_equal(results, "digest[63] = 0x9f", Memory.memory_get_byte(dig, 63), 159)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_cross_algorithm_equality_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "hash_equal: rejects cross-algorithm comparison")
    Let arena be Arena.arena_create(1048576)
    Let msg be Arena.arena_allocate(arena, 3)
    set_abc_message(msg)
    Let h_sha2 be Hash.hash_compute(arena, Alg.ALG_SHA2_256, msg, 3)
    Let h_sha3 be Hash.hash_compute(arena, Alg.ALG_SHA3_256, msg, 3)
    T.assert_not_null(results, "SHA-256 hash exists", h_sha2)
    T.assert_not_null(results, "SHA3-256 hash exists", h_sha3)
    Let eq be Hash.hash_equal(h_sha2, h_sha3)
    T.assert_equal(results, "SHA-256(abc) != SHA3-256(abc)", eq, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_same_algorithm_equality_works" takes results as Integer returns Integer:
    T.begin_suite(results, "hash_equal: same-algorithm equality holds")
    Let arena be Arena.arena_create(1048576)
    Let msg be Arena.arena_allocate(arena, 3)
    set_abc_message(msg)
    Let h1 be Hash.hash_compute(arena, Alg.ALG_SHA2_256, msg, 3)
    Let h2 be Hash.hash_compute(arena, Alg.ALG_SHA2_256, msg, 3)
    Let eq be Hash.hash_equal(h1, h2)
    T.assert_equal(results, "SHA-256(abc) == SHA-256(abc)", eq, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_hash_create_rejects_wrong_length" takes results as Integer returns Integer:
    T.begin_suite(results, "hash_create: rejects mismatched byte length")
    Let arena be Arena.arena_create(1048576)
    Let buf be Arena.arena_allocate(arena, 32)
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(buf, i, 0)
        Set i to i plus 1
    End While
    Note: Claim it's SHA2_512 (which needs 64 bytes).
    Let h be Hash.hash_create(arena, Alg.ALG_SHA2_512, buf, 32)
    T.assert_equal(results, "SHA-512 with 32 bytes rejected", h, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_hash_create_rejects_non_hash_alg" takes results as Integer returns Integer:
    T.begin_suite(results, "hash_create: rejects non-hash algorithm tag")
    Let arena be Arena.arena_create(1048576)
    Let buf be Arena.arena_allocate(arena, 32)
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(buf, i, 1)
        Set i to i plus 1
    End While
    Let h be Hash.hash_create(arena, Alg.ALG_ED25519, buf, 32)
    T.assert_equal(results, "Ed25519 tag for a hash rejected", h, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_sha256_known_answer(results)
    test_sha512_known_answer(results)
    test_cross_algorithm_equality_rejected(results)
    test_same_algorithm_equality_works(results)
    test_hash_create_rejects_wrong_length(results)
    test_hash_create_rejects_non_hash_alg(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
