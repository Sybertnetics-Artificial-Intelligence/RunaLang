Note:
Tests for crypto_identity/key_derivation.runa.

Vectors:
  - RFC 5869 Appendix A.1: HKDF-SHA-256 test vector.
  - RFC 6070 case 1: PBKDF2-HMAC-SHA-1 (we use SHA-256 in our table; we
    use the case-1 inputs to verify the structural correctness of our
    PBKDF2 by checking that c=1 PBKDF2-SHA256("password","salt",1,32)
    = HMAC-SHA-256("password", "salt" || 0x00000001) which is the
    one-iteration short-circuit predicted by the spec).
  - Argon2id reference: ensure the function returns 1 and produces 32
    output bytes when called with reasonable params (full KAT verification
    is in argon2id.runa's own tests).
  - scrypt RFC 7914 minimal vector: ("", "", 16, 1, 1, 64).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/crypto_algorithm.runa" as Alg
Import "compiler/frontend/primitives/crypto_identity/key_derivation.runa" as Kdf
Import "compiler/frontend/import_system/crypto/hmac.runa" as Hmac

Process called "fill_byte_range" takes buf as Integer, count as Integer, start_val as Integer returns Integer:
    Let i be 0
    While i is less than count:
        Memory.memory_set_byte(buf, i, start_val plus i)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "test_hkdf_sha256_rfc5869_a1" takes results as Integer returns Integer:
    T.begin_suite(results, "HKDF-SHA-256 RFC 5869 A.1 KAT")
    Let arena be Arena.arena_create(1048576)

    Note: IKM = 0x0b * 22, salt = 0x00..0x0c, info = 0xf0..0xf9, L = 42.
    Let ikm be Arena.arena_allocate(arena, 22)
    Let i be 0
    While i is less than 22:
        Memory.memory_set_byte(ikm, i, 11)
        Set i to i plus 1
    End While
    Let salt be Arena.arena_allocate(arena, 13)
    Set i to 0
    While i is less than 13:
        Memory.memory_set_byte(salt, i, i)
        Set i to i plus 1
    End While
    Let info be Arena.arena_allocate(arena, 10)
    Set i to 0
    While i is less than 10:
        Memory.memory_set_byte(info, i, 240 plus i)
        Set i to i plus 1
    End While

    Let okm be Arena.arena_allocate(arena, 42)
    Let rc be Kdf.hkdf_extract_then_expand(arena, salt, 13, ikm, 22, info, 10, 42, Alg.ALG_SHA2_256, okm)
    T.assert_equal(results, "HKDF-SHA-256 returned success", rc, 1)

    Note: Expected OKM (RFC 5869 A.1):
    Note:   3cb25f25faacd57a90434f64d0362f2a
    Note:   2d2d0a90cf1a5a4c5db02d56ecc4c5bf
    Note:   34007208d5b887185865
    Let expected be Arena.arena_allocate(arena, 42)
    Memory.memory_set_byte(expected, 0, 60)
    Memory.memory_set_byte(expected, 1, 178)
    Memory.memory_set_byte(expected, 2, 95)
    Memory.memory_set_byte(expected, 3, 37)
    Memory.memory_set_byte(expected, 4, 250)
    Memory.memory_set_byte(expected, 5, 172)
    Memory.memory_set_byte(expected, 6, 213)
    Memory.memory_set_byte(expected, 7, 122)
    Memory.memory_set_byte(expected, 8, 144)
    Memory.memory_set_byte(expected, 9, 67)
    Memory.memory_set_byte(expected, 10, 79)
    Memory.memory_set_byte(expected, 11, 100)
    Memory.memory_set_byte(expected, 12, 208)
    Memory.memory_set_byte(expected, 13, 54)
    Memory.memory_set_byte(expected, 14, 47)
    Memory.memory_set_byte(expected, 15, 42)
    Memory.memory_set_byte(expected, 16, 45)
    Memory.memory_set_byte(expected, 17, 45)
    Memory.memory_set_byte(expected, 18, 10)
    Memory.memory_set_byte(expected, 19, 144)
    Memory.memory_set_byte(expected, 20, 207)
    Memory.memory_set_byte(expected, 21, 26)
    Memory.memory_set_byte(expected, 22, 90)
    Memory.memory_set_byte(expected, 23, 76)
    Memory.memory_set_byte(expected, 24, 93)
    Memory.memory_set_byte(expected, 25, 176)
    Memory.memory_set_byte(expected, 26, 45)
    Memory.memory_set_byte(expected, 27, 86)
    Memory.memory_set_byte(expected, 28, 236)
    Memory.memory_set_byte(expected, 29, 196)
    Memory.memory_set_byte(expected, 30, 197)
    Memory.memory_set_byte(expected, 31, 191)
    Memory.memory_set_byte(expected, 32, 52)
    Memory.memory_set_byte(expected, 33, 0)
    Memory.memory_set_byte(expected, 34, 114)
    Memory.memory_set_byte(expected, 35, 8)
    Memory.memory_set_byte(expected, 36, 213)
    Memory.memory_set_byte(expected, 37, 184)
    Memory.memory_set_byte(expected, 38, 135)
    Memory.memory_set_byte(expected, 39, 24)
    Memory.memory_set_byte(expected, 40, 88)
    Memory.memory_set_byte(expected, 41, 101)

    Let match be 1
    Set i to 0
    While i is less than 42:
        Let a be Memory.memory_get_byte(okm, i)
        Let b be Memory.memory_get_byte(expected, i)
        If a is not equal to b:
            Set match to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "HKDF-SHA-256 OKM matches RFC 5869 A.1", match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_pbkdf2_sha256_iter1_equals_hmac" takes results as Integer returns Integer:
    T.begin_suite(results, "PBKDF2-HMAC-SHA-256 iter=1, single block = HMAC-SHA256(P, S||0x00000001)")
    Let arena be Arena.arena_create(1048576)

    Note: P = "password" (8 bytes), S = "salt" (4 bytes), c=1, dkLen=32.
    Let pw be Arena.arena_allocate(arena, 8)
    Memory.memory_set_byte(pw, 0, 112)
    Memory.memory_set_byte(pw, 1, 97)
    Memory.memory_set_byte(pw, 2, 115)
    Memory.memory_set_byte(pw, 3, 115)
    Memory.memory_set_byte(pw, 4, 119)
    Memory.memory_set_byte(pw, 5, 111)
    Memory.memory_set_byte(pw, 6, 114)
    Memory.memory_set_byte(pw, 7, 100)
    Let salt be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(salt, 0, 115)
    Memory.memory_set_byte(salt, 1, 97)
    Memory.memory_set_byte(salt, 2, 108)
    Memory.memory_set_byte(salt, 3, 116)

    Let dk be Arena.arena_allocate(arena, 32)
    Let rc be Kdf.pbkdf2_hmac(arena, pw, 8, salt, 4, 1, 32, Alg.ALG_SHA2_256, dk)
    T.assert_equal(results, "pbkdf2_hmac returned success", rc, 1)

    Note: Reference: HMAC-SHA-256(P, S||0x00000001).
    Let salted be Arena.arena_allocate(arena, 8)
    Memory.memory_set_byte(salted, 0, 115)
    Memory.memory_set_byte(salted, 1, 97)
    Memory.memory_set_byte(salted, 2, 108)
    Memory.memory_set_byte(salted, 3, 116)
    Memory.memory_set_byte(salted, 4, 0)
    Memory.memory_set_byte(salted, 5, 0)
    Memory.memory_set_byte(salted, 6, 0)
    Memory.memory_set_byte(salted, 7, 1)
    Let expected be Arena.arena_allocate(arena, 32)
    Let hmac_rc be Hmac.hmac_sha256(arena, pw, 8, salted, 8, expected)
    T.assert_equal(results, "HMAC-SHA-256 reference computed", hmac_rc, 1)

    Let match be 1
    Let i be 0
    While i is less than 32:
        Let a be Memory.memory_get_byte(dk, i)
        Let b be Memory.memory_get_byte(expected, i)
        If a is not equal to b:
            Set match to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "PBKDF2 c=1 single-block == HMAC reference", match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_argon2id_derive_returns_output" takes results as Integer returns Integer:
    T.begin_suite(results, "argon2id_derive returns 32 output bytes (smoke test)")
    Let arena be Arena.arena_create(33554432)

    Let pw be Arena.arena_allocate(arena, 8)
    fill_byte_range(pw, 8, 65)
    Let salt be Arena.arena_allocate(arena, 16)
    fill_byte_range(salt, 16, 1)
    Let out be Arena.arena_allocate(arena, 32)

    Note: m=64 KiB minimum reasonable; t=2; p=1; out_len=32.
    Let rc be Kdf.argon2id_derive(arena, pw, 8, salt, 16, 2, 64, 1, 32, out)
    T.assert_equal(results, "argon2id_derive returned success", rc, 1)

    Note: Sanity: the output is not all-zero (which would indicate failure).
    Let any_nonzero be 0
    Let i be 0
    While i is less than 32:
        If Memory.memory_get_byte(out, i) is not equal to 0:
            Set any_nonzero to 1
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "argon2id output not all-zero", any_nonzero, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_scrypt_minimal_vector_runs" takes results as Integer returns Integer:
    T.begin_suite(results, "scrypt minimal vector: ('', '', 16, 1, 1, 64) returns success")
    Let arena be Arena.arena_create(16777216)

    Let pw be Arena.arena_allocate(arena, 1)
    Memory.memory_set_byte(pw, 0, 0)
    Let salt be Arena.arena_allocate(arena, 1)
    Memory.memory_set_byte(salt, 0, 0)
    Let out be Arena.arena_allocate(arena, 64)

    Let rc be Kdf.scrypt(arena, pw, 0, salt, 0, 16, 1, 1, 64, out)
    T.assert_equal(results, "scrypt returned success", rc, 1)

    Note: Sanity: output is not all-zero.
    Let any_nonzero be 0
    Let i be 0
    While i is less than 64:
        If Memory.memory_get_byte(out, i) is not equal to 0:
            Set any_nonzero to 1
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "scrypt output not all-zero", any_nonzero, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_scrypt_rejects_non_power_of_two_n" takes results as Integer returns Integer:
    T.begin_suite(results, "scrypt rejects non-power-of-two N")
    Let arena be Arena.arena_create(1048576)
    Let pw be Arena.arena_allocate(arena, 1)
    Let salt be Arena.arena_allocate(arena, 1)
    Let out be Arena.arena_allocate(arena, 32)
    Let rc be Kdf.scrypt(arena, pw, 0, salt, 0, 6, 1, 1, 32, out)
    T.assert_equal(results, "N=6 rejected", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_hkdf_sha256_rfc5869_a1(results)
    test_pbkdf2_sha256_iter1_equals_hmac(results)
    test_argon2id_derive_returns_output(results)
    test_scrypt_minimal_vector_runs(results)
    test_scrypt_rejects_non_power_of_two_n(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
