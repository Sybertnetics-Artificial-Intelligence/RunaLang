Note:
Tests for crypto_identity/secret_share.runa.

Verifies:
  - GF(2^8) arithmetic: add, mul, inv basic properties.
  - shamir_split(secret, 3, 5) then shamir_combine_select of any 3 of 5
    recovers the original secret.
  - shamir_combine of fewer than threshold shares does NOT recover the
    secret (test by combining 2 of a (3,5) split and showing the result
    differs from the original).
  - Reject malformed inputs.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/secret_share.runa" as SS

Process called "test_gf256_add_identity" takes results as Integer returns Integer:
    T.begin_suite(results, "GF(2^8) add: x + 0 = x")
    Let a be SS.gf256_add(42, 0)
    T.assert_equal(results, "42 + 0 = 42", a, 42)
    Let b be SS.gf256_add(0, 137)
    T.assert_equal(results, "0 + 137 = 137", b, 137)
    Let c be SS.gf256_add(255, 255)
    T.assert_equal(results, "255 + 255 = 0 (XOR self)", c, 0)
    Return 1
End Process

Process called "test_gf256_mul_identity" takes results as Integer returns Integer:
    T.begin_suite(results, "GF(2^8) mul: x * 1 = x and x * 0 = 0")
    Let a be SS.gf256_mul(42, 1)
    T.assert_equal(results, "42 * 1 = 42", a, 42)
    Let b be SS.gf256_mul(1, 137)
    T.assert_equal(results, "1 * 137 = 137", b, 137)
    Let c be SS.gf256_mul(42, 0)
    T.assert_equal(results, "42 * 0 = 0", c, 0)
    Return 1
End Process

Process called "test_gf256_inv_correctness" takes results as Integer returns Integer:
    T.begin_suite(results, "GF(2^8) inverse: x * inv(x) = 1 for non-zero x")
    Let i be 1
    Let all_ok be 1
    While i is less than 256:
        Let inv_i be SS.gf256_inv(i)
        Let prod be SS.gf256_mul(i, inv_i)
        If prod is not equal to 1:
            Set all_ok to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "inv(x)*x = 1 for x in 1..255", all_ok, 1)
    Return 1
End Process

Process called "test_shamir_split_combine_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "Shamir (3,5): split then combine any 3 -> original")
    Let arena be Arena.arena_create(1048576)

    Note: Original secret = "hello world!" (12 bytes).
    Let secret be Arena.arena_allocate(arena, 12)
    Memory.memory_set_byte(secret, 0, 104)
    Memory.memory_set_byte(secret, 1, 101)
    Memory.memory_set_byte(secret, 2, 108)
    Memory.memory_set_byte(secret, 3, 108)
    Memory.memory_set_byte(secret, 4, 111)
    Memory.memory_set_byte(secret, 5, 32)
    Memory.memory_set_byte(secret, 6, 119)
    Memory.memory_set_byte(secret, 7, 111)
    Memory.memory_set_byte(secret, 8, 114)
    Memory.memory_set_byte(secret, 9, 108)
    Memory.memory_set_byte(secret, 10, 100)
    Memory.memory_set_byte(secret, 11, 33)

    Let shares be SS.shamir_split(arena, secret, 12, 3, 5)
    T.assert_not_null(results, "split produced shares buffer", shares)
    T.assert_equal(results, "share count = 5", SS.shamir_share_count(shares), 5)
    T.assert_equal(results, "per-share size = 13", SS.shamir_per_share_size(shares), 13)

    Note: Combine shares 0, 1, 2.
    Let sel_012 be Arena.arena_allocate(arena, 12)
    Memory.memory_set_int32(sel_012, 0, 0)
    Memory.memory_set_int32(sel_012, 4, 1)
    Memory.memory_set_int32(sel_012, 8, 2)
    Let rec_012 be SS.shamir_combine_select(arena, shares, sel_012, 3)
    T.assert_not_null(results, "combine 0,1,2 returned", rec_012)
    Let match_012 be 1
    Let i be 0
    While i is less than 12:
        If Memory.memory_get_byte(rec_012, i) is not equal to Memory.memory_get_byte(secret, i):
            Set match_012 to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "combine 0,1,2 = original", match_012, 1)

    Note: Combine shares 0, 2, 4.
    Let sel_024 be Arena.arena_allocate(arena, 12)
    Memory.memory_set_int32(sel_024, 0, 0)
    Memory.memory_set_int32(sel_024, 4, 2)
    Memory.memory_set_int32(sel_024, 8, 4)
    Let rec_024 be SS.shamir_combine_select(arena, shares, sel_024, 3)
    T.assert_not_null(results, "combine 0,2,4 returned", rec_024)
    Let match_024 be 1
    Set i to 0
    While i is less than 12:
        If Memory.memory_get_byte(rec_024, i) is not equal to Memory.memory_get_byte(secret, i):
            Set match_024 to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "combine 0,2,4 = original", match_024, 1)

    Note: Combine shares 1, 3, 4.
    Let sel_134 be Arena.arena_allocate(arena, 12)
    Memory.memory_set_int32(sel_134, 0, 1)
    Memory.memory_set_int32(sel_134, 4, 3)
    Memory.memory_set_int32(sel_134, 8, 4)
    Let rec_134 be SS.shamir_combine_select(arena, shares, sel_134, 3)
    T.assert_not_null(results, "combine 1,3,4 returned", rec_134)
    Let match_134 be 1
    Set i to 0
    While i is less than 12:
        If Memory.memory_get_byte(rec_134, i) is not equal to Memory.memory_get_byte(secret, i):
            Set match_134 to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "combine 1,3,4 = original", match_134, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_shamir_below_threshold_does_not_recover" takes results as Integer returns Integer:
    T.begin_suite(results, "Shamir (3,5): combining 2 shares is rejected by threshold gate")
    Let arena be Arena.arena_create(1048576)

    Let secret be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(secret, 0, 222)
    Memory.memory_set_byte(secret, 1, 173)
    Memory.memory_set_byte(secret, 2, 190)
    Memory.memory_set_byte(secret, 3, 239)

    Let shares be SS.shamir_split(arena, secret, 4, 3, 5)
    T.assert_not_null(results, "shares built", shares)
    T.assert_equal(results, "threshold_k recorded in header", SS.shamir_threshold_k(shares), 3)

    Note: Combine 2 of 5: the threshold gate in shamir_combine_select reads
    Note: the recorded k=3 from the header and returns 0 because use_count<k.
    Note: This eliminates the silent-garbage failure mode where a caller
    Note: with k-1 shares would otherwise receive a buffer resembling a
    Note: secret but actually holding a degree-(k-2) polynomial.
    Let sel_01 be Arena.arena_allocate(arena, 8)
    Memory.memory_set_int32(sel_01, 0, 0)
    Memory.memory_set_int32(sel_01, 4, 1)
    Let rec be SS.shamir_combine_select(arena, shares, sel_01, 2)
    T.assert_equal(results, "below-threshold combine returns 0", rec, 0)

    Note: Threshold met (3 of 5): reconstruction recovers the original.
    Let sel_012 be Arena.arena_allocate(arena, 12)
    Memory.memory_set_int32(sel_012, 0, 0)
    Memory.memory_set_int32(sel_012, 4, 1)
    Memory.memory_set_int32(sel_012, 8, 2)
    Let rec3 be SS.shamir_combine_select(arena, shares, sel_012, 3)
    T.assert_not_null(results, "threshold-met combine returned", rec3)
    Let match3 be 1
    Let i3 be 0
    While i3 is less than 4:
        If Memory.memory_get_byte(rec3, i3) is not equal to Memory.memory_get_byte(secret, i3):
            Set match3 to 0
        End If
        Set i3 to i3 plus 1
    End While
    T.assert_equal(results, "threshold-met combine = original", match3, 1)

    Note: All 5 shares: reconstruction also recovers the original.
    Let sel_all be Arena.arena_allocate(arena, 20)
    Memory.memory_set_int32(sel_all, 0, 0)
    Memory.memory_set_int32(sel_all, 4, 1)
    Memory.memory_set_int32(sel_all, 8, 2)
    Memory.memory_set_int32(sel_all, 12, 3)
    Memory.memory_set_int32(sel_all, 16, 4)
    Let rec5 be SS.shamir_combine_select(arena, shares, sel_all, 5)
    T.assert_not_null(results, "all-shares combine returned", rec5)
    Let match5 be 1
    Let i5 be 0
    While i5 is less than 4:
        If Memory.memory_get_byte(rec5, i5) is not equal to Memory.memory_get_byte(secret, i5):
            Set match5 to 0
        End If
        Set i5 to i5 plus 1
    End While
    T.assert_equal(results, "all-shares combine = original", match5, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_shamir_split_invalid_params" takes results as Integer returns Integer:
    T.begin_suite(results, "shamir_split rejects invalid (k,n)")
    Let arena be Arena.arena_create(1048576)
    Let secret be Arena.arena_allocate(arena, 4)
    fill_zeros(secret, 4)
    Note: k > n -> reject.
    Let r1 be SS.shamir_split(arena, secret, 4, 5, 3)
    T.assert_equal(results, "k>n rejected", r1, 0)
    Note: k < 2 -> reject.
    Let r2 be SS.shamir_split(arena, secret, 4, 1, 3)
    T.assert_equal(results, "k<2 rejected", r2, 0)
    Note: n > 255 -> reject.
    Let r3 be SS.shamir_split(arena, secret, 4, 2, 256)
    T.assert_equal(results, "n>255 rejected", r3, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "fill_zeros" takes buf as Integer, count as Integer returns Integer:
    Let i be 0
    While i is less than count:
        Memory.memory_set_byte(buf, i, 0)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_gf256_add_identity(results)
    test_gf256_mul_identity(results)
    test_gf256_inv_correctness(results)
    test_shamir_split_combine_roundtrip(results)
    test_shamir_below_threshold_does_not_recover(results)
    test_shamir_split_invalid_params(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
