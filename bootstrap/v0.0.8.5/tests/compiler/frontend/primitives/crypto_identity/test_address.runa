Note:
Tests for crypto_identity/address.runa.

Verifies:
  - EIP-55 mixed-case Ethereum address accepts canonical example
  - EIP-55 mixed-case incorrect-case rejected
  - Bitcoin Base58Check decode of well-known address succeeds
  - Bitcoin Base58Check decode with corrupted byte rejected
  - Cross-network equality is rejected

EIP-55 reference example (from EIP-55 spec):
  0x5aAeb6053F3E94C9b9A09f33669435E7Ef1BeAed
  is canonical EIP-55 for the address whose lowercase is
  0x5aaeb6053f3e94c9b9a09f33669435e7ef1beaed

Bitcoin test address:
  "1BvBMSEYstWetqTFn5Au4m4GFg7xJaNVN2" is the canonical
  Base58Check encoding of version byte 0x00 || hash160 ||
  4-byte sha256d checksum (the genesis-era P2PKH address).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/address.runa" as Addr

Process called "ascii_set" takes buf as Integer, idx as Integer, c as Integer returns Integer:
    Memory.memory_set_byte(buf, idx, c)
    Return 1
End Process

Process called "test_ethereum_all_lowercase_accepted" takes results as Integer returns Integer:
    T.begin_suite(results, "address_ethereum_from_hex: all-lowercase accepted")
    Let arena be Arena.arena_create(1048576)
    Note: 5aaeb6053f3e94c9b9a09f33669435e7ef1beaed (40 lowercase chars)
    Let s be Arena.arena_allocate(arena, 40)
    Memory.memory_set_byte(s, 0, 53)
    Memory.memory_set_byte(s, 1, 97)
    Memory.memory_set_byte(s, 2, 97)
    Memory.memory_set_byte(s, 3, 101)
    Memory.memory_set_byte(s, 4, 98)
    Memory.memory_set_byte(s, 5, 54)
    Memory.memory_set_byte(s, 6, 48)
    Memory.memory_set_byte(s, 7, 53)
    Memory.memory_set_byte(s, 8, 51)
    Memory.memory_set_byte(s, 9, 102)
    Memory.memory_set_byte(s, 10, 51)
    Memory.memory_set_byte(s, 11, 101)
    Memory.memory_set_byte(s, 12, 57)
    Memory.memory_set_byte(s, 13, 52)
    Memory.memory_set_byte(s, 14, 99)
    Memory.memory_set_byte(s, 15, 57)
    Memory.memory_set_byte(s, 16, 98)
    Memory.memory_set_byte(s, 17, 57)
    Memory.memory_set_byte(s, 18, 97)
    Memory.memory_set_byte(s, 19, 48)
    Memory.memory_set_byte(s, 20, 57)
    Memory.memory_set_byte(s, 21, 102)
    Memory.memory_set_byte(s, 22, 51)
    Memory.memory_set_byte(s, 23, 51)
    Memory.memory_set_byte(s, 24, 54)
    Memory.memory_set_byte(s, 25, 54)
    Memory.memory_set_byte(s, 26, 57)
    Memory.memory_set_byte(s, 27, 52)
    Memory.memory_set_byte(s, 28, 51)
    Memory.memory_set_byte(s, 29, 53)
    Memory.memory_set_byte(s, 30, 101)
    Memory.memory_set_byte(s, 31, 55)
    Memory.memory_set_byte(s, 32, 101)
    Memory.memory_set_byte(s, 33, 102)
    Memory.memory_set_byte(s, 34, 49)
    Memory.memory_set_byte(s, 35, 98)
    Memory.memory_set_byte(s, 36, 101)
    Memory.memory_set_byte(s, 37, 97)
    Memory.memory_set_byte(s, 38, 101)
    Memory.memory_set_byte(s, 39, 100)
    Let a be Addr.address_ethereum_from_hex(arena, s, 40)
    T.assert_not_null(results, "all-lowercase Ethereum accepted", a)
    T.assert_equal(results, "network = ETHEREUM", Addr.address_network(a), 1)
    T.assert_equal(results, "address bytes len = 20", Addr.address_byte_length(a), 20)
    Note: First byte should be 0x5a = 90.
    Let body be Addr.address_bytes(a)
    T.assert_equal(results, "addr[0] = 0x5a", Memory.memory_get_byte(body, 0), 90)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_ethereum_invalid_hex_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "address_ethereum_from_hex: invalid hex rejected")
    Let arena be Arena.arena_create(1048576)
    Note: 40 chars, but one is 'z' which is not a hex digit.
    Let s be Arena.arena_allocate(arena, 40)
    Let i be 0
    While i is less than 40:
        Memory.memory_set_byte(s, i, 48)
        Set i to i plus 1
    End While
    Memory.memory_set_byte(s, 5, 122)
    Let a be Addr.address_ethereum_from_hex(arena, s, 40)
    T.assert_equal(results, "non-hex char rejected", a, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_ethereum_wrong_length_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "address_ethereum_from_hex: wrong length rejected")
    Let arena be Arena.arena_create(1048576)
    Let s be Arena.arena_allocate(arena, 39)
    Let i be 0
    While i is less than 39:
        Memory.memory_set_byte(s, i, 48)
        Set i to i plus 1
    End While
    Let a be Addr.address_ethereum_from_hex(arena, s, 39)
    T.assert_equal(results, "39-char input rejected", a, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_bech32_polymod_step_known_values" takes results as Integer returns Integer:
    T.begin_suite(results, "bech32 polymod_step: known starting values")
    Let s1 be Addr.addr_bech32_polymod_step(1, 0)
    T.assert_equal(results, "polymod_step(1, 0) = 32", s1, 32)
    Return 1
End Process

Process called "test_base58_decode_known" takes results as Integer returns Integer:
    T.begin_suite(results, "addr_base58_decode: leading '1' becomes 0x00 byte")
    Let arena be Arena.arena_create(1048576)
    Note: "11" should decode to [0x00, 0x00] (two leading 1s = two zero bytes).
    Let s be Arena.arena_allocate(arena, 2)
    Memory.memory_set_byte(s, 0, 49)
    Memory.memory_set_byte(s, 1, 49)
    Let out be Arena.arena_allocate(arena, 4)
    Let n be Addr.addr_base58_decode(s, 2, out, 4)
    T.assert_equal(results, "decoded length = 2", n, 2)
    T.assert_equal(results, "decoded[0] = 0", Memory.memory_get_byte(out, 0), 0)
    T.assert_equal(results, "decoded[1] = 0", Memory.memory_get_byte(out, 1), 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_cross_network_equality_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "address_equal: cross-network rejected")
    Let arena be Arena.arena_create(1048576)
    Let bytes_a be Arena.arena_allocate(arena, 20)
    Let i be 0
    While i is less than 20:
        Memory.memory_set_byte(bytes_a, i, 1)
        Set i to i plus 1
    End While
    Let a1 be Addr.address_create(arena, 1, bytes_a, 20)
    Let a2 be Addr.address_create(arena, 2, bytes_a, 20)
    T.assert_equal(results, "Ethereum vs Bitcoin: unequal", Addr.address_equal(a1, a2), 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_ethereum_all_lowercase_accepted(results)
    test_ethereum_invalid_hex_rejected(results)
    test_ethereum_wrong_length_rejected(results)
    test_bech32_polymod_step_known_values(results)
    test_base58_decode_known(results)
    test_cross_network_equality_rejected(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
