Note:
Tests for crypto_identity/commitment.runa.

Verifies:
  - pedersen_commit + pedersen_verify: round-trip with the same value
    and blinding returns 1.
  - pedersen_verify with the wrong value returns 0 (binding).
  - hash_commit + hash_verify: round-trip with correct (value, blinding)
    returns 1.
  - hash_verify with a different value returns 0 (binding).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/commitment.runa" as C

Process called "fill_scalar" takes buf as Integer, count as Integer, seed_val as Integer returns Integer:
    Let i be 0
    While i is less than count:
        Memory.memory_set_byte(buf, i, (seed_val plus i) modulo by 256)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "test_pedersen_commit_verify_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "pedersen_commit + pedersen_verify: round-trip")
    Let arena be Arena.arena_create(8388608)

    Let value be Arena.arena_allocate(arena, 32)
    fill_scalar(value, 32, 7)
    Note: Clamp the value as an Ed25519 scalar by clearing the top 3 bits.
    Memory.memory_set_byte(value, 31, 31)
    Let blinding be Arena.arena_allocate(arena, 32)
    fill_scalar(blinding, 32, 200)
    Memory.memory_set_byte(blinding, 31, 31)

    Let commitment be Arena.arena_allocate(arena, 32)
    Let rc be C.pedersen_commit(arena, value, blinding, commitment)
    T.assert_equal(results, "pedersen_commit returned success", rc, 1)

    Let vf be C.pedersen_verify(arena, commitment, value, blinding)
    T.assert_equal(results, "pedersen_verify returns 1", vf, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_pedersen_verify_wrong_value_rejects" takes results as Integer returns Integer:
    T.begin_suite(results, "pedersen_verify rejects different value (binding)")
    Let arena be Arena.arena_create(8388608)

    Let value be Arena.arena_allocate(arena, 32)
    fill_scalar(value, 32, 11)
    Memory.memory_set_byte(value, 31, 31)
    Let blinding be Arena.arena_allocate(arena, 32)
    fill_scalar(blinding, 32, 77)
    Memory.memory_set_byte(blinding, 31, 31)

    Let commitment be Arena.arena_allocate(arena, 32)
    Let rc be C.pedersen_commit(arena, value, blinding, commitment)
    T.assert_equal(results, "commit OK", rc, 1)

    Let wrong_value be Arena.arena_allocate(arena, 32)
    fill_scalar(wrong_value, 32, 88)
    Memory.memory_set_byte(wrong_value, 31, 31)

    Let vf be C.pedersen_verify(arena, commitment, wrong_value, blinding)
    T.assert_equal(results, "verify with wrong value = 0", vf, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_hash_commit_verify_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "hash_commit + hash_verify: round-trip")
    Let arena be Arena.arena_create(1048576)

    Let value be Arena.arena_allocate(arena, 8)
    Memory.memory_set_byte(value, 0, 84)
    Memory.memory_set_byte(value, 1, 101)
    Memory.memory_set_byte(value, 2, 115)
    Memory.memory_set_byte(value, 3, 116)
    Memory.memory_set_byte(value, 4, 86)
    Memory.memory_set_byte(value, 5, 97)
    Memory.memory_set_byte(value, 6, 108)
    Memory.memory_set_byte(value, 7, 33)

    Let blinding be Arena.arena_allocate(arena, 32)
    fill_scalar(blinding, 32, 42)

    Let commitment be Arena.arena_allocate(arena, 32)
    Let rc be C.hash_commit(arena, value, 8, blinding, commitment)
    T.assert_equal(results, "hash_commit returned success", rc, 1)

    Let vf be C.hash_verify(arena, commitment, value, 8, blinding)
    T.assert_equal(results, "hash_verify with same inputs = 1", vf, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_hash_verify_wrong_value_rejects" takes results as Integer returns Integer:
    T.begin_suite(results, "hash_verify rejects different value (binding)")
    Let arena be Arena.arena_create(1048576)

    Let value be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(value, 0, 1)
    Memory.memory_set_byte(value, 1, 2)
    Memory.memory_set_byte(value, 2, 3)
    Memory.memory_set_byte(value, 3, 4)

    Let blinding be Arena.arena_allocate(arena, 32)
    fill_scalar(blinding, 32, 99)

    Let commitment be Arena.arena_allocate(arena, 32)
    Let rc be C.hash_commit(arena, value, 4, blinding, commitment)
    T.assert_equal(results, "hash_commit OK", rc, 1)

    Let wrong_value be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(wrong_value, 0, 5)
    Memory.memory_set_byte(wrong_value, 1, 6)
    Memory.memory_set_byte(wrong_value, 2, 7)
    Memory.memory_set_byte(wrong_value, 3, 8)

    Let vf be C.hash_verify(arena, commitment, wrong_value, 4, blinding)
    T.assert_equal(results, "verify with wrong value = 0", vf, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_hash_verify_wrong_blinding_rejects" takes results as Integer returns Integer:
    T.begin_suite(results, "hash_verify rejects different blinding")
    Let arena be Arena.arena_create(1048576)

    Let value be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(value, 0, 9)
    Memory.memory_set_byte(value, 1, 10)
    Memory.memory_set_byte(value, 2, 11)
    Memory.memory_set_byte(value, 3, 12)

    Let blinding1 be Arena.arena_allocate(arena, 32)
    fill_scalar(blinding1, 32, 1)
    Let blinding2 be Arena.arena_allocate(arena, 32)
    fill_scalar(blinding2, 32, 2)

    Let commitment be Arena.arena_allocate(arena, 32)
    Let rc be C.hash_commit(arena, value, 4, blinding1, commitment)
    T.assert_equal(results, "hash_commit OK", rc, 1)

    Let vf be C.hash_verify(arena, commitment, value, 4, blinding2)
    T.assert_equal(results, "verify with wrong blinding = 0", vf, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_pedersen_commit_verify_roundtrip(results)
    test_pedersen_verify_wrong_value_rejects(results)
    test_hash_commit_verify_roundtrip(results)
    test_hash_verify_wrong_value_rejects(results)
    test_hash_verify_wrong_blinding_rejects(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
