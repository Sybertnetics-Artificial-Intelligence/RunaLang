Process called "build_sha256_oid_body" takes arena as Integer returns Integer:
    Note: 2.16.840.1.101.3.4.2.1 -> DER body 60 86 48 01 65 03 04 02 01.
    Let buf be Arena.arena_allocate(arena, 9)
    Memory.memory_set_byte(buf, 0, 96)
    Memory.memory_set_byte(buf, 1, 134)
    Memory.memory_set_byte(buf, 2, 72)
    Memory.memory_set_byte(buf, 3, 1)
    Memory.memory_set_byte(buf, 4, 101)
    Memory.memory_set_byte(buf, 5, 3)
    Memory.memory_set_byte(buf, 6, 4)
    Memory.memory_set_byte(buf, 7, 2)
    Memory.memory_set_byte(buf, 8, 1)
    Return buf
End Process

Process called "build_sha384_oid_body" takes arena as Integer returns Integer:
    Note: 2.16.840.1.101.3.4.2.2 -> DER body 60 86 48 01 65 03 04 02 02.
    Let buf be Arena.arena_allocate(arena, 9)
    Memory.memory_set_byte(buf, 0, 96)
    Memory.memory_set_byte(buf, 1, 134)
    Memory.memory_set_byte(buf, 2, 72)
    Memory.memory_set_byte(buf, 3, 1)
    Memory.memory_set_byte(buf, 4, 101)
    Memory.memory_set_byte(buf, 5, 3)
    Memory.memory_set_byte(buf, 6, 4)
    Memory.memory_set_byte(buf, 7, 2)
    Memory.memory_set_byte(buf, 8, 2)
    Return buf
End Process

Process called "build_sha512_oid_body" takes arena as Integer returns Integer:
    Note: 2.16.840.1.101.3.4.2.3 -> DER body 60 86 48 01 65 03 04 02 03.
    Let buf be Arena.arena_allocate(arena, 9)
    Memory.memory_set_byte(buf, 0, 96)
    Memory.memory_set_byte(buf, 1, 134)
    Memory.memory_set_byte(buf, 2, 72)
    Memory.memory_set_byte(buf, 3, 1)
    Memory.memory_set_byte(buf, 4, 101)
    Memory.memory_set_byte(buf, 5, 3)
    Memory.memory_set_byte(buf, 6, 4)
    Memory.memory_set_byte(buf, 7, 2)
    Memory.memory_set_byte(buf, 8, 3)
    Return buf
End Process

Process called "build_pss_alg_id" takes arena as Integer, hash_oid_body as Integer, hash_oid_len as Integer returns Integer:
    Note: Construct a SEQUENCE for the PSS AlgorithmIdentifier:
    Note:   30 <total>
    Note:     06 09 <PSS OID body>          -- algorithm
    Note:     30 <param_len>                -- parameters
    Note:       A0 <ctx0_len>               -- [0] hashAlgorithm
    Note:         30 <inner_len>            -- AlgorithmIdentifier
    Note:           06 <hash_oid_len> <body>
    Note:           05 00                   -- NULL parameters

    Note: Inner AlgorithmIdentifier = 2 + hash_oid_len + 2 = hash_oid_len + 4
    Note: [0] body = 2 + (hash_oid_len + 4) = hash_oid_len + 6
    Note: Parameters body = 2 + (hash_oid_len + 6) = hash_oid_len + 8
    Note: Outer SEQUENCE body = 2 + 9 + 2 + (hash_oid_len + 8) = hash_oid_len + 21
    Note: Total bytes = 2 + (hash_oid_len + 21) = hash_oid_len + 23

    Let inner_alg_id_len be hash_oid_len plus 4
    Let ctx0_len be inner_alg_id_len plus 2
    Let params_len be ctx0_len plus 2
    Let outer_len be 11 plus params_len plus 2
    Let total_size be outer_len plus 2

    Let buf be Arena.arena_allocate(arena, total_size)
    If buf is equal to 0:
        Return 0
    End If

    Let i be 0
    Set i to write_byte(buf, i, 48)
    Set i to write_byte(buf, i, outer_len)
    Note: PSS OID
    Set i to write_byte(buf, i, 6)
    Set i to write_byte(buf, i, 9)
    Set i to write_byte(buf, i, 42)
    Set i to write_byte(buf, i, 134)
    Set i to write_byte(buf, i, 72)
    Set i to write_byte(buf, i, 134)
    Set i to write_byte(buf, i, 247)
    Set i to write_byte(buf, i, 13)
    Set i to write_byte(buf, i, 1)
    Set i to write_byte(buf, i, 1)
    Set i to write_byte(buf, i, 10)
    Note: parameters SEQUENCE
    Set i to write_byte(buf, i, 48)
    Set i to write_byte(buf, i, params_len)
    Note: [0] hashAlgorithm context tag
    Set i to write_byte(buf, i, 160)
    Set i to write_byte(buf, i, ctx0_len)
    Note: inner AlgorithmIdentifier
    Set i to write_byte(buf, i, 48)
    Set i to write_byte(buf, i, inner_alg_id_len)
    Note: hash OID
    Set i to write_byte(buf, i, 6)
    Set i to write_byte(buf, i, hash_oid_len)
    Set i to write_bytes(buf, i, hash_oid_body, hash_oid_len)
    Note: NULL parameters
    Set i to write_byte(buf, i, 5)
    Set i to write_byte(buf, i, 0)

    Return Asn1Der.asn1_parse_tlv(arena, buf, 0, total_size)
End Process

Process called "build_synthetic_cert_handle_for_modulus" takes arena as Integer, modulus_bytes as Integer returns Integer:
    Note: Build a minimal x509_cert handle that exposes an SPKI TLV at
    Note: slot offset 72. The SPKI is shaped as:
    Note:   30 <spki_len>
    Note:     30 <alg_len>             -- AlgorithmIdentifier (any opaque)
    Note:       06 09 2A 86 48 86 F7 0D 01 01 01   -- rsaEncryption OID
    Note:       05 00                              -- NULL parameters
    Note:     03 <bs_len> 00            -- BIT STRING wrapping inner SEQUENCE
    Note:       30 <inner_len>          -- RSAPublicKey SEQUENCE
    Note:         02 <mod_len> <modulus bytes> -- modulus INTEGER
    Note:         02 03 01 00 01                 -- publicExponent INTEGER

    Note: We size modulus content as modulus_bytes + 1 (leading 0 to keep
    Note: the INTEGER positive when MSB=1), which mirrors real RSA SPKI.
    Note: certificate_rsa_modulus_byte_length strips the leading zero, so
    Note: the dispatcher sees exactly modulus_bytes.

    Let modulus_content_len be modulus_bytes plus 1
    Note: modulus_content_len for 256 is 257; needs 2-byte long-form length.
    Note: We always use 2-byte long-form length for the modulus INTEGER and
    Note: also for the inner SEQUENCE, BIT STRING, and outer SEQUENCE to
    Note: keep DER construction uniform across 256/384/512 modulus sizes.
    Let exp_tlv_total be 5
    Let inner_seq_content_len be 4 plus modulus_content_len plus exp_tlv_total
    Note: Inner SEQUENCE: tag(1) + len(3 long-form) + content
    Let inner_seq_total be 4 plus inner_seq_content_len
    Let bs_content_len be 1 plus inner_seq_total
    Let bs_total be 4 plus bs_content_len
    Let alg_id_len be 13
    Note: AlgorithmIdentifier short-form: 30 0D 06 09 ...rsaEnc... 05 00
    Note: total = 2 + 13 = 15
    Let alg_id_total be 15
    Let spki_content_len be alg_id_total plus bs_total
    Let spki_total be 4 plus spki_content_len

    Let buf be Arena.arena_allocate(arena, spki_total)
    If buf is equal to 0:
        Return 0
    End If

    Let i be 0
    Note: Outer SPKI SEQUENCE with 2-byte long-form length.
    Set i to write_byte(buf, i, 48)
    Set i to write_byte(buf, i, 130)
    Set i to write_byte(buf, i, spki_content_len divided by 256)
    Set i to write_byte(buf, i, spki_content_len modulo by 256)
    Note: AlgorithmIdentifier
    Set i to write_byte(buf, i, 48)
    Set i to write_byte(buf, i, 13)
    Set i to write_byte(buf, i, 6)
    Set i to write_byte(buf, i, 9)
    Set i to write_byte(buf, i, 42)
    Set i to write_byte(buf, i, 134)
    Set i to write_byte(buf, i, 72)
    Set i to write_byte(buf, i, 134)
    Set i to write_byte(buf, i, 247)
    Set i to write_byte(buf, i, 13)
    Set i to write_byte(buf, i, 1)
    Set i to write_byte(buf, i, 1)
    Set i to write_byte(buf, i, 1)
    Set i to write_byte(buf, i, 5)
    Set i to write_byte(buf, i, 0)
    Note: BIT STRING wrapping RSAPublicKey.
    Set i to write_byte(buf, i, 3)
    Set i to write_byte(buf, i, 130)
    Set i to write_byte(buf, i, bs_content_len divided by 256)
    Set i to write_byte(buf, i, bs_content_len modulo by 256)
    Set i to write_byte(buf, i, 0)
    Note: Inner RSAPublicKey SEQUENCE.
    Set i to write_byte(buf, i, 48)
    Set i to write_byte(buf, i, 130)
    Set i to write_byte(buf, i, inner_seq_content_len divided by 256)
    Set i to write_byte(buf, i, inner_seq_content_len modulo by 256)
    Note: modulus INTEGER.
    Set i to write_byte(buf, i, 2)
    Set i to write_byte(buf, i, 130)
    Set i to write_byte(buf, i, modulus_content_len divided by 256)
    Set i to write_byte(buf, i, modulus_content_len modulo by 256)
    Note: leading zero (positive sign) then modulus_bytes of arbitrary data.
    Set i to write_byte(buf, i, 0)
    Let k be 0
    While k is less than modulus_bytes:
        Memory.memory_set_byte(buf, i plus k, (k plus 17) modulo by 256)
        Set k to k plus 1
    End While
    Set i to i plus modulus_bytes
    Note: publicExponent INTEGER (65537).
    Set i to write_byte(buf, i, 2)
    Set i to write_byte(buf, i, 3)
    Set i to write_byte(buf, i, 1)
    Set i to write_byte(buf, i, 0)
    Set i to write_byte(buf, i, 1)

    Let spki_tlv be Asn1Der.asn1_parse_tlv(arena, buf, 0, spki_total)
    If spki_tlv is equal to 0:
        Return 0
    End If
    Note: Build cert_handle with SPKI pointer at offset 72.
    Let handle be Arena.arena_allocate(arena, 96)
    If handle is equal to 0:
        Return 0
    End If
    Let z be 0
    While z is less than 96:
        Memory.memory_set_byte(handle, z, 0)
        Set z to z plus 1
    End While
    Memory.memory_set_qword(handle, 72, spki_tlv)
    Return handle
End Process

Note: ============================================================================
Note: TESTS - Edwards curve OIDs (no cert_handle needed)
Note: ============================================================================

Process called "test_ed25519_oid" takes results as Integer returns Integer:
    T.begin_suite(results, "certificate.signature_algorithm_from_tlv: Ed25519")
    Let arena be Arena.arena_create(1048576)
    Let oid_body be build_ed25519_oid(arena)
    Let alg_id be build_alg_id_with_oid(arena, oid_body, 3)
    T.assert_not_null(results, "Ed25519 alg_id parsed", alg_id)
    Let tag be Cert.certificate_signature_algorithm_from_tlv(arena, alg_id, 0)
    T.assert_equal(results, "Ed25519 OID -> ALG_ED25519", tag, Alg.ALG_ED25519)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_ed448_oid" takes results as Integer returns Integer:
    T.begin_suite(results, "certificate.signature_algorithm_from_tlv: Ed448")
    Let arena be Arena.arena_create(1048576)
    Let oid_body be build_ed448_oid(arena)
    Let alg_id be build_alg_id_with_oid(arena, oid_body, 3)
    T.assert_not_null(results, "Ed448 alg_id parsed", alg_id)
    Let tag be Cert.certificate_signature_algorithm_from_tlv(arena, alg_id, 0)
    T.assert_equal(results, "Ed448 OID -> ALG_ED448", tag, Alg.ALG_ED448)
    Arena.arena_destroy(arena)
    Return 1
End Process

