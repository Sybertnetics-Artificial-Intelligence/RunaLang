Note:
Tests for crypto_identity/certificate.runa.

Verifies certificate_signature_algorithm_from_tlv correctly maps each
supported X.509 signatureAlgorithm OID to its CryptoAlgorithm tag:
  - Ed25519                 (OID 1.3.101.112)
  - Ed448                   (OID 1.3.101.113)
  - ECDSA with SHA-256      (OID 1.2.840.10045.4.3.2)
  - ECDSA with SHA-384      (OID 1.2.840.10045.4.3.3)
  - ECDSA with SHA-512      (OID 1.2.840.10045.4.3.4)
  - RSA PKCS1v15 SHA-256    (OID 1.2.840.113549.1.1.11) -> 2048/3072/4096
  - RSA PKCS1v15 SHA-384    (OID 1.2.840.113549.1.1.12) -> 2048/3072/4096
  - RSA PKCS1v15 SHA-512    (OID 1.2.840.113549.1.1.13) -> 2048/3072/4096
  - RSA PSS                 (OID 1.2.840.113549.1.1.10) with explicit params
  - Unknown OID -> ALG_UNKNOWN

Test strategy: construct minimal DER-encoded AlgorithmIdentifier
TLVs as raw byte arrays in arena memory, parse them via
Asn1Der.asn1_parse_tlv, then invoke certificate_signature_algorithm_from_tlv
with the resulting TLV pointer. For RSA OIDs, also construct a
minimal synthetic cert_handle exposing an SPKI TLV that declares the
target modulus length so the dispatcher can compute the modulus
index. For PSS we additionally embed a parameters block carrying the
hashAlgorithm OID so the per-hash variant resolves.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/crypto_algorithm.runa" as Alg
Import "compiler/frontend/primitives/crypto_identity/certificate.runa" as Cert
Import "compiler/frontend/import_system/crypto/asn1_der.runa" as Asn1Der

Note: ============================================================================
Note: DER CONSTRUCTION HELPERS
Note: ============================================================================

Process called "write_bytes" takes buf as Integer, offset as Integer, src_ptr as Integer, src_len as Integer returns Integer:
    Note: Copy src_len bytes from src_ptr into buf starting at offset.
    Note: Returns new offset.
    Memory.memory_copy(buf plus offset, src_ptr, src_len)
    Return offset plus src_len
End Process

Process called "write_byte" takes buf as Integer, offset as Integer, value as Integer returns Integer:
    Memory.memory_set_byte(buf, offset, value)
    Return offset plus 1
End Process

Process called "build_alg_id_with_oid" takes arena as Integer, oid_bytes as Integer, oid_len as Integer returns Integer:
    Note: Build a SEQUENCE containing only an OID (no parameters).
    Note: DER layout:
    Note:   30 LEN
    Note:     06 oid_len <oid bytes>
    Note: Returns a parsed TLV pointer or 0 on failure.
    Let total_size be 2 plus 2 plus oid_len
    Let buf be Arena.arena_allocate(arena, total_size)
    If buf is equal to 0:
        Return 0
    End If
    Note: SEQUENCE header
    Let i be write_byte(buf, 0, 48)
    Set i to write_byte(buf, i, 2 plus oid_len)
    Note: OID header + body
    Set i to write_byte(buf, i, 6)
    Set i to write_byte(buf, i, oid_len)
    Set i to write_bytes(buf, i, oid_bytes, oid_len)
    Return Asn1Der.asn1_parse_tlv(arena, buf, 0, total_size)
End Process

Process called "build_ed25519_oid" takes arena as Integer returns Integer:
    Note: 1.3.101.112 -> DER body 2B 65 70.
    Let buf be Arena.arena_allocate(arena, 3)
    Memory.memory_set_byte(buf, 0, 43)
    Memory.memory_set_byte(buf, 1, 101)
    Memory.memory_set_byte(buf, 2, 112)
    Return buf
End Process

Process called "build_ed448_oid" takes arena as Integer returns Integer:
    Note: 1.3.101.113 -> DER body 2B 65 71.
    Let buf be Arena.arena_allocate(arena, 3)
    Memory.memory_set_byte(buf, 0, 43)
    Memory.memory_set_byte(buf, 1, 101)
    Memory.memory_set_byte(buf, 2, 113)
    Return buf
End Process

Process called "build_ecdsa_sha256_oid" takes arena as Integer returns Integer:
    Note: 1.2.840.10045.4.3.2 -> DER body 2A 86 48 CE 3D 04 03 02.
    Let buf be Arena.arena_allocate(arena, 8)
    Memory.memory_set_byte(buf, 0, 42)
    Memory.memory_set_byte(buf, 1, 134)
    Memory.memory_set_byte(buf, 2, 72)
    Memory.memory_set_byte(buf, 3, 206)
    Memory.memory_set_byte(buf, 4, 61)
    Memory.memory_set_byte(buf, 5, 4)
    Memory.memory_set_byte(buf, 6, 3)
    Memory.memory_set_byte(buf, 7, 2)
    Return buf
End Process

