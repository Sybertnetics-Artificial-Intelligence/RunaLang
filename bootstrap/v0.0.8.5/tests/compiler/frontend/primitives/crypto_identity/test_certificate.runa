Note: TESTS - RSA PKCS1v15 OIDs (need cert_handle with modulus length)
Note: ============================================================================

Process called "test_rsa_pkcs1v15_sha256_2048" takes results as Integer returns Integer:
    T.begin_suite(results, "certificate.signature_algorithm_from_tlv: RSA PKCS1v15 SHA-256 / 2048")
    Let arena be Arena.arena_create(4194304)
    Let oid_body be build_rsa_pkcs1v15_sha256_oid(arena)
    Let alg_id be build_alg_id_with_oid(arena, oid_body, 9)
    Let handle be build_synthetic_cert_handle_for_modulus(arena, 256)
    T.assert_not_null(results, "2048-bit synthetic cert_handle built", handle)
    Let tag be Cert.certificate_signature_algorithm_from_tlv(arena, alg_id, handle)
    T.assert_equal(results, "PKCS1v15-SHA256 / 2048 -> 110", tag, Alg.ALG_RSA_PKCS1V15_SHA256_2048)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_rsa_pkcs1v15_sha256_3072" takes results as Integer returns Integer:
    T.begin_suite(results, "certificate.signature_algorithm_from_tlv: RSA PKCS1v15 SHA-256 / 3072")
    Let arena be Arena.arena_create(4194304)
    Let oid_body be build_rsa_pkcs1v15_sha256_oid(arena)
    Let alg_id be build_alg_id_with_oid(arena, oid_body, 9)
    Let handle be build_synthetic_cert_handle_for_modulus(arena, 384)
    Let tag be Cert.certificate_signature_algorithm_from_tlv(arena, alg_id, handle)
    T.assert_equal(results, "PKCS1v15-SHA256 / 3072 -> 111", tag, Alg.ALG_RSA_PKCS1V15_SHA256_3072)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_rsa_pkcs1v15_sha256_4096" takes results as Integer returns Integer:
    T.begin_suite(results, "certificate.signature_algorithm_from_tlv: RSA PKCS1v15 SHA-256 / 4096")
    Let arena be Arena.arena_create(4194304)
    Let oid_body be build_rsa_pkcs1v15_sha256_oid(arena)
    Let alg_id be build_alg_id_with_oid(arena, oid_body, 9)
    Let handle be build_synthetic_cert_handle_for_modulus(arena, 512)
    Let tag be Cert.certificate_signature_algorithm_from_tlv(arena, alg_id, handle)
    T.assert_equal(results, "PKCS1v15-SHA256 / 4096 -> 112", tag, Alg.ALG_RSA_PKCS1V15_SHA256_4096)
    Arena.arena_destroy(arena)
    Return 1
End Process

