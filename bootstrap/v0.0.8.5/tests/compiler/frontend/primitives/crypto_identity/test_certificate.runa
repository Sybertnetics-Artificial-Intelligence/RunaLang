    Let hash_oid_body be build_sha256_oid_body(arena)
    Let alg_id be build_pss_alg_id(arena, hash_oid_body, 9)
    T.assert_not_null(results, "PSS-SHA256 alg_id parsed", alg_id)
    Let handle be build_synthetic_cert_handle_for_modulus(arena, 256)
    Let tag be Cert.certificate_signature_algorithm_from_tlv(arena, alg_id, handle)
    T.assert_equal(results, "PSS-SHA256 / 2048 -> 120", tag, Alg.ALG_RSA_PSS_SHA256_2048)
    Arena.arena_destroy(arena)
