Process called "test_unknown_oid" takes results as Integer returns Integer:
    T.begin_suite(results, "certificate.signature_algorithm_from_tlv: unknown OID -> ALG_UNKNOWN")
    Let arena be Arena.arena_create(1048576)
    Note: Use an arbitrary unassigned OID 1.3.99.99 -> DER body 2B 63 63.
    Let buf be Arena.arena_allocate(arena, 3)
    Memory.memory_set_byte(buf, 0, 43)
    Memory.memory_set_byte(buf, 1, 99)
    Memory.memory_set_byte(buf, 2, 99)
    Let alg_id be build_alg_id_with_oid(arena, buf, 3)
    Let tag be Cert.certificate_signature_algorithm_from_tlv(arena, alg_id, 0)
    T.assert_equal(results, "unknown OID -> ALG_UNKNOWN", tag, Alg.ALG_UNKNOWN)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_null_alg_id" takes results as Integer returns Integer:
    T.begin_suite(results, "certificate.signature_algorithm_from_tlv: NULL alg_id -> ALG_UNKNOWN")
    Let arena be Arena.arena_create(1048576)
    Let tag be Cert.certificate_signature_algorithm_from_tlv(arena, 0, 0)
    T.assert_equal(results, "NULL alg_id -> ALG_UNKNOWN", tag, Alg.ALG_UNKNOWN)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_rsa_pkcs1v15_no_cert_handle" takes results as Integer returns Integer:
    T.begin_suite(results, "certificate.signature_algorithm_from_tlv: RSA-PKCS1v15 with no cert_handle -> ALG_UNKNOWN")
    Let arena be Arena.arena_create(1048576)
    Let oid_body be build_rsa_pkcs1v15_sha256_oid(arena)
    Let alg_id be build_alg_id_with_oid(arena, oid_body, 9)
    Note: cert_handle=0 -> modulus length=0 -> modulus_index=-1 -> ALG_UNKNOWN.
    Let tag be Cert.certificate_signature_algorithm_from_tlv(arena, alg_id, 0)
    T.assert_equal(results, "RSA PKCS1v15 without cert_handle -> ALG_UNKNOWN", tag, Alg.ALG_UNKNOWN)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_ed25519_oid(results)
    test_ed448_oid(results)
    test_ecdsa_p256_oid(results)
    test_ecdsa_p384_oid(results)
    test_ecdsa_p521_oid(results)
    test_rsa_pkcs1v15_sha256_2048(results)
    test_rsa_pkcs1v15_sha256_3072(results)
    test_rsa_pkcs1v15_sha256_4096(results)
    test_rsa_pkcs1v15_sha384_2048(results)
    test_rsa_pkcs1v15_sha384_3072(results)
    test_rsa_pkcs1v15_sha384_4096(results)
    test_rsa_pkcs1v15_sha512_2048(results)
    test_rsa_pkcs1v15_sha512_3072(results)
    test_rsa_pkcs1v15_sha512_4096(results)
    test_rsa_pss_sha256_2048(results)
    test_rsa_pss_sha384_3072(results)
    test_rsa_pss_sha512_4096(results)
    test_unknown_oid(results)
    test_null_alg_id(results)
    test_rsa_pkcs1v15_no_cert_handle(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
