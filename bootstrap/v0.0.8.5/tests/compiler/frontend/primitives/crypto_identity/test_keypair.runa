Note:
Tests for crypto_identity/keypair.runa.

Verifies:
  - Capability check returns OK for classical algorithms, error for PQ.
  - keypair_create returns 0 for unsupported algorithms.
  - PKCS#8 round-trip for Ed25519 (RFC 8032 / RFC 8410).
  - SPKI emission for Ed25519: structure prefix verification.
  - RFC 8032 test vector for Ed25519 keygen + sign + verify (TEST-1).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/crypto_algorithm.runa" as Alg
Import "compiler/frontend/primitives/crypto_identity/public_key.runa" as PK
Import "compiler/frontend/primitives/crypto_identity/private_key.runa" as SK
Import "compiler/frontend/primitives/crypto_identity/key_pair.runa" as KP
Import "compiler/frontend/primitives/crypto_identity/signature.runa" as Sig
Import "compiler/frontend/primitives/crypto_identity/keypair.runa" as Kpx

Process called "test_capability_check_classical" takes results as Integer returns Integer:
    T.begin_suite(results, "keypair_keygen_capability_check classical algorithms")
    Let cap_ed be Kpx.keypair_keygen_capability_check(Alg.ALG_ED25519)
    T.assert_equal(results, "Ed25519 capability OK", cap_ed, 1)
    Let cap_x be Kpx.keypair_keygen_capability_check(Alg.ALG_X25519)
    T.assert_equal(results, "X25519 capability OK", cap_x, 1)
    Let cap_ec be Kpx.keypair_keygen_capability_check(Alg.ALG_ECDSA_P256)
    T.assert_equal(results, "ECDSA-P256 capability OK", cap_ec, 1)
    Let cap_rsa be Kpx.keypair_keygen_capability_check(Alg.ALG_RSA_PSS_SHA256_2048)
    T.assert_equal(results, "RSA-PSS-SHA256-2048 capability OK", cap_rsa, 1)
    Return 1
End Process

Process called "test_capability_check_falcon_supported" takes results as Integer returns Integer:
    Note: FALCON now drives the NTRU FFT through the stage1 Float64 SSE2 path
    Note: and the keygen orchestration (NTRUSolve, LDL, FFS sampler) is wired,
    Note: so capability check returns OK for FALCON-512 / FALCON-1024.
    T.begin_suite(results, "keypair_keygen_capability_check FALCON supported")
    Let cap_falcon_512 be Kpx.keypair_keygen_capability_check(Alg.ALG_FALCON_512)
    T.assert_equal(results, "FALCON-512 capability OK", cap_falcon_512, 1)
    Let cap_falcon_1024 be Kpx.keypair_keygen_capability_check(Alg.ALG_FALCON_1024)
    T.assert_equal(results, "FALCON-1024 capability OK", cap_falcon_1024, 1)
    Return 1
End Process

Process called "test_capability_check_pq_supported" takes results as Integer returns Integer:
    T.begin_suite(results, "keypair_keygen_capability_check integer-only PQ algorithms supported")
    Let cap_mlkem_512 be Kpx.keypair_keygen_capability_check(Alg.ALG_ML_KEM_512)
    T.assert_equal(results, "ML-KEM-512 capability OK (integer NTT)", cap_mlkem_512, 1)
    Let cap_mlkem_768 be Kpx.keypair_keygen_capability_check(Alg.ALG_ML_KEM_768)
    T.assert_equal(results, "ML-KEM-768 capability OK (integer NTT)", cap_mlkem_768, 1)
    Let cap_mlkem_1024 be Kpx.keypair_keygen_capability_check(Alg.ALG_ML_KEM_1024)
    T.assert_equal(results, "ML-KEM-1024 capability OK (integer NTT)", cap_mlkem_1024, 1)
    Let cap_mldsa_44 be Kpx.keypair_keygen_capability_check(Alg.ALG_ML_DSA_44)
    T.assert_equal(results, "ML-DSA-44 capability OK (integer NTT)", cap_mldsa_44, 1)
    Let cap_mldsa_65 be Kpx.keypair_keygen_capability_check(Alg.ALG_ML_DSA_65)
    T.assert_equal(results, "ML-DSA-65 capability OK (integer NTT)", cap_mldsa_65, 1)
    Let cap_mldsa_87 be Kpx.keypair_keygen_capability_check(Alg.ALG_ML_DSA_87)
    T.assert_equal(results, "ML-DSA-87 capability OK (integer NTT)", cap_mldsa_87, 1)
    Let cap_slh_128s be Kpx.keypair_keygen_capability_check(Alg.ALG_SLH_DSA_SHA2_128S)
    T.assert_equal(results, "SLH-DSA-SHA2-128s capability OK (hash-based)", cap_slh_128s, 1)
    Let cap_slh_128f be Kpx.keypair_keygen_capability_check(Alg.ALG_SLH_DSA_SHA2_128F)
    T.assert_equal(results, "SLH-DSA-SHA2-128f capability OK (hash-based)", cap_slh_128f, 1)
    Let cap_slh_192s be Kpx.keypair_keygen_capability_check(Alg.ALG_SLH_DSA_SHA2_192S)
    T.assert_equal(results, "SLH-DSA-SHA2-192s capability OK (hash-based)", cap_slh_192s, 1)
    Let cap_slh_192f be Kpx.keypair_keygen_capability_check(Alg.ALG_SLH_DSA_SHA2_192F)
    T.assert_equal(results, "SLH-DSA-SHA2-192f capability OK (hash-based)", cap_slh_192f, 1)
    Let cap_slh_256s be Kpx.keypair_keygen_capability_check(Alg.ALG_SLH_DSA_SHA2_256S)
    T.assert_equal(results, "SLH-DSA-SHA2-256s capability OK (hash-based)", cap_slh_256s, 1)
    Let cap_slh_256f be Kpx.keypair_keygen_capability_check(Alg.ALG_SLH_DSA_SHA2_256F)
    T.assert_equal(results, "SLH-DSA-SHA2-256f capability OK (hash-based)", cap_slh_256f, 1)
    Return 1
End Process

Process called "test_keypair_create_unknown_rejected" takes results as Integer returns Integer:
    Note: FALCON is now a supported algorithm with full NTRU keygen
    Note: orchestration; only unknown algorithm tags get the 0 return.  This
    Note: test keeps the unknown-tag branch verification.
    T.begin_suite(results, "keypair_create returns 0 for unknown algorithms")
    Let arena be Arena.arena_create(1048576)
    Let kp_unknown be Kpx.keypair_create(arena, 999)
    T.assert_equal(results, "Unknown algorithm tag returns 0", kp_unknown, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_keypair_create_ml_kem_512_succeeds" takes results as Integer returns Integer:
    T.begin_suite(results, "keypair_create(ALG_ML_KEM_512) generates a non-null keypair with FIPS 203 sizes")
    Let arena be Arena.arena_create(8388608)
    Let kp be Kpx.keypair_create(arena, Alg.ALG_ML_KEM_512)
    T.assert_not_null(results, "ML-KEM-512 keypair_create returned non-null", kp)
    Let pk be KP.keypair_public(kp)
    Let sk be KP.keypair_private(kp)
    T.assert_not_null(results, "ML-KEM-512 public_key non-null", pk)
    T.assert_not_null(results, "ML-KEM-512 private_key non-null", sk)
    Let pk_len be PK.public_key_byte_length(pk)
    Let sk_len be SK.private_key_byte_length(sk)
    T.assert_equal(results, "ML-KEM-512 pk size = 800 bytes (FIPS 203)", pk_len, 800)
    T.assert_equal(results, "ML-KEM-512 sk size = 1632 bytes (FIPS 203)", sk_len, 1632)
    Let pk_alg be PK.public_key_algorithm(pk)
    T.assert_equal(results, "ML-KEM-512 pk carries algorithm tag", pk_alg, Alg.ALG_ML_KEM_512)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_pkcs8_ml_kem_512_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "PKCS#8 round-trip for ML-KEM-512")
    Let arena be Arena.arena_create(8388608)
    Let kp be Kpx.keypair_create(arena, Alg.ALG_ML_KEM_512)
    T.assert_not_null(results, "kp generated", kp)

    Let pkcs8 be Kpx.keypair_serialize_pkcs8(arena, kp)
    T.assert_not_null(results, "PKCS#8 serialize returned buffer", pkcs8)
    Let der_len be Memory.memory_get_int32(pkcs8, 0)
    T.assert_greater_than(results, "PKCS#8 DER length > 0", der_len, 0)
    Let first_byte be Memory.memory_get_byte(pkcs8, 4)
    T.assert_equal(results, "PKCS#8 DER starts with 0x30 SEQUENCE", first_byte, 48)

    Let kp2 be Kpx.keypair_deserialize_pkcs8(arena, pkcs8 plus 4, der_len)
    T.assert_not_null(results, "deserialize_pkcs8 produced kp", kp2)
    Let sk_orig be KP.keypair_private(kp)
    Let sk_rec be KP.keypair_private(kp2)
    Let alg_rec be SK.private_key_algorithm(sk_rec)
    T.assert_equal(results, "recovered private key algorithm = ML-KEM-512", alg_rec, Alg.ALG_ML_KEM_512)
    Let sk_len_orig be SK.private_key_byte_length(sk_orig)
    Let sk_len_rec be SK.private_key_byte_length(sk_rec)
    T.assert_equal(results, "recovered sk length matches original", sk_len_rec, sk_len_orig)

    Note: Byte-equality of the dk bytes.
    Let sk_orig_bytes be SK.private_key_secret_bytes_internal(sk_orig)
    Let sk_rec_bytes be SK.private_key_secret_bytes_internal(sk_rec)
    Let match be 1
    Let i be 0
    While i is less than sk_len_orig:
        If Memory.memory_get_byte(sk_orig_bytes, i) is not equal to Memory.memory_get_byte(sk_rec_bytes, i):
            Set match to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "sk bytes match after PKCS#8 round-trip", match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_pkcs8_ed25519_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "PKCS#8 Ed25519 round-trip via keypair_from_seed/serialize_pkcs8/deserialize_pkcs8")
    Let arena be Arena.arena_create(8388608)

    Note: Deterministic seed = bytes 1, 2, 3, ..., 32.
    Let seed be Arena.arena_allocate(arena, 32)
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(seed, i, i plus 1)
        Set i to i plus 1
    End While

    Let kp be KP.keypair_from_seed(arena, Alg.ALG_ED25519, seed, 32)
    T.assert_not_null(results, "keypair_from_seed produced kp", kp)

    Let pkcs8 be Kpx.keypair_serialize_pkcs8(arena, kp)
    T.assert_not_null(results, "keypair_serialize_pkcs8 returned buffer", pkcs8)

    Let der_len be Memory.memory_get_int32(pkcs8, 0)
    T.assert_greater_than(results, "PKCS#8 DER length > 0", der_len, 0)

    Note: First byte of DER must be 0x30 (SEQUENCE).
    Let first_byte be Memory.memory_get_byte(pkcs8, 4)
    T.assert_equal(results, "DER starts with 0x30 SEQUENCE tag", first_byte, 48)

    Note: Deserialize.
    Let kp2 be Kpx.keypair_deserialize_pkcs8(arena, pkcs8 plus 4, der_len)
    T.assert_not_null(results, "deserialize_pkcs8 produced kp", kp2)

    Note: The deserialized kp should produce the same public key bytes.
    Let pk1 be KP.keypair_public(kp)
    Let pk2 be KP.keypair_public(kp2)
    Let pk1_bytes be PK.public_key_bytes(pk1)
    Let pk2_bytes be PK.public_key_bytes(pk2)
    Let pk1_len be PK.public_key_byte_length(pk1)
    Let pk2_len be PK.public_key_byte_length(pk2)
    T.assert_equal(results, "PK len matches after round-trip", pk2_len, pk1_len)
    Let match be 1
    Let i2 be 0
    While i2 is less than pk1_len:
        Let b1 be Memory.memory_get_byte(pk1_bytes, i2)
        Let b2 be Memory.memory_get_byte(pk2_bytes, i2)
        If b1 is not equal to b2:
            Set match to 0
        End If
        Set i2 to i2 plus 1
    End While
    T.assert_equal(results, "PK bytes match after round-trip", match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_spki_ed25519_emission" takes results as Integer returns Integer:
    T.begin_suite(results, "SPKI Ed25519 emission structural check")
    Let arena be Arena.arena_create(8388608)

    Let seed be Arena.arena_allocate(arena, 32)
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(seed, i, 5)
        Set i to i plus 1
    End While

    Let kp be KP.keypair_from_seed(arena, Alg.ALG_ED25519, seed, 32)
    T.assert_not_null(results, "kp built", kp)

    Let spki be Kpx.keypair_public_to_spki(arena, kp)
    T.assert_not_null(results, "SPKI emitted", spki)

    Let spki_len be Memory.memory_get_int32(spki, 0)
    T.assert_greater_than(results, "SPKI DER length > 0", spki_len, 0)
    T.assert_equal(results, "SPKI starts with 0x30", Memory.memory_get_byte(spki, 4), 48)

    Note: Round-trip via keypair_from_spki.
    Let kp_only_pub be Kpx.keypair_from_spki(arena, spki plus 4, spki_len)
    T.assert_not_null(results, "keypair_from_spki produced public-only kp", kp_only_pub)

    Let pk_orig be KP.keypair_public(kp)
    Let pk_recovered be KP.keypair_public(kp_only_pub)
    Let orig_alg be PK.public_key_algorithm(pk_orig)
    Let rec_alg be PK.public_key_algorithm(pk_recovered)
    T.assert_equal(results, "recovered alg = ED25519", rec_alg, orig_alg)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_rfc8032_ed25519_kat_test1" takes results as Integer returns Integer:
    T.begin_suite(results, "RFC 8032 Ed25519 TEST-1 vector: keygen+sign+verify round-trip")
    Let arena be Arena.arena_create(8388608)

    Note: TEST 1 from RFC 8032 7.1:
    Note: secret key (seed) =
    Note:   9d61b19deffd5a60ba844af492ec2cc4
    Note:   4449c5697b326919703bac031cae7f60
    Let seed be Arena.arena_allocate(arena, 32)
    Memory.memory_set_byte(seed, 0, 157)
    Memory.memory_set_byte(seed, 1, 97)
    Memory.memory_set_byte(seed, 2, 177)
    Memory.memory_set_byte(seed, 3, 157)
    Memory.memory_set_byte(seed, 4, 239)
    Memory.memory_set_byte(seed, 5, 253)
    Memory.memory_set_byte(seed, 6, 90)
    Memory.memory_set_byte(seed, 7, 96)
    Memory.memory_set_byte(seed, 8, 186)
    Memory.memory_set_byte(seed, 9, 132)
    Memory.memory_set_byte(seed, 10, 74)
    Memory.memory_set_byte(seed, 11, 244)
    Memory.memory_set_byte(seed, 12, 146)
    Memory.memory_set_byte(seed, 13, 236)
    Memory.memory_set_byte(seed, 14, 44)
    Memory.memory_set_byte(seed, 15, 196)
    Memory.memory_set_byte(seed, 16, 68)
    Memory.memory_set_byte(seed, 17, 73)
    Memory.memory_set_byte(seed, 18, 197)
    Memory.memory_set_byte(seed, 19, 105)
    Memory.memory_set_byte(seed, 20, 123)
    Memory.memory_set_byte(seed, 21, 50)
    Memory.memory_set_byte(seed, 22, 105)
    Memory.memory_set_byte(seed, 23, 25)
    Memory.memory_set_byte(seed, 24, 112)
    Memory.memory_set_byte(seed, 25, 59)
    Memory.memory_set_byte(seed, 26, 172)
    Memory.memory_set_byte(seed, 27, 3)
    Memory.memory_set_byte(seed, 28, 28)
    Memory.memory_set_byte(seed, 29, 174)
    Memory.memory_set_byte(seed, 30, 127)
    Memory.memory_set_byte(seed, 31, 96)

    Note: Expected public key:
    Note:   d75a980182b10ab7d54bfed3c964073a
    Note:   0ee172f3daa62325af021a68f707511a
    Let expected_pub be Arena.arena_allocate(arena, 32)
    Memory.memory_set_byte(expected_pub, 0, 215)
    Memory.memory_set_byte(expected_pub, 1, 90)
    Memory.memory_set_byte(expected_pub, 2, 152)
    Memory.memory_set_byte(expected_pub, 3, 1)
    Memory.memory_set_byte(expected_pub, 4, 130)
    Memory.memory_set_byte(expected_pub, 5, 177)
    Memory.memory_set_byte(expected_pub, 6, 10)
    Memory.memory_set_byte(expected_pub, 7, 183)
    Memory.memory_set_byte(expected_pub, 8, 213)
    Memory.memory_set_byte(expected_pub, 9, 75)
    Memory.memory_set_byte(expected_pub, 10, 254)
    Memory.memory_set_byte(expected_pub, 11, 211)
    Memory.memory_set_byte(expected_pub, 12, 201)
    Memory.memory_set_byte(expected_pub, 13, 100)
    Memory.memory_set_byte(expected_pub, 14, 7)
    Memory.memory_set_byte(expected_pub, 15, 58)
    Memory.memory_set_byte(expected_pub, 16, 14)
    Memory.memory_set_byte(expected_pub, 17, 225)
    Memory.memory_set_byte(expected_pub, 18, 114)
    Memory.memory_set_byte(expected_pub, 19, 243)
    Memory.memory_set_byte(expected_pub, 20, 218)
    Memory.memory_set_byte(expected_pub, 21, 166)
    Memory.memory_set_byte(expected_pub, 22, 35)
    Memory.memory_set_byte(expected_pub, 23, 37)
    Memory.memory_set_byte(expected_pub, 24, 175)
    Memory.memory_set_byte(expected_pub, 25, 2)
    Memory.memory_set_byte(expected_pub, 26, 26)
    Memory.memory_set_byte(expected_pub, 27, 104)
    Memory.memory_set_byte(expected_pub, 28, 247)
    Memory.memory_set_byte(expected_pub, 29, 7)
    Memory.memory_set_byte(expected_pub, 30, 81)
    Memory.memory_set_byte(expected_pub, 31, 26)

    Let kp be KP.keypair_from_seed(arena, Alg.ALG_ED25519, seed, 32)
    T.assert_not_null(results, "kp built from RFC 8032 TEST-1 seed", kp)

    Let pk be KP.keypair_public(kp)
    Let pk_bytes be PK.public_key_bytes(pk)
    Let pk_len be PK.public_key_byte_length(pk)
    T.assert_equal(results, "pub key len = 32", pk_len, 32)

    Let match be 1
    Let i be 0
    While i is less than 32:
        Let a be Memory.memory_get_byte(pk_bytes, i)
        Let b be Memory.memory_get_byte(expected_pub, i)
        If a is not equal to b:
            Set match to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "derived pub key = RFC 8032 TEST-1 expected", match, 1)

    Note: TEST-1 signs an empty message. Verify the round-trip works.
    Let empty_msg be Arena.arena_allocate(arena, 1)
    Memory.memory_set_byte(empty_msg, 0, 0)
    Let sk be KP.keypair_private(kp)
    Let sig be Sig.signature_sign(arena, sk, empty_msg, 0)
    T.assert_not_null(results, "sign empty message produced sig", sig)
    Let vf be Sig.signature_verify(arena, pk, empty_msg, 0, sig)
    T.assert_equal(results, "verify empty-message signature = 1", vf, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_capability_check_classical(results)
    test_capability_check_falcon_supported(results)
    test_capability_check_pq_supported(results)
    test_keypair_create_unknown_rejected(results)
    test_keypair_create_ml_kem_512_succeeds(results)
    test_pkcs8_ml_kem_512_roundtrip(results)
    test_pkcs8_ed25519_roundtrip(results)
    test_spki_ed25519_emission(results)
    test_rfc8032_ed25519_kat_test1(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
