Note:
Tests for crypto_identity/digital_signature.runa.

Verifies:
  - sign / verify round-trip (Ed25519).
  - verify rejects tampered messages.
  - sign_detached / verify_detached round-trip.
  - sign_batch / verify_batch produce parallel arrays of results.
  - sign with a wiped private key returns 0.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/crypto_algorithm.runa" as Alg
Import "compiler/frontend/primitives/crypto_identity/public_key.runa" as PK
Import "compiler/frontend/primitives/crypto_identity/private_key.runa" as SK
Import "compiler/frontend/primitives/crypto_identity/key_pair.runa" as KP
Import "compiler/frontend/primitives/crypto_identity/digital_signature.runa" as DS
Import "compiler/frontend/primitives/crypto_identity/signature.runa" as Sig

Process called "build_ed25519_kp" takes arena as Integer, seed_byte as Integer returns Integer:
    Let seed be Arena.arena_allocate(arena, 32)
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(seed, i, seed_byte plus i)
        Set i to i plus 1
    End While
    Return KP.keypair_from_seed(arena, Alg.ALG_ED25519, seed, 32)
End Process

Process called "test_sign_verify_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "DS.sign + DS.verify: Ed25519 round-trip")
    Let arena be Arena.arena_create(8388608)
    Let kp be build_ed25519_kp(arena, 1)
    T.assert_not_null(results, "kp built", kp)

    Let msg be Arena.arena_allocate(arena, 11)
    Memory.memory_set_byte(msg, 0, 104)
    Memory.memory_set_byte(msg, 1, 101)
    Memory.memory_set_byte(msg, 2, 108)
    Memory.memory_set_byte(msg, 3, 108)
    Memory.memory_set_byte(msg, 4, 111)
    Memory.memory_set_byte(msg, 5, 32)
    Memory.memory_set_byte(msg, 6, 119)
    Memory.memory_set_byte(msg, 7, 111)
    Memory.memory_set_byte(msg, 8, 114)
    Memory.memory_set_byte(msg, 9, 108)
    Memory.memory_set_byte(msg, 10, 100)

    Let sig be DS.sign(arena, msg, 11, kp)
    T.assert_not_null(results, "DS.sign produced sig", sig)

    Let pk be KP.keypair_public(kp)
    Let vf be DS.verify(arena, msg, 11, sig, pk)
    T.assert_equal(results, "DS.verify returns 1", vf, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_verify_rejects_tampered" takes results as Integer returns Integer:
    T.begin_suite(results, "DS.verify rejects tampered message")
    Let arena be Arena.arena_create(8388608)
    Let kp be build_ed25519_kp(arena, 2)

    Let msg be Arena.arena_allocate(arena, 5)
    Memory.memory_set_byte(msg, 0, 1)
    Memory.memory_set_byte(msg, 1, 2)
    Memory.memory_set_byte(msg, 2, 3)
    Memory.memory_set_byte(msg, 3, 4)
    Memory.memory_set_byte(msg, 4, 5)

    Let sig be DS.sign(arena, msg, 5, kp)
    T.assert_not_null(results, "sig", sig)
    Let pk be KP.keypair_public(kp)
    Memory.memory_set_byte(msg, 0, 99)
    Let vf be DS.verify(arena, msg, 5, sig, pk)
    T.assert_equal(results, "tampered verify = 0", vf, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_sign_verify_detached" takes results as Integer returns Integer:
    T.begin_suite(results, "DS.sign_detached + DS.verify_detached: round-trip")
    Let arena be Arena.arena_create(8388608)
    Let kp be build_ed25519_kp(arena, 3)

    Let msg be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(msg, 0, 84)
    Memory.memory_set_byte(msg, 1, 101)
    Memory.memory_set_byte(msg, 2, 115)
    Memory.memory_set_byte(msg, 3, 116)

    Let detached be DS.sign_detached(arena, msg, 4, kp)
    T.assert_not_null(results, "sign_detached produced buffer", detached)

    Let dsig_len be DS.detached_signature_length(detached)
    T.assert_equal(results, "detached sig length = 64 (Ed25519)", dsig_len, 64)
    Let dsig_bytes be DS.detached_signature_bytes(detached)
    T.assert_not_null(results, "detached sig bytes accessible", dsig_bytes)

    Let pk be KP.keypair_public(kp)
    Let vf be DS.verify_detached(arena, msg, 4, dsig_bytes, dsig_len, pk, Alg.ALG_ED25519)
    T.assert_equal(results, "verify_detached returns 1", vf, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_sign_batch_verify_batch" takes results as Integer returns Integer:
    T.begin_suite(results, "DS.sign_batch + DS.verify_batch: parallel arrays")
    Let arena be Arena.arena_create(16777216)
    Let kp be build_ed25519_kp(arena, 4)

    Let count be 3

    Note: Build messages: "A", "BB", "CCC".
    Let msg_a be Arena.arena_allocate(arena, 1)
    Memory.memory_set_byte(msg_a, 0, 65)
    Let msg_b be Arena.arena_allocate(arena, 2)
    Memory.memory_set_byte(msg_b, 0, 66)
    Memory.memory_set_byte(msg_b, 1, 66)
    Let msg_c be Arena.arena_allocate(arena, 3)
    Memory.memory_set_byte(msg_c, 0, 67)
    Memory.memory_set_byte(msg_c, 1, 67)
    Memory.memory_set_byte(msg_c, 2, 67)

    Let ptrs be Arena.arena_allocate(arena, 24)
    Memory.memory_set_int64(ptrs, 0, msg_a)
    Memory.memory_set_int64(ptrs, 8, msg_b)
    Memory.memory_set_int64(ptrs, 16, msg_c)
    Let lens be Arena.arena_allocate(arena, 12)
    Memory.memory_set_int32(lens, 0, 1)
    Memory.memory_set_int32(lens, 4, 2)
    Memory.memory_set_int32(lens, 8, 3)

    Let sigs_buf be DS.sign_batch(arena, count, ptrs, lens, kp)
    T.assert_not_null(results, "sign_batch produced buffer", sigs_buf)
    Let n_signed be Memory.memory_get_int64(sigs_buf, 0)
    T.assert_equal(results, "batch sign count = 3", n_signed, 3)

    Note: Build the parallel verify inputs.
    Let pk be KP.keypair_public(kp)
    Let pks be Arena.arena_allocate(arena, 24)
    Memory.memory_set_int64(pks, 0, pk)
    Memory.memory_set_int64(pks, 8, pk)
    Memory.memory_set_int64(pks, 16, pk)
    Let sigs_ptrs be Arena.arena_allocate(arena, 24)
    Memory.memory_set_int64(sigs_ptrs, 0, Memory.memory_get_qword(sigs_buf, 8))
    Memory.memory_set_int64(sigs_ptrs, 8, Memory.memory_get_qword(sigs_buf, 16))
    Memory.memory_set_int64(sigs_ptrs, 16, Memory.memory_get_qword(sigs_buf, 24))

    Let verify_buf be DS.verify_batch(arena, count, ptrs, lens, sigs_ptrs, pks)
    T.assert_not_null(results, "verify_batch produced buffer", verify_buf)
    Let v0 be DS.batch_result_at(verify_buf, 0)
    Let v1 be DS.batch_result_at(verify_buf, 1)
    Let v2 be DS.batch_result_at(verify_buf, 2)
    T.assert_equal(results, "verify[0] = 1", v0, 1)
    T.assert_equal(results, "verify[1] = 1", v1, 1)
    T.assert_equal(results, "verify[2] = 1", v2, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_sign_wiped_key_returns_zero" takes results as Integer returns Integer:
    T.begin_suite(results, "DS.sign with wiped private key returns 0")
    Let arena be Arena.arena_create(8388608)
    Let kp be build_ed25519_kp(arena, 5)

    Note: Destroy wipes the private key.
    KP.keypair_destroy(kp)

    Let msg be Arena.arena_allocate(arena, 2)
    Memory.memory_set_byte(msg, 0, 1)
    Memory.memory_set_byte(msg, 1, 2)
    Let sig be DS.sign(arena, msg, 2, kp)
    T.assert_equal(results, "sign-after-destroy returns 0", sig, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_sign_verify_roundtrip(results)
    test_verify_rejects_tampered(results)
    test_sign_verify_detached(results)
    test_sign_batch_verify_batch(results)
    test_sign_wiped_key_returns_zero(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
