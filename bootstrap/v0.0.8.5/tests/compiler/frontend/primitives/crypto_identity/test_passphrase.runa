Note:
Tests for crypto_identity/passphrase.runa.

Verifies:
  - passphrase_hash produces a string with the $argon2id$ prefix.
  - passphrase_verify with the correct password returns 1.
  - passphrase_verify with the wrong password returns 0.
  - passphrase_needs_rehash detects param drift.
  - generate_salt produces non-zero output.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/passphrase.runa" as Pass

Process called "test_generate_salt_nonzero" takes results as Integer returns Integer:
    T.begin_suite(results, "generate_salt produces non-zero bytes")
    Let arena be Arena.arena_create(1048576)
    Let salt be Pass.generate_salt(arena, 16)
    T.assert_not_null(results, "salt buffer returned", salt)
    Let any_nonzero be 0
    Let i be 0
    While i is less than 16:
        If Memory.memory_get_byte(salt, i) is not equal to 0:
            Set any_nonzero to 1
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "at least one salt byte non-zero", any_nonzero, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_passphrase_hash_prefix" takes results as Integer returns Integer:
    T.begin_suite(results, "passphrase_hash output starts with $argon2id$")
    Let arena be Arena.arena_create(67108864)

    Let pw be Arena.arena_allocate(arena, 8)
    Memory.memory_set_byte(pw, 0, 99)
    Memory.memory_set_byte(pw, 1, 111)
    Memory.memory_set_byte(pw, 2, 114)
    Memory.memory_set_byte(pw, 3, 114)
    Memory.memory_set_byte(pw, 4, 101)
    Memory.memory_set_byte(pw, 5, 99)
    Memory.memory_set_byte(pw, 6, 116)
    Memory.memory_set_byte(pw, 7, 33)

    Let encoded be Pass.passphrase_hash(arena, pw, 8, 64, 2, 1, 32, 16)
    T.assert_not_null(results, "encoded string returned", encoded)

    Note: Check the $argon2id$ prefix (10 chars).
    T.assert_equal(results, "[0] = '$'", Memory.memory_get_byte(encoded, 0), 36)
    T.assert_equal(results, "[1] = 'a'", Memory.memory_get_byte(encoded, 1), 97)
    T.assert_equal(results, "[2] = 'r'", Memory.memory_get_byte(encoded, 2), 114)
    T.assert_equal(results, "[3] = 'g'", Memory.memory_get_byte(encoded, 3), 103)
    T.assert_equal(results, "[4] = 'o'", Memory.memory_get_byte(encoded, 4), 111)
    T.assert_equal(results, "[5] = 'n'", Memory.memory_get_byte(encoded, 5), 110)
    T.assert_equal(results, "[6] = '2'", Memory.memory_get_byte(encoded, 6), 50)
    T.assert_equal(results, "[7] = 'i'", Memory.memory_get_byte(encoded, 7), 105)
    T.assert_equal(results, "[8] = 'd'", Memory.memory_get_byte(encoded, 8), 100)
    T.assert_equal(results, "[9] = '$'", Memory.memory_get_byte(encoded, 9), 36)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_passphrase_verify_correct" takes results as Integer returns Integer:
    T.begin_suite(results, "passphrase_verify returns 1 for the right password")
    Let arena be Arena.arena_create(67108864)

    Let pw be Arena.arena_allocate(arena, 6)
    Memory.memory_set_byte(pw, 0, 115)
    Memory.memory_set_byte(pw, 1, 101)
    Memory.memory_set_byte(pw, 2, 99)
    Memory.memory_set_byte(pw, 3, 114)
    Memory.memory_set_byte(pw, 4, 101)
    Memory.memory_set_byte(pw, 5, 116)

    Let encoded be Pass.passphrase_hash(arena, pw, 6, 64, 2, 1, 32, 16)
    T.assert_not_null(results, "encoded produced", encoded)

    Let vf be Pass.passphrase_verify(arena, pw, 6, encoded)
    T.assert_equal(results, "verify with correct password = 1", vf, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_passphrase_verify_wrong_password" takes results as Integer returns Integer:
    T.begin_suite(results, "passphrase_verify returns 0 for wrong password")
    Let arena be Arena.arena_create(67108864)

    Let pw be Arena.arena_allocate(arena, 6)
    Memory.memory_set_byte(pw, 0, 115)
    Memory.memory_set_byte(pw, 1, 101)
    Memory.memory_set_byte(pw, 2, 99)
    Memory.memory_set_byte(pw, 3, 114)
    Memory.memory_set_byte(pw, 4, 101)
    Memory.memory_set_byte(pw, 5, 116)

    Let encoded be Pass.passphrase_hash(arena, pw, 6, 64, 2, 1, 32, 16)
    T.assert_not_null(results, "encoded produced", encoded)

    Let wrong_pw be Arena.arena_allocate(arena, 6)
    Memory.memory_set_byte(wrong_pw, 0, 119)
    Memory.memory_set_byte(wrong_pw, 1, 114)
    Memory.memory_set_byte(wrong_pw, 2, 111)
    Memory.memory_set_byte(wrong_pw, 3, 110)
    Memory.memory_set_byte(wrong_pw, 4, 103)
    Memory.memory_set_byte(wrong_pw, 5, 33)

    Let vf be Pass.passphrase_verify(arena, wrong_pw, 6, encoded)
    T.assert_equal(results, "verify with wrong password = 0", vf, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_passphrase_needs_rehash" takes results as Integer returns Integer:
    T.begin_suite(results, "passphrase_needs_rehash detects param drift")
    Let arena be Arena.arena_create(67108864)
    Let pw be Arena.arena_allocate(arena, 3)
    Memory.memory_set_byte(pw, 0, 65)
    Memory.memory_set_byte(pw, 1, 66)
    Memory.memory_set_byte(pw, 2, 67)
    Let encoded be Pass.passphrase_hash(arena, pw, 3, 64, 2, 1, 32, 16)
    T.assert_not_null(results, "encoded produced", encoded)

    Note: Same params -> no rehash.
    Let need0 be Pass.passphrase_needs_rehash(arena, encoded, 64, 2, 1)
    T.assert_equal(results, "same params -> needs_rehash=0", need0, 0)

    Note: Higher t cost -> rehash required.
    Let need1 be Pass.passphrase_needs_rehash(arena, encoded, 64, 4, 1)
    T.assert_equal(results, "higher t -> needs_rehash=1", need1, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_generate_salt_nonzero(results)
    test_passphrase_hash_prefix(results)
    test_passphrase_verify_correct(results)
    test_passphrase_verify_wrong_password(results)
    test_passphrase_needs_rehash(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
