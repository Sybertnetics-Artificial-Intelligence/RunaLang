Note:
Tests for crypto_identity/jwt.runa.

Verifies:
  - "alg: none" is rejected at parse time
  - unsupported "alg" values are rejected
  - "alg: EdDSA" is mapped to ALG_ED25519
  - "alg: ES256" -> ALG_ECDSA_P256, etc.

The full RFC 7519 sample token verification path is exercised in
integration tests downstream; this test confirms the algorithm-name
gate (the historical JWT vulnerability surface).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/crypto_algorithm.runa" as Alg
Import "compiler/frontend/primitives/crypto_identity/jwt.runa" as JWT

Process called "set_str" takes buf as Integer, base as Integer, s as Integer, n as Integer returns Integer:
    Let i be 0
    While i is less than n:
        Memory.memory_set_byte(buf, base plus i, Memory.memory_get_byte(s, i))
        Set i to i plus 1
    End While
    Return n
End Process

Process called "test_alg_name_eddsa" takes results as Integer returns Integer:
    T.begin_suite(results, "jwt_alg_name_to_tag: EdDSA -> ALG_ED25519")
    Let arena be Arena.arena_create(1048576)
    Let s be Arena.arena_allocate(arena, 5)
    Memory.memory_set_byte(s, 0, 69)
    Memory.memory_set_byte(s, 1, 100)
    Memory.memory_set_byte(s, 2, 68)
    Memory.memory_set_byte(s, 3, 83)
    Memory.memory_set_byte(s, 4, 65)
    Let tag be JWT.jwt_alg_name_to_tag(s, 5)
    T.assert_equal(results, "EdDSA -> ED25519", tag, Alg.ALG_ED25519)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_alg_name_es256" takes results as Integer returns Integer:
    T.begin_suite(results, "jwt_alg_name_to_tag: ES256 -> ALG_ECDSA_P256")
    Let arena be Arena.arena_create(1048576)
    Let s be Arena.arena_allocate(arena, 5)
    Memory.memory_set_byte(s, 0, 69)
    Memory.memory_set_byte(s, 1, 83)
    Memory.memory_set_byte(s, 2, 50)
    Memory.memory_set_byte(s, 3, 53)
    Memory.memory_set_byte(s, 4, 54)
    Let tag be JWT.jwt_alg_name_to_tag(s, 5)
    T.assert_equal(results, "ES256 -> ECDSA_P256", tag, Alg.ALG_ECDSA_P256)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_alg_name_ps384" takes results as Integer returns Integer:
    T.begin_suite(results, "jwt_alg_name_to_tag: PS384 -> ALG_RSA_PSS_SHA384_3072")
    Let arena be Arena.arena_create(1048576)
    Let s be Arena.arena_allocate(arena, 5)
    Memory.memory_set_byte(s, 0, 80)
    Memory.memory_set_byte(s, 1, 83)
    Memory.memory_set_byte(s, 2, 51)
    Memory.memory_set_byte(s, 3, 56)
    Memory.memory_set_byte(s, 4, 52)
    Let tag be JWT.jwt_alg_name_to_tag(s, 5)
    T.assert_equal(results, "PS384 -> RSA_PSS_SHA384_3072", tag, Alg.ALG_RSA_PSS_SHA384_3072)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_alg_name_none_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "jwt_alg_name_to_tag: 'none' rejected (alg-none vuln)")
    Let arena be Arena.arena_create(1048576)
    Let s be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(s, 0, 110)
    Memory.memory_set_byte(s, 1, 111)
    Memory.memory_set_byte(s, 2, 110)
    Memory.memory_set_byte(s, 3, 101)
    Let tag be JWT.jwt_alg_name_to_tag(s, 4)
    T.assert_equal(results, "'none' -> ALG_UNKNOWN", tag, Alg.ALG_UNKNOWN)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_alg_name_unknown_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "jwt_alg_name_to_tag: 'XXXXX' rejected")
    Let arena be Arena.arena_create(1048576)
    Let s be Arena.arena_allocate(arena, 5)
    Memory.memory_set_byte(s, 0, 88)
    Memory.memory_set_byte(s, 1, 88)
    Memory.memory_set_byte(s, 2, 88)
    Memory.memory_set_byte(s, 3, 88)
    Memory.memory_set_byte(s, 4, 88)
    Let tag be JWT.jwt_alg_name_to_tag(s, 5)
    T.assert_equal(results, "'XXXXX' -> ALG_UNKNOWN", tag, Alg.ALG_UNKNOWN)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_alg_name_rs512" takes results as Integer returns Integer:
    T.begin_suite(results, "jwt_alg_name_to_tag: RS512 -> ALG_RSA_PKCS1V15_SHA512_4096")
    Let arena be Arena.arena_create(1048576)
    Let s be Arena.arena_allocate(arena, 5)
    Memory.memory_set_byte(s, 0, 82)
    Memory.memory_set_byte(s, 1, 83)
    Memory.memory_set_byte(s, 2, 53)
    Memory.memory_set_byte(s, 3, 49)
    Memory.memory_set_byte(s, 4, 50)
    Let tag be JWT.jwt_alg_name_to_tag(s, 5)
    T.assert_equal(results, "RS512 -> RSA_PKCS1V15_SHA512_4096", tag, Alg.ALG_RSA_PKCS1V15_SHA512_4096)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_alg_name_eddsa(results)
    test_alg_name_es256(results)
    test_alg_name_ps384(results)
    test_alg_name_none_rejected(results)
    test_alg_name_unknown_rejected(results)
    test_alg_name_rs512(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
