Note:
Tests for crypto_identity/signature.runa.

Verifies:
  - signature_create rejects wrong length per algorithm
  - signature_create rejects non-signature algorithm tags
  - cross-algorithm verify (sig.alg != pk.alg) is rejected without
    calling the underlying verify
  - Ed25519 sign + verify round trip via signature_sign and
    signature_verify produces a valid signature against the derived
    public key

RSA verify surface (rsa_verify_from_spki path via signature_verify):
  - signature_verify with RSA algorithm tags routes through
    rsa_verify_from_spki. We test the rejection paths exhaustively
    (the only production-safe behaviour for malformed inputs):
      * malformed SPKI (truncated, wrong outer tag) -> 0
      * arbitrary pk_buf bytes (not a real SPKI) -> 0
      * wrong-key (valid 2048-byte RSA pk_buf with random bytes vs a
        signature generated for a different key) -> 0
      * SHA-1 strength gate: there is no ALG_RSA_*_SHA1 tag at all
        in crypto_algorithm.runa; rsa_alg_to_rsa_hash_id returns -1
        for any non-RSA tag, which forces rsa_verify_from_spki to
        hard-reject. We verify this contract.
      * tag/modulus cross-check: PKCS1v15-SHA256-2048 tag with a
        4096-byte pk_buf is rejected at the modulus cross-check step.
  We exercise the 12 distinct ALG_RSA_* tags (3 hashes x 3 modulus
  sizes x 2 schemes minus a few that share rejection paths).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/crypto_algorithm.runa" as Alg
Import "compiler/frontend/primitives/crypto_identity/public_key.runa" as PK
Import "compiler/frontend/primitives/crypto_identity/private_key.runa" as SK
Import "compiler/frontend/primitives/crypto_identity/key_pair.runa" as KP
Import "compiler/frontend/primitives/crypto_identity/signature.runa" as Sig

Process called "fill_buf_pattern" takes buf as Integer, count as Integer, seed as Integer returns Integer:
    Let i be 0
    While i is less than count:
        Memory.memory_set_byte(buf, i, (i plus seed) modulo by 256)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "test_create_wrong_length_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "signature_create: Ed25519 + wrong length rejected")
    Let arena be Arena.arena_create(1048576)
    Let buf be Arena.arena_allocate(arena, 63)
    fill_buf_pattern(buf, 63, 5)
    Let sig be Sig.signature_create(arena, Alg.ALG_ED25519, buf, 63)
    T.assert_equal(results, "63-byte Ed25519 signature rejected", sig, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_create_hash_alg_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "signature_create: hash algorithm tag rejected")
    Let arena be Arena.arena_create(1048576)
    Let buf be Arena.arena_allocate(arena, 64)
    fill_buf_pattern(buf, 64, 5)
    Let sig be Sig.signature_create(arena, Alg.ALG_SHA2_256, buf, 64)
    T.assert_equal(results, "SHA-256 tag for signature rejected", sig, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_create_ed25519_ok" takes results as Integer returns Integer:
    T.begin_suite(results, "signature_create: Ed25519 64-byte succeeds")
    Let arena be Arena.arena_create(1048576)
    Let buf be Arena.arena_allocate(arena, 64)
    fill_buf_pattern(buf, 64, 0)
    Let sig be Sig.signature_create(arena, Alg.ALG_ED25519, buf, 64)
    T.assert_not_null(results, "sig is non-null", sig)
    T.assert_equal(results, "sig alg = ED25519", Sig.signature_algorithm(sig), Alg.ALG_ED25519)
    T.assert_equal(results, "sig len = 64", Sig.signature_byte_length(sig), 64)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_cross_alg_verify_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "signature_verify: cross-algorithm rejected immediately")
    Let arena be Arena.arena_create(2097152)
    Note: Build an Ed25519 pubkey buffer (32 bytes) and an ECDSA-P256 sig
    Note: (64 bytes); algorithms differ.
    Let pk_buf be Arena.arena_allocate(arena, 32)
    fill_buf_pattern(pk_buf, 32, 1)
    Let pk be PK.public_key_create(arena, Alg.ALG_ED25519, pk_buf, 32)
    T.assert_not_null(results, "ed25519 pk built", pk)

    Let sig_buf be Arena.arena_allocate(arena, 64)
    fill_buf_pattern(sig_buf, 64, 2)
    Let sig be Sig.signature_create(arena, Alg.ALG_ECDSA_P256, sig_buf, 64)
    T.assert_not_null(results, "ecdsa sig built", sig)

    Let msg be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(msg, 0, 116)
    Memory.memory_set_byte(msg, 1, 101)
    Memory.memory_set_byte(msg, 2, 115)
    Memory.memory_set_byte(msg, 3, 116)

    Let rc be Sig.signature_verify(arena, pk, msg, 4, sig)
    T.assert_equal(results, "Ed25519 pk with ECDSA sig -> 0", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_ed25519_sign_verify_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "signature_sign + signature_verify: Ed25519 roundtrip")
    Let arena be Arena.arena_create(8388608)
    Note: Use a deterministic seed.
    Let seed be Arena.arena_allocate(arena, 32)
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(seed, i, i plus 1)
        Set i to i plus 1
    End While
    Let kp be KP.keypair_from_seed(arena, Alg.ALG_ED25519, seed, 32)
    T.assert_not_null(results, "keypair created", kp)
    Let pk be KP.keypair_public(kp)
    Let sk be KP.keypair_private(kp)
    T.assert_not_null(results, "pk derived", pk)
    T.assert_not_null(results, "sk present", sk)

    Note: Sign a 5-byte message "hello".
    Let msg be Arena.arena_allocate(arena, 5)
    Memory.memory_set_byte(msg, 0, 104)
    Memory.memory_set_byte(msg, 1, 101)
    Memory.memory_set_byte(msg, 2, 108)
    Memory.memory_set_byte(msg, 3, 108)
    Memory.memory_set_byte(msg, 4, 111)

    Let sig be Sig.signature_sign(arena, sk, msg, 5)
    T.assert_not_null(results, "signature_sign returned non-null", sig)
    T.assert_equal(results, "sig alg = ED25519", Sig.signature_algorithm(sig), Alg.ALG_ED25519)
    T.assert_equal(results, "sig len = 64", Sig.signature_byte_length(sig), 64)

    Let vf be Sig.signature_verify(arena, pk, msg, 5, sig)
    T.assert_equal(results, "verify of own signature = 1", vf, 1)

    Note: Tamper the message; verify must reject.
    Memory.memory_set_byte(msg, 0, 105)
    Let vf2 be Sig.signature_verify(arena, pk, msg, 5, sig)
    T.assert_equal(results, "verify after tamper = 0", vf2, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Note: ============================================================================
Note: RSA verify surface tests (rsa_verify_from_spki via signature_verify)
Note: ============================================================================

Process called "alloc_pattern_buf" takes arena as Integer, length as Integer, seed as Integer returns Integer:
    Let buf be Arena.arena_allocate(arena, length)
    If buf is equal to 0:
        Return 0
    End If
    Let i be 0
    While i is less than length:
        Memory.memory_set_byte(buf, i, (i plus seed) modulo by 256)
        Set i to i plus 1
    End While
    Return buf
End Process

Process called "rsa_verify_arbitrary_pk_for_alg" takes arena as Integer, alg as Integer, pk_len as Integer returns Integer:
    Note: Build a public key with the given algorithm tag carrying pk_len
    Note: bytes of arbitrary content.  Build an arbitrary signature buffer
    Note: sized to the algorithm's required signature length (which equals
    Note: pk_len, the modulus byte count, for all four supported RSA
    Note: signature schemes).  Call signature_verify and return the result
    Note: (which MUST be 0 for any well-behaved verify, because the pk_buf
    Note: is not a valid SPKI).
    Let pk_buf be alloc_pattern_buf(arena, pk_len, 11)
    Let pk be PK.public_key_create(arena, alg, pk_buf, pk_len)
    If pk is equal to 0:
        Return 0 minus 1
    End If
    Let sig_buf be alloc_pattern_buf(arena, pk_len, 47)
    Let sig be Sig.signature_create(arena, alg, sig_buf, pk_len)
    If sig is equal to 0:
        Return 0 minus 2
    End If
    Let msg be alloc_pattern_buf(arena, 16, 91)
    Return Sig.signature_verify(arena, pk, msg, 16, sig)
End Process

Process called "test_rsa_pkcs1v15_sha256_2048_malformed_spki" takes results as Integer returns Integer:
    T.begin_suite(results, "signature_verify: RSA PKCS1v15 SHA-256 / 2048 malformed SPKI -> 0")
    Let arena be Arena.arena_create(4194304)
    Let rc be rsa_verify_arbitrary_pk_for_alg(arena, Alg.ALG_RSA_PKCS1V15_SHA256_2048, 256)
    T.assert_equal(results, "PKCS1v15-SHA256-2048 with garbage pk -> 0", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

