Process called "test_rsa_pkcs1v15_sha256_3072_modulus_mismatch" takes results as Integer returns Integer:
    Note: PK declares SHA-256/3072 (modulus 384B) but pk_buf carries 256B
    Note: arbitrary content. public_key_create accepts any 256..2048 byte
    Note: range, so creation succeeds. signature_verify reaches the modulus
    Note: cross-check (declared 384 vs decoded SPKI ~ undefined for garbage)
    Note: and rejects.
    T.begin_suite(results, "signature_verify: PKCS1v15 SHA-256 / 3072 tag with 256B pk -> 0")
    Let arena be Arena.arena_create(4194304)
    Let pk_buf be alloc_pattern_buf(arena, 256, 13)
    Let pk be PK.public_key_create(arena, Alg.ALG_RSA_PKCS1V15_SHA256_3072, pk_buf, 256)
    T.assert_not_null(results, "pk built with mismatched modulus", pk)
    Let sig_buf be alloc_pattern_buf(arena, 384, 23)
    Let sig be Sig.signature_create(arena, Alg.ALG_RSA_PKCS1V15_SHA256_3072, sig_buf, 384)
    T.assert_not_null(results, "sig built", sig)
    Let msg be alloc_pattern_buf(arena, 8, 99)
    Let rc be Sig.signature_verify(arena, pk, msg, 8, sig)
    T.assert_equal(results, "modulus-mismatched verify -> 0", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_rsa_truncated_spki" takes results as Integer returns Integer:
    Note: Truncated SPKI: a pk_buf of minimum acceptable length (256)
    Note: filled with zeros. rsa_decode_spki must reject.
    T.begin_suite(results, "signature_verify: RSA truncated all-zero SPKI -> 0")
    Let arena be Arena.arena_create(4194304)
    Let pk_buf be Arena.arena_allocate(arena, 256)
    Let zi be 0
    While zi is less than 256:
        Memory.memory_set_byte(pk_buf, zi, 0)
        Set zi to zi plus 1
    End While
    Let pk be PK.public_key_create(arena, Alg.ALG_RSA_PKCS1V15_SHA256_2048, pk_buf, 256)
    T.assert_not_null(results, "pk built", pk)
    Let sig_buf be alloc_pattern_buf(arena, 256, 200)
    Let sig be Sig.signature_create(arena, Alg.ALG_RSA_PKCS1V15_SHA256_2048, sig_buf, 256)
    Let msg be alloc_pattern_buf(arena, 4, 55)
    Let rc be Sig.signature_verify(arena, pk, msg, 4, sig)
    T.assert_equal(results, "all-zero SPKI -> 0", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_rsa_wrong_outer_tag_spki" takes results as Integer returns Integer:
    Note: Wrong outer ASN.1 tag (0x02 INTEGER instead of 0x30 SEQUENCE).
    T.begin_suite(results, "signature_verify: RSA SPKI with wrong outer tag -> 0")
    Let arena be Arena.arena_create(4194304)
    Let pk_buf be Arena.arena_allocate(arena, 256)
    Memory.memory_set_byte(pk_buf, 0, 2)
    Memory.memory_set_byte(pk_buf, 1, 130)
    Memory.memory_set_byte(pk_buf, 2, 0)
    Memory.memory_set_byte(pk_buf, 3, 252)
    Let zi be 4
    While zi is less than 256:
        Memory.memory_set_byte(pk_buf, zi, (zi modulo by 7) plus 1)
        Set zi to zi plus 1
    End While
    Let pk be PK.public_key_create(arena, Alg.ALG_RSA_PKCS1V15_SHA256_2048, pk_buf, 256)
    Let sig_buf be alloc_pattern_buf(arena, 256, 19)
    Let sig be Sig.signature_create(arena, Alg.ALG_RSA_PKCS1V15_SHA256_2048, sig_buf, 256)
    Let msg be alloc_pattern_buf(arena, 4, 77)
    Let rc be Sig.signature_verify(arena, pk, msg, 4, sig)
    T.assert_equal(results, "wrong-outer-tag SPKI -> 0", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_rsa_alg_hash_id_negative_for_non_rsa" takes results as Integer returns Integer:
    Note: SHA-1 strength gate verification. There is no ALG_RSA_*_SHA1
    Note: tag at all; rsa_alg_to_rsa_hash_id returns -1 for any non-RSA
    Note: tag. We verify this contract on a few representative tags so
    Note: a regression that accepts SHA-1 (e.g. by widening the modulus
    Note: index map) surfaces here.
    T.begin_suite(results, "rsa_alg_to_rsa_hash_id: SHA-1 strength gate via tag absence")
    T.assert_equal(results, "ALG_ED25519 -> -1", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_ED25519), 0 minus 1)
    T.assert_equal(results, "ALG_ECDSA_P256 -> -1", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_ECDSA_P256), 0 minus 1)
    T.assert_equal(results, "ALG_SHA2_256 -> -1", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_SHA2_256), 0 minus 1)
    T.assert_equal(results, "ALG_UNKNOWN -> -1", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_UNKNOWN), 0 minus 1)
    Note: Boundary check on slots 109 and 129 (just outside RSA range).
    T.assert_equal(results, "slot 109 -> -1", Alg.rsa_alg_to_rsa_hash_id(109), 0 minus 1)
    T.assert_equal(results, "slot 129 -> -1", Alg.rsa_alg_to_rsa_hash_id(129), 0 minus 1)
    Note: All 18 RSA tags must return a valid hash id (0/1/2).
    T.assert_equal(results, "PKCS1v15-SHA256-2048 -> 0", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_RSA_PKCS1V15_SHA256_2048), 0)
    T.assert_equal(results, "PKCS1v15-SHA384-3072 -> 1", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_RSA_PKCS1V15_SHA384_3072), 1)
    T.assert_equal(results, "PKCS1v15-SHA512-4096 -> 2", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_RSA_PKCS1V15_SHA512_4096), 2)
    T.assert_equal(results, "PSS-SHA256-2048 -> 0", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_RSA_PSS_SHA256_2048), 0)
    T.assert_equal(results, "PSS-SHA384-3072 -> 1", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_RSA_PSS_SHA384_3072), 1)
    T.assert_equal(results, "PSS-SHA512-4096 -> 2", Alg.rsa_alg_to_rsa_hash_id(Alg.ALG_RSA_PSS_SHA512_4096), 2)
    Return 1
End Process

Process called "test_rsa_alg_is_pss_dispatch" takes results as Integer returns Integer:
    T.begin_suite(results, "rsa_alg_is_pss: PSS vs PKCS1v15 dispatch")
    T.assert_equal(results, "PKCS1v15-SHA256-2048 -> 0 (PKCS#1 v1.5)", Alg.rsa_alg_is_pss(Alg.ALG_RSA_PKCS1V15_SHA256_2048), 0)
    T.assert_equal(results, "PKCS1v15-SHA512-4096 -> 0", Alg.rsa_alg_is_pss(Alg.ALG_RSA_PKCS1V15_SHA512_4096), 0)
    T.assert_equal(results, "PSS-SHA256-2048 -> 1 (PSS)", Alg.rsa_alg_is_pss(Alg.ALG_RSA_PSS_SHA256_2048), 1)
    T.assert_equal(results, "PSS-SHA512-4096 -> 1", Alg.rsa_alg_is_pss(Alg.ALG_RSA_PSS_SHA512_4096), 1)
    T.assert_equal(results, "ALG_ED25519 -> -1", Alg.rsa_alg_is_pss(Alg.ALG_ED25519), 0 minus 1)
    T.assert_equal(results, "slot 109 -> -1", Alg.rsa_alg_is_pss(109), 0 minus 1)
    T.assert_equal(results, "slot 129 -> -1", Alg.rsa_alg_is_pss(129), 0 minus 1)
    Return 1
End Process

Process called "test_rsa_alg_modulus_bytes_dispatch" takes results as Integer returns Integer:
    T.begin_suite(results, "rsa_alg_modulus_bytes: tag-level modulus declaration")
    T.assert_equal(results, "PKCS1v15-SHA256-2048 -> 256", Alg.rsa_alg_modulus_bytes(Alg.ALG_RSA_PKCS1V15_SHA256_2048), 256)
    T.assert_equal(results, "PKCS1v15-SHA384-3072 -> 384", Alg.rsa_alg_modulus_bytes(Alg.ALG_RSA_PKCS1V15_SHA384_3072), 384)
    T.assert_equal(results, "PKCS1v15-SHA512-4096 -> 512", Alg.rsa_alg_modulus_bytes(Alg.ALG_RSA_PKCS1V15_SHA512_4096), 512)
    T.assert_equal(results, "PSS-SHA256-2048 -> 256", Alg.rsa_alg_modulus_bytes(Alg.ALG_RSA_PSS_SHA256_2048), 256)
    T.assert_equal(results, "PSS-SHA384-3072 -> 384", Alg.rsa_alg_modulus_bytes(Alg.ALG_RSA_PSS_SHA384_3072), 384)
    T.assert_equal(results, "PSS-SHA512-4096 -> 512", Alg.rsa_alg_modulus_bytes(Alg.ALG_RSA_PSS_SHA512_4096), 512)
    T.assert_equal(results, "ALG_ED25519 -> 0 (not RSA)", Alg.rsa_alg_modulus_bytes(Alg.ALG_ED25519), 0)
    T.assert_equal(results, "ALG_UNKNOWN -> 0", Alg.rsa_alg_modulus_bytes(Alg.ALG_UNKNOWN), 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_create_wrong_length_rejected(results)
    test_create_hash_alg_rejected(results)
    test_create_ed25519_ok(results)
    test_cross_alg_verify_rejected(results)
    test_ed25519_sign_verify_roundtrip(results)
    test_rsa_pkcs1v15_sha256_2048_malformed_spki(results)
    test_rsa_pkcs1v15_sha384_3072_malformed_spki(results)
    test_rsa_pkcs1v15_sha512_4096_malformed_spki(results)
    test_rsa_pss_sha256_2048_malformed_spki(results)
    test_rsa_pss_sha384_3072_malformed_spki(results)
    test_rsa_pss_sha512_4096_malformed_spki(results)
    test_rsa_pkcs1v15_sha256_3072_modulus_mismatch(results)
    test_rsa_truncated_spki(results)
    test_rsa_wrong_outer_tag_spki(results)
    test_rsa_alg_hash_id_negative_for_non_rsa(results)
    test_rsa_alg_is_pss_dispatch(results)
    test_rsa_alg_modulus_bytes_dispatch(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
