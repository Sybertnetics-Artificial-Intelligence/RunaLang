Note:
Tests for crypto_identity/nonce.runa.

Verifies:
  - nonce_context_byte_length returns the right value per context
  - nonce_check_context refuses cross-context use
  - nonce_counter_init + nonce_counter_next advance the counter and
    re-encode it in the nonce bytes correctly
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/nonce.runa" as N

Process called "test_context_byte_lengths" takes results as Integer returns Integer:
    T.begin_suite(results, "nonce_context_byte_length: per-context sizes")
    T.assert_equal(results, "AES-GCM = 12", N.nonce_context_byte_length(N.NONCE_CTX_AES_GCM), 12)
    T.assert_equal(results, "AES-GCM-SIV = 12", N.nonce_context_byte_length(N.NONCE_CTX_AES_GCM_SIV), 12)
    T.assert_equal(results, "ChaCha20 = 12", N.nonce_context_byte_length(N.NONCE_CTX_CHACHA20), 12)
    T.assert_equal(results, "XChaCha20 = 24", N.nonce_context_byte_length(N.NONCE_CTX_XCHACHA20), 24)
    T.assert_equal(results, "ED25519_R = 64", N.nonce_context_byte_length(N.NONCE_CTX_ED25519_R), 64)
    T.assert_equal(results, "TLS_RECORD = 8", N.nonce_context_byte_length(N.NONCE_CTX_TLS_RECORD), 8)
    T.assert_equal(results, "GENERIC = 0", N.nonce_context_byte_length(9), 0)
    Return 1
End Process

Process called "test_context_supports_counter" takes results as Integer returns Integer:
    T.begin_suite(results, "nonce_context_supports_counter: which contexts allow counter mode")
    T.assert_equal(results, "AES-GCM supports counter", N.nonce_context_supports_counter(N.NONCE_CTX_AES_GCM), 1)
    T.assert_equal(results, "TLS_RECORD supports counter", N.nonce_context_supports_counter(N.NONCE_CTX_TLS_RECORD), 1)
    T.assert_equal(results, "XChaCha20 does NOT support counter (random-only)", N.nonce_context_supports_counter(N.NONCE_CTX_XCHACHA20), 0)
    T.assert_equal(results, "ECDSA_K does NOT support counter", N.nonce_context_supports_counter(N.NONCE_CTX_ECDSA_K), 0)
    Return 1
End Process

Process called "test_counter_init_encodes_value" takes results as Integer returns Integer:
    T.begin_suite(results, "nonce_counter_init: salt + initial counter encoded")
    Let arena be Arena.arena_create(1048576)
    Let salt be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(salt, 0, 9)
    Memory.memory_set_byte(salt, 1, 8)
    Memory.memory_set_byte(salt, 2, 7)
    Memory.memory_set_byte(salt, 3, 6)
    Let n be N.nonce_counter_init(arena, N.NONCE_CTX_AES_GCM, salt, 1)
    T.assert_not_null(results, "counter nonce created", n)
    T.assert_equal(results, "context tag = AES_GCM", N.nonce_context(n), N.NONCE_CTX_AES_GCM)
    T.assert_equal(results, "length = 12", N.nonce_byte_length(n), 12)
    Let buf be N.nonce_bytes(n)
    Note: First 4 bytes = salt.
    T.assert_equal(results, "byte[0] = 9 (salt)", Memory.memory_get_byte(buf, 0), 9)
    T.assert_equal(results, "byte[3] = 6 (salt)", Memory.memory_get_byte(buf, 3), 6)
    Note: Last byte of counter (big-endian; initial=1) = 1.
    T.assert_equal(results, "byte[11] = 1 (counter LSB)", Memory.memory_get_byte(buf, 11), 1)
    T.assert_equal(results, "counter value = 1", N.nonce_counter_value(n), 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_counter_next_advances" takes results as Integer returns Integer:
    T.begin_suite(results, "nonce_counter_next: advances and re-encodes")
    Let arena be Arena.arena_create(1048576)
    Let salt be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(salt, 0, 0)
    Memory.memory_set_byte(salt, 1, 0)
    Memory.memory_set_byte(salt, 2, 0)
    Memory.memory_set_byte(salt, 3, 0)
    Let n be N.nonce_counter_init(arena, N.NONCE_CTX_TLS_RECORD, salt, 254)
    T.assert_not_null(results, "TLS_RECORD counter nonce created", n)
    Let buf be N.nonce_bytes(n)
    Note: TLS_RECORD is 8 bytes: 4-byte salt + 4-byte counter.
    T.assert_equal(results, "counter LSB = 254", Memory.memory_get_byte(buf, 7), 254)
    N.nonce_counter_next(n)
    T.assert_equal(results, "counter value = 255 after next", N.nonce_counter_value(n), 255)
    T.assert_equal(results, "counter byte LSB = 255", Memory.memory_get_byte(buf, 7), 255)
    N.nonce_counter_next(n)
    Note: After increment from 255 -> 256, LSB is 0 and previous byte is 1.
    T.assert_equal(results, "counter value = 256", N.nonce_counter_value(n), 256)
    T.assert_equal(results, "counter byte[7] = 0 after carry", Memory.memory_get_byte(buf, 7), 0)
    T.assert_equal(results, "counter byte[6] = 1 after carry", Memory.memory_get_byte(buf, 6), 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_check_context_rejects_mismatch" takes results as Integer returns Integer:
    T.begin_suite(results, "nonce_check_context: cross-context refused")
    Let arena be Arena.arena_create(1048576)
    Let salt be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(salt, 0, 0)
    Memory.memory_set_byte(salt, 1, 0)
    Memory.memory_set_byte(salt, 2, 0)
    Memory.memory_set_byte(salt, 3, 0)
    Let n be N.nonce_counter_init(arena, N.NONCE_CTX_AES_GCM, salt, 0)
    T.assert_equal(results, "AES-GCM nonce passes AES-GCM check", N.nonce_check_context(n, N.NONCE_CTX_AES_GCM), 1)
    T.assert_equal(results, "AES-GCM nonce fails CHACHA20 check", N.nonce_check_context(n, N.NONCE_CTX_CHACHA20), 0)
    T.assert_equal(results, "AES-GCM nonce fails ECDSA_K check", N.nonce_check_context(n, N.NONCE_CTX_ECDSA_K), 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_counter_init_rejects_non_counter_context" takes results as Integer returns Integer:
    T.begin_suite(results, "nonce_counter_init: rejects non-counter context")
    Let arena be Arena.arena_create(1048576)
    Let salt be Arena.arena_allocate(arena, 4)
    Memory.memory_set_byte(salt, 0, 0)
    Memory.memory_set_byte(salt, 1, 0)
    Memory.memory_set_byte(salt, 2, 0)
    Memory.memory_set_byte(salt, 3, 0)
    Note: XChaCha20 is random-only; counter_init must reject.
    Let n be N.nonce_counter_init(arena, N.NONCE_CTX_XCHACHA20, salt, 0)
    T.assert_equal(results, "XChaCha20 counter_init rejected", n, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_context_byte_lengths(results)
    test_context_supports_counter(results)
    test_counter_init_encodes_value(results)
    test_counter_next_advances(results)
    test_check_context_rejects_mismatch(results)
    test_counter_init_rejects_non_counter_context(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
