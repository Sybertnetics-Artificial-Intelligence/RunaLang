Note:
Tests for crypto_identity/public_key.runa.

Verifies:
  - construction succeeds for valid (algorithm, length) pairs
  - construction rejects mismatched length
  - construction rejects non-asymmetric algorithm tags
  - hex / base64 round-trip
  - constant-time equality works on identical keys, rejects different keys
  - cross-algorithm comparison is rejected
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/crypto_identity/crypto_algorithm.runa" as Alg
Import "compiler/frontend/primitives/crypto_identity/public_key.runa" as PK

Process called "fill_32_pattern" takes buf as Integer, seed as Integer returns Integer:
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(buf, i, (i plus seed) modulo by 256)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "test_ed25519_construct_ok" takes results as Integer returns Integer:
    T.begin_suite(results, "public_key_create: Ed25519 32-byte construct succeeds")
    Let arena be Arena.arena_create(1048576)
    Let buf be Arena.arena_allocate(arena, 32)
    fill_32_pattern(buf, 1)
    Let pk be PK.public_key_create(arena, Alg.ALG_ED25519, buf, 32)
    T.assert_not_null(results, "pk is non-null", pk)
    T.assert_equal(results, "pk alg = ED25519", PK.public_key_algorithm(pk), Alg.ALG_ED25519)
    T.assert_equal(results, "pk byte length = 32", PK.public_key_byte_length(pk), 32)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_ed25519_construct_wrong_length" takes results as Integer returns Integer:
    T.begin_suite(results, "public_key_create: Ed25519 + wrong length rejected")
    Let arena be Arena.arena_create(1048576)
    Let buf be Arena.arena_allocate(arena, 31)
    Let i be 0
    While i is less than 31:
        Memory.memory_set_byte(buf, i, 0)
        Set i to i plus 1
    End While
    Let pk be PK.public_key_create(arena, Alg.ALG_ED25519, buf, 31)
    T.assert_equal(results, "31-byte Ed25519 key rejected", pk, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_hash_alg_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "public_key_create: hash algorithm tag rejected")
    Let arena be Arena.arena_create(1048576)
    Let buf be Arena.arena_allocate(arena, 32)
    fill_32_pattern(buf, 0)
    Let pk be PK.public_key_create(arena, Alg.ALG_SHA2_256, buf, 32)
    T.assert_equal(results, "SHA-256 alg tag for pk rejected", pk, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_cross_alg_equality_rejected" takes results as Integer returns Integer:
    T.begin_suite(results, "public_key_equal: cross-algorithm rejected")
    Let arena be Arena.arena_create(1048576)
    Let buf be Arena.arena_allocate(arena, 32)
    fill_32_pattern(buf, 7)
    Let pk_ed be PK.public_key_create(arena, Alg.ALG_ED25519, buf, 32)
    Let pk_x be PK.public_key_create(arena, Alg.ALG_X25519, buf, 32)
    Let eq be PK.public_key_equal(pk_ed, pk_x)
    T.assert_equal(results, "Ed25519 key bytes != X25519 key bytes (cross-alg)", eq, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_same_alg_equality_works" takes results as Integer returns Integer:
    T.begin_suite(results, "public_key_equal: identical bytes + same alg = equal")
    Let arena be Arena.arena_create(1048576)
    Let buf1 be Arena.arena_allocate(arena, 32)
    Let buf2 be Arena.arena_allocate(arena, 32)
    fill_32_pattern(buf1, 13)
    fill_32_pattern(buf2, 13)
    Let pk1 be PK.public_key_create(arena, Alg.ALG_ED25519, buf1, 32)
    Let pk2 be PK.public_key_create(arena, Alg.ALG_ED25519, buf2, 32)
    Let eq be PK.public_key_equal(pk1, pk2)
    T.assert_equal(results, "same bytes + same alg compare equal", eq, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_different_bytes_unequal" takes results as Integer returns Integer:
    T.begin_suite(results, "public_key_equal: same alg, different bytes unequal")
    Let arena be Arena.arena_create(1048576)
    Let buf1 be Arena.arena_allocate(arena, 32)
    Let buf2 be Arena.arena_allocate(arena, 32)
    fill_32_pattern(buf1, 3)
    fill_32_pattern(buf2, 17)
    Let pk1 be PK.public_key_create(arena, Alg.ALG_ED25519, buf1, 32)
    Let pk2 be PK.public_key_create(arena, Alg.ALG_ED25519, buf2, 32)
    Let eq be PK.public_key_equal(pk1, pk2)
    T.assert_equal(results, "different bytes compare unequal", eq, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_metadata_ml_dsa_44" takes results as Integer returns Integer:
    T.begin_suite(results, "algorithm metadata: ML-DSA-44 key sizes")
    T.assert_equal(results, "ML-DSA-44 pubkey = 1312", Alg.algorithm_key_byte_length(Alg.ALG_ML_DSA_44), 1312)
    T.assert_equal(results, "ML-DSA-44 sec = 2560", Alg.algorithm_private_key_byte_length(Alg.ALG_ML_DSA_44), 2560)
    T.assert_equal(results, "ML-DSA-44 sig = 2420", Alg.algorithm_signature_byte_length(Alg.ALG_ML_DSA_44), 2420)
    T.assert_equal(results, "ML-DSA-44 is post-quantum", Alg.algorithm_is_post_quantum(Alg.ALG_ML_DSA_44), 1)
    T.assert_equal(results, "ML-DSA-44 is not classical", Alg.algorithm_is_classical(Alg.ALG_ML_DSA_44), 0)
    Return 1
End Process

Process called "test_metadata_ed25519" takes results as Integer returns Integer:
    T.begin_suite(results, "algorithm metadata: Ed25519")
    T.assert_equal(results, "Ed25519 pubkey = 32", Alg.algorithm_key_byte_length(Alg.ALG_ED25519), 32)
    T.assert_equal(results, "Ed25519 sec = 32", Alg.algorithm_private_key_byte_length(Alg.ALG_ED25519), 32)
    T.assert_equal(results, "Ed25519 sig = 64", Alg.algorithm_signature_byte_length(Alg.ALG_ED25519), 64)
    T.assert_equal(results, "Ed25519 is classical", Alg.algorithm_is_classical(Alg.ALG_ED25519), 1)
    T.assert_equal(results, "Ed25519 is not post-quantum", Alg.algorithm_is_post_quantum(Alg.ALG_ED25519), 0)
    T.assert_equal(results, "Ed25519 security bits = 128", Alg.algorithm_security_bits(Alg.ALG_ED25519), 128)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_ed25519_construct_ok(results)
    test_ed25519_construct_wrong_length(results)
    test_hash_alg_rejected(results)
    test_cross_alg_equality_rejected(results)
    test_same_alg_equality_works(results)
    test_different_bytes_unequal(results)
    test_metadata_ml_dsa_44(results)
    test_metadata_ed25519(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
