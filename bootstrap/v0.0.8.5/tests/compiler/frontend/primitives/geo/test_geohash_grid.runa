Note:
KAT for compiler/frontend/primitives/geo/geohash_grid.runa.

Verifies:
  - Cell width/height decrease geometrically with precision
  - Bounding box of a known geohash contains its centre
  - Neighbour cells are different from the source cell
  - Neighbour-of-neighbour relationships are consistent
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/geo/geohash_grid.runa" as GG
Import "compiler/frontend/primitives/geo/geohash.runa" as GH
Import "compiler/frontend/primitives/geo/bounding_box.runa" as BB
Import "compiler/frontend/primitives/core/string_core.runa" as StrCore
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let scaled be f multiplied by scale
    Return proc float_to_int from Arith with scaled
End Process

Process called "test_cell_dimensions" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash_grid.cell_dimensions")

    Note: precision 1: 4 lon bits (32 cells across 360 deg) -> width = 45
    Note: precision 1: 3 lat bits (8 cells across 180 deg) -> height = 22.5? Actually
    Note: precision N=1 -> total_bits = 5, lon_bits = (5+1)/2 = 3, 2^3=8 -> w = 45 deg
    Note: lat_bits = 5/2 = 2, 2^2 = 4 -> h = 45 deg
    Let w1 be proc geohash_grid_width_degrees from GG with 1
    Let h1 be proc geohash_grid_height_degrees from GG with 1
    T.assert_equal(results, "p1 width = 45", float_to_scaled_int(w1, 1.0), 45)
    T.assert_equal(results, "p1 height = 45", float_to_scaled_int(h1, 1.0), 45)

    Note: precision 2: total_bits=10, lon=5 (32 across 360 -> w=11.25), lat=5 -> 360/32 = 11.25, h=180/32=5.625
    Let w2 be proc geohash_grid_width_degrees from GG with 2
    Let h2 be proc geohash_grid_height_degrees from GG with 2
    T.assert_equal(results, "p2 width = 11.25*100", float_to_scaled_int(w2, 100.0), 1125)
    T.assert_equal(results, "p2 height = 5.625*1000", float_to_scaled_int(h2, 1000.0), 5625)

    Return 1
End Process

Process called "test_bounding_box_contains_center" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash_grid.bbox_contains_center")

    Let hash be proc geohash_encode from GH with 51.5074, 0.0 minus 0.1278, 6
    Let bb be proc geohash_grid_bounding_box from GG with hash
    Note: Center should be inside its own bbox
    T.assert_equal(results, "center inside bbox", proc bbox_contains_point from BB with bb, 51.5074, 0.0 minus 0.1278, 1)

    Return 1
End Process

Process called "test_neighbors_differ" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash_grid.neighbors_differ")

    Let hash be proc geohash_encode from GH with 40.7128, 0.0 minus 74.0060, 5
    Let n be proc geohash_grid_neighbor_north from GG with hash
    Let s be proc geohash_grid_neighbor_south from GG with hash
    Let e be proc geohash_grid_neighbor_east from GG with hash
    Let w be proc geohash_grid_neighbor_west from GG with hash

    T.assert_equal(results, "N != orig", proc string_equals from StrCore with n, hash, 0)
    T.assert_equal(results, "S != orig", proc string_equals from StrCore with s, hash, 0)
    T.assert_equal(results, "E != orig", proc string_equals from StrCore with e, hash, 0)
    T.assert_equal(results, "W != orig", proc string_equals from StrCore with w, hash, 0)

    Return 1
End Process

Process called "test_diagonal_neighbors" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash_grid.diagonal_neighbors")

    Let hash be proc geohash_encode from GH with 40.0, 0.0 minus 70.0, 5
    Let ne be proc geohash_grid_neighbor_northeast from GG with hash
    Let nw be proc geohash_grid_neighbor_northwest from GG with hash
    Let se be proc geohash_grid_neighbor_southeast from GG with hash
    Let sw be proc geohash_grid_neighbor_southwest from GG with hash

    Note: All diagonal neighbours should be distinct from origin
    T.assert_equal(results, "NE != orig", proc string_equals from StrCore with ne, hash, 0)
    T.assert_equal(results, "NW != orig", proc string_equals from StrCore with nw, hash, 0)
    T.assert_equal(results, "SE != orig", proc string_equals from StrCore with se, hash, 0)
    T.assert_equal(results, "SW != orig", proc string_equals from StrCore with sw, hash, 0)

    Note: NE != NW, SE != SW
    T.assert_equal(results, "NE != NW", proc string_equals from StrCore with ne, nw, 0)
    T.assert_equal(results, "SE != SW", proc string_equals from StrCore with se, sw, 0)

    Return 1
End Process

Process called "test_neighbors_have_same_length" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash_grid.same_precision")

    Let hash be proc geohash_encode from GH with 35.6762, 139.6503, 6
    Let length_orig be proc string_length from StrCore with hash
    Let n be proc geohash_grid_neighbor_north from GG with hash
    T.assert_equal(results, "N has same length", proc string_length from StrCore with n, length_orig)
    Let e be proc geohash_grid_neighbor_east from GG with hash
    T.assert_equal(results, "E has same length", proc string_length from StrCore with e, length_orig)

    Return 1
End Process

Process called "test_decode_with_extent" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash_grid.decode_with_extent")

    Let hash be proc geohash_encode from GH with 35.6762, 139.6503, 5
    Let cell be proc geohash_grid_decode_with_extent from GG with hash
    Note: half-extents are positive
    T.assert_greater_than(results, "lat half extent > 0", float_to_scaled_int(proc geohash_grid_cell_lat_half_extent from GG with cell, 1000.0), 0)
    T.assert_greater_than(results, "lon half extent > 0", float_to_scaled_int(proc geohash_grid_cell_lon_half_extent from GG with cell, 1000.0), 0)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_cell_dimensions(results)
    test_bounding_box_contains_center(results)
    test_neighbors_differ(results)
    test_diagonal_neighbors(results)
    test_neighbors_have_same_length(results)
    test_decode_with_extent(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
