Note:
KAT for compiler/frontend/primitives/geo/latlon.runa.

Verifies:
  - Constructor stores radians correctly
  - Haversine London-Paris ~ 343 km
  - Vincenty London-NYC ~ 5570 km
  - Antipode of (0, 0) is (0, 180)
  - destination_point preserves the starting bearing approximately
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/geo/latlon.runa" as LL
Import "compiler/frontend/primitives/geo/ellipsoid.runa" as Ell
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Note: Round half-up to mitigate Float64 representation error. Without
    Note: rounding, 45 deg -> rad -> deg = 44.99999...96 which truncates to
    Note: 44 instead of 45. Adding +/-0.5 before truncation yields nearest-
    Note: integer semantics, matching the round-trip identity assertions in
    Note: tests that verify deg<->rad inverses and great-circle endpoints.
    Let scaled be f multiplied by scale
    If scaled is greater than or equal to 0.0:
        Set scaled to scaled plus 0.5
    Otherwise:
        Set scaled to scaled minus 0.5
    End If
    Return proc float_to_int from Arith with scaled
End Process

Process called "test_constructor" takes results as Integer returns Integer:
    T.begin_suite(results, "latlon.constructor")

    Let p be proc latlon_create_wgs84 from LL with 45.0, 90.0
    Note: 45 deg = 0.78539816... rad; *10000 + half-up rounding = 7854.
    T.assert_equal(results, "45 deg -> rad *10000", float_to_scaled_int((proc latlon_latitude_radians from LL with p), 10000.0), 7854)
    T.assert_equal(results, "round-trip to deg", float_to_scaled_int((proc latlon_latitude_degrees from LL with p), 1.0), 45)

    Return 1
End Process

Process called "test_haversine_london_paris" takes results as Integer returns Integer:
    T.begin_suite(results, "latlon.haversine_london_paris")

    Note: London Heathrow LHR ~ (51.4700, -0.4543), Paris CDG ~ (49.0097, 2.5479)
    Let london be proc latlon_create_wgs84 from LL with 51.4700, 0.0 minus 0.4543
    Let paris be proc latlon_create_wgs84 from LL with 49.0097, 2.5479
    Let dist be proc haversine_distance from LL with london, paris
    Note: ~ 343 km, accept 340000 .. 350000 m
    T.assert_greater_than(results, "LHR-CDG > 340000 m", float_to_scaled_int(dist, 1.0), 340000)
    T.assert_less_than(results, "LHR-CDG < 360000 m", float_to_scaled_int(dist, 1.0), 360000)

    Return 1
End Process

Process called "test_vincenty_london_nyc" takes results as Integer returns Integer:
    T.begin_suite(results, "latlon.vincenty_london_nyc")

    Note: London (51.5074, -0.1278), New York (40.7128, -74.0060)
    Let london be proc latlon_create_wgs84 from LL with 51.5074, 0.0 minus 0.1278
    Let nyc be proc latlon_create_wgs84 from LL with 40.7128, 0.0 minus 74.0060
    Let dist be proc vincenty_distance from LL with london, nyc
    Note: Vincenty distance ~ 5570 km. Allow range 5500-5600 km to absorb iteration tolerance.
    T.assert_greater_than(results, "LON-NYC > 5500 km", float_to_scaled_int(dist, 1.0), 5500000)
    T.assert_less_than(results, "LON-NYC < 5600 km", float_to_scaled_int(dist, 1.0), 5600000)

    Return 1
End Process

Process called "test_antipode" takes results as Integer returns Integer:
    T.begin_suite(results, "latlon.antipode")

    Let origin be proc latlon_create_wgs84 from LL with 0.0, 0.0
    Let anti be proc antipode from LL with origin
    T.assert_equal(results, "antipode(0,0) lat = 0", float_to_scaled_int((proc latlon_latitude_degrees from LL with anti), 1.0), 0)
    Note: antipode longitude is +pi rad = +180 deg
    T.assert_equal(results, "antipode(0,0) lon = +180", float_to_scaled_int((proc latlon_longitude_degrees from LL with anti), 1.0), 180)

    Note: antipode of (45, 30) is (-45, -150)
    Let p be proc latlon_create_wgs84 from LL with 45.0, 30.0
    Let ap be proc antipode from LL with p
    T.assert_equal(results, "antipode(45,30) lat = -45", float_to_scaled_int((proc latlon_latitude_degrees from LL with ap), 1.0), 0 minus 45)
    T.assert_equal(results, "antipode(45,30) lon = -150", float_to_scaled_int((proc latlon_longitude_degrees from LL with ap), 1.0), 0 minus 150)

    Return 1
End Process

Process called "test_initial_bearing" takes results as Integer returns Integer:
    T.begin_suite(results, "latlon.initial_bearing")

    Note: Due east from equator: bearing ~ 90 deg = pi/2 rad
    Let p1 be proc latlon_create_wgs84 from LL with 0.0, 0.0
    Let p2 be proc latlon_create_wgs84 from LL with 0.0, 10.0
    Let bearing be proc initial_bearing from LL with p1, p2
    Note: pi/2 ~ 1.5708 rad. Scale by 10000.
    T.assert_greater_than(results, "due east > pi/2 - eps", float_to_scaled_int(bearing, 10000.0), 15700)
    T.assert_less_than(results, "due east < pi/2 + eps", float_to_scaled_int(bearing, 10000.0), 15720)

    Return 1
End Process

Process called "test_vincenty_london_paris" takes results as Integer returns Integer:
    T.begin_suite(results, "latlon.vincenty_london_paris")

    Note: London (51.5074, -0.1278), Paris (48.8566, 2.3522).
    Note: Vincenty ellipsoidal distance ~ 343.6 km. Tighter ellipsoidal
    Note: bound than haversine confirms the corrected A/B Horner expansion.
    Let london be proc latlon_create_wgs84 from LL with 51.5074, 0.0 minus 0.1278
    Let paris be proc latlon_create_wgs84 from LL with 48.8566, 2.3522
    Let dist be proc vincenty_distance from LL with london, paris
    T.assert_greater_than(results, "LON-PAR > 340000 m", float_to_scaled_int(dist, 1.0), 340000)
    T.assert_less_than(results, "LON-PAR < 350000 m", float_to_scaled_int(dist, 1.0), 350000)

    Return 1
End Process

Process called "test_destination_point" takes results as Integer returns Integer:
    T.begin_suite(results, "latlon.destination_point")

    Note: From (0, 0), heading 90 deg east, going 1/4 great-circle (pi/2 * R ~ 1e7 m)
    Let p be proc latlon_create_wgs84 from LL with 0.0, 0.0
    Let east_rad be 1.5707963267948966
    Let quarter_circ be 10007543.398
    Let dest be proc destination_point from LL with p, east_rad, quarter_circ
    Note: Should end at (0, 90)
    T.assert_equal(results, "dest lat = 0", float_to_scaled_int((proc latlon_latitude_degrees from LL with dest), 1.0), 0)
    T.assert_equal(results, "dest lon = 90", float_to_scaled_int((proc latlon_longitude_degrees from LL with dest), 1.0), 90)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_constructor(results)
    test_haversine_london_paris(results)
    test_vincenty_london_nyc(results)
    test_vincenty_london_paris(results)
    test_antipode(results)
    test_initial_bearing(results)
    test_destination_point(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
