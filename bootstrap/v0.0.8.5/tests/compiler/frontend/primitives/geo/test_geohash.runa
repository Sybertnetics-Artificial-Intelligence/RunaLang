Note:
KAT for compiler/frontend/primitives/geo/geohash.runa.

Verifies:
  - Geohash alphabet character lookup.
  - Encode-decode round trip (within the precision-determined bin size).
  - S2 cell ID is a 64-bit integer for valid inputs (deterministic).
  - H3 base cell selection is in range.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/geo/geohash.runa" as GH
Import "compiler/frontend/primitives/geo/geo_coordinate.runa" as G
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith
Import "compiler/frontend/primitives/core/string_core.runa" as StrCore

Process called "abs_float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let a be f
    If a is less than 0.0:
        Set a to 0.0 minus a
    End If
    Return proc float_to_int from Arith with (a multiplied by scale)
End Process

Process called "test_alphabet" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash.alphabet")

    Note: idx 0 = '0' (ASCII 48)
    T.assert_equal(results, "alpha[0] = '0'", GH.geohash_alphabet_char_at(0), 48)
    Note: idx 9 = '9' (ASCII 57)
    T.assert_equal(results, "alpha[9] = '9'", GH.geohash_alphabet_char_at(9), 57)
    Note: idx 10 = 'b' (ASCII 98)
    T.assert_equal(results, "alpha[10] = 'b'", GH.geohash_alphabet_char_at(10), 98)
    Note: idx 31 = 'z' (ASCII 122)
    T.assert_equal(results, "alpha[31] = 'z'", GH.geohash_alphabet_char_at(31), 122)

    Note: Inverse
    T.assert_equal(results, "inv('0') = 0", GH.geohash_alphabet_index_for_char(48), 0)
    T.assert_equal(results, "inv('z') = 31", GH.geohash_alphabet_index_for_char(122), 31)

    Return 1
End Process

Process called "test_encode_decode_round_trip" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash.round_trip")

    Note: San Francisco approximate
    Let sf_lat be 37.7749
    Let sf_lon be 0.0 minus 122.4194
    Let hash be GH.geohash_encode(sf_lat, sf_lon, 8)
    Note: 8-char geohash bin size is ~ 19 meters in lat and ~ 19 meters in lon
    Let decoded_lat be GH.geohash_decode_lat(hash)
    Let decoded_lon be GH.geohash_decode_lon(hash)
    Let lat_diff be decoded_lat minus sf_lat
    Let lat_diff_x10000 be abs_float_to_scaled_int(lat_diff, 10000.0)
    T.assert_less_than(results, "lat round-trip <0.01 deg", lat_diff_x10000, 100)
    Let lon_diff be decoded_lon minus sf_lon
    Let lon_diff_x10000 be abs_float_to_scaled_int(lon_diff, 10000.0)
    T.assert_less_than(results, "lon round-trip <0.01 deg", lon_diff_x10000, 100)

    Note: Verify hash is non-empty
    T.assert_equal(results, "hash len = 8", StrCore.string_length(hash), 8)

    Return 1
End Process

Process called "test_s2_cell_deterministic" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash.s2_cell")

    Let cell1 be GH.s2_cell_id_from_lat_lon(40.7128, 0.0 minus 74.0060, 10)
    Let cell2 be GH.s2_cell_id_from_lat_lon(40.7128, 0.0 minus 74.0060, 10)
    T.assert_equal(results, "same input -> same cell", cell1, cell2)

    Note: Different inputs should likely produce different cells
    Let cell3 be GH.s2_cell_id_from_lat_lon(0.0, 0.0, 10)
    T.assert_not_equal(results, "different input -> different cell", cell1, cell3)

    Return 1
End Process

Process called "test_h3_base_cell" takes results as Integer returns Integer:
    T.begin_suite(results, "geohash.h3_base")

    Let cell_eq be GH.h3_base_cell_for_lat_lon(0.0, 0.0, 0)
    Note: At the equator the band index ~ 5 (45 lat / 16.36 ~ 2.75? - centered, let's just verify in [0, 131])
    T.assert_greater_than(results, "h3 base cell >= 0", cell_eq, 0 minus 1)
    T.assert_less_than(results, "h3 base cell < 132", cell_eq, 132)

    Note: Different points should yield different cells (usually)
    Let cell_np be GH.h3_base_cell_for_lat_lon(89.0, 0.0, 0)
    T.assert_greater_than(results, "h3 np cell >= 0", cell_np, 0 minus 1)
    T.assert_less_than(results, "h3 np cell < 132", cell_np, 132)
    T.assert_not_equal(results, "eq != np", cell_eq, cell_np)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_alphabet(results)
    test_encode_decode_round_trip(results)
    test_s2_cell_deterministic(results)
    test_h3_base_cell(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
