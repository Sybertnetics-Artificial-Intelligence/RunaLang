Note:
KAT for compiler/frontend/primitives/geo/bounding_box.runa.

Verifies:
  - Basic construction from corners
  - Containment of points within and outside
  - Intersection and union
  - Antimeridian crossing detection and split
  - Center latitude/longitude
  - Empty test
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/geo/bounding_box.runa" as BB
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let scaled be f multiplied by scale
    Return proc float_to_int from Arith with scaled
End Process

Process called "test_create_and_accessors" takes results as Integer returns Integer:
    T.begin_suite(results, "bbox.create_accessors")

    Let bb be proc bbox_create from BB with 10.0, 20.0, 30.0, 40.0
    T.assert_equal(results, "min_lat = 10", float_to_scaled_int((proc bbox_min_lat from BB with bb), 1.0), 10)
    T.assert_equal(results, "max_lat = 20", float_to_scaled_int((proc bbox_max_lat from BB with bb), 1.0), 20)
    T.assert_equal(results, "min_lon = 30", float_to_scaled_int((proc bbox_min_lon from BB with bb), 1.0), 30)
    T.assert_equal(results, "max_lon = 40", float_to_scaled_int((proc bbox_max_lon from BB with bb), 1.0), 40)

    Return 1
End Process

Process called "test_contains_point" takes results as Integer returns Integer:
    T.begin_suite(results, "bbox.contains_point")

    Let bb be proc bbox_create from BB with 0.0, 50.0, 0.0, 100.0
    T.assert_equal(results, "(25, 50) inside", (proc bbox_contains_point from BB with bb, 25.0, 50.0), 1)
    T.assert_equal(results, "(0, 0) edge", (proc bbox_contains_point from BB with bb, 0.0, 0.0), 1)
    T.assert_equal(results, "(50, 100) edge", (proc bbox_contains_point from BB with bb, 50.0, 100.0), 1)
    T.assert_equal(results, "(-10, 50) outside lat", (proc bbox_contains_point from BB with bb, 0.0 minus 10.0, 50.0), 0)
    T.assert_equal(results, "(25, 200) outside lon", (proc bbox_contains_point from BB with bb, 25.0, 200.0), 0)

    Return 1
End Process

Process called "test_intersection_union" takes results as Integer returns Integer:
    T.begin_suite(results, "bbox.intersect_union")

    Let a be proc bbox_create from BB with 0.0, 10.0, 0.0, 10.0
    Let b be proc bbox_create from BB with 5.0, 15.0, 5.0, 15.0
    Let inter be proc bbox_intersection from BB with a, b
    Let uni be proc bbox_union from BB with a, b

    T.assert_equal(results, "inter min_lat = 5", float_to_scaled_int((proc bbox_min_lat from BB with inter), 1.0), 5)
    T.assert_equal(results, "inter max_lat = 10", float_to_scaled_int((proc bbox_max_lat from BB with inter), 1.0), 10)
    T.assert_equal(results, "union min_lat = 0", float_to_scaled_int((proc bbox_min_lat from BB with uni), 1.0), 0)
    T.assert_equal(results, "union max_lat = 15", float_to_scaled_int((proc bbox_max_lat from BB with uni), 1.0), 15)

    Return 1
End Process

Process called "test_intersects" takes results as Integer returns Integer:
    T.begin_suite(results, "bbox.intersects")

    Let a be proc bbox_create from BB with 0.0, 10.0, 0.0, 10.0
    Let b be proc bbox_create from BB with 5.0, 15.0, 5.0, 15.0
    Let c be proc bbox_create from BB with 20.0, 30.0, 20.0, 30.0

    T.assert_equal(results, "a-b overlap", (proc bbox_intersects from BB with a, b), 1)
    T.assert_equal(results, "a-c disjoint", (proc bbox_intersects from BB with a, c), 0)

    Return 1
End Process

Process called "test_intersects_antimeridian" takes results as Integer returns Integer:
    T.begin_suite(results, "bbox.intersects_antimeridian")

    Note: Wide Pacific bbox wrapping the antimeridian: lon [140, 180] U [-180, -140].
    Let pacific be proc bbox_create from BB with 0.0 minus 10.0, 30.0, 140.0, 0.0 minus 140.0

    Note: Hawaii sits in the western arm [-180, -140]: lon [-160, -155]. Should intersect.
    Let hawaii be proc bbox_create from BB with 18.0, 23.0, 0.0 minus 160.0, 0.0 minus 155.0
    T.assert_equal(results, "pacific-hawaii overlap", (proc bbox_intersects from BB with pacific, hawaii), 1)
    T.assert_equal(results, "hawaii-pacific overlap symmetric", (proc bbox_intersects from BB with hawaii, pacific), 1)

    Note: Kiribati sits in the eastern arm [140, 180]: lon [172, 178]. Should intersect.
    Let kiribati be proc bbox_create from BB with 0.0 minus 5.0, 5.0, 172.0, 178.0
    T.assert_equal(results, "pacific-kiribati overlap", (proc bbox_intersects from BB with pacific, kiribati), 1)

    Note: A bbox at lon=0 sits between the two arms of pacific and should NOT intersect.
    Note: Use a lat-overlapping bbox so failure can only come from longitude logic.
    Let mid_atlantic be proc bbox_create from BB with 0.0, 10.0, 0.0 minus 30.0, 30.0
    T.assert_equal(results, "pacific-midatlantic disjoint", (proc bbox_intersects from BB with pacific, mid_atlantic), 0)
    T.assert_equal(results, "midatlantic-pacific disjoint symmetric", (proc bbox_intersects from BB with mid_atlantic, pacific), 0)

    Note: A second wrapping bbox always overlaps with the first wrapping bbox
    Note: (both span +/-180 so they share at least the antimeridian line).
    Let wrap2 be proc bbox_create from BB with 0.0, 20.0, 150.0, 0.0 minus 150.0
    T.assert_equal(results, "two wrapping bboxes overlap", (proc bbox_intersects from BB with pacific, wrap2), 1)

    Note: Lat-disjoint case: pacific is lat [-10, 30] but a bbox at lat [50, 60] should not overlap.
    Let arctic_wrap be proc bbox_create from BB with 50.0, 60.0, 170.0, 0.0 minus 170.0
    T.assert_equal(results, "pacific-arctic lat-disjoint", (proc bbox_intersects from BB with pacific, arctic_wrap), 0)

    Return 1
End Process

Process called "test_antimeridian" takes results as Integer returns Integer:
    T.begin_suite(results, "bbox.antimeridian")

    Note: bbox wrapping across the antimeridian: min_lon = 170, max_lon = -170
    Let bb be proc bbox_create from BB with 0.0, 10.0, 170.0, 0.0 minus 170.0
    T.assert_equal(results, "crosses antimeridian", (proc bbox_crosses_antimeridian from BB with bb), 1)
    Note: (5, 175) is inside (in the western arm)
    T.assert_equal(results, "(5, 175) inside wrap", (proc bbox_contains_point from BB with bb, 5.0, 175.0), 1)
    Note: (5, -175) is inside (in the eastern arm)
    T.assert_equal(results, "(5, -175) inside wrap", (proc bbox_contains_point from BB with bb, 5.0, 0.0 minus 175.0), 1)
    Note: (5, 0) is outside
    T.assert_equal(results, "(5, 0) outside wrap", (proc bbox_contains_point from BB with bb, 5.0, 0.0), 0)

    Note: Split into west [170, 180] and east [-180, -170]
    Let west be proc bbox_split_into_west_part from BB with bb
    Let east be proc bbox_split_into_east_part from BB with bb
    T.assert_equal(results, "west.min_lon = 170", float_to_scaled_int((proc bbox_min_lon from BB with west), 1.0), 170)
    T.assert_equal(results, "west.max_lon = 180", float_to_scaled_int((proc bbox_max_lon from BB with west), 1.0), 180)
    T.assert_equal(results, "east.min_lon = -180", float_to_scaled_int((proc bbox_min_lon from BB with east), 1.0), 0 minus 180)
    T.assert_equal(results, "east.max_lon = -170", float_to_scaled_int((proc bbox_max_lon from BB with east), 1.0), 0 minus 170)

    Return 1
End Process

Process called "test_center" takes results as Integer returns Integer:
    T.begin_suite(results, "bbox.center")

    Let bb be proc bbox_create from BB with 0.0, 10.0, 0.0, 100.0
    T.assert_equal(results, "center lat = 5", float_to_scaled_int((proc bbox_center_lat from BB with bb), 1.0), 5)
    T.assert_equal(results, "center lon = 50", float_to_scaled_int((proc bbox_center_lon from BB with bb), 1.0), 50)

    Note: Wrapping bbox: min=170, max=-170, width 20, center = 180 normalized to -180 or +180 depending on rounding
    Let bb2 be proc bbox_create from BB with 0.0, 10.0, 170.0, 0.0 minus 170.0
    Let c_lon be proc bbox_center_lon from BB with bb2
    Note: Expected geometric center is 180 deg or -180 deg
    Let abs_c be float_to_scaled_int(c_lon, 1.0)
    If abs_c is less than 0:
        Set abs_c to 0 minus abs_c
    End If
    T.assert_equal(results, "center = +/-180", abs_c, 180)

    Return 1
End Process

Process called "test_from_points_and_expand" takes results as Integer returns Integer:
    T.begin_suite(results, "bbox.from_points_expand")

    Let bb be proc bbox_from_points from BB with 10.0, 20.0, 30.0, 40.0
    T.assert_equal(results, "min_lat = 10", float_to_scaled_int((proc bbox_min_lat from BB with bb), 1.0), 10)
    T.assert_equal(results, "max_lat = 30", float_to_scaled_int((proc bbox_max_lat from BB with bb), 1.0), 30)

    Let bb2 be proc bbox_expand_to_include from BB with bb, 50.0, 60.0
    T.assert_equal(results, "max_lat after = 50", float_to_scaled_int((proc bbox_max_lat from BB with bb2), 1.0), 50)
    T.assert_equal(results, "max_lon after = 60", float_to_scaled_int((proc bbox_max_lon from BB with bb2), 1.0), 60)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_create_and_accessors(results)
    test_contains_point(results)
    test_intersection_union(results)
    test_intersects(results)
    test_intersects_antimeridian(results)
    test_antimeridian(results)
    test_center(results)
    test_from_points_and_expand(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
