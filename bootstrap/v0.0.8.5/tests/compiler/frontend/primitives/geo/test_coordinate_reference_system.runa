Note:
KAT for compiler/frontend/primitives/geo/coordinate_reference_system.runa.

Verifies:
  - ELLIPSOID parameter constants (WGS84 axis = 6378137).
  - ECEF <-> LLH round trip for a known position.
  - Inline trig helpers reproduce expected values (sin(0) = 0, cos(0) = 1).
  - degrees <-> radians conversions are inverses.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/geo/coordinate_reference_system.runa" as CRS
Import "compiler/frontend/primitives/geo/geo_coordinate.runa" as G
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let scaled be f multiplied by scale
    Return proc float_to_int from Arith with scaled
End Process

Process called "abs_float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let abs_f be f
    If abs_f is less than 0.0:
        Set abs_f to 0.0 minus abs_f
    End If
    Let scaled be abs_f multiplied by scale
    Return proc float_to_int from Arith with scaled
End Process

Note: We exercise the ellipsoid via the ecef_from_llh / llh_from_ecef path
Note: instead of direct field access because cross-module struct-field reads
Note: are not yet generic in stage1 (the importing test cannot know the
Note: field offsets of a type defined in another module). The round-trip
Note: test below verifies the ellipsoid parameters indirectly: if a is
Note: wrong the ECEF radius would be wrong by the same factor.

Process called "test_inline_trig" takes results as Integer returns Integer:
    T.begin_suite(results, "crs.inline_trig")

    Note: sin(0) = 0
    Let s0 be CRS.geo_sin(0.0)
    T.assert_equal(results, "sin(0) = 0", abs_float_to_scaled_int(s0, 1000000.0), 0)

    Note: cos(0) = 1
    Let c0 be CRS.geo_cos(0.0)
    Let c0_x100 be float_to_scaled_int(c0, 100.0)
    T.assert_equal(results, "cos(0) = 100/100", c0_x100, 100)

    Note: sin(pi/2) = 1
    Let s_half_pi be CRS.geo_sin(1.5707963267948966)
    Let s_half_pi_x100 be float_to_scaled_int(s_half_pi, 100.0)
    T.assert_equal(results, "sin(pi/2) = 1", s_half_pi_x100, 100)

    Note: cos(pi/2) ~= 0 (within 1e-10)
    Let c_half_pi be CRS.geo_cos(1.5707963267948966)
    Let c_half_pi_abs be abs_float_to_scaled_int(c_half_pi, 1000000000.0)
    T.assert_less_than(results, "|cos(pi/2)| < 1e-6", c_half_pi_abs, 1000)

    Return 1
End Process

Process called "test_deg_rad_conversion" takes results as Integer returns Integer:
    T.begin_suite(results, "crs.deg_rad")

    Note: 180 deg -> pi rad (within 1e-12)
    Let r be CRS.geo_deg_to_rad(180.0)
    Let pi_x1000 be float_to_scaled_int(r, 1000.0)
    T.assert_equal(results, "180 deg = 3141 mrad", pi_x1000, 3141)

    Note: pi rad -> 180 deg
    Let d be CRS.geo_rad_to_deg(3.141592653589793)
    Let d_int be float_to_scaled_int(d, 1.0)
    T.assert_equal(results, "pi rad = 180 deg", d_int, 180)

    Return 1
End Process

Process called "test_ecef_llh_round_trip" takes results as Integer returns Integer:
    T.begin_suite(results, "crs.ecef_llh_round_trip")

    Note: New York City. lat=40.7128, lon=-74.0060, alt=10
    Let nyc be G.geo_coord_create_wgs84(40.7128, 0.0 minus 74.0060, 10.0)
    Let p be CRS.ellipsoid_params_wgs84()
    Let ecef be CRS.ecef_from_llh(nyc, p)
    Note: Convert back
    Let llh_back be CRS.llh_from_ecef(ecef, p, 0)

    Note: Verify lat within 0.001 deg
    Let lat_diff be G.geo_coord_latitude(llh_back) minus 40.7128
    Let lat_diff_abs_x10000 be abs_float_to_scaled_int(lat_diff, 10000.0)
    T.assert_less_than(results, "lat round-trip <0.001 deg", lat_diff_abs_x10000, 10)

    Note: Verify lon within 0.001 deg
    Let lon_diff be G.geo_coord_longitude(llh_back) minus (0.0 minus 74.0060)
    Let lon_diff_abs_x10000 be abs_float_to_scaled_int(lon_diff, 10000.0)
    T.assert_less_than(results, "lon round-trip <0.001 deg", lon_diff_abs_x10000, 10)

    Note: Altitude within 1 m
    Let alt_diff be G.geo_coord_altitude_meters(llh_back) minus 10.0
    Let alt_diff_abs be abs_float_to_scaled_int(alt_diff, 1.0)
    T.assert_less_than(results, "alt round-trip <1m", alt_diff_abs, 1)

    Return 1
End Process

Process called "test_ellipsoid_params" takes results as Integer returns Integer:
    T.begin_suite(results, "crs.ellipsoid_params")

    Note: WGS84 semi-major axis is 6378137 m (exact by DMA TR 8350.2).
    Let wgs84 be CRS.ellipsoid_params_wgs84()
    Let wgs84_a be CRS.ellipsoid_semi_major_axis_meters(wgs84)
    Let wgs84_a_int be float_to_scaled_int(wgs84_a, 1.0)
    T.assert_equal(results, "wgs84 a = 6378137 m", wgs84_a_int, 6378137)

    Note: WGS84 inverse flattening: 298.257223563. Verify within 1e-9.
    Let wgs84_invf be CRS.ellipsoid_inverse_flattening(wgs84)
    Let wgs84_invf_diff be wgs84_invf minus 298.257223563
    Let wgs84_invf_diff_abs be abs_float_to_scaled_int(wgs84_invf_diff, 1000000000.0)
    T.assert_less_than(results, "wgs84 1/f near 298.257223563", wgs84_invf_diff_abs, 10)

    Note: GRS80 shares the same axis but uses a different inverse flattening.
    Let grs80 be CRS.ellipsoid_params_grs80()
    Let grs80_a_int be float_to_scaled_int(CRS.ellipsoid_semi_major_axis_meters(grs80), 1.0)
    T.assert_equal(results, "grs80 a = 6378137 m", grs80_a_int, 6378137)

    Note: Clarke 1866: a = 6378206.4 m.
    Let clarke be CRS.ellipsoid_params_clarke_1866()
    Let clarke_a_int be float_to_scaled_int(CRS.ellipsoid_semi_major_axis_meters(clarke), 10.0)
    T.assert_equal(results, "clarke 1866 a = 63782064 (a x10)", clarke_a_int, 63782064)

    Note: Airy 1830: a = 6377563.396 m.
    Let airy be CRS.ellipsoid_params_airy_1830()
    Let airy_a_int be float_to_scaled_int(CRS.ellipsoid_semi_major_axis_meters(airy), 1000.0)
    T.assert_equal(results, "airy 1830 a x1000 = 6377563396", airy_a_int, 6377563396)

    Note: Bessel 1841: a = 6377397.155 m.
    Let bessel be CRS.ellipsoid_params_bessel_1841()
    Let bessel_a_int be float_to_scaled_int(CRS.ellipsoid_semi_major_axis_meters(bessel), 1000.0)
    T.assert_equal(results, "bessel 1841 a x1000 = 6377397155", bessel_a_int, 6377397155)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_ellipsoid_params(results)
    test_inline_trig(results)
    test_deg_rad_conversion(results)
    test_ecef_llh_round_trip(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
