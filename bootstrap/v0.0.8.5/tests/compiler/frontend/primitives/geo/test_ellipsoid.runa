Note:
KAT for compiler/frontend/primitives/geo/ellipsoid.runa.

Verifies:
  - WGS84 semi-major and semi-minor axes
  - WGS84 mean radius ~ 6371008.7 m
  - GRS80 ~ identical to WGS84 in a, distinct from WGS84 in 1/f
  - First-eccentricity-squared sanity (positive, small for Earth)
  - Different ellipsoids produce different semi-major axes
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/geo/ellipsoid.runa" as Ell
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let scaled be f multiplied by scale
    Return proc float_to_int from Arith with scaled
End Process

Process called "test_wgs84" takes results as Integer returns Integer:
    T.begin_suite(results, "ellipsoid.wgs84")

    Let ell be proc ellipsoid_wgs84 from Ell
    T.assert_equal(results, "WGS84 a = 6378137", float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with ell), 1.0), 6378137)
    Note: WGS84 b ~ 6356752.314245179
    Let b be proc ellipsoid_semi_minor_axis from Ell with ell
    T.assert_greater_than(results, "WGS84 b > 6356752 m", float_to_scaled_int(b, 1.0), 6356751)
    T.assert_less_than(results, "WGS84 b < 6356753 m", float_to_scaled_int(b, 1.0), 6356753)

    Return 1
End Process

Process called "test_mean_radius" takes results as Integer returns Integer:
    T.begin_suite(results, "ellipsoid.mean_radius")

    Let ell be proc ellipsoid_wgs84 from Ell
    Let R be proc ellipsoid_mean_radius from Ell with ell
    Note: ~ 6371008.7 m
    T.assert_greater_than(results, "R > 6371008", float_to_scaled_int(R, 1.0), 6371007)
    T.assert_less_than(results, "R < 6371010", float_to_scaled_int(R, 1.0), 6371010)

    Return 1
End Process

Process called "test_eccentricity" takes results as Integer returns Integer:
    T.begin_suite(results, "ellipsoid.eccentricity")

    Let ell be proc ellipsoid_wgs84 from Ell
    Let e2 be proc ellipsoid_first_eccentricity_sq from Ell with ell
    Note: WGS84 e^2 ~ 0.00669437999 (1e3 -> ~ 6)
    T.assert_greater_than(results, "e^2 * 1e6 > 6694", float_to_scaled_int(e2, 1.0e6), 6693)
    T.assert_less_than(results, "e^2 * 1e6 < 6695", float_to_scaled_int(e2, 1.0e6), 6695)

    Let e be proc ellipsoid_first_eccentricity from Ell with ell
    Note: e ~ 0.0818
    T.assert_greater_than(results, "e * 1000 > 81", float_to_scaled_int(e, 1000.0), 80)
    T.assert_less_than(results, "e * 1000 < 82", float_to_scaled_int(e, 1000.0), 82)

    Return 1
End Process

Process called "test_different_ellipsoids" takes results as Integer returns Integer:
    T.begin_suite(results, "ellipsoid.distinct_a")

    Let wgs84 be proc ellipsoid_wgs84 from Ell
    Let airy be proc ellipsoid_airy_1830 from Ell
    Let clarke be proc ellipsoid_clarke_1866 from Ell
    Let intl be proc ellipsoid_international_1924 from Ell

    T.assert_not_equal(results, "WGS84 a != Airy a", float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with wgs84), 1.0), float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with airy), 1.0))
    T.assert_not_equal(results, "WGS84 a != Clarke a", float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with wgs84), 1.0), float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with clarke), 1.0))
    T.assert_not_equal(results, "WGS84 a != International a", float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with wgs84), 1.0), float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with intl), 1.0))

    Return 1
End Process

Process called "test_get_by_id" takes results as Integer returns Integer:
    T.begin_suite(results, "ellipsoid.get_by_id")

    Let by_id be proc ellipsoid_get from Ell with (proc ellipsoid_id_wgs84 from Ell)
    Let direct be proc ellipsoid_wgs84 from Ell
    T.assert_equal(results, "get(WGS84) = WGS84", float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with by_id), 1.0), float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with direct), 1.0))

    Note: Unknown id falls back to WGS84
    Let unknown be proc ellipsoid_get from Ell with 99
    T.assert_equal(results, "unknown id -> WGS84", float_to_scaled_int((proc ellipsoid_semi_major_axis from Ell with unknown), 1.0), 6378137)

    Return 1
End Process

Process called "test_radius_at_latitude" takes results as Integer returns Integer:
    T.begin_suite(results, "ellipsoid.radius_at_latitude")

    Let ell be proc ellipsoid_wgs84 from Ell
    Note: At equator (lat=0), radius = a = 6378137
    Let R_eq be proc ellipsoid_radius_at_latitude from Ell with ell, 0.0
    T.assert_equal(results, "R(0) = a", float_to_scaled_int(R_eq, 1.0), 6378137)

    Note: At pole (lat = pi/2), radius = b ~ 6356752
    Let R_pole be proc ellipsoid_radius_at_latitude from Ell with ell, 1.5707963267948966
    T.assert_greater_than(results, "R(pi/2) > 6356750", float_to_scaled_int(R_pole, 1.0), 6356749)
    T.assert_less_than(results, "R(pi/2) < 6356755", float_to_scaled_int(R_pole, 1.0), 6356755)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_wgs84(results)
    test_mean_radius(results)
    test_eccentricity(results)
    test_different_ellipsoids(results)
    test_get_by_id(results)
    test_radius_at_latitude(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
