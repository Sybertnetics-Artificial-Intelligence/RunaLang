Note:
KAT for compiler/frontend/primitives/geo/map_projection.runa.

Verifies:
  - Web Mercator at (0, 0) projects to (0, 0).
  - Web Mercator at the equator with lon=180 projects to x = ~ 20037508 m
    (the world width at zoom 0).
  - Web Mercator round trip: project -> unproject yields original coord
    (modulo tiny IEEE rounding).
  - natural log and exp helpers reproduce ln(e) = 1, exp(0) = 1.
  - UTM zone selection produces the documented zone numbers.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/geo/map_projection.runa" as MP
Import "compiler/frontend/primitives/geo/geo_coordinate.runa" as G
Import "compiler/frontend/primitives/geo/coordinate_reference_system.runa" as CRS
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Note: Round half-up to mitigate Float64 representation error. ln(e) computed
    Note: through the Taylor series produces 0.999...96 rather than exactly 1.0;
    Note: pure truncation drops it to 999 instead of the asserted 1000. Adding
    Note: +/- 0.5 before truncation yields nearest-integer rounding that matches
    Note: the mathematical identity assertions used in these reference tests.
    Let scaled be f multiplied by scale
    If scaled is greater than or equal to 0.0:
        Set scaled to scaled plus 0.5
    Otherwise:
        Set scaled to scaled minus 0.5
    End If
    Return proc float_to_int from Arith with scaled
End Process

Process called "abs_float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let a be f
    If a is less than 0.0:
        Set a to 0.0 minus a
    End If
    Let scaled be a multiplied by scale
    Set scaled to scaled plus 0.5
    Return proc float_to_int from Arith with scaled
End Process

Process called "test_log_exp_helpers" takes results as Integer returns Integer:
    T.begin_suite(results, "mp.log_exp")

    Note: exp(0) = 1
    Let e_zero be MP.project_natural_exp(0.0)
    T.assert_equal(results, "exp(0) = 1000/1000", float_to_scaled_int(e_zero, 1000.0), 1000)

    Note: ln(e) ~= 1
    Let ln_e be MP.project_natural_log(2.718281828459045)
    Let ln_e_x1000 be float_to_scaled_int(ln_e, 1000.0)
    T.assert_equal(results, "ln(e) = 1000/1000", ln_e_x1000, 1000)

    Note: exp(ln(5)) = 5
    Let five be MP.project_natural_exp(MP.project_natural_log(5.0))
    Let five_x100 be float_to_scaled_int(five, 100.0)
    Let diff be five_x100 minus 500
    Let abs_diff be diff
    If abs_diff is less than 0:
        Set abs_diff to 0 minus abs_diff
    End If
    T.assert_less_than(results, "exp(ln(5)) round-trip <0.01", abs_diff, 2)

    Return 1
End Process

Process called "test_web_mercator_origin" takes results as Integer returns Integer:
    T.begin_suite(results, "mp.web_mercator_origin")

    Note: (0, 0) -> (0, 0)
    Let origin_coord be G.geo_coord_create_wgs84(0.0, 0.0, 0.0)
    Let p_origin be MP.project_web_mercator(origin_coord)
    T.assert_equal(results, "(0,0) -> x = 0", abs_float_to_scaled_int(MP.projected_x(p_origin), 1.0), 0)
    T.assert_equal(results, "(0,0) -> y = 0", abs_float_to_scaled_int(MP.projected_y(p_origin), 1.0), 0)

    Return 1
End Process

Process called "test_web_mercator_world_extent" takes results as Integer returns Integer:
    T.begin_suite(results, "mp.web_mercator_world_extent")

    Note: At lon = 180 the x coord is R*pi = 6378137 * 3.14159... ~= 20037508
    Let east_edge be G.geo_coord_create_wgs84(0.0, 180.0, 0.0)
    Let p_east be MP.project_web_mercator(east_edge)
    Let x_int be float_to_scaled_int(MP.projected_x(p_east), 1.0)
    T.assert_greater_than(results, "(0,180) x > 20030000", x_int, 20030000)
    T.assert_less_than(results, "(0,180) x < 20040000", x_int, 20040000)

    Return 1
End Process

Process called "test_web_mercator_round_trip" takes results as Integer returns Integer:
    T.begin_suite(results, "mp.web_mercator_round_trip")

    Let sf be G.geo_coord_create_wgs84(37.7749, 0.0 minus 122.4194, 0.0)
    Let projected be MP.project_web_mercator(sf)
    Let back be MP.unproject_web_mercator(projected)
    Note: Latitude diff
    Let lat_diff be G.geo_coord_latitude(back) minus 37.7749
    Let lat_diff_abs_x1e6 be abs_float_to_scaled_int(lat_diff, 1000000.0)
    T.assert_less_than(results, "lat round-trip <1e-3 deg", lat_diff_abs_x1e6, 1000)
    Note: Longitude diff
    Let lon_diff be G.geo_coord_longitude(back) minus (0.0 minus 122.4194)
    Let lon_diff_abs_x1e6 be abs_float_to_scaled_int(lon_diff, 1000000.0)
    T.assert_less_than(results, "lon round-trip <1e-3 deg", lon_diff_abs_x1e6, 1000)

    Return 1
End Process

Process called "test_utm_zone" takes results as Integer returns Integer:
    T.begin_suite(results, "mp.utm_zone")

    Note: Greenwich (lon=0) is in zone 31
    T.assert_equal(results, "lon=0 -> zone 31", MP.utm_zone_for_longitude(0.0), 31)
    Note: NYC (lon=-74) is in zone 18
    T.assert_equal(results, "lon=-74 -> zone 18", MP.utm_zone_for_longitude(0.0 minus 74.0), 18)
    Note: Tokyo (lon=139.7) is in zone 54
    T.assert_equal(results, "lon=139.7 -> zone 54", MP.utm_zone_for_longitude(139.7), 54)
    Note: Antimeridian (lon=180) is in zone 60
    T.assert_equal(results, "lon=180 -> zone 60", MP.utm_zone_for_longitude(180.0), 60)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_log_exp_helpers(results)
    test_web_mercator_origin(results)
    test_web_mercator_world_extent(results)
    test_web_mercator_round_trip(results)
    test_utm_zone(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
