Note:
KAT for compiler/frontend/primitives/geo/geo_distance.runa.

Verifies:
  - NYC to London great-circle distance ~ 5570 km.
  - Bearing from NYC to London ~ 51 deg (initial).
  - Destination point: starting from NYC and going 5570 km on bearing 51
    deg ends near London (within a few km).
  - Identical points produce distance 0.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/geo/geo_distance.runa" as GD
Import "compiler/frontend/primitives/geo/geo_coordinate.runa" as G
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Return proc float_to_int from Arith with (f multiplied by scale)
End Process

Process called "abs_float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let a be f
    If a is less than 0.0:
        Set a to 0.0 minus a
    End If
    Return proc float_to_int from Arith with (a multiplied by scale)
End Process

Process called "test_haversine_nyc_to_london" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_dist.nyc_to_london")

    Let nyc be G.geo_coord_create_wgs84(40.7128, 0.0 minus 74.0060, 0.0)
    Let london be G.geo_coord_create_wgs84(51.5074, 0.0 minus 0.1278, 0.0)
    Let dist_m be GD.geo_distance_great_circle(nyc, london)
    Let dist_km be dist_m divided by 1000.0
    Let dist_km_int be proc float_to_int from Arith with dist_km
    Note: Expected: 5570 km. Allow 30 km tolerance for haversine spherical approx.
    T.assert_greater_than(results, "NYC-London > 5540 km", dist_km_int, 5540)
    T.assert_less_than(results, "NYC-London < 5600 km", dist_km_int, 5600)

    Return 1
End Process

Process called "test_zero_distance" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_dist.zero")

    Let same be G.geo_coord_create_wgs84(45.0, 90.0, 0.0)
    Let dist be GD.geo_distance_great_circle(same, same)
    T.assert_equal(results, "identical -> 0", abs_float_to_scaled_int(dist, 1.0), 0)

    Return 1
End Process

Process called "test_initial_bearing_nyc_to_london" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_dist.bearing_nyc_to_london")

    Let nyc be G.geo_coord_create_wgs84(40.7128, 0.0 minus 74.0060, 0.0)
    Let london be G.geo_coord_create_wgs84(51.5074, 0.0 minus 0.1278, 0.0)
    Let bearing be GD.geo_bearing_initial(nyc, london)
    Let bearing_int be proc float_to_int from Arith with bearing
    Note: Expected: ~ 51 deg. Allow +-2 deg.
    T.assert_greater_than(results, "bearing > 49", bearing_int, 49)
    T.assert_less_than(results, "bearing < 53", bearing_int, 53)

    Return 1
End Process

Process called "test_destination_point" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_dist.destination")

    Note: From (0, 0) east 111195 m (about 1 deg longitude at the equator)
    Let origin be G.geo_coord_create_wgs84(0.0, 0.0, 0.0)
    Let dest be GD.geo_destination_point(origin, 90.0, 111195.0)
    Note: Expected lat ~ 0, lon ~ 1
    Let lat_x100 be abs_float_to_scaled_int(G.geo_coord_latitude(dest), 100.0)
    T.assert_less_than(results, "dest lat ~ 0", lat_x100, 1)
    Let lon_x100 be float_to_scaled_int(G.geo_coord_longitude(dest), 100.0)
    Note: Expect ~ 100 (1 degree * 100)
    Let diff be lon_x100 minus 100
    Let abs_diff be diff
    If abs_diff is less than 0:
        Set abs_diff to 0 minus abs_diff
    End If
    T.assert_less_than(results, "dest lon ~ 1.0 deg", abs_diff, 10)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_haversine_nyc_to_london(results)
    test_zero_distance(results)
    test_initial_bearing_nyc_to_london(results)
    test_destination_point(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
