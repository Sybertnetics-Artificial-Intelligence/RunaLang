Note:
KAT for compiler/frontend/primitives/geo/geo_coordinate.runa.

Verifies:
  - Constructors store the supplied coordinate verbatim (default and strict).
  - geo_coord_is_valid rejects out-of-range latitudes and longitudes.
  - Famous reference points (Greenwich, North Pole, Equator) are within
    expected ranges.
  - Datum index encoding round-trips.
  - Longitude normalization wraps periodic angles.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/geo/geo_coordinate.runa" as G
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let scaled be f multiplied by scale
    Return proc float_to_int from Arith with scaled
End Process

Process called "test_constructors" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_coord.constructors")

    Let c be G.geo_coord_create_wgs84(40.7128, 0.0 minus 74.0060, 10.0)
    T.assert_equal(results, "NYC lat*10000", float_to_scaled_int(G.geo_coord_latitude(c), 10000.0), 407128)
    T.assert_equal(results, "NYC lon*10000", float_to_scaled_int(G.geo_coord_longitude(c), 10000.0), 0 minus 740060)
    T.assert_equal(results, "NYC alt", float_to_scaled_int(G.geo_coord_altitude_meters(c), 1.0), 10)
    T.assert_equal(results, "NYC datum = WGS84", G.geo_coord_datum_index(c), 0)

    Return 1
End Process

Process called "test_validation" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_coord.is_valid")

    Let good be G.geo_coord_create_wgs84(45.0, 90.0, 0.0)
    T.assert_equal(results, "(45, 90) valid", G.geo_coord_is_valid(good), 1)

    Let bad_lat be G.geo_coord_create_wgs84(91.0, 0.0, 0.0)
    T.assert_equal(results, "(91, 0) invalid", G.geo_coord_is_valid(bad_lat), 0)

    Let bad_lon be G.geo_coord_create_wgs84(0.0, 181.0, 0.0)
    T.assert_equal(results, "(0, 181) invalid", G.geo_coord_is_valid(bad_lon), 0)

    Let edge_pole be G.geo_coord_create_wgs84(90.0, 0.0, 0.0)
    T.assert_equal(results, "north pole valid", G.geo_coord_is_valid(edge_pole), 1)

    Let edge_antimeridian be G.geo_coord_create_wgs84(0.0, 0.0 minus 180.0, 0.0)
    T.assert_equal(results, "antimeridian -180 valid", G.geo_coord_is_valid(edge_antimeridian), 1)

    Return 1
End Process

Process called "test_strict_constructor" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_coord.create_strict")

    Note: Bad lat -> zero coord
    Let strict_bad be G.geo_coord_create_strict(95.0, 0.0, 0.0, 0)
    T.assert_equal(results, "strict bad lat -> 0 lat", float_to_scaled_int(G.geo_coord_latitude(strict_bad), 1.0), 0)

    Let strict_good be G.geo_coord_create_strict(45.0, 90.0, 100.0, 0)
    T.assert_equal(results, "strict good lat", float_to_scaled_int(G.geo_coord_latitude(strict_good), 1.0), 45)

    Return 1
End Process

Process called "test_reference_points" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_coord.reference_points")

    Note: Greenwich observatory
    Let greenwich be G.geo_coord_greenwich()
    Let g_lat_x10000 be float_to_scaled_int(G.geo_coord_latitude(greenwich), 10000.0)
    T.assert_equal(results, "Greenwich lat", g_lat_x10000, 514779)
    Let g_lon_int be float_to_scaled_int(G.geo_coord_longitude(greenwich), 1.0)
    T.assert_equal(results, "Greenwich lon = 0", g_lon_int, 0)

    Note: North pole lat = 90
    Let np be G.geo_coord_north_pole()
    T.assert_equal(results, "North pole lat = 90", float_to_scaled_int(G.geo_coord_latitude(np), 1.0), 90)

    Note: Everest summit altitude ~ 8849 m
    Let everest be G.geo_coord_everest_summit()
    Let e_alt be float_to_scaled_int(G.geo_coord_altitude_meters(everest), 1.0)
    T.assert_greater_than(results, "Everest > 8000m", e_alt, 8000)
    T.assert_less_than(results, "Everest < 9000m", e_alt, 9000)

    Return 1
End Process

Process called "test_datum_names" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_coord.datum_names")

    Let wgs_name be G.datum_name_from_index(0)
    T.assert_equal(results, "0 -> WGS84 length", (proc string_length from StrCore with wgs_name), 5)

    Note: Unknown index returns "Unknown"
    Let unknown_name be G.datum_name_from_index(99)
    T.assert_equal(results, "99 -> Unknown length", (proc string_length from StrCore with unknown_name), 7)

    Return 1
End Process

Process called "test_longitude_normalization" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_coord.normalize_longitude")

    Note: 540 deg -> 180 deg (because 540 - 360 = 180 which is at the boundary)
    Let n540 be G.normalize_longitude(540.0)
    Let n540_int be float_to_scaled_int(n540, 1.0)
    T.assert_equal(results, "normalize(540) = 180", n540_int, 180)

    Note: -270 -> 90
    Let nneg270 be G.normalize_longitude(0.0 minus 270.0)
    T.assert_equal(results, "normalize(-270) = 90", float_to_scaled_int(nneg270, 1.0), 90)

    Note: Already in range
    Let n45 be G.normalize_longitude(45.0)
    T.assert_equal(results, "normalize(45) = 45", float_to_scaled_int(n45, 1.0), 45)

    Return 1
End Process

Process called "test_clamp_latitude" takes results as Integer returns Integer:
    T.begin_suite(results, "geo_coord.clamp_latitude")

    T.assert_equal(results, "clamp(100) = 90", float_to_scaled_int(G.clamp_latitude(100.0), 1.0), 90)
    T.assert_equal(results, "clamp(-100) = -90", float_to_scaled_int(G.clamp_latitude(0.0 minus 100.0), 1.0), 0 minus 90)
    T.assert_equal(results, "clamp(45) = 45", float_to_scaled_int(G.clamp_latitude(45.0), 1.0), 45)

    Return 1
End Process

Import "compiler/frontend/primitives/core/string_core.runa" as StrCore

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_constructors(results)
    test_validation(results)
    test_strict_constructor(results)
    test_reference_points(results)
    test_datum_names(results)
    test_longitude_normalization(results)
    test_clamp_latitude(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
