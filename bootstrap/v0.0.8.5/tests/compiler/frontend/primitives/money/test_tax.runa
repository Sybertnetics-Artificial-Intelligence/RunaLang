Note:
Unit tests for compiler/frontend/primitives/money/tax.runa.

Verifies VAT/GST/SalesTax computation, including inclusive vs exclusive
price handling (EU VAT-inclusive extraction).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/decimal/ieee754_decimal64.runa" as Dec64
Import "compiler/frontend/primitives/money/currency.runa" as Currency
Import "compiler/frontend/primitives/money/money.runa" as Money
Import "compiler/frontend/primitives/money/tax.runa" as Tax

Process called "test_tax_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "tax.rate_create")

    Let pct be Dec64.dec64_from_string("0.20")
    Let vat_de be Tax.tax_rate_create(Tax.TAX_TYPE_VAT, pct, "DE")
    T.assert_not_null(results, "VAT rate non-null", vat_de)
    T.assert_equal(results, "type = VAT", Tax.tax_rate_get_type(vat_de), Tax.TAX_TYPE_VAT)

    Tax.tax_rate_destroy(vat_de)
    Return 1
End Process

Process called "test_tax_compute_exclusive" that takes results as Integer returns Integer:
    T.begin_suite(results, "tax.compute on exclusive price")

    Note: $100 net + 8.25% sales tax = $8.25 tax
    Let pct be Dec64.dec64_from_string("0.0825")
    Let ca_sales_tax be Tax.tax_rate_create(Tax.TAX_TYPE_SALES_TAX, pct, "US-CA")

    Let net be Money.money_from_decimal_string(Currency.CURRENCY_USD, "100.00")
    Let tax_amt be Tax.tax_compute(net, ca_sales_tax)
    T.assert_not_null(results, "tax amount non-null", tax_amt)

    Let expected be Money.money_from_decimal_string(Currency.CURRENCY_USD, "8.25")
    T.assert_equal(results, "$100 * 8.25% = $8.25", Money.money_equals(tax_amt, expected), 1)

    Money.money_destroy(net)
    Money.money_destroy(tax_amt)
    Money.money_destroy(expected)
    Tax.tax_rate_destroy(ca_sales_tax)
    Return 1
End Process

Process called "test_tax_add_to_exclusive" that takes results as Integer returns Integer:
    T.begin_suite(results, "tax.add_to_exclusive (gross from net)")

    Let pct be Dec64.dec64_from_string("0.20")
    Let vat be Tax.tax_rate_create(Tax.TAX_TYPE_VAT, pct, "DE")

    Let net be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "100.00")
    Let gross be Tax.tax_add_to_exclusive(net, vat)
    T.assert_not_null(results, "gross non-null", gross)

    Let expected be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "120.00")
    T.assert_equal(results, "100 EUR + 20% VAT = 120 EUR", Money.money_equals(gross, expected), 1)

    Money.money_destroy(net)
    Money.money_destroy(gross)
    Money.money_destroy(expected)
    Tax.tax_rate_destroy(vat)
    Return 1
End Process

Process called "test_tax_extract_from_inclusive" that takes results as Integer returns Integer:
    T.begin_suite(results, "tax.extract_from_inclusive (net from gross)")

    Let pct be Dec64.dec64_from_string("0.20")
    Let vat be Tax.tax_rate_create(Tax.TAX_TYPE_VAT, pct, "DE")

    Note: VAT-inclusive 120 EUR with 20% rate -> net = 120 / 1.20 = 100 EUR
    Let gross be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "120.00")
    Let net be Tax.tax_extract_from_inclusive(gross, vat)
    T.assert_not_null(results, "extracted net non-null", net)

    Let expected be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "100.00")
    T.assert_equal(results, "VAT-inclusive 120 EUR -> net 100 EUR", Money.money_equals(net, expected), 1)

    Money.money_destroy(gross)
    Money.money_destroy(net)
    Money.money_destroy(expected)
    Tax.tax_rate_destroy(vat)
    Return 1
End Process

Process called "test_tax_extract_tax_component" that takes results as Integer returns Integer:
    T.begin_suite(results, "tax.extract_tax_from_inclusive (tax component)")

    Let pct be Dec64.dec64_from_string("0.20")
    Let vat be Tax.tax_rate_create(Tax.TAX_TYPE_VAT, pct, "DE")

    Let gross be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "120.00")
    Let tax_amt be Tax.tax_extract_tax_from_inclusive(gross, vat)
    T.assert_not_null(results, "tax component non-null", tax_amt)

    Let expected be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "20.00")
    T.assert_equal(results, "VAT-inclusive 120 EUR -> tax 20 EUR", Money.money_equals(tax_amt, expected), 1)

    Money.money_destroy(gross)
    Money.money_destroy(tax_amt)
    Money.money_destroy(expected)
    Tax.tax_rate_destroy(vat)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_tax_create(results)
    test_tax_compute_exclusive(results)
    test_tax_add_to_exclusive(results)
    test_tax_extract_from_inclusive(results)
    test_tax_extract_tax_component(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
