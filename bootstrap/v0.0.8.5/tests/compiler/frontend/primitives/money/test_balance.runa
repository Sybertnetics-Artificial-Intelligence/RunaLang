Note:
Unit tests for compiler/frontend/primitives/money/balance.runa.

Verifies balance construction, accessor wiring, ledger-entry application
folding, currency-mismatch rejection, and sign predicates. Account
handles are passed as opaque non-zero Integer sentinels - both Balance
and LedgerEntry treat them as integer tokens, so the tests do not need
the full Account allocator to exercise the contract.

KNOWN COMPILER LIMITATION: This file exercises Entry.ledger_entry_create,
which takes 8 parameters per the LedgerEntry spec. The current stage1
bootstrap compiler (runac) emits "[CODEGEN ERROR] Unsupported expression
type" against any 8-argument function call. Reproducible with a four-line
standalone test. The test source matches the language spec and the
balance.runa contract; source pattern verified by hand against the
patterns used in test_money.runa and test_exchange_rate.runa, which both
compile cleanly under runac.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/money/currency.runa" as Currency
Import "compiler/frontend/primitives/money/money.runa" as Money
Import "compiler/frontend/primitives/money/balance.runa" as Balance
Import "compiler/frontend/primitives/money/ledger_entry.runa" as Entry

Process called "main" returns Integer:
    Let results be T.create_test_results()

    Note: ===== balance.zero_and_accessors =====
    T.begin_suite(results, "balance.zero_and_accessors")
    Let cash_handle be 1001
    Let b1 be Balance.balance_zero(cash_handle, Currency.CURRENCY_USD)
    T.assert_not_null(results, "balance non-null", b1)
    T.assert_equal(results, "account accessor", Balance.balance_get_account(b1), cash_handle)
    T.assert_not_null(results, "money accessor non-null", Balance.balance_get_money(b1))
    T.assert_equal(results, "last_entry_id starts at 0", Balance.balance_get_last_entry_id(b1), 0)
    T.assert_equal(results, "is_zero = 1 on zero balance", Balance.balance_is_zero(b1), 1)
    T.assert_equal(results, "is_positive = 0 on zero balance", Balance.balance_is_positive(b1), 0)
    T.assert_equal(results, "is_negative = 0 on zero balance", Balance.balance_is_negative(b1), 0)
    Balance.balance_destroy(b1)

    Note: ===== balance.zero_rejects_invalid =====
    T.begin_suite(results, "balance.zero_rejects_invalid")
    T.assert_equal(results, "null account rejected", Balance.balance_zero(0, Currency.CURRENCY_USD), 0)
    T.assert_equal(results, "currency_id 0 rejected", Balance.balance_zero(1001, 0), 0)

    Note: ===== balance.apply_entry credit =====
    T.begin_suite(results, "balance.apply_entry credit")
    Let asset_handle be 1001
    Let other_handle be 4001
    Let b2 be Balance.balance_zero(asset_handle, Currency.CURRENCY_USD)
    Let m100 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "100.00")
    T.assert_not_null(results, "money 100 USD built", m100)
    Let e2 be Entry.ledger_entry_create(1, 0, other_handle, asset_handle, m100, 0, 0, 0)
    T.assert_not_null(results, "entry built", e2)
    Let rc2 be Balance.balance_apply_entry(b2, e2)
    T.assert_equal(results, "apply returns OK", rc2, 0)
    T.assert_equal(results, "is_positive after credit", Balance.balance_is_positive(b2), 1)
    T.assert_equal(results, "last_entry_id = 1", Balance.balance_get_last_entry_id(b2), 1)
    Entry.ledger_entry_destroy(e2)
    Balance.balance_destroy(b2)

    Note: ===== balance.apply_entry debit =====
    T.begin_suite(results, "balance.apply_entry debit")
    Let cash_handle3 be 1001
    Let expense_handle3 be 5001
    Let b3 be Balance.balance_zero(cash_handle3, Currency.CURRENCY_USD)
    Let m50 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "50.00")
    Let e3 be Entry.ledger_entry_create(7, 0, cash_handle3, expense_handle3, m50, 0, 0, 0)
    T.assert_not_null(results, "debit entry built", e3)
    Let rc3 be Balance.balance_apply_entry(b3, e3)
    T.assert_equal(results, "apply returns OK", rc3, 0)
    T.assert_equal(results, "is_negative after debit", Balance.balance_is_negative(b3), 1)
    T.assert_equal(results, "last_entry_id = 7", Balance.balance_get_last_entry_id(b3), 7)
    Entry.ledger_entry_destroy(e3)
    Balance.balance_destroy(b3)

    Note: ===== balance.apply_entry no-touch returns OK without change =====
    T.begin_suite(results, "balance.apply_entry no-touch returns OK without change")
    Let cash_handle4 be 1001
    Let revenue_handle4 be 4001
    Let expense_handle4 be 5001
    Let b4 be Balance.balance_zero(cash_handle4, Currency.CURRENCY_USD)
    Let m25 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "25.00")
    Let e4 be Entry.ledger_entry_create(3, 0, revenue_handle4, expense_handle4, m25, 0, 0, 0)
    Let rc4 be Balance.balance_apply_entry(b4, e4)
    T.assert_equal(results, "no-touch returns OK", rc4, 0)
    T.assert_equal(results, "balance still zero", Balance.balance_is_zero(b4), 1)
    T.assert_equal(results, "last_entry_id unchanged at 0", Balance.balance_get_last_entry_id(b4), 0)
    Entry.ledger_entry_destroy(e4)
    Balance.balance_destroy(b4)

    Note: ===== balance.apply_entry rejects currency mismatch =====
    T.begin_suite(results, "balance.apply_entry rejects currency mismatch")
    Let cash_handle5 be 1001
    Let revenue_handle5 be 4001
    Let b5 be Balance.balance_zero(cash_handle5, Currency.CURRENCY_USD)
    Let m_eur be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "10.00")
    Let e5 be Entry.ledger_entry_create(5, 0, revenue_handle5, cash_handle5, m_eur, 0, 0, 0)
    Let rc5 be Balance.balance_apply_entry(b5, e5)
    T.assert_equal(results, "currency mismatch error code", rc5, 0 minus 2)
    T.assert_equal(results, "balance unchanged on mismatch", Balance.balance_is_zero(b5), 1)
    Entry.ledger_entry_destroy(e5)
    Balance.balance_destroy(b5)

    Note: ===== balance.null-safe accessors and apply =====
    T.begin_suite(results, "balance.null-safe accessors and apply")
    T.assert_equal(results, "get_account on null = 0", Balance.balance_get_account(0), 0)
    T.assert_equal(results, "get_money on null = 0", Balance.balance_get_money(0), 0)
    T.assert_equal(results, "get_last_entry_id on null = 0", Balance.balance_get_last_entry_id(0), 0)
    T.assert_equal(results, "is_zero on null = 0", Balance.balance_is_zero(0), 0)
    T.assert_equal(results, "destroy on null = 0", Balance.balance_destroy(0), 0)
    T.assert_equal(results, "apply with null balance returns ERR_NULL", Balance.balance_apply_entry(0, 0), 0 minus 1)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
