Note:
Unit tests for compiler/frontend/primitives/money/money.runa.

Verifies the type-safe currency arithmetic contract: same-currency addition
works exactly (decimal-FP guarantees 0.1 + 0.2 = 0.3), cross-currency
arithmetic is REJECTED.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/decimal/ieee754_decimal64.runa" as Dec64
Import "compiler/frontend/primitives/money/currency.runa" as Currency
Import "compiler/frontend/primitives/money/money.runa" as Money

Process called "test_money_create_and_destroy" that takes results as Integer returns Integer:
    T.begin_suite(results, "money.create_and_destroy")

    Let amt be Dec64.dec64_from_integer(100)
    Let m be Money.money_create(Currency.CURRENCY_USD, amt)
    T.assert_not_null(results, "money_create returns non-null", m)
    T.assert_equal(results, "currency = USD", Money.money_get_currency(m), Currency.CURRENCY_USD)
    Money.money_destroy(m)
    Return 1
End Process

Process called "test_money_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "money.zero")

    Let m be Money.money_zero(Currency.CURRENCY_USD)
    T.assert_not_null(results, "money_zero non-null", m)
    T.assert_equal(results, "money_zero is_zero", Money.money_is_zero(m), 1)
    T.assert_equal(results, "money_zero is_positive = 0", Money.money_is_positive(m), 0)
    T.assert_equal(results, "money_zero is_negative = 0", Money.money_is_negative(m), 0)
    Money.money_destroy(m)
    Return 1
End Process

Process called "test_money_add_same_currency" that takes results as Integer returns Integer:
    T.begin_suite(results, "money.add same currency")

    Note: 0.1 USD + 0.2 USD = 0.3 USD - the canonical decimal-FP test
    Note: that binary IEEE 754 fails. Decimal64 represents these exactly.
    Let a be Money.money_from_decimal_string(Currency.CURRENCY_USD, "0.1")
    Let b be Money.money_from_decimal_string(Currency.CURRENCY_USD, "0.2")
    Let expected be Money.money_from_decimal_string(Currency.CURRENCY_USD, "0.3")
    T.assert_not_null(results, "0.1 USD parsed", a)
    T.assert_not_null(results, "0.2 USD parsed", b)
    T.assert_not_null(results, "0.3 USD parsed", expected)

    Let sum be Money.money_add(a, b)
    T.assert_not_null(results, "0.1 + 0.2 USD non-null", sum)
    T.assert_equal(results, "0.1 USD + 0.2 USD = 0.3 USD (decimal FP exact)", Money.money_equals(sum, expected), 1)

    Money.money_destroy(a)
    Money.money_destroy(b)
    Money.money_destroy(expected)
    Money.money_destroy(sum)
    Return 1
End Process

Process called "test_money_add_cross_currency_rejected" that takes results as Integer returns Integer:
    T.begin_suite(results, "money.add cross-currency REJECTED")

    Let usd_100 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "100")
    Let eur_50 be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "50")

    Let bad be Money.money_add(usd_100, eur_50)
    T.assert_equal(results, "USD + EUR is REJECTED (returns 0)", bad, 0)

    Let bad2 be Money.money_sub(usd_100, eur_50)
    T.assert_equal(results, "USD - EUR is REJECTED (returns 0)", bad2, 0)

    Let cmp_result be Money.money_compare(usd_100, eur_50)
    T.assert_equal(results, "compare USD vs EUR returns -2 (incomparable)", cmp_result, 0 minus 2)

    Money.money_destroy(usd_100)
    Money.money_destroy(eur_50)
    Return 1
End Process

Process called "test_money_sub" that takes results as Integer returns Integer:
    T.begin_suite(results, "money.sub")

    Let a be Money.money_from_decimal_string(Currency.CURRENCY_USD, "10.00")
    Let b be Money.money_from_decimal_string(Currency.CURRENCY_USD, "3.50")
    Let expected be Money.money_from_decimal_string(Currency.CURRENCY_USD, "6.50")

    Let diff be Money.money_sub(a, b)
    T.assert_not_null(results, "diff non-null", diff)
    T.assert_equal(results, "10.00 USD - 3.50 USD = 6.50 USD", Money.money_equals(diff, expected), 1)

    Money.money_destroy(a)
    Money.money_destroy(b)
    Money.money_destroy(expected)
    Money.money_destroy(diff)
    Return 1
End Process

Process called "test_money_negate_and_abs" that takes results as Integer returns Integer:
    T.begin_suite(results, "money.negate_and_abs")

    Let pos be Money.money_from_decimal_string(Currency.CURRENCY_USD, "42.00")
    Let neg be Money.money_negate(pos)
    T.assert_equal(results, "negate flips sign to negative", Money.money_is_negative(neg), 1)

    Let restored be Money.money_abs(neg)
    T.assert_equal(results, "abs of negative is positive", Money.money_is_positive(restored), 1)
    T.assert_equal(results, "abs round-trip equal", Money.money_equals(pos, restored), 1)

    Money.money_destroy(pos)
    Money.money_destroy(neg)
    Money.money_destroy(restored)
    Return 1
End Process

Process called "test_money_multiply_scalar" that takes results as Integer returns Integer:
    T.begin_suite(results, "money.multiply_scalar")

    Let principal be Money.money_from_decimal_string(Currency.CURRENCY_USD, "1000.00")
    Let rate be Dec64.dec64_from_string("0.05")
    Let interest be Money.money_multiply_scalar(principal, rate)
    Let expected be Money.money_from_decimal_string(Currency.CURRENCY_USD, "50.00")

    T.assert_not_null(results, "interest non-null", interest)
    T.assert_equal(results, "1000 USD * 0.05 = 50 USD", Money.money_equals(interest, expected), 1)

    Money.money_destroy(principal)
    Dec64.dec64_destroy(rate)
    Money.money_destroy(interest)
    Money.money_destroy(expected)
    Return 1
End Process

Process called "test_money_clone" that takes results as Integer returns Integer:
    T.begin_suite(results, "money.clone")

    Let original be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "123.45")
    Let copy be Money.money_clone(original)
    T.assert_not_null(results, "clone non-null", copy)
    T.assert_equal(results, "clone equals original", Money.money_equals(original, copy), 1)
    T.assert_equal(results, "clone same currency", Money.money_same_currency(original, copy), 1)

    Money.money_destroy(original)
    Money.money_destroy(copy)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_money_create_and_destroy(results)
    test_money_zero(results)
    test_money_add_same_currency(results)
    test_money_add_cross_currency_rejected(results)
    test_money_sub(results)
    test_money_negate_and_abs(results)
    test_money_multiply_scalar(results)
    test_money_clone(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
