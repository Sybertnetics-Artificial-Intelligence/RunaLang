Note:
Unit tests for compiler/frontend/primitives/money/account.runa.

Verifies IBAN mod-97 validation, ACH ABA check digit, SWIFT BIC format
checks, and Ethereum address structural validation.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/money/account.runa" as Account

Note: ============================================================================
Note: IBAN
Note: ============================================================================

Process called "test_iban_valid_de" that takes results as Integer returns Integer:
    T.begin_suite(results, "iban.valid German IBAN")

    Note: Standard ISO 13616 sample German IBAN
    Let r be Account.iban_parse("DE89370400440532013000")
    T.assert_not_null(results, "parse DE89... non-null", r)
    T.assert_equal(results, "DE89370400440532013000 is valid", Account.iban_is_valid(r), 1)
    T.assert_equal(results, "length = 22", Account.iban_get_length(r), 22)
    T.assert_equal(results, "check digits = 89", Account.iban_get_check_digits(r), 89)
    T.assert_equal(results, "bban offset = 4", Account.iban_get_bban_offset(r), 4)
    T.assert_equal(results, "bban length = 18", Account.iban_get_bban_length(r), 18)

    Account.iban_destroy(r)
    Return 1
End Process

Process called "test_iban_valid_gb" that takes results as Integer returns Integer:
    T.begin_suite(results, "iban.valid UK IBAN")

    Note: Standard ISO 13616 sample UK IBAN (Nat West)
    Let r be Account.iban_parse("GB82WEST12345698765432")
    T.assert_not_null(results, "parse GB82... non-null", r)
    T.assert_equal(results, "GB82WEST12345698765432 is valid", Account.iban_is_valid(r), 1)

    Account.iban_destroy(r)
    Return 1
End Process

Process called "test_iban_invalid_checksum" that takes results as Integer returns Integer:
    T.begin_suite(results, "iban.invalid checksum")

    Note: Tamper with the check digits - 89 -> 00
    Let r be Account.iban_parse("DE00370400440532013000")
    T.assert_not_null(results, "parse non-null", r)
    T.assert_equal(results, "tampered IBAN flagged invalid", Account.iban_is_valid(r), 0)

    Account.iban_destroy(r)
    Return 1
End Process

Process called "test_iban_too_short" that takes results as Integer returns Integer:
    T.begin_suite(results, "iban.too_short rejected")

    Note: Too short - returns 0 (not even a record)
    Let r be Account.iban_parse("DE89")
    T.assert_equal(results, "too-short IBAN returns 0", r, 0)
    Return 1
End Process

Process called "test_iban_country_length_de" that takes results as Integer returns Integer:
    T.begin_suite(results, "iban.per-country length: DE requires 22")

    Note: DE = packed 17477; expected length must be 22 per SWIFT IBAN Registry
    T.assert_equal(results, "DE expected length = 22", Account.iban_country_expected_length(17477), 22)

    Note: 20-char DE IBAN must be rejected by the per-country length enforcement
    Note: even though the global 15..34 range admits it.
    Let r_short be Account.iban_parse("DE89370400440532")
    T.assert_equal(results, "20-char DE IBAN rejected", r_short, 0)

    Note: 22-char DE IBAN with valid mod-97 is accepted
    Let r_ok be Account.iban_parse("DE89370400440532013000")
    T.assert_not_null(results, "22-char DE IBAN accepted", r_ok)
    Account.iban_destroy(r_ok)
    Return 1
End Process

Process called "test_iban_country_length_mt" that takes results as Integer returns Integer:
    T.begin_suite(results, "iban.per-country length: MT requires 31")

    Note: MT = packed 19796; expected length 31
    T.assert_equal(results, "MT expected length = 31", Account.iban_country_expected_length(19796), 31)

    Note: 22-char MT IBAN must be rejected (MT requires 31)
    Let r_short be Account.iban_parse("MT84MALT011000012345MT")
    T.assert_equal(results, "22-char MT IBAN rejected (needs 31)", r_short, 0)

    Note: Standard 31-char MT IBAN with valid mod-97
    Let r_ok be Account.iban_parse("MT84MALT011000012345MTLCAST001S")
    T.assert_not_null(results, "31-char MT IBAN accepted", r_ok)
    T.assert_equal(results, "length = 31", Account.iban_get_length(r_ok), 31)
    Account.iban_destroy(r_ok)
    Return 1
End Process

Process called "test_iban_country_length_kw" that takes results as Integer returns Integer:
    T.begin_suite(results, "iban.per-country length: KW requires 30")

    Note: KW = packed 19287; expected length 30
    T.assert_equal(results, "KW expected length = 30", Account.iban_country_expected_length(19287), 30)

    Note: Standard 30-char Kuwait IBAN with valid mod-97
    Let r_ok be Account.iban_parse("KW81CBKU0000000000001234560101")
    T.assert_not_null(results, "30-char KW IBAN accepted", r_ok)
    T.assert_equal(results, "length = 30", Account.iban_get_length(r_ok), 30)
    Account.iban_destroy(r_ok)
    Return 1
End Process

Process called "test_iban_unknown_country" that takes results as Integer returns Integer:
    T.begin_suite(results, "iban.unknown country rejected")

    Note: XY is not a registered IBAN country
    Note: XY = (88<<8)|89 = 22617 - must return -1 from registry lookup
    T.assert_equal(results, "XY country lookup returns -1", Account.iban_country_expected_length(22617), 0 minus 1)

    Note: An 18-char "XY..." string with valid mod-97 numerics must still be rejected
    Note: because the country is not registered.
    Let r be Account.iban_parse("XY8237040044053201")
    T.assert_equal(results, "unknown-country IBAN rejected (returns 0)", r, 0)
    Return 1
End Process

Note: ============================================================================
Note: ACH (ABA routing check digit)
Note: ============================================================================

Process called "test_ach_valid_routing" that takes results as Integer returns Integer:
    T.begin_suite(results, "ach.valid routing numbers (NACHA)")

    Note: Real Fed routing numbers with verified check digits.
    Note: 011000015 = Federal Reserve Bank, Boston (verified)
    T.assert_equal(results, "011000015 (FRB Boston) valid", Account.ach_routing_check_digit_valid(11000015), 1)
    Note: 021000021 = Citibank N.A., New York (verified)
    T.assert_equal(results, "021000021 (Citibank) valid", Account.ach_routing_check_digit_valid(21000021), 1)
    Note: 121000358 = Bank of America, California (verified)
    T.assert_equal(results, "121000358 (BoA) valid", Account.ach_routing_check_digit_valid(121000358), 1)
    Return 1
End Process

Process called "test_ach_invalid_routing" that takes results as Integer returns Integer:
    T.begin_suite(results, "ach.invalid routing checksums")

    Note: Tampered: change last digit (check digit)
    T.assert_equal(results, "011000019 (bad check) invalid", Account.ach_routing_check_digit_valid(11000019), 0)
    Note: Out of range
    T.assert_equal(results, "0 rejected", Account.ach_routing_check_digit_valid(0), 0)
    T.assert_equal(results, "negative rejected", Account.ach_routing_check_digit_valid(0 minus 1), 0)
    Return 1
End Process

Process called "test_ach_account_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "ach.account_create")

    Let acct be Account.ach_account_create(11000015, "123456789012")
    T.assert_not_null(results, "account record non-null", acct)
    T.assert_equal(results, "routing accessible", Account.ach_account_get_routing(acct), 11000015)
    T.assert_equal(results, "validity from check digit", Account.ach_account_is_valid(acct), 1)

    Account.ach_account_destroy(acct)
    Return 1
End Process

Note: ============================================================================
Note: SWIFT BIC
Note: ============================================================================

Process called "test_swift_bic_valid_short" that takes results as Integer returns Integer:
    T.begin_suite(results, "swift_bic.valid 8-char")

    Note: DEUTDEFF = Deutsche Bank, Frankfurt
    Let r be Account.swift_bic_parse("DEUTDEFF")
    T.assert_not_null(results, "parse non-null", r)
    T.assert_equal(results, "DEUTDEFF is valid", Account.swift_bic_is_valid(r), 1)
    T.assert_equal(results, "has_branch = 0 (short form)", Account.swift_bic_has_branch(r), 0)

    Account.swift_bic_destroy(r)
    Return 1
End Process

Process called "test_swift_bic_valid_long" that takes results as Integer returns Integer:
    T.begin_suite(results, "swift_bic.valid 11-char with branch")

    Note: DEUTDEFF500 = Deutsche Bank, Frankfurt, Branch 500
    Let r be Account.swift_bic_parse("DEUTDEFF500")
    T.assert_not_null(results, "parse non-null", r)
    T.assert_equal(results, "DEUTDEFF500 is valid", Account.swift_bic_is_valid(r), 1)
    T.assert_equal(results, "has_branch = 1", Account.swift_bic_has_branch(r), 1)

    Account.swift_bic_destroy(r)
    Return 1
End Process

Process called "test_swift_bic_bad_length" that takes results as Integer returns Integer:
    T.begin_suite(results, "swift_bic.bad length rejected")

    Let r1 be Account.swift_bic_parse("ABC")
    T.assert_equal(results, "3-char rejected (returns 0)", r1, 0)

    Let r2 be Account.swift_bic_parse("DEUTDEFF50")
    T.assert_equal(results, "10-char rejected (returns 0)", r2, 0)
    Return 1
End Process

Note: ============================================================================
Note: Ethereum address
Note: ============================================================================

Process called "test_eth_address_structural_lowercase" that takes results as Integer returns Integer:
    T.begin_suite(results, "eth_address.structural lowercase")

    Note: Vitalik Buterin's well-known address (without 0x prefix, all lowercase)
    Let r be Account.eth_address_parse("d8da6bf26964af9d7eed9e03e53415d37aa96045")
    T.assert_not_null(results, "parse non-null", r)
    T.assert_equal(results, "structurally valid", Account.eth_address_is_structurally_valid(r), 1)
    T.assert_equal(results, "has_prefix = 0", Account.eth_address_has_prefix(r), 0)
    T.assert_equal(results, "has_mixed_case = 0", Account.eth_address_has_mixed_case(r), 0)

    Account.eth_address_destroy(r)
    Return 1
End Process

Process called "test_eth_address_structural_with_prefix" that takes results as Integer returns Integer:
    T.begin_suite(results, "eth_address.with 0x prefix")

    Note: EIP-55 mixed-case form of Vitalik's address
    Let r be Account.eth_address_parse("0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045")
    T.assert_not_null(results, "parse non-null", r)
    T.assert_equal(results, "structurally valid", Account.eth_address_is_structurally_valid(r), 1)
    T.assert_equal(results, "has_prefix = 1", Account.eth_address_has_prefix(r), 1)
    T.assert_equal(results, "has_mixed_case = 1 (EIP-55 form)", Account.eth_address_has_mixed_case(r), 1)

    Account.eth_address_destroy(r)
    Return 1
End Process

Process called "test_eth_address_invalid" that takes results as Integer returns Integer:
    T.begin_suite(results, "eth_address.invalid")

    Note: Too short
    Let r1 be Account.eth_address_parse("0xabc")
    T.assert_equal(results, "too-short rejected (returns 0)", r1, 0)

    Note: Non-hex char in body
    Let r2 be Account.eth_address_parse("zZdA6BF26964aF9D7eEd9e03E53415D37aA96045")
    T.assert_not_null(results, "parses but flagged invalid", r2)
    T.assert_equal(results, "non-hex flagged invalid", Account.eth_address_is_structurally_valid(r2), 0)
    Account.eth_address_destroy(r2)
    Return 1
End Process

Process called "test_eth_address_eip55_all_uppercase" that takes results as Integer returns Integer:
    T.begin_suite(results, "eth_address.EIP-55 all-uppercase legacy form")

    Note: All-uppercase form: legacy pre-EIP-55, accepted without checksum
    Let r be Account.eth_address_parse("0x52908400098527886E0F7030069857D2E4169EE7")
    T.assert_not_null(results, "parse non-null", r)
    T.assert_equal(results, "structurally valid (all-uppercase accepted)", Account.eth_address_is_structurally_valid(r), 1)
    T.assert_equal(results, "has_prefix = 1", Account.eth_address_has_prefix(r), 1)
    Account.eth_address_destroy(r)
    Return 1
End Process

Process called "test_eth_address_eip55_mixed_valid" that takes results as Integer returns Integer:
    T.begin_suite(results, "eth_address.EIP-55 valid mixed-case")

    Note: Vitalik Buterin's address - canonical EIP-55 mixed-case form (verified)
    Let r be Account.eth_address_parse("0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045")
    T.assert_not_null(results, "parse non-null", r)
    T.assert_equal(results, "EIP-55 checksum verifies", Account.eth_address_is_structurally_valid(r), 1)
    T.assert_equal(results, "has_mixed_case = 1", Account.eth_address_has_mixed_case(r), 1)

    Note: Direct verify helper returns 1
    T.assert_equal(results, "checksum_verify direct = 1", Account.eth_address_checksum_verify("0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045"), 1)

    Account.eth_address_destroy(r)
    Return 1
End Process

Process called "test_eth_address_eip55_legacy_lowercase" that takes results as Integer returns Integer:
    T.begin_suite(results, "eth_address.EIP-55 legacy all-lowercase accepted")

    Note: All-lowercase form of Vitalik's address - legacy pre-EIP-55 form
    Let r be Account.eth_address_parse("0xde709f2102306220921060314715629080e2fb77")
    T.assert_not_null(results, "parse non-null", r)
    T.assert_equal(results, "structurally valid (all-lowercase accepted)", Account.eth_address_is_structurally_valid(r), 1)
    T.assert_equal(results, "has_mixed_case = 0", Account.eth_address_has_mixed_case(r), 0)
    Account.eth_address_destroy(r)
    Return 1
End Process

Process called "test_eth_address_eip55_invalid_mixed" that takes results as Integer returns Integer:
    T.begin_suite(results, "eth_address.EIP-55 invalid mixed-case checksum rejected")

    Note: Same all-lowercase address but with the first 'd' uppercased to 'D'.
    Note: That creates a mixed-case body whose EIP-55 checksum does NOT verify
    Note: (the keccak-256 of the lowercase form does not mandate uppercase at
    Note: position 0). The structural check must mark this as invalid.
    Let r be Account.eth_address_parse("0xDe709f2102306220921060314715629080e2fb77")
    T.assert_not_null(results, "parse non-null (allocates record)", r)
    T.assert_equal(results, "EIP-55 checksum violation flagged invalid", Account.eth_address_is_structurally_valid(r), 0)
    T.assert_equal(results, "has_mixed_case = 1", Account.eth_address_has_mixed_case(r), 1)

    Note: Direct verify helper returns 0
    T.assert_equal(results, "checksum_verify direct = 0", Account.eth_address_checksum_verify("0xDe709f2102306220921060314715629080e2fb77"), 0)

    Account.eth_address_destroy(r)
    Return 1
End Process

Process called "test_eth_address_eip55_canonical_kat" that takes results as Integer returns Integer:
    T.begin_suite(results, "eth_address.EIP-55 canonical KATs from EIP-55 spec")

    Note: All four canonical EIP-55 test addresses from the EIP-55 spec.
    T.assert_equal(results, "0x5aAeb6053F3E94C9b9A09f33669435E7Ef1BeAed verifies", Account.eth_address_checksum_verify("0x5aAeb6053F3E94C9b9A09f33669435E7Ef1BeAed"), 1)
    T.assert_equal(results, "0xfB6916095ca1df60bB79Ce92cE3Ea74c37c5d359 verifies", Account.eth_address_checksum_verify("0xfB6916095ca1df60bB79Ce92cE3Ea74c37c5d359"), 1)
    T.assert_equal(results, "0xdbF03B407c01E7cD3CBea99509d93f8DDDC8C6FB verifies", Account.eth_address_checksum_verify("0xdbF03B407c01E7cD3CBea99509d93f8DDDC8C6FB"), 1)
    T.assert_equal(results, "0xD1220A0cf47c7B9Be7A2E6BA89F429762e7b9aDb verifies", Account.eth_address_checksum_verify("0xD1220A0cf47c7B9Be7A2E6BA89F429762e7b9aDb"), 1)
    Return 1
End Process

Note: ============================================================================
Note: Ledger account
Note: ============================================================================

Process called "test_ledger_account" that takes results as Integer returns Integer:
    T.begin_suite(results, "ledger_account.create_and_classify")

    Let cash be Account.ledger_account_create(1001, "Cash on hand", Account.LEDGER_KIND_ASSET)
    T.assert_not_null(results, "cash account non-null", cash)
    T.assert_equal(results, "cash coa = 1001", Account.ledger_account_get_coa_code(cash), 1001)
    T.assert_equal(results, "cash is debit-normal", Account.ledger_account_is_debit_normal(cash), 1)

    Let payable be Account.ledger_account_create(2001, "Accounts payable", Account.LEDGER_KIND_LIABILITY)
    T.assert_equal(results, "payable is credit-normal", Account.ledger_account_is_debit_normal(payable), 0)

    Let revenue be Account.ledger_account_create(4001, "Sales revenue", Account.LEDGER_KIND_REVENUE)
    T.assert_equal(results, "revenue is credit-normal", Account.ledger_account_is_debit_normal(revenue), 0)

    Let expense be Account.ledger_account_create(5001, "Office supplies", Account.LEDGER_KIND_EXPENSE)
    T.assert_equal(results, "expense is debit-normal", Account.ledger_account_is_debit_normal(expense), 1)

    Account.ledger_account_destroy(cash)
    Account.ledger_account_destroy(payable)
    Account.ledger_account_destroy(revenue)
    Account.ledger_account_destroy(expense)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_iban_valid_de(results)
    test_iban_valid_gb(results)
    test_iban_invalid_checksum(results)
    test_iban_too_short(results)
    test_iban_country_length_de(results)
    test_iban_country_length_mt(results)
    test_iban_country_length_kw(results)
    test_iban_unknown_country(results)
    test_ach_valid_routing(results)
    test_ach_invalid_routing(results)
    test_ach_account_create(results)
    test_swift_bic_valid_short(results)
    test_swift_bic_valid_long(results)
    test_swift_bic_bad_length(results)
    test_eth_address_structural_lowercase(results)
    test_eth_address_structural_with_prefix(results)
    test_eth_address_invalid(results)
    test_eth_address_eip55_all_uppercase(results)
    test_eth_address_eip55_mixed_valid(results)
    test_eth_address_eip55_legacy_lowercase(results)
    test_eth_address_eip55_invalid_mixed(results)
    test_eth_address_eip55_canonical_kat(results)
    test_ledger_account(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
