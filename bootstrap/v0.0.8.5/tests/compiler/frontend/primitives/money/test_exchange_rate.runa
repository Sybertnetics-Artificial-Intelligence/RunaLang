Note:
Unit tests for compiler/frontend/primitives/money/exchange_rate.runa.

Verifies explicit currency conversion: rate apply, inverse round-trip,
composition (USD->EUR + EUR->JPY = USD->JPY), and staleness check.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/decimal/ieee754_decimal64.runa" as Dec64
Import "compiler/frontend/primitives/money/currency.runa" as Currency
Import "compiler/frontend/primitives/money/money.runa" as Money
Import "compiler/frontend/primitives/money/exchange_rate.runa" as XR

Process called "test_xr_create_and_accessors" that takes results as Integer returns Integer:
    T.begin_suite(results, "exchange_rate.create_and_accessors")

    Let rate_dec be Dec64.dec64_from_string("1.10")
    Let r be XR.exchange_rate_create(Currency.CURRENCY_USD, Currency.CURRENCY_EUR, rate_dec, 1000000000, "ECB:daily")
    T.assert_not_null(results, "create returns non-null", r)
    T.assert_equal(results, "source = USD", XR.exchange_rate_get_source(r), Currency.CURRENCY_USD)
    T.assert_equal(results, "target = EUR", XR.exchange_rate_get_target(r), Currency.CURRENCY_EUR)
    T.assert_equal(results, "timestamp recorded", XR.exchange_rate_get_timestamp(r), 1000000000)

    XR.exchange_rate_destroy(r)
    Return 1
End Process

Process called "test_xr_same_currency_rejected" that takes results as Integer returns Integer:
    T.begin_suite(results, "exchange_rate.same_currency rejected")

    Let rate_dec be Dec64.dec64_from_string("1.00")
    Let bad be XR.exchange_rate_create(Currency.CURRENCY_USD, Currency.CURRENCY_USD, rate_dec, 0, "test")
    T.assert_equal(results, "same-currency rate REJECTED", bad, 0)
    Dec64.dec64_destroy(rate_dec)
    Return 1
End Process

Process called "test_xr_apply_correct_currency" that takes results as Integer returns Integer:
    T.begin_suite(results, "exchange_rate.apply correct currency")

    Let rate_dec be Dec64.dec64_from_string("1.10")
    Let usd_to_eur be XR.exchange_rate_create(Currency.CURRENCY_USD, Currency.CURRENCY_EUR, rate_dec, 0, "test")

    Let usd_100 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "100.00")
    Let eur_result be XR.exchange_rate_apply(usd_to_eur, usd_100)
    T.assert_not_null(results, "apply returns Money", eur_result)
    T.assert_equal(results, "result currency = EUR", Money.money_get_currency(eur_result), Currency.CURRENCY_EUR)

    Let expected be Money.money_from_decimal_string(Currency.CURRENCY_EUR, "110.00")
    T.assert_equal(results, "100 USD * 1.10 = 110 EUR", Money.money_equals(eur_result, expected), 1)

    Money.money_destroy(usd_100)
    Money.money_destroy(eur_result)
    Money.money_destroy(expected)
    XR.exchange_rate_destroy(usd_to_eur)
    Return 1
End Process

Process called "test_xr_apply_wrong_currency_rejected" that takes results as Integer returns Integer:
    T.begin_suite(results, "exchange_rate.apply wrong currency REJECTED")

    Let rate_dec be Dec64.dec64_from_string("1.10")
    Let usd_to_eur be XR.exchange_rate_create(Currency.CURRENCY_USD, Currency.CURRENCY_EUR, rate_dec, 0, "test")

    Note: Trying to apply USD->EUR rate to JPY money MUST be rejected.
    Let jpy_money be Money.money_from_decimal_string(Currency.CURRENCY_JPY, "10000")
    Let bad be XR.exchange_rate_apply(usd_to_eur, jpy_money)
    T.assert_equal(results, "apply USD->EUR rate to JPY money REJECTED", bad, 0)

    Money.money_destroy(jpy_money)
    XR.exchange_rate_destroy(usd_to_eur)
    Return 1
End Process

Process called "test_xr_inverse" that takes results as Integer returns Integer:
    T.begin_suite(results, "exchange_rate.inverse")

    Let rate_dec be Dec64.dec64_from_string("2.0")
    Let usd_to_eur be XR.exchange_rate_create(Currency.CURRENCY_USD, Currency.CURRENCY_EUR, rate_dec, 0, "test")

    Let inv be XR.exchange_rate_inverse(usd_to_eur)
    T.assert_not_null(results, "inverse non-null", inv)
    T.assert_equal(results, "inverse source = EUR", XR.exchange_rate_get_source(inv), Currency.CURRENCY_EUR)
    T.assert_equal(results, "inverse target = USD", XR.exchange_rate_get_target(inv), Currency.CURRENCY_USD)

    XR.exchange_rate_destroy(usd_to_eur)
    XR.exchange_rate_destroy(inv)
    Return 1
End Process

Process called "test_xr_compose" that takes results as Integer returns Integer:
    T.begin_suite(results, "exchange_rate.compose")

    Let usd_eur_dec be Dec64.dec64_from_string("0.90")
    Let usd_to_eur be XR.exchange_rate_create(Currency.CURRENCY_USD, Currency.CURRENCY_EUR, usd_eur_dec, 0, "test")

    Let eur_jpy_dec be Dec64.dec64_from_string("150.00")
    Let eur_to_jpy be XR.exchange_rate_create(Currency.CURRENCY_EUR, Currency.CURRENCY_JPY, eur_jpy_dec, 0, "test")

    Let usd_to_jpy be XR.exchange_rate_compose(usd_to_eur, eur_to_jpy)
    T.assert_not_null(results, "compose non-null", usd_to_jpy)
    T.assert_equal(results, "composed source = USD", XR.exchange_rate_get_source(usd_to_jpy), Currency.CURRENCY_USD)
    T.assert_equal(results, "composed target = JPY", XR.exchange_rate_get_target(usd_to_jpy), Currency.CURRENCY_JPY)

    Note: USD -> JPY apply: 100 USD * 0.90 * 150 = 13500 JPY
    Let usd_100 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "100")
    Let jpy_result be XR.exchange_rate_apply(usd_to_jpy, usd_100)
    T.assert_not_null(results, "compose apply non-null", jpy_result)
    T.assert_equal(results, "compose result currency = JPY", Money.money_get_currency(jpy_result), Currency.CURRENCY_JPY)

    Money.money_destroy(usd_100)
    Money.money_destroy(jpy_result)
    XR.exchange_rate_destroy(usd_to_eur)
    XR.exchange_rate_destroy(eur_to_jpy)
    XR.exchange_rate_destroy(usd_to_jpy)
    Return 1
End Process

Process called "test_xr_compose_non_adjacent_rejected" that takes results as Integer returns Integer:
    T.begin_suite(results, "exchange_rate.compose non-adjacent REJECTED")

    Let usd_eur_dec be Dec64.dec64_from_string("0.90")
    Let usd_to_eur be XR.exchange_rate_create(Currency.CURRENCY_USD, Currency.CURRENCY_EUR, usd_eur_dec, 0, "test")

    Note: Compose USD->EUR with JPY->GBP should fail (no shared currency)
    Let jpy_gbp_dec be Dec64.dec64_from_string("0.006")
    Let jpy_to_gbp be XR.exchange_rate_create(Currency.CURRENCY_JPY, Currency.CURRENCY_GBP, jpy_gbp_dec, 0, "test")

    Let bad be XR.exchange_rate_compose(usd_to_eur, jpy_to_gbp)
    T.assert_equal(results, "compose non-adjacent REJECTED", bad, 0)

    XR.exchange_rate_destroy(usd_to_eur)
    XR.exchange_rate_destroy(jpy_to_gbp)
    Return 1
End Process

Process called "test_xr_staleness" that takes results as Integer returns Integer:
    T.begin_suite(results, "exchange_rate.staleness")

    Let rate_dec be Dec64.dec64_from_string("1.0")
    Let r be XR.exchange_rate_create(Currency.CURRENCY_USD, Currency.CURRENCY_EUR, rate_dec, 1000000000, "test")

    Note: Age = current - timestamp. With timestamp = 1e9 ns and current = 5e9 ns,
    Note: age = 4e9 ns. With max_age_ns = 3e9, the rate is stale.
    T.assert_equal(results, "rate age = 4 seconds (ns)", XR.exchange_rate_age_ns(r, 5000000000), 4000000000)
    T.assert_equal(results, "stale when max < age", XR.exchange_rate_is_stale(r, 5000000000, 3000000000), 1)
    T.assert_equal(results, "fresh when max > age", XR.exchange_rate_is_stale(r, 5000000000, 10000000000), 0)

    XR.exchange_rate_destroy(r)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_xr_create_and_accessors(results)
    test_xr_same_currency_rejected(results)
    test_xr_apply_correct_currency(results)
    test_xr_apply_wrong_currency_rejected(results)
    test_xr_inverse(results)
    test_xr_compose(results)
    test_xr_compose_non_adjacent_rejected(results)
    test_xr_staleness(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
