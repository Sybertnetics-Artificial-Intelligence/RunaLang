Note:
Unit tests for compiler/frontend/primitives/money/ledger_entry.runa.

Verifies construction, accessor wiring, account-touching predicates,
sign-for-account computation, and null-safety. The double-entry
invariants tested here are the per-entry shape (one money amount, two
accounts). LedgerEntry stores account handles opaquely as non-zero
Integer tokens; these tests pass raw sentinel integers (1001, 4001, 7777)
in place of real LedgerAccount records, exercising the LedgerEntry
contract directly without coupling to the Account module.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/money/currency.runa" as Currency
Import "compiler/frontend/primitives/money/money.runa" as Money
Import "compiler/frontend/primitives/money/ledger_entry.runa" as Entry

Process called "main" returns Integer:
    Let results be T.create_test_results()

    Note: ===== ledger_entry.create_and_accessors =====
    T.begin_suite(results, "ledger_entry.create_and_accessors")
    Let cash be 1001
    Let revenue be 4001
    Let m1 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "250.00")
    T.assert_not_null(results, "money built", m1)
    Let e1 be Entry.ledger_entry_create(42, 1234567890, revenue, cash, m1, 99, 0, 0)
    T.assert_not_null(results, "entry built", e1)
    T.assert_equal(results, "id = 42", Entry.ledger_entry_get_id(e1), 42)
    T.assert_equal(results, "timestamp = 1234567890", Entry.ledger_entry_get_timestamp(e1), 1234567890)
    T.assert_equal(results, "account_from = revenue", Entry.ledger_entry_get_account_from(e1), revenue)
    T.assert_equal(results, "account_to = cash", Entry.ledger_entry_get_account_to(e1), cash)
    T.assert_equal(results, "money handle preserved", Entry.ledger_entry_get_money(e1), m1)
    T.assert_equal(results, "transaction_id = 99", Entry.ledger_entry_get_transaction_id(e1), 99)
    T.assert_equal(results, "reference borrowed = 0", Entry.ledger_entry_get_reference(e1), 0)
    T.assert_equal(results, "audit metadata borrowed = 0", Entry.ledger_entry_get_audit_metadata(e1), 0)
    Entry.ledger_entry_destroy(e1)

    Note: ===== ledger_entry.create_rejects_invalid =====
    T.begin_suite(results, "ledger_entry.create_rejects_invalid")
    Let cash2 be 1001
    Let m2 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "10.00")
    Let inv1 be Entry.ledger_entry_create(1, 0, 0, cash2, m2, 0, 0, 0)
    T.assert_equal(results, "null account_from rejected", inv1, 0)
    Let inv2 be Entry.ledger_entry_create(1, 0, cash2, 0, m2, 0, 0, 0)
    T.assert_equal(results, "null account_to rejected", inv2, 0)
    Let inv3 be Entry.ledger_entry_create(1, 0, cash2, cash2, 0, 0, 0, 0)
    T.assert_equal(results, "null money rejected", inv3, 0)
    Money.money_destroy(m2)

    Note: ===== ledger_entry.affects_account =====
    T.begin_suite(results, "ledger_entry.affects_account")
    Let cash3 be 1001
    Let revenue3 be 4001
    Let unrelated3 be 7777
    Let m3 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "1.00")
    Let e3 be Entry.ledger_entry_create(1, 0, revenue3, cash3, m3, 0, 0, 0)
    T.assert_equal(results, "affects cash (account_to)", Entry.ledger_entry_affects_account(e3, cash3), 1)
    T.assert_equal(results, "affects revenue (account_from)", Entry.ledger_entry_affects_account(e3, revenue3), 1)
    T.assert_equal(results, "does not affect unrelated", Entry.ledger_entry_affects_account(e3, unrelated3), 0)
    T.assert_equal(results, "null entry returns 0", Entry.ledger_entry_affects_account(0, cash3), 0)
    T.assert_equal(results, "null account returns 0", Entry.ledger_entry_affects_account(e3, 0), 0)
    Entry.ledger_entry_destroy(e3)

    Note: ===== ledger_entry.sign_for_account =====
    T.begin_suite(results, "ledger_entry.sign_for_account")
    Let cash4 be 1001
    Let revenue4 be 4001
    Let unrelated4 be 7777
    Let m4 be Money.money_from_decimal_string(Currency.CURRENCY_USD, "5.00")
    Let e4 be Entry.ledger_entry_create(1, 0, revenue4, cash4, m4, 0, 0, 0)
    T.assert_equal(results, "sign for cash (account_to) = +1", Entry.ledger_entry_sign_for_account(e4, cash4), 1)
    T.assert_equal(results, "sign for revenue (account_from) = -1", Entry.ledger_entry_sign_for_account(e4, revenue4), 0 minus 1)
    T.assert_equal(results, "sign for unrelated = 0", Entry.ledger_entry_sign_for_account(e4, unrelated4), 0)
    T.assert_equal(results, "sign with null entry = 0", Entry.ledger_entry_sign_for_account(0, cash4), 0)
    T.assert_equal(results, "sign with null account = 0", Entry.ledger_entry_sign_for_account(e4, 0), 0)
    Entry.ledger_entry_destroy(e4)

    Note: ===== ledger_entry.null-safe accessors =====
    T.begin_suite(results, "ledger_entry.null-safe accessors")
    T.assert_equal(results, "get_id on null = 0", Entry.ledger_entry_get_id(0), 0)
    T.assert_equal(results, "get_timestamp on null = 0", Entry.ledger_entry_get_timestamp(0), 0)
    T.assert_equal(results, "get_account_from on null = 0", Entry.ledger_entry_get_account_from(0), 0)
    T.assert_equal(results, "get_account_to on null = 0", Entry.ledger_entry_get_account_to(0), 0)
    T.assert_equal(results, "get_money on null = 0", Entry.ledger_entry_get_money(0), 0)
    T.assert_equal(results, "get_transaction_id on null = 0", Entry.ledger_entry_get_transaction_id(0), 0)
    T.assert_equal(results, "get_reference on null = 0", Entry.ledger_entry_get_reference(0), 0)
    T.assert_equal(results, "get_audit_metadata on null = 0", Entry.ledger_entry_get_audit_metadata(0), 0)
    T.assert_equal(results, "destroy on null = 0", Entry.ledger_entry_destroy(0), 0)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
