Note:
Unit tests for compiler/frontend/primitives/money/sovereign_credit.runa.

Verifies SC-specific constructors (SC currency tag, 18-digit exponent),
treasury-scale (sovereign) arithmetic via the bignum decimal backend.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/money/currency.runa" as Currency
Import "compiler/frontend/primitives/money/money.runa" as Money
Import "compiler/frontend/primitives/money/sovereign_credit.runa" as SC

Process called "test_sc_exponent" that takes results as Integer returns Integer:
    T.begin_suite(results, "sc.decimal_exponent = 18 (wei-style)")

    T.assert_equal(results, "exponent constant = 18", SC.sc_decimal_exponent(), 18)
    Return 1
End Process

Process called "test_sc_money_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "sc.money_zero")

    Let m be SC.sc_money_zero()
    T.assert_not_null(results, "non-null", m)
    T.assert_equal(results, "currency = SC", Money.money_get_currency(m), Currency.CURRENCY_SC)
    T.assert_equal(results, "is_zero", Money.money_is_zero(m), 1)

    Money.money_destroy(m)
    Return 1
End Process

Process called "test_sc_money_from_whole_units" that takes results as Integer returns Integer:
    T.begin_suite(results, "sc.money_from_whole_units")

    Let m be SC.sc_money_from_whole_units(5)
    T.assert_not_null(results, "5 SC non-null", m)
    T.assert_equal(results, "currency = SC", Money.money_get_currency(m), Currency.CURRENCY_SC)
    T.assert_equal(results, "is_positive", Money.money_is_positive(m), 1)

    Money.money_destroy(m)
    Return 1
End Process

Process called "test_sc_sovereign_create_and_destroy" that takes results as Integer returns Integer:
    T.begin_suite(results, "sc.sovereign_from_integer")

    Let v be SC.sc_sovereign_from_integer(1000000000000)
    T.assert_not_null(results, "1 trillion SC non-null", v)
    T.assert_equal(results, "sign = 0 (positive)", SC.sc_sovereign_get_sign(v), 0)

    Note: 1e12 has 13 decimal digits, base-1000 representation has ceil(13/3) = 5 limbs
    Let count be SC.sc_sovereign_get_digit_count(v)
    T.assert_greater_than(results, "digit_count > 0", count, 0)

    SC.sc_sovereign_destroy(v)
    Return 1
End Process

Process called "test_sc_sovereign_negate" that takes results as Integer returns Integer:
    T.begin_suite(results, "sc.sovereign_negate")

    Let v be SC.sc_sovereign_from_integer(1000)
    Let neg be SC.sc_sovereign_negate(v)
    T.assert_not_null(results, "negate non-null", neg)
    T.assert_equal(results, "negate sign = 1", SC.sc_sovereign_get_sign(neg), 1)

    SC.sc_sovereign_destroy(v)
    SC.sc_sovereign_destroy(neg)
    Return 1
End Process

Process called "test_sc_sovereign_add" that takes results as Integer returns Integer:
    T.begin_suite(results, "sc.sovereign_add same-sign")

    Let a be SC.sc_sovereign_from_integer(500000000000)
    Let b be SC.sc_sovereign_from_integer(500000000000)
    Let sum be SC.sc_sovereign_add(a, b)
    T.assert_not_null(results, "5e11 + 5e11 non-null", sum)
    T.assert_equal(results, "sum sign = positive", SC.sc_sovereign_get_sign(sum), 0)

    SC.sc_sovereign_destroy(a)
    SC.sc_sovereign_destroy(b)
    SC.sc_sovereign_destroy(sum)
    Return 1
End Process

Process called "test_sc_sovereign_add_cancellation" that takes results as Integer returns Integer:
    T.begin_suite(results, "sc.sovereign_add cancellation (a + -a = 0)")

    Let a be SC.sc_sovereign_from_integer(123456789)
    Let neg_a be SC.sc_sovereign_negate(a)
    Let zero be SC.sc_sovereign_add(a, neg_a)
    T.assert_not_null(results, "cancellation non-null", zero)

    Note: Compare against a fresh zero.
    Let z2 be SC.sc_sovereign_from_integer(0)
    Let cmp be SC.sc_sovereign_compare(zero, z2)
    T.assert_equal(results, "a + (-a) compares equal to zero", cmp, 0)

    SC.sc_sovereign_destroy(a)
    SC.sc_sovereign_destroy(neg_a)
    SC.sc_sovereign_destroy(zero)
    SC.sc_sovereign_destroy(z2)
    Return 1
End Process

Process called "test_sc_sovereign_compare_ordering" that takes results as Integer returns Integer:
    T.begin_suite(results, "sc.sovereign_compare ordering")

    Let small be SC.sc_sovereign_from_integer(100)
    Let big be SC.sc_sovereign_from_integer(1000)
    Let neg_big be SC.sc_sovereign_negate(big)

    T.assert_equal(results, "small < big returns -1", SC.sc_sovereign_compare(small, big), 0 minus 1)
    T.assert_equal(results, "big > small returns +1", SC.sc_sovereign_compare(big, small), 1)
    T.assert_equal(results, "small > -big returns +1", SC.sc_sovereign_compare(small, neg_big), 1)
    T.assert_equal(results, "-big < small returns -1", SC.sc_sovereign_compare(neg_big, small), 0 minus 1)

    SC.sc_sovereign_destroy(small)
    SC.sc_sovereign_destroy(big)
    SC.sc_sovereign_destroy(neg_big)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_sc_exponent(results)
    test_sc_money_zero(results)
    test_sc_money_from_whole_units(results)
    test_sc_sovereign_create_and_destroy(results)
    test_sc_sovereign_negate(results)
    test_sc_sovereign_add(results)
    test_sc_sovereign_add_cancellation(results)
    test_sc_sovereign_compare_ordering(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
