Note:
Unit tests for compiler/frontend/primitives/money/currency.runa.

Verifies the currency registry: slot population, ISO 4217 alpha/numeric
round-trip, classification, decimal exponent for major fiats and crypto.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/money/currency.runa" as Currency

Process called "test_registry_init" that takes results as Integer returns Integer:
    T.begin_suite(results, "currency.registry_initialize_once")

    Let base be Currency.currency_registry_initialize_once()
    T.assert_not_null(results, "registry base is non-null", base)

    Let usd_classification be Currency.currency_get_classification(base, Currency.CURRENCY_USD)
    T.assert_equal(results, "USD classification is FIAT", usd_classification, Currency.CURRENCY_CLASS_FIAT)

    Let btc_classification be Currency.currency_get_classification(base, Currency.CURRENCY_BTC)
    T.assert_equal(results, "BTC classification is CRYPTO", btc_classification, Currency.CURRENCY_CLASS_CRYPTO)

    Let sc_classification be Currency.currency_get_classification(base, Currency.CURRENCY_SC)
    T.assert_equal(results, "SC classification is SOVEREIGN", sc_classification, Currency.CURRENCY_CLASS_SOVEREIGN)

    Let xau_classification be Currency.currency_get_classification(base, Currency.CURRENCY_XAU)
    T.assert_equal(results, "XAU classification is COMMODITY", xau_classification, Currency.CURRENCY_CLASS_COMMODITY)

    Currency.currency_registry_destroy(base)
    Return 1
End Process

Process called "test_iso_numeric_codes" that takes results as Integer returns Integer:
    T.begin_suite(results, "currency.iso_numeric_codes")

    Let base be Currency.currency_registry_initialize_once()

    T.assert_equal(results, "USD numeric = 840", Currency.currency_get_iso_numeric(base, Currency.CURRENCY_USD), 840)
    T.assert_equal(results, "EUR numeric = 978", Currency.currency_get_iso_numeric(base, Currency.CURRENCY_EUR), 978)
    T.assert_equal(results, "GBP numeric = 826", Currency.currency_get_iso_numeric(base, Currency.CURRENCY_GBP), 826)
    T.assert_equal(results, "JPY numeric = 392", Currency.currency_get_iso_numeric(base, Currency.CURRENCY_JPY), 392)
    T.assert_equal(results, "CNY numeric = 156", Currency.currency_get_iso_numeric(base, Currency.CURRENCY_CNY), 156)
    T.assert_equal(results, "CHF numeric = 756", Currency.currency_get_iso_numeric(base, Currency.CURRENCY_CHF), 756)
    T.assert_equal(results, "XAU numeric = 959", Currency.currency_get_iso_numeric(base, Currency.CURRENCY_XAU), 959)
    T.assert_equal(results, "BTC numeric = -1 (non-ISO)", Currency.currency_get_iso_numeric(base, Currency.CURRENCY_BTC), 0 minus 1)
    T.assert_equal(results, "SC numeric = -1 (non-ISO)", Currency.currency_get_iso_numeric(base, Currency.CURRENCY_SC), 0 minus 1)

    Currency.currency_registry_destroy(base)
    Return 1
End Process

Process called "test_iso_alpha_lookup" that takes results as Integer returns Integer:
    T.begin_suite(results, "currency.from_iso_code")

    Let base be Currency.currency_registry_initialize_once()

    T.assert_equal(results, "from 'USD' = CURRENCY_USD", Currency.currency_from_iso_code(base, "USD"), Currency.CURRENCY_USD)
    T.assert_equal(results, "from 'EUR' = CURRENCY_EUR", Currency.currency_from_iso_code(base, "EUR"), Currency.CURRENCY_EUR)
    T.assert_equal(results, "from 'JPY' = CURRENCY_JPY", Currency.currency_from_iso_code(base, "JPY"), Currency.CURRENCY_JPY)
    T.assert_equal(results, "from 'BTC' = CURRENCY_BTC", Currency.currency_from_iso_code(base, "BTC"), Currency.CURRENCY_BTC)
    T.assert_equal(results, "from 'ETH' = CURRENCY_ETH", Currency.currency_from_iso_code(base, "ETH"), Currency.CURRENCY_ETH)
    T.assert_equal(results, "from 'SC' = CURRENCY_SC", Currency.currency_from_iso_code(base, "SC"), Currency.CURRENCY_SC)
    T.assert_equal(results, "from 'XAU' = CURRENCY_XAU", Currency.currency_from_iso_code(base, "XAU"), Currency.CURRENCY_XAU)
    T.assert_equal(results, "from 'XYZ' = INVALID", Currency.currency_from_iso_code(base, "XYZ"), Currency.CURRENCY_ID_INVALID)
    T.assert_equal(results, "from '' = INVALID", Currency.currency_from_iso_code(base, ""), Currency.CURRENCY_ID_INVALID)

    Currency.currency_registry_destroy(base)
    Return 1
End Process

Process called "test_numeric_code_lookup" that takes results as Integer returns Integer:
    T.begin_suite(results, "currency.from_numeric_code")

    Let base be Currency.currency_registry_initialize_once()

    T.assert_equal(results, "from 840 = USD", Currency.currency_from_numeric_code(base, 840), Currency.CURRENCY_USD)
    T.assert_equal(results, "from 978 = EUR", Currency.currency_from_numeric_code(base, 978), Currency.CURRENCY_EUR)
    T.assert_equal(results, "from 392 = JPY", Currency.currency_from_numeric_code(base, 392), Currency.CURRENCY_JPY)
    T.assert_equal(results, "from 999999 = INVALID", Currency.currency_from_numeric_code(base, 999999), Currency.CURRENCY_ID_INVALID)
    T.assert_equal(results, "from 0 = INVALID", Currency.currency_from_numeric_code(base, 0), Currency.CURRENCY_ID_INVALID)

    Currency.currency_registry_destroy(base)
    Return 1
End Process

Process called "test_decimal_exponents" that takes results as Integer returns Integer:
    T.begin_suite(results, "currency.decimal_exponent")

    Let base be Currency.currency_registry_initialize_once()

    T.assert_equal(results, "USD exponent = 2", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_USD), 2)
    T.assert_equal(results, "EUR exponent = 2", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_EUR), 2)
    T.assert_equal(results, "JPY exponent = 0", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_JPY), 0)
    T.assert_equal(results, "KRW exponent = 0", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_KRW), 0)
    T.assert_equal(results, "KWD exponent = 3", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_KWD), 3)
    T.assert_equal(results, "BHD exponent = 3", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_BHD), 3)
    T.assert_equal(results, "BTC exponent = 8 (satoshi)", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_BTC), 8)
    T.assert_equal(results, "ETH exponent = 18 (wei)", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_ETH), 18)
    T.assert_equal(results, "SC exponent = 18 (wei-style)", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_SC), 18)
    T.assert_equal(results, "SOL exponent = 9 (lamport)", Currency.currency_get_decimal_exponent(base, Currency.CURRENCY_SOL), 9)

    Currency.currency_registry_destroy(base)
    Return 1
End Process

Process called "test_classification_predicates" that takes results as Integer returns Integer:
    T.begin_suite(results, "currency.classification_predicates")

    Let base be Currency.currency_registry_initialize_once()

    T.assert_equal(results, "USD is_fiat", Currency.currency_is_fiat(base, Currency.CURRENCY_USD), 1)
    T.assert_equal(results, "USD is_crypto = 0", Currency.currency_is_crypto(base, Currency.CURRENCY_USD), 0)
    T.assert_equal(results, "BTC is_crypto", Currency.currency_is_crypto(base, Currency.CURRENCY_BTC), 1)
    T.assert_equal(results, "BTC is_fiat = 0", Currency.currency_is_fiat(base, Currency.CURRENCY_BTC), 0)
    T.assert_equal(results, "SC is_sovereign", Currency.currency_is_sovereign(base, Currency.CURRENCY_SC), 1)
    T.assert_equal(results, "SC is_fiat = 0", Currency.currency_is_fiat(base, Currency.CURRENCY_SC), 0)
    T.assert_equal(results, "SC is_crypto = 0", Currency.currency_is_crypto(base, Currency.CURRENCY_SC), 0)
    T.assert_equal(results, "XAU is_commodity", Currency.currency_is_commodity(base, Currency.CURRENCY_XAU), 1)
    T.assert_equal(results, "invalid id is_valid = 0", Currency.currency_is_valid(base, 9999), 0)
    T.assert_equal(results, "USD is_valid", Currency.currency_is_valid(base, Currency.CURRENCY_USD), 1)

    Currency.currency_registry_destroy(base)
    Return 1
End Process

Process called "test_equals" that takes results as Integer returns Integer:
    T.begin_suite(results, "currency.equals")

    T.assert_equal(results, "USD equals USD", Currency.currency_equals(Currency.CURRENCY_USD, Currency.CURRENCY_USD), 1)
    T.assert_equal(results, "USD equals EUR = 0", Currency.currency_equals(Currency.CURRENCY_USD, Currency.CURRENCY_EUR), 0)
    T.assert_equal(results, "SC equals SC", Currency.currency_equals(Currency.CURRENCY_SC, Currency.CURRENCY_SC), 1)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_registry_init(results)
    test_iso_numeric_codes(results)
    test_iso_alpha_lookup(results)
    test_numeric_code_lookup(results)
    test_decimal_exponents(results)
    test_classification_predicates(results)
    test_equals(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
