Note:
Unit tests for compiler/frontend/primitives/config/config_value.runa.

Covers: DateTime/Duration, path get/set, merge, runa-native round-trip.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/config/config_value.runa" as CV
Import "compiler/frontend/primitives/config/config.runa" as Cfg
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/collections/list.runa" as List

Process called "test_datetime_duration" that takes results as Integer returns Integer:
    T.begin_suite(results, "config_value.datetime / duration")

    Let dt be proc config_value_datetime from CV with "2026-06-03T12:00:00Z"
    T.assert_not_null(results, "datetime non-null", dt)
    Let dt_str be proc config_value_as_datetime from CV with dt
    T.assert_not_null(results, "datetime accessor", dt_str)
    proc config_value_destroy from Cfg with dt

    Let dur be proc config_value_duration from CV with 5000000000
    T.assert_not_null(results, "duration non-null", dur)
    Let ns be proc config_value_as_duration from CV with dur
    T.assert_equal(results, "duration ns", ns, 5000000000)
    proc config_value_destroy from Cfg with dur
    Return 1
End Process

Process called "test_path_get_set" that takes results as Integer returns Integer:
    T.begin_suite(results, "config_value.get / set")

    Let root_dict be proc create from Dict
    Let root be proc config_value_map from Cfg with root_dict
    Let v_50 be proc config_value_integer from Cfg with 50
    proc config_value_set from CV with root, "server.port", v_50

    Let got be proc config_value_get from CV with root, "server.port"
    T.assert_not_null(results, "got server.port", got)
    T.assert_equal(results, "value 50", proc config_value_as_integer from Cfg with got, 50)

    Let missing be proc config_value_get from CV with root, "server.host"
    T.assert_equal(results, "missing returns 0", missing, 0)

    proc config_value_destroy from Cfg with root
    Return 1
End Process

Process called "test_merge" that takes results as Integer returns Integer:
    T.begin_suite(results, "config_value.merge")

    Let base_dict be proc create from Dict
    Let base be proc config_value_map from Cfg with base_dict
    Let v_a be proc config_value_integer from Cfg with 1
    Let v_b be proc config_value_integer from Cfg with 2
    proc config_value_set from CV with base, "a", v_a
    proc config_value_set from CV with base, "b", v_b

    Let over_dict be proc create from Dict
    Let over be proc config_value_map from Cfg with over_dict
    Let v_b2 be proc config_value_integer from Cfg with 99
    Let v_c be proc config_value_integer from Cfg with 3
    proc config_value_set from CV with over, "b", v_b2
    proc config_value_set from CV with over, "c", v_c

    proc config_value_merge from CV with base, over

    Let got_a be proc config_value_get from CV with base, "a"
    T.assert_equal(results, "a preserved", proc config_value_as_integer from Cfg with got_a, 1)
    Let got_b be proc config_value_get from CV with base, "b"
    T.assert_equal(results, "b overridden", proc config_value_as_integer from Cfg with got_b, 99)
    Let got_c be proc config_value_get from CV with base, "c"
    T.assert_equal(results, "c added", proc config_value_as_integer from Cfg with got_c, 3)

    proc config_value_destroy from Cfg with base
    proc config_value_destroy from Cfg with over
    Return 1
End Process

Process called "test_native_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "config_value.to_runa_native / from_runa_native")

    Let v_int be proc config_value_integer from Cfg with 42
    Let txt be proc config_value_to_runa_native from CV with v_int
    T.assert_not_null(results, "serialized int", txt)
    Let v_int2 be proc config_value_from_runa_native from CV with txt
    T.assert_not_null(results, "parsed back", v_int2)
    T.assert_equal(results, "value matches", proc config_value_as_integer from Cfg with v_int2, 42)
    proc config_value_destroy from Cfg with v_int
    proc config_value_destroy from Cfg with v_int2

    Let v_str be proc config_value_string from Cfg with "hello"
    Let txt2 be proc config_value_to_runa_native from CV with v_str
    T.assert_not_null(results, "string serialized", txt2)
    Let v_str2 be proc config_value_from_runa_native from CV with txt2
    T.assert_not_null(results, "string re-parsed", v_str2)
    proc config_value_destroy from Cfg with v_str
    proc config_value_destroy from Cfg with v_str2

    Let v_bool be proc config_value_bool from Cfg with 1
    Let txt3 be proc config_value_to_runa_native from CV with v_bool
    T.assert_not_null(results, "bool serialized", txt3)
    Let v_bool2 be proc config_value_from_runa_native from CV with txt3
    T.assert_not_null(results, "bool re-parsed", v_bool2)
    T.assert_equal(results, "bool true matches", proc config_value_as_bool from Cfg with v_bool2, 1)
    proc config_value_destroy from Cfg with v_bool
    proc config_value_destroy from Cfg with v_bool2

    Return 1
End Process

Process called "test_list_index_path" that takes results as Integer returns Integer:
    T.begin_suite(results, "config_value.path on list")
    Let inner_dict be proc create from Dict
    Let root be proc config_value_map from Cfg with inner_dict

    Let elem1 be proc config_value_integer from Cfg with 10
    Let elem2 be proc config_value_integer from Cfg with 20
    Let arr_list be proc list_create from List
    proc list_push from List with arr_list, elem1
    proc list_push from List with arr_list, elem2
    Let arr_cv be proc config_value_list from Cfg with arr_list
    proc config_value_set from CV with root, "nums", arr_cv

    Let got be proc config_value_get from CV with root, "nums.1"
    T.assert_not_null(results, "got nums.1", got)
    T.assert_equal(results, "nums[1] = 20", proc config_value_as_integer from Cfg with got, 20)

    proc config_value_destroy from Cfg with root
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_datetime_duration(results)
    test_path_get_set(results)
    test_merge(results)
    test_native_roundtrip(results)
    test_list_index_path(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
