Note:
Unit tests for compiler/frontend/primitives/config/runa_config.runa.

KAT: runa-config round-trip preserves ordering.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/config/runa_config.runa" as RC
Import "compiler/frontend/primitives/config/config.runa" as Cfg
Import "compiler/frontend/primitives/config/config_value.runa" as CV
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_parse_empty_config" that takes results as Integer returns Integer:
    T.begin_suite(results, "runa_config.parse empty")
    Let v be proc runa_config_parse from RC with "Configuration:\nEnd Configuration\n"
    T.assert_not_null(results, "empty config parsed", v)
    T.assert_equal(results, "kind map", proc config_value_kind from Cfg with v, 6)
    proc config_value_destroy from Cfg with v
    Return 1
End Process

Process called "test_parse_top_level_bindings" that takes results as Integer returns Integer:
    T.begin_suite(results, "runa_config.parse top-level bindings")
    Let source be "Configuration:\n    port as 5432\n    name as \"db\"\n    debug as true\nEnd Configuration\n"
    Let v be proc runa_config_parse from RC with source
    T.assert_not_null(results, "parsed", v)
    Let port_v be proc config_value_get from CV with v, "port"
    T.assert_not_null(results, "port found", port_v)
    T.assert_equal(results, "port=5432", proc config_value_as_integer from Cfg with port_v, 5432)
    Let name_v be proc config_value_get from CV with v, "name"
    T.assert_not_null(results, "name found", name_v)
    Let debug_v be proc config_value_get from CV with v, "debug"
    T.assert_equal(results, "debug=true", proc config_value_as_bool from Cfg with debug_v, 1)
    proc config_value_destroy from Cfg with v
    Return 1
End Process

Process called "test_parse_section" that takes results as Integer returns Integer:
    T.begin_suite(results, "runa_config.parse section")
    Let source be "Configuration:\n    Section \"database\":\n        host as \"localhost\"\n        port as 5432\n    End Section\nEnd Configuration\n"
    Let v be proc runa_config_parse from RC with source
    T.assert_not_null(results, "parsed", v)
    Let host_v be proc config_value_get from CV with v, "database.host"
    T.assert_not_null(results, "database.host found", host_v)
    Let port_v be proc config_value_get from CV with v, "database.port"
    T.assert_not_null(results, "database.port found", port_v)
    T.assert_equal(results, "port=5432", proc config_value_as_integer from Cfg with port_v, 5432)
    proc config_value_destroy from Cfg with v
    Return 1
End Process

Process called "test_serialize_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "runa_config.serialize round-trip preserves data")
    Let source be "Configuration:\n    threshold as 100\n    Section \"logging\":\n        level as \"info\"\n    End Section\nEnd Configuration\n"
    Let v be proc runa_config_parse from RC with source
    T.assert_not_null(results, "parsed", v)
    Let text be proc runa_config_serialize from RC with v
    T.assert_not_null(results, "serialized non-null", text)
    Let v2 be proc runa_config_parse from RC with text
    T.assert_not_null(results, "round-trip re-parses", v2)
    Let thresh_v be proc config_value_get from CV with v2, "threshold"
    T.assert_equal(results, "threshold=100 preserved", proc config_value_as_integer from Cfg with thresh_v, 100)
    Let level_v be proc config_value_get from CV with v2, "logging.level"
    T.assert_not_null(results, "logging.level preserved", level_v)
    proc config_value_destroy from Cfg with v
    proc config_value_destroy from Cfg with v2
    Return 1
End Process

Process called "test_parse_list_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "runa_config.parse list value")
    Let source be "Configuration:\n    nums as a list containing 1, 2, 3\nEnd Configuration\n"
    Let v be proc runa_config_parse from RC with source
    T.assert_not_null(results, "parsed", v)
    Let nums be proc config_value_get from CV with v, "nums"
    T.assert_not_null(results, "nums found", nums)
    T.assert_equal(results, "kind list", proc config_value_kind from Cfg with nums, 5)
    Let lst be proc config_value_as_list from Cfg with nums
    T.assert_equal(results, "length 3", proc length from List with lst, 3)
    proc config_value_destroy from Cfg with v
    Return 1
End Process

Process called "test_null_handling" that takes results as Integer returns Integer:
    T.begin_suite(results, "runa_config.parse null and false")
    Let source be "Configuration:\n    nothing as null\n    cold as false\nEnd Configuration\n"
    Let v be proc runa_config_parse from RC with source
    T.assert_not_null(results, "parsed", v)
    Let nv be proc config_value_get from CV with v, "nothing"
    T.assert_not_null(results, "nothing found", nv)
    T.assert_equal(results, "kind null", proc config_value_kind from Cfg with nv, 0)
    Let fv be proc config_value_get from CV with v, "cold"
    T.assert_equal(results, "false=0", proc config_value_as_bool from Cfg with fv, 0)
    proc config_value_destroy from Cfg with v
    Return 1
End Process

Process called "test_parse_includes" that takes results as Integer returns Integer:
    T.begin_suite(results, "runa_config.parse include directives")
    Let source be "Configuration:\n    Include \"base.runa\"\n    Include \"override.runa\"\n    port as 5432\nEnd Configuration\n"
    Let v be proc runa_config_parse from RC with source
    T.assert_not_null(results, "parsed", v)
    Let includes_cv be proc config_value_get from CV with v, "__includes"
    T.assert_not_null(results, "__includes key present", includes_cv)
    T.assert_equal(results, "kind list", proc config_value_kind from Cfg with includes_cv, 5)
    Let lst be proc config_value_as_list from Cfg with includes_cv
    T.assert_equal(results, "two includes recorded", proc length from List with lst, 2)
    Let first be proc list_get from List with lst, 0
    T.assert_equal(results, "first include kind string", proc config_value_kind from Cfg with first, 1)
    Let first_str be proc config_value_as_string from Cfg with first
    Let first_eq be proc string_equals from StringCore with first_str, "base.runa"
    T.assert_equal(results, "first include path is base.runa", first_eq, 1)
    Let second be proc list_get from List with lst, 1
    Let second_str be proc config_value_as_string from Cfg with second
    Let second_eq be proc string_equals from StringCore with second_str, "override.runa"
    T.assert_equal(results, "second include path is override.runa", second_eq, 1)
    Let port_v be proc config_value_get from CV with v, "port"
    T.assert_not_null(results, "port still parsed after includes", port_v)
    T.assert_equal(results, "port=5432", proc config_value_as_integer from Cfg with port_v, 5432)
    proc config_value_destroy from Cfg with v
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_parse_empty_config(results)
    test_parse_top_level_bindings(results)
    test_parse_section(results)
    test_serialize_roundtrip(results)
    test_parse_list_value(results)
    test_null_handling(results)
    test_parse_includes(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
