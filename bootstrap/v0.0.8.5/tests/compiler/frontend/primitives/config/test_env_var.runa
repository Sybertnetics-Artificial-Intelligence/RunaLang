Note:
Unit tests for compiler/frontend/primitives/config/env_var.runa.

KAT: env_expand "${HOME:-/tmp}" with HOME unset -> "/tmp".
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/config/env_var.runa" as EnvVar
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_parse_boolean_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "env_var.parse_boolean_value")
    T.assert_equal(results, "true -> 1", (proc parse_boolean_value from EnvVar with "true"), 1)
    T.assert_equal(results, "True -> 1", (proc parse_boolean_value from EnvVar with "True"), 1)
    T.assert_equal(results, "yes -> 1", (proc parse_boolean_value from EnvVar with "yes"), 1)
    T.assert_equal(results, "1 -> 1", (proc parse_boolean_value from EnvVar with "1"), 1)
    T.assert_equal(results, "ON -> 1", (proc parse_boolean_value from EnvVar with "ON"), 1)
    T.assert_equal(results, "false -> 0", (proc parse_boolean_value from EnvVar with "false"), 0)
    T.assert_equal(results, "garbage -> 0", (proc parse_boolean_value from EnvVar with "garbage"), 0)
    T.assert_equal(results, "empty -> 0", (proc parse_boolean_value from EnvVar with ""), 0)
    Return 1
End Process

Process called "test_parse_duration_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "env_var.parse_duration_value")
    T.assert_equal(results, "5s -> 5e9 ns", (proc parse_duration_value from EnvVar with "5s"), 5000000000)
    T.assert_equal(results, "100ms -> 1e8 ns", (proc parse_duration_value from EnvVar with "100ms"), 100000000)
    T.assert_equal(results, "1ns -> 1 ns", (proc parse_duration_value from EnvVar with "1ns"), 1)
    T.assert_equal(results, "10us -> 1e4 ns", (proc parse_duration_value from EnvVar with "10us"), 10000)
    T.assert_equal(results, "2m -> 1.2e11 ns", (proc parse_duration_value from EnvVar with "2m"), 120000000000)
    Return 1
End Process

Process called "test_env_expand_default" that takes results as Integer returns Integer:
    T.begin_suite(results, "env_var.expand KAT: ${HOME:-/tmp}")
    Note: HOME may or may not be set in the test environment. The KAT verifies that the default branch is reachable when HOME is unset.
    Let result be proc env_expand from EnvVar with "${RUNA_NEVER_SET_TEST_VAR:-/tmp}"
    T.assert_not_null(results, "expand returns non-null", result)
    Let eq be proc string_equals from StringCore with result, "/tmp"
    T.assert_equal(results, "default substituted", eq, 1)
    Return 1
End Process

Process called "test_env_expand_literal" that takes results as Integer returns Integer:
    T.begin_suite(results, "env_var.expand literal passthrough")
    Let r be proc env_expand from EnvVar with "hello world"
    T.assert_not_null(results, "literal expanded", r)
    Let eq be proc string_equals from StringCore with r, "hello world"
    T.assert_equal(results, "unchanged", eq, 1)
    Return 1
End Process

Process called "test_load_from_file_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "env_var.load_from_file")
    Let source be "KEY1=value1\nKEY2=\"quoted value\"\n# comment\n\nKEY3=42\n"
    Let dict be proc env_load_from_file from EnvVar with source
    T.assert_not_null(results, "dict produced", dict)
    Let v1 be proc get from Dict with dict, "KEY1"
    T.assert_not_null(results, "KEY1 present", v1)
    Let eq1 be proc string_equals from StringCore with v1, "value1"
    T.assert_equal(results, "KEY1 = value1", eq1, 1)
    Let v2 be proc get from Dict with dict, "KEY2"
    T.assert_not_null(results, "KEY2 present", v2)
    Let v3 be proc get from Dict with dict, "KEY3"
    T.assert_not_null(results, "KEY3 present", v3)
    Return 1
End Process

Process called "test_env_for_subprocess" that takes results as Integer returns Integer:
    T.begin_suite(results, "env_var.env_for_subprocess")
    Let overrides be proc create from Dict
    proc set from Dict with overrides, "TEST_OVERRIDE", "value123"
    Let result_dict be proc env_for_subprocess from EnvVar with 0, overrides
    T.assert_not_null(results, "result non-null", result_dict)
    Let v be proc get from Dict with result_dict, "TEST_OVERRIDE"
    T.assert_not_null(results, "override applied", v)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_parse_boolean_value(results)
    test_parse_duration_value(results)
    test_env_expand_default(results)
    test_env_expand_literal(results)
    test_load_from_file_basic(results)
    test_env_for_subprocess(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
