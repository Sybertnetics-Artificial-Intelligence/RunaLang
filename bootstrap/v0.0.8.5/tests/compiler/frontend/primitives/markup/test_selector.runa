Note:
KAT - markup/selector.runa (the matching engine).

Exercises the selector_match and selector_query_all primitives across
simple, compound, and complex selectors against Element AST trees.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/markup/element.runa" as Elem
Import "compiler/frontend/primitives/markup/selector.runa" as MS
Import "compiler/frontend/primitives/style/selector.runa" as Sel
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "build_tree" returns Integer:
    Let root be Elem.element_create("div", 0)
    Elem.element_append_attribute(root, Elem.attribute_create("class", "container", 0))
    Let a be Elem.element_create("a", 0)
    Elem.element_append_attribute(a, Elem.attribute_create("href", "https://example.com", 0))
    Elem.element_append_attribute(a, Elem.attribute_create("class", "foo", 0))
    Elem.element_append_child(root, Elem.markup_node_create_element(a))
    Let span be Elem.element_create("span", 0)
    Elem.element_append_attribute(span, Elem.attribute_create("id", "marker", 0))
    Elem.element_append_child(root, Elem.markup_node_create_element(span))
    Return root
End Process

Process called "test_match_universal" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.selector.match_universal")
    Let root be build_tree()
    Let star be Sel.selector_universal()
    Let m be MS.selector_match(root, star)
    T.assert_equal(results, "* matches any element", m, 1)
    Sel.selector_destroy(star)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_match_type" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.selector.match_type")
    Let root be build_tree()
    Let div_sel be Sel.selector_type("div")
    Let m1 be MS.selector_match(root, div_sel)
    T.assert_equal(results, "div matches root div", m1, 1)
    Let span_sel be Sel.selector_type("span")
    Let m2 be MS.selector_match(root, span_sel)
    T.assert_equal(results, "span does not match root", m2, 0)
    Sel.selector_destroy(div_sel)
    Sel.selector_destroy(span_sel)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_match_class" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.selector.match_class")
    Let root be build_tree()
    Let sel be Sel.selector_class("container")
    Let m be MS.selector_match(root, sel)
    T.assert_equal(results, ".container matches", m, 1)
    Sel.selector_destroy(sel)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_match_id" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.selector.match_id")
    Let root be build_tree()
    Let sel be Sel.selector_id("marker")
    Let r2 be MS.selector_match(root, sel)
    T.assert_equal(results, "#marker does not match root div", r2, 0)
    Let span be Elem.element_get_child(root, 1)
    Let span_elem be Elem.markup_node_get_payload(span)
    Let r3 be MS.selector_match(span_elem, sel)
    T.assert_equal(results, "#marker matches span", r3, 1)
    Sel.selector_destroy(sel)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_match_attribute_prefix" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.selector.attribute_prefix")
    Let root be build_tree()
    Let a_node be Elem.element_get_child(root, 0)
    Let a_elem be Elem.markup_node_get_payload(a_node)
    Let sel be Sel.selector_attribute("href", "https://", 4)
    Let m be MS.selector_match(a_elem, sel)
    T.assert_equal(results, "[href^=https://] matches", m, 1)
    Sel.selector_destroy(sel)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_query_all" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.selector.query_all")
    Let root be build_tree()
    Let sel be Sel.selector_parse("a")
    Let matches be MS.selector_query_all(root, sel)
    T.assert_not_null(results, "query_all returns list", matches)
    T.assert_equal(results, "found 1 anchor", List.list_length(matches), 1)
    List.list_destroy(matches)
    Sel.selector_destroy(sel)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_parse_and_match" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.selector.parse_and_match")
    Let root be build_tree()
    Let sel be Sel.selector_parse("a.foo")
    T.assert_not_null(results, "selector_parse returns non-null", sel)
    Let matches be MS.selector_query_all(root, sel)
    T.assert_not_null(results, "query_all returns list", matches)
    Let n be List.list_length(matches)
    T.assert_greater_than(results, "found at least one match", n, 0)
    List.list_destroy(matches)
    Sel.selector_destroy(sel)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_match_universal(results)
    test_match_type(results)
    test_match_class(results)
    test_match_id(results)
    test_match_attribute_prefix(results)
    test_query_all(results)
    test_parse_and_match(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
