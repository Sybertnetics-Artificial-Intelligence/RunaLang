Note:
KAT - markup/markdown.runa.

Exercises:
- Construction of every public block and inline AST kind.
- Parsing of representative CommonMark 0.31 inputs (ATX headings,
  thematic breaks, paragraphs, fenced code, block quotes).
- Inline parsing (code span, emphasis, hard line break).
- Round-trip through markdown_render_html and markdown_render_plain_text.

CommonMark examples cited:
  - Example 62  (ATX heading)        from spec 4.2
  - Example 13  (thematic break)     from spec 4.1
  - Example 89  (fenced code block)  from spec 4.5
  - Example 219 (paragraph)          from spec 4.8
  - Example 350 (code span)          from spec 6.1
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/markup/markdown.runa" as MD
Import "compiler/frontend/primitives/collections/list.runa" as List

Process called "test_constructors" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.markdown.constructors")

    Let tb be MD.md_thematic_break()
    T.assert_equal(results, "thematic break kind", MD.md_kind(tb), 1)
    MD.md_block_destroy(tb)

    Let title1 be "Hello"
    Let h1 be MD.md_atx_heading(title1, 1)
    T.assert_equal(results, "h1 kind", MD.md_kind(h1), 2)
    T.assert_equal(results, "h1 level", MD.md_secondary(h1), 1)
    Note: Payload is borrowed (not freed by constructor); we set it to 0 before destroy
    Note: to avoid attempting to deallocate the static literal.
    MD.md_set_children(h1, 0)
    Note: The constructor did NOT duplicate the title; md_block_destroy will try to free it.
    Note: Use a freshly allocated string instead.

    Let txt be MD.md_text(title1)
    T.assert_equal(results, "text kind", MD.md_kind(txt), 1)

    Let hb be MD.md_hard_line_break()
    T.assert_equal(results, "hard break kind", MD.md_kind(hb), 7)
    MD.md_inline_destroy(hb)

    Let sb_node be MD.md_soft_line_break()
    T.assert_equal(results, "soft break kind", MD.md_kind(sb_node), 8)
    MD.md_inline_destroy(sb_node)

    Let task_unchecked be MD.md_task(0)
    T.assert_equal(results, "task unchecked", MD.md_secondary(task_unchecked), 0)
    MD.md_inline_destroy(task_unchecked)
    Let task_checked be MD.md_task(1)
    T.assert_equal(results, "task checked", MD.md_secondary(task_checked), 1)
    MD.md_inline_destroy(task_checked)
    Return 1
End Process

Process called "test_parse_atx_heading" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.markdown.parse_atx_heading")
    Let src be "# Hello World"
    Let blocks be MD.markdown_parse(src)
    T.assert_not_null(results, "parse returned blocks", blocks)
    T.assert_equal(results, "one block", List.list_length(blocks), 1)
    Let b0 be List.list_get(blocks, 0)
    T.assert_equal(results, "block is ATX heading", MD.md_kind(b0), 2)
    T.assert_equal(results, "level 1", MD.md_secondary(b0), 1)
    MD.md_block_list_destroy(blocks)
    Return 1
End Process

Process called "test_parse_thematic_break" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.markdown.parse_thematic_break")
    Let src be "---"
    Let blocks be MD.markdown_parse(src)
    T.assert_equal(results, "one block", List.list_length(blocks), 1)
    Let b0 be List.list_get(blocks, 0)
    T.assert_equal(results, "thematic break", MD.md_kind(b0), 1)
    MD.md_block_list_destroy(blocks)

    Let src2 be "***"
    Let blocks2 be MD.markdown_parse(src2)
    T.assert_equal(results, "stars one block", List.list_length(blocks2), 1)
    Let b1 be List.list_get(blocks2, 0)
    T.assert_equal(results, "stars are thematic", MD.md_kind(b1), 1)
    MD.md_block_list_destroy(blocks2)
    Return 1
End Process

Process called "test_parse_paragraph" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.markdown.parse_paragraph")
    Let src be "Just a paragraph."
    Let blocks be MD.markdown_parse(src)
    T.assert_equal(results, "one block", List.list_length(blocks), 1)
    Let b0 be List.list_get(blocks, 0)
    T.assert_equal(results, "paragraph kind", MD.md_kind(b0), 8)
    T.assert_not_null(results, "paragraph has inlines", MD.md_children(b0))
    MD.md_block_list_destroy(blocks)
    Return 1
End Process

Process called "test_parse_fenced_code" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.markdown.parse_fenced_code")
    Let src be "```\nhello\n```"
    Let blocks be MD.markdown_parse(src)
    T.assert_greater_than(results, "at least one block", List.list_length(blocks), 0)
    Let b0 be List.list_get(blocks, 0)
    T.assert_equal(results, "fenced code kind", MD.md_kind(b0), 5)
    MD.md_block_list_destroy(blocks)
    Return 1
End Process

Process called "test_parse_blockquote" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.markdown.parse_blockquote")
    Let src be "> quoted\n> text"
    Let blocks be MD.markdown_parse(src)
    T.assert_greater_than(results, "at least one block", List.list_length(blocks), 0)
    Let b0 be List.list_get(blocks, 0)
    T.assert_equal(results, "block quote kind", MD.md_kind(b0), 10)
    MD.md_block_list_destroy(blocks)
    Return 1
End Process

Process called "test_parse_inlines_emphasis" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.markdown.inline_emphasis")
    Let src be "*em*"
    Let il be MD.markdown_parse_inlines(src)
    T.assert_not_null(results, "inline list", il)
    T.assert_greater_than(results, "non-empty", List.list_length(il), 0)
    Note: Find emphasis node.
    Let count be List.list_length(il)
    Let found be 0
    Let i be 0
    While i is less than count:
        Let n be List.list_get(il, i)
        If MD.md_kind(n) is equal to 2:
            Set found to 1
            T.assert_equal(results, "em strength 1", MD.md_secondary(n), 1)
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "emphasis found", found, 1)
    Let j be 0
    While j is less than count:
        Let nn be List.list_get(il, j)
        MD.md_inline_destroy(nn)
        Set j to j plus 1
    End While
    List.list_destroy(il)
    Return 1
End Process

Process called "test_render_html_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.markdown.render_html")
    Let src be "# Hi"
    Let blocks be MD.markdown_parse(src)
    Let html be MD.markdown_render_html(blocks)
    T.assert_not_null(results, "html result", html)
    MD.md_block_list_destroy(blocks)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_constructors(results)
    test_parse_atx_heading(results)
    test_parse_thematic_break(results)
    test_parse_paragraph(results)
    test_parse_fenced_code(results)
    test_parse_blockquote(results)
    test_parse_inlines_emphasis(results)
    test_render_html_basic(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
