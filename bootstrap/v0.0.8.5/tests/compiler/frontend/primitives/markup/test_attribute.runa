Note:
KAT - markup/attribute.runa typed-value parsing, validation, normalization.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/markup/attribute.runa" as Attr
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_typed_value_construct" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.attribute.typed_value")
    Let v be Attr.typed_value_create(2, 42, 0)
    T.assert_not_null(results, "create", v)
    T.assert_equal(results, "type tag", Attr.typed_value_get_type(v), 2)
    T.assert_equal(results, "payload", Attr.typed_value_get_payload(v), 42)
    Attr.typed_value_destroy(v)
    Return 1
End Process

Process called "test_parse_integer" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.attribute.parse_integer")
    Let v be Attr.attribute_parse("42", 2)
    T.assert_not_null(results, "parse 42", v)
    T.assert_equal(results, "type is INTEGER", Attr.typed_value_get_type(v), 2)
    T.assert_equal(results, "value is 42", Attr.typed_value_get_payload(v), 42)
    Attr.typed_value_destroy(v)
    Let bad be Attr.attribute_parse("abc", 2)
    T.assert_equal(results, "non-numeric returns 0", bad, 0)
    Return 1
End Process

Process called "test_parse_color_hex" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.attribute.parse_color_hex")
    Let v be Attr.attribute_parse("#ff0000", 5)
    T.assert_not_null(results, "parse #ff0000", v)
    T.assert_equal(results, "type is COLOR", Attr.typed_value_get_type(v), 5)
    T.assert_equal(results, "color space is HEX", Attr.typed_value_get_unit(v), 2)
    Let r be Attr.typed_value_color_get_r(v)
    Let g be Attr.typed_value_color_get_g(v)
    Let b be Attr.typed_value_color_get_b(v)
    Let a be Attr.typed_value_color_get_a(v)
    Let r_ok be 0
    If r is greater than 0.999:
        Set r_ok to 1
    End If
    T.assert_equal(results, "r ~ 1.0", r_ok, 1)
    Let g_ok be 0
    If g is less than 0.001:
        Set g_ok to 1
    End If
    T.assert_equal(results, "g ~ 0.0", g_ok, 1)
    Let b_ok be 0
    If b is less than 0.001:
        Set b_ok to 1
    End If
    T.assert_equal(results, "b ~ 0.0", b_ok, 1)
    Let a_ok be 0
    If a is greater than 0.999:
        Set a_ok to 1
    End If
    T.assert_equal(results, "a ~ 1.0", a_ok, 1)
    Attr.typed_value_destroy(v)
    Let v2 be Attr.attribute_parse("#abc", 5)
    T.assert_not_null(results, "parse #abc (3-digit hex)", v2)
    Attr.typed_value_destroy(v2)
    Let v3 be Attr.attribute_parse("#00ff0080", 5)
    T.assert_not_null(results, "parse #00ff0080 (8-digit hex with alpha)", v3)
    Let a3 be Attr.typed_value_color_get_a(v3)
    Let a3_ok be 0
    If a3 is greater than 0.49:
        If a3 is less than 0.51:
            Set a3_ok to 1
        End If
    End If
    T.assert_equal(results, "alpha ~ 0.5", a3_ok, 1)
    Attr.typed_value_destroy(v3)
    Return 1
End Process

Process called "test_parse_color_rgb" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.attribute.parse_color_rgb")
    Let v be Attr.attribute_parse("rgb(255,0,0)", 5)
    T.assert_not_null(results, "parse rgb()", v)
    T.assert_equal(results, "color space is RGB", Attr.typed_value_get_unit(v), 3)
    Let r be Attr.typed_value_color_get_r(v)
    Let r_ok be 0
    If r is greater than 0.999:
        Set r_ok to 1
    End If
    T.assert_equal(results, "r ~ 1.0", r_ok, 1)
    Attr.typed_value_destroy(v)
    Let v2 be Attr.attribute_parse("rgba(255, 0, 0, 0.5)", 5)
    T.assert_not_null(results, "parse rgba()", v2)
    T.assert_equal(results, "color space is RGBA", Attr.typed_value_get_unit(v2), 4)
    Let a be Attr.typed_value_color_get_a(v2)
    Let a_ok be 0
    If a is greater than 0.49:
        If a is less than 0.51:
            Set a_ok to 1
        End If
    End If
    T.assert_equal(results, "alpha ~ 0.5", a_ok, 1)
    Attr.typed_value_destroy(v2)
    Return 1
End Process

Process called "test_parse_url" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.attribute.parse_url")
    Let v be Attr.attribute_parse("https://example.com", 4)
    T.assert_not_null(results, "valid URL", v)
    Attr.typed_value_destroy(v)
    Let bad be Attr.attribute_parse("has spaces", 4)
    T.assert_equal(results, "URL with whitespace rejected", bad, 0)
    Return 1
End Process

Process called "test_parse_length_px" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.attribute.parse_length_px")
    Let v be Attr.attribute_parse("12px", 6)
    T.assert_not_null(results, "parse 12px", v)
    T.assert_equal(results, "type is LENGTH", Attr.typed_value_get_type(v), 6)
    T.assert_equal(results, "unit is PX", Attr.typed_value_get_unit(v), 1)
    T.assert_equal(results, "payload is 12", Attr.typed_value_get_payload(v), 12)
    Attr.typed_value_destroy(v)
    Return 1
End Process

Process called "test_normalize_whitespace" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.attribute.normalize_whitespace")
    Let norm be Attr.attribute_normalize_whitespace("  hello   world  ")
    T.assert_not_null(results, "normalize returns string", norm)
    Let expected be "hello world"
    Let eq be StringCore.string_equals(norm, expected)
    T.assert_equal(results, "normalized correctly", eq, 1)
    Return 1
End Process

Process called "test_validate_schema" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.attribute.validate_schema")
    Let schemas be List.list_create()
    Let s be Attr.schema_create("count", 2, 0, 0)
    List.list_push(schemas, s)
    Let ok be Attr.attribute_validate("count", "42", schemas)
    T.assert_equal(results, "valid integer accepts", ok, 0)
    Let bad be Attr.attribute_validate("count", "abc", schemas)
    T.assert_equal(results, "invalid integer rejects", bad, -2)
    Let unknown be Attr.attribute_validate("unknown_attr", "anything", schemas)
    T.assert_equal(results, "unknown attribute passes", unknown, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_typed_value_construct(results)
    test_parse_integer(results)
    test_parse_color_hex(results)
    test_parse_color_rgb(results)
    test_parse_url(results)
    test_parse_length_px(results)
    test_normalize_whitespace(results)
    test_validate_schema(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
