Note:
KAT - markup/element.runa.

Exercises the substrate node primitives: Attribute construction and
field access, MarkupNode tagging and kind discrimination, Element
construction with attribute and child mutation, document tree assembly
with prologue/epilogue, and full subtree destruction.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/markup/element.runa" as Elem

Process called "test_attribute_basics" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.attribute_basics")

    Let name be "id"
    Let value be "main"
    Let ns be 0
    Let attr be Elem.attribute_create(name, value, ns)
    T.assert_not_null(results, "attribute_create", attr)
    T.assert_equal(results, "attribute_get_name", Elem.attribute_get_name(attr), name)
    T.assert_equal(results, "attribute_get_value", Elem.attribute_get_value(attr), value)
    T.assert_equal(results, "attribute_get_namespace null", Elem.attribute_get_namespace(attr), 0)
    Elem.attribute_destroy(attr)
    T.assert_equal(results, "attribute_destroy(0) safe", Elem.attribute_destroy(0), 0)
    Return 1
End Process

Process called "test_markup_node_kinds" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.node_kinds")

    Let text_payload be "hello"
    Let text_node be Elem.markup_node_create_text(text_payload)
    T.assert_equal(results, "text node kind", Elem.markup_node_get_kind(text_node), 3)
    T.assert_equal(results, "is_text true", Elem.markup_node_is_text(text_node), 1)
    T.assert_equal(results, "is_element false", Elem.markup_node_is_element(text_node), 0)
    T.assert_equal(results, "text payload", Elem.markup_node_get_payload(text_node), text_payload)
    Elem.markup_node_destroy(text_node)

    Let comment_payload be "TODO"
    Let comment_node be Elem.markup_node_create_comment(comment_payload)
    T.assert_equal(results, "comment kind", Elem.markup_node_get_kind(comment_node), 8)
    Elem.markup_node_destroy(comment_node)

    Let cdata_payload be "<![CDATA[raw]]>"
    Let cdata_node be Elem.markup_node_create_cdata(cdata_payload)
    T.assert_equal(results, "cdata kind", Elem.markup_node_get_kind(cdata_node), 4)
    Elem.markup_node_destroy(cdata_node)

    Let ent_name be "amp"
    Let ent_node be Elem.markup_node_create_entity_reference(ent_name)
    T.assert_equal(results, "entity-ref kind", Elem.markup_node_get_kind(ent_node), 5)
    Elem.markup_node_destroy(ent_node)

    T.assert_equal(results, "null node kind safe", Elem.markup_node_get_kind(0), 0)
    Return 1
End Process

Process called "test_element_create_and_accessors" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.element_basics")

    Let tag be "div"
    Let ns be 0
    Let elem be Elem.element_create(tag, ns)
    T.assert_not_null(results, "element_create", elem)
    T.assert_equal(results, "tag accessor", Elem.element_get_tag_name(elem), tag)
    T.assert_equal(results, "namespace null", Elem.element_get_namespace(elem), 0)
    T.assert_equal(results, "self_closing initially 0", Elem.element_is_self_closing(elem), 0)
    T.assert_equal(results, "attribute_count initially 0", Elem.element_attribute_count(elem), 0)
    T.assert_equal(results, "child_count initially 0", Elem.element_child_count(elem), 0)

    Elem.element_set_self_closing(elem)
    T.assert_equal(results, "self_closing after set", Elem.element_is_self_closing(elem), 1)

    Elem.element_set_source_position(elem, 42, 7)
    T.assert_equal(results, "source line", Elem.element_get_source_line(elem), 42)
    T.assert_equal(results, "source column", Elem.element_get_source_column(elem), 7)

    Elem.element_destroy(elem)
    Return 1
End Process

Process called "test_element_attributes" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.attributes")

    Let tag be "input"
    Let elem be Elem.element_create(tag, 0)
    Let id_name be "id"
    Let id_value be "username"
    Let attr1 be Elem.attribute_create(id_name, id_value, 0)
    Elem.element_append_attribute(elem, attr1)

    Let type_name be "type"
    Let type_value be "text"
    Let attr2 be Elem.attribute_create(type_name, type_value, 0)
    Elem.element_append_attribute(elem, attr2)

    T.assert_equal(results, "attribute_count after 2 appends", Elem.element_attribute_count(elem), 2)
    T.assert_equal(results, "has_attribute id", Elem.element_has_attribute(elem, id_name), 1)
    T.assert_equal(results, "has_attribute type", Elem.element_has_attribute(elem, type_name), 1)
    T.assert_equal(results, "has_attribute missing", Elem.element_has_attribute(elem, "missing"), 0)
    T.assert_equal(results, "get_attribute id value", Elem.element_get_attribute(elem, id_name), id_value)
    T.assert_equal(results, "get_attribute type value", Elem.element_get_attribute(elem, type_name), type_value)
    T.assert_equal(results, "get_attribute missing", Elem.element_get_attribute(elem, "missing"), 0)
    T.assert_equal(results, "get_attribute_at 0", Elem.element_get_attribute_at(elem, 0), attr1)
    T.assert_equal(results, "get_attribute_at 1", Elem.element_get_attribute_at(elem, 1), attr2)
    T.assert_equal(results, "get_attribute_at oob", Elem.element_get_attribute_at(elem, 5), 0)
    T.assert_equal(results, "get_attribute_at negative", Elem.element_get_attribute_at(elem, -1), 0)

    Elem.element_destroy(elem)
    Return 1
End Process

Process called "test_element_children" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.children")

    Let tag be "ul"
    Let parent be Elem.element_create(tag, 0)

    Let li_tag be "li"
    Let child1 be Elem.element_create(li_tag, 0)
    Let child2 be Elem.element_create(li_tag, 0)
    Let n1 be Elem.markup_node_create_element(child1)
    Let n2 be Elem.markup_node_create_element(child2)
    Elem.element_append_child(parent, n1)
    Elem.element_append_child(parent, n2)
    T.assert_equal(results, "child_count 2", Elem.element_child_count(parent), 2)
    T.assert_equal(results, "get_child 0", Elem.element_get_child(parent, 0), n1)
    T.assert_equal(results, "get_child 1", Elem.element_get_child(parent, 1), n2)
    T.assert_equal(results, "get_child oob", Elem.element_get_child(parent, 99), 0)
    T.assert_equal(results, "get_child negative", Elem.element_get_child(parent, -1), 0)
    T.assert_equal(results, "child 0 is element", Elem.markup_node_is_element(n1), 1)

    Elem.element_destroy(parent)
    Return 1
End Process

Process called "test_document_tree" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.document")

    Let html_tag be "html"
    Let root be Elem.element_create(html_tag, 0)
    Let doctype be "<!DOCTYPE html>"
    Let doc be Elem.document_create(doctype, root)
    T.assert_not_null(results, "document_create", doc)
    T.assert_equal(results, "document_get_doctype", Elem.document_get_doctype(doc), doctype)
    T.assert_equal(results, "document_get_root", Elem.document_get_root(doc), root)
    T.assert_not_null(results, "document_get_prologue", Elem.document_get_prologue(doc))
    T.assert_not_null(results, "document_get_epilogue", Elem.document_get_epilogue(doc))

    Let comment_text be "pre-root"
    Let comment_node be Elem.markup_node_create_comment(comment_text)
    Elem.document_append_prologue_node(doc, comment_node)

    Let post_text be "post-root"
    Let post_node be Elem.markup_node_create_comment(post_text)
    Elem.document_append_epilogue_node(doc, post_node)

    Elem.document_destroy(doc)
    T.assert_equal(results, "destroy(0) safe", Elem.document_destroy(0), 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_attribute_basics(results)
    test_markup_node_kinds(results)
    test_element_create_and_accessors(results)
    test_element_attributes(results)
    test_element_children(results)
    test_document_tree(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
