Note:
KAT - markup/rml.runa parser, serializer, validator.
Round-trip test on a 50-line sample document.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/markup/element.runa" as Elem
Import "compiler/frontend/primitives/markup/rml.runa" as RML
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_parse_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.rml.parse_basic")
    Let source be "Element called \"p\":\nText \"hi\"\nEnd Element"
    Let root be RML.rml_parse(source)
    T.assert_not_null(results, "parse returns root", root)
    Let tag be Elem.element_get_tag_name(root)
    Let eq be StringCore.string_equals(tag, "p")
    T.assert_equal(results, "tag is p", eq, 1)
    T.assert_equal(results, "has one child", Elem.element_child_count(root), 1)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_parse_attrs" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.rml.parse_attrs")
    Let source be "Element called \"section\" with id as \"intro\", class as \"main\":\nEnd Element"
    Let root be RML.rml_parse(source)
    T.assert_not_null(results, "parse returns root", root)
    T.assert_equal(results, "has 2 attributes", Elem.element_attribute_count(root), 2)
    Let id_val be Elem.element_get_attribute(root, "id")
    Let eq be StringCore.string_equals(id_val, "intro")
    T.assert_equal(results, "id is intro", eq, 1)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_parse_nested" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.rml.parse_nested")
    Let source be "Element called \"div\":\nElement called \"p\":\nText \"hello\"\nEnd Element\nElement called \"p\":\nText \"world\"\nEnd Element\nEnd Element"
    Let root be RML.rml_parse(source)
    T.assert_not_null(results, "parse returns root", root)
    T.assert_equal(results, "root has 2 children", Elem.element_child_count(root), 2)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_serialize_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.rml.serialize_roundtrip")
    Let source be "Element called \"section\" with id as \"intro\":\n    Element called \"h1\":\n        Text \"Welcome\"\n    End Element\n    Element called \"p\" with class as \"lede\":\n        Text \"Hello world\"\n    End Element\nEnd Element"
    Let root1 be RML.rml_parse(source)
    T.assert_not_null(results, "first parse", root1)
    Let serialized be RML.rml_serialize(root1)
    T.assert_not_null(results, "serialize returns non-null", serialized)
    Let root2 be RML.rml_parse(serialized)
    T.assert_not_null(results, "second parse of serialized form", root2)
    Let serialized2 be RML.rml_serialize(root2)
    Let eq be StringCore.string_equals(serialized, serialized2)
    T.assert_equal(results, "second serialization matches first", eq, 1)
    Elem.element_destroy(root1)
    Elem.element_destroy(root2)
    Return 1
End Process

Process called "test_validate_well_formed" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.rml.validate")
    Let source be "Element called \"p\":\nText \"hi\"\nEnd Element"
    Let root be RML.rml_parse(source)
    Let issues be RML.rml_validate_well_formed(root)
    T.assert_not_null(results, "issues list non-null", issues)
    T.assert_equal(results, "no issues for valid tree", List.list_length(issues), 0)
    RML.rml_issues_destroy(issues)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_parse_basic(results)
    test_parse_attrs(results)
    test_parse_nested(results)
    test_serialize_roundtrip(results)
    test_validate_well_formed(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
