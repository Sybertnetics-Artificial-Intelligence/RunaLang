Note:
KAT - markup/element.runa traversal, query, serialization, and clone
operations (the extended API beyond constructors/accessors which are
covered by test_element.runa).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/markup/element.runa" as Elem
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "build_sample_tree" returns Integer:
    Note: Builds <root><div id="main"><p>text</p><p class="lede">other</p></div><div>second</div></root>
    Let root be Elem.element_create("root", 0)
    Let div1 be Elem.element_create("div", 0)
    Let id_attr be Elem.attribute_create("id", "main", 0)
    Elem.element_append_attribute(div1, id_attr)
    Let p1 be Elem.element_create("p", 0)
    Let p2 be Elem.element_create("p", 0)
    Let class_attr be Elem.attribute_create("class", "lede", 0)
    Elem.element_append_attribute(p2, class_attr)
    Elem.element_append_child(div1, Elem.markup_node_create_element(p1))
    Elem.element_append_child(div1, Elem.markup_node_create_element(p2))
    Let div2 be Elem.element_create("div", 0)
    Elem.element_append_child(root, Elem.markup_node_create_element(div1))
    Elem.element_append_child(root, Elem.markup_node_create_element(div2))
    Return root
End Process

Process called "test_element_walk" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.walk")
    Let root be build_sample_tree()
    Let out be List.list_create()
    T.assert_not_null(results, "list_create", out)
    Elem.element_walk(root, out)
    Note: Tree should have root + 2 divs + 2 ps = 5 elements
    T.assert_equal(results, "walk visits all elements", List.list_length(out), 5)
    Let first be List.list_get(out, 0)
    T.assert_equal(results, "first visited is root", first, root)
    List.list_destroy(out)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_find_by_tag" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.find_by_tag")
    Let root be build_sample_tree()
    Let p_results be Elem.element_find_by_tag(root, "p")
    T.assert_not_null(results, "find_by_tag returns list", p_results)
    T.assert_equal(results, "found 2 p elements", List.list_length(p_results), 2)
    Let div_results be Elem.element_find_by_tag(root, "div")
    T.assert_equal(results, "found 2 div elements", List.list_length(div_results), 2)
    Let none be Elem.element_find_by_tag(root, "span")
    T.assert_equal(results, "found 0 span elements", List.list_length(none), 0)
    List.list_destroy(p_results)
    List.list_destroy(div_results)
    List.list_destroy(none)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_find_by_id" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.find_by_id")
    Let root be build_sample_tree()
    Let found be Elem.element_find_by_id(root, "main")
    T.assert_not_null(results, "find_by_id finds main", found)
    Let tag be Elem.element_get_tag_name(found)
    Let is_div be StringCore.string_equals(tag, "div")
    T.assert_equal(results, "found is div", is_div, 1)
    Let not_found be Elem.element_find_by_id(root, "nonexistent")
    T.assert_equal(results, "not_found is 0", not_found, 0)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_element_to_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.to_string")
    Let root be Elem.element_create("p", 0)
    Let attr be Elem.attribute_create("id", "x", 0)
    Elem.element_append_attribute(root, attr)
    Let text_node be Elem.markup_node_create_text("hello")
    Elem.element_append_child(root, text_node)
    Let serialized be Elem.element_to_string(root, 0)
    T.assert_not_null(results, "to_string returns non-null", serialized)
    Let len be StringCore.string_length(serialized)
    T.assert_greater_than(results, "serialized non-empty", len, 0)
    Elem.element_destroy(root)
    Return 1
End Process

Process called "test_element_clone" that takes results as Integer returns Integer:
    T.begin_suite(results, "markup.element.clone")
    Let original be build_sample_tree()
    Let clone be Elem.element_clone(original)
    T.assert_not_null(results, "clone returns non-null", clone)
    T.assert_not_equal(results, "clone is distinct pointer", clone, original)
    Let orig_tag be Elem.element_get_tag_name(original)
    Let clone_tag be Elem.element_get_tag_name(clone)
    T.assert_equal(results, "tag name shared", orig_tag, clone_tag)
    Let clone_walk be List.list_create()
    Elem.element_walk(clone, clone_walk)
    T.assert_equal(results, "clone has same element count", List.list_length(clone_walk), 5)
    List.list_destroy(clone_walk)
    Elem.element_destroy(clone)
    Elem.element_destroy(original)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_element_walk(results)
    test_find_by_tag(results)
    test_find_by_id(results)
    test_element_to_string(results)
    test_element_clone(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
