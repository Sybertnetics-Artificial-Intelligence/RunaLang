Note:
Unit tests for compiler/frontend/primitives/text/codepoint.runa.
Covers: validity, classification, UTF-8 round-trip including 4-byte
sequences (e.g., U+1F680 ROCKET = F0 9F 9A 80).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/text/codepoint.runa" as C
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Process called "test_codepoint_validity" that takes results as Integer returns Integer:
    T.begin_suite(results, "codepoint.validity")
    T.assert_equal(results, "U+0000 valid", C.codepoint_is_valid(0), 1)
    T.assert_equal(results, "U+0041 valid", C.codepoint_is_valid(65), 1)
    T.assert_equal(results, "U+D7FF valid", C.codepoint_is_valid(55295), 1)
    T.assert_equal(results, "U+D800 surrogate invalid", C.codepoint_is_valid(55296), 0)
    T.assert_equal(results, "U+DFFF surrogate invalid", C.codepoint_is_valid(57343), 0)
    T.assert_equal(results, "U+E000 valid", C.codepoint_is_valid(57344), 1)
    T.assert_equal(results, "U+10FFFF valid", C.codepoint_is_valid(1114111), 1)
    T.assert_equal(results, "U+110000 invalid", C.codepoint_is_valid(1114112), 0)
    T.assert_equal(results, "negative invalid", C.codepoint_is_valid(-1), 0)
    Return 1
End Process

Process called "test_codepoint_classification" that takes results as Integer returns Integer:
    T.begin_suite(results, "codepoint.classification")
    T.assert_equal(results, "'a' is letter", C.codepoint_is_letter(97), 1)
    T.assert_equal(results, "'A' is letter", C.codepoint_is_letter(65), 1)
    T.assert_equal(results, "'5' is not letter", C.codepoint_is_letter(53), 0)
    T.assert_equal(results, "'5' is digit", C.codepoint_is_digit(53), 1)
    T.assert_equal(results, "'A' is uppercase", C.codepoint_is_uppercase(65), 1)
    T.assert_equal(results, "'a' is lowercase", C.codepoint_is_lowercase(97), 1)
    T.assert_equal(results, "space is whitespace", C.codepoint_is_whitespace(32), 1)
    T.assert_equal(results, "tab is whitespace", C.codepoint_is_whitespace(9), 1)
    T.assert_equal(results, "NBSP is whitespace", C.codepoint_is_whitespace(160), 1)
    T.assert_equal(results, "'!' is punctuation", C.codepoint_is_punctuation(33), 1)
    T.assert_equal(results, "DEL is control", C.codepoint_is_control(127), 1)
    T.assert_equal(results, "'+' is symbol", C.codepoint_is_symbol(43), 1)
    T.assert_equal(results, "U+1F680 ROCKET is emoji", C.codepoint_is_emoji(128640), 1)
    T.assert_equal(results, "'a' is ASCII", C.codepoint_is_ascii(97), 1)
    T.assert_equal(results, "U+0100 not ASCII", C.codepoint_is_ascii(256), 0)
    Return 1
End Process

Process called "test_codepoint_case" that takes results as Integer returns Integer:
    T.begin_suite(results, "codepoint.case")
    T.assert_equal(results, "'a' -> 'A'", C.codepoint_to_upper(97), 65)
    T.assert_equal(results, "'A' -> 'A'", C.codepoint_to_upper(65), 65)
    T.assert_equal(results, "'A' -> 'a'", C.codepoint_to_lower(65), 97)
    T.assert_equal(results, "'5' unchanged upper", C.codepoint_to_upper(53), 53)
    T.assert_equal(results, "Latin a-grave -> A-grave", C.codepoint_to_upper(224), 192)
    Return 1
End Process

Process called "test_codepoint_utf8_roundtrip_1byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "codepoint.utf8_1byte")
    Let buf be allocate(4)
    Memory.memory_fill(buf, 0, 4)
    Let len be C.codepoint_to_utf8_bytes(65, buf, 0)
    T.assert_equal(results, "encode 'A' len=1", len, 1)
    T.assert_equal(results, "byte=0x41", Memory.memory_get_byte(buf, 0), 65)
    Let packed be C.codepoint_from_utf8_bytes(buf, 0, 1)
    T.assert_equal(results, "decode len=1", C.codepoint_decode_length(packed), 1)
    T.assert_equal(results, "decode cp=65", C.codepoint_decode_value(packed), 65)
    deallocate(buf)
    Return 1
End Process

Process called "test_codepoint_utf8_roundtrip_2byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "codepoint.utf8_2byte")
    Note: U+00E9 (e-acute) = C3 A9
    Let buf be allocate(4)
    Memory.memory_fill(buf, 0, 4)
    Let len be C.codepoint_to_utf8_bytes(233, buf, 0)
    T.assert_equal(results, "encode U+00E9 len=2", len, 2)
    T.assert_equal(results, "byte0=0xC3", Memory.memory_get_byte(buf, 0), 195)
    T.assert_equal(results, "byte1=0xA9", Memory.memory_get_byte(buf, 1), 169)
    Let packed be C.codepoint_from_utf8_bytes(buf, 0, 2)
    T.assert_equal(results, "decode len=2", C.codepoint_decode_length(packed), 2)
    T.assert_equal(results, "decode cp=233", C.codepoint_decode_value(packed), 233)
    deallocate(buf)
    Return 1
End Process

Process called "test_codepoint_utf8_roundtrip_3byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "codepoint.utf8_3byte")
    Note: U+20AC EURO SIGN = E2 82 AC
    Let buf be allocate(4)
    Memory.memory_fill(buf, 0, 4)
    Let len be C.codepoint_to_utf8_bytes(8364, buf, 0)
    T.assert_equal(results, "encode U+20AC len=3", len, 3)
    T.assert_equal(results, "byte0=0xE2", Memory.memory_get_byte(buf, 0), 226)
    T.assert_equal(results, "byte1=0x82", Memory.memory_get_byte(buf, 1), 130)
    T.assert_equal(results, "byte2=0xAC", Memory.memory_get_byte(buf, 2), 172)
    Let packed be C.codepoint_from_utf8_bytes(buf, 0, 3)
    T.assert_equal(results, "decode len=3", C.codepoint_decode_length(packed), 3)
    T.assert_equal(results, "decode cp=8364", C.codepoint_decode_value(packed), 8364)
    deallocate(buf)
    Return 1
End Process

Process called "test_codepoint_utf8_roundtrip_4byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "codepoint.utf8_4byte")
    Note: U+1F680 ROCKET = F0 9F 9A 80
    Let buf be allocate(8)
    Memory.memory_fill(buf, 0, 8)
    Let len be C.codepoint_to_utf8_bytes(128640, buf, 0)
    T.assert_equal(results, "encode U+1F680 len=4", len, 4)
    T.assert_equal(results, "byte0=0xF0", Memory.memory_get_byte(buf, 0), 240)
    T.assert_equal(results, "byte1=0x9F", Memory.memory_get_byte(buf, 1), 159)
    T.assert_equal(results, "byte2=0x9A", Memory.memory_get_byte(buf, 2), 154)
    T.assert_equal(results, "byte3=0x80", Memory.memory_get_byte(buf, 3), 128)
    Let packed be C.codepoint_from_utf8_bytes(buf, 0, 4)
    T.assert_equal(results, "decode len=4", C.codepoint_decode_length(packed), 4)
    T.assert_equal(results, "decode cp=128640", C.codepoint_decode_value(packed), 128640)
    deallocate(buf)
    Return 1
End Process

Process called "test_codepoint_invalid_utf8" that takes results as Integer returns Integer:
    T.begin_suite(results, "codepoint.invalid_utf8")
    Let buf be allocate(4)
    Memory.memory_fill(buf, 0, 4)
    Note: 0xC0 0x80 is an overlong encoding of U+0000 - must be rejected
    Memory.memory_set_byte(buf, 0, 192)
    Memory.memory_set_byte(buf, 1, 128)
    Let packed be C.codepoint_from_utf8_bytes(buf, 0, 2)
    T.assert_equal(results, "overlong rejected", packed, -1)

    Note: 0xED 0xA0 0x80 is U+D800 surrogate - must be rejected
    Memory.memory_set_byte(buf, 0, 237)
    Memory.memory_set_byte(buf, 1, 160)
    Memory.memory_set_byte(buf, 2, 128)
    Let packed2 be C.codepoint_from_utf8_bytes(buf, 0, 3)
    T.assert_equal(results, "surrogate rejected", packed2, -1)

    deallocate(buf)
    Return 1
End Process

Process called "test_codepoint_block" that takes results as Integer returns Integer:
    T.begin_suite(results, "codepoint.block")
    T.assert_equal(results, "ASCII block", C.codepoint_block(65), 0)
    T.assert_equal(results, "Latin-1 Supplement block", C.codepoint_block(200), 1)
    T.assert_equal(results, "Greek block", C.codepoint_block(945), 4)
    T.assert_equal(results, "Hiragana block", C.codepoint_block(12400), 10)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_codepoint_validity(results)
    test_codepoint_classification(results)
    test_codepoint_case(results)
    test_codepoint_utf8_roundtrip_1byte(results)
    test_codepoint_utf8_roundtrip_2byte(results)
    test_codepoint_utf8_roundtrip_3byte(results)
    test_codepoint_utf8_roundtrip_4byte(results)
    test_codepoint_invalid_utf8(results)
    test_codepoint_block(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
