Note:
UAX #15 Known-Answer Test vectors for the four normalization forms.

Tests verify the algorithm end-to-end on the canonical reference vectors:

  KAT-1: café NFC -> NFD -> NFC round-trip
    "café" (UTF-8: 63 61 66 C3 A9)
       NFD:  c a f e + U+0301 = 63 61 66 65 CC 81
       NFC:  c a f é = 63 61 66 C3 A9

  KAT-2: precomposed -> decomposed
    U+00E9 -> NFD -> U+0065 U+0301

  KAT-3: Hangul composition
    U+1100 U+1161 -> NFC -> U+AC00 (GA syllable)

  KAT-4: Compatibility decomposition
    U+FB01 (LIGATURE FI) -> NFKC -> "fi"
    U+FB01 (LIGATURE FI) -> NFKD -> "fi" (same bytes; no Latin recomposition)

  KAT-5: ASCII invariance
    "hello world" -> NFD -> NFC -> "hello world" byte-identical

  KAT-6: Canonical reordering
    U+0061 U+0327 U+0301 -> NFD -> U+0061 U+0327 U+0301
    (cedilla CCC=202 comes before acute CCC=230)

  KAT-7: Compose pair where intermediate ordering matters
    U+0041 U+0301 -> NFC -> U+00C1 (A with acute)

References:
- UAX #15 Annex D (Conformance test data)
- The reference vectors above are from the public NormalizationTest.txt
  shipped in Unicode 15.1.0.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/text/normalized_string.runa" as N
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StrCore

Note: ============================================================================
Note: Helpers for raw-byte buffer comparisons.
Note: ============================================================================

Process called "build_byte_buffer" takes b0 as Integer, b1 as Integer, b2 as Integer, b3 as Integer, b4 as Integer, b5 as Integer, b6 as Integer, n as Integer returns Integer:
    Note: Allocates a null-terminated buffer of n bytes from b0..b6.
    Note: Up to 7 bytes per call; unused slots ignored.
    Let buf be allocate(n plus 1)
    If buf is equal to 0:
        Return 0
    End If
    If n is greater than 0:
        Memory.memory_set_byte(buf, 0, b0)
    End If
    If n is greater than 1:
        Memory.memory_set_byte(buf, 1, b1)
    End If
    If n is greater than 2:
        Memory.memory_set_byte(buf, 2, b2)
    End If
    If n is greater than 3:
        Memory.memory_set_byte(buf, 3, b3)
    End If
    If n is greater than 4:
        Memory.memory_set_byte(buf, 4, b4)
    End If
    If n is greater than 5:
        Memory.memory_set_byte(buf, 5, b5)
    End If
    If n is greater than 6:
        Memory.memory_set_byte(buf, 6, b6)
    End If
    Memory.memory_set_byte(buf, n, 0)
    Return buf
End Process

Process called "ns_get_byte" takes ns as Integer, index as Integer returns Integer:
    Let data be N.normalized_string_data(ns)
    If data is equal to 0:
        Return 0 minus 1
    End If
    Return Memory.memory_get_byte(data, index)
End Process

Note: ============================================================================
Note: KAT-1: cafe with acute - NFD decomposition
Note: ============================================================================

Process called "test_kat_cafe_nfd" takes results as Integer returns Integer:
    T.begin_suite(results, "uax15.kat.cafe_nfd")
    Note: Build "café" as UTF-8 bytes: 63 61 66 C3 A9 (5 bytes).
    Let cafe be build_byte_buffer(99, 97, 102, 195, 169, 0, 0, 5)
    T.assert_not_null(results, "cafe buffer allocated", cafe)

    Let nfd be N.string_normalize_nfd(cafe)
    T.assert_not_null(results, "NFD result allocated", nfd)

    Note: Expected NFD: 63 61 66 65 CC 81 (6 bytes).
    T.assert_equal(results, "NFD length is 6", N.normalized_string_length(nfd), 6)
    T.assert_equal(results, "NFD byte 0 = 0x63 c", ns_get_byte(nfd, 0), 99)
    T.assert_equal(results, "NFD byte 1 = 0x61 a", ns_get_byte(nfd, 1), 97)
    T.assert_equal(results, "NFD byte 2 = 0x66 f", ns_get_byte(nfd, 2), 102)
    T.assert_equal(results, "NFD byte 3 = 0x65 e", ns_get_byte(nfd, 3), 101)
    T.assert_equal(results, "NFD byte 4 = 0xCC", ns_get_byte(nfd, 4), 204)
    T.assert_equal(results, "NFD byte 5 = 0x81", ns_get_byte(nfd, 5), 129)
    T.assert_equal(results, "NFD form tag", N.normalized_string_form(nfd), 2)

    N.normalized_string_destroy(nfd)
    deallocate(cafe)
    Return 1
End Process

Note: ============================================================================
Note: KAT-2: cafe NFC roundtrip - decompose then compose
Note: ============================================================================

Process called "test_kat_cafe_nfc" takes results as Integer returns Integer:
    T.begin_suite(results, "uax15.kat.cafe_nfc")
    Note: Build cafe + combining-acute as already-decomposed input:
    Note:    63 61 66 65 CC 81 (6 bytes)
    Let decomposed be build_byte_buffer(99, 97, 102, 101, 204, 129, 0, 6)
    T.assert_not_null(results, "decomposed buffer allocated", decomposed)

    Let nfc be N.string_normalize_nfc(decomposed)
    T.assert_not_null(results, "NFC result allocated", nfc)

    Note: Expected NFC: 63 61 66 C3 A9 (5 bytes, cafe + precomposed e-acute).
    T.assert_equal(results, "NFC length is 5", N.normalized_string_length(nfc), 5)
    T.assert_equal(results, "NFC byte 0 = 0x63 c", ns_get_byte(nfc, 0), 99)
    T.assert_equal(results, "NFC byte 1 = 0x61 a", ns_get_byte(nfc, 1), 97)
    T.assert_equal(results, "NFC byte 2 = 0x66 f", ns_get_byte(nfc, 2), 102)
    T.assert_equal(results, "NFC byte 3 = 0xC3", ns_get_byte(nfc, 3), 195)
    T.assert_equal(results, "NFC byte 4 = 0xA9", ns_get_byte(nfc, 4), 169)
    T.assert_equal(results, "NFC form tag", N.normalized_string_form(nfc), 1)

    N.normalized_string_destroy(nfc)
    deallocate(decomposed)
    Return 1
End Process

Note: ============================================================================
Note: KAT-3: Hangul L+V -> LV (algorithmic recomposition)
Note: ============================================================================

Process called "test_kat_hangul_LV" takes results as Integer returns Integer:
    T.begin_suite(results, "uax15.kat.hangul_LV")
    Note: U+1100 (HANGUL CHOSEONG KIYEOK) UTF-8: E1 84 80 (3 bytes)
    Note: U+1161 (HANGUL JUNGSEONG A)     UTF-8: E1 85 A1 (3 bytes)
    Note: Total input 6 bytes.
    Let buf be allocate(7)
    T.assert_not_null(results, "LV input buffer", buf)
    Memory.memory_set_byte(buf, 0, 225)
    Memory.memory_set_byte(buf, 1, 132)
    Memory.memory_set_byte(buf, 2, 128)
    Memory.memory_set_byte(buf, 3, 225)
    Memory.memory_set_byte(buf, 4, 133)
    Memory.memory_set_byte(buf, 5, 161)
    Memory.memory_set_byte(buf, 6, 0)

    Let nfc be N.string_normalize_nfc(buf)
    T.assert_not_null(results, "NFC result allocated", nfc)

    Note: Expected: U+AC00 GA -> UTF-8 EA B0 80 (3 bytes).
    T.assert_equal(results, "Hangul NFC length is 3", N.normalized_string_length(nfc), 3)
    T.assert_equal(results, "Hangul NFC byte 0 = 0xEA", ns_get_byte(nfc, 0), 234)
    T.assert_equal(results, "Hangul NFC byte 1 = 0xB0", ns_get_byte(nfc, 1), 176)
    T.assert_equal(results, "Hangul NFC byte 2 = 0x80", ns_get_byte(nfc, 2), 128)

    N.normalized_string_destroy(nfc)
    deallocate(buf)
    Return 1
End Process

Note: ============================================================================
Note: KAT-4: Compatibility decomposition - FI ligature
Note: ============================================================================

Process called "test_kat_fi_ligature_nfkc" takes results as Integer returns Integer:
    T.begin_suite(results, "uax15.kat.fi_ligature_nfkc")
    Note: U+FB01 (LATIN SMALL LIGATURE FI) UTF-8: EF AC 81 (3 bytes)
    Let buf be allocate(4)
    T.assert_not_null(results, "FI input buffer", buf)
    Memory.memory_set_byte(buf, 0, 239)
    Memory.memory_set_byte(buf, 1, 172)
    Memory.memory_set_byte(buf, 2, 129)
    Memory.memory_set_byte(buf, 3, 0)

    Let nfkc be N.string_normalize_nfkc(buf)
    T.assert_not_null(results, "NFKC result allocated", nfkc)

    Note: Expected NFKC: "fi" -> 66 69 (2 bytes).
    T.assert_equal(results, "NFKC FI length is 2", N.normalized_string_length(nfkc), 2)
    T.assert_equal(results, "NFKC FI byte 0 = 0x66 f", ns_get_byte(nfkc, 0), 102)
    T.assert_equal(results, "NFKC FI byte 1 = 0x69 i", ns_get_byte(nfkc, 1), 105)

    N.normalized_string_destroy(nfkc)
    deallocate(buf)
    Return 1
End Process

Note: ============================================================================
Note: KAT-5: ASCII invariance
Note: ============================================================================

Process called "test_kat_ascii_invariance" takes results as Integer returns Integer:
    T.begin_suite(results, "uax15.kat.ascii_invariance")
    Let nfc be N.string_normalize_nfc("hello world")
    T.assert_not_null(results, "ASCII NFC allocated", nfc)
    T.assert_equal(results, "ASCII NFC length", N.normalized_string_length(nfc), 11)
    T.assert_equal(results, "ASCII NFC byte 0 = h", ns_get_byte(nfc, 0), 104)
    T.assert_equal(results, "ASCII NFC byte 4 = o", ns_get_byte(nfc, 4), 111)
    T.assert_equal(results, "ASCII NFC byte 10 = d", ns_get_byte(nfc, 10), 100)
    N.normalized_string_destroy(nfc)

    Let nfd be N.string_normalize_nfd("hello world")
    T.assert_not_null(results, "ASCII NFD allocated", nfd)
    T.assert_equal(results, "ASCII NFD length", N.normalized_string_length(nfd), 11)
    T.assert_equal(results, "ASCII NFD byte 0 = h", ns_get_byte(nfd, 0), 104)
    N.normalized_string_destroy(nfd)
    Return 1
End Process

Note: ============================================================================
Note: KAT-6: Canonical reordering - cedilla before acute by CCC
Note: ============================================================================

Process called "test_kat_canonical_reorder" takes results as Integer returns Integer:
    T.begin_suite(results, "uax15.kat.canonical_reorder")
    Note: Input as ALREADY DECOMPOSED bytes a + combining-acute (230)
    Note: + combining-cedilla (202). Because cedilla has lower CCC (202)
    Note: than acute (230), canonical ordering puts cedilla FIRST.
    Note: Input UTF-8: 61 CC 81 CC A7 = a + U+0301 + U+0327 (5 bytes)
    Note: Output NFD : 61 CC A7 CC 81 = a + U+0327 + U+0301 (5 bytes,
    Note:                                cedilla before acute)
    Let buf be allocate(6)
    T.assert_not_null(results, "reorder buffer", buf)
    Memory.memory_set_byte(buf, 0, 97)
    Memory.memory_set_byte(buf, 1, 204)
    Memory.memory_set_byte(buf, 2, 129)
    Memory.memory_set_byte(buf, 3, 204)
    Memory.memory_set_byte(buf, 4, 167)
    Memory.memory_set_byte(buf, 5, 0)

    Let nfd be N.string_normalize_nfd(buf)
    T.assert_not_null(results, "reorder NFD allocated", nfd)
    T.assert_equal(results, "reorder NFD length", N.normalized_string_length(nfd), 5)
    T.assert_equal(results, "reorder NFD byte 0 = a", ns_get_byte(nfd, 0), 97)
    Note: Cedilla (U+0327) UTF-8 is CC A7 = 204, 167. Lower CCC sorts first.
    T.assert_equal(results, "reorder NFD byte 1 = 0xCC", ns_get_byte(nfd, 1), 204)
    T.assert_equal(results, "reorder NFD byte 2 = 0xA7 cedilla", ns_get_byte(nfd, 2), 167)
    Note: Acute (U+0301) UTF-8 is CC 81 = 204, 129.
    T.assert_equal(results, "reorder NFD byte 3 = 0xCC", ns_get_byte(nfd, 3), 204)
    T.assert_equal(results, "reorder NFD byte 4 = 0x81 acute", ns_get_byte(nfd, 4), 129)

    N.normalized_string_destroy(nfd)
    deallocate(buf)
    Return 1
End Process

Note: ============================================================================
Note: KAT-7: A + acute -> U+00C1 (capital A with acute) via primary compose
Note: ============================================================================

Process called "test_kat_compose_A_acute" takes results as Integer returns Integer:
    T.begin_suite(results, "uax15.kat.compose_A_acute")
    Note: Input UTF-8: 41 CC 81 = A + U+0301 acute (3 bytes)
    Note: Output NFC: C3 81 = U+00C1 LATIN CAPITAL A WITH ACUTE (2 bytes)
    Let buf be allocate(4)
    T.assert_not_null(results, "compose buffer", buf)
    Memory.memory_set_byte(buf, 0, 65)
    Memory.memory_set_byte(buf, 1, 204)
    Memory.memory_set_byte(buf, 2, 129)
    Memory.memory_set_byte(buf, 3, 0)

    Let nfc be N.string_normalize_nfc(buf)
    T.assert_not_null(results, "compose NFC allocated", nfc)
    T.assert_equal(results, "compose NFC length", N.normalized_string_length(nfc), 2)
    T.assert_equal(results, "compose NFC byte 0 = 0xC3", ns_get_byte(nfc, 0), 195)
    T.assert_equal(results, "compose NFC byte 1 = 0x81", ns_get_byte(nfc, 1), 129)

    N.normalized_string_destroy(nfc)
    deallocate(buf)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_kat_cafe_nfd(results)
    test_kat_cafe_nfc(results)
    test_kat_hangul_LV(results)
    test_kat_fi_ligature_nfkc(results)
    test_kat_ascii_invariance(results)
    test_kat_canonical_reorder(results)
    test_kat_compose_A_acute(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
