Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/text/locale.runa" as L
Import "compiler/frontend/primitives/core/string_core.runa" as Str

Process called "test_locale_simple_lang" that takes results as Integer returns Integer:
    T.begin_suite(results, "locale.simple_lang")
    Let loc be L.locale_from_string("en")
    T.assert_not_null(results, "parse 'en'", loc)
    Let lang be L.locale_language(loc)
    T.assert_equal(results, "lang equals 'en'", Str.string_equals(lang, "en"), 1)
    T.assert_null(results, "no region", L.locale_region(loc))
    T.assert_null(results, "no script", L.locale_script(loc))
    L.locale_destroy(loc)
    Return 1
End Process

Process called "test_locale_bcp47" that takes results as Integer returns Integer:
    T.begin_suite(results, "locale.bcp47")
    Let loc be L.locale_from_string("en-US")
    T.assert_not_null(results, "parse 'en-US'", loc)
    Let lang be L.locale_language(loc)
    T.assert_equal(results, "lang=en", Str.string_equals(lang, "en"), 1)
    Let region be L.locale_region(loc)
    T.assert_equal(results, "region=US", Str.string_equals(region, "US"), 1)
    L.locale_destroy(loc)
    Return 1
End Process

Process called "test_locale_posix" that takes results as Integer returns Integer:
    T.begin_suite(results, "locale.posix")
    Let loc be L.locale_from_string("en_US")
    T.assert_not_null(results, "parse 'en_US'", loc)
    Let lang be L.locale_language(loc)
    T.assert_equal(results, "lang=en", Str.string_equals(lang, "en"), 1)
    Let region be L.locale_region(loc)
    T.assert_equal(results, "region=US", Str.string_equals(region, "US"), 1)
    L.locale_destroy(loc)
    Return 1
End Process

Process called "test_locale_with_script" that takes results as Integer returns Integer:
    T.begin_suite(results, "locale.with_script")
    Let loc be L.locale_from_string("zh-Hans-CN")
    T.assert_not_null(results, "parse 'zh-Hans-CN'", loc)
    Let lang be L.locale_language(loc)
    T.assert_equal(results, "lang=zh", Str.string_equals(lang, "zh"), 1)
    Let script be L.locale_script(loc)
    T.assert_equal(results, "script=Hans", Str.string_equals(script, "Hans"), 1)
    Let region be L.locale_region(loc)
    T.assert_equal(results, "region=CN", Str.string_equals(region, "CN"), 1)
    L.locale_destroy(loc)
    Return 1
End Process

Process called "test_locale_with_encoding" that takes results as Integer returns Integer:
    T.begin_suite(results, "locale.with_encoding")
    Let loc be L.locale_from_string("en_US.UTF-8")
    T.assert_not_null(results, "parse 'en_US.UTF-8'", loc)
    Let lang be L.locale_language(loc)
    T.assert_equal(results, "lang=en", Str.string_equals(lang, "en"), 1)
    Let region be L.locale_region(loc)
    T.assert_equal(results, "region=US", Str.string_equals(region, "US"), 1)
    Let variant be L.locale_variant(loc)
    T.assert_not_null(results, "variant captured", variant)
    L.locale_destroy(loc)
    Return 1
End Process

Process called "test_locale_invalid" that takes results as Integer returns Integer:
    T.begin_suite(results, "locale.invalid")
    Let loc be L.locale_from_string("123")
    T.assert_equal(results, "all-digit rejected", loc, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_locale_simple_lang(results)
    test_locale_bcp47(results)
    test_locale_posix(results)
    test_locale_with_script(results)
    test_locale_with_encoding(results)
    test_locale_invalid(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
