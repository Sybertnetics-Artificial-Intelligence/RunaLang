Note:
Unit tests for compiler/frontend/primitives/text/normalized_string.runa.
Verifies form-tagged construction, accessors, and equality.

Note: In the v0.0.8.5 baseline (zero-population Unicode tables) NFC/NFD
proc bodies pass the bytes through. The contract is that the FORM TAG
distinguishes the result, not its bytes. When the v0.2.x tables ship
the round-trip cases will additionally observe canonical recomposition.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/text/normalized_string.runa" as N

Process called "test_normalized_string_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "normalized_string.create")
    Let nfc be N.string_normalize_nfc("hello")
    T.assert_not_null(results, "NFC created", nfc)
    T.assert_equal(results, "NFC length", N.normalized_string_length(nfc), 5)
    T.assert_equal(results, "NFC form tag", N.normalized_string_form(nfc), 1)
    N.normalized_string_destroy(nfc)

    Let nfd be N.string_normalize_nfd("hello")
    T.assert_equal(results, "NFD form tag", N.normalized_string_form(nfd), 2)
    N.normalized_string_destroy(nfd)

    Let nfkc be N.string_normalize_nfkc("hello")
    T.assert_equal(results, "NFKC form tag", N.normalized_string_form(nfkc), 3)
    N.normalized_string_destroy(nfkc)

    Let nfkd be N.string_normalize_nfkd("hello")
    T.assert_equal(results, "NFKD form tag", N.normalized_string_form(nfkd), 4)
    N.normalized_string_destroy(nfkd)
    Return 1
End Process

Process called "test_normalized_string_equals" that takes results as Integer returns Integer:
    T.begin_suite(results, "normalized_string.equals")
    Let a be N.string_normalize_nfc("cafe")
    Let b be N.string_normalize_nfc("cafe")
    T.assert_equal(results, "NFC==NFC same content", N.normalized_string_equals(a, b), 1)

    Let c be N.string_normalize_nfd("cafe")
    T.assert_equal(results, "NFC vs NFD different form -> not equal", N.normalized_string_equals(a, c), 0)

    Let d be N.string_normalize_nfc("other")
    T.assert_equal(results, "NFC vs NFC different content", N.normalized_string_equals(a, d), 0)

    N.normalized_string_destroy(a)
    N.normalized_string_destroy(b)
    N.normalized_string_destroy(c)
    N.normalized_string_destroy(d)
    Return 1
End Process

Process called "test_normalized_string_ascii_invariant" that takes results as Integer returns Integer:
    T.begin_suite(results, "normalized_string.ascii_invariant")
    Note: ASCII is the same in all four forms; bytes are identical.
    Let a be N.string_normalize_nfc("abc")
    Let b be N.string_normalize_nfd("abc")
    T.assert_equal(results, "NFC bytes length", N.normalized_string_length(a), 3)
    T.assert_equal(results, "NFD bytes length", N.normalized_string_length(b), 3)
    N.normalized_string_destroy(a)
    N.normalized_string_destroy(b)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_normalized_string_create(results)
    test_normalized_string_equals(results)
    test_normalized_string_ascii_invariant(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
