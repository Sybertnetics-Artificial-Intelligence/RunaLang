Note:
Unit tests for compiler/frontend/primitives/text/grapheme.runa.
Covers UAX #29 grapheme clustering.

Test fixtures:
  "abc"             -> 3 graphemes
  "hello world"     -> 11 graphemes
  "\r\n"            -> 1 grapheme (CR+LF coalesces)
  "🇺🇸"             -> 1 grapheme = 2 RI codepoints = 8 bytes
  "🚀"              -> 1 grapheme = 1 codepoint = 4 bytes
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/text/grapheme.runa" as G

Process called "test_grapheme_ascii" that takes results as Integer returns Integer:
    T.begin_suite(results, "grapheme.ascii")
    T.assert_equal(results, "'abc' -> 3", G.grapheme_count("abc"), 3)
    T.assert_equal(results, "'hello' -> 5", G.grapheme_count("hello"), 5)
    T.assert_equal(results, "empty -> 0", G.grapheme_count(""), 0)
    Return 1
End Process

Process called "test_grapheme_crlf" that takes results as Integer returns Integer:
    T.begin_suite(results, "grapheme.crlf")
    Note: CR+LF should be one grapheme per UAX #29 GB3.
    Let s be "
"
    T.assert_equal(results, "CR+LF as 1", G.grapheme_count(s), 1)
    Return 1
End Process

Process called "test_grapheme_emoji_simple" that takes results as Integer returns Integer:
    T.begin_suite(results, "grapheme.emoji_simple")
    Note: U+1F680 ROCKET as single 4-byte UTF-8 sequence -> 1 grapheme.
    Let s be "🚀"
    T.assert_equal(results, "rocket -> 1 grapheme", G.grapheme_count(s), 1)
    Return 1
End Process

Process called "test_grapheme_flag" that takes results as Integer returns Integer:
    T.begin_suite(results, "grapheme.flag")
    Note: 🇺🇸 = U+1F1FA + U+1F1F8 = 8 bytes = 2 codepoints = 1 grapheme via GB12/13.
    Let s be "🇺🇸"
    T.assert_equal(results, "flag -> 1 grapheme", G.grapheme_count(s), 1)
    Return 1
End Process

Process called "test_grapheme_iteration" that takes results as Integer returns Integer:
    T.begin_suite(results, "grapheme.iteration")
    Note: Verify grapheme_next_offset advances correctly across boundaries.
    Let s be "ab"
    Let off1 be G.grapheme_next_offset(s, 2, 0)
    T.assert_equal(results, "first cluster ends at 1", off1, 1)
    Let off2 be G.grapheme_next_offset(s, 2, 1)
    T.assert_equal(results, "second cluster ends at 2", off2, 2)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_grapheme_ascii(results)
    test_grapheme_crlf(results)
    test_grapheme_emoji_simple(results)
    test_grapheme_flag(results)
    test_grapheme_iteration(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
