Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/text/regex.runa" as R

Process called "test_regex_literal" that takes results as Integer returns Integer:
    T.begin_suite(results, "regex.literal")
    Let re be R.regex_compile("abc", 0)
    T.assert_not_null(results, "compiled", re)
    Let m be R.regex_match(re, "abcdef")
    T.assert_not_null(results, "matched", m)
    T.assert_equal(results, "match_end = 3", R.regex_match_end(m), 3)
    R.regex_match_destroy(m)
    Let m2 be R.regex_match(re, "xabc")
    T.assert_equal(results, "anchored mismatch", m2, 0)
    Return 1
End Process

Process called "test_regex_find" that takes results as Integer returns Integer:
    T.begin_suite(results, "regex.find")
    Let re be R.regex_compile("def", 0)
    Let m be R.regex_find(re, "abcdef", 0)
    T.assert_not_null(results, "found", m)
    T.assert_equal(results, "start=3", R.regex_match_start(m), 3)
    T.assert_equal(results, "end=6", R.regex_match_end(m), 6)
    R.regex_match_destroy(m)
    Return 1
End Process

Process called "test_regex_class" that takes results as Integer returns Integer:
    T.begin_suite(results, "regex.class")
    Let re be R.regex_compile("[abc]", 0)
    Let m1 be R.regex_match(re, "a")
    T.assert_not_null(results, "a matches", m1)
    R.regex_match_destroy(m1)
    Let m2 be R.regex_match(re, "b")
    T.assert_not_null(results, "b matches", m2)
    R.regex_match_destroy(m2)
    Let m3 be R.regex_match(re, "d")
    T.assert_equal(results, "d does not match", m3, 0)
    Return 1
End Process

Process called "test_regex_range_class" that takes results as Integer returns Integer:
    T.begin_suite(results, "regex.range_class")
    Let re be R.regex_compile("[a-z]", 0)
    Let m1 be R.regex_match(re, "k")
    T.assert_not_null(results, "k in [a-z]", m1)
    R.regex_match_destroy(m1)
    Let m2 be R.regex_match(re, "K")
    T.assert_equal(results, "K not in [a-z]", m2, 0)
    Return 1
End Process

Process called "test_regex_alternation" that takes results as Integer returns Integer:
    T.begin_suite(results, "regex.alternation")
    Let re be R.regex_compile("cat|dog", 0)
    Let m1 be R.regex_match(re, "cat")
    T.assert_not_null(results, "cat matches", m1)
    R.regex_match_destroy(m1)
    Let m2 be R.regex_match(re, "dog")
    T.assert_not_null(results, "dog matches", m2)
    R.regex_match_destroy(m2)
    Let m3 be R.regex_match(re, "fox")
    T.assert_equal(results, "fox does not match", m3, 0)
    Return 1
End Process

Process called "test_regex_quantifier" that takes results as Integer returns Integer:
    T.begin_suite(results, "regex.quantifier")
    Let re_star be R.regex_compile("a*", 0)
    Let m1 be R.regex_match(re_star, "aaa")
    T.assert_not_null(results, "a* matches aaa", m1)
    T.assert_equal(results, "consumed 3 chars", R.regex_match_end(m1), 3)
    R.regex_match_destroy(m1)
    Let m_zero be R.regex_match(re_star, "")
    T.assert_not_null(results, "a* matches empty", m_zero)
    R.regex_match_destroy(m_zero)

    Let re_plus be R.regex_compile("a+", 0)
    Let m2 be R.regex_match(re_plus, "aaa")
    T.assert_equal(results, "a+ consumes 3", R.regex_match_end(m2), 3)
    R.regex_match_destroy(m2)
    Let m_no be R.regex_match(re_plus, "")
    T.assert_equal(results, "a+ rejects empty", m_no, 0)

    Let re_opt be R.regex_compile("ab?c", 0)
    Let m3 be R.regex_match(re_opt, "ac")
    T.assert_not_null(results, "b? optional present omitted", m3)
    T.assert_equal(results, "ac consumed 2", R.regex_match_end(m3), 2)
    R.regex_match_destroy(m3)
    Let m4 be R.regex_match(re_opt, "abc")
    T.assert_not_null(results, "b? present", m4)
    T.assert_equal(results, "abc consumed 3", R.regex_match_end(m4), 3)
    R.regex_match_destroy(m4)
    Return 1
End Process

Process called "test_regex_group" that takes results as Integer returns Integer:
    T.begin_suite(results, "regex.group")
    Let re be R.regex_compile("(abc)d", 0)
    Let m be R.regex_match(re, "abcd")
    T.assert_not_null(results, "matched", m)
    T.assert_equal(results, "group 1 start=0", R.regex_match_group_start(m, 1), 0)
    T.assert_equal(results, "group 1 end=3", R.regex_match_group_end(m, 1), 3)
    R.regex_match_destroy(m)
    Return 1
End Process

Process called "test_regex_digit_class" that takes results as Integer returns Integer:
    T.begin_suite(results, "regex.digit_class")
    Let re be R.regex_compile("\\d+", 0)
    Let m be R.regex_find(re, "abc123def", 0)
    T.assert_not_null(results, "found digits", m)
    T.assert_equal(results, "start=3", R.regex_match_start(m), 3)
    T.assert_equal(results, "end=6", R.regex_match_end(m), 6)
    R.regex_match_destroy(m)
    Return 1
End Process

Process called "test_regex_unicode_category" that takes results as Integer returns Integer:
    T.begin_suite(results, "regex.unicode_category")
    Let re be R.regex_compile("\\p{L}", 0)
    Let m be R.regex_match(re, "X")
    T.assert_not_null(results, "L matches X", m)
    R.regex_match_destroy(m)
    Let re2 be R.regex_compile("\\p{N}", 0)
    Let m2 be R.regex_match(re2, "5")
    T.assert_not_null(results, "N matches 5", m2)
    R.regex_match_destroy(m2)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_regex_literal(results)
    test_regex_find(results)
    test_regex_class(results)
    test_regex_range_class(results)
    test_regex_alternation(results)
    test_regex_quantifier(results)
    test_regex_group(results)
    test_regex_digit_class(results)
    test_regex_unicode_category(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
