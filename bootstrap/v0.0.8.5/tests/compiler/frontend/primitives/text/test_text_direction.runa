Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/text/text_direction.runa" as D
Import "compiler/frontend/primitives/text/locale.runa" as L

Process called "test_dir_string_ltr" that takes results as Integer returns Integer:
    T.begin_suite(results, "text_direction.string_ltr")
    T.assert_equal(results, "ASCII -> LTR", D.text_direction_for_string("hello"), 1)
    T.assert_equal(results, "empty -> LTR", D.text_direction_for_string(""), 1)
    T.assert_equal(results, "digits/punct only -> LTR", D.text_direction_for_string("123!"), 1)
    Return 1
End Process

Process called "test_dir_string_rtl" that takes results as Integer returns Integer:
    T.begin_suite(results, "text_direction.string_rtl")
    Note: Hebrew shalom: U+05E9 U+05DC U+05D5 U+05DD
    Let s be "שלום"
    T.assert_equal(results, "Hebrew -> RTL", D.text_direction_for_string(s), 2)
    Note: Arabic salam: U+0633 U+0644 U+0627 U+0645
    Let s2 be "سلام"
    T.assert_equal(results, "Arabic -> RTL", D.text_direction_for_string(s2), 2)
    Return 1
End Process

Process called "test_dir_string_bidi" that takes results as Integer returns Integer:
    T.begin_suite(results, "text_direction.string_bidi")
    Note: Arabic + English: "salam hello"
    Let s be "سلام hello"
    T.assert_equal(results, "mixed -> BIDI", D.text_direction_for_string(s), 3)
    Return 1
End Process

Process called "test_dir_first_strong" that takes results as Integer returns Integer:
    T.begin_suite(results, "text_direction.first_strong")
    Note: First strong char is Arabic -> RTL paragraph
    Let s be "سلام hello"
    T.assert_equal(results, "first-strong = Arabic -> RTL", D.text_direction_for_string_first_strong(s), 2)
    Note: First strong char is Latin -> LTR
    Let s2 be "hello سلام"
    T.assert_equal(results, "first-strong = Latin -> LTR", D.text_direction_for_string_first_strong(s2), 1)
    Return 1
End Process

Process called "test_dir_locale" that takes results as Integer returns Integer:
    T.begin_suite(results, "text_direction.for_locale")
    Let en be L.locale_from_string("en-US")
    T.assert_equal(results, "en-US -> LTR", D.text_direction_for_locale(en), 1)
    Let ar be L.locale_from_string("ar-SA")
    T.assert_equal(results, "ar-SA -> RTL", D.text_direction_for_locale(ar), 2)
    Let he be L.locale_from_string("he-IL")
    T.assert_equal(results, "he-IL -> RTL", D.text_direction_for_locale(he), 2)
    Let fa be L.locale_from_string("fa")
    T.assert_equal(results, "fa -> RTL", D.text_direction_for_locale(fa), 2)
    L.locale_destroy(en)
    L.locale_destroy(ar)
    L.locale_destroy(he)
    L.locale_destroy(fa)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_dir_string_ltr(results)
    test_dir_string_rtl(results)
    test_dir_string_bidi(results)
    test_dir_first_strong(results)
    test_dir_locale(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
