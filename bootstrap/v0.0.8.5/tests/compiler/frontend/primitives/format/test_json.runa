Note:
Unit tests for compiler/frontend/primitives/format/json.runa.

Covers RFC 8259 conformance: escape sequences, surrogate pairs,
nested objects/arrays, the canonical RFC 9535 example for JsonPath,
and RFC 6901 JsonPointer traversal.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/format/json.runa" as J
Import "compiler/frontend/primitives/core/string_core.runa" as Str

Note: ============================================================================
Note: PARSE TESTS - RFC 8259 LITERALS AND PRIMITIVES
Note: ============================================================================

Process called "test_parse_null" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_null")
    Let r be J.json_parse("null")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "tag is NULL", J.json_get_tag(v), 0)
    Return 1
End Process

Process called "test_parse_bool_true" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_bool_true")
    Let r be J.json_parse("true")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "tag is BOOL", J.json_get_tag(v), 1)
    T.assert_equal(results, "value is 1", J.json_get_bool(v), 1)
    Return 1
End Process

Process called "test_parse_bool_false" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_bool_false")
    Let r be J.json_parse("false")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "tag is BOOL", J.json_get_tag(v), 1)
    T.assert_equal(results, "value is 0", J.json_get_bool(v), 0)
    Return 1
End Process

Process called "test_parse_integer" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_integer")
    Let r be J.json_parse("42")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "tag is NUMBER", J.json_get_tag(v), 2)
    T.assert_equal(results, "integer coercion", J.json_number_to_integer(v), 42)
    Return 1
End Process

Process called "test_parse_negative" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_negative")
    Let r be J.json_parse("-17")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "integer coercion", J.json_number_to_integer(v), -17)
    Return 1
End Process

Process called "test_parse_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_zero")
    Let r be J.json_parse("0")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Return 1
End Process

Process called "test_reject_leading_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.reject_leading_zero")
    Note: RFC 8259 section 6: "0" prefix on multi-digit integer is illegal.
    Let r be J.json_parse("01")
    T.assert_equal(results, "result is Error", J.json_result_is_ok(r), 0)
    Return 1
End Process

Process called "test_parse_simple_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_simple_string")
    Let r be J.json_parse("\"hello\"")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "tag is STRING", J.json_get_tag(v), 3)
    T.assert_equal(results, "string equals hello", Str.string_equals(J.json_get_string(v), "hello"), 1)
    Return 1
End Process

Process called "test_parse_escaped_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_escaped_string")
    Note: RFC 8259 section 13 includes "Hello\nworld" - tests \n escape.
    Let r be J.json_parse("\"a\\nb\"")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    Let s be J.json_get_string(v)
    T.assert_equal(results, "length is 3", Str.string_length(s), 3)
    T.assert_equal(results, "byte 0 is 'a'", Str.string_char_at(s, 0), 97)
    T.assert_equal(results, "byte 1 is LF", Str.string_char_at(s, 1), 10)
    T.assert_equal(results, "byte 2 is 'b'", Str.string_char_at(s, 2), 98)
    Return 1
End Process

Process called "test_parse_unicode_escape" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_unicode_escape")
    Note: U+00E9 = e-acute = 0xC3 0xA9 in UTF-8
    Let r be J.json_parse("\"\\u00e9\"")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    Let s be J.json_get_string(v)
    T.assert_equal(results, "utf8 length is 2", Str.string_length(s), 2)
    T.assert_equal(results, "byte 0 is 0xC3", Str.string_char_at(s, 0), 195)
    T.assert_equal(results, "byte 1 is 0xA9", Str.string_char_at(s, 1), 169)
    Return 1
End Process

Process called "test_parse_surrogate_pair" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_surrogate_pair")
    Note: U+1D11E (MUSICAL SYMBOL G CLEF) = 𝄞 -> 4 UTF-8 bytes
    Let r be J.json_parse("\"\\uD834\\uDD1E\"")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    Let s be J.json_get_string(v)
    T.assert_equal(results, "utf8 length is 4", Str.string_length(s), 4)
    T.assert_equal(results, "byte 0 is 0xF0", Str.string_char_at(s, 0), 240)
    T.assert_equal(results, "byte 1 is 0x9D", Str.string_char_at(s, 1), 157)
    T.assert_equal(results, "byte 2 is 0x84", Str.string_char_at(s, 2), 132)
    T.assert_equal(results, "byte 3 is 0x9E", Str.string_char_at(s, 3), 158)
    Return 1
End Process

Process called "test_parse_empty_array" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_empty_array")
    Let r be J.json_parse("[]")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "tag is ARRAY", J.json_get_tag(v), 4)
    T.assert_equal(results, "length is 0", J.json_array_length(v), 0)
    Return 1
End Process

Process called "test_parse_array_values" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_array_values")
    Let r be J.json_parse("[1, 2, 3]")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "length is 3", J.json_array_length(v), 3)
    T.assert_equal(results, "[0] is 1", J.json_number_to_integer(J.json_array_get(v, 0)), 1)
    T.assert_equal(results, "[1] is 2", J.json_number_to_integer(J.json_array_get(v, 1)), 2)
    T.assert_equal(results, "[2] is 3", J.json_number_to_integer(J.json_array_get(v, 2)), 3)
    Return 1
End Process

Process called "test_parse_empty_object" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_empty_object")
    Let r be J.json_parse("{}")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "tag is OBJECT", J.json_get_tag(v), 5)
    T.assert_equal(results, "length is 0", J.json_object_length(v), 0)
    Return 1
End Process

Process called "test_parse_object_keys" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_object_keys")
    Let r be J.json_parse("{\"a\":1, \"b\":2}")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let v be J.json_result_payload(r)
    T.assert_equal(results, "length is 2", J.json_object_length(v), 2)
    Let a_val be J.json_object_get(v, "a")
    T.assert_equal(results, "a is 1", J.json_number_to_integer(a_val), 1)
    Let b_val be J.json_object_get(v, "b")
    T.assert_equal(results, "b is 2", J.json_number_to_integer(b_val), 2)
    Return 1
End Process

Process called "test_parse_nested" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_nested")
    Let r be J.json_parse("{\"x\":[1,{\"y\":2}]}")
    T.assert_equal(results, "result is Ok", J.json_result_is_ok(r), 1)
    Let root be J.json_result_payload(r)
    Let x_arr be J.json_object_get(root, "x")
    T.assert_equal(results, "x is array of length 2", J.json_array_length(x_arr), 2)
    Let elem1 be J.json_array_get(x_arr, 1)
    T.assert_equal(results, "elem1 tag is OBJECT", J.json_get_tag(elem1), 5)
    Let y_val be J.json_object_get(elem1, "y")
    T.assert_equal(results, "y is 2", J.json_number_to_integer(y_val), 2)
    Return 1
End Process

Process called "test_parse_reject_trailing" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.parse_reject_trailing")
    Let r be J.json_parse("1 garbage")
    T.assert_equal(results, "result is Error", J.json_result_is_ok(r), 0)
    Return 1
End Process

Process called "test_strict_duplicate_rejection" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.strict_duplicate_rejection")
    Let r be J.json_parse_strict("{\"a\":1,\"a\":2}")
    T.assert_equal(results, "duplicate is rejected", J.json_result_is_ok(r), 0)
    Let r2 be J.json_parse("{\"a\":1,\"a\":2}")
    T.assert_equal(results, "default allows duplicates", J.json_result_is_ok(r2), 1)
    Let root be J.json_result_payload(r2)
    Let a_val be J.json_object_get(root, "a")
    T.assert_equal(results, "last-key-wins yields 2", J.json_number_to_integer(a_val), 2)
    Return 1
End Process

Note: ============================================================================
Note: SERIALIZE TESTS
Note: ============================================================================

Process called "test_serialize_primitive" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.serialize_primitive")
    Let n be J.json_number_from_int(42)
    Let s be J.json_serialize(n)
    T.assert_equal(results, "42 -> \"42\"", Str.string_equals(s, "42"), 1)
    Let b be J.json_bool(1)
    Let sb be J.json_serialize(b)
    T.assert_equal(results, "true -> \"true\"", Str.string_equals(sb, "true"), 1)
    Let nu be J.json_null()
    Let snu be J.json_serialize(nu)
    T.assert_equal(results, "null -> \"null\"", Str.string_equals(snu, "null"), 1)
    Return 1
End Process

Process called "test_serialize_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.serialize_string")
    Let s be J.json_string("hello")
    Let out be J.json_serialize(s)
    T.assert_equal(results, "hello roundtrip", Str.string_equals(out, "\"hello\""), 1)
    Return 1
End Process

Process called "test_serialize_escape" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.serialize_escape")
    Note: Build a string containing a literal newline byte then serialize.
    Let buf be allocate(3)
    __store_byte(buf, 0, 97)
    __store_byte(buf, 1, 10)
    __store_byte(buf, 2, 0)
    Let s be J.json_string(buf)
    Let out be J.json_serialize(s)
    T.assert_equal(results, "newline escaped", Str.string_equals(out, "\"a\\n\""), 1)
    Return 1
End Process

Process called "test_serialize_object" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.serialize_object")
    Let o be J.json_object_new()
    J.json_object_set(o, "a", J.json_number_from_int(1))
    J.json_object_set(o, "b", J.json_number_from_int(2))
    Let out be J.json_serialize(o)
    T.assert_equal(results, "compact form", Str.string_equals(out, "{\"a\":1,\"b\":2}"), 1)
    Return 1
End Process

Process called "test_serialize_sorted" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.serialize_sorted")
    Let o be J.json_object_new()
    J.json_object_set(o, "b", J.json_number_from_int(2))
    J.json_object_set(o, "a", J.json_number_from_int(1))
    Let out be J.json_serialize_sorted(o)
    T.assert_equal(results, "sorted alphabetically", Str.string_equals(out, "{\"a\":1,\"b\":2}"), 1)
    Return 1
End Process

Process called "test_serialize_pretty" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.serialize_pretty")
    Let a be J.json_array_new()
    J.json_array_push(a, J.json_number_from_int(1))
    J.json_array_push(a, J.json_number_from_int(2))
    Let out be J.json_serialize_pretty(a, 2)
    T.assert_equal(results, "pretty length > compact", Str.string_length(out) is greater than 7, 1)
    T.assert_equal(results, "first byte is [", Str.string_char_at(out, 0), 91)
    Return 1
End Process

Note: ============================================================================
Note: JSON POINTER (RFC 6901)
Note: ============================================================================

Process called "test_jsonpointer_root" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.jsonpointer_root")
    Let pr be J.json_parse("{\"a\":1}")
    Let root be J.json_result_payload(pr)
    Let ptr be J.jsonpointer_parse("")
    Let r be J.jsonpointer_eval(ptr, root)
    T.assert_equal(results, "empty pointer returns root", r, root)
    Return 1
End Process

Process called "test_jsonpointer_member" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.jsonpointer_member")
    Let pr be J.json_parse("{\"a\":{\"b\":42}}")
    Let root be J.json_result_payload(pr)
    Let ptr be J.jsonpointer_parse("/a/b")
    Let r be J.jsonpointer_eval(ptr, root)
    T.assert_equal(results, "/a/b -> 42", J.json_number_to_integer(r), 42)
    Return 1
End Process

Process called "test_jsonpointer_array_index" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.jsonpointer_array_index")
    Let pr be J.json_parse("[10,20,30]")
    Let root be J.json_result_payload(pr)
    Let ptr be J.jsonpointer_parse("/1")
    Let r be J.jsonpointer_eval(ptr, root)
    T.assert_equal(results, "/1 -> 20", J.json_number_to_integer(r), 20)
    Return 1
End Process

Process called "test_jsonpointer_escape" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.jsonpointer_escape")
    Note: RFC 6901: key "a/b" is referenced as "/a~1b"
    Let pr be J.json_parse("{\"a/b\":7}")
    Let root be J.json_result_payload(pr)
    Let ptr be J.jsonpointer_parse("/a~1b")
    Let r be J.jsonpointer_eval(ptr, root)
    T.assert_equal(results, "/a~1b -> 7", J.json_number_to_integer(r), 7)
    Return 1
End Process

Note: ============================================================================
Note: JSONPATH (RFC 9535)
Note: ============================================================================
Note:
RFC 9535 canonical example:
{ "store": { "book": [
    { "category":"reference","author":"Nigel Rees","title":"Sayings","price":8.95 },
    { "category":"fiction","author":"Evelyn Waugh","title":"Sword","price":12.99 }
] } }

Query: $.store.book[*].author -> ["Nigel Rees","Evelyn Waugh"]
:End Note

Process called "test_jsonpath_root_member" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.jsonpath_root_member")
    Let pr be J.json_parse("{\"x\":42}")
    Let root be J.json_result_payload(pr)
    Let expr be J.jsonpath_parse("$.x")
    Let nodes be J.jsonpath_eval(expr, root)
    T.assert_equal(results, "1 match", J.json_array_length(nodes), 1)
    Let n be J.json_array_get(nodes, 0)
    T.assert_equal(results, "value 42", J.json_number_to_integer(n), 42)
    Return 1
End Process

Process called "test_jsonpath_array_index" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.jsonpath_array_index")
    Let pr be J.json_parse("{\"a\":[10,20,30]}")
    Let root be J.json_result_payload(pr)
    Let expr be J.jsonpath_parse("$.a[1]")
    Let nodes be J.jsonpath_eval(expr, root)
    T.assert_equal(results, "1 match", J.json_array_length(nodes), 1)
    Let n be J.json_array_get(nodes, 0)
    T.assert_equal(results, "value 20", J.json_number_to_integer(n), 20)
    Return 1
End Process

Process called "test_jsonpath_wildcard" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.jsonpath_wildcard")
    Note: RFC 9535 canonical example with two book entries.
    Let json_text be "{\"store\":{\"book\":[{\"category\":\"reference\",\"author\":\"Nigel Rees\"},{\"category\":\"fiction\",\"author\":\"Evelyn Waugh\"}]}}"
    Let pr be J.json_parse(json_text)
    T.assert_equal(results, "parse ok", J.json_result_is_ok(pr), 1)
    Let root be J.json_result_payload(pr)
    Let expr be J.jsonpath_parse("$.store.book[*].author")
    Let nodes be J.jsonpath_eval(expr, root)
    T.assert_equal(results, "2 authors found", J.json_array_length(nodes), 2)
    Let a0 be J.json_array_get(nodes, 0)
    T.assert_equal(results, "first is Nigel Rees", Str.string_equals(J.json_get_string(a0), "Nigel Rees"), 1)
    Let a1 be J.json_array_get(nodes, 1)
    T.assert_equal(results, "second is Evelyn Waugh", Str.string_equals(J.json_get_string(a1), "Evelyn Waugh"), 1)
    Return 1
End Process

Process called "test_jsonpath_bracketed_name" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.jsonpath_bracketed_name")
    Let pr be J.json_parse("{\"x\":{\"y\":99}}")
    Let root be J.json_result_payload(pr)
    Let expr be J.jsonpath_parse("$['x']['y']")
    Let nodes be J.jsonpath_eval(expr, root)
    T.assert_equal(results, "1 match", J.json_array_length(nodes), 1)
    Let n be J.json_array_get(nodes, 0)
    T.assert_equal(results, "value 99", J.json_number_to_integer(n), 99)
    Return 1
End Process

Note: ============================================================================
Note: ROUNDTRIP
Note: ============================================================================

Process called "test_roundtrip_complex" that takes results as Integer returns Integer:
    T.begin_suite(results, "json.roundtrip_complex")
    Let original be "{\"name\":\"Alice\",\"age\":30,\"active\":true,\"scores\":[1,2,3]}"
    Let pr be J.json_parse(original)
    T.assert_equal(results, "parse ok", J.json_result_is_ok(pr), 1)
    Let root be J.json_result_payload(pr)
    Let out be J.json_serialize(root)
    T.assert_equal(results, "roundtrip equal", Str.string_equals(out, original), 1)
    Return 1
End Process

Note: ============================================================================
Note: MAIN
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_parse_null(results)
    test_parse_bool_true(results)
    test_parse_bool_false(results)
    test_parse_integer(results)
    test_parse_negative(results)
    test_parse_zero(results)
    test_reject_leading_zero(results)
    test_parse_simple_string(results)
    test_parse_escaped_string(results)
    test_parse_unicode_escape(results)
    test_parse_surrogate_pair(results)
    test_parse_empty_array(results)
    test_parse_array_values(results)
    test_parse_empty_object(results)
    test_parse_object_keys(results)
    test_parse_nested(results)
    test_parse_reject_trailing(results)
    test_strict_duplicate_rejection(results)
    test_serialize_primitive(results)
    test_serialize_string(results)
    test_serialize_escape(results)
    test_serialize_object(results)
    test_serialize_sorted(results)
    test_serialize_pretty(results)
    test_jsonpointer_root(results)
    test_jsonpointer_member(results)
    test_jsonpointer_array_index(results)
    test_jsonpointer_escape(results)
    test_jsonpath_root_member(results)
    test_jsonpath_array_index(results)
    test_jsonpath_wildcard(results)
    test_jsonpath_bracketed_name(results)
    test_roundtrip_complex(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
