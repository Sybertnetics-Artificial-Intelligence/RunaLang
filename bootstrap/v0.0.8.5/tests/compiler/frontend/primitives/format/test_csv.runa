Note:
Unit tests for compiler/frontend/primitives/format/csv.runa.

Covers RFC 4180 example, embedded newlines in quoted fields,
double-quote escapes, TSV dialect, and the streaming iterator.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/format/csv.runa" as C
Import "compiler/frontend/primitives/core/string_core.runa" as Str

Note: ============================================================================
Note: RFC 4180 BASELINE
Note: ============================================================================

Process called "test_parse_rfc4180_example" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.parse_rfc4180_example")
    Note: From RFC 4180 section 2:
    Note:   aaa,bbb,ccc\r\n
    Note:   zzz,yyy,xxx\r\n
    Let input be "aaa,bbb,ccc\r\nzzz,yyy,xxx\r\n"
    Let r be C.csv_parse(input, 0)
    T.assert_equal(results, "result is Ok", C.csv_result_is_ok(r), 1)
    Let doc be C.csv_result_payload(r)
    T.assert_equal(results, "2 rows", C.csv_document_row_count(doc), 2)
    Let row0 be C.csv_document_row_at(doc, 0)
    T.assert_equal(results, "row0 has 3 fields", C.csv_row_field_count(row0), 3)
    T.assert_equal(results, "row0[0] = aaa", Str.string_equals(C.csv_row_field_at(row0, 0), "aaa"), 1)
    T.assert_equal(results, "row0[1] = bbb", Str.string_equals(C.csv_row_field_at(row0, 1), "bbb"), 1)
    T.assert_equal(results, "row0[2] = ccc", Str.string_equals(C.csv_row_field_at(row0, 2), "ccc"), 1)
    Let row1 be C.csv_document_row_at(doc, 1)
    T.assert_equal(results, "row1[0] = zzz", Str.string_equals(C.csv_row_field_at(row1, 0), "zzz"), 1)
    T.assert_equal(results, "row1[2] = xxx", Str.string_equals(C.csv_row_field_at(row1, 2), "xxx"), 1)
    Return 1
End Process

Process called "test_parse_quoted_field" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.parse_quoted_field")
    Let input be "\"a\",\"b\",\"c\"\n"
    Let r be C.csv_parse(input, 0)
    T.assert_equal(results, "result is Ok", C.csv_result_is_ok(r), 1)
    Let doc be C.csv_result_payload(r)
    Let row be C.csv_document_row_at(doc, 0)
    T.assert_equal(results, "field 0 = a", Str.string_equals(C.csv_row_field_at(row, 0), "a"), 1)
    T.assert_equal(results, "field 1 = b", Str.string_equals(C.csv_row_field_at(row, 1), "b"), 1)
    T.assert_equal(results, "field 2 = c", Str.string_equals(C.csv_row_field_at(row, 2), "c"), 1)
    Return 1
End Process

Process called "test_parse_double_quote_escape" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.parse_double_quote_escape")
    Note: RFC 4180 section 2: "foo""bar" -> foo"bar
    Let input be "\"foo\"\"bar\"\n"
    Let r be C.csv_parse(input, 0)
    T.assert_equal(results, "result is Ok", C.csv_result_is_ok(r), 1)
    Let doc be C.csv_result_payload(r)
    Let row be C.csv_document_row_at(doc, 0)
    Let field be C.csv_row_field_at(row, 0)
    T.assert_equal(results, "decoded value is foo\"bar", Str.string_equals(field, "foo\"bar"), 1)
    Return 1
End Process

Process called "test_parse_embedded_newline" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.parse_embedded_newline")
    Note: RFC 4180 section 2 allows CRLF inside quoted fields.
    Let input be "\"line1\nline2\",second\n"
    Let r be C.csv_parse(input, 0)
    T.assert_equal(results, "result is Ok", C.csv_result_is_ok(r), 1)
    Let doc be C.csv_result_payload(r)
    T.assert_equal(results, "1 row", C.csv_document_row_count(doc), 1)
    Let row be C.csv_document_row_at(doc, 0)
    T.assert_equal(results, "row has 2 fields", C.csv_row_field_count(row), 2)
    Let field0 be C.csv_row_field_at(row, 0)
    T.assert_equal(results, "field0 length 11", Str.string_length(field0), 11)
    T.assert_equal(results, "field0 contains LF", Str.string_char_at(field0, 5), 10)
    T.assert_equal(results, "field1 = second", Str.string_equals(C.csv_row_field_at(row, 1), "second"), 1)
    Return 1
End Process

Process called "test_parse_empty_field" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.parse_empty_field")
    Let input be "a,,c\n"
    Let r be C.csv_parse(input, 0)
    T.assert_equal(results, "result is Ok", C.csv_result_is_ok(r), 1)
    Let doc be C.csv_result_payload(r)
    Let row be C.csv_document_row_at(doc, 0)
    T.assert_equal(results, "3 fields", C.csv_row_field_count(row), 3)
    T.assert_equal(results, "field 1 is empty", Str.string_length(C.csv_row_field_at(row, 1)), 0)
    Return 1
End Process

Process called "test_parse_lf_only" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.parse_lf_only")
    Note: Many CSV files in the wild use LF terminators.
    Let input be "a,b,c\nd,e,f\n"
    Let r be C.csv_parse(input, 0)
    T.assert_equal(results, "result is Ok", C.csv_result_is_ok(r), 1)
    Let doc be C.csv_result_payload(r)
    T.assert_equal(results, "2 rows", C.csv_document_row_count(doc), 2)
    Return 1
End Process

Note: ============================================================================
Note: TSV DIALECT
Note: ============================================================================

Process called "test_parse_tsv" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.parse_tsv")
    Let dialect be C.csv_tsv_dialect()
    Let input be "a\tb\tc\nd\te\tf\n"
    Let r be C.csv_parse(input, dialect)
    T.assert_equal(results, "result is Ok", C.csv_result_is_ok(r), 1)
    Let doc be C.csv_result_payload(r)
    T.assert_equal(results, "2 rows", C.csv_document_row_count(doc), 2)
    Let row be C.csv_document_row_at(doc, 0)
    T.assert_equal(results, "field 0 = a", Str.string_equals(C.csv_row_field_at(row, 0), "a"), 1)
    T.assert_equal(results, "field 2 = c", Str.string_equals(C.csv_row_field_at(row, 2), "c"), 1)
    C.csv_dialect_destroy(dialect)
    Return 1
End Process

Note: ============================================================================
Note: SERIALIZE
Note: ============================================================================

Process called "test_serialize_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.serialize_roundtrip")
    Let doc be C.csv_document_create()
    Let r0 be C.csv_row_create()
    C.csv_row_append_field(r0, Str.string_duplicate("a"))
    C.csv_row_append_field(r0, Str.string_duplicate("b"))
    C.csv_row_append_field(r0, Str.string_duplicate("c"))
    C.csv_document_append_row(doc, r0)
    Let r1 be C.csv_row_create()
    C.csv_row_append_field(r1, Str.string_duplicate("d"))
    C.csv_row_append_field(r1, Str.string_duplicate("e"))
    C.csv_row_append_field(r1, Str.string_duplicate("f"))
    C.csv_document_append_row(doc, r1)
    Let out be C.csv_serialize(doc, 0)
    T.assert_equal(results, "expected CRLF format", Str.string_equals(out, "a,b,c\r\nd,e,f\r\n"), 1)
    Return 1
End Process

Process called "test_serialize_quote_when_needed" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.serialize_quote_when_needed")
    Let doc be C.csv_document_create()
    Let row be C.csv_row_create()
    C.csv_row_append_field(row, Str.string_duplicate("hello,world"))
    C.csv_row_append_field(row, Str.string_duplicate("normal"))
    C.csv_document_append_row(doc, row)
    Let out be C.csv_serialize(doc, 0)
    T.assert_equal(results, "comma forces quotes", Str.string_equals(out, "\"hello,world\",normal\r\n"), 1)
    Return 1
End Process

Process called "test_serialize_escape_quote" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.serialize_escape_quote")
    Let doc be C.csv_document_create()
    Let row be C.csv_row_create()
    C.csv_row_append_field(row, Str.string_duplicate("foo\"bar"))
    C.csv_document_append_row(doc, row)
    Let out be C.csv_serialize(doc, 0)
    T.assert_equal(results, "embedded quote doubled", Str.string_equals(out, "\"foo\"\"bar\"\r\n"), 1)
    Return 1
End Process

Note: ============================================================================
Note: STREAMING ITERATOR
Note: ============================================================================

Process called "test_iterator_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "csv.iterator_basic")
    Let input be "a,b\nc,d\ne,f\n"
    Let it be C.csv_iterator_create(input, 0)
    Let row1 be C.csv_iterator_next(it)
    T.assert_equal(results, "row1 not null", row1 is not equal to 0, 1)
    T.assert_equal(results, "row1 field 0 = a", Str.string_equals(C.csv_row_field_at(row1, 0), "a"), 1)
    Let row2 be C.csv_iterator_next(it)
    T.assert_equal(results, "row2 not null", row2 is not equal to 0, 1)
    T.assert_equal(results, "row2 field 1 = d", Str.string_equals(C.csv_row_field_at(row2, 1), "d"), 1)
    Let row3 be C.csv_iterator_next(it)
    T.assert_equal(results, "row3 field 0 = e", Str.string_equals(C.csv_row_field_at(row3, 0), "e"), 1)
    Let row4 be C.csv_iterator_next(it)
    T.assert_equal(results, "row4 is null (EOF)", row4, 0)
    T.assert_equal(results, "no error", C.csv_iterator_has_error(it), 0)
    C.csv_iterator_destroy(it)
    Return 1
End Process

Note: ============================================================================
Note: MAIN
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_parse_rfc4180_example(results)
    test_parse_quoted_field(results)
    test_parse_double_quote_escape(results)
    test_parse_embedded_newline(results)
    test_parse_empty_field(results)
    test_parse_lf_only(results)
    test_parse_tsv(results)
    test_serialize_roundtrip(results)
    test_serialize_quote_when_needed(results)
    test_serialize_escape_quote(results)
    test_iterator_basic(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
