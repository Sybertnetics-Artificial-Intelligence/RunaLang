Note:
Unit tests for compiler/frontend/primitives/format/ini.runa.

Covers a standard INI document with sections, ';' and '#' comments,
continuation lines and quoted values.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/format/ini.runa" as I
Import "compiler/frontend/primitives/core/string_core.runa" as Str

Note: ============================================================================
Note: STANDARD INI
Note: ============================================================================

Process called "test_parse_basic_section" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_basic_section")
    Let input be "[server]\nhost=localhost\nport=8080\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    T.assert_equal(results, "1 section", I.ini_document_section_count(doc), 1)
    Let sec be I.ini_document_section_at(doc, 0)
    T.assert_equal(results, "section name is server", Str.string_equals(I.ini_section_name(sec), "server"), 1)
    T.assert_equal(results, "2 entries", I.ini_section_entry_count(sec), 2)
    T.assert_equal(results, "host=localhost", Str.string_equals(I.ini_section_get(sec, "host"), "localhost"), 1)
    T.assert_equal(results, "port=8080", Str.string_equals(I.ini_section_get(sec, "port"), "8080"), 1)
    Return 1
End Process

Process called "test_parse_semicolon_comment" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_semicolon_comment")
    Let input be "; comment\n[s]\nkey=value\n; trailing\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    T.assert_equal(results, "1 section", I.ini_document_section_count(doc), 1)
    Let sec be I.ini_document_section_at(doc, 0)
    T.assert_equal(results, "key value preserved", Str.string_equals(I.ini_section_get(sec, "key"), "value"), 1)
    Return 1
End Process

Process called "test_parse_hash_comment" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_hash_comment")
    Let input be "# comment\n[s]\nkey=value\n# trailing\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    Let sec be I.ini_document_section_at(doc, 0)
    T.assert_equal(results, "key value preserved", Str.string_equals(I.ini_section_get(sec, "key"), "value"), 1)
    Return 1
End Process

Process called "test_parse_inline_comment_trim" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_inline_comment_trim")
    Let input be "[s]\nkey=value ; trailing comment\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    Let sec be I.ini_document_section_at(doc, 0)
    T.assert_equal(results, "comment stripped", Str.string_equals(I.ini_section_get(sec, "key"), "value"), 1)
    Return 1
End Process

Process called "test_parse_toplevel_keys" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_toplevel_keys")
    Let input be "global=true\n[s]\nlocal=false\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    Let tl be I.ini_document_toplevel(doc)
    T.assert_equal(results, "toplevel present", tl is not equal to 0, 1)
    T.assert_equal(results, "global=true", Str.string_equals(I.ini_section_get(tl, "global"), "true"), 1)
    Let sec be I.ini_document_section_at(doc, 0)
    T.assert_equal(results, "local=false", Str.string_equals(I.ini_section_get(sec, "local"), "false"), 1)
    Return 1
End Process

Process called "test_parse_quoted_value_double" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_quoted_value_double")
    Let input be "[s]\nkey=\"  spaced  \"\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    Let sec be I.ini_document_section_at(doc, 0)
    Let v be I.ini_section_get(sec, "key")
    T.assert_equal(results, "value preserves spaces", Str.string_equals(v, "  spaced  "), 1)
    Return 1
End Process

Process called "test_parse_quoted_value_single" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_quoted_value_single")
    Let input be "[s]\nkey='literal \\n bytes'\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    Let sec be I.ini_document_section_at(doc, 0)
    Let v be I.ini_section_get(sec, "key")
    Note: Single-quoted is literal: backslash and n are taken as-is.
    T.assert_equal(results, "single quote literal", Str.string_equals(v, "literal \\n bytes"), 1)
    Return 1
End Process

Process called "test_parse_quoted_escape" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_quoted_escape")
    Let input be "[s]\nkey=\"line1\\nline2\"\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    Let sec be I.ini_document_section_at(doc, 0)
    Let v be I.ini_section_get(sec, "key")
    T.assert_equal(results, "length is 11", Str.string_length(v), 11)
    T.assert_equal(results, "byte 5 is LF", Str.string_char_at(v, 5), 10)
    Return 1
End Process

Process called "test_parse_continuation" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_continuation")
    Note: Trailing backslash joins to next line.
    Let input be "[s]\nkey=line1 \\\n     line2\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    Let sec be I.ini_document_section_at(doc, 0)
    Let v be I.ini_section_get(sec, "key")
    Note: After continuation, the second line's leading whitespace is included
    Note: but the key=value trim removes the trailing whitespace from the
    Note: joined logical line.
    T.assert_equal(results, "value contains line1", Str.string_length(v) is greater than 4, 1)
    Return 1
End Process

Process called "test_parse_subsection_dotted" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_subsection_dotted")
    Let input be "[parent.child]\nkey=value\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    Let sec be I.ini_document_section_at(doc, 0)
    T.assert_equal(results, "section name parent.child", Str.string_equals(I.ini_section_name(sec), "parent.child"), 1)
    T.assert_equal(results, "parent is recorded", Str.string_equals(I.ini_section_parent(sec), "parent"), 1)
    Return 1
End Process

Process called "test_parse_two_sections" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_two_sections")
    Let input be "[alpha]\na=1\n[beta]\nb=2\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    T.assert_equal(results, "2 sections", I.ini_document_section_count(doc), 2)
    Let s_alpha be I.ini_document_find_section(doc, "alpha")
    Let s_beta be I.ini_document_find_section(doc, "beta")
    T.assert_equal(results, "alpha found", s_alpha is not equal to 0, 1)
    T.assert_equal(results, "beta found", s_beta is not equal to 0, 1)
    T.assert_equal(results, "alpha.a=1", Str.string_equals(I.ini_section_get(s_alpha, "a"), "1"), 1)
    T.assert_equal(results, "beta.b=2", Str.string_equals(I.ini_section_get(s_beta, "b"), "2"), 1)
    Return 1
End Process

Process called "test_parse_colon_assign" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.parse_colon_assign")
    Note: Many INI dialects allow ':' instead of '=' (e.g. Java properties).
    Let input be "[s]\nkey: value\n"
    Let r be I.ini_parse(input)
    T.assert_equal(results, "result is Ok", I.ini_result_is_ok(r), 1)
    Let doc be I.ini_result_payload(r)
    Let sec be I.ini_document_section_at(doc, 0)
    T.assert_equal(results, "colon-assigned", Str.string_equals(I.ini_section_get(sec, "key"), "value"), 1)
    Return 1
End Process

Note: ============================================================================
Note: SERIALIZE
Note: ============================================================================

Process called "test_serialize_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.serialize_roundtrip")
    Let doc be I.ini_document_create()
    Let sec be I.ini_section_create("server")
    I.ini_section_set(sec, "host", "localhost")
    I.ini_section_set(sec, "port", "8080")
    I.ini_document_append_section(doc, sec)
    Let dialect be I.ini_dialect_create()
    I.ini_dialect_set_line_endings(dialect, 1)
    Let out be I.ini_serialize(doc, dialect)
    T.assert_equal(results, "expected layout", Str.string_equals(out, "[server]\nhost=localhost\nport=8080\n"), 1)
    I.ini_dialect_destroy(dialect)
    Return 1
End Process

Process called "test_serialize_quote_needed" that takes results as Integer returns Integer:
    T.begin_suite(results, "ini.serialize_quote_needed")
    Let doc be I.ini_document_create()
    Let sec be I.ini_section_create("s")
    I.ini_section_set(sec, "name", "  spaced  ")
    I.ini_document_append_section(doc, sec)
    Let dialect be I.ini_dialect_create()
    I.ini_dialect_set_line_endings(dialect, 1)
    Let out be I.ini_serialize(doc, dialect)
    T.assert_equal(results, "value is quoted", Str.string_equals(out, "[s]\nname=\"  spaced  \"\n"), 1)
    I.ini_dialect_destroy(dialect)
    Return 1
End Process

Note: ============================================================================
Note: MAIN
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_parse_basic_section(results)
    test_parse_semicolon_comment(results)
    test_parse_hash_comment(results)
    test_parse_inline_comment_trim(results)
    test_parse_toplevel_keys(results)
    test_parse_quoted_value_double(results)
    test_parse_quoted_value_single(results)
    test_parse_quoted_escape(results)
    test_parse_continuation(results)
    test_parse_subsection_dotted(results)
    test_parse_two_sections(results)
    test_parse_colon_assign(results)
    test_serialize_roundtrip(results)
    test_serialize_quote_needed(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
