Note:
Known-answer tests for compiler/frontend/primitives/numeric/integer/biginteger.runa.

Coverage:
- Construction from Integer, sign handling
- Addition / subtraction / negation across sign boundaries
- Multiplication: small values plus a Karatsuba-threshold case
- Division and modulo, including quotient-remainder pairing
- GCD, LCM, integer pow, modular exponentiation, modular inverse, sqrt
- Decimal string round-trip
- Hex string round-trip
- Comparison
- Miller-Rabin primality on known primes and composites
- bit_length, shift left / shift right
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/integer/biginteger.runa" as BI

Note: ============================================================================
Note: Construction and basic conversion
Note: ============================================================================

Process called "test_bigint_construction" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.construction")
    Let a be BI.bigint_from_int64(0)
    T.assert_equal(results, "bigint_from_int64(0) is_zero", BI.bigint_is_zero(a), 1)
    BI.bigint_free(a)

    Let b be BI.bigint_from_int64(42)
    T.assert_equal(results, "from(42) sign = +1", BI.bigint_get_sign(b), 1)
    T.assert_equal(results, "from(42) limb count = 1", BI.bigint_get_limb_count(b), 1)
    T.assert_equal(results, "from(42) limb[0] = 42", BI.bigint_get_limb(b, 0), 42)

    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)
    Let v be BI.bigint_to_int64(b, status_buf)
    T.assert_equal(results, "to_int64(42) = 42", v, 42)
    BI.bigint_free(b)

    Let neg be BI.bigint_from_int64(-1000)
    T.assert_equal(results, "from(-1000) sign = -1", BI.bigint_get_sign(neg), -1)
    Let v2 be BI.bigint_to_int64(neg, status_buf)
    T.assert_equal(results, "to_int64(-1000) = -1000", v2, -1000)
    BI.bigint_free(neg)

    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: Addition / subtraction
Note: ============================================================================

Process called "test_bigint_add_sub" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.add_sub")

    Let a be BI.bigint_from_int64(123456789)
    Let b be BI.bigint_from_int64(987654321)
    Let sum be BI.bigint_add(a, b)
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)
    Let sum_val be BI.bigint_to_int64(sum, status_buf)
    T.assert_equal(results, "123456789 + 987654321 = 1111111110", sum_val, 1111111110)
    BI.bigint_free(sum)

    Let diff be BI.bigint_sub(b, a)
    Let diff_val be BI.bigint_to_int64(diff, status_buf)
    T.assert_equal(results, "987654321 - 123456789 = 864197532", diff_val, 864197532)
    BI.bigint_free(diff)

    Let neg_diff be BI.bigint_sub(a, b)
    Let neg_diff_val be BI.bigint_to_int64(neg_diff, status_buf)
    T.assert_equal(results, "123456789 - 987654321 = -864197532", neg_diff_val, -864197532)
    BI.bigint_free(neg_diff)

    Let n_a be BI.bigint_from_int64(-50)
    Let n_b be BI.bigint_from_int64(30)
    Let mixed be BI.bigint_add(n_a, n_b)
    Let mixed_val be BI.bigint_to_int64(mixed, status_buf)
    T.assert_equal(results, "-50 + 30 = -20", mixed_val, -20)
    BI.bigint_free(mixed)

    BI.bigint_free(a)
    BI.bigint_free(b)
    BI.bigint_free(n_a)
    BI.bigint_free(n_b)
    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: Multiplication
Note: ============================================================================

Process called "test_bigint_mul" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.mul")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Let a be BI.bigint_from_int64(123456)
    Let b be BI.bigint_from_int64(7890)
    Let prod be BI.bigint_mul(a, b)
    Let prod_val be BI.bigint_to_int64(prod, status_buf)
    T.assert_equal(results, "123456 * 7890 = 974067840", prod_val, 974067840)
    BI.bigint_free(prod)

    Let neg_a be BI.bigint_from_int64(-100)
    Let pos_b be BI.bigint_from_int64(50)
    Let neg_prod be BI.bigint_mul(neg_a, pos_b)
    Let neg_prod_val be BI.bigint_to_int64(neg_prod, status_buf)
    T.assert_equal(results, "-100 * 50 = -5000", neg_prod_val, -5000)
    BI.bigint_free(neg_prod)

    Let zero be BI.bigint_from_int64(0)
    Let zero_prod be BI.bigint_mul(a, zero)
    T.assert_equal(results, "x * 0 = 0", BI.bigint_is_zero(zero_prod), 1)
    BI.bigint_free(zero_prod)
    BI.bigint_free(zero)

    BI.bigint_free(a)
    BI.bigint_free(b)
    BI.bigint_free(neg_a)
    BI.bigint_free(pos_b)
    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: Division
Note: ============================================================================

Process called "test_bigint_divmod" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.divmod")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)
    Let rem_holder be allocate(8)
    __store(rem_holder, 0, 0)

    Let a be BI.bigint_from_int64(100)
    Let b be BI.bigint_from_int64(7)
    Let q be BI.bigint_divmod(a, b, rem_holder)
    Let r be __load(rem_holder, 0)

    Let q_val be BI.bigint_to_int64(q, status_buf)
    Let r_val be BI.bigint_to_int64(r, status_buf)
    T.assert_equal(results, "100 / 7 = 14", q_val, 14)
    T.assert_equal(results, "100 % 7 = 2", r_val, 2)
    BI.bigint_free(q)
    BI.bigint_free(r)

    Let neg_a be BI.bigint_from_int64(-100)
    __store(rem_holder, 0, 0)
    Let nq be BI.bigint_divmod(neg_a, b, rem_holder)
    Let nr be __load(rem_holder, 0)
    Let nq_val be BI.bigint_to_int64(nq, status_buf)
    Let nr_val be BI.bigint_to_int64(nr, status_buf)
    T.assert_equal(results, "-100 / 7 = -14", nq_val, -14)
    T.assert_equal(results, "-100 %% 7 = -2", nr_val, -2)
    BI.bigint_free(nq)
    BI.bigint_free(nr)

    BI.bigint_free(a)
    BI.bigint_free(b)
    BI.bigint_free(neg_a)
    deallocate(rem_holder)
    deallocate(status_buf)
    Return 1
End Process

