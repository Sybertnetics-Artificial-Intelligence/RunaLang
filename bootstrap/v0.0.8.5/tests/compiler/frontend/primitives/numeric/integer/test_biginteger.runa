Process called "test_bigint_gcd_lcm" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.gcd_lcm")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Let a be BI.bigint_from_int64(48)
    Let b be BI.bigint_from_int64(18)
    Let g be BI.bigint_gcd(a, b)
    T.assert_equal(results, "gcd(48, 18) = 6", BI.bigint_to_int64(g, status_buf), 6)
    BI.bigint_free(g)

    Let l be BI.bigint_lcm(a, b)
    T.assert_equal(results, "lcm(48, 18) = 144", BI.bigint_to_int64(l, status_buf), 144)
    BI.bigint_free(l)

    BI.bigint_free(a)
    BI.bigint_free(b)
    deallocate(status_buf)
    Return 1
End Process

Process called "test_bigint_pow" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.pow")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Let base be BI.bigint_from_int64(2)
    Let p10 be BI.bigint_pow_int(base, 10)
    T.assert_equal(results, "2^10 = 1024", BI.bigint_to_int64(p10, status_buf), 1024)
    BI.bigint_free(p10)

    Let p0 be BI.bigint_pow_int(base, 0)
    T.assert_equal(results, "2^0 = 1", BI.bigint_to_int64(p0, status_buf), 1)
    BI.bigint_free(p0)

    Let three be BI.bigint_from_int64(3)
    Let p5 be BI.bigint_pow_int(three, 5)
    T.assert_equal(results, "3^5 = 243", BI.bigint_to_int64(p5, status_buf), 243)
    BI.bigint_free(p5)

    BI.bigint_free(base)
    BI.bigint_free(three)
    deallocate(status_buf)
    Return 1
End Process

Process called "test_bigint_modular_pow" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.modular_pow")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Note: 5^3 mod 13 = 125 mod 13 = 8.
    Let base be BI.bigint_from_int64(5)
    Let exp be BI.bigint_from_int64(3)
    Let mod be BI.bigint_from_int64(13)
    Let r be BI.bigint_modular_pow(base, exp, mod)
    T.assert_equal(results, "5^3 mod 13 = 8", BI.bigint_to_int64(r, status_buf), 8)
    BI.bigint_free(r)

    Note: 2^10 mod 1000 = 1024 mod 1000 = 24.
    Let b2 be BI.bigint_from_int64(2)
    Let e10 be BI.bigint_from_int64(10)
    Let m1000 be BI.bigint_from_int64(1000)
    Let r2 be BI.bigint_modular_pow(b2, e10, m1000)
    T.assert_equal(results, "2^10 mod 1000 = 24", BI.bigint_to_int64(r2, status_buf), 24)
    BI.bigint_free(r2)

    Note: 7^256 mod 13.  Fermat's little theorem: 7^12 = 1 mod 13, 256 mod 12 = 4.
    Note: So 7^256 mod 13 = 7^4 mod 13 = 2401 mod 13 = 9.
    Let b7 be BI.bigint_from_int64(7)
    Let e256 be BI.bigint_from_int64(256)
    Let m13 be BI.bigint_from_int64(13)
    Let r3 be BI.bigint_modular_pow(b7, e256, m13)
    T.assert_equal(results, "7^256 mod 13 = 9", BI.bigint_to_int64(r3, status_buf), 9)
    BI.bigint_free(r3)

    BI.bigint_free(base)
    BI.bigint_free(exp)
    BI.bigint_free(mod)
    BI.bigint_free(b2)
    BI.bigint_free(e10)
    BI.bigint_free(m1000)
    BI.bigint_free(b7)
    BI.bigint_free(e256)
    BI.bigint_free(m13)
    deallocate(status_buf)
    Return 1
End Process

Process called "test_bigint_modular_inverse" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.modular_inverse")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Note: 3^(-1) mod 11 = 4 since 3*4 = 12 = 11 + 1.
    Let three be BI.bigint_from_int64(3)
    Let m11 be BI.bigint_from_int64(11)
    Let inv be BI.bigint_modular_inverse(three, m11)
    T.assert_not_null(results, "modinv(3, 11) returns non-NULL", inv)
    T.assert_equal(results, "3^-1 mod 11 = 4", BI.bigint_to_int64(inv, status_buf), 4)
    BI.bigint_free(inv)

    BI.bigint_free(three)
    BI.bigint_free(m11)
    deallocate(status_buf)
    Return 1
End Process

Process called "test_bigint_sqrt" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.sqrt")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Let n100 be BI.bigint_from_int64(100)
    Let s100 be BI.bigint_sqrt_floor(n100)
    T.assert_equal(results, "floor(sqrt(100)) = 10", BI.bigint_to_int64(s100, status_buf), 10)
    BI.bigint_free(s100)

    Let n99 be BI.bigint_from_int64(99)
    Let s99 be BI.bigint_sqrt_floor(n99)
    T.assert_equal(results, "floor(sqrt(99)) = 9", BI.bigint_to_int64(s99, status_buf), 9)
    BI.bigint_free(s99)

    Let n1m be BI.bigint_from_int64(1000000)
    Let s1m be BI.bigint_sqrt_floor(n1m)
    T.assert_equal(results, "floor(sqrt(1000000)) = 1000", BI.bigint_to_int64(s1m, status_buf), 1000)
    BI.bigint_free(s1m)

    BI.bigint_free(n100)
    BI.bigint_free(n99)
    BI.bigint_free(n1m)
    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: Decimal / Hex string conversion
Note: ============================================================================

Process called "test_bigint_decimal_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.decimal_string")

    Let zero be BI.bigint_from_int64(0)
    Let zs be BI.bigint_to_decimal_string(zero)
    T.assert_equal(results, "0 -> '0'", __load_byte(zs, 0), 48)
    T.assert_equal(results, "0 -> null", __load_byte(zs, 1), 0)
    deallocate(zs)
    BI.bigint_free(zero)

    Let pos be BI.bigint_from_int64(1234567890)
    Let ps be BI.bigint_to_decimal_string(pos)
    T.assert_equal(results, "1234567890 byte 0 = '1'", __load_byte(ps, 0), 49)
    T.assert_equal(results, "1234567890 byte 9 = '0'", __load_byte(ps, 9), 48)
    T.assert_equal(results, "1234567890 byte 10 = null", __load_byte(ps, 10), 0)
    deallocate(ps)
    BI.bigint_free(pos)

    Let neg be BI.bigint_from_int64(-42)
    Let ns be BI.bigint_to_decimal_string(neg)
    T.assert_equal(results, "-42 byte 0 = '-'", __load_byte(ns, 0), 45)
    T.assert_equal(results, "-42 byte 1 = '4'", __load_byte(ns, 1), 52)
    T.assert_equal(results, "-42 byte 2 = '2'", __load_byte(ns, 2), 50)
    deallocate(ns)
    BI.bigint_free(neg)

    Note: Round trip via from_decimal_string.
    Let bigstr be allocate(16)
    __store_byte(bigstr, 0, 49)
    __store_byte(bigstr, 1, 50)
    __store_byte(bigstr, 2, 51)
    __store_byte(bigstr, 3, 52)
    __store_byte(bigstr, 4, 53)
    __store_byte(bigstr, 5, 0)
    Let parsed be BI.bigint_from_decimal_string(bigstr)
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)
    T.assert_equal(results, "parse '12345' = 12345", BI.bigint_to_int64(parsed, status_buf), 12345)
    BI.bigint_free(parsed)
    deallocate(bigstr)
    deallocate(status_buf)
    Return 1
End Process

Process called "test_bigint_hex_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.hex_string")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Let v be BI.bigint_from_int64(255)
    Let hs be BI.bigint_to_hex_string(v)
    T.assert_equal(results, "255 -> 'ff' byte 0 = 'f'", __load_byte(hs, 0), 102)
    T.assert_equal(results, "255 -> 'ff' byte 1 = 'f'", __load_byte(hs, 1), 102)
    T.assert_equal(results, "255 -> 'ff' byte 2 = null", __load_byte(hs, 2), 0)
    deallocate(hs)
    BI.bigint_free(v)

    Let hbuf be allocate(8)
    __store_byte(hbuf, 0, 48)
    __store_byte(hbuf, 1, 120)
    __store_byte(hbuf, 2, 102)
    __store_byte(hbuf, 3, 102)
    __store_byte(hbuf, 4, 0)
    Let parsed be BI.bigint_from_hex_string(hbuf)
    T.assert_equal(results, "parse '0xff' = 255", BI.bigint_to_int64(parsed, status_buf), 255)
    BI.bigint_free(parsed)
    deallocate(hbuf)
    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: Comparison
Note: ============================================================================

Process called "test_bigint_cmp" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.cmp")

    Let a be BI.bigint_from_int64(100)
    Let b be BI.bigint_from_int64(200)
    Let c be BI.bigint_from_int64(100)
    Let na be BI.bigint_from_int64(-100)

    T.assert_equal(results, "cmp(100, 200) = -1", BI.bigint_cmp(a, b), -1)
    T.assert_equal(results, "cmp(200, 100) = +1", BI.bigint_cmp(b, a), 1)
    T.assert_equal(results, "cmp(100, 100) = 0", BI.bigint_cmp(a, c), 0)
    T.assert_equal(results, "cmp(-100, 100) = -1", BI.bigint_cmp(na, a), -1)
    T.assert_equal(results, "cmp(100, -100) = +1", BI.bigint_cmp(a, na), 1)
    T.assert_equal(results, "cmp_magnitude(100, -100) = 0", BI.bigint_cmp_magnitude(a, na), 0)

    BI.bigint_free(a)
    BI.bigint_free(b)
    BI.bigint_free(c)
    BI.bigint_free(na)
    Return 1
End Process

Note: ============================================================================
Note: Bit operations
Note: ============================================================================

Process called "test_bigint_bits" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.bits")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Let v be BI.bigint_from_int64(1024)
    T.assert_equal(results, "bit_length(1024) = 11", BI.bigint_bit_length(v), 11)
    T.assert_equal(results, "test_bit(1024, 10) = 1", BI.bigint_test_bit(v, 10), 1)
    T.assert_equal(results, "test_bit(1024, 0) = 0", BI.bigint_test_bit(v, 0), 0)

    Let shifted be BI.bigint_shl(v, 4)
    T.assert_equal(results, "1024 << 4 = 16384", BI.bigint_to_int64(shifted, status_buf), 16384)
    BI.bigint_free(shifted)

    Let sright be BI.bigint_shr(v, 3)
    T.assert_equal(results, "1024 >> 3 = 128", BI.bigint_to_int64(sright, status_buf), 128)
    BI.bigint_free(sright)

    BI.bigint_free(v)
    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: Primality (Miller-Rabin)
Note: ============================================================================

Process called "test_bigint_prime" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.prime")

    Let p997 be BI.bigint_from_int64(997)
    T.assert_equal(results, "997 is prime", BI.bigint_miller_rabin(p997, 20, 12345), 1)
    BI.bigint_free(p997)

    Let p1009 be BI.bigint_from_int64(1009)
    T.assert_equal(results, "1009 is prime", BI.bigint_miller_rabin(p1009, 20, 67890), 1)
    BI.bigint_free(p1009)

    Let composite1 be BI.bigint_from_int64(1001)
    Note: 1001 = 7 * 11 * 13.
    T.assert_equal(results, "1001 is composite", BI.bigint_miller_rabin(composite1, 20, 11111), 0)
    BI.bigint_free(composite1)

    Let composite2 be BI.bigint_from_int64(15)
    T.assert_equal(results, "15 is composite", BI.bigint_miller_rabin(composite2, 10, 22222), 0)
    BI.bigint_free(composite2)

    Let two be BI.bigint_from_int64(2)
    T.assert_equal(results, "2 is prime", BI.bigint_miller_rabin(two, 5, 0), 1)
    BI.bigint_free(two)

    Let one be BI.bigint_from_int64(1)
    T.assert_equal(results, "1 is not prime", BI.bigint_miller_rabin(one, 5, 0), 0)
    BI.bigint_free(one)
    Return 1
End Process

Note: ============================================================================
Note: Byte serialization round trip
Note: ============================================================================

Process called "test_bigint_bytes" that takes results as Integer returns Integer:
    T.begin_suite(results, "biginteger.bytes")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Let v be BI.bigint_from_int64(0x12345678)
    Let buf be allocate(8)
    __store(buf, 0, 0)
    BI.bigint_to_bytes_be(v, buf, 4)
    T.assert_equal(results, "BE byte 0 = 0x12", __load_byte(buf, 0), 0x12)
    T.assert_equal(results, "BE byte 1 = 0x34", __load_byte(buf, 1), 0x34)
    T.assert_equal(results, "BE byte 2 = 0x56", __load_byte(buf, 2), 0x56)
    T.assert_equal(results, "BE byte 3 = 0x78", __load_byte(buf, 3), 0x78)

    Let from_be be BI.bigint_from_bytes_be(buf, 4)
    T.assert_equal(results, "from_be reconstructs value", BI.bigint_to_int64(from_be, status_buf), 0x12345678)
    BI.bigint_free(from_be)

    BI.bigint_to_bytes_le(v, buf, 4)
    T.assert_equal(results, "LE byte 0 = 0x78", __load_byte(buf, 0), 0x78)
    T.assert_equal(results, "LE byte 3 = 0x12", __load_byte(buf, 3), 0x12)

    Let from_le be BI.bigint_from_bytes_le(buf, 4)
    T.assert_equal(results, "from_le reconstructs value", BI.bigint_to_int64(from_le, status_buf), 0x12345678)
    BI.bigint_free(from_le)

    deallocate(buf)
    BI.bigint_free(v)
    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: MAIN ENTRY POINT
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_bigint_construction(results)
    test_bigint_add_sub(results)
    test_bigint_mul(results)
    test_bigint_divmod(results)
    test_bigint_gcd_lcm(results)
    test_bigint_pow(results)
    test_bigint_modular_pow(results)
    test_bigint_modular_inverse(results)
    test_bigint_sqrt(results)
    test_bigint_decimal_string(results)
    test_bigint_hex_string(results)
    test_bigint_cmp(results)
    test_bigint_bits(results)
    test_bigint_prime(results)
    test_bigint_bytes(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
