    test_uint8_arithmetic(results)
    test_int16_boundaries(results)
    test_int16_bitwise(results)
    test_int32_arithmetic(results)
    test_uint32_mul_overflow(results)
    test_int64_checked(results)
    test_pack_unpack_roundtrip(results)
    test_popcount(results)
    test_clz_ctz(results)
    test_bit_manipulate(results)
