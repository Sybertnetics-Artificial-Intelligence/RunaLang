    test_int_decimal_string(results)
    test_int_hex_string(results)
    test_uint64_arithmetic(results)
    test_int128_arithmetic(results)
    test_conversions(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
