Note:
Known-answer tests for compiler/frontend/primitives/numeric/integer/int_widths.runa.

Coverage:
- Arithmetic correctness at every width (Int8, Int16, Int32, Int64, UInt8,
  UInt16, UInt32, UInt64)
- Overflow / underflow boundaries and checked-variant status reporting
- Bitwise operations: AND, OR, XOR, NOT, shifts, rotations
- Pack / unpack round-trip in both big-endian and little-endian
- Population count, leading-zero count, trailing-zero count
- Bit set / clear / test / reverse
- Comparison: eq, ne, lt, le, gt, ge
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/integer/int_widths.runa" as IW

Note: ============================================================================
Note: Int8 / UInt8 arithmetic
Note: ============================================================================

Process called "test_int8_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int8.arithmetic")
    T.assert_equal(results, "int8_add 50+50=100", IW.int8_add(50, 50), 100)
    T.assert_equal(results, "int8_add 100+50 wraps to -106", IW.int8_add(100, 50), -106)
    T.assert_equal(results, "int8_sub -100-50 wraps", IW.int8_sub(-100, 50), 106)
    T.assert_equal(results, "int8_mul 16*8=-128 wrap", IW.int8_mul(16, 8), -128)
    T.assert_equal(results, "int8_mul 12*12=-112 wrap", IW.int8_mul(12, 12), -112)
    T.assert_equal(results, "int8_div -128/-1 wraps to -128", IW.int8_div(-128, -1), -128)
    T.assert_equal(results, "int8_div 10/3=3", IW.int8_div(10, 3), 3)
    T.assert_equal(results, "int8_mod 10%3=1", IW.int8_mod(10, 3), 1)
    T.assert_equal(results, "int8_mod -10%3=-1", IW.int8_mod(-10, 3), -1)
    T.assert_equal(results, "int8_neg -128 stays -128", IW.int8_neg(-128), -128)
    T.assert_equal(results, "int8_abs -50=50", IW.int8_abs(-50), 50)
    T.assert_equal(results, "int8_min 5,-7=-7", IW.int8_min(5, -7), -7)
    T.assert_equal(results, "int8_max 5,-7=5", IW.int8_max(5, -7), 5)
    T.assert_equal(results, "int8_clamp 200 in [0,100]=100", IW.int8_clamp(200, 0, 100), 100)
    T.assert_equal(results, "int8_clamp -200 in [0,100]=0", IW.int8_clamp(-200, 0, 100), 0)
    T.assert_equal(results, "int8_clamp 50 in [0,100]=50", IW.int8_clamp(50, 0, 100), 50)
    Return 1
End Process

Process called "test_int8_checked" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int8.checked")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    IW.int8_add_checked(100, 50, status_buf)
    T.assert_equal(results, "add 100+50 reports OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    IW.int8_add_checked(50, 50, status_buf)
    T.assert_equal(results, "add 50+50 reports OK", __load(status_buf, 0), IW.CHECKED_OK)

    IW.int8_sub_checked(-100, 100, status_buf)
    T.assert_equal(results, "sub -100-100 reports UNDERFLOW", __load(status_buf, 0), IW.CHECKED_UNDERFLOW)

    IW.int8_mul_checked(16, 8, status_buf)
    T.assert_equal(results, "mul 16*8 reports OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    IW.int8_div_checked(10, 0, status_buf)
    T.assert_equal(results, "div 10/0 reports DIVZERO", __load(status_buf, 0), IW.CHECKED_DIVZERO)

    IW.int8_div_checked(-128, -1, status_buf)
    T.assert_equal(results, "div INT8_MIN/-1 reports OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    deallocate(status_buf)
    Return 1
End Process

Process called "test_int8_bitwise" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int8.bitwise")
    T.assert_equal(results, "int8_and 0x0F & 0x33 = 0x03", IW.int8_and(15, 51), 3)
    T.assert_equal(results, "int8_or  0x0F | 0x30 = 0x3F", IW.int8_or(15, 48), 63)
    T.assert_equal(results, "int8_xor 0x55 ^ 0xAA = -1", IW.int8_xor(85, -86), -1)
    T.assert_equal(results, "int8_not 0 = -1", IW.int8_not(0), -1)
    T.assert_equal(results, "int8_not -1 = 0", IW.int8_not(-1), 0)
    T.assert_equal(results, "int8_shl 1<<4=16", IW.int8_shl(1, 4), 16)
    T.assert_equal(results, "int8_shl 1<<7=-128", IW.int8_shl(1, 7), -128)
    T.assert_equal(results, "int8_shr -128>>4 = -8", IW.int8_shr(-128, 4), -8)
    T.assert_equal(results, "int8_rotl 0x80 rot 1 = 0x01", IW.int8_rotl(-128, 1), 1)
    T.assert_equal(results, "int8_rotr 1 rot 1 = -128 (0x80)", IW.int8_rotr(1, 1), -128)
    Return 1
End Process

Process called "test_uint8_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.uint8.arithmetic")
    T.assert_equal(results, "uint8_add 100+200 wraps to 44", IW.uint8_add(100, 200), 44)
    T.assert_equal(results, "uint8_sub 10-20 wraps to 246", IW.uint8_sub(10, 20), 246)
    T.assert_equal(results, "uint8_mul 16*16=0 wrap", IW.uint8_mul(16, 16), 0)
    T.assert_equal(results, "uint8_div 200/3 = 66", IW.uint8_div(200, 3), 66)
    T.assert_equal(results, "uint8_mod 200%3 = 2", IW.uint8_mod(200, 3), 2)

    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)
    IW.uint8_add_checked(200, 100, status_buf)
    T.assert_equal(results, "uint8 add 200+100 reports OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)
    IW.uint8_sub_checked(10, 20, status_buf)
    T.assert_equal(results, "uint8 sub 10-20 reports UNDERFLOW", __load(status_buf, 0), IW.CHECKED_UNDERFLOW)
    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: Int16 / UInt16 boundaries and bitwise
Note: ============================================================================

Process called "test_int16_boundaries" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int16.boundaries")
    T.assert_equal(results, "int16_truncate 65536=0", IW.int16_truncate(65536), 0)
    T.assert_equal(results, "int16_truncate 32768=-32768", IW.int16_truncate(32768), -32768)
    T.assert_equal(results, "int16_add 32000+1000 wraps", IW.int16_add(32000, 1000), -32536)
    T.assert_equal(results, "int16_mul 200*200=40000 wraps", IW.int16_mul(200, 200), -25536)
    T.assert_equal(results, "uint16_add 60000+10000 wraps to 4464", IW.uint16_add(60000, 10000), 4464)

    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)
    IW.int16_add_checked(32000, 1000, status_buf)
    T.assert_equal(results, "int16 add 32000+1000 OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)
    deallocate(status_buf)
    Return 1
End Process

Process called "test_int16_bitwise" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int16.bitwise")
    T.assert_equal(results, "int16_and 0xFF00 & 0x0FF0 = 0x0F00", IW.int16_and(-256, 4080), 3840)
    T.assert_equal(results, "int16_shl 1<<15=-32768", IW.int16_shl(1, 15), -32768)
    T.assert_equal(results, "int16_rotl 0x8000 rot 1 = 1", IW.int16_rotl(-32768, 1), 1)
    Return 1
End Process

Note: ============================================================================
Note: Int32 / UInt32 boundaries and large-value behaviour
Note: ============================================================================

Process called "test_int32_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int32.arithmetic")
    T.assert_equal(results, "int32_truncate INT32_MAX+1 -> INT32_MIN", IW.int32_truncate(2147483648), -2147483648)
    T.assert_equal(results, "int32_add 2000000000+200000000 OK", IW.int32_add(2000000000, 200000000), -2094967296)

    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)
    IW.int32_add_checked(2000000000, 200000000, status_buf)
    T.assert_equal(results, "int32 add 2e9+2e8 OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    IW.int32_mul_checked(100000, 100000, status_buf)
    T.assert_equal(results, "int32 mul 100000*100000 OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    IW.int32_div_checked(-2147483648, -1, status_buf)
    T.assert_equal(results, "int32 div INT32_MIN/-1 OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)
    deallocate(status_buf)
    Return 1
End Process

Process called "test_uint32_mul_overflow" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.uint32.mul_overflow")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    Note: 100000 * 50000 = 5e9 > UINT32_MAX (4.29e9) -> OVERFLOW
    IW.uint32_mul_checked(100000, 50000, status_buf)
    T.assert_equal(results, "uint32 mul 100000*50000 reports OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    Note: 1e6 * 5000 = 5e9 > UINT32_MAX -> OVERFLOW
    IW.uint32_mul_checked(1000000, 5000, status_buf)
    T.assert_equal(results, "uint32 mul 1e6*5000 reports OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    IW.uint32_mul_checked(70000, 70000, status_buf)
    T.assert_equal(results, "uint32 mul 7e4*7e4 OVERFLOW (4.9e9 > 4.29e9)", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: Int64 arithmetic and overflow detection
Note: ============================================================================

Process called "test_int64_checked" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int64.checked")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    IW.int64_add_checked(IW.INT64_MAX, 1, status_buf)
    T.assert_equal(results, "int64 add INT64_MAX+1 OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    IW.int64_add_checked(IW.INT64_MIN, -1, status_buf)
    T.assert_equal(results, "int64 add INT64_MIN-1 UNDERFLOW", __load(status_buf, 0), IW.CHECKED_UNDERFLOW)

    IW.int64_sub_checked(IW.INT64_MAX, -1, status_buf)
    T.assert_equal(results, "int64 sub INT64_MAX - -1 OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    IW.int64_mul_checked(IW.INT64_MIN, -1, status_buf)
    T.assert_equal(results, "int64 mul INT64_MIN*-1 OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    IW.int64_div_checked(5, 0, status_buf)
    T.assert_equal(results, "int64 div /0 DIVZERO", __load(status_buf, 0), IW.CHECKED_DIVZERO)

    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: Pack / unpack round-trip across all widths
Note: ============================================================================

Process called "test_pack_unpack_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.pack_unpack")
    Let buf be allocate(16)

    IW.int8_pack_be(-42, buf)
    T.assert_equal(results, "int8 BE round-trip -42", IW.int8_unpack_be(buf), -42)
    IW.int8_pack_le(-42, buf)
    T.assert_equal(results, "int8 LE round-trip -42", IW.int8_unpack_le(buf), -42)

    IW.int16_pack_be(-12345, buf)
    T.assert_equal(results, "int16 BE high byte", __load_byte(buf, 0), 207)
    T.assert_equal(results, "int16 BE round-trip -12345", IW.int16_unpack_be(buf), -12345)
    IW.int16_pack_le(-12345, buf)
    T.assert_equal(results, "int16 LE round-trip -12345", IW.int16_unpack_le(buf), -12345)

    IW.int32_pack_be(-123456789, buf)
    T.assert_equal(results, "int32 BE round-trip", IW.int32_unpack_be(buf), -123456789)
    IW.int32_pack_le(-123456789, buf)
    T.assert_equal(results, "int32 LE round-trip", IW.int32_unpack_le(buf), -123456789)

    IW.int64_pack_be(-1234567890123, buf)
    T.assert_equal(results, "int64 BE round-trip", IW.int64_unpack_be(buf), -1234567890123)
    IW.int64_pack_le(-1234567890123, buf)
    T.assert_equal(results, "int64 LE round-trip", IW.int64_unpack_le(buf), -1234567890123)

    IW.uint16_pack_be(0xABCD, buf)
    T.assert_equal(results, "uint16 BE 0xABCD high byte", __load_byte(buf, 0), 0xAB)
    T.assert_equal(results, "uint16 BE 0xABCD low byte", __load_byte(buf, 1), 0xCD)
    IW.uint32_pack_le(0xDEADBEEF, buf)
    T.assert_equal(results, "uint32 LE 0xDEADBEEF byte 0", __load_byte(buf, 0), 0xEF)
    T.assert_equal(results, "uint32 LE 0xDEADBEEF byte 3", __load_byte(buf, 3), 0xDE)

    deallocate(buf)
    Return 1
End Process

Note: ============================================================================
Note: Bit manipulation: popcount, clz, ctz, set/clear/test/reverse
Note: ============================================================================

Process called "test_popcount" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.popcount")
    T.assert_equal(results, "popcount8(0xFF) = 8", IW.popcount8(255), 8)
    T.assert_equal(results, "popcount8(0x55) = 4", IW.popcount8(85), 4)
    T.assert_equal(results, "popcount16(0xFFFF) = 16", IW.popcount16(65535), 16)
    T.assert_equal(results, "popcount32(0xFFFFFFFF) = 32", IW.popcount32(IW.UINT32_MAX), 32)
    T.assert_equal(results, "popcount32(0xAAAAAAAA) = 16", IW.popcount32(2863311530), 16)
    T.assert_equal(results, "popcount64(-1) = 64", IW.popcount64(-1), 64)
    T.assert_equal(results, "popcount64(0) = 0", IW.popcount64(0), 0)
    T.assert_equal(results, "popcount64(1) = 1", IW.popcount64(1), 1)
    Return 1
End Process

Process called "test_clz_ctz" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.clz_ctz")
    T.assert_equal(results, "clz64(0) = 64", IW.clz64(0), 64)
    T.assert_equal(results, "clz64(1) = 63", IW.clz64(1), 63)
    T.assert_equal(results, "clz64(INT64_MAX) = 1", IW.clz64(IW.INT64_MAX), 1)
    T.assert_equal(results, "clz64(-1) = 0", IW.clz64(-1), 0)
    T.assert_equal(results, "ctz64(0) = 64", IW.ctz64(0), 64)
    T.assert_equal(results, "ctz64(1) = 0", IW.ctz64(1), 0)
    T.assert_equal(results, "ctz64(2) = 1", IW.ctz64(2), 1)
    T.assert_equal(results, "ctz64(8) = 3", IW.ctz64(8), 3)
    T.assert_equal(results, "clz32(1) = 31", IW.clz32(1), 31)
    T.assert_equal(results, "clz32(0) = 32", IW.clz32(0), 32)
    T.assert_equal(results, "ctz32(0) = 32", IW.ctz32(0), 32)
    T.assert_equal(results, "ctz32(8) = 3", IW.ctz32(8), 3)
    Return 1
End Process

Process called "test_bit_manipulate" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.bit_manipulate")
    T.assert_equal(results, "bit_set64(0, 0) = 1", IW.bit_set64(0, 0), 1)
    T.assert_equal(results, "bit_set64(0, 5) = 32", IW.bit_set64(0, 5), 32)
    T.assert_equal(results, "bit_clear64(255, 0) = 254", IW.bit_clear64(255, 0), 254)
    T.assert_equal(results, "bit_clear64(0xFF, 3) = 0xF7", IW.bit_clear64(255, 3), 247)
    T.assert_equal(results, "bit_test64(5, 0) = 1", IW.bit_test64(5, 0), 1)
    T.assert_equal(results, "bit_test64(5, 1) = 0", IW.bit_test64(5, 1), 0)
    T.assert_equal(results, "bit_test64(5, 2) = 1", IW.bit_test64(5, 2), 1)
    T.assert_equal(results, "bit_reverse8(1) = 0x80 = -128", IW.bit_reverse8(1), 128)
    T.assert_equal(results, "bit_reverse8(0x80) = 1", IW.bit_reverse8(128), 1)
    T.assert_equal(results, "bit_reverse32(1) = 0x80000000", IW.bit_reverse32(1), 2147483648)
    Return 1
End Process

Note: ============================================================================
Note: Comparison predicates
Note: ============================================================================

Process called "test_comparisons" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.comparisons")
    T.assert_equal(results, "int32_eq 5 5", IW.int32_eq(5, 5), 1)
    T.assert_equal(results, "int32_eq 5 6", IW.int32_eq(5, 6), 0)
    T.assert_equal(results, "int32_ne 5 6", IW.int32_ne(5, 6), 1)
    T.assert_equal(results, "int32_lt 5 6", IW.int32_lt(5, 6), 1)
    T.assert_equal(results, "int32_le 5 5", IW.int32_le(5, 5), 1)
    T.assert_equal(results, "int32_gt 7 5", IW.int32_gt(7, 5), 1)
    T.assert_equal(results, "int32_ge 5 5", IW.int32_ge(5, 5), 1)
    T.assert_equal(results, "uint32_lt 5 6", IW.uint32_lt(5, 6), 1)
    T.assert_equal(results, "uint32_gt 6 5", IW.uint32_gt(6, 5), 1)
    Return 1
End Process

Note: ============================================================================
Note: Decimal / Hex string conversion
Note: ============================================================================

Process called "test_int_decimal_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int_decimal_string")
    Let s be IW.int_to_decimal_string(12345)
    T.assert_equal(results, "12345 byte 0 ='1'", __load_byte(s, 0), 49)
    T.assert_equal(results, "12345 byte 4 ='5'", __load_byte(s, 4), 53)
    T.assert_equal(results, "12345 byte 5 = null", __load_byte(s, 5), 0)
    deallocate(s)

    Let s2 be IW.int_to_decimal_string(-42)
    T.assert_equal(results, "-42 byte 0 ='-'", __load_byte(s2, 0), 45)
    T.assert_equal(results, "-42 byte 1 ='4'", __load_byte(s2, 1), 52)
    T.assert_equal(results, "-42 byte 2 ='2'", __load_byte(s2, 2), 50)
    deallocate(s2)

    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)
    Let parsed be IW.int_from_decimal_string(s2, status_buf)
    Note: s2 was freed; skip that check.  Test with a fresh buffer.
    Let buf be allocate(8)
    __store_byte(buf, 0, 49)
    __store_byte(buf, 1, 50)
    __store_byte(buf, 2, 51)
    __store_byte(buf, 3, 0)
    Let val be IW.int_from_decimal_string(buf, status_buf)
    T.assert_equal(results, "parse '123' = 123", val, 123)
    T.assert_equal(results, "parse '123' status OK", __load(status_buf, 0), IW.CHECKED_OK)

    Let nbuf be allocate(8)
    __store_byte(nbuf, 0, 45)
    __store_byte(nbuf, 1, 53)
    __store_byte(nbuf, 2, 53)
    __store_byte(nbuf, 3, 0)
    Let nval be IW.int_from_decimal_string(nbuf, status_buf)
    T.assert_equal(results, "parse '-55' = -55", nval, -55)

    deallocate(buf)
    deallocate(nbuf)
    deallocate(status_buf)
    Return 1
End Process

Process called "test_int_hex_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int_hex_string")
    Let s be IW.int_to_hex_string(255)
    Note: 255 = 0xff renders as the 16-char zero-padded hex string
    Note: "00000000000000ff", so bytes 14 and 15 are both 'f' (= 102).
    T.assert_equal(results, "255 byte 13 = '0'", __load_byte(s, 13), 48)
    T.assert_equal(results, "255 byte 14 = 'f'", __load_byte(s, 14), 102)
    T.assert_equal(results, "255 byte 15 = 'f'", __load_byte(s, 15), 102)
    deallocate(s)

    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)
    Let hbuf be allocate(8)
    __store_byte(hbuf, 0, 48)
    __store_byte(hbuf, 1, 120)
    __store_byte(hbuf, 2, 102)
    __store_byte(hbuf, 3, 102)
    __store_byte(hbuf, 4, 0)
    Let parsed be IW.int_from_hex_string(hbuf, status_buf)
    T.assert_equal(results, "parse '0xff' = 255", parsed, 255)

    deallocate(hbuf)
    deallocate(status_buf)
    Return 1
End Process

Note: ============================================================================
Note: UInt64 / 128-bit limb buffer arithmetic
Note: ============================================================================

Process called "test_uint64_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.uint64.arithmetic")
    Let a be IW.uint64_from_int(1000000)
    Let b be IW.uint64_from_int(2000000)
    Let sum be IW.uint64_add(a, b)
    T.assert_equal(results, "uint64 add 1e6+2e6=3e6", IW.uint64_get_low(sum), 3000000)
    IW.uint64_free(sum)

    Let cmp be IW.uint64_compare(a, b)
    T.assert_equal(results, "uint64 cmp 1e6 < 2e6 = -1", cmp, -1)

    IW.uint64_free(a)
    IW.uint64_free(b)
    Return 1
End Process

Process called "test_int128_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.int128.arithmetic")
    Let a be IW.int128_from_int(100)
    Let b be IW.int128_from_int(200)
    Let sum be IW.int128_add(a, b)
    T.assert_equal(results, "int128 add 100+200=300", IW.int128_get_low(sum), 300)
    T.assert_equal(results, "int128 add high limb = 0", IW.int128_get_high(sum), 0)
    IW.int128_free(sum)

    Let neg be IW.int128_from_int(-50)
    T.assert_equal(results, "int128_is_negative(-50) = 1", IW.int128_is_negative(neg), 1)
    T.assert_equal(results, "int128_is_negative(100) = 0", IW.int128_is_negative(a), 0)

    Let diff be IW.int128_sub(a, b)
    T.assert_equal(results, "int128 sub 100-200=-100 low", IW.int128_get_low(diff), -100)
    IW.int128_free(diff)

    IW.int128_free(a)
    IW.int128_free(b)
    IW.int128_free(neg)
    Return 1
End Process

Note: ============================================================================
Note: Conversion checks
Note: ============================================================================

Process called "test_conversions" that takes results as Integer returns Integer:
    T.begin_suite(results, "int_widths.conversions")
    Let status_buf be allocate(8)
    __store(status_buf, 0, 0)

    IW.convert_int_to_int8_checked(1000, status_buf)
    T.assert_equal(results, "convert 1000 to int8 OVERFLOW", __load(status_buf, 0), IW.CHECKED_OVERFLOW)

    IW.convert_int_to_int8_checked(50, status_buf)
    T.assert_equal(results, "convert 50 to int8 OK", __load(status_buf, 0), IW.CHECKED_OK)

    IW.convert_int_to_uint8_checked(-5, status_buf)
    T.assert_equal(results, "convert -5 to uint8 UNDERFLOW", __load(status_buf, 0), IW.CHECKED_UNDERFLOW)

    IW.convert_int_to_uint32_checked(-1, status_buf)
    T.assert_equal(results, "convert -1 to uint32 UNDERFLOW", __load(status_buf, 0), IW.CHECKED_UNDERFLOW)

    deallocate(status_buf)
    Return 1
End Process

