Note:
Int256 KAT (Known Answer Test) suite. Verifies that the 256-bit
unsigned integer primitives produce bit-exact deterministic output
for all KAT vectors below. Determinism across platforms is the
critical property under test for consensus-grade arithmetic.

Coverage:
- Construction: allocate, set_zero, set_one, set_max, set_u64, copy
- Predicates: is_zero, is_max
- Comparison: compare on equal / less / greater across all limbs
- Arithmetic: add, add_checked (overflow flag), sub, sub_checked
              (underflow flag), wrapping at 2^256 boundary,
              two's-complement negation
- Multiplication: mul (wrapping), mul_checked (overflow detection),
                  mul_full (256x256 -> 512-bit), with the key vector
                  2^128 * 2^128 = 2^256 (sets high limb 0 of high-out
                  to 1, low-out is zero)
- Division: divmod (basic + non-trivial widths), error on /0
- Shifts: shift_left/right by 0, 1, 64, 65, 256, edge cases
- Bitwise: and, or, xor, not
- Byte serialization: round-trip hex / decimal / big-endian / little-endian
- Fixed-point operations: CRD-currency-style 18-decimal-place transfer of
                          1000.5 units, multiplication preserving scale,
                          division preserving scale

Exit code legend:
     0   All assertions passed.
    10   allocate returned 0 (out of memory).
    11   set_zero / is_zero round-trip failure.
    12   set_one did not produce value 1.
    13   set_max did not set all limbs to all-ones.
    14   set_u64 did not zero upper limbs.
    15   copy did not duplicate all 4 limbs.
    16   is_max false on max value.
    17   compare did not return 0 for equal values.
    18   compare did not return -1/1 correctly across high limbs.
    19   add 1 + 2 != 3.
    20   add carry across limb boundary failed.
    21   add wrap of (2^256-1) + 1 != 0.
    22   add_checked did not flag overflow on wrap.
    23   sub 5 - 3 != 2.
    24   sub wrap of 0 - 1 != (2^256 - 1).
    25   sub_checked did not flag underflow.
    26   negate_twos_complement of 1 != (2^256 - 1).
    27   negate_twos_complement applied twice != original.
    28   bit_and pattern mismatch.
    29   bit_or pattern mismatch.
    30   bit_xor pattern mismatch.
    31   bit_not pattern mismatch.
    32   shift_left by 0 changed value.
    33   shift_left by 1 of 5 != 10.
    34   shift_left by 64 did not move limb[0] to limb[1].
    35   shift_left by 65 did not produce expected partial-limb shift.
    36   shift_left by 255 did not place 1 at top of limb[3].
    37   shift_left by 256 did not zero result.
    38   shift_right by 64 did not move limb[1] to limb[0].
    39   shift_right by 1 of 100 != 50.
    40   divmod 100 / 7 != q=14, r=2.
    41   divmod by zero did not return INT256_ERR_DIVIDE_BY_ZERO.
    42   mul 3 * 7 != 21.
    43   mul wrap test (max * 2) did not produce expected wrap value.
    44   mul_checked did not flag overflow on max * 2.
    45   mul_full 2^128 * 2^128 != 2^256 (high[0]=1, low all zero).
    46   from_bytes_be / to_bytes_be round-trip failure.
    47   from_bytes_le / to_bytes_le round-trip failure.
    48   from_hex_string / to_hex_string round-trip failure on small value.
    49   from_hex_string of "0xff" != 255.
    50   to_hex_string of zero != "0".
    51   from_hex_string of empty string did not return error.
    52   from_hex_string of "g0" (invalid char) did not return error.
    53   from_decimal_string of "1000" != 1000.
    54   to_decimal_string of 1000 != "1000".
    55   to_decimal_string of zero != "0".
    56   from_decimal_string of "0" != 0.
    57   fixed_mul: 1.5 * 2.0 != 3.0 with scale 10^18.
    58   fixed_div: 3.0 / 2.0 != 1.5 with scale 10^18.
    59   fixed_mul: 1000.5 * 1 (CRD transfer) != 1000.5 with scale 10^18.
:End Note

Import "compiler/frontend/primitives/numeric/fixed/int256.runa" as Int256
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Process called "main" returns Integer:
    Let max_u64 be bitwise not 0

    Note: -----------------------------------------------------------------
    Note: Case 10: allocate returns non-zero
    Note: -----------------------------------------------------------------
    Let a be proc int256_allocate from Int256
    If a is equal to 0:
        Return 10
    End If

    Note: -----------------------------------------------------------------
    Note: Case 11: set_zero + is_zero round-trip
    Note: -----------------------------------------------------------------
    Let dummy_sz be proc int256_set_zero from Int256 with a
    Let z_check be proc int256_is_zero from Int256 with a
    If z_check is not equal to 1:
        Return 11
    End If

    Note: -----------------------------------------------------------------
    Note: Case 12: set_one produces limb[0]=1, others 0
    Note: -----------------------------------------------------------------
    Let dummy_so be proc int256_set_one from Int256 with a
    Let s1_l0 be proc memory_get_int64 from MemoryCore with a, 0
    Let s1_l1 be proc memory_get_int64 from MemoryCore with a, 8
    Let s1_l2 be proc memory_get_int64 from MemoryCore with a, 16
    Let s1_l3 be proc memory_get_int64 from MemoryCore with a, 24
    If s1_l0 is not equal to 1:
        Return 12
    End If
    If s1_l1 is not equal to 0:
        Return 12
    End If
    If s1_l2 is not equal to 0:
        Return 12
    End If
    If s1_l3 is not equal to 0:
        Return 12
    End If

    Note: -----------------------------------------------------------------
    Note: Case 13: set_max produces all-ones in every limb
    Note: -----------------------------------------------------------------
    Let dummy_sm be proc int256_set_max from Int256 with a
    Let sm_l0 be proc memory_get_int64 from MemoryCore with a, 0
    Let sm_l3 be proc memory_get_int64 from MemoryCore with a, 24
    If sm_l0 is not equal to max_u64:
        Return 13
    End If
    If sm_l3 is not equal to max_u64:
        Return 13
    End If

    Note: -----------------------------------------------------------------
    Note: Case 14: set_u64 zeroes upper limbs
    Note: -----------------------------------------------------------------
    Let dummy_su be proc int256_set_u64 from Int256 with a, 0xABCD
    Let su_l0 be proc memory_get_int64 from MemoryCore with a, 0
    Let su_l1 be proc memory_get_int64 from MemoryCore with a, 8
    If su_l0 is not equal to 0xABCD:
        Return 14
    End If
    If su_l1 is not equal to 0:
        Return 14
    End If

    Note: -----------------------------------------------------------------
    Note: Case 15: copy duplicates all 4 limbs
    Note: -----------------------------------------------------------------
    Let b be proc int256_allocate from Int256
    If b is equal to 0:
        Return 10
    End If
    Let dsa be proc memory_set_int64 from MemoryCore with a, 0, 100
    Let dsa1 be proc memory_set_int64 from MemoryCore with a, 8, 200
    Let dsa2 be proc memory_set_int64 from MemoryCore with a, 16, 300
    Let dsa3 be proc memory_set_int64 from MemoryCore with a, 24, 400
    Let dummy_cp be proc int256_copy from Int256 with a, b
    Let cb0 be proc memory_get_int64 from MemoryCore with b, 0
    Let cb3 be proc memory_get_int64 from MemoryCore with b, 24
    If cb0 is not equal to 100:
        Return 15
    End If
    If cb3 is not equal to 400:
        Return 15
    End If

    Note: -----------------------------------------------------------------
    Note: Case 16: is_max true on the max value
    Note: -----------------------------------------------------------------
    Let dummy_sm2 be proc int256_set_max from Int256 with a
    Let imax be proc int256_is_max from Int256 with a
    If imax is not equal to 1:
        Return 16
    End If

    Note: -----------------------------------------------------------------
    Note: Case 17: compare equal returns 0
    Note: -----------------------------------------------------------------
    Let dummy_setb_max be proc int256_set_max from Int256 with b
    Let cmpeq be proc int256_compare from Int256 with a, b
    If cmpeq is not equal to 0:
        Return 17
    End If

    Note: -----------------------------------------------------------------
    Note: Case 18: compare returns -1 when a<b across the top limb,
    Note:         and +1 when a>b across the top limb
    Note: -----------------------------------------------------------------
    Let dummy_seta_u be proc int256_set_u64 from Int256 with a, 100
    Let dummy_setb_top be proc int256_set_u64 from Int256 with b, 100
    Let dstop be proc memory_set_int64 from MemoryCore with b, 24, 1
    Let cmpneg be proc int256_compare from Int256 with a, b
    If cmpneg is not equal to -1:
        Return 18
    End If
    Let dstopa be proc memory_set_int64 from MemoryCore with a, 24, 2
    Let cmppos be proc int256_compare from Int256 with a, b
    If cmppos is not equal to 1:
        Return 18
    End If

    Note: -----------------------------------------------------------------
    Note: Case 19: add 1 + 2 = 3
    Note: -----------------------------------------------------------------
    Let x be proc int256_allocate from Int256
    Let y be proc int256_allocate from Int256
    Let r be proc int256_allocate from Int256
    If x is equal to 0:
        Return 10
    End If
    If y is equal to 0:
        Return 10
    End If
    If r is equal to 0:
        Return 10
    End If
    Let xset1 be proc int256_set_u64 from Int256 with x, 1
    Let yset2 be proc int256_set_u64 from Int256 with y, 2
    Let add_rc be proc int256_add from Int256 with x, y, r
    Let rl0 be proc memory_get_int64 from MemoryCore with r, 0
    If rl0 is not equal to 3:
        Return 19
    End If

    Note: -----------------------------------------------------------------
    Note: Case 20: add max_u64 + 1 carries into limb[1]
    Note: -----------------------------------------------------------------
    Let xset_max be proc int256_set_u64 from Int256 with x, max_u64
    Let yset_one be proc int256_set_u64 from Int256 with y, 1
    Let addc_rc be proc int256_add from Int256 with x, y, r
    Let rc_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let rc_hi be proc memory_get_int64 from MemoryCore with r, 8
    If rc_lo is not equal to 0:
        Return 20
    End If
    If rc_hi is not equal to 1:
        Return 20
    End If

    Note: -----------------------------------------------------------------
    Note: Case 21: (2^256 - 1) + 1 wraps to 0
    Note: -----------------------------------------------------------------
    Let xset_full_max be proc int256_set_max from Int256 with x
    Let yset_one2 be proc int256_set_u64 from Int256 with y, 1
    Let addw be proc int256_add from Int256 with x, y, r
    Let rzero be proc int256_is_zero from Int256 with r
    If rzero is not equal to 1:
        Return 21
    End If

    Note: -----------------------------------------------------------------
    Note: Case 22: add_checked flags overflow on (2^256-1) + 1
    Note: -----------------------------------------------------------------
    Let ovbuf be proc int256_allocate from Int256
    Let acc_rc be proc int256_add_checked from Int256 with x, y, r, ovbuf
    Let ovf be proc memory_get_int64 from MemoryCore with ovbuf, 0
    If ovf is not equal to 1:
        Return 22
    End If

    Note: -----------------------------------------------------------------
    Note: Case 23: sub 5 - 3 = 2
    Note: -----------------------------------------------------------------
    Let xset5 be proc int256_set_u64 from Int256 with x, 5
    Let yset3 be proc int256_set_u64 from Int256 with y, 3
    Let sub_rc be proc int256_sub from Int256 with x, y, r
    Let sublo be proc memory_get_int64 from MemoryCore with r, 0
    If sublo is not equal to 2:
        Return 23
    End If

    Note: -----------------------------------------------------------------
    Note: Case 24: sub 0 - 1 wraps to (2^256 - 1)
    Note: -----------------------------------------------------------------
    Let xset_zero be proc int256_set_zero from Int256 with x
    Let yset_one_w be proc int256_set_u64 from Int256 with y, 1
    Let subw be proc int256_sub from Int256 with x, y, r
    Let rmax be proc int256_is_max from Int256 with r
    If rmax is not equal to 1:
        Return 24
    End If

    Note: -----------------------------------------------------------------
    Note: Case 25: sub_checked flags underflow on 0 - 1
    Note: -----------------------------------------------------------------
    Let ufbuf be proc int256_allocate from Int256
    Let scc_rc be proc int256_sub_checked from Int256 with x, y, r, ufbuf
    Let ufv be proc memory_get_int64 from MemoryCore with ufbuf, 0
    If ufv is not equal to 1:
        Return 25
    End If

    Note: -----------------------------------------------------------------
    Note: Case 26: negate_twos_complement of 1 = (2^256 - 1)
    Note: -----------------------------------------------------------------
    Let xset1n be proc int256_set_u64 from Int256 with x, 1
    Let neg_rc be proc int256_negate_twos_complement from Int256 with x, r
    Let neg_is_max be proc int256_is_max from Int256 with r
    If neg_is_max is not equal to 1:
        Return 26
    End If

    Note: -----------------------------------------------------------------
    Note: Case 27: negate twice returns original. Use 12345.
    Note: -----------------------------------------------------------------
    Let xset12345 be proc int256_set_u64 from Int256 with x, 12345
    Let neg1_rc be proc int256_negate_twos_complement from Int256 with x, r
    Let neg2_rc be proc int256_negate_twos_complement from Int256 with r, r
    Let r_back_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let r_back_hi be proc memory_get_int64 from MemoryCore with r, 24
    If r_back_lo is not equal to 12345:
        Return 27
    End If
    If r_back_hi is not equal to 0:
        Return 27
    End If

    Note: -----------------------------------------------------------------
    Note: Case 28: bit_and: 0xF0F0... AND 0x0F0F... = 0
    Note: -----------------------------------------------------------------
    Let pa be 0xF0F0F0F0F0F0F0F0
    Let pb be 0x0F0F0F0F0F0F0F0F
    Let sa0 be proc memory_set_int64 from MemoryCore with x, 0, pa
    Let sa1 be proc memory_set_int64 from MemoryCore with x, 8, pa
    Let sa2 be proc memory_set_int64 from MemoryCore with x, 16, pa
    Let sa3 be proc memory_set_int64 from MemoryCore with x, 24, pa
    Let sb0 be proc memory_set_int64 from MemoryCore with y, 0, pb
    Let sb1 be proc memory_set_int64 from MemoryCore with y, 8, pb
    Let sb2 be proc memory_set_int64 from MemoryCore with y, 16, pb
    Let sb3 be proc memory_set_int64 from MemoryCore with y, 24, pb
    Let and_rc be proc int256_bit_and from Int256 with x, y, r
    Let and_zero be proc int256_is_zero from Int256 with r
    If and_zero is not equal to 1:
        Return 28
    End If

    Note: -----------------------------------------------------------------
    Note: Case 29: bit_or yields all_ones
    Note: -----------------------------------------------------------------
    Let or_rc be proc int256_bit_or from Int256 with x, y, r
    Let or_is_max be proc int256_is_max from Int256 with r
    If or_is_max is not equal to 1:
        Return 29
    End If

    Note: -----------------------------------------------------------------
    Note: Case 30: bit_xor: a XOR a = 0
    Note: -----------------------------------------------------------------
    Let xor_rc be proc int256_bit_xor from Int256 with x, x, r
    Let xor_zero be proc int256_is_zero from Int256 with r
    If xor_zero is not equal to 1:
        Return 30
    End If

    Note: -----------------------------------------------------------------
    Note: Case 31: bit_not of zero = all_ones
    Note: -----------------------------------------------------------------
    Let zret_x_31 be proc int256_set_zero from Int256 with x
    Let not_rc be proc int256_bit_not from Int256 with x, r
    Let not_max be proc int256_is_max from Int256 with r
    If not_max is not equal to 1:
        Return 31
    End If

    Note: -----------------------------------------------------------------
    Note: Case 32: shift_left by 0 preserves the value
    Note: -----------------------------------------------------------------
    Let setv32 be proc int256_set_u64 from Int256 with x, 0xCAFEBABE
    Let shl0 be proc int256_shift_left from Int256 with x, 0, r
    Let r32 be proc memory_get_int64 from MemoryCore with r, 0
    If r32 is not equal to 0xCAFEBABE:
        Return 32
    End If

    Note: -----------------------------------------------------------------
    Note: Case 33: shift_left by 1 of 5 = 10
    Note: -----------------------------------------------------------------
    Let set5 be proc int256_set_u64 from Int256 with x, 5
    Let shl1 be proc int256_shift_left from Int256 with x, 1, r
    Let r33 be proc memory_get_int64 from MemoryCore with r, 0
    If r33 is not equal to 10:
        Return 33
    End If

    Note: -----------------------------------------------------------------
    Note: Case 34: shift_left by 64 of 7: limb[0] = 0, limb[1] = 7
    Note: -----------------------------------------------------------------
    Let set7 be proc int256_set_u64 from Int256 with x, 7
    Let shl64 be proc int256_shift_left from Int256 with x, 64, r
    Let r34_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let r34_hi be proc memory_get_int64 from MemoryCore with r, 8
    If r34_lo is not equal to 0:
        Return 34
    End If
    If r34_hi is not equal to 7:
        Return 34
    End If

    Note: -----------------------------------------------------------------
    Note: Case 35: shift_left by 65 of 1: limb[0] = 0, limb[1] = 2
    Note: -----------------------------------------------------------------
    Let set1_35 be proc int256_set_u64 from Int256 with x, 1
    Let shl65 be proc int256_shift_left from Int256 with x, 65, r
    Let r35_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let r35_hi be proc memory_get_int64 from MemoryCore with r, 8
    If r35_lo is not equal to 0:
        Return 35
    End If
    If r35_hi is not equal to 2:
        Return 35
    End If

    Note: -----------------------------------------------------------------
    Note: Case 36: shift_left by 255 of 1: top bit of limb[3] set
    Note: -----------------------------------------------------------------
    Let set1_36 be proc int256_set_u64 from Int256 with x, 1
    Let shl255 be proc int256_shift_left from Int256 with x, 255, r
    Let r36_l3 be proc memory_get_int64 from MemoryCore with r, 24
    Let high_bit_mask be 0x8000000000000000
    If r36_l3 is not equal to high_bit_mask:
        Return 36
    End If

    Note: -----------------------------------------------------------------
    Note: Case 37: shift_left by 256 (>=width) zeroes the result
    Note: -----------------------------------------------------------------
    Let set1_37 be proc int256_set_u64 from Int256 with x, 1
    Let shl256 be proc int256_shift_left from Int256 with x, 256, r
    Let r37_zero be proc int256_is_zero from Int256 with r
    If r37_zero is not equal to 1:
        Return 37
    End If

    Note: -----------------------------------------------------------------
    Note: Case 38: shift_right by 64 of limb[1]=7 returns 7 in limb[0]
    Note: -----------------------------------------------------------------
    Let zret_x_38 be proc int256_set_zero from Int256 with x
    Let s_l1_7 be proc memory_set_int64 from MemoryCore with x, 8, 7
    Let shr64 be proc int256_shift_right from Int256 with x, 64, r
    Let r38_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let r38_hi be proc memory_get_int64 from MemoryCore with r, 8
    If r38_lo is not equal to 7:
        Return 38
    End If
    If r38_hi is not equal to 0:
        Return 38
    End If

    Note: -----------------------------------------------------------------
    Note: Case 39: shift_right by 1 of 100 = 50
    Note: -----------------------------------------------------------------
    Let set100 be proc int256_set_u64 from Int256 with x, 100
    Let shr1 be proc int256_shift_right from Int256 with x, 1, r
    Let r39 be proc memory_get_int64 from MemoryCore with r, 0
    If r39 is not equal to 50:
        Return 39
    End If

    Note: -----------------------------------------------------------------
    Note: Case 40: divmod 100 / 7 = 14 r 2
    Note: -----------------------------------------------------------------
    Let set100b be proc int256_set_u64 from Int256 with x, 100
    Let set7b be proc int256_set_u64 from Int256 with y, 7
    Let q_out be proc int256_allocate from Int256
    Let r_out be proc int256_allocate from Int256
    Let dm_rc be proc int256_divmod from Int256 with x, y, q_out, r_out
    Let q_lo be proc memory_get_int64 from MemoryCore with q_out, 0
    Let r_lo be proc memory_get_int64 from MemoryCore with r_out, 0
    If q_lo is not equal to 14:
        Return 40
    End If
    If r_lo is not equal to 2:
        Return 40
    End If

    Note: -----------------------------------------------------------------
    Note: Case 41: divmod by zero returns INT256_ERR_DIVIDE_BY_ZERO (-2)
    Note: -----------------------------------------------------------------
    Let zret_y_41 be proc int256_set_zero from Int256 with y
    Let dm_dz be proc int256_divmod from Int256 with x, y, q_out, r_out
    If dm_dz is not equal to -2:
        Return 41
    End If

    Note: -----------------------------------------------------------------
    Note: Case 42: mul 3 * 7 = 21
    Note: -----------------------------------------------------------------
    Let set3 be proc int256_set_u64 from Int256 with x, 3
    Let set7m be proc int256_set_u64 from Int256 with y, 7
    Let mul_rc be proc int256_mul from Int256 with x, y, r
    Let mul_lo be proc memory_get_int64 from MemoryCore with r, 0
    If mul_lo is not equal to 21:
        Return 42
    End If

    Note: -----------------------------------------------------------------
    Note: Case 43: max * 2 wraps to (2^256 - 2) which is max_u64 in every
    Note: limb except limb[0] which is max_u64 - 1.
    Note: -----------------------------------------------------------------
    Let setm43 be proc int256_set_max from Int256 with x
    Let set2_43 be proc int256_set_u64 from Int256 with y, 2
    Let mul_w be proc int256_mul from Int256 with x, y, r
    Let r43_l0 be proc memory_get_int64 from MemoryCore with r, 0
    Let r43_l3 be proc memory_get_int64 from MemoryCore with r, 24
    Let max_minus_1 be max_u64 minus 1
    If r43_l0 is not equal to max_minus_1:
        Return 43
    End If
    If r43_l3 is not equal to max_u64:
        Return 43
    End If

    Note: -----------------------------------------------------------------
    Note: Case 44: mul_checked flags overflow on max * 2
    Note: -----------------------------------------------------------------
    Let ovbuf44 be proc int256_allocate from Int256
    Let mck_rc be proc int256_mul_checked from Int256 with x, y, r, ovbuf44
    Let ovf44 be proc memory_get_int64 from MemoryCore with ovbuf44, 0
    If ovf44 is not equal to 1:
        Return 44
    End If

    Note: -----------------------------------------------------------------
    Note: Case 45: mul_full of 2^128 * 2^128 = 2^256.
    Note: Construct 2^128 as limb[0]=0, limb[1]=0, limb[2]=1, limb[3]=0.
    Note: Wait: 2^128 is bit 128, which is bit 0 of limb[2]. So 2^128
    Note: has limb[0]=0, limb[1]=0, limb[2]=1, limb[3]=0.
    Note: (2^128)^2 = 2^256 which is the value with low_out=0 and
    Note: high_out limb[0]=1, rest 0.
    Note: -----------------------------------------------------------------
    Let z_x_45 be proc int256_set_zero from Int256 with x
    Let set_x_l2 be proc memory_set_int64 from MemoryCore with x, 16, 1
    Let z_y_45 be proc int256_set_zero from Int256 with y
    Let set_y_l2 be proc memory_set_int64 from MemoryCore with y, 16, 1
    Let low_out be proc int256_allocate from Int256
    Let high_out be proc int256_allocate from Int256
    Let mfull_rc be proc int256_mul_full from Int256 with x, y, low_out, high_out
    Let low_is_zero be proc int256_is_zero from Int256 with low_out
    Let h_l0 be proc memory_get_int64 from MemoryCore with high_out, 0
    Let h_l1 be proc memory_get_int64 from MemoryCore with high_out, 8
    Let h_l2 be proc memory_get_int64 from MemoryCore with high_out, 16
    Let h_l3 be proc memory_get_int64 from MemoryCore with high_out, 24
    If low_is_zero is not equal to 1:
        Return 45
    End If
    If h_l0 is not equal to 1:
        Return 45
    End If
    If h_l1 is not equal to 0:
        Return 45
    End If
    If h_l2 is not equal to 0:
        Return 45
    End If
    If h_l3 is not equal to 0:
        Return 45
    End If

    Note: -----------------------------------------------------------------
    Note: Case 46: from_bytes_be / to_bytes_be round-trip.
    Note: Build a 32-byte BE buffer with byte 0 = 0x01, byte 31 = 0x20.
    Note: After from_bytes_be, the value should be:
    Note:   (0x01 in MSB position, 0x20 in LSB position)
    Note: To-bytes-be should reproduce the original buffer byte-for-byte.
    Note: -----------------------------------------------------------------
    Let be_buf be proc allocate from Layout with 32
    Let be_back be proc allocate from Layout with 32
    Let i46 be 0
    While i46 is less than 32:
        Let bv be i46 plus 1
        Let dummy_bs be proc memory_set_byte from MemoryCore with be_buf, i46, bv
        Set i46 to i46 plus 1
    End While
    Let from_be_rc be proc int256_from_bytes_be from Int256 with be_buf, x
    Let to_be_rc be proc int256_to_bytes_be from Int256 with x, be_back
    Let i46b be 0
    Let mismatch46 be 0
    While i46b is less than 32:
        Let original be proc memory_get_byte from MemoryCore with be_buf, i46b
        Let back be proc memory_get_byte from MemoryCore with be_back, i46b
        If original is not equal to back:
            Set mismatch46 to 1
            Set i46b to 32
        Otherwise:
            Set i46b to i46b plus 1
        End If
    End While
    If mismatch46 is equal to 1:
        Return 46
    End If

    Note: -----------------------------------------------------------------
    Note: Case 47: from_bytes_le / to_bytes_le round-trip
    Note: -----------------------------------------------------------------
    Let le_buf be proc allocate from Layout with 32
    Let le_back be proc allocate from Layout with 32
    Let i47 be 0
    While i47 is less than 32:
        Let bv47 be i47 plus 1
        Let dummy_ls be proc memory_set_byte from MemoryCore with le_buf, i47, bv47
        Set i47 to i47 plus 1
    End While
    Let from_le_rc be proc int256_from_bytes_le from Int256 with le_buf, x
    Let to_le_rc be proc int256_to_bytes_le from Int256 with x, le_back
    Let i47b be 0
    Let mismatch47 be 0
    While i47b is less than 32:
        Let original_le be proc memory_get_byte from MemoryCore with le_buf, i47b
        Let back_le be proc memory_get_byte from MemoryCore with le_back, i47b
        If original_le is not equal to back_le:
            Set mismatch47 to 1
            Set i47b to 32
        Otherwise:
            Set i47b to i47b plus 1
        End If
    End While
    If mismatch47 is equal to 1:
        Return 47
    End If

    Note: -----------------------------------------------------------------
    Note: Case 48: hex round-trip for value 0xCAFE.
    Note: Build the string "cafe" and ensure from + to produces "cafe".
    Note: -----------------------------------------------------------------
    Let hex_in be proc allocate from Layout with 8
    Let dh0 be proc memory_set_byte from MemoryCore with hex_in, 0, 99
    Let dh1 be proc memory_set_byte from MemoryCore with hex_in, 1, 97
    Let dh2 be proc memory_set_byte from MemoryCore with hex_in, 2, 102
    Let dh3 be proc memory_set_byte from MemoryCore with hex_in, 3, 101
    Let dh4 be proc memory_set_byte from MemoryCore with hex_in, 4, 0
    Let hex_rc be proc int256_from_hex_string from Int256 with hex_in, x
    If hex_rc is not equal to 0:
        Return 48
    End If
    Let hex_val be proc memory_get_int64 from MemoryCore with x, 0
    If hex_val is not equal to 0xCAFE:
        Return 48
    End If
    Let hex_out be proc allocate from Layout with 80
    Let to_hex_rc be proc int256_to_hex_string from Int256 with x, hex_out, 80
    Note: to_hex_string returns length on success; 0xCAFE is 4 hex chars
    If to_hex_rc is not equal to 4:
        Return 48
    End If
    Let oh0 be proc memory_get_byte from MemoryCore with hex_out, 0
    Let oh1 be proc memory_get_byte from MemoryCore with hex_out, 1
    Let oh2 be proc memory_get_byte from MemoryCore with hex_out, 2
    Let oh3 be proc memory_get_byte from MemoryCore with hex_out, 3
    If oh0 is not equal to 99:
        Return 48
    End If
    If oh1 is not equal to 97:
        Return 48
    End If
    If oh2 is not equal to 102:
        Return 48
    End If
    If oh3 is not equal to 101:
        Return 48
    End If

    Note: -----------------------------------------------------------------
    Note: Case 49: from_hex_string with "0xff" prefix yields 255
    Note: -----------------------------------------------------------------
    Let hex_pref be proc allocate from Layout with 8
    Let dp0 be proc memory_set_byte from MemoryCore with hex_pref, 0, 48
    Let dp1 be proc memory_set_byte from MemoryCore with hex_pref, 1, 120
    Let dp2 be proc memory_set_byte from MemoryCore with hex_pref, 2, 102
    Let dp3 be proc memory_set_byte from MemoryCore with hex_pref, 3, 102
    Let dp4 be proc memory_set_byte from MemoryCore with hex_pref, 4, 0
    Let hex_rc2 be proc int256_from_hex_string from Int256 with hex_pref, x
    If hex_rc2 is not equal to 0:
        Return 49
    End If
    Let hex_val2 be proc memory_get_int64 from MemoryCore with x, 0
    If hex_val2 is not equal to 255:
        Return 49
    End If

    Note: -----------------------------------------------------------------
    Note: Case 50: to_hex_string of zero = "0"
    Note: -----------------------------------------------------------------
    Let zret_x_50 be proc int256_set_zero from Int256 with x
    Let to_hex_zero_rc be proc int256_to_hex_string from Int256 with x, hex_out, 80
    If to_hex_zero_rc is not equal to 1:
        Return 50
    End If
    Let hz0 be proc memory_get_byte from MemoryCore with hex_out, 0
    If hz0 is not equal to 48:
        Return 50
    End If

    Note: -----------------------------------------------------------------
    Note: Case 51: from_hex_string of empty string returns error -4
    Note: -----------------------------------------------------------------
    Let empty be proc allocate from Layout with 4
    Let de0 be proc memory_set_byte from MemoryCore with empty, 0, 0
    Let he_rc be proc int256_from_hex_string from Int256 with empty, x
    If he_rc is not equal to -4:
        Return 51
    End If

    Note: -----------------------------------------------------------------
    Note: Case 52: from_hex_string of "g0" (invalid hex char) returns -4
    Note: -----------------------------------------------------------------
    Let bad_hex be proc allocate from Layout with 4
    Let dbg0 be proc memory_set_byte from MemoryCore with bad_hex, 0, 103
    Let dbg1 be proc memory_set_byte from MemoryCore with bad_hex, 1, 48
    Let dbg2 be proc memory_set_byte from MemoryCore with bad_hex, 2, 0
    Let bh_rc be proc int256_from_hex_string from Int256 with bad_hex, x
    If bh_rc is not equal to -4:
        Return 52
    End If

    Note: -----------------------------------------------------------------
    Note: Case 53: from_decimal_string of "1000" yields 1000
    Note: -----------------------------------------------------------------
    Let dec_in be proc allocate from Layout with 8
    Let dd0 be proc memory_set_byte from MemoryCore with dec_in, 0, 49
    Let dd1 be proc memory_set_byte from MemoryCore with dec_in, 1, 48
    Let dd2 be proc memory_set_byte from MemoryCore with dec_in, 2, 48
    Let dd3 be proc memory_set_byte from MemoryCore with dec_in, 3, 48
    Let dd4 be proc memory_set_byte from MemoryCore with dec_in, 4, 0
    Let dec_rc be proc int256_from_decimal_string from Int256 with dec_in, x
    Let dec_lo be proc memory_get_int64 from MemoryCore with x, 0
    Let dec_l1 be proc memory_get_int64 from MemoryCore with x, 8
    If dec_lo is not equal to 1000:
        Return 53
    End If
    If dec_l1 is not equal to 0:
        Return 53
    End If

    Note: -----------------------------------------------------------------
    Note: Case 54: to_decimal_string of 1000 = "1000"
    Note: -----------------------------------------------------------------
    Let dec_out be proc allocate from Layout with 80
    Let to_dec_rc be proc int256_to_decimal_string from Int256 with x, dec_out, 80
    If to_dec_rc is not equal to 4:
        Return 54
    End If
    Let od0 be proc memory_get_byte from MemoryCore with dec_out, 0
    Let od3 be proc memory_get_byte from MemoryCore with dec_out, 3
    If od0 is not equal to 49:
        Return 54
    End If
    If od3 is not equal to 48:
        Return 54
    End If

    Note: -----------------------------------------------------------------
    Note: Case 55: to_decimal_string of zero = "0"
    Note: -----------------------------------------------------------------
    Let zret_x_55 be proc int256_set_zero from Int256 with x
    Let to_dec_zero_rc be proc int256_to_decimal_string from Int256 with x, dec_out, 80
    If to_dec_zero_rc is not equal to 1:
        Return 55
    End If
    Let dz0 be proc memory_get_byte from MemoryCore with dec_out, 0
    If dz0 is not equal to 48:
        Return 55
    End If

    Note: -----------------------------------------------------------------
    Note: Case 56: from_decimal_string of "0" yields 0
    Note: -----------------------------------------------------------------
    Let dec_zero be proc allocate from Layout with 4
    Let dz_set0 be proc memory_set_byte from MemoryCore with dec_zero, 0, 48
    Let dz_set1 be proc memory_set_byte from MemoryCore with dec_zero, 1, 0
    Let dz_rc be proc int256_from_decimal_string from Int256 with dec_zero, x
    Let dz_is_zero be proc int256_is_zero from Int256 with x
    If dz_is_zero is not equal to 1:
        Return 56
    End If

    Note: -----------------------------------------------------------------
    Note: Case 57: Fixed-point mul: 1.5 * 2.0 = 3.0, scale = 10^18.
    Note: -
    Note: 10^18 = 1000000000000000000 fits in a u64 (< 2^60), so set_u64.
    Note: a = 1500000000000000000 = 1.5 at scale 10^18.
    Note: b = 2000000000000000000 = 2.0 at scale 10^18.
    Note: expected = 3000000000000000000.
    Note: -----------------------------------------------------------------
    Let scale_18 be 1000000000000000000
    Let a_15 be 1500000000000000000
    Let b_20 be 2000000000000000000
    Let exp_30 be 3000000000000000000

    Let scale_buf be proc int256_allocate from Int256
    Let a_buf be proc int256_allocate from Int256
    Let b_buf be proc int256_allocate from Int256
    Let fix_r be proc int256_allocate from Int256
    Let sb_rc be proc int256_set_u64 from Int256 with scale_buf, scale_18
    Let ab_rc be proc int256_set_u64 from Int256 with a_buf, a_15
    Let bb_rc be proc int256_set_u64 from Int256 with b_buf, b_20
    Let fm_rc be proc int256_fixed_mul from Int256 with a_buf, b_buf, scale_buf, fix_r
    Let fix_lo be proc memory_get_int64 from MemoryCore with fix_r, 0
    Let fix_hi be proc memory_get_int64 from MemoryCore with fix_r, 8
    If fix_lo is not equal to exp_30:
        Return 57
    End If
    If fix_hi is not equal to 0:
        Return 57
    End If

    Note: -----------------------------------------------------------------
    Note: Case 58: Fixed-point div: 3.0 / 2.0 = 1.5 with scale 10^18.
    Note: a = 3.0 = 3000000000000000000, b = 2.0 = 2000000000000000000.
    Note: expected = 1500000000000000000.
    Note: -----------------------------------------------------------------
    Let ab_rc2 be proc int256_set_u64 from Int256 with a_buf, exp_30
    Let bb_rc2 be proc int256_set_u64 from Int256 with b_buf, b_20
    Let fd_rc be proc int256_fixed_div from Int256 with a_buf, b_buf, scale_buf, fix_r
    Let fix_lo2 be proc memory_get_int64 from MemoryCore with fix_r, 0
    Let fix_hi2 be proc memory_get_int64 from MemoryCore with fix_r, 8
    If fix_lo2 is not equal to a_15:
        Return 58
    End If
    If fix_hi2 is not equal to 0:
        Return 58
    End If

    Note: -----------------------------------------------------------------
    Note: Case 59: CRD currency transfer simulation.
    Note: -
    Note: Scenario: 1000.5 CRD * 1.0 (multiplied by unity at scale 10^18)
    Note: should return 1000.5 CRD exactly. This validates that the
    Note: identity-multiplication path preserves the exact fixed-point
    Note: value, which is critical for token-transfer determinism on a
    Note: distributed ledger.
    Note: -
    Note: 1000.5 CRD with 18 decimal places = 1000500000000000000000.
    Note: This value is larger than 2^64 - 1 (~1.8e19), so it must be
    Note: split across two u64 limbs.
    Note: -
    Note: 1000500000000000000000 = 0x36346FBFB02F320000 + 0x36... actually
    Note: 1000500000000000000000 / 2^64 = 54 (since 2^64 ~= 1.84e19; 54 *
    Note: 1.84e19 ~= 9.95e20, and 1000.5 * 1e18 = 1.0005e21; so q ~= 54).
    Note: We instead build it programmatically: 1000 * 10^18 + 500000000000000000.
    Note: 1000 * 10^18 = 10^21 = 1000000000000000000000.
    Note: 500000000000000000 = 5 * 10^17.
    Note: Both 1000 and the 0.5 portion fit easily in u64.
    Note: -
    Note: Construction:
    Note:   thousand = int256(1000)
    Note:   scale = int256(10^18)
    Note:   thousand_scaled = thousand * scale (regular wrapping mul; the
    Note:                      product 10^21 still fits in 2^256)
    Note:   half = int256(5 * 10^17)
    Note:   amount = thousand_scaled + half
    Note: -
    Note: Then amount * 1.0 fixed-point with scale = scale should equal
    Note: amount.
    Note: -----------------------------------------------------------------
    Let thousand_buf be proc int256_allocate from Int256
    Let half_buf be proc int256_allocate from Int256
    Let amount_buf be proc int256_allocate from Int256
    Let scaled_buf be proc int256_allocate from Int256
    Let one_buf be proc int256_allocate from Int256
    Let result_buf be proc int256_allocate from Int256

    Let st59 be proc int256_set_u64 from Int256 with thousand_buf, 1000
    Let half_value be 500000000000000000
    Let sh59 be proc int256_set_u64 from Int256 with half_buf, half_value
    Note: scaled_buf = thousand_buf * scale_buf
    Let m59_rc be proc int256_mul from Int256 with thousand_buf, scale_buf, scaled_buf
    Note: amount_buf = scaled_buf + half_buf
    Let a59_rc be proc int256_add from Int256 with scaled_buf, half_buf, amount_buf

    Note: one (fixed-point 1.0 at scale 10^18) = scale itself.
    Let so59 be proc int256_copy from Int256 with scale_buf, one_buf

    Note: result = fixed_mul(amount, one, scale)
    Let fm59_rc be proc int256_fixed_mul from Int256 with amount_buf, one_buf, scale_buf, result_buf

    Note: Verify result == amount (limb-by-limb)
    Let am0 be proc memory_get_int64 from MemoryCore with amount_buf, 0
    Let am1 be proc memory_get_int64 from MemoryCore with amount_buf, 8
    Let am2 be proc memory_get_int64 from MemoryCore with amount_buf, 16
    Let am3 be proc memory_get_int64 from MemoryCore with amount_buf, 24
    Let rs0 be proc memory_get_int64 from MemoryCore with result_buf, 0
    Let rs1 be proc memory_get_int64 from MemoryCore with result_buf, 8
    Let rs2 be proc memory_get_int64 from MemoryCore with result_buf, 16
    Let rs3 be proc memory_get_int64 from MemoryCore with result_buf, 24
    If am0 is not equal to rs0:
        Return 59
    End If
    If am1 is not equal to rs1:
        Return 59
    End If
    If am2 is not equal to rs2:
        Return 59
    End If
    If am3 is not equal to rs3:
        Return 59
    End If

    Note: Cleanup (allocations are leaked in a true smoke test; this is
    Note: a CI runner where the process exit reclaims everything, but we
    Note: free the major buffers to verify no double-free regressions.)
    Let f_a be proc int256_free from Int256 with a
    Let f_b be proc int256_free from Int256 with b
    Let f_x be proc int256_free from Int256 with x
    Let f_y be proc int256_free from Int256 with y
    Let f_r be proc int256_free from Int256 with r
    Let f_ovbuf be proc int256_free from Int256 with ovbuf
    Let f_ufbuf be proc int256_free from Int256 with ufbuf
    Let f_qo be proc int256_free from Int256 with q_out
    Let f_ro be proc int256_free from Int256 with r_out
    Let f_low be proc int256_free from Int256 with low_out
    Let f_high be proc int256_free from Int256 with high_out
    Let f_ovbuf44 be proc int256_free from Int256 with ovbuf44
    Let f_scale be proc int256_free from Int256 with scale_buf
    Let f_ab be proc int256_free from Int256 with a_buf
    Let f_bb be proc int256_free from Int256 with b_buf
    Let f_fr be proc int256_free from Int256 with fix_r
    Let f_th be proc int256_free from Int256 with thousand_buf
    Let f_hb be proc int256_free from Int256 with half_buf
    Let f_am be proc int256_free from Int256 with amount_buf
    Let f_sc be proc int256_free from Int256 with scaled_buf
    Let f_ob be proc int256_free from Int256 with one_buf
    Let f_rb be proc int256_free from Int256 with result_buf

    Return 0
End Process
