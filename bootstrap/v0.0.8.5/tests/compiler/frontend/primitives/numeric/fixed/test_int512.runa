Note:
Int512 KAT (Known Answer Test) suite. Verifies that the 512-bit
unsigned integer primitives produce bit-exact identical output for
identical input. Determinism is the property under test.

Exit code legend:
     0   All assertions passed.
    10   allocate returned 0.
    11   set_zero result not detected as zero.
    12   set_u64 placed the value in the wrong limb.
    13   copy did not duplicate all 8 limbs.
    14   compare did not return 0 for equal values.
    15   compare did not return -1 for a<b across the high limb.
    16   compare did not return 1 for a>b across the high limb.
    17   add of 1 + 2 did not yield 3 in the low limb.
    18   add did not propagate carry from limb 0 to limb 1.
    19   add wrap of (2^512-1)+1 did not wrap to 0 (low and rest).
    20   add_checked did not flag overflow on (2^512-1)+1.
    21   sub of 5 - 3 did not yield 2.
    22   sub with borrow across limb boundary failed.
    23   bit_and pattern mismatch.
    24   bit_or pattern mismatch.
    25   bit_xor pattern mismatch.
    26   bit_not did not invert all limbs.
    27   shift_left by 0 did not preserve value.
    28   shift_left by 1 did not double low limb (no carry case).
    29   shift_left by 64 did not move limb[0] to limb[1].
    30   shift_left by 65 did not produce expected partial-limb shift.
    31   shift_right by 64 did not move limb[1] to limb[0].
    32   shift_right by 1 did not halve a known value.
    33   divmod of 100 / 7 did not yield q=14, r=2.
    34   divmod by zero did not return INT512_ERR_DIVIDE_BY_ZERO.
    35   mul of 3 * 7 did not yield 21.
    36   mul of 2^64 * 2^64 did not place 1 at limb[2].
:End Note

Import "compiler/frontend/primitives/numeric/fixed/int512.runa" as Int512
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore

Process called "main" returns Integer:
    Note: -----------------------------------------------------------------
    Note: Case 10: basic allocation
    Note: -----------------------------------------------------------------
    Let a be proc int512_allocate from Int512
    If a is equal to 0:
        Return 10
    End If

    Note: -----------------------------------------------------------------
    Note: Case 11: set_zero produces a buffer that is_zero detects
    Note: -----------------------------------------------------------------
    Let dummy_zero_a be proc int512_set_zero from Int512 with a
    Let is_zero_a be proc int512_is_zero from Int512 with a
    If is_zero_a is not equal to 1:
        Return 11
    End If

    Note: -----------------------------------------------------------------
    Note: Case 12: set_u64 places value in limb[0] only
    Note: -----------------------------------------------------------------
    Let dummy_u64 be proc int512_set_u64 from Int512 with a, 42
    Let limb0 be proc memory_get_int64 from MemoryCore with a, 0
    Let limb1 be proc memory_get_int64 from MemoryCore with a, 8
    Let limb7 be proc memory_get_int64 from MemoryCore with a, 56
    If limb0 is not equal to 42:
        Return 12
    End If
    If limb1 is not equal to 0:
        Return 12
    End If
    If limb7 is not equal to 0:
        Return 12
    End If

    Note: -----------------------------------------------------------------
    Note: Case 13: copy duplicates all 8 limbs
    Note: -----------------------------------------------------------------
    Let b be proc int512_allocate from Int512
    If b is equal to 0:
        Return 10
    End If
    Let dummy_set_a be proc memory_set_int64 from MemoryCore with a, 0, 1
    Let dummy_set_a2 be proc memory_set_int64 from MemoryCore with a, 8, 2
    Let dummy_set_a3 be proc memory_set_int64 from MemoryCore with a, 16, 3
    Let dummy_set_a4 be proc memory_set_int64 from MemoryCore with a, 24, 4
    Let dummy_set_a5 be proc memory_set_int64 from MemoryCore with a, 32, 5
    Let dummy_set_a6 be proc memory_set_int64 from MemoryCore with a, 40, 6
    Let dummy_set_a7 be proc memory_set_int64 from MemoryCore with a, 48, 7
    Let dummy_set_a8 be proc memory_set_int64 from MemoryCore with a, 56, 8
    Let dummy_cp be proc int512_copy from Int512 with a, b
    Let cb0 be proc memory_get_int64 from MemoryCore with b, 0
    Let cb3 be proc memory_get_int64 from MemoryCore with b, 24
    Let cb7 be proc memory_get_int64 from MemoryCore with b, 56
    If cb0 is not equal to 1:
        Return 13
    End If
    If cb3 is not equal to 4:
        Return 13
    End If
    If cb7 is not equal to 8:
        Return 13
    End If

    Note: -----------------------------------------------------------------
    Note: Case 14: compare returns 0 for equal values
    Note: -----------------------------------------------------------------
    Let cmp_eq be proc int512_compare from Int512 with a, b
    If cmp_eq is not equal to 0:
        Return 14
    End If

    Note: -----------------------------------------------------------------
    Note: Case 15: compare returns -1 when a<b at the highest limb
    Note: -----------------------------------------------------------------
    Let dummy_set_b56 be proc memory_set_int64 from MemoryCore with b, 56, 999
    Let cmp_lt be proc int512_compare from Int512 with a, b
    If cmp_lt is not equal to -1:
        Return 15
    End If

    Note: -----------------------------------------------------------------
    Note: Case 16: compare returns 1 when a>b at the highest limb
    Note: -----------------------------------------------------------------
    Let dummy_set_a_top be proc memory_set_int64 from MemoryCore with a, 56, 1000
    Let cmp_gt be proc int512_compare from Int512 with a, b
    If cmp_gt is not equal to 1:
        Return 16
    End If

    Note: -----------------------------------------------------------------
    Note: Case 17: add 1 + 2 = 3
    Note: -----------------------------------------------------------------
    Let x be proc int512_allocate from Int512
    Let y be proc int512_allocate from Int512
    Let r be proc int512_allocate from Int512
    If x is equal to 0:
        Return 10
    End If
    If y is equal to 0:
        Return 10
    End If
    If r is equal to 0:
        Return 10
    End If
    Let su1 be proc int512_set_u64 from Int512 with x, 1
    Let su2 be proc int512_set_u64 from Int512 with y, 2
    Let add_rc be proc int512_add from Int512 with x, y, r
    Let r_low be proc memory_get_int64 from MemoryCore with r, 0
    If r_low is not equal to 3:
        Return 17
    End If

    Note: -----------------------------------------------------------------
    Note: Case 18: add of max_u64 + 1 carries into limb[1]
    Note: -----------------------------------------------------------------
    Let max_u64 be bitwise not 0
    Let su3 be proc int512_set_u64 from Int512 with x, max_u64
    Let su4 be proc int512_set_u64 from Int512 with y, 1
    Let add_rc2 be proc int512_add from Int512 with x, y, r
    Let r_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let r_hi be proc memory_get_int64 from MemoryCore with r, 8
    If r_lo is not equal to 0:
        Return 18
    End If
    If r_hi is not equal to 1:
        Return 18
    End If

    Note: -----------------------------------------------------------------
    Note: Case 19: add (2^512 - 1) + 1 wraps to 0
    Note: -----------------------------------------------------------------
    Let all_ones be bitwise not 0
    Let ws0 be proc memory_set_int64 from MemoryCore with x, 0, all_ones
    Let ws1 be proc memory_set_int64 from MemoryCore with x, 8, all_ones
    Let ws2 be proc memory_set_int64 from MemoryCore with x, 16, all_ones
    Let ws3 be proc memory_set_int64 from MemoryCore with x, 24, all_ones
    Let ws4 be proc memory_set_int64 from MemoryCore with x, 32, all_ones
    Let ws5 be proc memory_set_int64 from MemoryCore with x, 40, all_ones
    Let ws6 be proc memory_set_int64 from MemoryCore with x, 48, all_ones
    Let ws7 be proc memory_set_int64 from MemoryCore with x, 56, all_ones
    Let su5 be proc int512_set_u64 from Int512 with y, 1
    Let add_wrap be proc int512_add from Int512 with x, y, r
    Let r_is_zero be proc int512_is_zero from Int512 with r
    If r_is_zero is not equal to 1:
        Return 19
    End If

    Note: -----------------------------------------------------------------
    Note: Case 20: add_checked flags overflow on (2^512-1) + 1
    Note: -----------------------------------------------------------------
    Let overflow_buf be proc int512_allocate from Int512
    Let add_chk be proc int512_add_checked from Int512 with x, y, r, overflow_buf
    Let overflow_flag be proc memory_get_int64 from MemoryCore with overflow_buf, 0
    If overflow_flag is not equal to 1:
        Return 20
    End If
    Let dummy_free_of be proc int512_free from Int512 with overflow_buf

    Note: -----------------------------------------------------------------
    Note: Case 21: sub 5 - 3 = 2
    Note: -----------------------------------------------------------------
    Let su6 be proc int512_set_u64 from Int512 with x, 5
    Let su7 be proc int512_set_u64 from Int512 with y, 3
    Let sub_rc be proc int512_sub from Int512 with x, y, r
    Let sub_low be proc memory_get_int64 from MemoryCore with r, 0
    If sub_low is not equal to 2:
        Return 21
    End If

    Note: -----------------------------------------------------------------
    Note: Case 22: sub with borrow across limb 0->1 boundary.
    Note: 2^64 - 1 = max_u64 in low limb, zero in high limbs.
    Note: -----------------------------------------------------------------
    Let su8 be proc int512_set_u64 from Int512 with x, 0
    Let zero_b1 be proc memory_set_int64 from MemoryCore with x, 8, 1
    Note: Now x = 2^64 exactly (limb0=0, limb1=1)
    Let su9 be proc int512_set_u64 from Int512 with y, 1
    Let sub_rc2 be proc int512_sub from Int512 with x, y, r
    Let s_low be proc memory_get_int64 from MemoryCore with r, 0
    Let s_hi be proc memory_get_int64 from MemoryCore with r, 8
    If s_low is not equal to all_ones:
        Return 22
    End If
    If s_hi is not equal to 0:
        Return 22
    End If

    Note: -----------------------------------------------------------------
    Note: Case 23: bit_and: 0xF0F0... AND 0x0F0F... = 0
    Note: -----------------------------------------------------------------
    Let pattern_a be 0xF0F0F0F0F0F0F0F0
    Let pattern_b be 0x0F0F0F0F0F0F0F0F
    Let pa0 be proc memory_set_int64 from MemoryCore with x, 0, pattern_a
    Let pa1 be proc memory_set_int64 from MemoryCore with x, 8, pattern_a
    Let pa2 be proc memory_set_int64 from MemoryCore with x, 16, pattern_a
    Let pa3 be proc memory_set_int64 from MemoryCore with x, 24, pattern_a
    Let pa4 be proc memory_set_int64 from MemoryCore with x, 32, pattern_a
    Let pa5 be proc memory_set_int64 from MemoryCore with x, 40, pattern_a
    Let pa6 be proc memory_set_int64 from MemoryCore with x, 48, pattern_a
    Let pa7 be proc memory_set_int64 from MemoryCore with x, 56, pattern_a
    Let pb0 be proc memory_set_int64 from MemoryCore with y, 0, pattern_b
    Let pb1 be proc memory_set_int64 from MemoryCore with y, 8, pattern_b
    Let pb2 be proc memory_set_int64 from MemoryCore with y, 16, pattern_b
    Let pb3 be proc memory_set_int64 from MemoryCore with y, 24, pattern_b
    Let pb4 be proc memory_set_int64 from MemoryCore with y, 32, pattern_b
    Let pb5 be proc memory_set_int64 from MemoryCore with y, 40, pattern_b
    Let pb6 be proc memory_set_int64 from MemoryCore with y, 48, pattern_b
    Let pb7 be proc memory_set_int64 from MemoryCore with y, 56, pattern_b
    Let and_rc be proc int512_bit_and from Int512 with x, y, r
    Let r_and_is_zero be proc int512_is_zero from Int512 with r
    If r_and_is_zero is not equal to 1:
        Return 23
    End If

    Note: -----------------------------------------------------------------
    Note: Case 24: bit_or: 0xF0F0... OR 0x0F0F... = all_ones
    Note: -----------------------------------------------------------------
    Let or_rc be proc int512_bit_or from Int512 with x, y, r
    Let r_or_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let r_or_hi be proc memory_get_int64 from MemoryCore with r, 56
    If r_or_lo is not equal to all_ones:
        Return 24
    End If
    If r_or_hi is not equal to all_ones:
        Return 24
    End If

    Note: -----------------------------------------------------------------
    Note: Case 25: bit_xor: a XOR a = 0
    Note: -----------------------------------------------------------------
    Let xor_rc be proc int512_bit_xor from Int512 with x, x, r
    Let r_xor_zero be proc int512_is_zero from Int512 with r
    If r_xor_zero is not equal to 1:
        Return 25
    End If

    Note: -----------------------------------------------------------------
    Note: Case 26: bit_not: NOT (zero buffer) = all_ones in every limb
    Note: -----------------------------------------------------------------
    Let zret_x be proc int512_set_zero from Int512 with x
    Let not_rc be proc int512_bit_not from Int512 with x, r
    Let nr0 be proc memory_get_int64 from MemoryCore with r, 0
    Let nr7 be proc memory_get_int64 from MemoryCore with r, 56
    If nr0 is not equal to all_ones:
        Return 26
    End If
    If nr7 is not equal to all_ones:
        Return 26
    End If

    Note: -----------------------------------------------------------------
    Note: Case 27: shift_left by 0 preserves value
    Note: -----------------------------------------------------------------
    Let setv be proc int512_set_u64 from Int512 with x, 0xDEADBEEF
    Let shl0 be proc int512_shift_left from Int512 with x, 0, r
    Let s0v be proc memory_get_int64 from MemoryCore with r, 0
    If s0v is not equal to 0xDEADBEEF:
        Return 27
    End If

    Note: -----------------------------------------------------------------
    Note: Case 28: shift_left by 1 of value 5 = 10 (no carry into limb 1)
    Note: -----------------------------------------------------------------
    Let s5 be proc int512_set_u64 from Int512 with x, 5
    Let shl1 be proc int512_shift_left from Int512 with x, 1, r
    Let s1v be proc memory_get_int64 from MemoryCore with r, 0
    Let s1v_hi be proc memory_get_int64 from MemoryCore with r, 8
    If s1v is not equal to 10:
        Return 28
    End If
    If s1v_hi is not equal to 0:
        Return 28
    End If

    Note: -----------------------------------------------------------------
    Note: Case 29: shift_left by 64 of value 7 moves to limb[1], zero in limb[0]
    Note: -----------------------------------------------------------------
    Let s7 be proc int512_set_u64 from Int512 with x, 7
    Let shl64 be proc int512_shift_left from Int512 with x, 64, r
    Let shl64_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let shl64_hi be proc memory_get_int64 from MemoryCore with r, 8
    If shl64_lo is not equal to 0:
        Return 29
    End If
    If shl64_hi is not equal to 7:
        Return 29
    End If

    Note: -----------------------------------------------------------------
    Note: Case 30: shift_left by 65 of value 1: limb[1] should hold 2, limb[0] = 0
    Note: -----------------------------------------------------------------
    Let s1u be proc int512_set_u64 from Int512 with x, 1
    Let shl65 be proc int512_shift_left from Int512 with x, 65, r
    Let s65_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let s65_hi be proc memory_get_int64 from MemoryCore with r, 8
    If s65_lo is not equal to 0:
        Return 30
    End If
    If s65_hi is not equal to 2:
        Return 30
    End If

    Note: -----------------------------------------------------------------
    Note: Case 31: shift_right by 64 of limb[1]=7 should give 7 in limb[0]
    Note: -----------------------------------------------------------------
    Let zr_x be proc int512_set_zero from Int512 with x
    Let store_l1_7 be proc memory_set_int64 from MemoryCore with x, 8, 7
    Let shr64 be proc int512_shift_right from Int512 with x, 64, r
    Let shr64_lo be proc memory_get_int64 from MemoryCore with r, 0
    Let shr64_hi be proc memory_get_int64 from MemoryCore with r, 8
    If shr64_lo is not equal to 7:
        Return 31
    End If
    If shr64_hi is not equal to 0:
        Return 31
    End If

    Note: -----------------------------------------------------------------
    Note: Case 32: shift_right by 1 of value 100 = 50
    Note: -----------------------------------------------------------------
    Let s100 be proc int512_set_u64 from Int512 with x, 100
    Let shr1 be proc int512_shift_right from Int512 with x, 1, r
    Let shr1_lo be proc memory_get_int64 from MemoryCore with r, 0
    If shr1_lo is not equal to 50:
        Return 32
    End If

    Note: -----------------------------------------------------------------
    Note: Case 33: divmod 100 / 7 = quotient 14, remainder 2
    Note: -----------------------------------------------------------------
    Let s100b be proc int512_set_u64 from Int512 with x, 100
    Let s7b be proc int512_set_u64 from Int512 with y, 7
    Let q_out be proc int512_allocate from Int512
    Let r_out be proc int512_allocate from Int512
    Let dm_rc be proc int512_divmod from Int512 with x, y, q_out, r_out
    Let q_lo be proc memory_get_int64 from MemoryCore with q_out, 0
    Let r_lo_dm be proc memory_get_int64 from MemoryCore with r_out, 0
    If q_lo is not equal to 14:
        Return 33
    End If
    If r_lo_dm is not equal to 2:
        Return 33
    End If

    Note: -----------------------------------------------------------------
    Note: Case 34: divmod by zero returns INT512_ERR_DIVIDE_BY_ZERO (-2)
    Note: -----------------------------------------------------------------
    Let zret_y be proc int512_set_zero from Int512 with y
    Let dm_zero_rc be proc int512_divmod from Int512 with x, y, q_out, r_out
    If dm_zero_rc is not equal to -2:
        Return 34
    End If

    Note: -----------------------------------------------------------------
    Note: Case 35: mul 3 * 7 = 21
    Note: -----------------------------------------------------------------
    Let s3m be proc int512_set_u64 from Int512 with x, 3
    Let s7m be proc int512_set_u64 from Int512 with y, 7
    Let mul_rc be proc int512_mul from Int512 with x, y, r
    Let mul_lo be proc memory_get_int64 from MemoryCore with r, 0
    If mul_lo is not equal to 21:
        Return 35
    End If

    Note: -----------------------------------------------------------------
    Note: Case 36: mul (2^64) * (2^64) places 1 at limb[2].
    Note: We construct 2^64 as limb[0]=0, limb[1]=1.
    Note: -----------------------------------------------------------------
    Let zret_x2 be proc int512_set_zero from Int512 with x
    Let setp be proc memory_set_int64 from MemoryCore with x, 8, 1
    Let zret_y2 be proc int512_set_zero from Int512 with y
    Let setp2 be proc memory_set_int64 from MemoryCore with y, 8, 1
    Let mul_rc2 be proc int512_mul from Int512 with x, y, r
    Let mul_l0 be proc memory_get_int64 from MemoryCore with r, 0
    Let mul_l1 be proc memory_get_int64 from MemoryCore with r, 8
    Let mul_l2 be proc memory_get_int64 from MemoryCore with r, 16
    Let mul_l3 be proc memory_get_int64 from MemoryCore with r, 24
    If mul_l0 is not equal to 0:
        Return 36
    End If
    If mul_l1 is not equal to 0:
        Return 36
    End If
    If mul_l2 is not equal to 1:
        Return 36
    End If
    If mul_l3 is not equal to 0:
        Return 36
    End If

    Let f_a be proc int512_free from Int512 with a
    Let f_b be proc int512_free from Int512 with b
    Let f_x be proc int512_free from Int512 with x
    Let f_y be proc int512_free from Int512 with y
    Let f_r be proc int512_free from Int512 with r
    Let f_q be proc int512_free from Int512 with q_out
    Let f_ro be proc int512_free from Int512 with r_out

    Return 0
End Process
