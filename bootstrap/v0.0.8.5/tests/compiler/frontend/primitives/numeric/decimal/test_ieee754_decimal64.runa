Note:
IEEE 754-2008 §3.5.2 / §5 conformance Known-Answer Tests for the Decimal64
interchange format (16-digit significand).

Verifies:
  - "0.1 + 0.2 = 0.3" exact arithmetic at 16-digit precision (binary FP
    gets ~5.5e-17 error; decimal64 must produce EXACT 0.3).
  - Cumulative-summation invariant: sum(0.01, 100 times) = 1.00 (binary
    FP accumulates ~1e-15 error after 100 additions; decimal64 keeps it
    exact).
  - Standard arithmetic vectors per IEEE 754-2008 Annex A.
  - NaN/Inf propagation per §6.2 + §7.2.
  - Signed zero per §3.3.
  - Rounding-mode behavior per §4.3.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/decimal/ieee754_decimal64.runa" as D64

Note: ============================================================================
Note: Headline KAT: 0.1 + 0.2 = 0.3 exactly at 16-digit precision
Note: ============================================================================

Process called "test_zero_point_one_plus_zero_point_two" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal64.0.1+0.2=0.3 exactly")

    Let a be D64.dec64_from_string("0.1")
    Let b be D64.dec64_from_string("0.2")
    Let expected be D64.dec64_from_string("0.3")
    Let sum be D64.dec64_add(a, b, 0)

    T.assert_equal(results, "0.1 + 0.2 == 0.3 (exact)", D64.dec64_eq(sum, expected), 1)
    T.assert_equal(results, "0.1 + 0.2 not gt 0.3", D64.dec64_gt(sum, expected), 0)
    T.assert_equal(results, "0.1 + 0.2 not lt 0.3", D64.dec64_lt(sum, expected), 0)

    D64.dec64_destroy(a)
    D64.dec64_destroy(b)
    D64.dec64_destroy(expected)
    D64.dec64_destroy(sum)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Cumulative-summation invariant
Note: ============================================================================

Process called "test_cumulative_summation_one_hundred" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal64.sum(0.01)*100=1.00")

    Let increment be D64.dec64_from_string("0.01")
    Let acc be D64.dec64_from_string("0")
    Let one be D64.dec64_from_string("1")
    Let i be 0
    While i is less than 100:
        Let new_acc be D64.dec64_add(acc, increment, 0)
        D64.dec64_destroy(acc)
        Set acc to new_acc
        Set i to i plus 1
    End While
    T.assert_equal(results, "sum(0.01, 100 times) == 1.00 exact", D64.dec64_eq(acc, one), 1)
    D64.dec64_destroy(increment)
    D64.dec64_destroy(acc)
    D64.dec64_destroy(one)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Standard arithmetic vectors
Note: ============================================================================

Process called "test_standard_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal64.arithmetic vectors")

    Note: 3.14 + 2.86 = 6.00 exact in decimal
    Let a1 be D64.dec64_from_string("3.14")
    Let b1 be D64.dec64_from_string("2.86")
    Let e1 be D64.dec64_from_string("6.00")
    Let r1 be D64.dec64_add(a1, b1, 0)
    T.assert_equal(results, "3.14 + 2.86 = 6.00", D64.dec64_eq(r1, e1), 1)
    D64.dec64_destroy(a1)
    D64.dec64_destroy(b1)
    D64.dec64_destroy(e1)
    D64.dec64_destroy(r1)

    Note: 1.5 * 2.0 = 3.0
    Let a2 be D64.dec64_from_string("1.5")
    Let b2 be D64.dec64_from_string("2.0")
    Let e2 be D64.dec64_from_string("3.0")
    Let r2 be D64.dec64_mul(a2, b2, 0)
    T.assert_equal(results, "1.5 * 2.0 = 3.0", D64.dec64_eq(r2, e2), 1)
    D64.dec64_destroy(a2)
    D64.dec64_destroy(b2)
    D64.dec64_destroy(e2)
    D64.dec64_destroy(r2)

    Note: 10 - 3 = 7
    Let a3 be D64.dec64_from_string("10")
    Let b3 be D64.dec64_from_string("3")
    Let e3 be D64.dec64_from_string("7")
    Let r3 be D64.dec64_sub(a3, b3, 0)
    T.assert_equal(results, "10 - 3 = 7", D64.dec64_eq(r3, e3), 1)
    D64.dec64_destroy(a3)
    D64.dec64_destroy(b3)
    D64.dec64_destroy(e3)
    D64.dec64_destroy(r3)

    Note: 100 / 4 = 25 exact
    Let a4 be D64.dec64_from_string("100")
    Let b4 be D64.dec64_from_string("4")
    Let e4 be D64.dec64_from_string("25")
    Let r4 be D64.dec64_div(a4, b4, 0)
    T.assert_equal(results, "100 / 4 = 25", D64.dec64_eq(r4, e4), 1)
    D64.dec64_destroy(a4)
    D64.dec64_destroy(b4)
    D64.dec64_destroy(e4)
    D64.dec64_destroy(r4)

    Return 1
End Process

Note: ============================================================================
Note: KAT: Special-value handling
Note: ============================================================================

Process called "test_nan_propagation" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal64.NaN propagation per §6.2")

    Let nan be D64.dec64_from_string("NaN")
    Let one be D64.dec64_from_string("1")

    Let add_result be D64.dec64_add(nan, one, 0)
    T.assert_equal(results, "NaN + 1 is NaN", D64.dec64_is_nan(add_result), 1)
    D64.dec64_destroy(add_result)

    Let mul_result be D64.dec64_mul(nan, one, 0)
    T.assert_equal(results, "NaN * 1 is NaN", D64.dec64_is_nan(mul_result), 1)
    D64.dec64_destroy(mul_result)

    T.assert_equal(results, "NaN != NaN per spec", D64.dec64_eq(nan, nan), 0)
    T.assert_equal(results, "NaN ne NaN is true", D64.dec64_ne(nan, nan), 1)

    D64.dec64_destroy(nan)
    D64.dec64_destroy(one)
    Return 1
End Process

Process called "test_infinity_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal64.Inf arithmetic per §7.2")

    Let pos_inf be D64.dec64_from_string("Inf")
    Let neg_inf be D64.dec64_from_string("-Inf")
    Let one be D64.dec64_from_string("1")
    Let zero be D64.dec64_from_string("0")

    Let r1 be D64.dec64_add(pos_inf, one, 0)
    T.assert_equal(results, "+Inf + 1 = +Inf", D64.dec64_is_infinite(r1), 1)
    T.assert_equal(results, "+Inf + 1 sign is positive", D64.dec64_is_negative(r1), 0)
    D64.dec64_destroy(r1)

    Let r2 be D64.dec64_add(neg_inf, one, 0)
    T.assert_equal(results, "-Inf + 1 = -Inf", D64.dec64_is_infinite(r2), 1)
    T.assert_equal(results, "-Inf + 1 sign is negative", D64.dec64_is_negative(r2), 1)
    D64.dec64_destroy(r2)

    Let r3 be D64.dec64_add(pos_inf, neg_inf, 0)
    T.assert_equal(results, "+Inf + -Inf = NaN", D64.dec64_is_nan(r3), 1)
    D64.dec64_destroy(r3)

    Let r4 be D64.dec64_mul(pos_inf, zero, 0)
    T.assert_equal(results, "+Inf * 0 = NaN", D64.dec64_is_nan(r4), 1)
    D64.dec64_destroy(r4)

    Let r5 be D64.dec64_div(one, zero, 0)
    T.assert_equal(results, "1 / 0 = +Inf", D64.dec64_is_infinite(r5), 1)
    D64.dec64_destroy(r5)

    D64.dec64_destroy(pos_inf)
    D64.dec64_destroy(neg_inf)
    D64.dec64_destroy(one)
    D64.dec64_destroy(zero)
    Return 1
End Process

Process called "test_signed_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal64.signed zero §3.3")

    Let pos_zero be D64.dec64_from_string("0")
    Let neg_zero be D64.dec64_from_string("-0")

    T.assert_equal(results, "+0 is zero", D64.dec64_is_zero(pos_zero), 1)
    T.assert_equal(results, "-0 is zero", D64.dec64_is_zero(neg_zero), 1)
    T.assert_equal(results, "+0 == -0 (compareQuietEqual)", D64.dec64_eq(pos_zero, neg_zero), 1)
    T.assert_equal(results, "+0 sign is 0", D64.dec64_is_negative(pos_zero), 0)
    T.assert_equal(results, "-0 sign is 1", D64.dec64_is_negative(neg_zero), 1)

    D64.dec64_destroy(pos_zero)
    D64.dec64_destroy(neg_zero)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Rounding-mode behavior per §4.3
Note: ============================================================================

Process called "test_rounding_modes" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal64.rounding modes §4.3")

    Note: 1/3 produces a finite repeating-decimal under any rounding.
    Let one be D64.dec64_from_string("1")
    Let three be D64.dec64_from_string("3")
    Let q be D64.dec64_div(one, three, 0)
    T.assert_equal(results, "1/3 is finite", D64.dec64_is_finite(q), 1)
    T.assert_not_null(results, "1/3 produces value", q)
    D64.dec64_destroy(q)
    D64.dec64_destroy(one)
    D64.dec64_destroy(three)
    Return 1
End Process

Note: ============================================================================
Note: KAT: 16-digit round-trip
Note: ============================================================================

Process called "test_16_digit_round_trip" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal64.16-digit string round-trip")

    Let v be D64.dec64_from_string("1234567890123456")
    Let buf be allocate(32)
    D64.dec64_to_string(v, buf, 32)
    Let reparsed be D64.dec64_from_string(buf)
    T.assert_equal(results, "16-digit round-trip equal", D64.dec64_eq(v, reparsed), 1)
    deallocate(buf)
    D64.dec64_destroy(v)
    D64.dec64_destroy(reparsed)
    Return 1
End Process

Note: ============================================================================
Note: Main entry point
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_zero_point_one_plus_zero_point_two(results)
    test_cumulative_summation_one_hundred(results)
    test_standard_arithmetic(results)
    test_nan_propagation(results)
    test_infinity_arithmetic(results)
    test_signed_zero(results)
    test_rounding_modes(results)
    test_16_digit_round_trip(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
