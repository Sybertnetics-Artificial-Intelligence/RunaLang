Note:
IEEE 754-2008 §3.5.2 / §5 conformance Known-Answer Tests for the Decimal32
interchange format (7-digit significand).

Verifies:
  - "0.1 + 0.2 = 0.3" exact arithmetic at 7-digit precision (binary FP
    binary32 gets ~3e-8 error; decimal32 must produce EXACT 0.3).
  - Standard arithmetic vectors per IEEE 754-2008 Annex A.
  - NaN/Inf propagation per §6.2 + §7.2.
  - Signed zero per §3.3 - sign preservation through arithmetic.
  - Rounding modes (HALF_EVEN, HALF_UP differ on 0.5 ties per §4.3).
  - Exponent overflow -> Inf with correct sign per §7.4.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/decimal/ieee754_decimal32.runa" as D32

Note: ============================================================================
Note: Headline KAT: 0.1 + 0.2 = 0.3 exactly at 7-digit precision
Note: ============================================================================

Process called "test_zero_point_one_plus_zero_point_two" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal32.0.1+0.2=0.3 exactly")

    Let a be D32.dec32_from_string("0.1")
    Let b be D32.dec32_from_string("0.2")
    Let expected be D32.dec32_from_string("0.3")
    Let sum be D32.dec32_add(a, b, 0)

    T.assert_equal(results, "0.1 + 0.2 == 0.3 (exact)", D32.dec32_eq(sum, expected), 1)
    T.assert_equal(results, "0.1 + 0.2 not gt 0.3", D32.dec32_gt(sum, expected), 0)
    T.assert_equal(results, "0.1 + 0.2 not lt 0.3", D32.dec32_lt(sum, expected), 0)

    D32.dec32_destroy(a)
    D32.dec32_destroy(b)
    D32.dec32_destroy(expected)
    D32.dec32_destroy(sum)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Standard arithmetic vectors
Note: ============================================================================

Process called "test_standard_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal32.arithmetic vectors")

    Note: 3.14 + 2.86 = 6.00 exact in decimal
    Let a1 be D32.dec32_from_string("3.14")
    Let b1 be D32.dec32_from_string("2.86")
    Let e1 be D32.dec32_from_string("6.00")
    Let r1 be D32.dec32_add(a1, b1, 0)
    T.assert_equal(results, "3.14 + 2.86 = 6.00", D32.dec32_eq(r1, e1), 1)
    D32.dec32_destroy(a1)
    D32.dec32_destroy(b1)
    D32.dec32_destroy(e1)
    D32.dec32_destroy(r1)

    Note: 1.5 * 2.0 = 3.0
    Let a2 be D32.dec32_from_string("1.5")
    Let b2 be D32.dec32_from_string("2.0")
    Let e2 be D32.dec32_from_string("3.0")
    Let r2 be D32.dec32_mul(a2, b2, 0)
    T.assert_equal(results, "1.5 * 2.0 = 3.0", D32.dec32_eq(r2, e2), 1)
    D32.dec32_destroy(a2)
    D32.dec32_destroy(b2)
    D32.dec32_destroy(e2)
    D32.dec32_destroy(r2)

    Note: 10 - 3 = 7
    Let a3 be D32.dec32_from_string("10")
    Let b3 be D32.dec32_from_string("3")
    Let e3 be D32.dec32_from_string("7")
    Let r3 be D32.dec32_sub(a3, b3, 0)
    T.assert_equal(results, "10 - 3 = 7", D32.dec32_eq(r3, e3), 1)
    D32.dec32_destroy(a3)
    D32.dec32_destroy(b3)
    D32.dec32_destroy(e3)
    D32.dec32_destroy(r3)

    Note: 100 / 4 = 25
    Let a4 be D32.dec32_from_string("100")
    Let b4 be D32.dec32_from_string("4")
    Let e4 be D32.dec32_from_string("25")
    Let r4 be D32.dec32_div(a4, b4, 0)
    T.assert_equal(results, "100 / 4 = 25", D32.dec32_eq(r4, e4), 1)
    D32.dec32_destroy(a4)
    D32.dec32_destroy(b4)
    D32.dec32_destroy(e4)
    D32.dec32_destroy(r4)

    Return 1
End Process

Note: ============================================================================
Note: KAT: NaN propagation per §6.2
Note: ============================================================================

Process called "test_nan_propagation" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal32.NaN propagation §6.2")

    Let nan be D32.dec32_from_string("NaN")
    Let one be D32.dec32_from_string("1")

    Let add_result be D32.dec32_add(nan, one, 0)
    T.assert_equal(results, "NaN + 1 is NaN", D32.dec32_is_nan(add_result), 1)
    D32.dec32_destroy(add_result)

    Let mul_result be D32.dec32_mul(nan, one, 0)
    T.assert_equal(results, "NaN * 1 is NaN", D32.dec32_is_nan(mul_result), 1)
    D32.dec32_destroy(mul_result)

    Let sub_result be D32.dec32_sub(nan, one, 0)
    T.assert_equal(results, "NaN - 1 is NaN", D32.dec32_is_nan(sub_result), 1)
    D32.dec32_destroy(sub_result)

    Note: NaN != NaN per §5.11.
    T.assert_equal(results, "NaN != NaN per spec", D32.dec32_eq(nan, nan), 0)
    T.assert_equal(results, "NaN ne NaN is true", D32.dec32_ne(nan, nan), 1)

    D32.dec32_destroy(nan)
    D32.dec32_destroy(one)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Infinity arithmetic per §7.2
Note: ============================================================================

Process called "test_infinity_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal32.Inf arithmetic §7.2")

    Let pos_inf be D32.dec32_from_string("Inf")
    Let neg_inf be D32.dec32_from_string("-Inf")
    Let one be D32.dec32_from_string("1")
    Let zero be D32.dec32_from_string("0")

    Let r1 be D32.dec32_add(pos_inf, one, 0)
    T.assert_equal(results, "+Inf + 1 = +Inf", D32.dec32_is_infinite(r1), 1)
    T.assert_equal(results, "+Inf + 1 is positive", D32.dec32_is_negative(r1), 0)
    D32.dec32_destroy(r1)

    Let r2 be D32.dec32_add(neg_inf, one, 0)
    T.assert_equal(results, "-Inf + 1 = -Inf", D32.dec32_is_infinite(r2), 1)
    T.assert_equal(results, "-Inf + 1 is negative", D32.dec32_is_negative(r2), 1)
    D32.dec32_destroy(r2)

    Let r3 be D32.dec32_add(pos_inf, neg_inf, 0)
    T.assert_equal(results, "+Inf + -Inf = NaN (invalid)", D32.dec32_is_nan(r3), 1)
    D32.dec32_destroy(r3)

    Let r4 be D32.dec32_mul(pos_inf, zero, 0)
    T.assert_equal(results, "+Inf * 0 = NaN (invalid)", D32.dec32_is_nan(r4), 1)
    D32.dec32_destroy(r4)

    Let r5 be D32.dec32_div(one, zero, 0)
    T.assert_equal(results, "1 / 0 = +Inf (divideByZero)", D32.dec32_is_infinite(r5), 1)
    D32.dec32_destroy(r5)

    D32.dec32_destroy(pos_inf)
    D32.dec32_destroy(neg_inf)
    D32.dec32_destroy(one)
    D32.dec32_destroy(zero)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Signed zero per §3.3
Note: ============================================================================

Process called "test_signed_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal32.signed zero §3.3")

    Let pos_zero be D32.dec32_from_string("0")
    Let neg_zero be D32.dec32_from_string("-0")

    T.assert_equal(results, "+0 is zero", D32.dec32_is_zero(pos_zero), 1)
    T.assert_equal(results, "-0 is zero", D32.dec32_is_zero(neg_zero), 1)
    T.assert_equal(results, "+0 == -0 (compareQuietEqual)", D32.dec32_eq(pos_zero, neg_zero), 1)
    T.assert_equal(results, "+0 sign is 0", D32.dec32_is_negative(pos_zero), 0)
    T.assert_equal(results, "-0 sign is 1", D32.dec32_is_negative(neg_zero), 1)

    Note: Negation of zero flips the sign.
    Let neg_pos_zero be D32.dec32_neg(pos_zero, 0)
    T.assert_equal(results, "neg(+0) sign is 1", D32.dec32_is_negative(neg_pos_zero), 1)
    T.assert_equal(results, "neg(+0) still zero", D32.dec32_is_zero(neg_pos_zero), 1)
    D32.dec32_destroy(neg_pos_zero)

    D32.dec32_destroy(pos_zero)
    D32.dec32_destroy(neg_zero)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Sign preservation through arithmetic
Note: ============================================================================

Process called "test_sign_preservation" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal32.sign preservation")

    Let neg_one be D32.dec32_from_string("-1")
    Let pos_two be D32.dec32_from_string("2")
    Let zero be D32.dec32_from_string("0")

    Note: -1 * 2 = -2
    Let r1 be D32.dec32_mul(neg_one, pos_two, 0)
    T.assert_equal(results, "-1 * 2 is negative", D32.dec32_is_negative(r1), 1)
    D32.dec32_destroy(r1)

    Note: -1 + 0 = -1 (sign preserved across zero add)
    Let r2 be D32.dec32_add(neg_one, zero, 0)
    T.assert_equal(results, "-1 + 0 sign preserved", D32.dec32_is_negative(r2), 1)
    D32.dec32_destroy(r2)

    Note: -1 - (-1) = 0 (sign 0 under HALF_EVEN per §6.3)
    Let r3 be D32.dec32_sub(neg_one, neg_one, 0)
    T.assert_equal(results, "-1 - (-1) is zero", D32.dec32_is_zero(r3), 1)
    D32.dec32_destroy(r3)

    D32.dec32_destroy(neg_one)
    D32.dec32_destroy(pos_two)
    D32.dec32_destroy(zero)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Exponent overflow -> Inf per §7.4
Note: ============================================================================

Process called "test_exponent_overflow" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal32.overflow -> Inf §7.4")

    Note: Decimal32 has Emax = 96 (exponent range up to ~10^96).
    Note: 9.999999E96 (max-finite) * 10 should overflow to +Inf.
    Let max_like be D32.dec32_from_string("9.999999E96")
    Let ten be D32.dec32_from_string("10")
    Let r1 be D32.dec32_mul(max_like, ten, 0)
    T.assert_equal(results, "9.999999E96 * 10 = +Inf", D32.dec32_is_infinite(r1), 1)
    T.assert_equal(results, "+overflow is positive", D32.dec32_is_negative(r1), 0)
    D32.dec32_destroy(r1)

    Note: -9.999999E96 * 10 should overflow to -Inf.
    Let neg_max be D32.dec32_from_string("-9.999999E96")
    Let r2 be D32.dec32_mul(neg_max, ten, 0)
    T.assert_equal(results, "-9.999999E96 * 10 = -Inf", D32.dec32_is_infinite(r2), 1)
    T.assert_equal(results, "-overflow is negative", D32.dec32_is_negative(r2), 1)
    D32.dec32_destroy(r2)

    D32.dec32_destroy(max_like)
    D32.dec32_destroy(ten)
    D32.dec32_destroy(neg_max)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Rounding modes per §4.3 (0.5 ties)
Note: ============================================================================

Process called "test_rounding_half_even_vs_half_up" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal32.HALF_EVEN vs HALF_UP at ties §4.3")

    Note: HALF_EVEN and HALF_UP differ at exact 0.5 ties: HALF_EVEN
    Note: rounds to the nearest even last digit ("banker's rounding"),
    Note: HALF_UP always rounds away from zero. We use to_integer with
    Note: half-even (mode 0) vs half-up (mode 1) on 0.5 (i.e. 5E-1).
    Let half be D32.dec32_from_string("0.5")
    Let half_even_int be D32.dec32_to_integer(half, 0)
    T.assert_equal(results, "0.5 -> 0 under HALF_EVEN (rounds to even)", half_even_int, 0)
    Let half_up_int be D32.dec32_to_integer(half, 1)
    T.assert_equal(results, "0.5 -> 1 under HALF_UP", half_up_int, 1)
    D32.dec32_destroy(half)

    Note: 1.5 -> 2 under HALF_EVEN (tie -> even = 2)
    Note:     -> 2 under HALF_UP (always away from zero)
    Let one_point_five be D32.dec32_from_string("1.5")
    T.assert_equal(results, "1.5 -> 2 under HALF_EVEN", D32.dec32_to_integer(one_point_five, 0), 2)
    T.assert_equal(results, "1.5 -> 2 under HALF_UP", D32.dec32_to_integer(one_point_five, 1), 2)
    D32.dec32_destroy(one_point_five)

    Note: 2.5 -> 2 under HALF_EVEN (tie -> even = 2)
    Note:     -> 3 under HALF_UP
    Let two_point_five be D32.dec32_from_string("2.5")
    T.assert_equal(results, "2.5 -> 2 under HALF_EVEN (banker's)", D32.dec32_to_integer(two_point_five, 0), 2)
    T.assert_equal(results, "2.5 -> 3 under HALF_UP", D32.dec32_to_integer(two_point_five, 1), 3)
    D32.dec32_destroy(two_point_five)

    Return 1
End Process

Note: ============================================================================
Note: Main entry point
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_zero_point_one_plus_zero_point_two(results)
    test_standard_arithmetic(results)
    test_nan_propagation(results)
    test_infinity_arithmetic(results)
    test_signed_zero(results)
    test_sign_preservation(results)
    test_exponent_overflow(results)
    test_rounding_half_even_vs_half_up(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
