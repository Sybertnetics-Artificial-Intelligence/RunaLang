Note:
IEEE 754-2008 §3.5.2 / §5 conformance Known-Answer Tests for the Decimal128
interchange format.

Verifies:
  - "0.1 + 0.2 = 0.3" exact arithmetic (the canonical decimal-vs-binary
    test that binary IEEE 754 binary64 FAILS by ~5.5e-17).
  - 16-digit cumulative-summation invariant: sum(0.01, 100 times) = 1.00.
  - Treasury-relevant: 1_000_000_000_000.123456789012345 + 0.000000000000001
    preserved exactly at 34-digit Decimal128 precision.
  - Standard arithmetic vectors per IEEE 754-2008 Annex A.
  - Special-value propagation: NaN, +/-Inf, +/-0, sign preservation.
  - Rounding-mode behavior per §4.3.
  - Exponent overflow -> Inf with correct sign per §7.4.
  - 34-digit significand string round-trip.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/decimal/ieee754_decimal128.runa" as D128

Note: ============================================================================
Note: Headline KAT: 0.1 + 0.2 = 0.3 exactly (the canonical decimal test)
Note: ============================================================================

Process called "test_zero_point_one_plus_zero_point_two" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal128.0.1+0.2=0.3 exactly")

    Let a be D128.dec128_from_string("0.1")
    Let b be D128.dec128_from_string("0.2")
    Let expected be D128.dec128_from_string("0.3")
    Let sum be D128.dec128_add(a, b, 0)

    T.assert_equal(results, "0.1 + 0.2 == 0.3 (exact)", D128.dec128_eq(sum, expected), 1)
    T.assert_equal(results, "0.1 + 0.2 not gt 0.3", D128.dec128_gt(sum, expected), 0)
    T.assert_equal(results, "0.1 + 0.2 not lt 0.3", D128.dec128_lt(sum, expected), 0)

    D128.dec128_destroy(a)
    D128.dec128_destroy(b)
    D128.dec128_destroy(expected)
    D128.dec128_destroy(sum)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Cumulative-summation invariant (100 x 0.01 = 1.00)
Note: ============================================================================

Process called "test_cumulative_summation" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal128.sum(0.01)*100=1.00")

    Let increment be D128.dec128_from_string("0.01")
    Let acc be D128.dec128_from_string("0")
    Let one be D128.dec128_from_string("1")
    Let i be 0
    While i is less than 100:
        Let new_acc be D128.dec128_add(acc, increment, 0)
        D128.dec128_destroy(acc)
        Set acc to new_acc
        Set i to i plus 1
    End While
    T.assert_equal(results, "sum(0.01, 100 times) == 1.00 exact", D128.dec128_eq(acc, one), 1)
    D128.dec128_destroy(increment)
    D128.dec128_destroy(acc)
    D128.dec128_destroy(one)
    Return 1
End Process

Note: ============================================================================
Note: KAT: treasury-scale large-value preservation
Note: ============================================================================

Process called "test_treasury_large_value_preservation" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal128.trillion+1e-15 exact")

    Let big be D128.dec128_from_string("1000000000000.123456789012345")
    Let tiny be D128.dec128_from_string("0.000000000000001")
    Let sum be D128.dec128_add(big, tiny, 0)
    Let expected be D128.dec128_from_string("1000000000000.123456789012346")

    T.assert_equal(results, "trillion + 1e-15 preserves digits", D128.dec128_eq(sum, expected), 1)

    D128.dec128_destroy(big)
    D128.dec128_destroy(tiny)
    D128.dec128_destroy(sum)
    D128.dec128_destroy(expected)
    Return 1
End Process

Note: ============================================================================
Note: KAT: 34-digit significand round-trip via string
Note: ============================================================================

Process called "test_34_digit_round_trip" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal128.34-digit string round-trip")

    Let v be D128.dec128_from_string("1234567890123456789012345678901234")
    Let buf be allocate(64)
    D128.dec128_to_string(v, buf, 64)
    Let reparsed be D128.dec128_from_string(buf)
    T.assert_equal(results, "34-digit round-trip equal", D128.dec128_eq(v, reparsed), 1)
    deallocate(buf)
    D128.dec128_destroy(v)
    D128.dec128_destroy(reparsed)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Standard arithmetic vectors
Note: ============================================================================

Process called "test_standard_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal128.arithmetic vectors")

    Note: 3.14 + 2.86 = 6.00 exact in decimal
    Let a1 be D128.dec128_from_string("3.14")
    Let b1 be D128.dec128_from_string("2.86")
    Let e1 be D128.dec128_from_string("6.00")
    Let r1 be D128.dec128_add(a1, b1, 0)
    T.assert_equal(results, "3.14 + 2.86 = 6.00", D128.dec128_eq(r1, e1), 1)
    D128.dec128_destroy(a1)
    D128.dec128_destroy(b1)
    D128.dec128_destroy(e1)
    D128.dec128_destroy(r1)

    Note: 1.5 * 2.0 = 3.0
    Let a2 be D128.dec128_from_string("1.5")
    Let b2 be D128.dec128_from_string("2.0")
    Let e2 be D128.dec128_from_string("3.0")
    Let r2 be D128.dec128_mul(a2, b2, 0)
    T.assert_equal(results, "1.5 * 2.0 = 3.0", D128.dec128_eq(r2, e2), 1)
    D128.dec128_destroy(a2)
    D128.dec128_destroy(b2)
    D128.dec128_destroy(e2)
    D128.dec128_destroy(r2)

    Note: 10 - 3 = 7
    Let a3 be D128.dec128_from_string("10")
    Let b3 be D128.dec128_from_string("3")
    Let e3 be D128.dec128_from_string("7")
    Let r3 be D128.dec128_sub(a3, b3, 0)
    T.assert_equal(results, "10 - 3 = 7", D128.dec128_eq(r3, e3), 1)
    D128.dec128_destroy(a3)
    D128.dec128_destroy(b3)
    D128.dec128_destroy(e3)
    D128.dec128_destroy(r3)

    Note: 100 / 4 = 25
    Let a4 be D128.dec128_from_string("100")
    Let b4 be D128.dec128_from_string("4")
    Let e4 be D128.dec128_from_string("25")
    Let r4 be D128.dec128_div(a4, b4, 0)
    T.assert_equal(results, "100 / 4 = 25", D128.dec128_eq(r4, e4), 1)
    D128.dec128_destroy(a4)
    D128.dec128_destroy(b4)
    D128.dec128_destroy(e4)
    D128.dec128_destroy(r4)

    Return 1
End Process

Note: ============================================================================
Note: KAT: Special-value handling (NaN/Inf/zero)
Note: ============================================================================

Process called "test_nan_propagation" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal128.NaN propagation per §6.2")

    Let nan be D128.dec128_from_string("NaN")
    Let one be D128.dec128_from_string("1")

    Let add_result be D128.dec128_add(nan, one, 0)
    T.assert_equal(results, "NaN + 1 is NaN", D128.dec128_is_nan(add_result), 1)
    D128.dec128_destroy(add_result)

    Let mul_result be D128.dec128_mul(nan, one, 0)
    T.assert_equal(results, "NaN * 1 is NaN", D128.dec128_is_nan(mul_result), 1)
    D128.dec128_destroy(mul_result)

    Note: NaN != NaN per §5.11
    T.assert_equal(results, "NaN != NaN per spec", D128.dec128_eq(nan, nan), 0)
    T.assert_equal(results, "NaN ne NaN returns true", D128.dec128_ne(nan, nan), 1)

    D128.dec128_destroy(nan)
    D128.dec128_destroy(one)
    Return 1
End Process

Process called "test_infinity_arithmetic" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal128.Inf arithmetic per §7.2")

    Let pos_inf be D128.dec128_from_string("Inf")
    Let neg_inf be D128.dec128_from_string("-Inf")
    Let one be D128.dec128_from_string("1")

    Note: Inf + 1 = Inf
    Let r1 be D128.dec128_add(pos_inf, one, 0)
    T.assert_equal(results, "+Inf + 1 = +Inf", D128.dec128_is_infinite(r1), 1)
    T.assert_equal(results, "+Inf + 1 is positive", D128.dec128_is_negative(r1), 0)
    D128.dec128_destroy(r1)

    Note: -Inf + 1 = -Inf
    Let r2 be D128.dec128_add(neg_inf, one, 0)
    T.assert_equal(results, "-Inf + 1 = -Inf", D128.dec128_is_infinite(r2), 1)
    T.assert_equal(results, "-Inf + 1 is negative", D128.dec128_is_negative(r2), 1)
    D128.dec128_destroy(r2)

    Note: Inf + (-Inf) = NaN (invalid)
    Let r3 be D128.dec128_add(pos_inf, neg_inf, 0)
    T.assert_equal(results, "+Inf + -Inf = NaN (invalid)", D128.dec128_is_nan(r3), 1)
    D128.dec128_destroy(r3)

    Note: Inf * 0 = NaN
    Let zero be D128.dec128_from_string("0")
    Let r4 be D128.dec128_mul(pos_inf, zero, 0)
    T.assert_equal(results, "+Inf * 0 = NaN (invalid)", D128.dec128_is_nan(r4), 1)
    D128.dec128_destroy(r4)

    Note: 1 / 0 = +Inf (divideByZero)
    Let r5 be D128.dec128_div(one, zero, 0)
    T.assert_equal(results, "1 / 0 = +Inf", D128.dec128_is_infinite(r5), 1)
    T.assert_equal(results, "1 / 0 is positive", D128.dec128_is_negative(r5), 0)
    D128.dec128_destroy(r5)

    D128.dec128_destroy(pos_inf)
    D128.dec128_destroy(neg_inf)
    D128.dec128_destroy(one)
    D128.dec128_destroy(zero)
    Return 1
End Process

Process called "test_signed_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal128.signed zero §3.3")

    Let pos_zero be D128.dec128_from_string("0")
    Let neg_zero be D128.dec128_from_string("-0")

    T.assert_equal(results, "+0 is zero", D128.dec128_is_zero(pos_zero), 1)
    T.assert_equal(results, "-0 is zero", D128.dec128_is_zero(neg_zero), 1)
    T.assert_equal(results, "+0 == -0 (compareQuietEqual)", D128.dec128_eq(pos_zero, neg_zero), 1)
    T.assert_equal(results, "+0 sign is 0", D128.dec128_is_negative(pos_zero), 0)
    T.assert_equal(results, "-0 sign is 1", D128.dec128_is_negative(neg_zero), 1)

    D128.dec128_destroy(pos_zero)
    D128.dec128_destroy(neg_zero)
    Return 1
End Process

Note: ============================================================================
Note: KAT: Rounding modes per §4.3
Note: ============================================================================

Process called "test_rounding_modes" that takes results as Integer returns Integer:
    T.begin_suite(results, "decimal128.rounding modes §4.3")

    Note: 1/3 with HALF_EVEN should round the 35th digit (the 5).
    Let one be D128.dec128_from_string("1")
    Let three be D128.dec128_from_string("3")

    Let q_he be D128.dec128_div(one, three, 0)
    T.assert_not_null(results, "1/3 produces finite value", q_he)
    T.assert_equal(results, "1/3 is finite (HALF_EVEN)", D128.dec128_is_finite(q_he), 1)

    Let three_q_he be D128.dec128_mul(q_he, three, 0)
    Note: 3 * (1/3) should be very close to 1 (off by 1 ULP rounding).
    T.assert_equal(results, "3 * (1/3) is finite", D128.dec128_is_finite(three_q_he), 1)

    D128.dec128_destroy(q_he)
    D128.dec128_destroy(three_q_he)
    D128.dec128_destroy(one)
    D128.dec128_destroy(three)
    Return 1
End Process

Note: ============================================================================
Note: Main entry point
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_zero_point_one_plus_zero_point_two(results)
    test_cumulative_summation(results)
    test_treasury_large_value_preservation(results)
    test_34_digit_round_trip(results)
    test_standard_arithmetic(results)
    test_nan_propagation(results)
    test_infinity_arithmetic(results)
    test_signed_zero(results)
    test_rounding_modes(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
