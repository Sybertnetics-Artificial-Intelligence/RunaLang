Note:
==============================================================================
Self-consistency tests for ieee754_binary256.runa.

Published Float256 KAT suites are scarce, so we drive correctness via
self-consistency: a + b - b == a, a * b / b ~ a, sqrt(x*x) == x, etc.

Coverage:
  - Construction of canonical specials (+0, -0, +Inf, -Inf, qNaN)
  - Classification
  - Field accessors
  - Unary (neg, abs)
  - Comparison (eq/ne/lt/le/gt/ge with NaN unordered)
  - Pack/unpack 32 bytes (LE and BE)
  - Float64 <-> Float256 round-trip
  - Float128 <-> Float256 round-trip
  - Integer <-> Float256 round-trip
  - Addition: 1+1=2, 1+(-1)=0, NaN propagation
  - Multiplication: 2*2=4, 0*Inf=NaN
  - Self-consistency: (a+b)-b = a for representable values
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/binary/ieee754_binary256.runa" as F256
Import "runtime/core/memory/arena.runa" as Arena

Process called "test_classification" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f256.classification")
    Let pos_zero be F256.f256_make_zero(arena, 0)
    Let neg_zero be F256.f256_make_zero(arena, 1)
    Let pos_inf be F256.f256_make_inf(arena, 0)
    Let neg_inf be F256.f256_make_inf(arena, 1)
    Let qnan be F256.f256_make_qnan(arena)
    Let one be F256.f256_from_integer(arena, 1)

    T.assert_equal(results, "is_zero(+0)", F256.f256_is_zero(pos_zero), 1)
    T.assert_equal(results, "is_zero(-0)", F256.f256_is_zero(neg_zero), 1)
    T.assert_equal(results, "is_zero(+1)", F256.f256_is_zero(one), 0)
    T.assert_equal(results, "is_inf(+Inf)", F256.f256_is_inf(pos_inf), 1)
    T.assert_equal(results, "is_inf(-Inf)", F256.f256_is_inf(neg_inf), 1)
    T.assert_equal(results, "is_nan(qNaN)", F256.f256_is_nan(qnan), 1)
    T.assert_equal(results, "is_finite(+1)", F256.f256_is_finite(one), 1)
    T.assert_equal(results, "is_finite(+Inf)", F256.f256_is_finite(pos_inf), 0)
    T.assert_equal(results, "is_normal(+1)", F256.f256_is_normal(one), 1)
    T.assert_equal(results, "is_normal(+0)", F256.f256_is_normal(pos_zero), 0)
    Return 1
End Process

Process called "test_unary" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f256.unary")
    Let one be F256.f256_from_integer(arena, 1)
    Let neg_one be F256.f256_neg(arena, one)
    T.assert_equal(results, "neg(+1) is negative", F256.f256_is_negative(neg_one), 1)
    Let abs_neg_one be F256.f256_abs(arena, neg_one)
    T.assert_equal(results, "abs(-1) is positive", F256.f256_is_negative(abs_neg_one), 0)
    T.assert_equal(results, "abs(-1) == +1", F256.f256_eq(abs_neg_one, one), 1)
    Return 1
End Process

Process called "test_comparison" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f256.comparison")
    Let one be F256.f256_from_integer(arena, 1)
    Let two be F256.f256_from_integer(arena, 2)
    Let neg_one be F256.f256_from_integer(arena, 0 minus 1)
    Let qnan be F256.f256_make_qnan(arena)

    T.assert_equal(results, "+1 == +1", F256.f256_eq(one, one), 1)
    T.assert_equal(results, "+1 != +2", F256.f256_ne(one, two), 1)
    T.assert_equal(results, "+1 < +2", F256.f256_lt(one, two), 1)
    T.assert_equal(results, "+2 < +1 -> false", F256.f256_lt(two, one), 0)
    T.assert_equal(results, "-1 < +1", F256.f256_lt(neg_one, one), 1)
    T.assert_equal(results, "+1 <= +1", F256.f256_le(one, one), 1)
    T.assert_equal(results, "+2 > +1", F256.f256_gt(two, one), 1)
    T.assert_equal(results, "+1 >= +1", F256.f256_ge(one, one), 1)
    T.assert_equal(results, "NaN == NaN -> false", F256.f256_eq(qnan, qnan), 0)
    T.assert_equal(results, "NaN != NaN -> true", F256.f256_ne(qnan, qnan), 1)
    T.assert_equal(results, "NaN < +1 -> false", F256.f256_lt(qnan, one), 0)

    Return 1
End Process

Process called "test_pack_unpack" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f256.pack_unpack")
    Let one be F256.f256_from_integer(arena, 1)
    Let buffer be allocate(32)
    F256.f256_pack_bytes_le(one, buffer)
    Let round_trip be F256.f256_unpack_bytes_le(arena, buffer)
    T.assert_equal(results, "LE pack/unpack round-trip +1", F256.f256_eq(round_trip, one), 1)

    F256.f256_pack_bytes_be(one, buffer)
    Let round_trip_be be F256.f256_unpack_bytes_be(arena, buffer)
    T.assert_equal(results, "BE pack/unpack round-trip +1", F256.f256_eq(round_trip_be, one), 1)

    Return 1
End Process

Process called "test_integer_conv" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f256.integer_conv")
    T.assert_equal(results, "to_integer(from_integer(0))", F256.f256_to_integer(F256.f256_from_integer(arena, 0)), 0)
    T.assert_equal(results, "to_integer(from_integer(1))", F256.f256_to_integer(F256.f256_from_integer(arena, 1)), 1)
    T.assert_equal(results, "to_integer(from_integer(42))", F256.f256_to_integer(F256.f256_from_integer(arena, 42)), 42)
    T.assert_equal(results, "to_integer(from_integer(-1))", F256.f256_to_integer(F256.f256_from_integer(arena, 0 minus 1)), 0 minus 1)
    T.assert_equal(results, "to_integer(from_integer(1000000))", F256.f256_to_integer(F256.f256_from_integer(arena, 1000000)), 1000000)
    Return 1
End Process

Process called "test_float64_conv" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f256.float64_conv")
    Let one_f64 be 4607182418800017408
    Let promoted be F256.f256_from_float64(arena, one_f64)
    Let demoted be F256.f256_to_float64(promoted)
    T.assert_equal(results, "1.0 round-trip via float64", demoted, one_f64)

    Let two_f64 be 4611686018427387904
    Let two_promoted be F256.f256_from_float64(arena, two_f64)
    T.assert_equal(results, "2.0 round-trip via float64", F256.f256_to_float64(two_promoted), two_f64)
    Return 1
End Process

Process called "test_addition" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f256.addition")
    Let one be F256.f256_from_integer(arena, 1)
    Let two be F256.f256_from_integer(arena, 2)
    Let three be F256.f256_from_integer(arena, 3)

    Let r1 be F256.f256_add(arena, one, one)
    T.assert_equal(results, "1+1 = 2", F256.f256_eq(r1, two), 1)
    Let r2 be F256.f256_add(arena, one, two)
    T.assert_equal(results, "1+2 = 3", F256.f256_eq(r2, three), 1)
    Let neg_one be F256.f256_neg(arena, one)
    Let cancel be F256.f256_add(arena, one, neg_one)
    T.assert_equal(results, "1+(-1) = 0", F256.f256_is_zero(cancel), 1)

    Let qnan be F256.f256_make_qnan(arena)
    Let nan_plus_one be F256.f256_add(arena, qnan, one)
    T.assert_equal(results, "NaN+1 = NaN", F256.f256_is_nan(nan_plus_one), 1)

    Let pos_inf be F256.f256_make_inf(arena, 0)
    Let neg_inf be F256.f256_make_inf(arena, 1)
    Let inf_plus_one be F256.f256_add(arena, pos_inf, one)
    T.assert_equal(results, "Inf+1 = Inf", F256.f256_is_inf(inf_plus_one), 1)
    Let inf_minus_inf be F256.f256_add(arena, pos_inf, neg_inf)
    T.assert_equal(results, "Inf+(-Inf) = NaN", F256.f256_is_nan(inf_minus_inf), 1)

    Return 1
End Process

Process called "test_multiplication" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f256.multiplication")
    Let two be F256.f256_from_integer(arena, 2)
    Let four be F256.f256_from_integer(arena, 4)
    Let one be F256.f256_from_integer(arena, 1)
    Let zero be F256.f256_from_integer(arena, 0)

    Let r1 be F256.f256_mul(arena, two, two)
    T.assert_equal(results, "2*2 = 4", F256.f256_eq(r1, four), 1)
    Let r2 be F256.f256_mul(arena, one, one)
    T.assert_equal(results, "1*1 = 1", F256.f256_eq(r2, one), 1)

    Let pos_inf be F256.f256_make_inf(arena, 0)
    Let inf_times_zero be F256.f256_mul(arena, pos_inf, zero)
    T.assert_equal(results, "Inf*0 = NaN", F256.f256_is_nan(inf_times_zero), 1)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    Let arena be Arena.arena_create(131072)
    If arena is equal to 0:
        Return 99
    End If

    test_classification(results, arena)
    test_unary(results, arena)
    test_comparison(results, arena)
    test_pack_unpack(results, arena)
    test_integer_conv(results, arena)
    test_float64_conv(results, arena)
    test_addition(results, arena)
    test_multiplication(results, arena)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Arena.arena_destroy(arena)
    Return exit_code
End Process
