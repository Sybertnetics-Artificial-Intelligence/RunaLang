Note:
==============================================================================
Conformance tests for ieee754_binary32.runa.

Coverage:
  - bit-pattern field accessors (sign, exponent, mantissa)
  - classification (zero, inf, nan, signaling-nan, subnormal, normal, finite)
  - special-value constructors (zero, inf, qnan)
  - unary ops (neg, abs)
  - arithmetic (add, sub, mul, div, sqrt, fma) on representative
    canonical IEEE 754 values
  - NaN propagation invariants
  - Inf arithmetic
  - sign-of-zero preservation
  - Float32<->Float64 round-trip
  - Integer<->Float32 round-trip for exactly-representable values
  - pack/unpack bytes (LE & BE)
  - comparison operators (eq/ne/lt/le/gt/ge) including NaN unordered

Canonical bit patterns used:
  0x00000000 = +0
  0x80000000 = -0
  0x3F800000 = +1.0
  0xBF800000 = -1.0
  0x40000000 = +2.0
  0x40400000 = +3.0
  0x40800000 = +4.0
  0x40A00000 = +5.0
  0x7F800000 = +Infinity
  0xFF800000 = -Infinity
  0x7FC00000 = canonical qNaN
  0x7F800001 = canonical sNaN (smallest)
  0x00000001 = smallest subnormal
  0x00800000 = smallest normal
  0x7F7FFFFF = largest finite
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/binary/ieee754_binary32.runa" as F32

Note: ============================================================================
Note: Bit-pattern field accessors
Note: ============================================================================

Process called "test_field_accessors" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.field_accessors")

    Let one be 1065353216
    Let neg_one be 3212836864
    Let pos_zero be 0
    Let neg_zero be 2147483648

    T.assert_equal(results, "sign(+1) = 0", F32.f32_get_sign(one), 0)
    T.assert_equal(results, "sign(-1) = 1", F32.f32_get_sign(neg_one), 1)
    T.assert_equal(results, "sign(+0) = 0", F32.f32_get_sign(pos_zero), 0)
    T.assert_equal(results, "sign(-0) = 1", F32.f32_get_sign(neg_zero), 1)

    T.assert_equal(results, "exponent(+1) = 127", F32.f32_get_exponent(one), 127)
    T.assert_equal(results, "exponent(+0) = 0", F32.f32_get_exponent(pos_zero), 0)
    T.assert_equal(results, "mantissa(+1) = 0", F32.f32_get_mantissa(one), 0)

    Let two be 1073741824
    T.assert_equal(results, "exponent(+2) = 128", F32.f32_get_exponent(two), 128)
    T.assert_equal(results, "mantissa(+2) = 0", F32.f32_get_mantissa(two), 0)

    Return 1
End Process

Note: ============================================================================
Note: Classification predicates
Note: ============================================================================

Process called "test_classification" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.classification")

    Let pos_zero be 0
    Let neg_zero be 2147483648
    Let one be 1065353216
    Let pos_inf be 2139095040
    Let neg_inf be 4286578688
    Let qnan be 2143289344
    Let snan be 2139095041
    Let smallest_subnormal be 1
    Let largest_finite be 2139095039

    T.assert_equal(results, "is_zero(+0) = 1", F32.f32_is_zero(pos_zero), 1)
    T.assert_equal(results, "is_zero(-0) = 1", F32.f32_is_zero(neg_zero), 1)
    T.assert_equal(results, "is_zero(+1) = 0", F32.f32_is_zero(one), 0)
    T.assert_equal(results, "is_zero(+Inf) = 0", F32.f32_is_zero(pos_inf), 0)

    T.assert_equal(results, "is_inf(+Inf) = 1", F32.f32_is_inf(pos_inf), 1)
    T.assert_equal(results, "is_inf(-Inf) = 1", F32.f32_is_inf(neg_inf), 1)
    T.assert_equal(results, "is_inf(qNaN) = 0", F32.f32_is_inf(qnan), 0)
    T.assert_equal(results, "is_inf(+1) = 0", F32.f32_is_inf(one), 0)

    T.assert_equal(results, "is_nan(qNaN) = 1", F32.f32_is_nan(qnan), 1)
    T.assert_equal(results, "is_nan(sNaN) = 1", F32.f32_is_nan(snan), 1)
    T.assert_equal(results, "is_nan(+Inf) = 0", F32.f32_is_nan(pos_inf), 0)
    T.assert_equal(results, "is_nan(+1) = 0", F32.f32_is_nan(one), 0)

    T.assert_equal(results, "is_signaling_nan(sNaN) = 1", F32.f32_is_signaling_nan(snan), 1)
    T.assert_equal(results, "is_signaling_nan(qNaN) = 0", F32.f32_is_signaling_nan(qnan), 0)

    T.assert_equal(results, "is_subnormal(smallest_subnormal) = 1", F32.f32_is_subnormal(smallest_subnormal), 1)
    T.assert_equal(results, "is_subnormal(+1) = 0", F32.f32_is_subnormal(one), 0)
    T.assert_equal(results, "is_subnormal(+0) = 0", F32.f32_is_subnormal(pos_zero), 0)

    T.assert_equal(results, "is_normal(+1) = 1", F32.f32_is_normal(one), 1)
    T.assert_equal(results, "is_normal(+0) = 0", F32.f32_is_normal(pos_zero), 0)
    T.assert_equal(results, "is_normal(+Inf) = 0", F32.f32_is_normal(pos_inf), 0)
    T.assert_equal(results, "is_normal(largest_finite) = 1", F32.f32_is_normal(largest_finite), 1)

    T.assert_equal(results, "is_finite(+1) = 1", F32.f32_is_finite(one), 1)
    T.assert_equal(results, "is_finite(+0) = 1", F32.f32_is_finite(pos_zero), 1)
    T.assert_equal(results, "is_finite(+Inf) = 0", F32.f32_is_finite(pos_inf), 0)
    T.assert_equal(results, "is_finite(qNaN) = 0", F32.f32_is_finite(qnan), 0)

    Return 1
End Process

Note: ============================================================================
Note: Unary operations
Note: ============================================================================

Process called "test_unary" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.unary")

    Let one be 1065353216
    Let neg_one be 3212836864
    Let pos_zero be 0
    Let neg_zero be 2147483648
    Let pos_inf be 2139095040
    Let neg_inf be 4286578688

    T.assert_equal(results, "neg(+1) = -1", F32.f32_neg(one), neg_one)
    T.assert_equal(results, "neg(-1) = +1", F32.f32_neg(neg_one), one)
    T.assert_equal(results, "neg(+0) = -0", F32.f32_neg(pos_zero), neg_zero)
    T.assert_equal(results, "neg(-0) = +0", F32.f32_neg(neg_zero), pos_zero)
    T.assert_equal(results, "neg(+Inf) = -Inf", F32.f32_neg(pos_inf), neg_inf)
    T.assert_equal(results, "neg(-Inf) = +Inf", F32.f32_neg(neg_inf), pos_inf)

    T.assert_equal(results, "abs(-1) = +1", F32.f32_abs(neg_one), one)
    T.assert_equal(results, "abs(+1) = +1", F32.f32_abs(one), one)
    T.assert_equal(results, "abs(-0) = +0", F32.f32_abs(neg_zero), pos_zero)
    T.assert_equal(results, "abs(-Inf) = +Inf", F32.f32_abs(neg_inf), pos_inf)

    Return 1
End Process

Note: ============================================================================
Note: Comparison (NaN-aware)
Note: ============================================================================

Process called "test_comparison" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.comparison")

    Let one be 1065353216
    Let neg_one be 3212836864
    Let two be 1073741824
    Let pos_zero be 0
    Let neg_zero be 2147483648
    Let pos_inf be 2139095040
    Let neg_inf be 4286578688
    Let qnan be 2143289344

    T.assert_equal(results, "+1 == +1", F32.f32_eq(one, one), 1)
    T.assert_equal(results, "+1 == +2", F32.f32_eq(one, two), 0)
    T.assert_equal(results, "+0 == -0", F32.f32_eq(pos_zero, neg_zero), 1)
    T.assert_equal(results, "NaN == NaN -> false", F32.f32_eq(qnan, qnan), 0)

    T.assert_equal(results, "NaN != NaN -> true", F32.f32_ne(qnan, qnan), 1)
    T.assert_equal(results, "+0 != -0 -> false", F32.f32_ne(pos_zero, neg_zero), 0)

    T.assert_equal(results, "+1 < +2", F32.f32_lt(one, two), 1)
    T.assert_equal(results, "+2 < +1 -> false", F32.f32_lt(two, one), 0)
    T.assert_equal(results, "NaN < +1 -> false", F32.f32_lt(qnan, one), 0)
    T.assert_equal(results, "+1 < NaN -> false", F32.f32_lt(one, qnan), 0)
    T.assert_equal(results, "-1 < +1", F32.f32_lt(neg_one, one), 1)
    T.assert_equal(results, "-Inf < +Inf", F32.f32_lt(neg_inf, pos_inf), 1)
    T.assert_equal(results, "+1 < +Inf", F32.f32_lt(one, pos_inf), 1)
    T.assert_equal(results, "-Inf < +1", F32.f32_lt(neg_inf, one), 1)

    T.assert_equal(results, "+1 <= +1", F32.f32_le(one, one), 1)
    T.assert_equal(results, "+1 <= +2", F32.f32_le(one, two), 1)
    T.assert_equal(results, "+2 <= +1 -> false", F32.f32_le(two, one), 0)

    T.assert_equal(results, "+2 > +1", F32.f32_gt(two, one), 1)
    T.assert_equal(results, "+1 > +2 -> false", F32.f32_gt(one, two), 0)
    T.assert_equal(results, "+1 > NaN -> false", F32.f32_gt(one, qnan), 0)

    T.assert_equal(results, "+1 >= +1", F32.f32_ge(one, one), 1)
    T.assert_equal(results, "+2 >= +1", F32.f32_ge(two, one), 1)
    T.assert_equal(results, "+1 >= +2 -> false", F32.f32_ge(one, two), 0)

    Return 1
End Process

Note: ============================================================================
Note: Addition
Note: ============================================================================

Process called "test_addition" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.addition")

    Let one be 1065353216
    Let neg_one be 3212836864
    Let two be 1073741824
    Let three be 1077936128
    Let pos_zero be 0
    Let neg_zero be 2147483648
    Let pos_inf be 2139095040
    Let neg_inf be 4286578688
    Let qnan be 2143289344

    T.assert_equal(results, "1+1 = 2", F32.f32_add(one, one), two)
    T.assert_equal(results, "1+2 = 3", F32.f32_add(one, two), three)
    T.assert_equal(results, "1+(-1) = 0", F32.f32_add(one, neg_one), pos_zero)
    T.assert_equal(results, "0+0 = 0", F32.f32_add(pos_zero, pos_zero), pos_zero)
    T.assert_equal(results, "(-0)+(-0) = -0", F32.f32_add(neg_zero, neg_zero), neg_zero)
    T.assert_equal(results, "0+(-0) = 0 (round-nearest)", F32.f32_add(pos_zero, neg_zero), pos_zero)

    T.assert_equal(results, "Inf+1 = Inf", F32.f32_add(pos_inf, one), pos_inf)
    T.assert_equal(results, "1+Inf = Inf", F32.f32_add(one, pos_inf), pos_inf)
    T.assert_equal(results, "Inf+Inf = Inf", F32.f32_add(pos_inf, pos_inf), pos_inf)

    Note: Inf + (-Inf) = NaN (invalid)
    Let inf_minus_inf be F32.f32_add(pos_inf, neg_inf)
    T.assert_equal(results, "Inf+(-Inf) is NaN", F32.f32_is_nan(inf_minus_inf), 1)

    Note: NaN+anything = NaN
    Let nan_plus_one be F32.f32_add(qnan, one)
    T.assert_equal(results, "NaN+1 is NaN", F32.f32_is_nan(nan_plus_one), 1)

    Return 1
End Process

Note: ============================================================================
Note: Subtraction
Note: ============================================================================

Process called "test_subtraction" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.subtraction")

    Let one be 1065353216
    Let two be 1073741824
    Let three be 1077936128
    Let pos_zero be 0

    T.assert_equal(results, "2-1 = 1", F32.f32_sub(two, one), one)
    T.assert_equal(results, "3-2 = 1", F32.f32_sub(three, two), one)
    T.assert_equal(results, "1-1 = 0", F32.f32_sub(one, one), pos_zero)

    Return 1
End Process

Note: ============================================================================
Note: Multiplication
Note: ============================================================================

Process called "test_multiplication" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.multiplication")

    Let one be 1065353216
    Let two be 1073741824
    Let four be 1082130432
    Let pos_zero be 0
    Let neg_zero be 2147483648
    Let pos_inf be 2139095040

    T.assert_equal(results, "1*1 = 1", F32.f32_mul(one, one), one)
    T.assert_equal(results, "2*2 = 4", F32.f32_mul(two, two), four)
    T.assert_equal(results, "1*0 = 0", F32.f32_mul(one, pos_zero), pos_zero)
    T.assert_equal(results, "1*(-0) = -0", F32.f32_mul(one, neg_zero), neg_zero)

    Note: Inf * 0 = NaN
    Let inf_times_zero be F32.f32_mul(pos_inf, pos_zero)
    T.assert_equal(results, "Inf*0 is NaN", F32.f32_is_nan(inf_times_zero), 1)

    T.assert_equal(results, "Inf*1 = Inf", F32.f32_mul(pos_inf, one), pos_inf)

    Return 1
End Process

Note: ============================================================================
Note: Division
Note: ============================================================================

Process called "test_division" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.division")

    Let one be 1065353216
    Let two be 1073741824
    Let four be 1082130432
    Let pos_zero be 0
    Let neg_zero be 2147483648
    Let pos_inf be 2139095040
    Let neg_inf be 4286578688

    T.assert_equal(results, "1/1 = 1", F32.f32_div(one, one), one)
    T.assert_equal(results, "4/2 = 2", F32.f32_div(four, two), two)
    T.assert_equal(results, "1/0 = +Inf (divide-by-zero)", F32.f32_div(one, pos_zero), pos_inf)
    T.assert_equal(results, "1/(-0) = -Inf", F32.f32_div(one, neg_zero), neg_inf)

    Note: 0/0 = NaN, Inf/Inf = NaN
    Let zero_div_zero be F32.f32_div(pos_zero, pos_zero)
    T.assert_equal(results, "0/0 is NaN", F32.f32_is_nan(zero_div_zero), 1)
    Let inf_div_inf be F32.f32_div(pos_inf, pos_inf)
    T.assert_equal(results, "Inf/Inf is NaN", F32.f32_is_nan(inf_div_inf), 1)

    T.assert_equal(results, "0/1 = 0", F32.f32_div(pos_zero, one), pos_zero)
    T.assert_equal(results, "1/Inf = 0", F32.f32_div(one, pos_inf), pos_zero)

    Return 1
End Process

Note: ============================================================================
Note: Square root
Note: ============================================================================

Process called "test_sqrt" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.sqrt")

    Let zero be 0
    Let neg_zero be 2147483648
    Let pos_inf be 2139095040
    Let one be 1065353216
    Let four be 1082130432
    Let two be 1073741824
    Let nine be 1091567616
    Let three be 1077936128

    T.assert_equal(results, "sqrt(0) = 0", F32.f32_sqrt(zero), zero)
    T.assert_equal(results, "sqrt(-0) = -0", F32.f32_sqrt(neg_zero), neg_zero)
    T.assert_equal(results, "sqrt(+Inf) = +Inf", F32.f32_sqrt(pos_inf), pos_inf)
    T.assert_equal(results, "sqrt(1) = 1", F32.f32_sqrt(one), one)
    T.assert_equal(results, "sqrt(4) = 2", F32.f32_sqrt(four), two)
    T.assert_equal(results, "sqrt(9) = 3", F32.f32_sqrt(nine), three)

    Note: sqrt(-1) is NaN (invalid)
    Let neg_one be 3212836864
    Let sqrt_neg_one be F32.f32_sqrt(neg_one)
    T.assert_equal(results, "sqrt(-1) is NaN", F32.f32_is_nan(sqrt_neg_one), 1)

    Return 1
End Process

Note: ============================================================================
Note: Integer conversions
Note: ============================================================================

Process called "test_integer_conv" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.integer_conv")

    Let zero_f32 be 0
    Let one_f32 be 1065353216
    Let two_f32 be 1073741824
    Let neg_one_f32 be 3212836864
    Let three_f32 be 1077936128
    Let ten_f32 be 1092616192

    T.assert_equal(results, "from_integer(0)", F32.f32_from_integer(0), zero_f32)
    T.assert_equal(results, "from_integer(1)", F32.f32_from_integer(1), one_f32)
    T.assert_equal(results, "from_integer(2)", F32.f32_from_integer(2), two_f32)
    T.assert_equal(results, "from_integer(-1)", F32.f32_from_integer(0 minus 1), neg_one_f32)
    T.assert_equal(results, "from_integer(3)", F32.f32_from_integer(3), three_f32)
    T.assert_equal(results, "from_integer(10)", F32.f32_from_integer(10), ten_f32)

    T.assert_equal(results, "to_integer(1.0) = 1", F32.f32_to_integer(one_f32), 1)
    T.assert_equal(results, "to_integer(2.0) = 2", F32.f32_to_integer(two_f32), 2)
    T.assert_equal(results, "to_integer(0.0) = 0", F32.f32_to_integer(zero_f32), 0)
    T.assert_equal(results, "to_integer(-1.0) = -1", F32.f32_to_integer(neg_one_f32), 0 minus 1)

    Return 1
End Process

Note: ============================================================================
Note: Float64 conversions
Note: ============================================================================

Process called "test_float64_conv" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.float64_conv")

    Note: 1.0 in binary64 = 0x3FF0000000000000 = 4607182418800017408
    Let one_f64 be 4607182418800017408
    Let one_f32 be 1065353216

    T.assert_equal(results, "from_float64(1.0)", F32.f32_from_float64(one_f64), one_f32)
    T.assert_equal(results, "to_float64(1.0)", F32.f32_to_float64(one_f32), one_f64)

    Note: 2.0 in binary64
    Let two_f64 be 4611686018427387904
    Let two_f32 be 1073741824
    T.assert_equal(results, "from_float64(2.0)", F32.f32_from_float64(two_f64), two_f32)
    T.assert_equal(results, "to_float64(2.0)", F32.f32_to_float64(two_f32), two_f64)

    Return 1
End Process

Note: ============================================================================
Note: Pack / unpack bytes
Note: ============================================================================

Process called "test_pack_unpack" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.pack_unpack")

    Let one be 1065353216
    Let buffer be allocate(8)
    F32.f32_pack_bytes_le(one, buffer)

    Note: 1.0 = 0x3F800000; LE bytes = 00 00 80 3F
    Let b0 be __load_byte(buffer, 0)
    Let b1 be __load_byte(buffer, 1)
    Let b2 be __load_byte(buffer, 2)
    Let b3 be __load_byte(buffer, 3)
    T.assert_equal(results, "pack_le 1.0 b0 = 0x00", b0, 0)
    T.assert_equal(results, "pack_le 1.0 b1 = 0x00", b1, 0)
    T.assert_equal(results, "pack_le 1.0 b2 = 0x80", b2, 128)
    T.assert_equal(results, "pack_le 1.0 b3 = 0x3F", b3, 63)

    Let round_trip be F32.f32_unpack_bytes_le(buffer)
    T.assert_equal(results, "unpack_le round-trip 1.0", round_trip, one)

    F32.f32_pack_bytes_be(one, buffer)
    Note: BE bytes = 3F 80 00 00
    Let bb0 be __load_byte(buffer, 0)
    Let bb1 be __load_byte(buffer, 1)
    Let bb2 be __load_byte(buffer, 2)
    Let bb3 be __load_byte(buffer, 3)
    T.assert_equal(results, "pack_be 1.0 b0 = 0x3F", bb0, 63)
    T.assert_equal(results, "pack_be 1.0 b1 = 0x80", bb1, 128)
    T.assert_equal(results, "pack_be 1.0 b2 = 0x00", bb2, 0)
    T.assert_equal(results, "pack_be 1.0 b3 = 0x00", bb3, 0)

    Let round_trip_be be F32.f32_unpack_bytes_be(buffer)
    T.assert_equal(results, "unpack_be round-trip 1.0", round_trip_be, one)

    Return 1
End Process

Note: ============================================================================
Note: Rounding mode + flags
Note: ============================================================================

Process called "test_rounding_flags" that takes results as Integer returns Integer:
    T.begin_suite(results, "f32.rounding_flags")

    F32.f32_set_rounding_mode(0)
    T.assert_equal(results, "rounding mode 0 set", F32.f32_get_rounding_mode(), 0)
    F32.f32_set_rounding_mode(1)
    T.assert_equal(results, "rounding mode 1 set", F32.f32_get_rounding_mode(), 1)
    F32.f32_set_rounding_mode(2)
    T.assert_equal(results, "rounding mode 2 set", F32.f32_get_rounding_mode(), 2)
    F32.f32_set_rounding_mode(3)
    T.assert_equal(results, "rounding mode 3 set", F32.f32_get_rounding_mode(), 3)
    F32.f32_set_rounding_mode(0)

    F32.f32_clear_flags()
    T.assert_equal(results, "flags cleared", F32.f32_get_flags(), 0)

    Return 1
End Process

Note: ============================================================================
Note: Main entry
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_field_accessors(results)
    test_classification(results)
    test_unary(results)
    test_comparison(results)
    test_addition(results)
    test_subtraction(results)
    test_multiplication(results)
    test_division(results)
    test_sqrt(results)
    test_integer_conv(results)
    test_float64_conv(results)
    test_pack_unpack(results)
    test_rounding_flags(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
