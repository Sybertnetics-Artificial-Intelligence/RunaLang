Note:
==============================================================================
Conformance tests for arbitrary_precision_float.runa.

We test ArbitraryFloat at precisions 64, 128, 256, 512, 1024, 2048 using
identity invariants:
  - apf_from_integer(n) is finite, sign-correct, exact
  - 1 + 1 == 2 across all precisions
  - 2 * 2 == 4
  - sqrt(4) == 2
  - a + (-a) == 0
  - (a + b) - b == a (for representable values)
  - pow_int(2, 10) == 1024
  - apf_to_float64 round-trips for binary64-representable values
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/binary/arbitrary_precision_float.runa" as APF
Import "runtime/core/memory/arena.runa" as Arena

Note: ============================================================================
Note: Construction and classification
Note: ============================================================================

Process called "test_construction" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "apf.construction")

    Let zero be APF.apf_from_integer(arena, 0, 128)
    T.assert_equal(results, "apf_from_integer(0) is zero", APF.apf_is_zero(zero), 1)
    T.assert_equal(results, "apf_from_integer(0) precision = 128", APF.apf_get_precision(zero), 128)

    Let one be APF.apf_from_integer(arena, 1, 128)
    T.assert_equal(results, "apf_from_integer(1) finite", APF.apf_is_finite(one), 1)
    T.assert_equal(results, "apf_from_integer(1) not negative", APF.apf_is_negative(one), 0)

    Let neg_one be APF.apf_from_integer(arena, 0 minus 1, 128)
    T.assert_equal(results, "apf_from_integer(-1) is negative", APF.apf_is_negative(neg_one), 1)

    Let prec256 be APF.apf_alloc(arena, 256)
    T.assert_equal(results, "apf_alloc(256) precision = 256", APF.apf_get_precision(prec256), 256)
    T.assert_equal(results, "apf_alloc(256) limb_count = 4", APF.apf_get_limb_count(prec256), 4)

    Let prec_too_low be APF.apf_alloc(arena, 8)
    T.assert_equal(results, "precision floor enforced (min 32)", APF.apf_get_precision(prec_too_low), 32)

    Return 1
End Process

Note: ============================================================================
Note: Comparison
Note: ============================================================================

Process called "test_comparison" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "apf.comparison")

    Let one be APF.apf_from_integer(arena, 1, 128)
    Let two be APF.apf_from_integer(arena, 2, 128)
    Let neg_one be APF.apf_from_integer(arena, 0 minus 1, 128)

    T.assert_equal(results, "1 == 1", APF.apf_eq(one, one), 1)
    T.assert_equal(results, "1 < 2", APF.apf_lt(one, two), 1)
    T.assert_equal(results, "2 > 1", APF.apf_gt(two, one), 1)
    T.assert_equal(results, "-1 < 1", APF.apf_lt(neg_one, one), 1)
    T.assert_equal(results, "1 <= 1", APF.apf_le(one, one), 1)
    T.assert_equal(results, "1 >= 1", APF.apf_ge(one, one), 1)
    T.assert_equal(results, "1 != 2", APF.apf_ne(one, two), 1)

    Return 1
End Process

Note: ============================================================================
Note: Unary
Note: ============================================================================

Process called "test_unary" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "apf.unary")

    Let one be APF.apf_from_integer(arena, 1, 128)
    Let neg_one be APF.apf_neg(arena, one)
    T.assert_equal(results, "neg(+1) is negative", APF.apf_is_negative(neg_one), 1)
    Let abs_neg_one be APF.apf_abs(arena, neg_one)
    T.assert_equal(results, "abs(-1) is positive", APF.apf_is_negative(abs_neg_one), 0)
    T.assert_equal(results, "abs(-1) == +1", APF.apf_eq(abs_neg_one, one), 1)

    Return 1
End Process

Note: ============================================================================
Note: Float64 round-trip
Note: ============================================================================

Process called "test_float64_conv" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "apf.float64_conv")

    Let one_f64 be 4607182418800017408
    Let two_f64 be 4611686018427387904

    Let one_apf be APF.apf_from_float64(arena, one_f64, 128)
    T.assert_equal(results, "from_float64(1.0) round-trips", APF.apf_to_float64(one_apf), one_f64)

    Let two_apf be APF.apf_from_float64(arena, two_f64, 128)
    T.assert_equal(results, "from_float64(2.0) round-trips", APF.apf_to_float64(two_apf), two_f64)

    Note: Inf and NaN
    Let inf_f64 be 9218868437227405312
    Let inf_apf be APF.apf_from_float64(arena, inf_f64, 64)
    T.assert_equal(results, "from_float64(+Inf) is inf", APF.apf_is_inf(inf_apf), 1)
    T.assert_equal(results, "to_float64(inf_apf) round-trips", APF.apf_to_float64(inf_apf), inf_f64)

    Note: +0 and -0
    Let pos_zero_f64 be 0
    Let neg_zero_f64 be -9223372036854775808
    Let pz_apf be APF.apf_from_float64(arena, pos_zero_f64, 64)
    T.assert_equal(results, "from_float64(+0)", APF.apf_to_float64(pz_apf), pos_zero_f64)
    Let nz_apf be APF.apf_from_float64(arena, neg_zero_f64, 64)
    T.assert_equal(results, "from_float64(-0)", APF.apf_to_float64(nz_apf), neg_zero_f64)

    Return 1
End Process

Note: ============================================================================
Note: Integer arithmetic identities at multiple precisions
Note: ============================================================================

Process called "verify_arithmetic_at_precision" that takes results as Integer, arena as Integer, precision as Integer, label_prefix as String returns Integer:
    T.begin_suite(results, label_prefix)

    Let one be APF.apf_from_integer(arena, 1, precision)
    Let two be APF.apf_from_integer(arena, 2, precision)
    Let three be APF.apf_from_integer(arena, 3, precision)
    Let four be APF.apf_from_integer(arena, 4, precision)
    Let zero be APF.apf_from_integer(arena, 0, precision)

    Let sum_1_1 be APF.apf_add(arena, one, one)
    T.assert_equal(results, "1+1 = 2", APF.apf_eq(sum_1_1, two), 1)

    Let sum_1_2 be APF.apf_add(arena, one, two)
    T.assert_equal(results, "1+2 = 3", APF.apf_eq(sum_1_2, three), 1)

    Let neg_one be APF.apf_neg(arena, one)
    Let cancel be APF.apf_add(arena, one, neg_one)
    T.assert_equal(results, "1+(-1) = 0", APF.apf_is_zero(cancel), 1)

    Let prod_2_2 be APF.apf_mul(arena, two, two)
    T.assert_equal(results, "2*2 = 4", APF.apf_eq(prod_2_2, four), 1)

    Note: Self-consistency: (a + b) - b = a for representable values
    Let a be APF.apf_from_integer(arena, 5, precision)
    Let b be APF.apf_from_integer(arena, 3, precision)
    Let a_plus_b be APF.apf_add(arena, a, b)
    Let recovered be APF.apf_sub(arena, a_plus_b, b)
    T.assert_equal(results, "(5+3)-3 = 5", APF.apf_eq(recovered, a), 1)

    Note: 2^10 = 1024 via pow_int
    Let pow_2_10 be APF.apf_pow_int(arena, two, 10)
    Let expected_1024 be APF.apf_from_integer(arena, 1024, precision)
    T.assert_equal(results, "2^10 = 1024", APF.apf_eq(pow_2_10, expected_1024), 1)

    Return 1
End Process

Process called "test_arithmetic_64" that takes results as Integer, arena as Integer returns Integer:
    Return verify_arithmetic_at_precision(results, arena, 64, "apf.arithmetic_p64")
End Process

Process called "test_arithmetic_128" that takes results as Integer, arena as Integer returns Integer:
    Return verify_arithmetic_at_precision(results, arena, 128, "apf.arithmetic_p128")
End Process

Process called "test_arithmetic_256" that takes results as Integer, arena as Integer returns Integer:
    Return verify_arithmetic_at_precision(results, arena, 256, "apf.arithmetic_p256")
End Process

Process called "test_arithmetic_512" that takes results as Integer, arena as Integer returns Integer:
    Return verify_arithmetic_at_precision(results, arena, 512, "apf.arithmetic_p512")
End Process

Process called "test_arithmetic_1024" that takes results as Integer, arena as Integer returns Integer:
    Return verify_arithmetic_at_precision(results, arena, 1024, "apf.arithmetic_p1024")
End Process

Process called "test_arithmetic_2048" that takes results as Integer, arena as Integer returns Integer:
    Return verify_arithmetic_at_precision(results, arena, 2048, "apf.arithmetic_p2048")
End Process

Note: ============================================================================
Note: Square root
Note: ============================================================================

Process called "test_sqrt" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "apf.sqrt")

    Let four be APF.apf_from_integer(arena, 4, 128)
    Let two be APF.apf_from_integer(arena, 2, 128)
    Let sqrt4 be APF.apf_sqrt(arena, four)
    T.assert_equal(results, "sqrt(4) is finite", APF.apf_is_finite(sqrt4), 1)
    Note: We don't require bit-exact equality because of Newton iteration
    Note: precision; we check via f64 demotion within tolerance.
    Let sqrt4_f64 be APF.apf_to_float64(sqrt4)
    Let two_f64 be 4611686018427387904
    Note: sqrt(4) should equal 2.0 exactly (Newton converges to integer here)
    T.assert_equal(results, "sqrt(4) f64 == 2.0", sqrt4_f64, two_f64)

    Let nine be APF.apf_from_integer(arena, 9, 128)
    Let sqrt9 be APF.apf_sqrt(arena, nine)
    Let three_f64 be 4613937818241073152
    T.assert_equal(results, "sqrt(9) f64 == 3.0", APF.apf_to_float64(sqrt9), three_f64)

    Note: sqrt(0) = 0
    Let zero be APF.apf_from_integer(arena, 0, 128)
    Let sqrt0 be APF.apf_sqrt(arena, zero)
    T.assert_equal(results, "sqrt(0) is zero", APF.apf_is_zero(sqrt0), 1)

    Note: sqrt(-1) = NaN (invalid)
    Let neg_one be APF.apf_from_integer(arena, 0 minus 1, 128)
    Let sqrt_neg be APF.apf_sqrt(arena, neg_one)
    T.assert_equal(results, "sqrt(-1) is NaN", APF.apf_is_nan(sqrt_neg), 1)

    Return 1
End Process

Note: ============================================================================
Note: Specials propagation
Note: ============================================================================

Process called "test_specials" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "apf.specials")

    Let one be APF.apf_from_integer(arena, 1, 128)
    Let zero be APF.apf_from_integer(arena, 0, 128)

    Note: division by zero -> Inf
    Let inf_result be APF.apf_div(arena, one, zero)
    T.assert_equal(results, "1/0 is Inf", APF.apf_is_inf(inf_result), 1)

    Note: 0/0 -> NaN
    Let nan_result be APF.apf_div(arena, zero, zero)
    T.assert_equal(results, "0/0 is NaN", APF.apf_is_nan(nan_result), 1)

    Note: NaN propagation through arithmetic
    Let nan_plus_one be APF.apf_add(arena, nan_result, one)
    T.assert_equal(results, "NaN + 1 is NaN", APF.apf_is_nan(nan_plus_one), 1)

    Return 1
End Process

Note: ============================================================================
Note: Rounding mode + flags
Note: ============================================================================

Process called "test_rounding_flags" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "apf.rounding_flags")

    APF.apf_set_rounding_mode(0)
    T.assert_equal(results, "mode 0 set", APF.apf_get_rounding_mode(), 0)
    APF.apf_set_rounding_mode(1)
    T.assert_equal(results, "mode 1 set", APF.apf_get_rounding_mode(), 1)
    APF.apf_set_rounding_mode(0)

    APF.apf_clear_flags()
    T.assert_equal(results, "flags cleared", APF.apf_get_flags(), 0)

    Return 1
End Process

Note: ============================================================================
Note: Main entry
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()
    Let arena be Arena.arena_create(2097152)
    If arena is equal to 0:
        Return 99
    End If

    test_construction(results, arena)
    test_comparison(results, arena)
    test_unary(results, arena)
    test_float64_conv(results, arena)

    test_arithmetic_64(results, arena)
    test_arithmetic_128(results, arena)
    test_arithmetic_256(results, arena)
    test_arithmetic_512(results, arena)
    test_arithmetic_1024(results, arena)
    test_arithmetic_2048(results, arena)

    test_sqrt(results, arena)
    test_specials(results, arena)
    test_rounding_flags(results, arena)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Arena.arena_destroy(arena)
    Return exit_code
End Process
