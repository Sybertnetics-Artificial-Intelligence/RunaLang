Note:
==============================================================================
Conformance tests for ieee754_binary128.runa.

Coverage:
  - Construction of canonical specials: +0, -0, +Inf, -Inf, qNaN
  - Classification: is_zero, is_inf, is_nan, is_finite, is_normal,
    is_subnormal, is_signaling_nan
  - Unary: neg, abs
  - Comparison: eq, ne, lt, le, gt, ge with NaN unordered
  - Field accessors (sign, exponent, mantissa high/low)
  - Pack/unpack 16-byte buffers (LE and BE)
  - Float64 <-> Float128 round-trip exactness
  - Integer -> Float128 conversion
  - Addition: 1+1=2, 1+(-1)=0, Inf+Inf=Inf, Inf-Inf=NaN, NaN propagation
  - Subtraction
  - Multiplication: 2*2=4, 0*Inf=NaN
  - Self-consistency: (a+b)-b ~ a for canonical values

Canonical Float128 test vectors used (high 64 bits | low 64 bits):
  +0.0:    0x0000000000000000 | 0x0000000000000000
  -0.0:    0x8000000000000000 | 0x0000000000000000
  +1.0:    0x3FFF000000000000 | 0x0000000000000000
  -1.0:    0xBFFF000000000000 | 0x0000000000000000
  +2.0:    0x4000000000000000 | 0x0000000000000000
  +Inf:    0x7FFF000000000000 | 0x0000000000000000
  -Inf:    0xFFFF000000000000 | 0x0000000000000000
  qNaN:    0x7FFF800000000000 | 0x0000000000000000
  smallest subnormal:  0x0000000000000000 | 0x0000000000000001
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/numeric/binary/ieee754_binary128.runa" as F128
Import "runtime/core/memory/arena.runa" as Arena

Note: ============================================================================
Note: Helper: construct a Float128 directly from 64-bit halves
Note: ============================================================================

Process called "build_f128" that takes arena as Integer, hi as Integer, lo as Integer returns Integer:
    Let p be F128.f128_alloc(arena)
    If p is equal to 0:
        Return 0
    End If
    F128.f128_store_high(p, hi)
    F128.f128_store_low(p, lo)
    Return p
End Process

Process called "f128_equals_bits" that takes p as Integer, hi as Integer, lo as Integer returns Integer:
    Let p_hi be F128.f128_load_high(p)
    Let p_lo be F128.f128_load_low(p)
    If p_hi is not equal to hi:
        Return 0
    End If
    If p_lo is not equal to lo:
        Return 0
    End If
    Return 1
End Process

Note: ============================================================================
Note: Classification + specials
Note: ============================================================================

Process called "test_classification" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f128.classification")

    Let pos_zero be build_f128(arena, 0, 0)
    Let neg_zero be build_f128(arena, -9223372036854775808, 0)
    Let one_hi be 4611404543450677248
    Let one be build_f128(arena, one_hi, 0)
    Let inf_hi be 9223090561878065152
    Let pos_inf be build_f128(arena, inf_hi, 0)
    Let neg_inf_hi be 9223090561878065152 bitwise or -9223372036854775808
    Let neg_inf be build_f128(arena, neg_inf_hi, 0)
    Let qnan_hi be 9223231299730112512
    Let qnan be build_f128(arena, qnan_hi, 0)

    T.assert_equal(results, "is_zero(+0) = 1", F128.f128_is_zero(pos_zero), 1)
    T.assert_equal(results, "is_zero(-0) = 1", F128.f128_is_zero(neg_zero), 1)
    T.assert_equal(results, "is_zero(+1) = 0", F128.f128_is_zero(one), 0)
    T.assert_equal(results, "is_zero(+Inf) = 0", F128.f128_is_zero(pos_inf), 0)
    T.assert_equal(results, "is_inf(+Inf) = 1", F128.f128_is_inf(pos_inf), 1)
    T.assert_equal(results, "is_inf(-Inf) = 1", F128.f128_is_inf(neg_inf), 1)
    T.assert_equal(results, "is_inf(qNaN) = 0", F128.f128_is_inf(qnan), 0)
    T.assert_equal(results, "is_nan(qNaN) = 1", F128.f128_is_nan(qnan), 1)
    T.assert_equal(results, "is_nan(+Inf) = 0", F128.f128_is_nan(pos_inf), 0)
    T.assert_equal(results, "is_finite(+1) = 1", F128.f128_is_finite(one), 1)
    T.assert_equal(results, "is_finite(+Inf) = 0", F128.f128_is_finite(pos_inf), 0)
    T.assert_equal(results, "is_finite(qNaN) = 0", F128.f128_is_finite(qnan), 0)
    T.assert_equal(results, "is_normal(+1) = 1", F128.f128_is_normal(one), 1)
    T.assert_equal(results, "is_normal(+0) = 0", F128.f128_is_normal(pos_zero), 0)
    T.assert_equal(results, "is_subnormal(smallest subnormal)", F128.f128_is_subnormal(build_f128(arena, 0, 1)), 1)
    T.assert_equal(results, "is_subnormal(+1) = 0", F128.f128_is_subnormal(one), 0)

    Return 1
End Process

Note: ============================================================================
Note: Field accessors
Note: ============================================================================

Process called "test_field_accessors" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f128.field_accessors")

    Let one_hi be 4611404543450677248
    Let one be build_f128(arena, one_hi, 0)
    T.assert_equal(results, "sign(+1) = 0", F128.f128_get_sign(one), 0)
    T.assert_equal(results, "exponent(+1) = 16383", F128.f128_get_exponent(one), 16383)
    T.assert_equal(results, "mantissa_high(+1) = 0", F128.f128_get_mantissa_high(one), 0)
    T.assert_equal(results, "mantissa_low(+1) = 0", F128.f128_get_mantissa_low(one), 0)

    Let neg_one_hi be one_hi bitwise or -9223372036854775808
    Let neg_one be build_f128(arena, neg_one_hi, 0)
    T.assert_equal(results, "sign(-1) = 1", F128.f128_get_sign(neg_one), 1)

    Return 1
End Process

Note: ============================================================================
Note: Unary
Note: ============================================================================

Process called "test_unary" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f128.unary")

    Let one_hi be 4611404543450677248
    Let neg_one_hi be one_hi bitwise or -9223372036854775808
    Let one be build_f128(arena, one_hi, 0)

    Let negated be F128.f128_neg(arena, one)
    T.assert_equal(results, "neg(+1) bit pattern", f128_equals_bits(negated, neg_one_hi, 0), 1)

    Let abs_neg be F128.f128_abs(arena, build_f128(arena, neg_one_hi, 0))
    T.assert_equal(results, "abs(-1) bit pattern", f128_equals_bits(abs_neg, one_hi, 0), 1)

    Return 1
End Process

Note: ============================================================================
Note: Comparison
Note: ============================================================================

Process called "test_comparison" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f128.comparison")

    Let one_hi be 4611404543450677248
    Let two_hi be 4611545280939032576
    Let neg_one_hi be one_hi bitwise or -9223372036854775808
    Let qnan_hi be 9223231299730112512
    Let one be build_f128(arena, one_hi, 0)
    Let two be build_f128(arena, two_hi, 0)
    Let neg_one be build_f128(arena, neg_one_hi, 0)
    Let qnan be build_f128(arena, qnan_hi, 0)
    Let pos_zero be build_f128(arena, 0, 0)
    Let neg_zero be build_f128(arena, -9223372036854775808, 0)

    T.assert_equal(results, "+1 == +1", F128.f128_eq(one, one), 1)
    T.assert_equal(results, "+1 == +2 -> false", F128.f128_eq(one, two), 0)
    T.assert_equal(results, "+0 == -0", F128.f128_eq(pos_zero, neg_zero), 1)
    T.assert_equal(results, "NaN == NaN -> false", F128.f128_eq(qnan, qnan), 0)
    T.assert_equal(results, "NaN != NaN -> true", F128.f128_ne(qnan, qnan), 1)
    T.assert_equal(results, "+1 < +2", F128.f128_lt(one, two), 1)
    T.assert_equal(results, "+2 < +1 -> false", F128.f128_lt(two, one), 0)
    T.assert_equal(results, "-1 < +1", F128.f128_lt(neg_one, one), 1)
    T.assert_equal(results, "+1 <= +1", F128.f128_le(one, one), 1)
    T.assert_equal(results, "+2 > +1", F128.f128_gt(two, one), 1)
    T.assert_equal(results, "+1 >= +1", F128.f128_ge(one, one), 1)
    T.assert_equal(results, "NaN < +1 -> false", F128.f128_lt(qnan, one), 0)
    T.assert_equal(results, "+1 < NaN -> false", F128.f128_lt(one, qnan), 0)

    Return 1
End Process

Note: ============================================================================
Note: Pack / unpack bytes
Note: ============================================================================

Process called "test_pack_unpack" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f128.pack_unpack")

    Let one_hi be 4611404543450677248
    Let one be build_f128(arena, one_hi, 0)
    Let buffer be allocate(16)
    F128.f128_pack_bytes_le(one, buffer)
    Let round_trip be F128.f128_unpack_bytes_le(arena, buffer)
    T.assert_equal(results, "LE pack/unpack round-trip +1", f128_equals_bits(round_trip, one_hi, 0), 1)

    F128.f128_pack_bytes_be(one, buffer)
    Let round_trip_be be F128.f128_unpack_bytes_be(arena, buffer)
    T.assert_equal(results, "BE pack/unpack round-trip +1", f128_equals_bits(round_trip_be, one_hi, 0), 1)

    Return 1
End Process

Note: ============================================================================
Note: Float64 <-> Float128 round-trip
Note: ============================================================================

Process called "test_float64_conv" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f128.float64_conv")

    Let one_f64 be 4607182418800017408
    Let promoted be F128.f128_from_float64(arena, one_f64)
    Note: 1.0 in f128 has high = 0x3FFF000000000000 = 4611404543450677248
    T.assert_equal(results, "from_float64(1.0) high", F128.f128_load_high(promoted), 4611404543450677248)
    T.assert_equal(results, "from_float64(1.0) low", F128.f128_load_low(promoted), 0)

    Let demoted be F128.f128_to_float64(promoted)
    T.assert_equal(results, "to_float64(1.0)", demoted, one_f64)

    Let two_f64 be 4611686018427387904
    Let two_promoted be F128.f128_from_float64(arena, two_f64)
    T.assert_equal(results, "from_float64(2.0) -> to_float64 round-trip", F128.f128_to_float64(two_promoted), two_f64)

    Return 1
End Process

Note: ============================================================================
Note: Integer conversion
Note: ============================================================================

Process called "test_integer_conv" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f128.integer_conv")

    Let zero_f128 be F128.f128_from_integer(arena, 0)
    T.assert_equal(results, "from_integer(0) is zero", F128.f128_is_zero(zero_f128), 1)

    Let one_f128 be F128.f128_from_integer(arena, 1)
    Let one_hi be 4611404543450677248
    T.assert_equal(results, "from_integer(1) high", F128.f128_load_high(one_f128), one_hi)

    T.assert_equal(results, "to_integer(from_integer(42))", F128.f128_to_integer(F128.f128_from_integer(arena, 42)), 42)
    T.assert_equal(results, "to_integer(from_integer(-1))", F128.f128_to_integer(F128.f128_from_integer(arena, 0 minus 1)), 0 minus 1)

    Return 1
End Process

Note: ============================================================================
Note: Addition
Note: ============================================================================

Process called "test_addition" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f128.addition")

    Let one be F128.f128_from_integer(arena, 1)
    Let two be F128.f128_from_integer(arena, 2)
    Let result_1_plus_1 be F128.f128_add(arena, one, one)
    T.assert_equal(results, "1+1 = 2 via f128_eq", F128.f128_eq(result_1_plus_1, two), 1)

    Let neg_one be F128.f128_neg(arena, one)
    Let cancel be F128.f128_add(arena, one, neg_one)
    T.assert_equal(results, "1+(-1) = 0", F128.f128_is_zero(cancel), 1)

    Let inf_hi be 9223090561878065152
    Let pos_inf be build_f128(arena, inf_hi, 0)
    Let neg_inf_hi be inf_hi bitwise or -9223372036854775808
    Let neg_inf be build_f128(arena, neg_inf_hi, 0)
    Let inf_minus_inf be F128.f128_add(arena, pos_inf, neg_inf)
    T.assert_equal(results, "Inf + (-Inf) = NaN", F128.f128_is_nan(inf_minus_inf), 1)

    Let inf_plus_one be F128.f128_add(arena, pos_inf, one)
    T.assert_equal(results, "Inf + 1 is Inf", F128.f128_is_inf(inf_plus_one), 1)

    Note: NaN propagation
    Let qnan_hi be 9223231299730112512
    Let qnan be build_f128(arena, qnan_hi, 0)
    Let nan_plus_one be F128.f128_add(arena, qnan, one)
    T.assert_equal(results, "NaN + 1 is NaN", F128.f128_is_nan(nan_plus_one), 1)

    Return 1
End Process

Note: ============================================================================
Note: Multiplication
Note: ============================================================================

Process called "test_multiplication" that takes results as Integer, arena as Integer returns Integer:
    T.begin_suite(results, "f128.multiplication")

    Let one be F128.f128_from_integer(arena, 1)
    Let two be F128.f128_from_integer(arena, 2)
    Let four be F128.f128_from_integer(arena, 4)
    Let mul_2_2 be F128.f128_mul(arena, two, two)
    T.assert_equal(results, "2*2 = 4", F128.f128_eq(mul_2_2, four), 1)

    Let mul_1_1 be F128.f128_mul(arena, one, one)
    T.assert_equal(results, "1*1 = 1", F128.f128_eq(mul_1_1, one), 1)

    Let zero be F128.f128_from_integer(arena, 0)
    Let inf_hi be 9223090561878065152
    Let pos_inf be build_f128(arena, inf_hi, 0)
    Let inf_times_zero be F128.f128_mul(arena, pos_inf, zero)
    T.assert_equal(results, "Inf * 0 = NaN", F128.f128_is_nan(inf_times_zero), 1)

    Return 1
End Process

Note: ============================================================================
Note: Main entry
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()
    Let arena be Arena.arena_create(65536)
    If arena is equal to 0:
        Return 99
    End If

    test_classification(results, arena)
    test_field_accessors(results, arena)
    test_unary(results, arena)
    test_comparison(results, arena)
    test_pack_unpack(results, arena)
    test_float64_conv(results, arena)
    test_integer_conv(results, arena)
    test_addition(results, arena)
    test_multiplication(results, arena)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Arena.arena_destroy(arena)
    Return exit_code
End Process
