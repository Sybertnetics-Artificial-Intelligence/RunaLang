Note:
Complex128 KAT suite.

Coverage:
  10  allocate / set / real / imag round-trip
  11  i * i = -1 (i^2 = -1, the defining property of complex numbers)
  12  (1+2i) + (3+4i) = 4+6i
  13  (3+4i) - (1+2i) = 2+2i
  14  (1+2i) * (3+4i) = -5+10i
  15  (3+4i) / (1+2i) = 11/5 - 2/5 i = 2.2 - 0.4i
  16  magnitude of 3+4i = 5
  17  argument of 0+1i = pi/2
  18  conjugate (1+2i) = 1-2i
  19  reciprocal of 1+1i = 0.5 - 0.5i
  20  polar -> rectangular -> polar round-trip
  21  Euler's identity: exp(i*pi) ~= -1
  22  sqrt(-1) = i
  23  Complex64 basic mul: i * i = -1 (lower precision tolerance)
:End Note

Import "compiler/frontend/primitives/numeric/extended/complex.runa" as Complex

Process called "abs_diff" takes a as Float, b as Float returns Float:
    Let d be a minus b
    If d is less than 0.0:
        Return 0.0 minus d
    End If
    Return d
End Process

Process called "main" returns Integer:
    Let eps be 0.0000000001
    Let bigger_eps be 0.000001

    Note: ------ Case 10 ------
    Let a be proc complex128_allocate from Complex
    If a is equal to 0:
        Return 10
    End If
    Let b be proc complex128_allocate from Complex
    Let r be proc complex128_allocate from Complex
    Let _sa be proc complex128_set from Complex with a, 3.5, 4.5
    Let ar be proc complex128_real from Complex with a
    Let ai be proc complex128_imag from Complex with a
    If proc abs_diff with ar, 3.5 is greater than eps:
        Return 10
    End If
    If proc abs_diff with ai, 4.5 is greater than eps:
        Return 10
    End If

    Note: ------ Case 11: i * i = -1 ------
    Let _i1 be proc complex128_set from Complex with a, 0.0, 1.0
    Let _i2 be proc complex128_set from Complex with b, 0.0, 1.0
    Let _mul be proc complex128_mul from Complex with a, b, r
    Let rr be proc complex128_real from Complex with r
    Let ri be proc complex128_imag from Complex with r
    Let neg1 be 0.0 minus 1.0
    If proc abs_diff with rr, neg1 is greater than eps:
        Return 11
    End If
    If proc abs_diff with ri, 0.0 is greater than eps:
        Return 11
    End If

    Note: ------ Case 12: (1+2i)+(3+4i) = 4+6i ------
    Let _a12 be proc complex128_set from Complex with a, 1.0, 2.0
    Let _b12 be proc complex128_set from Complex with b, 3.0, 4.0
    Let _add be proc complex128_add from Complex with a, b, r
    Set rr to proc complex128_real from Complex with r
    Set ri to proc complex128_imag from Complex with r
    If proc abs_diff with rr, 4.0 is greater than eps:
        Return 12
    End If
    If proc abs_diff with ri, 6.0 is greater than eps:
        Return 12
    End If

    Note: ------ Case 13: (3+4i)-(1+2i) = 2+2i ------
    Let _a13 be proc complex128_set from Complex with a, 3.0, 4.0
    Let _b13 be proc complex128_set from Complex with b, 1.0, 2.0
    Let _sub be proc complex128_sub from Complex with a, b, r
    Set rr to proc complex128_real from Complex with r
    Set ri to proc complex128_imag from Complex with r
    If proc abs_diff with rr, 2.0 is greater than eps:
        Return 13
    End If
    If proc abs_diff with ri, 2.0 is greater than eps:
        Return 13
    End If

    Note: ------ Case 14: (1+2i)*(3+4i) = -5+10i ------
    Let _a14 be proc complex128_set from Complex with a, 1.0, 2.0
    Let _b14 be proc complex128_set from Complex with b, 3.0, 4.0
    Let _mu2 be proc complex128_mul from Complex with a, b, r
    Set rr to proc complex128_real from Complex with r
    Set ri to proc complex128_imag from Complex with r
    Let neg5 be 0.0 minus 5.0
    If proc abs_diff with rr, neg5 is greater than eps:
        Return 14
    End If
    If proc abs_diff with ri, 10.0 is greater than eps:
        Return 14
    End If

    Note: ------ Case 15: (3+4i)/(1+2i) = 2.2 - 0.4i ------
    Let _a15 be proc complex128_set from Complex with a, 3.0, 4.0
    Let _b15 be proc complex128_set from Complex with b, 1.0, 2.0
    Let _di be proc complex128_div from Complex with a, b, r
    Set rr to proc complex128_real from Complex with r
    Set ri to proc complex128_imag from Complex with r
    If proc abs_diff with rr, 2.2 is greater than eps:
        Return 15
    End If
    Let neg04 be 0.0 minus 0.4
    If proc abs_diff with ri, neg04 is greater than eps:
        Return 15
    End If

    Note: ------ Case 16: magnitude (3+4i) = 5 ------
    Let _a16 be proc complex128_set from Complex with a, 3.0, 4.0
    Let mag be proc complex128_magnitude from Complex with a
    If proc abs_diff with mag, 5.0 is greater than eps:
        Return 16
    End If

    Note: ------ Case 17: argument (0+1i) = pi/2 ------
    Let _a17 be proc complex128_set from Complex with a, 0.0, 1.0
    Let arg be proc complex128_argument from Complex with a
    Let half_pi be 1.5707963267948966
    If proc abs_diff with arg, half_pi is greater than bigger_eps:
        Return 17
    End If

    Note: ------ Case 18: conjugate (1+2i) = 1-2i ------
    Let _a18 be proc complex128_set from Complex with a, 1.0, 2.0
    Let _cj be proc complex128_conjugate from Complex with a, r
    Set rr to proc complex128_real from Complex with r
    Set ri to proc complex128_imag from Complex with r
    Let neg2 be 0.0 minus 2.0
    If proc abs_diff with rr, 1.0 is greater than eps:
        Return 18
    End If
    If proc abs_diff with ri, neg2 is greater than eps:
        Return 18
    End If

    Note: ------ Case 19: reciprocal of (1+1i) = 0.5 - 0.5i ------
    Let _a19 be proc complex128_set from Complex with a, 1.0, 1.0
    Let _rc be proc complex128_reciprocal from Complex with a, r
    Set rr to proc complex128_real from Complex with r
    Set ri to proc complex128_imag from Complex with r
    Let neg_half be 0.0 minus 0.5
    If proc abs_diff with rr, 0.5 is greater than eps:
        Return 19
    End If
    If proc abs_diff with ri, neg_half is greater than eps:
        Return 19
    End If

    Note: ------ Case 20: polar round-trip ------
    Let _fp be proc complex128_from_polar from Complex with a, 5.0, half_pi
    Set rr to proc complex128_real from Complex with a
    Set ri to proc complex128_imag from Complex with a
    Note: 5 * (cos(pi/2) + i sin(pi/2)) = 0 + 5i
    If proc abs_diff with rr, 0.0 is greater than bigger_eps:
        Return 20
    End If
    If proc abs_diff with ri, 5.0 is greater than bigger_eps:
        Return 20
    End If

    Note: ------ Case 21: Euler's identity exp(i*pi) ~= -1 ------
    Let pi_val be 3.141592653589793
    Let _ep be proc complex128_set from Complex with a, 0.0, pi_val
    Let _ex be proc complex128_exp from Complex with a, r
    Set rr to proc complex128_real from Complex with r
    Set ri to proc complex128_imag from Complex with r
    If proc abs_diff with rr, neg1 is greater than bigger_eps:
        Return 21
    End If
    If proc abs_diff with ri, 0.0 is greater than bigger_eps:
        Return 21
    End If

    Note: ------ Case 22: sqrt(-1) = i ------
    Let _n1 be proc complex128_set from Complex with a, neg1, 0.0
    Let _sq be proc complex128_sqrt from Complex with a, r
    Set rr to proc complex128_real from Complex with r
    Set ri to proc complex128_imag from Complex with r
    If proc abs_diff with rr, 0.0 is greater than bigger_eps:
        Return 22
    End If
    If proc abs_diff with ri, 1.0 is greater than bigger_eps:
        Return 22
    End If

    Note: ------ Case 23: Complex64 i * i = -1 ------
    Let ca be proc complex64_allocate from Complex
    Let cb be proc complex64_allocate from Complex
    Let cr be proc complex64_allocate from Complex
    Let _ci1 be proc complex64_set from Complex with ca, 0.0, 1.0
    Let _ci2 be proc complex64_set from Complex with cb, 0.0, 1.0
    Let _cmul be proc complex64_mul from Complex with ca, cb, cr
    Let crr be proc complex64_real from Complex with cr
    Let cri be proc complex64_imag from Complex with cr
    Let f32_eps be 0.00001
    If proc abs_diff with crr, neg1 is greater than f32_eps:
        Return 23
    End If
    If proc abs_diff with cri, 0.0 is greater than f32_eps:
        Return 23
    End If

    Return 0
End Process
