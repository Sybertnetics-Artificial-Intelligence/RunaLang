:End Note

Note:
Tensor base KAT suite.

Coverage:
  10  zeros shape=[2,3] gives rank 2, total 6
  11  ones gives a tensor where every element equals 1.0
  12  arange(0, 5, 1) -> [0, 1, 2, 3, 4]
  13  linspace(0, 10, 11) endpoint check
  14  reshape preserves data: [1,2,3,4,5,6] reshape (2,3) gives row 0 = [1,2,3]
  15  transpose 2x3 -> 3x2 with element matching
  16  elementwise add same shape
  17  sum_all_f64 of [1, 2, 3, 4] = 10
  18  mean_all = 2.5 on [1, 2, 3, 4]
  19  max_all on [2, 5, 1, 3] = 5; argmax = 1
  20  matmul (2x3) * (3x4) = (2x4); spot-check one entry
:End Note

Import "compiler/frontend/primitives/numeric/extended/tensor_base.runa" as Tensor
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Process called "abs_diff_f" takes a as Float, b as Float returns Float:
    Let d be a minus b
    If d is less than 0.0:
        Return 0.0 minus d
    End If
    Return d
End Process

Process called "float_to_bits_tb" takes x as Float returns Integer:
    Note: Stack: x@[rbp-8], result@[rbp-16]. Inline asm copies the float-occupying slot to the integer slot.
    Let result be 0
    Inline Assembly:
        mov rax, qword ptr [rbp-8]
        mov qword ptr [rbp-16], rax
    End Assembly
    Return result
End Process

Process called "main" returns Integer:
    Let eps be 0.0000000001

    Note: ---- 10: zeros shape [2, 3] ----
    Let shape_buf be proc allocate from Layout with 16
    Let _ws0 be proc memory_set_int64 from Memory with shape_buf, 0, 2
    Let _ws1 be proc memory_set_int64 from Memory with shape_buf, 8, 3
    Let t be proc tensor_zeros from Tensor with shape_buf, 2, 2
    If t is equal to 0:
        Return 10
    End If
    Let rank be proc tensor_get_rank from Tensor with t
    If rank is not equal to 2:
        Return 10
    End If
    Let total be proc tensor_get_total_elements from Tensor with t
    If total is not equal to 6:
        Return 10
    End If

    Note: ---- 11: ones ----
    Let t1 be proc tensor_ones_f64 from Tensor with shape_buf, 2
    Let v0 be proc tensor_at_flat_f64 from Tensor with t1, 0
    Let v5 be proc tensor_at_flat_f64 from Tensor with t1, 5
    If proc abs_diff_f with v0, 1.0 is greater than eps:
        Return 11
    End If
    If proc abs_diff_f with v5, 1.0 is greater than eps:
        Return 11
    End If

    Note: ---- 12: arange(0, 5, 1) ----
    Let ar be proc tensor_arange_f64 from Tensor with 0.0, 5.0, 1.0
    If ar is equal to 0:
        Return 12
    End If
    Let ar_total be proc tensor_get_total_elements from Tensor with ar
    If ar_total is not equal to 5:
        Return 12
    End If
    Let ar0 be proc tensor_at_flat_f64 from Tensor with ar, 0
    Let ar4 be proc tensor_at_flat_f64 from Tensor with ar, 4
    If proc abs_diff_f with ar0, 0.0 is greater than eps:
        Return 12
    End If
    If proc abs_diff_f with ar4, 4.0 is greater than eps:
        Return 12
    End If

    Note: ---- 13: linspace(0, 10, 11) ----
    Let ls be proc tensor_linspace_f64 from Tensor with 0.0, 10.0, 11
    Let ls10 be proc tensor_at_flat_f64 from Tensor with ls, 10
    Let ls0 be proc tensor_at_flat_f64 from Tensor with ls, 0
    If proc abs_diff_f with ls10, 10.0 is greater than eps:
        Return 13
    End If
    If proc abs_diff_f with ls0, 0.0 is greater than eps:
        Return 13
    End If

    Note: ---- 14: reshape preserves data ----
    Note: Allocate flat [1, 2, 3, 4, 5, 6] then reshape (2, 3)
    Let flat_buf be proc allocate from Layout with 48
    Let i be 0
    While i is less than 6:
        Let v_f be 0.0
        If i is equal to 0:
            Set v_f to 1.0
        End If
        If i is equal to 1:
            Set v_f to 2.0
        End If
        If i is equal to 2:
            Set v_f to 3.0
        End If
        If i is equal to 3:
            Set v_f to 4.0
        End If
        If i is equal to 4:
            Set v_f to 5.0
        End If
        If i is equal to 5:
            Set v_f to 6.0
        End If
        Let bits be float_to_bits_tb(v_f)
        Let _w be proc memory_set_int64 from Memory with flat_buf, i multiplied by 8, bits
        Set i to i plus 1
    End While
    Let from_arr be proc tensor_from_array_f64 from Tensor with flat_buf, shape_buf, 2
    Let v00 be proc tensor_at_2d_f64 from Tensor with from_arr, 0, 0
    Let v02 be proc tensor_at_2d_f64 from Tensor with from_arr, 0, 2
    Let v10 be proc tensor_at_2d_f64 from Tensor with from_arr, 1, 0
    Let v12 be proc tensor_at_2d_f64 from Tensor with from_arr, 1, 2
    If proc abs_diff_f with v00, 1.0 is greater than eps:
        Return 14
    End If
    If proc abs_diff_f with v02, 3.0 is greater than eps:
        Return 14
    End If
    If proc abs_diff_f with v10, 4.0 is greater than eps:
        Return 14
    End If
    If proc abs_diff_f with v12, 6.0 is greater than eps:
        Return 14
    End If

    Note: ---- 15: transpose 2x3 -> 3x2 ----
    Let tt be proc tensor_transpose_2d_f64 from Tensor with from_arr
    Let tt_r0 be proc tensor_get_shape_at from Tensor with tt, 0
    Let tt_r1 be proc tensor_get_shape_at from Tensor with tt, 1
    If tt_r0 is not equal to 3:
        Return 15
    End If
    If tt_r1 is not equal to 2:
        Return 15
    End If
    Let tt00 be proc tensor_at_2d_f64 from Tensor with tt, 0, 0
    Let tt20 be proc tensor_at_2d_f64 from Tensor with tt, 2, 0
    Let tt21 be proc tensor_at_2d_f64 from Tensor with tt, 2, 1
    If proc abs_diff_f with tt00, 1.0 is greater than eps:
        Return 15
    End If
    If proc abs_diff_f with tt20, 3.0 is greater than eps:
        Return 15
    End If
    If proc abs_diff_f with tt21, 6.0 is greater than eps:
        Return 15
    End If

    Note: ---- 16: elementwise add same shape ----
    Let ones1 be proc tensor_ones_f64 from Tensor with shape_buf, 2
    Let added be proc tensor_elementwise_add_f64 from Tensor with from_arr, ones1
    Let added00 be proc tensor_at_2d_f64 from Tensor with added, 0, 0
    Let added12 be proc tensor_at_2d_f64 from Tensor with added, 1, 2
    If proc abs_diff_f with added00, 2.0 is greater than eps:
        Return 16
    End If
    If proc abs_diff_f with added12, 7.0 is greater than eps:
        Return 16
    End If

    Note: ---- 17: sum_all = 21 on [1..6] ----
    Let s be proc tensor_sum_all_f64 from Tensor with from_arr
    If proc abs_diff_f with s, 21.0 is greater than eps:
        Return 17
    End If

    Note: ---- 18: mean_all = 3.5 on [1..6] ----
    Let mean be proc tensor_mean_all_f64 from Tensor with from_arr
    If proc abs_diff_f with mean, 3.5 is greater than eps:
        Return 18
    End If

    Note: ---- 19: max_all = 6; argmax = 5 ----
    Let mx be proc tensor_max_all_f64 from Tensor with from_arr
    Let amx be proc tensor_argmax_all_f64 from Tensor with from_arr
    If proc abs_diff_f with mx, 6.0 is greater than eps:
        Return 19
    End If
    If amx is not equal to 5:
        Return 19
    End If

    Note: ---- 20: matmul (2x3) * (3x4) = (2x4) ----
    Note: A = [[1,2,3],[4,5,6]], B = identity-like 3x4 where B[0,0]=B[1,1]=B[2,2]=1.
    Note: Then C = A * B has C[0,0..2] = A[0,0..2], C[0,3] = 0, C[1,0..2] = A[1,0..2], C[1,3] = 0.
    Let b_shape be proc allocate from Layout with 16
    Let _wb0 be proc memory_set_int64 from Memory with b_shape, 0, 3
    Let _wb1 be proc memory_set_int64 from Memory with b_shape, 8, 4
    Let bb be proc tensor_zeros from Tensor with b_shape, 2, 2
    Let _b00 be proc tensor_set_2d_f64 from Tensor with bb, 0, 0, 1.0
    Let _b11 be proc tensor_set_2d_f64 from Tensor with bb, 1, 1, 1.0
    Let _b22 be proc tensor_set_2d_f64 from Tensor with bb, 2, 2, 1.0
    Let c be proc tensor_matmul_2d_f64 from Tensor with from_arr, bb
    If c is equal to 0:
        Return 20
    End If
    Let c00 be proc tensor_at_2d_f64 from Tensor with c, 0, 0
    Let c01 be proc tensor_at_2d_f64 from Tensor with c, 0, 1
    Let c02 be proc tensor_at_2d_f64 from Tensor with c, 0, 2
    Let c03 be proc tensor_at_2d_f64 from Tensor with c, 0, 3
    Let c10 be proc tensor_at_2d_f64 from Tensor with c, 1, 0
    Let c12 be proc tensor_at_2d_f64 from Tensor with c, 1, 2
    If proc abs_diff_f with c00, 1.0 is greater than eps:
        Return 20
    End If
    If proc abs_diff_f with c01, 2.0 is greater than eps:
        Return 20
    End If
    If proc abs_diff_f with c02, 3.0 is greater than eps:
        Return 20
    End If
    If proc abs_diff_f with c03, 0.0 is greater than eps:
        Return 20
    End If
    If proc abs_diff_f with c10, 4.0 is greater than eps:
        Return 20
    End If
    If proc abs_diff_f with c12, 6.0 is greater than eps:
        Return 20
    End If

    Return 0
End Process
