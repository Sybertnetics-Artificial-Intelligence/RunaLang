Note:
Vector2/3/4 KAT (Known Answer Test) suite.

Coverage:
  10  vector3_allocate non-null
  11  vector3_set then get_x/y/z round-trip
  12  vector3_add (1,2,3) + (4,5,6) = (5,7,9)
  13  vector3_sub (4,5,6) - (1,2,3) = (3,3,3)
  14  vector3_scalar_mul (1,2,3) * 2 = (2,4,6)
  15  vector3_dot (1,2,3) . (4,5,6) = 32
  16  vector3_cross right-hand rule: x_hat cross y_hat = z_hat
  17  vector3_cross anticommutativity: a x b = -(b x a)
  18  vector3_magnitude (3,4,0) = 5
  19  vector3_magnitude_squared (3,4,0) = 25
  20  vector3_normalize (3,0,0) = (1,0,0)
  21  vector3_distance (1,0,0) (4,0,0) = 3
  22  vector3_lerp t=0 returns a; t=1 returns b
  23  vector3_dot orthogonal vectors = 0
  24  vector3_reflect on flat normal: incident (1,-1,0) on normal (0,1,0) = (1,1,0)
  25  vector3_project (3,0,0) onto (1,0,0) = (3,0,0)
  26  vector2 add/dot/magnitude basic
  27  vector4 add/dot/magnitude basic
  28  vector3_angle_between (1,0,0) and (0,1,0) = pi/2 within 1e-6
:End Note

Import "compiler/frontend/primitives/numeric/extended/vector.runa" as Vector

Process called "abs_diff" takes a as Float, b as Float returns Float:
    Let d be a minus b
    If d is less than 0.0:
        Return 0.0 minus d
    End If
    Return d
End Process

Process called "main" returns Integer:
    Note: --- Case 10: allocate non-null ---
    Let v1 be proc vector3_allocate from Vector
    If v1 is equal to 0:
        Return 10
    End If
    Let v2 be proc vector3_allocate from Vector
    Let v3 be proc vector3_allocate from Vector

    Note: --- Case 11: set + get round-trip ---
    Let _s1 be proc vector3_set from Vector with v1, 1.5, 2.5, 3.5
    Let gx be proc vector3_get_x from Vector with v1
    Let gy be proc vector3_get_y from Vector with v1
    Let gz be proc vector3_get_z from Vector with v1
    Let eps be 0.0000000001
    Let dgx be proc abs_diff with gx, 1.5
    If dgx is greater than eps:
        Return 11
    End If
    Let dgy be proc abs_diff with gy, 2.5
    If dgy is greater than eps:
        Return 11
    End If
    Let dgz be proc abs_diff with gz, 3.5
    If dgz is greater than eps:
        Return 11
    End If

    Note: --- Case 12: add ---
    Let _s2 be proc vector3_set from Vector with v1, 1.0, 2.0, 3.0
    Let _s3 be proc vector3_set from Vector with v2, 4.0, 5.0, 6.0
    Let _a be proc vector3_add from Vector with v1, v2, v3
    Let rx be proc vector3_get_x from Vector with v3
    Let ry be proc vector3_get_y from Vector with v3
    Let rz be proc vector3_get_z from Vector with v3
    If proc abs_diff with rx, 5.0 is greater than eps:
        Return 12
    End If
    If proc abs_diff with ry, 7.0 is greater than eps:
        Return 12
    End If
    If proc abs_diff with rz, 9.0 is greater than eps:
        Return 12
    End If

    Note: --- Case 13: sub ---
    Let _b be proc vector3_sub from Vector with v2, v1, v3
    Set rx to proc vector3_get_x from Vector with v3
    Set ry to proc vector3_get_y from Vector with v3
    Set rz to proc vector3_get_z from Vector with v3
    If proc abs_diff with rx, 3.0 is greater than eps:
        Return 13
    End If
    If proc abs_diff with ry, 3.0 is greater than eps:
        Return 13
    End If
    If proc abs_diff with rz, 3.0 is greater than eps:
        Return 13
    End If

    Note: --- Case 14: scalar_mul ---
    Let _c be proc vector3_scalar_mul from Vector with v1, 2.0, v3
    Set rx to proc vector3_get_x from Vector with v3
    Set ry to proc vector3_get_y from Vector with v3
    Set rz to proc vector3_get_z from Vector with v3
    If proc abs_diff with rx, 2.0 is greater than eps:
        Return 14
    End If
    If proc abs_diff with ry, 4.0 is greater than eps:
        Return 14
    End If
    If proc abs_diff with rz, 6.0 is greater than eps:
        Return 14
    End If

    Note: --- Case 15: dot ---
    Let d be proc vector3_dot from Vector with v1, v2
    If proc abs_diff with d, 32.0 is greater than eps:
        Return 15
    End If

    Note: --- Case 16: right-hand rule cross x_hat x y_hat = z_hat ---
    Let _xh be proc vector3_set from Vector with v1, 1.0, 0.0, 0.0
    Let _yh be proc vector3_set from Vector with v2, 0.0, 1.0, 0.0
    Let _cr be proc vector3_cross from Vector with v1, v2, v3
    Set rx to proc vector3_get_x from Vector with v3
    Set ry to proc vector3_get_y from Vector with v3
    Set rz to proc vector3_get_z from Vector with v3
    If proc abs_diff with rx, 0.0 is greater than eps:
        Return 16
    End If
    If proc abs_diff with ry, 0.0 is greater than eps:
        Return 16
    End If
    If proc abs_diff with rz, 1.0 is greater than eps:
        Return 16
    End If

    Note: --- Case 17: anticommutativity ---
    Let v4 be proc vector3_allocate from Vector
    Let _cr2 be proc vector3_cross from Vector with v2, v1, v4
    Let r2x be proc vector3_get_x from Vector with v4
    Let r2z be proc vector3_get_z from Vector with v4
    If proc abs_diff with r2x, 0.0 is greater than eps:
        Return 17
    End If
    Let neg_rz be 0.0 minus rz
    If proc abs_diff with r2z, neg_rz is greater than eps:
        Return 17
    End If

    Note: --- Case 18: magnitude (3,4,0) = 5 ---
    Let _m1 be proc vector3_set from Vector with v1, 3.0, 4.0, 0.0
    Let mag be proc vector3_magnitude from Vector with v1
    If proc abs_diff with mag, 5.0 is greater than eps:
        Return 18
    End If

    Note: --- Case 19: magnitude_squared ---
    Let msq be proc vector3_magnitude_squared from Vector with v1
    If proc abs_diff with msq, 25.0 is greater than eps:
        Return 19
    End If

    Note: --- Case 20: normalize (3,0,0) = (1,0,0) ---
    Let _n1 be proc vector3_set from Vector with v1, 3.0, 0.0, 0.0
    Let _no be proc vector3_normalize from Vector with v1, v3
    Set rx to proc vector3_get_x from Vector with v3
    Set ry to proc vector3_get_y from Vector with v3
    Set rz to proc vector3_get_z from Vector with v3
    If proc abs_diff with rx, 1.0 is greater than eps:
        Return 20
    End If
    If proc abs_diff with ry, 0.0 is greater than eps:
        Return 20
    End If
    If proc abs_diff with rz, 0.0 is greater than eps:
        Return 20
    End If

    Note: --- Case 21: distance ---
    Let _d1 be proc vector3_set from Vector with v1, 1.0, 0.0, 0.0
    Let _d2 be proc vector3_set from Vector with v2, 4.0, 0.0, 0.0
    Let dist be proc vector3_distance from Vector with v1, v2
    If proc abs_diff with dist, 3.0 is greater than eps:
        Return 21
    End If

    Note: --- Case 22: lerp t=0 returns a, t=1 returns b ---
    Let _l1 be proc vector3_set from Vector with v1, 1.0, 1.0, 1.0
    Let _l2 be proc vector3_set from Vector with v2, 5.0, 5.0, 5.0
    Let _lp0 be proc vector3_lerp from Vector with v1, v2, 0.0, v3
    Let lpx0 be proc vector3_get_x from Vector with v3
    If proc abs_diff with lpx0, 1.0 is greater than eps:
        Return 22
    End If
    Let _lp1 be proc vector3_lerp from Vector with v1, v2, 1.0, v3
    Let lpx1 be proc vector3_get_x from Vector with v3
    If proc abs_diff with lpx1, 5.0 is greater than eps:
        Return 22
    End If
    Let _lp5 be proc vector3_lerp from Vector with v1, v2, 0.5, v3
    Let lpx5 be proc vector3_get_x from Vector with v3
    If proc abs_diff with lpx5, 3.0 is greater than eps:
        Return 22
    End If

    Note: --- Case 23: orthogonal dot = 0 ---
    Let _o1 be proc vector3_set from Vector with v1, 1.0, 0.0, 0.0
    Let _o2 be proc vector3_set from Vector with v2, 0.0, 1.0, 0.0
    Let dot_orth be proc vector3_dot from Vector with v1, v2
    If proc abs_diff with dot_orth, 0.0 is greater than eps:
        Return 23
    End If

    Note: --- Case 24: reflect incident (1,-1,0) on normal (0,1,0) ---
    Let neg1 be 0.0 minus 1.0
    Let _ir be proc vector3_set from Vector with v1, 1.0, neg1, 0.0
    Let _nr be proc vector3_set from Vector with v2, 0.0, 1.0, 0.0
    Let _re be proc vector3_reflect from Vector with v1, v2, v3
    Set rx to proc vector3_get_x from Vector with v3
    Set ry to proc vector3_get_y from Vector with v3
    Set rz to proc vector3_get_z from Vector with v3
    If proc abs_diff with rx, 1.0 is greater than eps:
        Return 24
    End If
    If proc abs_diff with ry, 1.0 is greater than eps:
        Return 24
    End If

    Note: --- Case 25: project (3,0,0) onto (1,0,0) = (3,0,0) ---
    Let _p1 be proc vector3_set from Vector with v1, 3.0, 0.0, 0.0
    Let _p2 be proc vector3_set from Vector with v2, 1.0, 0.0, 0.0
    Let _pr be proc vector3_project from Vector with v1, v2, v3
    Set rx to proc vector3_get_x from Vector with v3
    Set ry to proc vector3_get_y from Vector with v3
    If proc abs_diff with rx, 3.0 is greater than eps:
        Return 25
    End If
    If proc abs_diff with ry, 0.0 is greater than eps:
        Return 25
    End If

    Note: --- Case 26: vector2 sanity ---
    Let w1 be proc vector2_allocate from Vector
    Let w2 be proc vector2_allocate from Vector
    Let w3 be proc vector2_allocate from Vector
    Let _ws1 be proc vector2_set from Vector with w1, 3.0, 4.0
    Let _ws2 be proc vector2_set from Vector with w2, 1.0, 2.0
    Let _wa be proc vector2_add from Vector with w1, w2, w3
    Let wgx be proc vector2_get_x from Vector with w3
    Let wgy be proc vector2_get_y from Vector with w3
    If proc abs_diff with wgx, 4.0 is greater than eps:
        Return 26
    End If
    If proc abs_diff with wgy, 6.0 is greater than eps:
        Return 26
    End If
    Let wmag be proc vector2_magnitude from Vector with w1
    If proc abs_diff with wmag, 5.0 is greater than eps:
        Return 26
    End If

    Note: --- Case 27: vector4 sanity ---
    Let q1 be proc vector4_allocate from Vector
    Let q2 be proc vector4_allocate from Vector
    Let q3 be proc vector4_allocate from Vector
    Let _qs1 be proc vector4_set from Vector with q1, 1.0, 0.0, 0.0, 0.0
    Let _qs2 be proc vector4_set from Vector with q2, 0.0, 1.0, 0.0, 0.0
    Let _qa be proc vector4_add from Vector with q1, q2, q3
    Let qgx be proc vector4_get_x from Vector with q3
    Let qgy be proc vector4_get_y from Vector with q3
    If proc abs_diff with qgx, 1.0 is greater than eps:
        Return 27
    End If
    If proc abs_diff with qgy, 1.0 is greater than eps:
        Return 27
    End If
    Let qdot be proc vector4_dot from Vector with q1, q2
    If proc abs_diff with qdot, 0.0 is greater than eps:
        Return 27
    End If

    Note: --- Case 28: angle_between orthogonal = pi/2 ---
    Let _ab1 be proc vector3_set from Vector with v1, 1.0, 0.0, 0.0
    Let _ab2 be proc vector3_set from Vector with v2, 0.0, 1.0, 0.0
    Let angle be proc vector3_angle_between from Vector with v1, v2
    Let half_pi be 1.5707963267948966
    Let dang be proc abs_diff with angle, half_pi
    Let ang_eps be 0.000001
    If dang is greater than ang_eps:
        Return 28
    End If

    Note: cleanup
    Let _f1 be proc vector3_free from Vector with v1
    Let _f2 be proc vector3_free from Vector with v2
    Let _f3 be proc vector3_free from Vector with v3
    Let _f4 be proc vector3_free from Vector with v4
    Let _fw1 be proc vector2_free from Vector with w1
    Let _fw2 be proc vector2_free from Vector with w2
    Let _fw3 be proc vector2_free from Vector with w3
    Let _fq1 be proc vector4_free from Vector with q1
    Let _fq2 be proc vector4_free from Vector with q2
    Let _fq3 be proc vector4_free from Vector with q3
    Return 0
End Process
