Note:
Rational KAT suite.

Coverage:
  10  allocate / get_numerator / get_denominator round-trip
  11  set 6/8 normalizes to 3/4 (GCD reduction)
  12  set -3/-6 normalizes to 1/2 (sign flip + GCD)
  13  1/3 + 1/6 = 1/2 exactly (KAT)
  14  1/2 - 1/4 = 1/4 exactly
  15  2/3 * 3/4 = 1/2 exactly (cross-cancellation)
  16  1/2 / 1/4 = 2/1 = 2
  17  negate 3/4 = -3/4; abs(-3/4) = 3/4
  18  reciprocal 3/4 = 4/3
  19  pow_int (2/3)^3 = 8/27
  20  compare 1/3 < 1/2; equal; 1/2 > 1/3
  21  from_decimal_string "0.1" = 1/10 exactly (the canonical exactness test)
  22  from_decimal_string "-3.25" = -13/4
  23  to_decimal_string of 1/3 = "1/3"
  24  to_float64 of 1/2 = 0.5
  25  division by zero returns RATIONAL_ERR_DENOM_ZERO
:End Note

Import "compiler/frontend/primitives/numeric/extended/rational.runa" as Rational
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Process called "abs_diff_f" takes a as Float, b as Float returns Float:
    Let d be a minus b
    If d is less than 0.0:
        Return 0.0 minus d
    End If
    Return d
End Process

Process called "main" returns Integer:
    Note: ---- 10 ----
    Let r be proc rational_allocate from Rational
    If r is equal to 0:
        Return 10
    End If
    Let _s be proc rational_set from Rational with r, 7, 11
    If proc rational_get_numerator from Rational with r is not equal to 7:
        Return 10
    End If
    If proc rational_get_denominator from Rational with r is not equal to 11:
        Return 10
    End If

    Note: ---- 11: 6/8 -> 3/4 ----
    Let _s11 be proc rational_set from Rational with r, 6, 8
    If proc rational_get_numerator from Rational with r is not equal to 3:
        Return 11
    End If
    If proc rational_get_denominator from Rational with r is not equal to 4:
        Return 11
    End If

    Note: ---- 12: -3/-6 -> 1/2 ----
    Let _s12 be proc rational_set from Rational with r, -3, -6
    If proc rational_get_numerator from Rational with r is not equal to 1:
        Return 12
    End If
    If proc rational_get_denominator from Rational with r is not equal to 2:
        Return 12
    End If

    Note: ---- 13: 1/3 + 1/6 = 1/2 ----
    Let a be proc rational_allocate from Rational
    Let b be proc rational_allocate from Rational
    Let c be proc rational_allocate from Rational
    Let _sa be proc rational_set from Rational with a, 1, 3
    Let _sb be proc rational_set from Rational with b, 1, 6
    Let _add be proc rational_add from Rational with a, b, c
    If proc rational_get_numerator from Rational with c is not equal to 1:
        Return 13
    End If
    If proc rational_get_denominator from Rational with c is not equal to 2:
        Return 13
    End If

    Note: ---- 14: 1/2 - 1/4 = 1/4 ----
    Let _sa14 be proc rational_set from Rational with a, 1, 2
    Let _sb14 be proc rational_set from Rational with b, 1, 4
    Let _sub be proc rational_sub from Rational with a, b, c
    If proc rational_get_numerator from Rational with c is not equal to 1:
        Return 14
    End If
    If proc rational_get_denominator from Rational with c is not equal to 4:
        Return 14
    End If

    Note: ---- 15: 2/3 * 3/4 = 1/2 ----
    Let _sa15 be proc rational_set from Rational with a, 2, 3
    Let _sb15 be proc rational_set from Rational with b, 3, 4
    Let _mul be proc rational_mul from Rational with a, b, c
    If proc rational_get_numerator from Rational with c is not equal to 1:
        Return 15
    End If
    If proc rational_get_denominator from Rational with c is not equal to 2:
        Return 15
    End If

    Note: ---- 16: 1/2 / 1/4 = 2 ----
    Let _sa16 be proc rational_set from Rational with a, 1, 2
    Let _sb16 be proc rational_set from Rational with b, 1, 4
    Let _div be proc rational_div from Rational with a, b, c
    If proc rational_get_numerator from Rational with c is not equal to 2:
        Return 16
    End If
    If proc rational_get_denominator from Rational with c is not equal to 1:
        Return 16
    End If

    Note: ---- 17: negate 3/4 = -3/4; abs back to 3/4 ----
    Let _sa17 be proc rational_set from Rational with a, 3, 4
    Let _nv be proc rational_neg from Rational with a, c
    If proc rational_get_numerator from Rational with c is not equal to -3:
        Return 17
    End If
    Let _av be proc rational_abs from Rational with c, c
    If proc rational_get_numerator from Rational with c is not equal to 3:
        Return 17
    End If

    Note: ---- 18: reciprocal 3/4 = 4/3 ----
    Let _sa18 be proc rational_set from Rational with a, 3, 4
    Let _rec be proc rational_reciprocal from Rational with a, c
    If proc rational_get_numerator from Rational with c is not equal to 4:
        Return 18
    End If
    If proc rational_get_denominator from Rational with c is not equal to 3:
        Return 18
    End If

    Note: ---- 19: (2/3)^3 = 8/27 ----
    Let _sa19 be proc rational_set from Rational with a, 2, 3
    Let _pw be proc rational_pow_int from Rational with a, 3, c
    If proc rational_get_numerator from Rational with c is not equal to 8:
        Return 19
    End If
    If proc rational_get_denominator from Rational with c is not equal to 27:
        Return 19
    End If

    Note: ---- 20: compare ----
    Let _ca be proc rational_set from Rational with a, 1, 3
    Let _cb be proc rational_set from Rational with b, 1, 2
    Let cmp1 be proc rational_compare from Rational with a, b
    If cmp1 is not equal to -1:
        Return 20
    End If
    Let cmp2 be proc rational_compare from Rational with a, a
    If cmp2 is not equal to 0:
        Return 20
    End If
    Let cmp3 be proc rational_compare from Rational with b, a
    If cmp3 is not equal to 1:
        Return 20
    End If

    Note: ---- 21: from_decimal_string "0.1" = 1/10 ----
    Let strbuf be proc allocate from Layout with 32
    Let _w0 be proc memory_set_byte from Memory with strbuf, 0, 48
    Let _w1 be proc memory_set_byte from Memory with strbuf, 1, 46
    Let _w2 be proc memory_set_byte from Memory with strbuf, 2, 49
    Let _w3 be proc memory_set_byte from Memory with strbuf, 3, 0
    Let ok21 be proc rational_from_decimal_string from Rational with c, strbuf
    If ok21 is not equal to 0:
        Return 21
    End If
    If proc rational_get_numerator from Rational with c is not equal to 1:
        Return 21
    End If
    If proc rational_get_denominator from Rational with c is not equal to 10:
        Return 21
    End If

    Note: ---- 22: from_decimal_string "-3.25" = -13/4 ----
    Let _w0b be proc memory_set_byte from Memory with strbuf, 0, 45
    Let _w1b be proc memory_set_byte from Memory with strbuf, 1, 51
    Let _w2b be proc memory_set_byte from Memory with strbuf, 2, 46
    Let _w3b be proc memory_set_byte from Memory with strbuf, 3, 50
    Let _w4b be proc memory_set_byte from Memory with strbuf, 4, 53
    Let _w5b be proc memory_set_byte from Memory with strbuf, 5, 0
    Let ok22 be proc rational_from_decimal_string from Rational with c, strbuf
    If ok22 is not equal to 0:
        Return 22
    End If
    If proc rational_get_numerator from Rational with c is not equal to -13:
        Return 22
    End If
    If proc rational_get_denominator from Rational with c is not equal to 4:
        Return 22
    End If

    Note: ---- 23: to_decimal_string of 1/3 ----
    Let _s23 be proc rational_set from Rational with c, 1, 3
    Let outbuf be proc allocate from Layout with 32
    Let len23 be proc rational_to_decimal_string from Rational with c, outbuf, 32
    If len23 is not equal to 3:
        Return 23
    End If
    Let ch0 be proc memory_get_byte from Memory with outbuf, 0
    Let ch1 be proc memory_get_byte from Memory with outbuf, 1
    Let ch2 be proc memory_get_byte from Memory with outbuf, 2
    If ch0 is not equal to 49:
        Return 23
    End If
    If ch1 is not equal to 47:
        Return 23
    End If
    If ch2 is not equal to 51:
        Return 23
    End If

    Note: ---- 24: to_float64 of 1/2 = 0.5 ----
    Let _s24 be proc rational_set from Rational with c, 1, 2
    Let f24 be proc rational_to_float64 from Rational with c
    Let eps be 0.0000000001
    If proc abs_diff_f with f24, 0.5 is greater than eps:
        Return 24
    End If

    Note: ---- 25: division by zero ----
    Let _sa25 be proc rational_set from Rational with a, 1, 2
    Let _zero be proc rational_allocate from Rational
    Let _sz be proc rational_set from Rational with _zero, 0, 1
    Let err be proc rational_div from Rational with a, _zero, c
    If err is not equal to -1:
        Return 25
    End If

    Return 0
End Process
