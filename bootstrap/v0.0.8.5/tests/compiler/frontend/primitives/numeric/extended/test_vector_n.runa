:End Note

Note:
VectorN (variable-dimension Float64 vector) KAT suite.

Coverage:
  10  allocate non-null, get_dim = 4
  11  set/get round-trip across all four components
  12  allocate(0) rejected
  13  bounds check: set/get on out-of-range index
  14  copy: src -> dst, full payload
  15  add: (1,2,3,4) + (5,6,7,8) = (6,8,10,12)
  16  sub: (5,6,7,8) - (1,2,3,4) = (4,4,4,4)
  17  scalar_mul: (1,2,3,4) * 2 = (2,4,6,8)
  18  negate: (1,2,3,4) -> (-1,-2,-3,-4)
  19  dot: (1,2,3,4) . (5,6,7,8) = 70
  20  magnitude_squared (3,4,0,0) = 25
  21  magnitude (3,4,0,0) = 5
  22  normalize (3,0,0,0) -> (1,0,0,0)
  23  distance (1,0,0,0) (4,0,0,0) = 3
  24  distance_squared (1,0,0,0) (4,0,0,0) = 9
  25  lerp t=0 returns a; t=1 returns b
  26  angle_between (1,0,0,0) and (0,1,0,0) = pi/2 within eps
  27  project (3,0,0,0) onto (1,0,0,0) = (3,0,0,0)
  28  variable dim N=8 round-trip
:End Note

Import "compiler/frontend/primitives/numeric/extended/vector_n.runa" as VN

Process called "abs_diff" takes a as Float, b as Float returns Float:
    Let d be a minus b
    If d is less than 0.0:
        Return 0.0 minus d
    End If
    Return d
End Process

Process called "main" returns Integer:
    Let eps be 0.0000000001

    Note: --- Case 10: allocate non-null, dim ---
    Let v1 be proc vector_n_allocate from VN with 4
    If v1 is equal to 0:
        Return 10
    End If
    Let v2 be proc vector_n_allocate from VN with 4
    Let v3 be proc vector_n_allocate from VN with 4
    Let d1 be proc vector_n_get_dim from VN with v1
    If d1 is not equal to 4:
        Return 10
    End If

    Note: --- Case 11: set/get round-trip ---
    Let _w0 be proc vector_n_set_component from VN with v1, 0, 1.5
    Let _w1 be proc vector_n_set_component from VN with v1, 1, 2.5
    Let _w2 be proc vector_n_set_component from VN with v1, 2, 3.5
    Let _w3 be proc vector_n_set_component from VN with v1, 3, 4.5
    Let g0 be proc vector_n_get_component from VN with v1, 0
    Let g1 be proc vector_n_get_component from VN with v1, 1
    Let g2 be proc vector_n_get_component from VN with v1, 2
    Let g3 be proc vector_n_get_component from VN with v1, 3
    If proc abs_diff with g0, 1.5 is greater than eps:
        Return 11
    End If
    If proc abs_diff with g1, 2.5 is greater than eps:
        Return 11
    End If
    If proc abs_diff with g2, 3.5 is greater than eps:
        Return 11
    End If
    If proc abs_diff with g3, 4.5 is greater than eps:
        Return 11
    End If

    Note: --- Case 12: allocate(0) rejected ---
    Let vz be proc vector_n_allocate from VN with 0
    If vz is not equal to 0:
        Return 12
    End If

    Note: --- Case 13: out-of-range index returns -1 / 0.0 ---
    Let oob_w be proc vector_n_set_component from VN with v1, 4, 9.0
    If oob_w is not equal to -1:
        Return 13
    End If
    Let oob_g be proc vector_n_get_component from VN with v1, 4
    If proc abs_diff with oob_g, 0.0 is greater than eps:
        Return 13
    End If

    Note: --- Case 14: copy ---
    Let _cp be proc vector_n_copy from VN with v1, v2
    Let c0 be proc vector_n_get_component from VN with v2, 0
    Let c3 be proc vector_n_get_component from VN with v2, 3
    If proc abs_diff with c0, 1.5 is greater than eps:
        Return 14
    End If
    If proc abs_diff with c3, 4.5 is greater than eps:
        Return 14
    End If

    Note: --- Case 15: add (1,2,3,4) + (5,6,7,8) = (6,8,10,12) ---
    Let _r1 be proc vector_n_set_component from VN with v1, 0, 1.0
    Let _r2 be proc vector_n_set_component from VN with v1, 1, 2.0
    Let _r3 be proc vector_n_set_component from VN with v1, 2, 3.0
    Let _r4 be proc vector_n_set_component from VN with v1, 3, 4.0
    Let _s1 be proc vector_n_set_component from VN with v2, 0, 5.0
    Let _s2 be proc vector_n_set_component from VN with v2, 1, 6.0
    Let _s3 be proc vector_n_set_component from VN with v2, 2, 7.0
    Let _s4 be proc vector_n_set_component from VN with v2, 3, 8.0
    Let _ad be proc vector_n_add from VN with v1, v2, v3
    Let a0 be proc vector_n_get_component from VN with v3, 0
    Let a3 be proc vector_n_get_component from VN with v3, 3
    If proc abs_diff with a0, 6.0 is greater than eps:
        Return 15
    End If
    If proc abs_diff with a3, 12.0 is greater than eps:
        Return 15
    End If

    Note: --- Case 16: sub ---
    Let _su be proc vector_n_sub from VN with v2, v1, v3
    Let su0 be proc vector_n_get_component from VN with v3, 0
    Let su3 be proc vector_n_get_component from VN with v3, 3
    If proc abs_diff with su0, 4.0 is greater than eps:
        Return 16
    End If
    If proc abs_diff with su3, 4.0 is greater than eps:
        Return 16
    End If

    Note: --- Case 17: scalar_mul ---
    Let _sm be proc vector_n_scalar_mul from VN with v1, 2.0, v3
    Let m0 be proc vector_n_get_component from VN with v3, 0
    Let m3 be proc vector_n_get_component from VN with v3, 3
    If proc abs_diff with m0, 2.0 is greater than eps:
        Return 17
    End If
    If proc abs_diff with m3, 8.0 is greater than eps:
        Return 17
    End If

    Note: --- Case 18: negate ---
    Let _ng be proc vector_n_negate from VN with v1, v3
    Let n0 be proc vector_n_get_component from VN with v3, 0
    Let n3 be proc vector_n_get_component from VN with v3, 3
    If proc abs_diff with n0, 0.0 minus 1.0 is greater than eps:
        Return 18
    End If
    If proc abs_diff with n3, 0.0 minus 4.0 is greater than eps:
        Return 18
    End If

    Note: --- Case 19: dot ---
    Let dt be proc vector_n_dot from VN with v1, v2
    If proc abs_diff with dt, 70.0 is greater than eps:
        Return 19
    End If

    Note: --- Case 20+21: magnitude / magnitude_squared (3,4,0,0) ---
    Let _q0 be proc vector_n_set_component from VN with v1, 0, 3.0
    Let _q1 be proc vector_n_set_component from VN with v1, 1, 4.0
    Let _q2 be proc vector_n_set_component from VN with v1, 2, 0.0
    Let _q3 be proc vector_n_set_component from VN with v1, 3, 0.0
    Let msq be proc vector_n_magnitude_squared from VN with v1
    If proc abs_diff with msq, 25.0 is greater than eps:
        Return 20
    End If
    Let mag be proc vector_n_magnitude from VN with v1
    If proc abs_diff with mag, 5.0 is greater than eps:
        Return 21
    End If

    Note: --- Case 22: normalize (3,0,0,0) -> (1,0,0,0) ---
    Let _nz0 be proc vector_n_set_component from VN with v1, 0, 3.0
    Let _nz1 be proc vector_n_set_component from VN with v1, 1, 0.0
    Let _nz2 be proc vector_n_set_component from VN with v1, 2, 0.0
    Let _nz3 be proc vector_n_set_component from VN with v1, 3, 0.0
    Let _norm be proc vector_n_normalize from VN with v1, v3
    Let nm0 be proc vector_n_get_component from VN with v3, 0
    Let nm1 be proc vector_n_get_component from VN with v3, 1
    If proc abs_diff with nm0, 1.0 is greater than eps:
        Return 22
    End If
    If proc abs_diff with nm1, 0.0 is greater than eps:
        Return 22
    End If

    Note: --- Case 23+24: distance / distance_squared ---
    Let _da0 be proc vector_n_set_component from VN with v1, 0, 1.0
    Let _da1 be proc vector_n_set_component from VN with v1, 1, 0.0
    Let _da2 be proc vector_n_set_component from VN with v1, 2, 0.0
    Let _da3 be proc vector_n_set_component from VN with v1, 3, 0.0
    Let _db0 be proc vector_n_set_component from VN with v2, 0, 4.0
    Let _db1 be proc vector_n_set_component from VN with v2, 1, 0.0
    Let _db2 be proc vector_n_set_component from VN with v2, 2, 0.0
    Let _db3 be proc vector_n_set_component from VN with v2, 3, 0.0
    Let dist be proc vector_n_distance from VN with v1, v2
    If proc abs_diff with dist, 3.0 is greater than eps:
        Return 23
    End If
    Let dsq be proc vector_n_distance_squared from VN with v1, v2
    If proc abs_diff with dsq, 9.0 is greater than eps:
        Return 24
    End If

    Note: --- Case 25: lerp endpoints ---
    Let _le1 be proc vector_n_lerp from VN with v1, v2, 0.0, v3
    Let l0 be proc vector_n_get_component from VN with v3, 0
    If proc abs_diff with l0, 1.0 is greater than eps:
        Return 25
    End If
    Let _le2 be proc vector_n_lerp from VN with v1, v2, 1.0, v3
    Let l1 be proc vector_n_get_component from VN with v3, 0
    If proc abs_diff with l1, 4.0 is greater than eps:
        Return 25
    End If

    Note: --- Case 26: angle_between (1,0,0,0) (0,1,0,0) = pi/2 ---
    Let _e10 be proc vector_n_set_component from VN with v1, 0, 1.0
    Let _e11 be proc vector_n_set_component from VN with v1, 1, 0.0
    Let _e20 be proc vector_n_set_component from VN with v2, 0, 0.0
    Let _e21 be proc vector_n_set_component from VN with v2, 1, 1.0
    Let theta be proc vector_n_angle_between from VN with v1, v2
    Let pi_half be 1.5707963267948966
    Let eps_trig be 0.000001
    If proc abs_diff with theta, pi_half is greater than eps_trig:
        Return 26
    End If

    Note: --- Case 27: project (3,0,0,0) onto (1,0,0,0) ---
    Let _pa0 be proc vector_n_set_component from VN with v1, 0, 3.0
    Let _pa1 be proc vector_n_set_component from VN with v1, 1, 0.0
    Let _pb0 be proc vector_n_set_component from VN with v2, 0, 1.0
    Let _pb1 be proc vector_n_set_component from VN with v2, 1, 0.0
    Let _pr be proc vector_n_project from VN with v1, v2, v3
    Let pj0 be proc vector_n_get_component from VN with v3, 0
    Let pj1 be proc vector_n_get_component from VN with v3, 1
    If proc abs_diff with pj0, 3.0 is greater than eps:
        Return 27
    End If
    If proc abs_diff with pj1, 0.0 is greater than eps:
        Return 27
    End If

    Note: --- Case 28: variable dim N=8 set/get round-trip ---
    Let v8 be proc vector_n_allocate from VN with 8
    If v8 is equal to 0:
        Return 28
    End If
    Let dd be proc vector_n_get_dim from VN with v8
    If dd is not equal to 8:
        Return 28
    End If
    Let i be 0
    While i is less than 8:
        Let val be 0.5 plus (i multiplied by 1)
        Let _wn be proc vector_n_set_component from VN with v8, i, val
        Set i to i plus 1
    End While
    Let i2 be 0
    While i2 is less than 8:
        Let want be 0.5 plus (i2 multiplied by 1)
        Let got be proc vector_n_get_component from VN with v8, i2
        If proc abs_diff with got, want is greater than eps:
            Return 28
        End If
        Set i2 to i2 plus 1
    End While
    Let _f8 be proc vector_n_free from VN with v8

    Note: --- Cleanup ---
    Let _f1 be proc vector_n_free from VN with v1
    Let _f2 be proc vector_n_free from VN with v2
    Let _f3 be proc vector_n_free from VN with v3

    Return 0
End Process
