Note:
Sparse matrix KAT suite.

Coverage:
  10  COO allocate / append / get_nnz / dimensions
  11  COO append over-capacity returns -1
  12  COO -> CSR round-trip via to_csr -> to_coo
  13  CSR matvec on a sparse identity I gives I * x = x
  14  CSR matvec on a 3x3 with explicit values
  15  CSC matvec equivalent to CSR matvec (transpose comparison via diagonal)
  16  CSR transpose: A^T's (i, j) equals A's (j, i)
:End Note

Import "compiler/frontend/primitives/numeric/extended/sparse_matrix.runa" as Sparse
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Process called "store_f64_at" takes buf as Integer, idx as Integer, value as Float returns Integer:
    Let bits be 0
    Inline Assembly:
        movq xmm0, qword ptr [rbp-24]
        movq rax, xmm0
        mov qword ptr [rbp-8], rax
    End Assembly
    Let _w be proc memory_set_int64 from Memory with buf, idx multiplied by 8, bits
    Return 0
End Process

Process called "load_f64_at" takes buf as Integer, idx as Integer returns Float:
    Let bits be proc memory_get_int64 from Memory with buf, idx multiplied by 8
    Let result be 0.0
    Inline Assembly:
        mov rax, qword ptr [rbp-8]
        mov qword ptr [rbp-16], rax
    End Assembly
    Return result
End Process

Process called "abs_diff_f" takes a as Float, b as Float returns Float:
    Let d be a minus b
    If d is less than 0.0:
        Return 0.0 minus d
    End If
    Return d
End Process

Process called "main" returns Integer:
    Let eps be 0.0000000001

    Note: ---- 10: COO basics ----
    Let coo be proc sparse_coo_allocate from Sparse with 3, 3, 8
    If coo is equal to 0:
        Return 10
    End If
    Let _a1 be proc sparse_coo_append_entry from Sparse with coo, 0, 0, 1.0
    Let _a2 be proc sparse_coo_append_entry from Sparse with coo, 1, 1, 2.0
    Let _a3 be proc sparse_coo_append_entry from Sparse with coo, 2, 2, 3.0
    Let nnz be proc sparse_coo_get_nnz from Sparse with coo
    If nnz is not equal to 3:
        Return 10
    End If
    Let nr be proc sparse_coo_get_n_rows from Sparse with coo
    If nr is not equal to 3:
        Return 10
    End If

    Note: ---- 11: COO over-capacity ----
    Let small be proc sparse_coo_allocate from Sparse with 2, 2, 2
    Let _ok1 be proc sparse_coo_append_entry from Sparse with small, 0, 0, 1.0
    Let _ok2 be proc sparse_coo_append_entry from Sparse with small, 1, 1, 1.0
    Let err be proc sparse_coo_append_entry from Sparse with small, 0, 1, 1.0
    If err is not equal to -1:
        Return 11
    End If

    Note: ---- 12: COO->CSR round-trip ----
    Let csr be proc sparse_coo_to_csr from Sparse with coo
    If csr is equal to 0:
        Return 12
    End If
    Let csr_nnz be proc sparse_csr_get_nnz from Sparse with csr
    If csr_nnz is not equal to 3:
        Return 12
    End If
    Let coo_back be proc sparse_csr_to_coo from Sparse with csr
    If coo_back is equal to 0:
        Return 12
    End If
    Let back_nnz be proc sparse_coo_get_nnz from Sparse with coo_back
    If back_nnz is not equal to 3:
        Return 12
    End If

    Note: ---- 13: CSR identity matvec ----
    Let x_buf be proc allocate from Layout with 24
    Let y_buf be proc allocate from Layout with 24
    Let _x0 be proc store_f64_at with x_buf, 0, 5.0
    Let _x1 be proc store_f64_at with x_buf, 1, 7.0
    Let _x2 be proc store_f64_at with x_buf, 2, 11.0
    Let _mv be proc sparse_csr_matvec from Sparse with csr, x_buf, y_buf
    Let y0 be proc load_f64_at with y_buf, 0
    Let y1 be proc load_f64_at with y_buf, 1
    Let y2 be proc load_f64_at with y_buf, 2
    Note: csr is diag(1,2,3) so y = (5, 14, 33)
    If proc abs_diff_f with y0, 5.0 is greater than eps:
        Return 13
    End If
    If proc abs_diff_f with y1, 14.0 is greater than eps:
        Return 13
    End If
    If proc abs_diff_f with y2, 33.0 is greater than eps:
        Return 13
    End If

    Note: ---- 14: 3x3 non-diagonal matvec ----
    Let coo2 be proc sparse_coo_allocate from Sparse with 3, 3, 6
    Let _ap1 be proc sparse_coo_append_entry from Sparse with coo2, 0, 0, 1.0
    Let _ap2 be proc sparse_coo_append_entry from Sparse with coo2, 0, 2, 2.0
    Let _ap3 be proc sparse_coo_append_entry from Sparse with coo2, 1, 1, 3.0
    Let _ap4 be proc sparse_coo_append_entry from Sparse with coo2, 2, 0, 4.0
    Let _ap5 be proc sparse_coo_append_entry from Sparse with coo2, 2, 2, 5.0
    Let csr2 be proc sparse_coo_to_csr from Sparse with coo2
    Note: x = [1, 1, 1]; expected y = [1+2, 3, 4+5] = [3, 3, 9]
    Let _x14_0 be proc store_f64_at with x_buf, 0, 1.0
    Let _x14_1 be proc store_f64_at with x_buf, 1, 1.0
    Let _x14_2 be proc store_f64_at with x_buf, 2, 1.0
    Let _mv2 be proc sparse_csr_matvec from Sparse with csr2, x_buf, y_buf
    Let y14_0 be proc load_f64_at with y_buf, 0
    Let y14_1 be proc load_f64_at with y_buf, 1
    Let y14_2 be proc load_f64_at with y_buf, 2
    If proc abs_diff_f with y14_0, 3.0 is greater than eps:
        Return 14
    End If
    If proc abs_diff_f with y14_1, 3.0 is greater than eps:
        Return 14
    End If
    If proc abs_diff_f with y14_2, 9.0 is greater than eps:
        Return 14
    End If

    Note: ---- 15: CSC matvec on diag(1,2,3) gives same result as CSR ----
    Let csc be proc sparse_csc_allocate from Sparse with 3, 3, 3
    Let col_ptr_buf be proc memory_get_int64 from Memory with csc, 32
    Let row_idx_buf be proc memory_get_int64 from Memory with csc, 40
    Let val_buf be proc memory_get_int64 from Memory with csc, 48
    Note: col_ptr [0, 1, 2, 3]: each column has exactly one entry.
    Let _wcp0 be proc memory_set_int64 from Memory with col_ptr_buf, 0, 0
    Let _wcp1 be proc memory_set_int64 from Memory with col_ptr_buf, 8, 1
    Let _wcp2 be proc memory_set_int64 from Memory with col_ptr_buf, 16, 2
    Let _wcp3 be proc memory_set_int64 from Memory with col_ptr_buf, 24, 3
    Let _wri0 be proc memory_set_int64 from Memory with row_idx_buf, 0, 0
    Let _wri1 be proc memory_set_int64 from Memory with row_idx_buf, 8, 1
    Let _wri2 be proc memory_set_int64 from Memory with row_idx_buf, 16, 2
    Let _wv0 be proc store_f64_at with val_buf, 0, 1.0
    Let _wv1 be proc store_f64_at with val_buf, 1, 2.0
    Let _wv2 be proc store_f64_at with val_buf, 2, 3.0
    Let _x15_0 be proc store_f64_at with x_buf, 0, 5.0
    Let _x15_1 be proc store_f64_at with x_buf, 1, 7.0
    Let _x15_2 be proc store_f64_at with x_buf, 2, 11.0
    Note: Zero y first
    Let _wy0 be proc store_f64_at with y_buf, 0, 0.0
    Let _wy1 be proc store_f64_at with y_buf, 1, 0.0
    Let _wy2 be proc store_f64_at with y_buf, 2, 0.0
    Let _csm be proc sparse_csc_matvec from Sparse with csc, x_buf, y_buf
    Let yc0 be proc load_f64_at with y_buf, 0
    Let yc1 be proc load_f64_at with y_buf, 1
    Let yc2 be proc load_f64_at with y_buf, 2
    If proc abs_diff_f with yc0, 5.0 is greater than eps:
        Return 15
    End If
    If proc abs_diff_f with yc1, 14.0 is greater than eps:
        Return 15
    End If
    If proc abs_diff_f with yc2, 33.0 is greater than eps:
        Return 15
    End If

    Note: ---- 16: CSR transpose dims swap ----
    Let csr_2x3 be proc sparse_csr_allocate from Sparse with 2, 3, 2
    Let _rp0 be proc sparse_csr_set_row_ptr from Sparse with csr_2x3, 0, 0
    Let _rp1 be proc sparse_csr_set_row_ptr from Sparse with csr_2x3, 1, 1
    Let _rp2 be proc sparse_csr_set_row_ptr from Sparse with csr_2x3, 2, 2
    Let _se0 be proc sparse_csr_set_entry from Sparse with csr_2x3, 0, 2, 7.0
    Let _se1 be proc sparse_csr_set_entry from Sparse with csr_2x3, 1, 0, 9.0
    Let csr_T be proc sparse_csr_transpose from Sparse with csr_2x3
    If csr_T is equal to 0:
        Return 16
    End If
    Let tr be proc memory_get_int64 from Memory with csr_T, 0
    Let tc be proc memory_get_int64 from Memory with csr_T, 8
    If tr is not equal to 3:
        Return 16
    End If
    If tc is not equal to 2:
        Return 16
    End If

    Return 0
End Process
