Note:
Quaternion KAT suite.

Coverage:
  10  allocate, identity, get_w/x/y/z
  11  Hamilton product: i * j = k where i=(0,1,0,0), j=(0,0,1,0), k=(0,0,0,1)
  12  conjugate negates xyz
  13  magnitude of unit quaternion = 1
  14  normalize a non-unit quaternion makes |q|=1
  15  axis-angle round-trip: build q for (axis=z, angle=pi/2), recover same
  16  slerp endpoints: slerp(a,b,0) = a, slerp(a,b,1) = b
  17  nlerp endpoints: nlerp(a,b,0) ~= a (modulo normalization)
  18  rotate_vector: 90deg rotation about z sends (1,0,0) to ~(0,1,0)
  19  Euler -> quat -> Euler round-trip on non-singular angles
:End Note

Import "compiler/frontend/primitives/numeric/extended/quaternion.runa" as Quaternion
Import "compiler/frontend/primitives/numeric/extended/vector.runa" as Vector
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Process called "abs_diff" takes a as Float, b as Float returns Float:
    Let d be a minus b
    If d is less than 0.0:
        Return 0.0 minus d
    End If
    Return d
End Process

Process called "load_f" takes ptr as Integer returns Float:
    Note: Stack: ptr@[rbp-8], bits@[rbp-16], result@[rbp-24].
    Let bits be proc memory_get_int64 from Memory with ptr, 0
    Let result be 0.0
    Inline Assembly:
        mov rax, qword ptr [rbp-16]
        mov qword ptr [rbp-24], rax
    End Assembly
    Return result
End Process

Process called "bits_to_float_local" takes b as Integer returns Float:
    Let result be 0.0
    Inline Assembly:
        mov rax, qword ptr [rbp-8]
        mov qword ptr [rbp-16], rax
    End Assembly
    Return result
End Process

Process called "main" returns Integer:
    Let eps be 0.0000000001
    Let bigger_eps be 0.00001

    Note: ------ Case 10: allocate / identity ------
    Let q be proc quaternion_allocate from Quaternion
    If q is equal to 0:
        Return 10
    End If
    Let _i be proc quaternion_identity from Quaternion with q
    Let w be proc quaternion_get_w from Quaternion with q
    Let x be proc quaternion_get_x from Quaternion with q
    Let y be proc quaternion_get_y from Quaternion with q
    Let z be proc quaternion_get_z from Quaternion with q
    If proc abs_diff with w, 1.0 is greater than eps:
        Return 10
    End If
    If proc abs_diff with x, 0.0 is greater than eps:
        Return 10
    End If
    If proc abs_diff with y, 0.0 is greater than eps:
        Return 10
    End If
    If proc abs_diff with z, 0.0 is greater than eps:
        Return 10
    End If

    Note: ------ Case 11: i * j = k ------
    Let qi be proc quaternion_allocate from Quaternion
    Let qj be proc quaternion_allocate from Quaternion
    Let qk be proc quaternion_allocate from Quaternion
    Let _si be proc quaternion_set from Quaternion with qi, 0.0, 1.0, 0.0, 0.0
    Let _sj be proc quaternion_set from Quaternion with qj, 0.0, 0.0, 1.0, 0.0
    Let _mij be proc quaternion_mul from Quaternion with qi, qj, qk
    Let mw be proc quaternion_get_w from Quaternion with qk
    Let mx be proc quaternion_get_x from Quaternion with qk
    Let my be proc quaternion_get_y from Quaternion with qk
    Let mz be proc quaternion_get_z from Quaternion with qk
    If proc abs_diff with mw, 0.0 is greater than eps:
        Return 11
    End If
    If proc abs_diff with mx, 0.0 is greater than eps:
        Return 11
    End If
    If proc abs_diff with my, 0.0 is greater than eps:
        Return 11
    End If
    If proc abs_diff with mz, 1.0 is greater than eps:
        Return 11
    End If

    Note: ------ Case 12: conjugate negates xyz ------
    Let qc be proc quaternion_allocate from Quaternion
    Let _sa be proc quaternion_set from Quaternion with q, 1.0, 2.0, 3.0, 4.0
    Let _cj be proc quaternion_conjugate from Quaternion with q, qc
    Let cw be proc quaternion_get_w from Quaternion with qc
    Let cx be proc quaternion_get_x from Quaternion with qc
    Let cy be proc quaternion_get_y from Quaternion with qc
    Let cz be proc quaternion_get_z from Quaternion with qc
    Let neg2 be 0.0 minus 2.0
    Let neg3 be 0.0 minus 3.0
    Let neg4 be 0.0 minus 4.0
    If proc abs_diff with cw, 1.0 is greater than eps:
        Return 12
    End If
    If proc abs_diff with cx, neg2 is greater than eps:
        Return 12
    End If
    If proc abs_diff with cy, neg3 is greater than eps:
        Return 12
    End If
    If proc abs_diff with cz, neg4 is greater than eps:
        Return 12
    End If

    Note: ------ Case 13: magnitude of unit q ------
    Let _qu be proc quaternion_set from Quaternion with q, 1.0, 0.0, 0.0, 0.0
    Let mag1 be proc quaternion_magnitude from Quaternion with q
    If proc abs_diff with mag1, 1.0 is greater than eps:
        Return 13
    End If

    Note: ------ Case 14: normalize ------
    Let qn be proc quaternion_allocate from Quaternion
    Let _ss be proc quaternion_set from Quaternion with q, 3.0, 4.0, 0.0, 0.0
    Let _nn be proc quaternion_normalize from Quaternion with q, qn
    Let mag_n be proc quaternion_magnitude from Quaternion with qn
    If proc abs_diff with mag_n, 1.0 is greater than bigger_eps:
        Return 14
    End If

    Note: ------ Case 15: axis-angle round-trip ------
    Let axis be proc vector3_allocate from Vector
    Let _ax be proc vector3_set from Vector with axis, 0.0, 0.0, 1.0
    Let half_pi be 1.5707963267948966
    Let _fa be proc quaternion_from_axis_angle from Quaternion with q, axis, half_pi
    Let axis_out be proc vector3_allocate from Vector
    Let angle_out_buf be proc vector3_allocate from Vector
    Let _ta be proc quaternion_to_axis_angle from Quaternion with q, axis_out, angle_out_buf
    Let ang_bits be proc memory_get_int64 from Memory with angle_out_buf, 0
    Let recovered_angle be proc bits_to_float_local with ang_bits
    If proc abs_diff with recovered_angle, half_pi is greater than bigger_eps:
        Return 15
    End If
    Let azx be proc vector3_get_x from Vector with axis_out
    Let azy be proc vector3_get_y from Vector with axis_out
    Let azz be proc vector3_get_z from Vector with axis_out
    If proc abs_diff with azx, 0.0 is greater than bigger_eps:
        Return 15
    End If
    If proc abs_diff with azy, 0.0 is greater than bigger_eps:
        Return 15
    End If
    If proc abs_diff with azz, 1.0 is greater than bigger_eps:
        Return 15
    End If

    Note: ------ Case 16: slerp endpoints ------
    Let qa be proc quaternion_allocate from Quaternion
    Let qb be proc quaternion_allocate from Quaternion
    Let qr be proc quaternion_allocate from Quaternion
    Let _qa be proc quaternion_set from Quaternion with qa, 1.0, 0.0, 0.0, 0.0
    Let _qb be proc quaternion_from_axis_angle from Quaternion with qb, axis, half_pi
    Let _sl0 be proc quaternion_slerp from Quaternion with qa, qb, 0.0, qr
    Let s0w be proc quaternion_get_w from Quaternion with qr
    Let s0z be proc quaternion_get_z from Quaternion with qr
    If proc abs_diff with s0w, 1.0 is greater than bigger_eps:
        Return 16
    End If
    If proc abs_diff with s0z, 0.0 is greater than bigger_eps:
        Return 16
    End If
    Let _sl1 be proc quaternion_slerp from Quaternion with qa, qb, 1.0, qr
    Let s1z be proc quaternion_get_z from Quaternion with qr
    Let expected_qb_z be proc quaternion_get_z from Quaternion with qb
    If proc abs_diff with s1z, expected_qb_z is greater than bigger_eps:
        Return 16
    End If

    Note: ------ Case 17: nlerp endpoints (within bigger_eps for normalize) ------
    Let _nl0 be proc quaternion_nlerp from Quaternion with qa, qb, 0.0, qr
    Let n0w be proc quaternion_get_w from Quaternion with qr
    If proc abs_diff with n0w, 1.0 is greater than bigger_eps:
        Return 17
    End If

    Note: ------ Case 18: rotate (1,0,0) by 90deg about z = (0,1,0) ------
    Let v_in be proc vector3_allocate from Vector
    Let v_out be proc vector3_allocate from Vector
    Let _vi be proc vector3_set from Vector with v_in, 1.0, 0.0, 0.0
    Let _qz be proc quaternion_from_axis_angle from Quaternion with q, axis, half_pi
    Let _rv be proc quaternion_rotate_vector from Quaternion with q, v_in, v_out
    Let ox be proc vector3_get_x from Vector with v_out
    Let oy be proc vector3_get_y from Vector with v_out
    Let oz be proc vector3_get_z from Vector with v_out
    If proc abs_diff with ox, 0.0 is greater than bigger_eps:
        Return 18
    End If
    If proc abs_diff with oy, 1.0 is greater than bigger_eps:
        Return 18
    End If
    If proc abs_diff with oz, 0.0 is greater than bigger_eps:
        Return 18
    End If

    Note: ------ Case 19: Euler -> quat -> Euler round-trip ------
    Note: Use small angles to avoid singularity: roll=0.1, pitch=0.2, yaw=0.3
    Let _fe be proc quaternion_from_euler from Quaternion with q, 0.1, 0.2, 0.3
    Let roll_out be proc vector3_allocate from Vector
    Let pitch_out be proc vector3_allocate from Vector
    Let yaw_out be proc vector3_allocate from Vector
    Let _te be proc quaternion_to_euler from Quaternion with q, roll_out, pitch_out, yaw_out
    Let roll_b be proc memory_get_int64 from Memory with roll_out, 0
    Let pitch_b be proc memory_get_int64 from Memory with pitch_out, 0
    Let yaw_b be proc memory_get_int64 from Memory with yaw_out, 0
    Let rr be proc bits_to_float_local with roll_b
    Let pp be proc bits_to_float_local with pitch_b
    Let yy be proc bits_to_float_local with yaw_b
    Let euler_eps be 0.0001
    If proc abs_diff with rr, 0.1 is greater than euler_eps:
        Return 19
    End If
    If proc abs_diff with pp, 0.2 is greater than euler_eps:
        Return 19
    End If
    If proc abs_diff with yy, 0.3 is greater than euler_eps:
        Return 19
    End If

    Return 0
End Process
