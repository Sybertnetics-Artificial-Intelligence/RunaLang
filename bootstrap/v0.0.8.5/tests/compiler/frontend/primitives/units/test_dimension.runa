Note:
KAT for compiler/frontend/primitives/units/dimension.runa.

Verifies:
  - Dimensional algebra: length * time = length*time
  - Dimension power: length^3 = volume
  - Dimensional equality and inequality
  - Dimensionless detection
  - Negative exponent encoding (1/time = frequency)
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/units/dimension.runa" as D

Process called "test_base_axes_distinct" takes results as Integer returns Integer:
    T.begin_suite(results, "dimension.base_axes_distinct")

    Let L be proc dimension_length from D
    Let M be proc dimension_mass from D
    Let Time be proc dimension_time from D

    T.assert_equal(results, "L = L", (proc dim_eq from D with L, L), 1)
    T.assert_equal(results, "L != M", (proc dim_eq from D with L, M), 0)
    T.assert_equal(results, "L != T", (proc dim_eq from D with L, Time), 0)

    Return 1
End Process

Process called "test_dimensionless" takes results as Integer returns Integer:
    T.begin_suite(results, "dimension.dimensionless")

    Let zero be proc dimension_dimensionless from D
    T.assert_equal(results, "0 dim is dimensionless", (proc dim_is_dimensionless from D with zero),1)

    Let L be proc dimension_length from D
    T.assert_equal(results, "L not dimensionless", (proc dim_is_dimensionless from D with L),0)

    Return 1
End Process

Process called "test_algebra_mul_div" takes results as Integer returns Integer:
    T.begin_suite(results, "dimension.algebra_mul_div")

    Let L be proc dimension_length from D
    Let Time be proc dimension_time from D
    Let L_per_T be proc dim_div from D with L, Time

    Note: L_per_T exponents: L=1, T=-1
    T.assert_equal(results, "(L/T).L = 1", (proc dim_get_length from D with L_per_T),1)
    T.assert_equal(results, "(L/T).T = -1", (proc dim_get_time from D with L_per_T),0 minus 1)
    T.assert_equal(results, "(L/T).M = 0", (proc dim_get_mass from D with L_per_T),0)

    Note: (L/T) * T = L
    Let back_to_L be proc dim_mul from D with L_per_T, Time
    T.assert_equal(results, "(L/T) * T = L", (proc dim_eq from D with back_to_L, L), 1)

    Return 1
End Process

Process called "test_pow" takes results as Integer returns Integer:
    T.begin_suite(results, "dimension.pow")

    Let L be proc dimension_length from D
    Let L3 be proc dim_pow from D with L, 3
    Let volume be proc dim_create from D with 3, 0, 0, 0, 0, 0, 0
    T.assert_equal(results, "L^3 = volume", (proc dim_eq from D with L3, volume), 1)

    Let inv_T be proc dim_pow from D with (proc dimension_time from D), 0 minus 1
    T.assert_equal(results, "(T)^-1 .T = -1", (proc dim_get_time from D with inv_T),0 minus 1)

    Return 1
End Process

Process called "test_inverse" takes results as Integer returns Integer:
    T.begin_suite(results, "dimension.inverse")

    Note: inverse(force_dim) gives (-1, -1, 2, 0, 0, 0, 0)
    Let force_dim be proc dim_create from D with 1, 1, 0 minus 2, 0, 0, 0, 0
    Let inv_force be proc dim_inverse from D with force_dim
    T.assert_equal(results, "inv(F).L = -1", (proc dim_get_length from D with inv_force),0 minus 1)
    T.assert_equal(results, "inv(F).M = -1", (proc dim_get_mass from D with inv_force),0 minus 1)
    T.assert_equal(results, "inv(F).T = +2", (proc dim_get_time from D with inv_force),2)

    Note: inverse(inverse(x)) = x
    Let inv_inv be proc dim_inverse from D with inv_force
    T.assert_equal(results, "inv(inv(F)) = F", (proc dim_eq from D with inv_inv, force_dim), 1)

    Return 1
End Process

Process called "test_compatibility" takes results as Integer returns Integer:
    T.begin_suite(results, "dimension.is_compatible")

    Let L1 be proc dimension_length from D
    Let L2 be proc dimension_length from D
    T.assert_equal(results, "L compat L", (proc dim_is_compatible from D with L1, L2), 1)

    Let M be proc dimension_mass from D
    T.assert_equal(results, "L not compat M", (proc dim_is_compatible from D with L1, M), 0)

    Return 1
End Process

Process called "test_signed_byte_round_trip" takes results as Integer returns Integer:
    T.begin_suite(results, "dimension.signed_byte_round_trip")

    Note: dim_create with negative exponents should round-trip via accessors
    Let dim be proc dim_create from D with 0 minus 3, 2, 0 minus 1, 0, 0, 0, 0
    T.assert_equal(results, "L = -3", (proc dim_get_length from D with dim),0 minus 3)
    T.assert_equal(results, "M = +2", (proc dim_get_mass from D with dim),2)
    T.assert_equal(results, "T = -1", (proc dim_get_time from D with dim),0 minus 1)
    T.assert_equal(results, "I = 0", (proc dim_get_current from D with dim),0)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_base_axes_distinct(results)
    test_dimensionless(results)
    test_algebra_mul_div(results)
    test_pow(results)
    test_inverse(results)
    test_compatibility(results)
    test_signed_byte_round_trip(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
