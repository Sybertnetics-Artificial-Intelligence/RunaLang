Note:
KAT for compiler/frontend/primitives/units/physical_constants.runa.

Verifies:
  - SI 2019 defining exact constants reproduce their literal values
  - Derived constants (R = N_A * k, F = N_A * e) are computed correctly
  - Standard gravity 9.80665 m/s^2 (exact)
  - Quantity-typed constants have the expected dimensions
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/units/physical_constants.runa" as PC
Import "compiler/frontend/primitives/units/quantity.runa" as Q
Import "compiler/frontend/primitives/units/dimension.runa" as D
Import "compiler/frontend/primitives/units/unit.runa" as U
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Note: Use a small epsilon (1e-9) to nudge values that fall just barely
    Note: under an integer boundary. Half-up rounding caused other
    Note: less-than-N assertions to flip the wrong way, so the bias here is
    Note: small enough to recover representation error without affecting
    Note: ordering against integer-quantum thresholds.
    Let scaled be f multiplied by scale
    If scaled is greater than or equal to 0.0:
        Set scaled to scaled plus 0.000000001
    End If
    Return proc float_to_int from Arith with scaled
End Process

Process called "test_si_exact" takes results as Integer returns Integer:
    T.begin_suite(results, "constants.si_exact")

    Note: c = 299792458 m/s
    T.assert_equal(results, "c = 299792458", float_to_scaled_int((proc speed_of_light_c_si from PC), 1.0), 299792458)
    Note: cesium hyperfine = 9192631770 Hz
    T.assert_equal(results, "Cs freq = 9192631770", float_to_scaled_int((proc cesium_hyperfine_freq_si from PC), 1.0), 9192631770)
    Note: K_cd = 683 lm/W
    T.assert_equal(results, "K_cd = 683", float_to_scaled_int((proc luminous_efficacy_Kcd_si from PC), 1.0), 683)
    Note: standard gravity = 9.80665 m/s^2 (exact)
    T.assert_equal(results, "g_n * 100000", float_to_scaled_int((proc standard_gravity_g_si from PC), 100000.0), 980665)

    Return 1
End Process

Process called "test_derived" takes results as Integer returns Integer:
    T.begin_suite(results, "constants.derived")

    Note: R = N_A * k ~ 8.31446
    Let R be proc molar_gas_constant_R_si from PC
    T.assert_equal(results, "R * 100000 ~ 831446", float_to_scaled_int(R, 100000.0), 831446)

    Note: F = N_A * e ~ 96485.33 C/mol
    Let F be proc faraday_F_si from PC
    T.assert_equal(results, "F ~ 96485", float_to_scaled_int(F, 1.0), 96485)

    Note: hbar = h / (2*pi) ~ 1.054571817e-34.  Scale by 1e37 so the integer
    Note: representation lands at 1054 (epsilon-biased truncation) and pin the
    Note: bounds at (1053, 1056) so the inequality clears the integer boundary
    Note: in both directions.
    Let hbar be proc hbar_si from PC
    T.assert_greater_than(results, "hbar*1e37 > 1053", float_to_scaled_int(hbar, 1.0e37), 1053)
    T.assert_less_than(results, "hbar*1e37 < 1056", float_to_scaled_int(hbar, 1.0e37), 1056)

    Return 1
End Process

Process called "test_measured" takes results as Integer returns Integer:
    T.begin_suite(results, "constants.measured")

    Note: G ~ 6.6743e-11
    Let G be proc gravitational_G_si from PC
    T.assert_equal(results, "G * 1e16 ~ 667430", float_to_scaled_int(G, 1.0e16), 667430)

    Note: electron mass ~ 9.109e-31 kg
    Let me_val be proc electron_mass_me_si from PC
    T.assert_greater_than(results, "m_e * 1e35 > 91093", float_to_scaled_int(me_val, 1.0e35), 91092)
    T.assert_less_than(results, "m_e * 1e35 < 91094", float_to_scaled_int(me_val, 1.0e35), 91094)

    Note: proton/electron mass ratio ~ 1836
    Let mp_val be proc proton_mass_mp_si from PC
    Let ratio be mp_val divided by me_val
    T.assert_equal(results, "m_p/m_e ~ 1836", (proc float_to_int from Arith with ratio), 1836)

    Return 1
End Process

Process called "test_quantity_form" takes results as Integer returns Integer:
    T.begin_suite(results, "constants.quantity_form")

    Note: c-quantity has dimension m/s i.e. (1, 0, -1, 0, 0, 0, 0)
    Let c_q be proc speed_of_light_c_quantity from PC
    Let speed_dim be proc dim_create from D with 1, 0, 0 minus 1, 0, 0, 0, 0
    T.assert_equal(results, "c-qty has m/s dim", (proc dim_eq from D with (proc quantity_dimension from Q with c_q), speed_dim), 1)
    T.assert_equal(results, "c-qty value = c", float_to_scaled_int((proc quantity_value_si from Q with c_q), 1.0), 299792458)

    Note: g-quantity has dimension m/s^2
    Let g_q be proc standard_gravity_g_quantity from PC
    Let accel_dim be proc dim_create from D with 1, 0, 0 minus 2, 0, 0, 0, 0
    T.assert_equal(results, "g-qty has m/s^2 dim", (proc dim_eq from D with (proc quantity_dimension from Q with g_q), accel_dim), 1)

    Note: G-quantity has dimension m^3/(kg*s^2) = (3, -1, -2, 0, 0, 0, 0)
    Let G_q be proc gravitational_G_quantity from PC
    Let G_dim be proc dim_create from D with 3, 0 minus 1, 0 minus 2, 0, 0, 0, 0
    T.assert_equal(results, "G-qty has m^3/(kg*s^2) dim", (proc dim_eq from D with (proc quantity_dimension from Q with G_q), G_dim), 1)

    Return 1
End Process

Process called "test_vacuum_constants" takes results as Integer returns Integer:
    T.begin_suite(results, "constants.vacuum")

    Note: epsilon_0 ~ 8.8541878128e-12
    Let eps0 be proc vacuum_permittivity_epsilon0_si from PC
    T.assert_greater_than(results, "eps0 * 1e16 > 88541", float_to_scaled_int(eps0, 1.0e16), 88540)
    T.assert_less_than(results, "eps0 * 1e16 < 88543", float_to_scaled_int(eps0, 1.0e16), 88543)

    Note: mu_0 ~ 1.25663706212e-6
    Let mu0 be proc vacuum_permeability_mu0_si from PC
    T.assert_greater_than(results, "mu0 * 1e11 > 125663", float_to_scaled_int(mu0, 1.0e11), 125662)

    Note: Z_0 ~ 376.73 ohms.  Scale by 100 to preserve sub-ohm precision so
    Note: the inequality is not pinned to the integer boundary at 376; the
    Note: assertion checks Z_0 > 376 and Z_0 < 378 in fixed-point cents-of-ohm.
    Let Z0 be proc vacuum_impedance_Z0_si from PC
    T.assert_greater_than(results, "Z_0 * 100 > 37600", float_to_scaled_int(Z0, 100.0), 37600)
    T.assert_less_than(results, "Z_0 * 100 < 37800", float_to_scaled_int(Z0, 100.0), 37800)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_si_exact(results)
    test_derived(results)
    test_measured(results)
    test_quantity_form(results)
    test_vacuum_constants(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
