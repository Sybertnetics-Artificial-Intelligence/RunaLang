Note:
KAT for compiler/frontend/primitives/units/quantity.runa.

Verifies:
  - Construction from value + unit tag yields the correct SI value
  - Dimensional algebra: F = m*a produces a Quantity with the newton dimension
  - Convert between units of the same dimension (m -> ft)
  - Cross-dimensional addition fails (returns sentinel)
  - Power operation scales the dimension and the value
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/units/quantity.runa" as Q
Import "compiler/frontend/primitives/units/unit.runa" as U
Import "compiler/frontend/primitives/units/dimension.runa" as D
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "approx_equal" takes a as Float, b as Float, tolerance as Float returns Integer:
    Let diff be a minus b
    If diff is less than 0.0:
        Set diff to 0.0 minus diff
    End If
    If diff is less than tolerance:
        Return 1
    End If
    Return 0
End Process

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let scaled be f multiplied by scale
    Return proc float_to_int from Arith with scaled
End Process

Process called "test_construction" takes results as Integer returns Integer:
    T.begin_suite(results, "quantity.construction")

    Let q_m be proc quantity_meters from Q with 5.0
    T.assert_equal(results, "5 m SI value = 5", float_to_scaled_int(proc quantity_value_si from Q with q_m, 1.0), 5)

    Let q_ft be proc quantity_create from Q with 1.0, (proc unit_tag_foot from U)
    Note: 1 ft = 0.3048 m
    T.assert_equal(results, "1 ft -> 0.3048 m * 10000", float_to_scaled_int(proc quantity_value_si from Q with q_ft, 10000.0), 3048)

    Let q_lb be proc quantity_create from Q with 1.0, (proc unit_tag_pound from U)
    Note: 1 lb = 0.45359237 kg
    T.assert_equal(results, "1 lb -> 0.45359237 kg * 100000", float_to_scaled_int(proc quantity_value_si from Q with q_lb, 100000.0), 45359)

    Return 1
End Process

Process called "test_dimensional_algebra" takes results as Integer returns Integer:
    T.begin_suite(results, "quantity.dimensional_algebra")

    Note: F = m * a; 2 kg * 9.80665 m/s^2 = 19.6133 N
    Let mass be proc quantity_kilograms from Q with 2.0
    Let accel_qty be a value of type Quantity
    Set accel_qty.value to 9.80665
    Set accel_qty.dimension to proc dim_create from D with 1, 0, 0 minus 2, 0, 0, 0, 0
    Set accel_qty.unit_tag to proc unit_tag_composite from U
    Let force be proc quantity_mul from Q with mass, accel_qty

    Note: Force should have newton dimension
    Let newton_dim be proc dim_create from D with 1, 1, 0 minus 2, 0, 0, 0, 0
    T.assert_equal(results, "F dim = newton", proc dim_eq from D with (proc quantity_dimension from Q with force), newton_dim, 1)
    T.assert_equal(results, "F value ~ 19.6133", float_to_scaled_int(proc quantity_value_si from Q with force, 10000.0), 196133)

    Return 1
End Process

Process called "test_add_compatible" takes results as Integer returns Integer:
    T.begin_suite(results, "quantity.add_compatible")

    Let a be proc quantity_meters from Q with 5.0
    Let b be proc quantity_create from Q with 3.0, (proc unit_tag_foot from U)
    Note: 5 m + 3 ft = 5 + 0.9144 = 5.9144 m
    Let sum be proc quantity_add from Q with a, b
    T.assert_equal(results, "5 m + 3 ft = 5.9144 m * 10000", float_to_scaled_int(proc quantity_value_si from Q with sum, 10000.0), 59144)

    Return 1
End Process

Process called "test_add_incompatible" takes results as Integer returns Integer:
    T.begin_suite(results, "quantity.add_incompatible_returns_error")

    Let a be proc quantity_meters from Q with 5.0
    Let b be proc quantity_kilograms from Q with 3.0
    Let sum be proc quantity_add from Q with a, b
    Note: Dimension mismatch returns the error sentinel (NaN value + tag_error).
    T.assert_equal(results, "m + kg -> is_error", proc quantity_is_error from Q with sum, 1)
    Note: A legitimate same-dimension add is NOT flagged as error.
    Let c be proc quantity_meters from Q with 4.0
    Let good_sum be proc quantity_add from Q with a, c
    T.assert_equal(results, "m + m -> not_error", proc quantity_is_error from Q with good_sum, 0)
    T.assert_equal(results, "m + m value = 9", float_to_scaled_int(proc quantity_value_si from Q with good_sum, 1.0), 9)

    Return 1
End Process

Process called "test_error_propagation" takes results as Integer returns Integer:
    T.begin_suite(results, "quantity.error_propagation")

    Note: Once an error sentinel exists it propagates through any further arithmetic.
    Let a be proc quantity_meters from Q with 5.0
    Let b be proc quantity_kilograms from Q with 3.0
    Let err be proc quantity_add from Q with a, b
    T.assert_equal(results, "err is_error", proc quantity_is_error from Q with err, 1)

    Note: add(err, m) -> error
    Let m_qty be proc quantity_meters from Q with 2.0
    Let r1 be proc quantity_add from Q with err, m_qty
    T.assert_equal(results, "err + m propagates", proc quantity_is_error from Q with r1, 1)

    Note: sub(m, err) -> error
    Let r2 be proc quantity_sub from Q with m_qty, err
    T.assert_equal(results, "m - err propagates", proc quantity_is_error from Q with r2, 1)

    Note: mul(err, m) -> error
    Let r3 be proc quantity_mul from Q with err, m_qty
    T.assert_equal(results, "err * m propagates", proc quantity_is_error from Q with r3, 1)

    Note: div(err, m) -> error
    Let r4 be proc quantity_div from Q with err, m_qty
    T.assert_equal(results, "err / m propagates", proc quantity_is_error from Q with r4, 1)

    Note: pow(err, 2) -> error
    Let r5 be proc quantity_pow from Q with err, 2
    T.assert_equal(results, "err^2 propagates", proc quantity_is_error from Q with r5, 1)

    Return 1
End Process

Process called "test_sub_incompatible" takes results as Integer returns Integer:
    T.begin_suite(results, "quantity.sub_incompatible_returns_error")

    Let a be proc quantity_meters from Q with 5.0
    Let b be proc quantity_kilograms from Q with 3.0
    Let diff be proc quantity_sub from Q with a, b
    T.assert_equal(results, "m - kg -> is_error", proc quantity_is_error from Q with diff, 1)

    Return 1
End Process

Process called "test_convert_to" takes results as Integer returns Integer:
    T.begin_suite(results, "quantity.convert_to")

    Note: 100 m -> ft
    Let q_m be proc quantity_meters from Q with 100.0
    Let q_ft be proc quantity_convert_to from Q with q_m, (proc unit_tag_foot from U)
    Note: SI value preserved
    T.assert_equal(results, "convert preserves SI", float_to_scaled_int(proc quantity_value_si from Q with q_ft, 1.0), 100)
    Note: value_in feet = 100 / 0.3048 ~ 328.084
    Let in_ft be proc quantity_value_in from Q with q_ft, (proc unit_tag_foot from U)
    T.assert_equal(results, "100 m in ft ~ 328", float_to_scaled_int(in_ft, 1.0), 328)

    Note: Convert mismatched dimensions yields zero-quantity
    Let q_km be proc quantity_meters from Q with 1000.0
    Let bad be proc quantity_convert_to from Q with q_km, (proc unit_tag_kilogram from U)
    T.assert_equal(results, "m -> kg fails to zero", float_to_scaled_int(proc quantity_value_si from Q with bad, 1.0), 0)

    Return 1
End Process

Process called "test_power" takes results as Integer returns Integer:
    T.begin_suite(results, "quantity.power")

    Note: 3 m ^ 2 = 9 m^2
    Let q3m be proc quantity_meters from Q with 3.0
    Let q9 be proc quantity_pow from Q with q3m, 2
    T.assert_equal(results, "(3 m)^2 value = 9", float_to_scaled_int(proc quantity_value_si from Q with q9, 1.0), 9)
    Let area_dim be proc dim_create from D with 2, 0, 0, 0, 0, 0, 0
    T.assert_equal(results, "(3 m)^2 dim = m^2", proc dim_eq from D with (proc quantity_dimension from Q with q9), area_dim, 1)

    Note: (2 s)^-1 = 0.5 / s -> 0.5 Hz
    Let q2s be proc quantity_seconds from Q with 2.0
    Let q_inv be proc quantity_pow from Q with q2s, 0 minus 1
    T.assert_equal(results, "(2 s)^-1 value = 0.5", float_to_scaled_int(proc quantity_value_si from Q with q_inv, 100.0), 50)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_construction(results)
    test_dimensional_algebra(results)
    test_add_compatible(results)
    test_add_incompatible(results)
    test_sub_incompatible(results)
    test_error_propagation(results)
    test_convert_to(results)
    test_power(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
