Note:
KAT for compiler/frontend/primitives/units/unit.runa.

Verifies:
  - Each base unit has the right dimension and scale 1.0
  - US gallon != UK gallon
  - SI prefixes have the right scale
  - Imperial scales: 1 mi = 1609.344 m, 1 lb = 0.45359237 kg
  - Pressure scales: 1 atm = 101325 Pa
  - Energy scales: 1 cal = 4.184 J
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/units/unit.runa" as U
Import "compiler/frontend/primitives/units/dimension.runa" as D
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "float_to_scaled_int" takes f as Float, scale as Float returns Integer:
    Let scaled be f multiplied by scale
    Return proc float_to_int from Arith with scaled
End Process

Process called "test_base_dimensions" takes results as Integer returns Integer:
    T.begin_suite(results, "unit.base_dimensions")

    Let length be proc dimension_length from D
    T.assert_equal(results, "meter dim = length", proc dim_eq from D with (proc unit_get_dimension from U with (proc unit_tag_meter from U)), length, 1)

    Let mass be proc dimension_mass from D
    T.assert_equal(results, "kilogram dim = mass", proc dim_eq from D with (proc unit_get_dimension from U with (proc unit_tag_kilogram from U)), mass, 1)

    Let time be proc dimension_time from D
    T.assert_equal(results, "second dim = time", proc dim_eq from D with (proc unit_get_dimension from U with (proc unit_tag_second from U)), time, 1)

    Return 1
End Process

Process called "test_imperial_scales" takes results as Integer returns Integer:
    T.begin_suite(results, "unit.imperial_scales")

    Note: 1 mi = 1609.344 m
    T.assert_equal(results, "mi scale * 1000", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_mile from U), 1000.0), 1609344)
    Note: 1 ft = 0.3048 m
    T.assert_equal(results, "ft scale * 10000", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_foot from U), 10000.0), 3048)
    Note: 1 in = 0.0254 m
    T.assert_equal(results, "in scale * 100000", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_inch from U), 100000.0), 2540)
    Note: 1 lb = 0.45359237 kg
    T.assert_equal(results, "lb scale * 100000", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_pound from U), 100000.0), 45359)
    Note: 1 oz = 0.028349523 kg
    T.assert_equal(results, "oz scale * 1000000", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_ounce from U), 1000000.0), 28349)

    Return 1
End Process

Process called "test_gallon_us_uk_differ" takes results as Integer returns Integer:
    T.begin_suite(results, "unit.gallon_us_vs_uk")

    Let us_gal be proc unit_get_scale_to_si from U with (proc unit_tag_gallon_us from U)
    Let uk_gal be proc unit_get_scale_to_si from U with (proc unit_tag_gallon_uk from U)
    Note: US gallon = 3.785411784 L, UK gallon = 4.54609 L
    T.assert_equal(results, "US gal != UK gal", float_to_scaled_int(us_gal, 1.0e9), 3785411)
    T.assert_equal(results, "UK gal scale * 1e6", float_to_scaled_int(uk_gal, 1.0e6), 4546)
    Note: They MUST differ
    T.assert_not_equal(results, "scales differ", float_to_scaled_int(us_gal, 1.0e9), float_to_scaled_int(uk_gal, 1.0e9))

    Return 1
End Process

Process called "test_pressure_scales" takes results as Integer returns Integer:
    T.begin_suite(results, "unit.pressure_scales")

    Note: 1 atm = 101325 Pa
    T.assert_equal(results, "atm = 101325 Pa", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_atmosphere from U), 1.0), 101325)
    Note: 1 bar = 100000 Pa
    T.assert_equal(results, "bar = 100000 Pa", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_bar from U), 1.0), 100000)

    Return 1
End Process

Process called "test_energy_scales" takes results as Integer returns Integer:
    T.begin_suite(results, "unit.energy_scales")

    Note: 1 cal = 4.184 J
    T.assert_equal(results, "cal = 4.184 J * 1000", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_calorie from U), 1000.0), 4184)
    Note: 1 kcal = 4184 J
    T.assert_equal(results, "kcal = 4184 J", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_kilocalorie from U), 1.0), 4184)
    Note: 1 kWh = 3.6e6 J
    T.assert_equal(results, "kWh = 3.6e6 J", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_kilowatt_hour from U), 1.0), 3600000)

    Return 1
End Process

Process called "test_si_prefixes" takes results as Integer returns Integer:
    T.begin_suite(results, "unit.si_prefixes")

    Note: kilo = 1000
    T.assert_equal(results, "kilo = 1000", float_to_scaled_int(proc unit_prefix_scale from U with (proc prefix_id_kilo from U), 1.0), 1000)
    Note: mega = 1e6
    T.assert_equal(results, "mega = 1e6", float_to_scaled_int(proc unit_prefix_scale from U with (proc prefix_id_mega from U), 1.0), 1000000)
    Note: milli = 0.001
    T.assert_equal(results, "milli = 0.001 * 1000", float_to_scaled_int(proc unit_prefix_scale from U with (proc prefix_id_milli from U), 1000.0), 1)
    Note: centi = 0.01
    T.assert_equal(results, "centi = 0.01 * 100", float_to_scaled_int(proc unit_prefix_scale from U with (proc prefix_id_centi from U), 100.0), 1)

    Return 1
End Process

Process called "test_time_scales" takes results as Integer returns Integer:
    T.begin_suite(results, "unit.time_scales")

    T.assert_equal(results, "min = 60", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_minute from U), 1.0), 60)
    T.assert_equal(results, "hour = 3600", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_hour from U), 1.0), 3600)
    T.assert_equal(results, "day = 86400", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_day from U), 1.0), 86400)
    T.assert_equal(results, "week = 604800", float_to_scaled_int(proc unit_get_scale_to_si from U with (proc unit_tag_week from U), 1.0), 604800)

    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_base_dimensions(results)
    test_imperial_scales(results)
    test_gallon_us_uk_differ(results)
    test_pressure_scales(results)
    test_energy_scales(results)
    test_si_prefixes(results)
    test_time_scales(results)
    T.print_summary(results)
    Let ec be T.get_failed(results)
    T.destroy_test_results(results)
    Return ec
End Process
