Note:
Unit tests for compiler/frontend/primitives/concurrency/channel.runa.

These exercise lifecycle, ordering, bounded/unbounded semantics,
non-blocking try variants and the closed-channel state machine. The
stage1 single-threaded harness is enough to validate FIFO and
backpressure invariants because the channel guarantees them on the
slow path under lock.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/concurrency/channel.runa" as C

Process called "test_channel_create_destroy" that takes results as Integer returns Integer:
    T.begin_suite(results, "channel.create_destroy")
    Let ch be C.channel_create(0)
    T.assert_not_null(results, "unbounded channel allocated", ch)
    T.assert_equal(results, "capacity 0 reported", C.channel_capacity(ch), 0)
    T.assert_equal(results, "freshly created channel is empty", C.channel_is_empty(ch), 1)
    T.assert_equal(results, "freshly created channel is not closed", C.channel_is_closed(ch), 0)
    Let rc be C.channel_destroy(ch)
    T.assert_equal(results, "destroy returns OK", rc, 1)
    Return 1
End Process

Process called "test_channel_bounded_capacity" that takes results as Integer returns Integer:
    T.begin_suite(results, "channel.bounded_capacity")
    Let ch be C.channel_create(2)
    T.assert_equal(results, "capacity is 2", C.channel_capacity(ch), 2)

    Let rc1 be C.channel_try_send(ch, 100)
    Let rc2 be C.channel_try_send(ch, 200)
    Let rc3 be C.channel_try_send(ch, 300)

    T.assert_equal(results, "first try_send accepted", rc1, 1)
    T.assert_equal(results, "second try_send accepted", rc2, 1)
    T.assert_equal(results, "third try_send rejected", rc3, -1)
    T.assert_equal(results, "length is 2", C.channel_length(ch), 2)

    C.channel_destroy(ch)
    Return 1
End Process

Process called "test_channel_send_recv_ordering" that takes results as Integer returns Integer:
    T.begin_suite(results, "channel.fifo_ordering")
    Let ch be C.channel_create(4)
    Let out_holder be allocate(8)

    C.channel_send(ch, 1)
    C.channel_send(ch, 2)
    C.channel_send(ch, 3)

    __store(out_holder, 0, 0)
    C.channel_receive(ch, out_holder)
    T.assert_equal(results, "first dequeue returns 1", __load(out_holder, 0), 1)

    __store(out_holder, 0, 0)
    C.channel_receive(ch, out_holder)
    T.assert_equal(results, "second dequeue returns 2", __load(out_holder, 0), 2)

    __store(out_holder, 0, 0)
    C.channel_receive(ch, out_holder)
    T.assert_equal(results, "third dequeue returns 3", __load(out_holder, 0), 3)

    T.assert_equal(results, "channel empty after drain", C.channel_is_empty(ch), 1)

    C.channel_destroy(ch)
    Return 1
End Process

Process called "test_channel_try_receive_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "channel.try_receive_empty")
    Let ch be C.channel_create(2)
    Let out_holder be allocate(8)
    __store(out_holder, 0, 0)
    Let rc be C.channel_try_receive(ch, out_holder)
    T.assert_equal(results, "try_receive on empty returns EMPTY", rc, -2)
    C.channel_destroy(ch)
    Return 1
End Process

Process called "test_channel_close_drains_then_fails" that takes results as Integer returns Integer:
    T.begin_suite(results, "channel.close_then_drain")
    Let ch be C.channel_create(3)
    C.channel_send(ch, 7)
    C.channel_send(ch, 8)
    C.channel_close(ch)
    T.assert_equal(results, "closed flag set", C.channel_is_closed(ch), 1)

    Let out_holder be allocate(8)
    __store(out_holder, 0, 0)
    Let rc1 be C.channel_receive(ch, out_holder)
    T.assert_equal(results, "first recv after close returns OK", rc1, 1)
    T.assert_equal(results, "first recv returns 7", __load(out_holder, 0), 7)

    __store(out_holder, 0, 0)
    Let rc2 be C.channel_receive(ch, out_holder)
    T.assert_equal(results, "second recv after close returns OK", rc2, 1)
    T.assert_equal(results, "second recv returns 8", __load(out_holder, 0), 8)

    __store(out_holder, 0, 0)
    Let rc3 be C.channel_receive(ch, out_holder)
    T.assert_equal(results, "third recv on drained closed channel returns CLOSED", rc3, 0)

    Let rc4 be C.channel_send(ch, 999)
    T.assert_equal(results, "send on closed channel rejected", rc4, 0)

    C.channel_destroy(ch)
    Return 1
End Process

Process called "test_channel_select_returns_first_ready" that takes results as Integer returns Integer:
    T.begin_suite(results, "channel.select")
    Let ch_a be C.channel_create(2)
    Let ch_b be C.channel_create(2)
    C.channel_send(ch_b, 42)

    Let chans be allocate(16)
    __store(chans, 0, ch_a)
    __store(chans, 8, ch_b)
    Let out_index be allocate(8)
    Let out_value be allocate(8)
    __store(out_index, 0, 0)
    __store(out_value, 0, 0)

    Let rc be C.channel_select(chans, 2, out_index, out_value)
    T.assert_equal(results, "select returns OK", rc, 1)
    T.assert_equal(results, "select chose index 1 (ch_b)", __load(out_index, 0), 1)
    T.assert_equal(results, "select returned value 42", __load(out_value, 0), 42)

    C.channel_destroy(ch_b)
    C.channel_destroy(ch_a)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_channel_create_destroy(results)
    test_channel_bounded_capacity(results)
    test_channel_send_recv_ordering(results)
    test_channel_try_receive_empty(results)
    test_channel_close_drains_then_fails(results)
    test_channel_select_returns_first_ready(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
