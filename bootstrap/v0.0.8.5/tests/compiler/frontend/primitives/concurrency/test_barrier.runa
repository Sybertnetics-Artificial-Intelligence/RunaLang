Note:
Unit tests for compiler/frontend/primitives/concurrency/barrier.runa.

Single-threaded validation of lifecycle, counters and parameter
validation. Real n-party blocking is exercised by thread tests in the
threading subsystem.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/concurrency/barrier.runa" as B

Process called "test_barrier_create_invalid_parties" that takes results as Integer returns Integer:
    T.begin_suite(results, "barrier.create_invalid_parties")
    Let b0 be B.barrier_create(0)
    T.assert_equal(results, "0 parties rejected", b0, 0)
    Let b_neg be B.barrier_create(-3)
    T.assert_equal(results, "negative parties rejected", b_neg, 0)
    Return 1
End Process

Process called "test_barrier_create_and_inspect" that takes results as Integer returns Integer:
    T.begin_suite(results, "barrier.create_and_inspect")
    Let b be B.barrier_create(3)
    T.assert_not_null(results, "barrier allocated", b)
    T.assert_equal(results, "total reports 3", B.barrier_total(b), 3)
    T.assert_equal(results, "no arrivals yet", B.barrier_arrived(b), 0)
    B.barrier_destroy(b)
    Return 1
End Process

Process called "test_barrier_total_one_releases_immediately" that takes results as Integer returns Integer:
    T.begin_suite(results, "barrier.single_party")
    Let b be B.barrier_create(1)
    T.assert_not_null(results, "barrier allocated", b)
    Let rc be B.barrier_wait(b)
    T.assert_equal(results, "single-party wait returns LAST_PARTY", rc, 2)
    T.assert_equal(results, "arrived counter resets after release", B.barrier_arrived(b), 0)
    B.barrier_destroy(b)
    Return 1
End Process

Process called "test_barrier_destroy_invalid" that takes results as Integer returns Integer:
    T.begin_suite(results, "barrier.destroy_invalid")
    Let rc be B.barrier_destroy(0)
    T.assert_equal(results, "destroy null returns INVALID", rc, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_barrier_create_invalid_parties(results)
    test_barrier_create_and_inspect(results)
    test_barrier_total_one_releases_immediately(results)
    test_barrier_destroy_invalid(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
