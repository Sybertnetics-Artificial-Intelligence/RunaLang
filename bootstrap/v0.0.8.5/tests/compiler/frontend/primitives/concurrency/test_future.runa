Note:
Unit tests for compiler/frontend/primitives/concurrency/future_promise.runa.

future_promise is the production Future/Promise type for Runa
v0.0.8.5. These tests exercise lifecycle, resolve/reject semantics,
state inspection and the multi-future combinators that the higher-level
"future" API in the brief is mapped onto.

The bootstrap stage1 compiler executes single-threaded so we verify
single-thread invariants here; multi-thread scheduling is covered by
the thread_core tests.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/concurrency/future_promise.runa" as F

Process called "test_promise_create_and_get_future" that takes results as Integer returns Integer:
    T.begin_suite(results, "future_promise.promise_create")

    Let p be F.promise_create()
    T.assert_not_null(results, "promise allocated", p)

    Let f be F.promise_get_future(p)
    T.assert_not_null(results, "future obtained", f)

    Let ready_initial be F.future_is_ready(f)
    T.assert_equal(results, "future not ready initially", ready_initial, 0)

    F.future_destroy(f)
    F.promise_destroy(p)
    Return 1
End Process

Process called "test_promise_set_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "future_promise.set_value")

    Let p be F.promise_create()
    Let f be F.promise_get_future(p)
    T.assert_not_null(results, "promise + future allocated", p)
    T.assert_not_null(results, "future obtained", f)

    Let rc be F.promise_set_value(p, 4242)
    T.assert_equal(results, "set_value returns OK", rc, 1)

    Let ready be F.future_is_ready(f)
    T.assert_equal(results, "future ready after set_value", ready, 1)

    Let v be F.future_get(f)
    T.assert_equal(results, "future_get returns stored value", v, 4242)

    Let err be F.future_get_error(f)
    T.assert_equal(results, "no error reported", err, 0)

    F.future_destroy(f)
    F.promise_destroy(p)
    Return 1
End Process

Process called "test_promise_set_error" that takes results as Integer returns Integer:
    T.begin_suite(results, "future_promise.set_error")

    Let p be F.promise_create()
    Let f be F.promise_get_future(p)

    Let rc be F.promise_set_error(p, 17, 0)
    T.assert_equal(results, "set_error returns OK", rc, 1)

    Let ready be F.future_is_ready(f)
    T.assert_equal(results, "future ready after error", ready, 1)

    Let err be F.future_get_error(f)
    T.assert_equal(results, "error code surfaced", err, 17)

    F.future_destroy(f)
    F.promise_destroy(p)
    Return 1
End Process

Process called "test_future_create_ready" that takes results as Integer returns Integer:
    T.begin_suite(results, "future_promise.future_create_ready")

    Let f be F.future_create_ready(99)
    T.assert_not_null(results, "ready future allocated", f)
    T.assert_equal(results, "ready future is ready", F.future_is_ready(f), 1)
    T.assert_equal(results, "ready future returns value", F.future_get(f), 99)
    T.assert_equal(results, "ready future has no error", F.future_get_error(f), 0)

    F.future_destroy(f)
    Return 1
End Process

Process called "test_future_clone_shares_state" that takes results as Integer returns Integer:
    T.begin_suite(results, "future_promise.future_clone")

    Let p be F.promise_create()
    Let f be F.promise_get_future(p)
    Let f2 be F.future_clone(f)
    T.assert_not_null(results, "future_clone produces handle", f2)

    F.promise_set_value(p, 7)
    T.assert_equal(results, "original future ready", F.future_is_ready(f), 1)
    T.assert_equal(results, "cloned future ready", F.future_is_ready(f2), 1)
    T.assert_equal(results, "both observe same value", F.future_get(f2), 7)

    F.future_destroy(f2)
    F.future_destroy(f)
    F.promise_destroy(p)
    Return 1
End Process

Process called "test_future_all_with_rejection" that takes results as Integer returns Integer:
    T.begin_suite(results, "future_promise.future_all_rejects_on_first_error")

    Let p1 be F.promise_create()
    Let p2 be F.promise_create()
    Let p3 be F.promise_create()
    Let f1 be F.promise_get_future(p1)
    Let f2 be F.promise_get_future(p2)
    Let f3 be F.promise_get_future(p3)

    F.promise_set_value(p1, 11)
    F.promise_set_error(p2, 99, 0)
    F.promise_set_value(p3, 33)

    Let futures_buf be allocate(24)
    __store(futures_buf, 0, f1)
    __store(futures_buf, 8, f2)
    __store(futures_buf, 16, f3)
    Let out_values be allocate(24)
    __store(out_values, 0, 0)
    __store(out_values, 8, 0)
    __store(out_values, 16, 0)

    Let aggregate_rc be F.future_all(futures_buf, 3, out_values)
    T.assert_equal(results, "future_all surfaces f2 error", aggregate_rc, 99)

    F.future_destroy(f3)
    F.future_destroy(f2)
    F.future_destroy(f1)
    F.promise_destroy(p3)
    F.promise_destroy(p2)
    F.promise_destroy(p1)
    Return 1
End Process

Process called "test_future_any_first_resolved" that takes results as Integer returns Integer:
    T.begin_suite(results, "future_promise.future_any")

    Let p1 be F.promise_create()
    Let p2 be F.promise_create()
    Let f1 be F.promise_get_future(p1)
    Let f2 be F.promise_get_future(p2)

    F.promise_set_value(p2, 555)

    Let futures_buf be allocate(16)
    __store(futures_buf, 0, f1)
    __store(futures_buf, 8, f2)
    Let out_index be allocate(8)
    __store(out_index, 0, 0)
    Let out_value be allocate(8)
    __store(out_value, 0, 0)

    Let rc be F.future_any(futures_buf, 2, out_index, out_value)
    T.assert_equal(results, "future_any returns OK", rc, 1)
    T.assert_equal(results, "future_any picks index 1", __load(out_index, 0), 1)
    T.assert_equal(results, "future_any returns value 555", __load(out_value, 0), 555)

    F.future_destroy(f2)
    F.future_destroy(f1)
    F.promise_destroy(p2)
    F.promise_destroy(p1)
    Return 1
End Process

Process called "test_future_cancel" that takes results as Integer returns Integer:
    T.begin_suite(results, "future_promise.cancel")

    Let p be F.promise_create()
    Let f be F.promise_get_future(p)
    Let rc be F.future_cancel(f)
    T.assert_equal(results, "cancel returns OK", rc, 1)

    F.future_destroy(f)
    F.promise_destroy(p)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_promise_create_and_get_future(results)
    test_promise_set_value(results)
    test_promise_set_error(results)
    test_future_create_ready(results)
    test_future_clone_shares_state(results)
    test_future_all_with_rejection(results)
    test_future_any_first_resolved(results)
    test_future_cancel(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
