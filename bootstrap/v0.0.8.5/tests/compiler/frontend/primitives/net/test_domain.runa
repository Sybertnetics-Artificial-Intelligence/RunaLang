Note:
KAT tests for compiler/frontend/primitives/net/domain.runa.

Verifies RFC 1123 hostname validation and RFC 3490 / RFC 3492 IDN
ToASCII / ToUnicode round-tripping including the "café.com" canonical
case "xn--caf-dma.com".
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/net/domain.runa" as DOM

Process called "test_valid_hostname" that takes results as Integer returns Integer:
    T.begin_suite(results, "domain.valid_hostname")
    T.assert_equal(results, "example.com valid", proc domain_is_valid_hostname from DOM with "example.com", 1)
    T.assert_equal(results, "www.example.com valid", proc domain_is_valid_hostname from DOM with "www.example.com", 1)
    T.assert_equal(results, "localhost valid", proc domain_is_valid_hostname from DOM with "localhost", 1)
    T.assert_equal(results, "with trailing dot valid", proc domain_is_valid_hostname from DOM with "example.com.", 1)
    T.assert_equal(results, "empty rejected", proc domain_is_valid_hostname from DOM with "", 0)
    T.assert_equal(results, "leading dot rejected", proc domain_is_valid_hostname from DOM with ".example.com", 0)
    T.assert_equal(results, "leading hyphen label rejected", proc domain_is_valid_hostname from DOM with "-bad.com", 0)
    T.assert_equal(results, "double dot rejected", proc domain_is_valid_hostname from DOM with "a..b", 0)
    Return 1
End Process

Process called "test_parent" that takes results as Integer returns Integer:
    T.begin_suite(results, "domain.parent")
    Let p1 be proc domain_parent from DOM with "www.example.com"
    T.assert_equal(results, "parent of www.example.com = example.com", proc string_equals from StringCore with p1, "example.com", 1)
    Let p2 be proc domain_parent from DOM with "com"
    T.assert_equal(results, "parent of com is null", p2, 0)
    Return 1
End Process

Process called "test_root" that takes results as Integer returns Integer:
    T.begin_suite(results, "domain.root")
    Let r be proc domain_root from DOM with "www.example.com"
    T.assert_equal(results, "root of www.example.com = com", proc string_equals from StringCore with r, "com", 1)
    Let r2 be proc domain_root from DOM with "localhost"
    T.assert_equal(results, "root of localhost = localhost", proc string_equals from StringCore with r2, "localhost", 1)
    Return 1
End Process

Process called "test_punycode_cafe" that takes results as Integer returns Integer:
    T.begin_suite(results, "domain.punycode_cafe")
    Note: "café" in UTF-8 = 0x63 0x61 0x66 0xC3 0xA9. We pass the literal as a UTF-8 string.
    Let utf8_input be "café"
    Let puny be proc domain_punycode_encode from DOM with utf8_input
    T.assert_not_null(results, "encode produces output", puny)
    T.assert_equal(results, "café -> caf-dma", proc string_equals from StringCore with puny, "caf-dma", 1)
    Let decoded be proc domain_punycode_decode from DOM with puny
    T.assert_not_null(results, "decode produces output", decoded)
    T.assert_equal(results, "round-trip", proc string_equals from StringCore with decoded, utf8_input, 1)
    Return 1
End Process

Process called "test_to_ascii" that takes results as Integer returns Integer:
    T.begin_suite(results, "domain.to_ascii")
    Let ace be proc domain_to_ascii from DOM with "café.com"
    T.assert_not_null(results, "to_ascii output", ace)
    T.assert_equal(results, "café.com -> xn--caf-dma.com", proc string_equals from StringCore with ace, "xn--caf-dma.com", 1)
    Let plain be proc domain_to_ascii from DOM with "example.com"
    T.assert_equal(results, "example.com unchanged", proc string_equals from StringCore with plain, "example.com", 1)
    Return 1
End Process

Process called "test_to_unicode" that takes results as Integer returns Integer:
    T.begin_suite(results, "domain.to_unicode")
    Let uni be proc domain_to_unicode from DOM with "xn--caf-dma.com"
    T.assert_not_null(results, "to_unicode output", uni)
    T.assert_equal(results, "xn--caf-dma.com -> café.com", proc string_equals from StringCore with uni, "café.com", 1)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_valid_hostname(results)
    test_parent(results)
    test_root(results)
    test_punycode_cafe(results)
    test_to_ascii(results)
    test_to_unicode(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
