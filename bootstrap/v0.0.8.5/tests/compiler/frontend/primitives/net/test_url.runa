Note:
KAT tests for compiler/frontend/primitives/net/url.runa.

Verifies RFC 3986 URL parsing, component extraction, percent-encoding,
and round-trip serialization.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/net/url.runa" as URL

Process called "test_parse_full" that takes results as Integer returns Integer:
    T.begin_suite(results, "url.parse_full")
    Let u be proc url_parse from URL with "https://user:pass@example.com:8080/path?q=1#frag"
    T.assert_not_null(results, "parse non-null", u)
    Let scheme be proc url_get_scheme from URL with u
    T.assert_equal(results, "scheme = https", proc string_equals from StringCore with scheme, "https", 1)
    Let userinfo be proc url_get_userinfo from URL with u
    T.assert_equal(results, "userinfo = user:pass", proc string_equals from StringCore with userinfo, "user:pass", 1)
    Let host be proc url_get_host from URL with u
    T.assert_equal(results, "host = example.com", proc string_equals from StringCore with host, "example.com", 1)
    Let port be proc url_get_port from URL with u
    T.assert_equal(results, "port = 8080", port, 8080)
    Let path be proc url_get_path from URL with u
    T.assert_equal(results, "path = /path", proc string_equals from StringCore with path, "/path", 1)
    Let query be proc url_get_query from URL with u
    T.assert_equal(results, "query = q=1", proc string_equals from StringCore with query, "q=1", 1)
    Let fragment be proc url_get_fragment from URL with u
    T.assert_equal(results, "fragment = frag", proc string_equals from StringCore with fragment, "frag", 1)
    proc url_destroy from URL with u
    Return 1
End Process

Process called "test_round_trip" that takes results as Integer returns Integer:
    T.begin_suite(results, "url.round_trip")
    Let original be "https://user:pass@example.com:8080/path?q=1#frag"
    Let u be proc url_parse from URL with original
    T.assert_not_null(results, "parse non-null", u)
    Let rendered be proc url_to_string from URL with u
    T.assert_equal(results, "round-trip identical", proc string_equals from StringCore with rendered, original, 1)
    proc url_destroy from URL with u
    Return 1
End Process

Process called "test_parse_minimal" that takes results as Integer returns Integer:
    T.begin_suite(results, "url.parse_minimal")
    Let u be proc url_parse from URL with "https://example.com"
    T.assert_not_null(results, "parse non-null", u)
    Let scheme be proc url_get_scheme from URL with u
    T.assert_equal(results, "scheme = https", proc string_equals from StringCore with scheme, "https", 1)
    Let host be proc url_get_host from URL with u
    T.assert_equal(results, "host = example.com", proc string_equals from StringCore with host, "example.com", 1)
    Let port be proc url_get_port from URL with u
    T.assert_equal(results, "port absent", port, -1)
    proc url_destroy from URL with u
    Return 1
End Process

Process called "test_percent_encode" that takes results as Integer returns Integer:
    T.begin_suite(results, "url.percent_encode")
    Let enc be proc url_percent_encode from URL with "hello world"
    T.assert_equal(results, "space encoded as %20", proc string_equals from StringCore with enc, "hello%20world", 1)
    Let enc2 be proc url_percent_encode from URL with "a/b"
    T.assert_equal(results, "/ encoded as %2F", proc string_equals from StringCore with enc2, "a%2Fb", 1)
    Return 1
End Process

Process called "test_percent_decode" that takes results as Integer returns Integer:
    T.begin_suite(results, "url.percent_decode")
    Let dec be proc url_percent_decode from URL with "hello%20world"
    T.assert_equal(results, "%20 decoded as space", proc string_equals from StringCore with dec, "hello world", 1)
    Let dec2 be proc url_percent_decode from URL with "a%2Fb"
    T.assert_equal(results, "%2F decoded as /", proc string_equals from StringCore with dec2, "a/b", 1)
    Let bad be proc url_percent_decode from URL with "abc%X"
    T.assert_equal(results, "malformed escape rejected", bad, 0)
    Return 1
End Process

Process called "test_reject_malformed" that takes results as Integer returns Integer:
    T.begin_suite(results, "url.reject_malformed")
    Let bad1 be proc url_parse from URL with "not a url"
    T.assert_equal(results, "no scheme rejected", bad1, 0)
    Let bad2 be proc url_parse from URL with ""
    T.assert_equal(results, "empty rejected", bad2, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_parse_full(results)
    test_round_trip(results)
    test_parse_minimal(results)
    test_percent_encode(results)
    test_percent_decode(results)
    test_reject_malformed(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
