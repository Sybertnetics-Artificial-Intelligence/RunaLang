Note:
KAT tests for compiler/frontend/primitives/net/asn.runa.

Verifies ASN formatting (RFC 5396 asplain), parsing, and reserved-range
classification per RFC 5398 / RFC 6996 / RFC 7607.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/net/asn.runa" as ASN

Process called "test_from_u32" that takes results as Integer returns Integer:
    T.begin_suite(results, "asn.from_u32")
    T.assert_equal(results, "0 valid", proc asn_from_u32 from ASN with 0, 0)
    T.assert_equal(results, "65000 valid", proc asn_from_u32 from ASN with 65000, 65000)
    T.assert_equal(results, "4294967295 valid", proc asn_from_u32 from ASN with 4294967295, 4294967295)
    T.assert_equal(results, "-1 rejected", proc asn_from_u32 from ASN with -1, -1)
    T.assert_equal(results, "4294967296 rejected", proc asn_from_u32 from ASN with 4294967296, -1)
    Return 1
End Process

Process called "test_to_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "asn.to_string")
    Let s be proc asn_to_string from ASN with 65000
    T.assert_equal(results, "AS65000 format", proc string_equals from StringCore with s, "AS65000", 1)
    Let s2 be proc asn_to_string from ASN with 4200000000
    T.assert_equal(results, "AS4200000000 format", proc string_equals from StringCore with s2, "AS4200000000", 1)
    Return 1
End Process

Process called "test_from_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "asn.from_string")
    T.assert_equal(results, "AS65000 parsed", proc asn_from_string from ASN with "AS65000", 65000)
    T.assert_equal(results, "as65000 parsed lowercase", proc asn_from_string from ASN with "as65000", 65000)
    T.assert_equal(results, "AS0 parsed", proc asn_from_string from ASN with "AS0", 0)
    T.assert_equal(results, "ASfoo rejected", proc asn_from_string from ASN with "ASfoo", -1)
    T.assert_equal(results, "AS rejected", proc asn_from_string from ASN with "AS", -1)
    Return 1
End Process

Process called "test_classification" that takes results as Integer returns Integer:
    T.begin_suite(results, "asn.classification")
    T.assert_equal(results, "AS 0 reserved", proc asn_is_reserved_zero from ASN with 0, 1)
    T.assert_equal(results, "AS 23456 is AS_TRANS", proc asn_is_as_trans from ASN with 23456, 1)
    T.assert_equal(results, "AS 64500 documentation", proc asn_is_documentation from ASN with 64500, 1)
    T.assert_equal(results, "AS 65000 private", proc asn_is_private from ASN with 65000, 1)
    T.assert_equal(results, "AS 4200000001 private", proc asn_is_private from ASN with 4200000001, 1)
    T.assert_equal(results, "AS 65535 is 16bit", proc asn_is_16bit from ASN with 65535, 1)
    T.assert_equal(results, "AS 65536 not 16bit", proc asn_is_16bit from ASN with 65536, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_from_u32(results)
    test_to_string(results)
    test_from_string(results)
    test_classification(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
