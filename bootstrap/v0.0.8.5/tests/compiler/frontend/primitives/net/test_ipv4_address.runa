Note:
KAT tests for compiler/frontend/primitives/net/ipv4_address.runa.

Verifies dotted-quad parsing, formatting, classification predicates
(RFC 1122 / 1918 / 3927 / 5771 / 5737 / 919), and CIDR containment
per RFC 4632.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/net/ipv4_address.runa" as IP

Process called "test_from_octets" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv4.from_octets")
    Let a be proc ipv4_from_octets from IP with 192, 168, 1, 1
    T.assert_equal(results, "192.168.1.1 packed", a, 3232235777)
    Let b be proc ipv4_from_octets from IP with 0, 0, 0, 0
    T.assert_equal(results, "0.0.0.0 packed", b, 0)
    Let c be proc ipv4_from_octets from IP with 255, 255, 255, 255
    T.assert_equal(results, "broadcast packed", c, 4294967295)
    Let d be proc ipv4_from_octets from IP with 256, 0, 0, 1
    T.assert_equal(results, "256.0.0.1 rejected", d, -1)
    Let e be proc ipv4_from_octets from IP with -1, 0, 0, 1
    T.assert_equal(results, "negative octet rejected", e, -1)
    Return 1
End Process

Process called "test_from_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv4.from_string")
    Let a be proc ipv4_from_string from IP with "192.168.1.1"
    T.assert_equal(results, "192.168.1.1 parsed", a, 3232235777)
    Let b be proc ipv4_from_string from IP with "10.0.0.1"
    T.assert_equal(results, "10.0.0.1 parsed", b, 167772161)
    Let c be proc ipv4_from_string from IP with "256.0.0.1"
    T.assert_equal(results, "256.0.0.1 rejected", c, -1)
    Let d be proc ipv4_from_string from IP with "1.2.3"
    T.assert_equal(results, "too few octets rejected", d, -1)
    Let e be proc ipv4_from_string from IP with "1.2.3.4.5"
    T.assert_equal(results, "too many octets rejected", e, -1)
    Let f be proc ipv4_from_string from IP with "a.b.c.d"
    T.assert_equal(results, "letters rejected", f, -1)
    Let g be proc ipv4_from_string from IP with ""
    T.assert_equal(results, "empty rejected", g, -1)
    Return 1
End Process

Process called "test_to_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv4.to_string")
    Let s be proc ipv4_to_string from IP with 3232235777
    T.assert_not_null(results, "to_string allocated", s)
    Let parsed be proc ipv4_from_string from IP with s
    T.assert_equal(results, "round-trip 192.168.1.1", parsed, 3232235777)
    Return 1
End Process

Process called "test_classification" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv4.classification")
    Let loopback be proc ipv4_from_string from IP with "127.0.0.1"
    T.assert_equal(results, "127.0.0.1 is loopback", (proc ipv4_is_loopback from IP with loopback), 1)
    Let public_addr be proc ipv4_from_string from IP with "8.8.8.8"
    T.assert_equal(results, "8.8.8.8 not loopback", (proc ipv4_is_loopback from IP with public_addr), 0)

    Let priv_a be proc ipv4_from_string from IP with "10.5.4.3"
    T.assert_equal(results, "10.5.4.3 is private", (proc ipv4_is_private from IP with priv_a), 1)
    Let priv_b be proc ipv4_from_string from IP with "172.20.0.1"
    T.assert_equal(results, "172.20.0.1 is private", (proc ipv4_is_private from IP with priv_b), 1)
    Let priv_c be proc ipv4_from_string from IP with "192.168.5.5"
    T.assert_equal(results, "192.168.5.5 is private", (proc ipv4_is_private from IP with priv_c), 1)
    T.assert_equal(results, "8.8.8.8 not private", (proc ipv4_is_private from IP with public_addr), 0)

    Let link_local be proc ipv4_from_string from IP with "169.254.1.1"
    T.assert_equal(results, "169.254.1.1 is link-local", (proc ipv4_is_link_local from IP with link_local), 1)

    Let mcast be proc ipv4_from_string from IP with "224.0.0.1"
    T.assert_equal(results, "224.0.0.1 is multicast", (proc ipv4_is_multicast from IP with mcast), 1)

    Let bcast be proc ipv4_from_string from IP with "255.255.255.255"
    T.assert_equal(results, "255.255.255.255 is broadcast", (proc ipv4_is_broadcast from IP with bcast), 1)

    Let doc be proc ipv4_from_string from IP with "192.0.2.5"
    T.assert_equal(results, "192.0.2.5 is documentation", (proc ipv4_is_documentation from IP with doc), 1)
    Return 1
End Process

Process called "test_cidr_contains" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv4.cidr_contains")
    Let r be proc ipv4_range_from_cidr_string from IP with "10.0.0.0/8"
    T.assert_not_null(results, "10.0.0.0/8 parsed", r)
    Let inside be proc ipv4_from_string from IP with "10.5.4.3"
    T.assert_equal(results, "10.5.4.3 contained", (proc ipv4_range_contains_address from IP with r, inside), 1)
    Let outside be proc ipv4_from_string from IP with "11.0.0.0"
    T.assert_equal(results, "11.0.0.0 not contained", (proc ipv4_range_contains_address from IP with r, outside), 0)
    Let net_addr be proc ipv4_range_network_address from IP with r
    T.assert_equal(results, "10.0.0.0/8 network is 10.0.0.0", net_addr, 167772160)
    Let bcast be proc ipv4_range_broadcast_address from IP with r
    T.assert_equal(results, "10.0.0.0/8 broadcast is 10.255.255.255", bcast, 184549375)
    Let host_count be proc ipv4_range_host_count from IP with r
    T.assert_equal(results, "10.0.0.0/8 has 2^24 addresses", host_count, 16777216)
    proc ipv4_range_destroy from IP with r
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_from_octets(results)
    test_from_string(results)
    test_to_string(results)
    test_classification(results)
    test_cidr_contains(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
