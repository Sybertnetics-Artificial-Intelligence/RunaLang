Note:
KAT tests for compiler/frontend/primitives/net/network_port.runa.

Verifies port range validation and IANA classification per RFC 6335.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/net/network_port.runa" as Port

Process called "test_construct" that takes results as Integer returns Integer:
    T.begin_suite(results, "port.construct")
    T.assert_equal(results, "0 valid", (proc port_from_u16 from Port with 0), 0)
    T.assert_equal(results, "80 valid", (proc port_from_u16 from Port with 80), 80)
    T.assert_equal(results, "65535 valid", (proc port_from_u16 from Port with 65535), 65535)
    T.assert_equal(results, "-1 rejected", (proc port_from_u16 from Port with -1), -1)
    T.assert_equal(results, "65536 rejected", (proc port_from_u16 from Port with 65536), -1)
    Return 1
End Process

Process called "test_classification" that takes results as Integer returns Integer:
    T.begin_suite(results, "port.classification")
    T.assert_equal(results, "22 is well-known", (proc port_is_well_known from Port with 22), 1)
    T.assert_equal(results, "1023 is well-known", (proc port_is_well_known from Port with 1023), 1)
    T.assert_equal(results, "1024 not well-known", (proc port_is_well_known from Port with 1024), 0)

    T.assert_equal(results, "1024 is registered", (proc port_is_registered from Port with 1024), 1)
    T.assert_equal(results, "49151 is registered", (proc port_is_registered from Port with 49151), 1)
    T.assert_equal(results, "49152 not registered", (proc port_is_registered from Port with 49152), 0)

    T.assert_equal(results, "49152 is dynamic", (proc port_is_dynamic from Port with 49152), 1)
    T.assert_equal(results, "65535 is dynamic", (proc port_is_dynamic from Port with 65535), 1)
    T.assert_equal(results, "1024 not dynamic", (proc port_is_dynamic from Port with 1024), 0)

    T.assert_equal(results, "22 is privileged", (proc port_is_privileged from Port with 22), 1)
    T.assert_equal(results, "1024 not privileged", (proc port_is_privileged from Port with 1024), 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_construct(results)
    test_classification(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
