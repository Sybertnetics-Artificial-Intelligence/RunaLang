Note:
KAT tests for compiler/frontend/primitives/net/email_address.runa.

Verifies RFC 5322 / RFC 5321 parsing including local-part validation,
domain validation, and malformed input rejection.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/net/email_address.runa" as EMAIL

Process called "test_parse_simple" that takes results as Integer returns Integer:
    T.begin_suite(results, "email.parse_simple")
    Let e be proc email_parse from EMAIL with "user@example.com", 0
    T.assert_not_null(results, "user@example.com parsed", e)
    Let local_part be proc email_get_local_part from EMAIL with e
    T.assert_equal(results, "local = user", proc string_equals from StringCore with local_part, "user", 1)
    Let domain be proc email_get_domain from EMAIL with e
    T.assert_equal(results, "domain = example.com", proc string_equals from StringCore with domain, "example.com", 1)
    proc email_destroy from EMAIL with e
    Return 1
End Process

Process called "test_parse_with_plus_tag" that takes results as Integer returns Integer:
    T.begin_suite(results, "email.parse_with_plus_tag")
    Let e be proc email_parse from EMAIL with "user+tag@example.com", 0
    T.assert_not_null(results, "user+tag@example.com parsed", e)
    Let local_part be proc email_get_local_part from EMAIL with e
    T.assert_equal(results, "local = user+tag", proc string_equals from StringCore with local_part, "user+tag", 1)
    proc email_destroy from EMAIL with e
    Return 1
End Process

Process called "test_parse_with_dots" that takes results as Integer returns Integer:
    T.begin_suite(results, "email.parse_with_dots")
    Let e be proc email_parse from EMAIL with "first.last@example.com", 0
    T.assert_not_null(results, "first.last@example.com parsed", e)
    proc email_destroy from EMAIL with e
    Return 1
End Process

Process called "test_reject_malformed" that takes results as Integer returns Integer:
    T.begin_suite(results, "email.reject_malformed")
    Let r1 be proc email_parse from EMAIL with "noatsign.com", 0
    T.assert_equal(results, "no @ rejected", r1, 0)
    Let r2 be proc email_parse from EMAIL with "@example.com", 0
    T.assert_equal(results, "missing local rejected", r2, 0)
    Let r3 be proc email_parse from EMAIL with "user@", 0
    T.assert_equal(results, "missing domain rejected", r3, 0)
    Let r4 be proc email_parse from EMAIL with ".user@example.com", 0
    T.assert_equal(results, "leading dot rejected", r4, 0)
    Let r5 be proc email_parse from EMAIL with "user.@example.com", 0
    T.assert_equal(results, "trailing dot rejected", r5, 0)
    Let r6 be proc email_parse from EMAIL with "u..s@example.com", 0
    T.assert_equal(results, "double dot rejected", r6, 0)
    Let r7 be proc email_parse from EMAIL with "user@.example.com", 0
    T.assert_equal(results, "empty domain label rejected", r7, 0)
    Let r8 be proc email_parse from EMAIL with "", 0
    T.assert_equal(results, "empty rejected", r8, 0)
    Return 1
End Process

Process called "test_round_trip" that takes results as Integer returns Integer:
    T.begin_suite(results, "email.round_trip")
    Let e be proc email_parse from EMAIL with "user+tag@example.com", 0
    Let s be proc email_to_string from EMAIL with e
    T.assert_equal(results, "round-trip identical", proc string_equals from StringCore with s, "user+tag@example.com", 1)
    proc email_destroy from EMAIL with e
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_parse_simple(results)
    test_parse_with_plus_tag(results)
    test_parse_with_dots(results)
    test_reject_malformed(results)
    test_round_trip(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
