Note:
KAT tests for compiler/frontend/primitives/net/mac_address.runa.

Verifies parse of colon (Linux), hyphen (Windows), and Cisco dot-quad
formats per RFC 7042 / IEEE 802 conventions.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/net/mac_address.runa" as MAC

Process called "test_from_octets" that takes results as Integer returns Integer:
    T.begin_suite(results, "mac.from_octets")
    Let a be proc mac_from_octets from MAC with 170, 187, 204, 221, 238, 255
    T.assert_equal(results, "AA:BB:CC:DD:EE:FF packed", a, 187723572702975)
    Let b be proc mac_from_octets from MAC with 0, 0, 0, 0, 0, 0
    T.assert_equal(results, "all-zero packed", b, 0)
    Let bad be proc mac_from_octets from MAC with 256, 0, 0, 0, 0, 0
    T.assert_equal(results, "256 octet rejected", bad, -1)
    Return 1
End Process

Process called "test_parse_colon" that takes results as Integer returns Integer:
    T.begin_suite(results, "mac.parse_colon")
    Let a be proc mac_from_string from MAC with "AA:BB:CC:DD:EE:FF"
    T.assert_equal(results, "Linux colon form parsed", a, 187723572702975)
    Let b be proc mac_from_string from MAC with "00:11:22:33:44:55"
    T.assert_equal(results, "00:11:22:33:44:55 parsed", b, 73588229205)
    Return 1
End Process

Process called "test_parse_hyphen" that takes results as Integer returns Integer:
    T.begin_suite(results, "mac.parse_hyphen")
    Let a be proc mac_from_string from MAC with "AA-BB-CC-DD-EE-FF"
    T.assert_equal(results, "Windows hyphen form parsed", a, 187723572702975)
    Return 1
End Process

Process called "test_parse_cisco" that takes results as Integer returns Integer:
    T.begin_suite(results, "mac.parse_cisco")
    Let a be proc mac_from_string from MAC with "AABB.CCDD.EEFF"
    T.assert_equal(results, "Cisco dot form parsed", a, 187723572702975)
    Return 1
End Process

Process called "test_reject_malformed" that takes results as Integer returns Integer:
    T.begin_suite(results, "mac.reject_malformed")
    Let r1 be proc mac_from_string from MAC with "AA:BB:CC:DD:EE"
    T.assert_equal(results, "too short rejected", r1, -1)
    Let r2 be proc mac_from_string from MAC with "GG:BB:CC:DD:EE:FF"
    T.assert_equal(results, "non-hex rejected", r2, -1)
    Let r3 be proc mac_from_string from MAC with ""
    T.assert_equal(results, "empty rejected", r3, -1)
    Return 1
End Process

Process called "test_classification" that takes results as Integer returns Integer:
    T.begin_suite(results, "mac.classification")
    Let bc be proc mac_from_string from MAC with "FF:FF:FF:FF:FF:FF"
    T.assert_equal(results, "broadcast detected", proc mac_is_broadcast from MAC with bc, 1)
    Let uni be proc mac_from_string from MAC with "00:11:22:33:44:55"
    T.assert_equal(results, "unicast detected", proc mac_is_unicast from MAC with uni, 1)
    T.assert_equal(results, "00:11... universal", proc mac_is_universal from MAC with uni, 1)
    Let local_mac be proc mac_from_string from MAC with "02:11:22:33:44:55"
    T.assert_equal(results, "02:... is locally administered", proc mac_is_universal from MAC with local_mac, 0)
    Return 1
End Process

Process called "test_oui" that takes results as Integer returns Integer:
    T.begin_suite(results, "mac.oui")
    Let a be proc mac_from_string from MAC with "AA:BB:CC:DD:EE:FF"
    Let oui be proc mac_oui from MAC with a
    T.assert_equal(results, "OUI of AA:BB:CC:... is 0xAABBCC", oui, 11189196)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_from_octets(results)
    test_parse_colon(results)
    test_parse_hyphen(results)
    test_parse_cisco(results)
    test_reject_malformed(results)
    test_classification(results)
    test_oui(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
