Note:
KAT tests for compiler/frontend/primitives/net/ipv6_address.runa.

Verifies textual parsing, canonical RFC 5952 compression, and
classification per RFC 4291.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/net/ipv6_address.runa" as IP6

Process called "test_loopback" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv6.loopback")
    Let lb be proc ipv6_from_string from IP6 with "::1"
    T.assert_not_null(results, "::1 parsed", lb)
    T.assert_equal(results, "::1 is loopback", proc ipv6_is_loopback from IP6 with lb, 1)
    Let lb_s be proc ipv6_to_string from IP6 with lb
    T.assert_not_null(results, "to_string ::1 non-null", lb_s)
    Let len be proc string_length from StringCore with lb_s
    T.assert_equal(results, "::1 emitted as 3 chars", len, 3)
    Let b0 be proc memory_get_byte from Memory with lb_s, 0
    Let b1 be proc memory_get_byte from Memory with lb_s, 1
    Let b2 be proc memory_get_byte from Memory with lb_s, 2
    T.assert_equal(results, "[0]=:", b0, 58)
    T.assert_equal(results, "[1]=:", b1, 58)
    T.assert_equal(results, "[2]=1", b2, 49)
    proc ipv6_destroy from IP6 with lb
    Return 1
End Process

Process called "test_unspecified" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv6.unspecified")
    Let un be proc ipv6_from_string from IP6 with "::"
    T.assert_not_null(results, ":: parsed", un)
    T.assert_equal(results, ":: is unspecified", proc ipv6_is_unspecified from IP6 with un, 1)
    proc ipv6_destroy from IP6 with un
    Return 1
End Process

Process called "test_documentation_addr" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv6.documentation_address")
    Let a be proc ipv6_from_string from IP6 with "2001:db8::1"
    T.assert_not_null(results, "2001:db8::1 parsed", a)
    Let s be proc ipv6_to_string from IP6 with a
    T.assert_not_null(results, "format non-null", s)
    Let g0 be proc ipv6_get_segment from IP6 with a, 0
    T.assert_equal(results, "group 0 = 0x2001", g0, 8193)
    Let g1 be proc ipv6_get_segment from IP6 with a, 1
    T.assert_equal(results, "group 1 = 0x0db8", g1, 3512)
    Let g7 be proc ipv6_get_segment from IP6 with a, 7
    T.assert_equal(results, "group 7 = 1", g7, 1)
    proc ipv6_destroy from IP6 with a
    Return 1
End Process

Process called "test_link_local" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv6.link_local")
    Let ll be proc ipv6_from_string from IP6 with "fe80::1"
    T.assert_not_null(results, "fe80::1 parsed", ll)
    T.assert_equal(results, "fe80::1 is link-local", proc ipv6_is_link_local from IP6 with ll, 1)
    T.assert_equal(results, "fe80::1 is not multicast", proc ipv6_is_multicast from IP6 with ll, 0)
    proc ipv6_destroy from IP6 with ll
    Return 1
End Process

Process called "test_multicast" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv6.multicast")
    Let mc be proc ipv6_from_string from IP6 with "ff02::1"
    T.assert_not_null(results, "ff02::1 parsed", mc)
    T.assert_equal(results, "ff02::1 is multicast", proc ipv6_is_multicast from IP6 with mc, 1)
    proc ipv6_destroy from IP6 with mc
    Return 1
End Process

Process called "test_ipv4_mapped" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv6.ipv4_mapped")
    Let m be proc ipv6_ipv4_mapped_in_ipv6 from IP6 with 167772161
    T.assert_not_null(results, "mapped(10.0.0.1) allocated", m)
    T.assert_equal(results, "mapped(10.0.0.1) is_mapped", proc ipv6_is_ipv4_mapped from IP6 with m, 1)
    Let extracted be proc ipv6_ipv4_from_mapped from IP6 with m
    T.assert_equal(results, "round-trip ipv4 value", extracted, 167772161)
    proc ipv6_destroy from IP6 with m
    Return 1
End Process

Process called "test_reject_malformed" that takes results as Integer returns Integer:
    T.begin_suite(results, "ipv6.reject_malformed")
    Let bad1 be proc ipv6_from_string from IP6 with "gggg::"
    T.assert_equal(results, "gggg:: rejected", bad1, 0)
    Let bad2 be proc ipv6_from_string from IP6 with "1::2::3"
    T.assert_equal(results, "double :: rejected", bad2, 0)
    Let bad3 be proc ipv6_from_string from IP6 with ""
    T.assert_equal(results, "empty rejected", bad3, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_loopback(results)
    test_unspecified(results)
    test_documentation_addr(results)
    test_link_local(results)
    test_multicast(results)
    test_ipv4_mapped(results)
    test_reject_malformed(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
