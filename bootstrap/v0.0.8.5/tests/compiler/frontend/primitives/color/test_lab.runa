Note:
Unit tests for compiler/frontend/primitives/color/lab.runa.

KAT (Known Answer Test) reference values:
  - rgb(1, 0, 0) -> lab ~ (53.24, 80.09, 67.20)
  - rgb(1, 1, 1) -> lab ~ (100, 0, 0)
  - rgb(0, 0, 0) -> lab ~ (0, 0, 0)
  - CIEDE2000 between Lab(50, 2.6772, -79.7751) and Lab(50, 0, -82.7485) = 2.0425
    (Sharma 2005 reference test case #1)

CIE 1976 L*u*v* reference values (D65 illuminant, CIE 15:2004):
  - D65 white (X=0.95047, Y=1.0, Z=1.08883) -> LUV(L=100, u=0, v=0)
  - Black (X=0, Y=0, Z=0)                    -> LUV(0, 0, 0)
  - Pure sRGB red (1,0,0) yields XYZ ~ (0.4124564, 0.2126729, 0.0193339).
    LUV under D65 ~ (53.241, 175.015, 37.756) per CIE 15:2004 forward
    formulae. The forward/inverse pair must round-trip to XYZ within
    machine precision, modulo the cubic-vs-linear branch tolerance
    near the y* = (24/116)^3 threshold.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/color/lab.runa" as Lab
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "abs_diff_q" takes a as Float, b as Float, quantum as Integer returns Integer:
    Let diff be a minus b
    If diff is less than 0.0:
        Set diff to 0.0 minus diff
    End If
    Return Arith.float_to_int(diff multiplied by Arith.int_to_float(quantum))
End Process

Process called "test_lab_red_kat" takes results as Integer returns Integer:
    T.begin_suite(results, "lab.xyz_to_lab red KAT")
    Let xyz be Lab.rgb_to_xyz(1.0, 0.0, 0.0)
    Let lab_red be Lab.xyz_to_lab(xyz)
    Note: Reference: rgb(1,0,0) -> lab ~ (53.24, 80.09, 67.20)
    T.assert_true(results, "lab.L ~ 53.24 within +/-0.5", abs_diff_q(lab_red.l, 53.24, 10) is less than 10)
    T.assert_true(results, "lab.a ~ 80.09 within +/-1.0", abs_diff_q(lab_red.a, 80.09, 10) is less than 15)
    T.assert_true(results, "lab.b ~ 67.20 within +/-1.0", abs_diff_q(lab_red.b, 67.20, 10) is less than 15)
    Return 1
End Process

Process called "test_lab_white" takes results as Integer returns Integer:
    T.begin_suite(results, "lab.xyz_to_lab white KAT")
    Let xyz be Lab.rgb_to_xyz(1.0, 1.0, 1.0)
    Let lab_white be Lab.xyz_to_lab(xyz)
    Note: Reference: rgb(1,1,1) -> lab ~ (100, 0, 0)
    T.assert_true(results, "lab.L ~ 100", abs_diff_q(lab_white.l, 100.0, 10) is less than 10)
    T.assert_true(results, "lab.a ~ 0", abs_diff_q(lab_white.a, 0.0, 10) is less than 20)
    T.assert_true(results, "lab.b ~ 0", abs_diff_q(lab_white.b, 0.0, 10) is less than 20)
    Return 1
End Process

Process called "test_lab_black" takes results as Integer returns Integer:
    T.begin_suite(results, "lab.xyz_to_lab black KAT")
    Let xyz be Lab.rgb_to_xyz(0.0, 0.0, 0.0)
    Let lab_black be Lab.xyz_to_lab(xyz)
    T.assert_equal(results, "black.L = 0", Arith.float_to_int(lab_black.l), 0)
    Return 1
End Process

Process called "test_lab_to_lch" takes results as Integer returns Integer:
    T.begin_suite(results, "lab.lab_to_lch")
    Let lab_red be Lab.lab_create(53.24, 80.09, 67.20)
    Let lch_red be Lab.lab_to_lch(lab_red)
    Note: Chroma = sqrt(80.09^2 + 67.20^2) ~ 104.55
    T.assert_true(results, "lch.C ~ 104.55", abs_diff_q(lch_red.c, 104.55, 10) is less than 20)
    Note: hue ~ atan2(67.20, 80.09) ~ 39.98 degrees
    T.assert_true(results, "lch.h ~ 40 degrees", abs_diff_q(lch_red.h, 40.0, 1) is less than 5)
    Return 1
End Process

Process called "test_delta_e_1976" takes results as Integer returns Integer:
    T.begin_suite(results, "lab.delta_e_1976")
    Let a be Lab.lab_create(50.0, 0.0, 0.0)
    Let b be Lab.lab_create(50.0, 0.0, 0.0)
    Let d_same be Lab.delta_e_1976(a, b)
    T.assert_equal(results, "delta_e_1976(equal) = 0", Arith.float_to_int(d_same), 0)

    Let c be Lab.lab_create(50.0, 10.0, 0.0)
    Let d_simple be Lab.delta_e_1976(a, c)
    T.assert_equal(results, "delta_e_1976 a=(50,0,0) vs (50,10,0) = 10", Arith.float_to_int(d_simple), 10)
    Return 1
End Process

Process called "test_delta_e_2000_sharma" takes results as Integer returns Integer:
    T.begin_suite(results, "lab.delta_e_2000 Sharma 2005 reference #1")
    Note: Sharma 2005 case #1: Lab(50, 2.6772, -79.7751) vs Lab(50, 0, -82.7485) -> 2.0425
    Let a be Lab.lab_create(50.0, 2.6772, 0.0 minus 79.7751)
    Let b be Lab.lab_create(50.0, 0.0, 0.0 minus 82.7485)
    Let de be Lab.delta_e_2000(a, b)
    Note: Reference value 2.0425, our impl is approximate due to series-based trig / pow
    T.assert_true(results, "delta_e_2000 within +/-0.5 of 2.0425", abs_diff_q(de, 2.0425, 10) is less than 10)
    Return 1
End Process

Note: ============================================================================
Note: CIE 1976 L*u*v* tests
Note: ============================================================================

Process called "test_luv_create_and_accessors" takes results as Integer returns Integer:
    T.begin_suite(results, "lab.luv_create + luv_l / luv_u / luv_v")
    Let c be Lab.luv_create(53.241, 175.015, 37.756)
    T.assert_equal(results, "luv_l = 53", Arith.float_to_int(Lab.luv_l(c)), 53)
    T.assert_equal(results, "luv_u = 175", Arith.float_to_int(Lab.luv_u(c)), 175)
    T.assert_equal(results, "luv_v = 37", Arith.float_to_int(Lab.luv_v(c)), 37)
    Note: Negative coordinates allowed (wide-gamut XYZ).
    Let neg be Lab.luv_create(20.0, 0.0 minus 50.0, 0.0 minus 25.0)
    T.assert_equal(results, "neg.l = 20", Arith.float_to_int(Lab.luv_l(neg)), 20)
    T.assert_equal(results, "neg.u = -50", Arith.float_to_int(Lab.luv_u(neg)), 0 minus 50)
    T.assert_equal(results, "neg.v = -25", Arith.float_to_int(Lab.luv_v(neg)), 0 minus 25)
    Return 1
End Process

Process called "test_luv_d65_white" takes results as Integer returns Integer:
    Note: D65 reference white (X=0.95047, Y=1.0, Z=1.08883).
    Note: L* = 116 * f(Y/Yw) - 16 = 116 * f(1) - 16 = 116 * 1 - 16 = 100.
    Note: u' and v' at the colour match (u_w', v_w'), so u* = v* = 0.
    T.begin_suite(results, "lab.xyz_to_luv: D65 reference white -> (100, 0, 0)")
    Let xyz be Lab.xyz_create(0.95047, 1.0, 1.08883)
    Let luv_w be Lab.xyz_to_luv(xyz)
    T.assert_equal(results, "L = 100", Arith.float_to_int(Lab.luv_l(luv_w)), 100)
    Note: u and v at the white point must be 0 modulo float epsilon.
    T.assert_true(results, "|u| < 0.001", abs_diff_q(Lab.luv_u(luv_w), 0.0, 1000) is less than 1)
    T.assert_true(results, "|v| < 0.001", abs_diff_q(Lab.luv_v(luv_w), 0.0, 1000) is less than 1)
    Return 1
End Process

Process called "test_luv_black" takes results as Integer returns Integer:
    T.begin_suite(results, "lab.xyz_to_luv: black -> (0, 0, 0)")
    Let xyz be Lab.xyz_create(0.0, 0.0, 0.0)
    Let luv_k be Lab.xyz_to_luv(xyz)
    Note: f(0) = (kappa * 0 + 16) / 116 = 16/116 yields L = 0.
    T.assert_equal(results, "L = 0", Arith.float_to_int(Lab.luv_l(luv_k)), 0)
    Note: At L = 0, u and v are mathematically 13 * 0 * (delta) = 0.
    T.assert_true(results, "|u| < 0.001", abs_diff_q(Lab.luv_u(luv_k), 0.0, 1000) is less than 1)
    T.assert_true(results, "|v| < 0.001", abs_diff_q(Lab.luv_v(luv_k), 0.0, 1000) is less than 1)
    Return 1
End Process

Process called "test_luv_red_kat" takes results as Integer returns Integer:
    Note: Pure sRGB red -> XYZ -> LUV. Reference values from CIE 15:2004
    Note: forward formulae (computed with double-precision arithmetic):
    Note:   L* ~ 53.241
    Note:   u* ~ 175.015
    Note:   v* ~ 37.756
    Note: The reference uses series-based approximations for cbrt and pow
    Note: in lab_f / xyz_to_lab; LUV inherits the same L. We tolerate
    Note: +/- 2.0 for u* and v* and +/- 0.5 for L*.
    T.begin_suite(results, "lab.xyz_to_luv: pure red KAT")
    Let xyz be Lab.rgb_to_xyz(1.0, 0.0, 0.0)
    Let luv_r be Lab.xyz_to_luv(xyz)
    T.assert_true(results, "L ~ 53.241 +/- 0.5", abs_diff_q(Lab.luv_l(luv_r), 53.241, 10) is less than 10)
    T.assert_true(results, "u ~ 175.015 +/- 2.0", abs_diff_q(Lab.luv_u(luv_r), 175.015, 10) is less than 25)
    T.assert_true(results, "v ~ 37.756 +/- 2.0", abs_diff_q(Lab.luv_v(luv_r), 37.756, 10) is less than 25)
    Return 1
End Process

Process called "test_luv_roundtrip_white" takes results as Integer returns Integer:
    Note: xyz_to_luv then luv_to_xyz must recover the same XYZ within
    Note: tolerance. White point: a fixed point of the cycle.
    T.begin_suite(results, "lab.xyz_to_luv -> luv_to_xyz: D65 white roundtrip")
    Let xyz_in be Lab.xyz_create(0.95047, 1.0, 1.08883)
    Let luv_w be Lab.xyz_to_luv(xyz_in)
    Let xyz_out be Lab.luv_to_xyz(luv_w)
    T.assert_true(results, "X round-trip", abs_diff_q(xyz_out.x, 0.95047, 1000) is less than 5)
    T.assert_true(results, "Y round-trip", abs_diff_q(xyz_out.y, 1.0, 1000) is less than 5)
    T.assert_true(results, "Z round-trip", abs_diff_q(xyz_out.z, 1.08883, 1000) is less than 5)
    Return 1
End Process

Process called "test_luv_roundtrip_red" takes results as Integer returns Integer:
    Note: Round-trip via XYZ -> LUV -> XYZ for pure sRGB red. The cycle
    Note: depends on lab_f's series-based cbrt; we accept +/- 0.01 per
    Note: channel which corresponds to the tolerance documented in lab.runa.
    T.begin_suite(results, "lab.xyz_to_luv -> luv_to_xyz: red roundtrip")
    Let xyz_in be Lab.rgb_to_xyz(1.0, 0.0, 0.0)
    Let luv_r be Lab.xyz_to_luv(xyz_in)
    Let xyz_out be Lab.luv_to_xyz(luv_r)
    T.assert_true(results, "X round-trip", abs_diff_q(xyz_out.x, xyz_in.x, 1000) is less than 50)
    T.assert_true(results, "Y round-trip", abs_diff_q(xyz_out.y, xyz_in.y, 1000) is less than 50)
    T.assert_true(results, "Z round-trip", abs_diff_q(xyz_out.z, xyz_in.z, 1000) is less than 50)
    Return 1
End Process

Process called "test_luv_to_xyz_zero_l" takes results as Integer returns Integer:
    Note: L = 0 is a degenerate case: chromaticity is undefined and
    Note: luv_to_xyz must return the origin.
    T.begin_suite(results, "lab.luv_to_xyz: L=0 -> origin")
    Let luv_k be Lab.luv_create(0.0, 50.0, 25.0)
    Let xyz be Lab.luv_to_xyz(luv_k)
    T.assert_equal(results, "X = 0", Arith.float_to_int(xyz.x multiplied by 1000.0), 0)
    T.assert_equal(results, "Y = 0", Arith.float_to_int(xyz.y multiplied by 1000.0), 0)
    T.assert_equal(results, "Z = 0", Arith.float_to_int(xyz.z multiplied by 1000.0), 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_lab_red_kat(results)
    test_lab_white(results)
    test_lab_black(results)
    test_lab_to_lch(results)
    test_delta_e_1976(results)
    test_delta_e_2000_sharma(results)
    test_luv_create_and_accessors(results)
    test_luv_d65_white(results)
    test_luv_black(results)
    test_luv_red_kat(results)
    test_luv_roundtrip_white(results)
    test_luv_roundtrip_red(results)
    test_luv_to_xyz_zero_l(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
