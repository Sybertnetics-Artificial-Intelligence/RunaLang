Note:
Unit tests for compiler/frontend/primitives/color/color_space.runa.

KAT (Known Answer Test) reference values:
  - color_space enum dispatch returns the documented indices
  - sRGB(0.5) -> linear ~ 0.214
  - Bradford D50 -> D65 round trip preserves XYZ within +/-0.001
  - linear_srgb_to_xyz(1, 0, 0) = (0.4124, 0.2126, 0.0193) approximately
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/color/color_space.runa" as Cs
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Process called "abs_diff_q" takes a as Float, b as Float, quantum as Integer returns Integer:
    Let diff be a minus b
    If diff is less than 0.0:
        Set diff to 0.0 minus diff
    End If
    Return Arith.float_to_int(diff multiplied by Arith.int_to_float(quantum))
End Process

Process called "load_float_at" takes ptr as Integer, offset as Integer returns Float:
    Note: Bit-cast: load 8 bytes from ptr+offset as Float.
    Let bits be Memory.memory_get_int64(ptr, offset)
    Let result be 0.0
    Inline Assembly:
        mov rax, qword ptr [rbp-8]
        mov qword ptr [rbp-16], rax
    End Assembly
    Return result
End Process

Process called "test_color_space_enum" takes results as Integer returns Integer:
    T.begin_suite(results, "color_space enum identifiers")
    T.assert_equal(results, "SRGB = 0", Cs.color_space_srgb(), 0)
    T.assert_equal(results, "LINEAR_RGB = 1", Cs.color_space_linear_rgb(), 1)
    T.assert_equal(results, "DISPLAY_P3 = 2", Cs.color_space_display_p3(), 2)
    T.assert_equal(results, "REC2020 = 3", Cs.color_space_rec2020(), 3)
    T.assert_equal(results, "XYZ_D65 = 7", Cs.color_space_xyz_d65(), 7)
    T.assert_equal(results, "OKLAB = 10", Cs.color_space_oklab(), 10)
    Return 1
End Process

Process called "test_srgb_to_linear_kat" takes results as Integer returns Integer:
    T.begin_suite(results, "color_space.srgb_to_linear_cs(0.5) ~ 0.214")
    Let lin be Cs.srgb_to_linear_cs(0.5)
    T.assert_true(results, "srgb(0.5) ~ 0.214 within +/-0.005", abs_diff_q(lin, 0.2140, 1000) is less than 5)
    T.assert_equal(results, "srgb(0.0) = 0", Arith.float_to_int(Cs.srgb_to_linear_cs(0.0) multiplied by 1000.0), 0)
    Return 1
End Process

Process called "test_linear_srgb_to_xyz" takes results as Integer returns Integer:
    T.begin_suite(results, "color_space.linear_srgb_to_xyz red KAT")
    Let xr be Cs.linear_srgb_to_xyz_x(1.0, 0.0, 0.0)
    Let yr be Cs.linear_srgb_to_xyz_y(1.0, 0.0, 0.0)
    Let zr be Cs.linear_srgb_to_xyz_z(1.0, 0.0, 0.0)
    T.assert_true(results, "X ~ 0.4124", abs_diff_q(xr, 0.4124, 1000) is less than 5)
    T.assert_true(results, "Y ~ 0.2127", abs_diff_q(yr, 0.2127, 1000) is less than 5)
    T.assert_true(results, "Z ~ 0.0193", abs_diff_q(zr, 0.0193, 1000) is less than 5)
    Return 1
End Process

Process called "test_xyz_to_linear_srgb" takes results as Integer returns Integer:
    T.begin_suite(results, "color_space.xyz_to_linear_rgb red roundtrip")
    Let rr be Cs.xyz_to_linear_rgb_r(0.4124, 0.2127, 0.0193, 0)
    Let gg be Cs.xyz_to_linear_rgb_g(0.4124, 0.2127, 0.0193, 0)
    Let bb be Cs.xyz_to_linear_rgb_b(0.4124, 0.2127, 0.0193, 0)
    T.assert_true(results, "r ~ 1.0", abs_diff_q(rr, 1.0, 1000) is less than 10)
    T.assert_true(results, "g ~ 0.0", abs_diff_q(gg, 0.0, 1000) is less than 10)
    T.assert_true(results, "b ~ 0.0", abs_diff_q(bb, 0.0, 1000) is less than 10)
    Return 1
End Process

Process called "test_bradford_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "color_space.bradford D50<->D65 roundtrip")
    Let buf1 be allocate(24)
    Let buf2 be allocate(24)
    Note: Start with arbitrary XYZ near D50, adapt to D65 then back
    Let _f be Cs.bradford_adapt_d50_to_d65(0.5, 0.5, 0.5, buf1)
    Let x1 be load_float_at(buf1, 0)
    Let y1 be load_float_at(buf1, 8)
    Let z1 be load_float_at(buf1, 16)
    Let _r be Cs.bradford_adapt_d65_to_d50(x1, y1, z1, buf2)
    Let x2 be load_float_at(buf2, 0)
    Let y2 be load_float_at(buf2, 8)
    Let z2 be load_float_at(buf2, 16)
    T.assert_true(results, "roundtrip X ~ 0.5", abs_diff_q(x2, 0.5, 1000) is less than 5)
    T.assert_true(results, "roundtrip Y ~ 0.5", abs_diff_q(y2, 0.5, 1000) is less than 5)
    T.assert_true(results, "roundtrip Z ~ 0.5", abs_diff_q(z2, 0.5, 1000) is less than 5)
    deallocate(buf1)
    deallocate(buf2)
    Return 1
End Process

Process called "test_color_space_convert" takes results as Integer returns Integer:
    T.begin_suite(results, "color_space.color_space_convert sRGB->XYZ_D65")
    Let buf be allocate(24)
    Let _r be Cs.color_space_convert(1.0, 0.0, 0.0, 0, 7, buf)
    Let xv be load_float_at(buf, 0)
    Let yv be load_float_at(buf, 8)
    Let zv be load_float_at(buf, 16)
    Note: sRGB(1,0,0) -> linear -> XYZ ~ (0.4124, 0.2127, 0.0193)
    T.assert_true(results, "convert X ~ 0.4124", abs_diff_q(xv, 0.4124, 1000) is less than 10)
    T.assert_true(results, "convert Y ~ 0.2127", abs_diff_q(yv, 0.2127, 1000) is less than 10)
    deallocate(buf)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_color_space_enum(results)
    test_srgb_to_linear_kat(results)
    test_linear_srgb_to_xyz(results)
    test_xyz_to_linear_srgb(results)
    test_bradford_roundtrip(results)
    test_color_space_convert(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
