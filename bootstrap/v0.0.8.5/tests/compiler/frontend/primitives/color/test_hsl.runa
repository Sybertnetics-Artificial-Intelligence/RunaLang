Note:
Unit tests for compiler/frontend/primitives/color/hsl.runa.

KAT (Known Answer Test) reference values:
  - rgb(1, 0, 0) -> hsl(0, 1, 0.5)
  - rgb(0, 1, 0) -> hsl(120, 1, 0.5)
  - rgb(0, 0, 1) -> hsl(240, 1, 0.5)
  - rgb(1, 1, 1) -> hsl(0, 0, 1)   (saturation 0 for grey)
  - rgb(0, 0, 0) -> hsl(0, 0, 0)
  - rgb(1, 0, 0) -> hsv(0, 1, 1)

HSV <-> HSL conversions (CSS Color Module Level 4):
  - HSV(0, 100%, 100%) <-> HSL(0, 100%, 50%)   (pure red)
  - HSV(120, 100%, 100%) <-> HSL(120, 100%, 50%) (pure green)
  - HSV(240, 100%, 100%) <-> HSL(240, 100%, 50%) (pure blue)
  - HSV(0, 0%, 100%) <-> HSL(0, 0%, 100%)      (white)
  - HSV(0, 0%, 0%) <-> HSL(0, 0%, 0%)          (black)
  - HSV(0, 0%, 50%) <-> HSL(0, 0%, 50%)        (mid-gray)
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/color/hsl.runa" as Hsl
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "abs_diff_q" takes a as Float, b as Float, quantum as Integer returns Integer:
    Let diff be a minus b
    If diff is less than 0.0:
        Set diff to 0.0 minus diff
    End If
    Return Arith.float_to_int(diff multiplied by Arith.int_to_float(quantum))
End Process

Process called "test_hsl_from_rgb_red" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsl_from_rgb red KAT")
    Let red_hsl be Hsl.hsl_from_rgb(1.0, 0.0, 0.0, 1.0)
    T.assert_equal(results, "red.h = 0", Arith.float_to_int(red_hsl.h), 0)
    T.assert_equal(results, "red.s = 1.0", Arith.float_to_int(red_hsl.s multiplied by 1000.0), 1000)
    T.assert_equal(results, "red.l = 0.5", Arith.float_to_int(red_hsl.l multiplied by 1000.0), 500)
    Return 1
End Process

Process called "test_hsl_from_rgb_green" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsl_from_rgb green KAT")
    Let green_hsl be Hsl.hsl_from_rgb(0.0, 1.0, 0.0, 1.0)
    T.assert_equal(results, "green.h = 120", Arith.float_to_int(green_hsl.h), 120)
    T.assert_equal(results, "green.s = 1.0", Arith.float_to_int(green_hsl.s multiplied by 1000.0), 1000)
    T.assert_equal(results, "green.l = 0.5", Arith.float_to_int(green_hsl.l multiplied by 1000.0), 500)
    Return 1
End Process

Process called "test_hsl_from_rgb_blue" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsl_from_rgb blue KAT")
    Let blue_hsl be Hsl.hsl_from_rgb(0.0, 0.0, 1.0, 1.0)
    T.assert_equal(results, "blue.h = 240", Arith.float_to_int(blue_hsl.h), 240)
    T.assert_equal(results, "blue.s = 1.0", Arith.float_to_int(blue_hsl.s multiplied by 1000.0), 1000)
    T.assert_equal(results, "blue.l = 0.5", Arith.float_to_int(blue_hsl.l multiplied by 1000.0), 500)
    Return 1
End Process

Process called "test_hsl_grey_saturation" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsl_from_rgb grey -> s=0")
    Let grey_hsl be Hsl.hsl_from_rgb(0.5, 0.5, 0.5, 1.0)
    T.assert_equal(results, "grey.s = 0", Arith.float_to_int(grey_hsl.s multiplied by 1000.0), 0)
    T.assert_equal(results, "grey.l = 0.5", Arith.float_to_int(grey_hsl.l multiplied by 1000.0), 500)
    Let white_hsl be Hsl.hsl_from_rgb(1.0, 1.0, 1.0, 1.0)
    T.assert_equal(results, "white.l = 1.0", Arith.float_to_int(white_hsl.l multiplied by 1000.0), 1000)
    Let black_hsl be Hsl.hsl_from_rgb(0.0, 0.0, 0.0, 1.0)
    T.assert_equal(results, "black.l = 0.0", Arith.float_to_int(black_hsl.l multiplied by 1000.0), 0)
    Return 1
End Process

Process called "test_hsv_from_rgb_red" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsv_from_rgb red KAT")
    Let red_hsv be Hsl.hsv_from_rgb(1.0, 0.0, 0.0, 1.0)
    T.assert_equal(results, "red.h = 0", Arith.float_to_int(red_hsv.h), 0)
    T.assert_equal(results, "red.s = 1.0", Arith.float_to_int(red_hsv.s multiplied by 1000.0), 1000)
    T.assert_equal(results, "red.v = 1.0", Arith.float_to_int(red_hsv.v multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_hsl_lighten" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsl_lighten")
    Let base be Hsl.hsl_create(120.0, 0.5, 0.5, 1.0)
    Let lighter be Hsl.hsl_lighten(base, 0.2)
    T.assert_equal(results, "lighten 0.2 -> l=0.7", Arith.float_to_int(lighter.l multiplied by 1000.0), 700)
    Let darker be Hsl.hsl_darken(base, 0.3)
    T.assert_equal(results, "darken 0.3 -> l=0.2", Arith.float_to_int(darker.l multiplied by 1000.0), 200)
    Return 1
End Process

Process called "test_hsl_saturate" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsl_saturate")
    Let base be Hsl.hsl_create(120.0, 0.3, 0.5, 1.0)
    Let saturated be Hsl.hsl_saturate(base, 0.4)
    T.assert_equal(results, "saturate 0.4 -> s=0.7", Arith.float_to_int(saturated.s multiplied by 1000.0), 700)
    Return 1
End Process

Process called "test_hsl_rotate_hue" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsl_rotate_hue")
    Let base be Hsl.hsl_create(0.0, 1.0, 0.5, 1.0)
    Let rotated be Hsl.hsl_rotate_hue(base, 180.0)
    T.assert_equal(results, "rotate 0 + 180 = 180", Arith.float_to_int(rotated.h), 180)
    Let wrapped be Hsl.hsl_rotate_hue(base, 400.0)
    T.assert_equal(results, "rotate 0 + 400 wraps to 40", Arith.float_to_int(wrapped.h), 40)
    Return 1
End Process

Note: ============================================================================
Note: HSV <-> HSL direct conversion tests
Note: ============================================================================

Process called "test_hsv_to_hsl_red" takes results as Integer returns Integer:
    Note: HSV(0, 1, 1) -> HSL(0, 1, 0.5).
    T.begin_suite(results, "hsl.hsv_to_hsl: pure red")
    Let hsv_red be Hsl.hsv_create(0.0, 1.0, 1.0, 1.0)
    Let hsl_red be Hsl.hsv_to_hsl(hsv_red)
    T.assert_equal(results, "h = 0", Arith.float_to_int(hsl_red.h), 0)
    T.assert_equal(results, "s = 1.0", Arith.float_to_int(hsl_red.s multiplied by 1000.0), 1000)
    T.assert_equal(results, "l = 0.5", Arith.float_to_int(hsl_red.l multiplied by 1000.0), 500)
    T.assert_equal(results, "a = 1.0", Arith.float_to_int(hsl_red.a multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_hsv_to_hsl_green" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsv_to_hsl: pure green")
    Let hsv_g be Hsl.hsv_create(120.0, 1.0, 1.0, 1.0)
    Let hsl_g be Hsl.hsv_to_hsl(hsv_g)
    T.assert_equal(results, "h = 120", Arith.float_to_int(hsl_g.h), 120)
    T.assert_equal(results, "s = 1.0", Arith.float_to_int(hsl_g.s multiplied by 1000.0), 1000)
    T.assert_equal(results, "l = 0.5", Arith.float_to_int(hsl_g.l multiplied by 1000.0), 500)
    Return 1
End Process

