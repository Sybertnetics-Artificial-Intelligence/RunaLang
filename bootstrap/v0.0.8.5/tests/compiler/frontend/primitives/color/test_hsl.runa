Process called "test_hsv_to_hsl_white" takes results as Integer returns Integer:
    Note: HSV(0, 0, 1) -> HSL(0, 0, 1).
    T.begin_suite(results, "hsl.hsv_to_hsl: white")
    Let hsv_w be Hsl.hsv_create(0.0, 0.0, 1.0, 1.0)
    Let hsl_w be Hsl.hsv_to_hsl(hsv_w)
    T.assert_equal(results, "h = 0", Arith.float_to_int(hsl_w.h), 0)
    T.assert_equal(results, "s = 0", Arith.float_to_int(hsl_w.s multiplied by 1000.0), 0)
    T.assert_equal(results, "l = 1.0", Arith.float_to_int(hsl_w.l multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_hsv_to_hsl_black" takes results as Integer returns Integer:
    Note: HSV(0, 0, 0) -> HSL(0, 0, 0).
    T.begin_suite(results, "hsl.hsv_to_hsl: black")
    Let hsv_k be Hsl.hsv_create(0.0, 0.0, 0.0, 1.0)
    Let hsl_k be Hsl.hsv_to_hsl(hsv_k)
    T.assert_equal(results, "h = 0", Arith.float_to_int(hsl_k.h), 0)
    T.assert_equal(results, "s = 0", Arith.float_to_int(hsl_k.s multiplied by 1000.0), 0)
    T.assert_equal(results, "l = 0", Arith.float_to_int(hsl_k.l multiplied by 1000.0), 0)
    Return 1
End Process

