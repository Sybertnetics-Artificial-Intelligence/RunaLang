Process called "test_hsv_hsl_roundtrip_red" takes results as Integer returns Integer:
    Note: HSV -> HSL -> HSV must be the identity on the unit RGB cube.
    T.begin_suite(results, "hsl.hsv_to_hsl -> hsl_to_hsv: red roundtrip")
    Let hsv_in be Hsl.hsv_create(0.0, 1.0, 1.0, 1.0)
    Let hsl_mid be Hsl.hsv_to_hsl(hsv_in)
    Let hsv_out be Hsl.hsl_to_hsv(hsl_mid)
    T.assert_equal(results, "h preserved", Arith.float_to_int(hsv_out.h), 0)
    T.assert_equal(results, "s preserved", Arith.float_to_int(hsv_out.s multiplied by 1000.0), 1000)
    T.assert_equal(results, "v preserved", Arith.float_to_int(hsv_out.v multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_hsv_hsl_roundtrip_green" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsv_to_hsl -> hsl_to_hsv: green roundtrip")
    Let hsv_in be Hsl.hsv_create(120.0, 1.0, 1.0, 1.0)
    Let hsl_mid be Hsl.hsv_to_hsl(hsv_in)
    Let hsv_out be Hsl.hsl_to_hsv(hsl_mid)
    T.assert_equal(results, "h preserved", Arith.float_to_int(hsv_out.h), 120)
    T.assert_equal(results, "v preserved", Arith.float_to_int(hsv_out.v multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_hsv_hsl_roundtrip_blue" takes results as Integer returns Integer:
    T.begin_suite(results, "hsl.hsv_to_hsl -> hsl_to_hsv: blue roundtrip")
    Let hsv_in be Hsl.hsv_create(240.0, 1.0, 1.0, 1.0)
    Let hsl_mid be Hsl.hsv_to_hsl(hsv_in)
    Let hsv_out be Hsl.hsl_to_hsv(hsl_mid)
    T.assert_equal(results, "h preserved", Arith.float_to_int(hsv_out.h), 240)
    T.assert_equal(results, "v preserved", Arith.float_to_int(hsv_out.v multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_hsv_hsl_roundtrip_gray" takes results as Integer returns Integer:
    Note: Mid-gray has no chroma; only lightness/value should change.
    T.begin_suite(results, "hsl.hsv_to_hsl -> hsl_to_hsv: gray roundtrip")
    Let hsv_in be Hsl.hsv_create(0.0, 0.0, 0.5, 1.0)
    Let hsl_mid be Hsl.hsv_to_hsl(hsv_in)
    Let hsv_out be Hsl.hsl_to_hsv(hsl_mid)
    T.assert_equal(results, "s preserved", Arith.float_to_int(hsv_out.s multiplied by 1000.0), 0)
    T.assert_equal(results, "v preserved", Arith.float_to_int(hsv_out.v multiplied by 1000.0), 500)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_hsl_from_rgb_red(results)
    test_hsl_from_rgb_green(results)
    test_hsl_from_rgb_blue(results)
    test_hsl_grey_saturation(results)
    test_hsv_from_rgb_red(results)
    test_hsl_lighten(results)
    test_hsl_saturate(results)
    test_hsl_rotate_hue(results)

    test_hsv_to_hsl_red(results)
    test_hsv_to_hsl_green(results)
    test_hsv_to_hsl_blue(results)
    test_hsv_to_hsl_white(results)
    test_hsv_to_hsl_black(results)
    test_hsv_to_hsl_mid_gray(results)
    test_hsl_to_hsv_red(results)
    test_hsl_to_hsv_green(results)
    test_hsl_to_hsv_blue(results)
    test_hsl_to_hsv_white(results)
    test_hsl_to_hsv_black(results)
    test_hsl_to_hsv_mid_gray(results)
    test_hsv_hsl_roundtrip_red(results)
    test_hsv_hsl_roundtrip_green(results)
    test_hsv_hsl_roundtrip_blue(results)
    test_hsv_hsl_roundtrip_gray(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
