Note:
Unit tests for compiler/frontend/primitives/color/rgb.runa.

Verifies ColorRgb construction, hex string parse / unparse, sRGB <->
linear transfer, Porter-Duff blending, and linear-space interpolation.

Reference values:
  - srgb(0.5) -> linear ~ 0.214
  - "#ff0000" -> ColorRgb(1.0, 0.0, 0.0, 1.0)
  - "#7f7f7fff" -> 8-digit form parses with alpha = 255/255 = 1.0
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/color/rgb.runa" as Rgb
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Process called "abs_diff_q" takes a as Float, b as Float, quantum as Integer returns Integer:
    Note: Returns absolute difference between a and b scaled by quantum.
    Note: Used by tests to compare floats with integer assertions.
    Let diff be a minus b
    If diff is less than 0.0:
        Set diff to 0.0 minus diff
    End If
    Let scaled be diff multiplied by Arith.int_to_float(quantum)
    Return Arith.float_to_int(scaled)
End Process

Process called "test_rgb_create" takes results as Integer returns Integer:
    T.begin_suite(results, "rgb.rgb_create")
    Let c be Rgb.rgb_create(1.0, 0.0, 0.0, 1.0)
    T.assert_equal(results, "r=1.0 quantum 1000", Arith.float_to_int(c.r multiplied by 1000.0), 1000)
    T.assert_equal(results, "g=0.0 quantum 1000", Arith.float_to_int(c.g multiplied by 1000.0), 0)
    T.assert_equal(results, "b=0.0 quantum 1000", Arith.float_to_int(c.b multiplied by 1000.0), 0)
    T.assert_equal(results, "a=1.0 quantum 1000", Arith.float_to_int(c.a multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_rgb_from_u8" takes results as Integer returns Integer:
    T.begin_suite(results, "rgb.rgb_from_u8")
    Let c be Rgb.rgb_from_u8(255, 0, 0, 255)
    T.assert_equal(results, "u8(255,0,0,255).r=1.0", Arith.float_to_int(c.r multiplied by 1000.0), 1000)
    T.assert_equal(results, "u8(255,0,0,255).g=0", Arith.float_to_int(c.g multiplied by 1000.0), 0)
    Let c2 be Rgb.rgb_from_u8(128, 64, 32, 255)
    Let r_q be Arith.float_to_int(c2.r multiplied by 1000.0)
    T.assert_true(results, "rgb_from_u8(128).r ~ 0.502", abs_diff_q(c2.r, 0.502, 1000) is less than 5)
    Return 1
End Process

Process called "test_channel_to_u8" takes results as Integer returns Integer:
    T.begin_suite(results, "rgb.channel_to_u8")
    T.assert_equal(results, "channel_to_u8(1.0) = 255", Rgb.channel_to_u8(1.0), 255)
    T.assert_equal(results, "channel_to_u8(0.0) = 0", Rgb.channel_to_u8(0.0), 0)
    T.assert_equal(results, "channel_to_u8(0.5) = 128", Rgb.channel_to_u8(0.5), 128)
    T.assert_equal(results, "channel_to_u8(-1.0) = 0 (clamp)", Rgb.channel_to_u8(0.0 minus 1.0), 0)
    T.assert_equal(results, "channel_to_u8(2.0) = 255 (clamp)", Rgb.channel_to_u8(2.0), 255)
    Return 1
End Process

Process called "test_rgb_to_u32" takes results as Integer returns Integer:
    T.begin_suite(results, "rgb.rgb_to_u32")
    Let red be Rgb.rgb_create(1.0, 0.0, 0.0, 1.0)
    Let argb be Rgb.rgb_to_u32_argb(red)
    Note: 0xFFFF0000 = 4294901760
    T.assert_equal(results, "u32_argb(red, opaque) = 0xFFFF0000", argb, 4294901760)
    Let rgba be Rgb.rgb_to_u32_rgba(red)
    Note: 0xFF0000FF = 4278190335
    T.assert_equal(results, "u32_rgba(red, opaque) = 0xFF0000FF", rgba, 4278190335)
    Return 1
End Process

Process called "test_rgb_from_hex_string" takes results as Integer returns Integer:
    T.begin_suite(results, "rgb.rgb_from_hex_string")
    Let red_string be "#ff0000"
    Let red be Rgb.rgb_from_hex_string(red_string)
    T.assert_equal(results, "#ff0000 -> r=1.0", Arith.float_to_int(red.r multiplied by 1000.0), 1000)
    T.assert_equal(results, "#ff0000 -> g=0", Arith.float_to_int(red.g multiplied by 1000.0), 0)
    T.assert_equal(results, "#ff0000 -> b=0", Arith.float_to_int(red.b multiplied by 1000.0), 0)
    T.assert_equal(results, "#ff0000 -> a=1.0", Arith.float_to_int(red.a multiplied by 1000.0), 1000)

    Let short_string be "#0f0"
    Let g_short be Rgb.rgb_from_hex_string(short_string)
    T.assert_equal(results, "#0f0 -> r=0", Arith.float_to_int(g_short.r multiplied by 1000.0), 0)
    T.assert_equal(results, "#0f0 -> g=1", Arith.float_to_int(g_short.g multiplied by 1000.0), 1000)
    T.assert_equal(results, "#0f0 -> b=0", Arith.float_to_int(g_short.b multiplied by 1000.0), 0)

    Let alpha_string be "#00ff00ff"
    Let g_alpha be Rgb.rgb_from_hex_string(alpha_string)
    T.assert_equal(results, "#00ff00ff -> g=1", Arith.float_to_int(g_alpha.g multiplied by 1000.0), 1000)
    T.assert_equal(results, "#00ff00ff -> a=1", Arith.float_to_int(g_alpha.a multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_srgb_to_linear_kat" takes results as Integer returns Integer:
    T.begin_suite(results, "rgb.srgb_to_linear KAT 0.5 -> 0.214")
    Let lin be Rgb.srgb_to_linear(0.5)
    Note: Reference: srgb(0.5) ~ 0.2140 (in linear space)
    T.assert_true(results, "srgb(0.5) ~ 0.2140 within +/-0.005", abs_diff_q(lin, 0.2140, 1000) is less than 5)
    T.assert_equal(results, "srgb(0.0) = 0.0", Arith.float_to_int(Rgb.srgb_to_linear(0.0) multiplied by 1000.0), 0)
    T.assert_equal(results, "srgb(1.0) = 1.0", Arith.float_to_int(Rgb.srgb_to_linear(1.0) multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_linear_to_srgb_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "rgb.linear_to_srgb (round-trip)")
    Let lin be Rgb.srgb_to_linear(0.7)
    Let back be Rgb.linear_to_srgb(lin)
    T.assert_true(results, "roundtrip 0.7 within +/-0.005", abs_diff_q(back, 0.7, 1000) is less than 5)
    Return 1
End Process

Process called "test_rgb_blend" takes results as Integer returns Integer:
    T.begin_suite(results, "rgb.rgb_blend Porter-Duff over")
    Let top be Rgb.rgb_create(1.0, 0.0, 0.0, 1.0)
    Let base be Rgb.rgb_create(0.0, 1.0, 0.0, 1.0)
    Let blended be Rgb.rgb_blend(top, base, 1.0)
    Note: Full opacity top covers base completely
    T.assert_equal(results, "over full alpha: r=1", Arith.float_to_int(blended.r multiplied by 1000.0), 1000)
    T.assert_equal(results, "over full alpha: g=0", Arith.float_to_int(blended.g multiplied by 1000.0), 0)
    Let half_blend be Rgb.rgb_blend(top, base, 0.0)
    T.assert_equal(results, "over zero alpha: g=1", Arith.float_to_int(half_blend.g multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "test_rgb_premultiply" takes results as Integer returns Integer:
    T.begin_suite(results, "rgb.rgb_premultiply")
    Let c be Rgb.rgb_create(1.0, 1.0, 1.0, 0.5)
    Let pm be Rgb.rgb_premultiply(c)
    T.assert_equal(results, "premul r = 0.5", Arith.float_to_int(pm.r multiplied by 1000.0), 500)
    T.assert_equal(results, "premul alpha preserved", Arith.float_to_int(pm.a multiplied by 1000.0), 500)
    Let back be Rgb.rgb_unpremultiply(pm)
    T.assert_equal(results, "unpremul r = 1.0", Arith.float_to_int(back.r multiplied by 1000.0), 1000)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_rgb_create(results)
    test_rgb_from_u8(results)
    test_channel_to_u8(results)
    test_rgb_to_u32(results)
    test_rgb_from_hex_string(results)
    test_srgb_to_linear_kat(results)
    test_linear_to_srgb_roundtrip(results)
    test_rgb_blend(results)
    test_rgb_premultiply(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
