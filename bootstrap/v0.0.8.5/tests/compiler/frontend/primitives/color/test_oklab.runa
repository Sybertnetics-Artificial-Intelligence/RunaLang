Note:
Unit tests for compiler/frontend/primitives/color/oklab.runa.

KAT (Known Answer Test) reference values per Ottosson 2020:
  - rgb(1, 0, 0) -> oklab ~ (0.628, 0.225, 0.126)
  - rgb(0, 1, 0) -> oklab ~ (0.866, -0.234, 0.179)
  - rgb(0, 0, 1) -> oklab ~ (0.452, -0.032, -0.312)
  - rgb(1, 1, 1) -> oklab ~ (1.000, 0.000, 0.000)
  - rgb(0, 0, 0) -> oklab ~ (0, 0, 0)
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/color/oklab.runa" as Oklab
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Arith

Process called "abs_diff_q" takes a as Float, b as Float, quantum as Integer returns Integer:
    Let diff be a minus b
    If diff is less than 0.0:
        Set diff to 0.0 minus diff
    End If
    Return Arith.float_to_int(diff multiplied by Arith.int_to_float(quantum))
End Process

Process called "test_oklab_red_kat" takes results as Integer returns Integer:
    T.begin_suite(results, "oklab.rgb_to_oklab red KAT")
    Let lab_red be Oklab.rgb_to_oklab(1.0, 0.0, 0.0)
    Note: Reference: rgb(1,0,0) -> oklab ~ (0.628, 0.225, 0.126)
    T.assert_true(results, "oklab.L ~ 0.628", abs_diff_q(lab_red.l, 0.628, 100) is less than 5)
    T.assert_true(results, "oklab.a ~ 0.225", abs_diff_q(lab_red.a, 0.225, 100) is less than 5)
    T.assert_true(results, "oklab.b ~ 0.126", abs_diff_q(lab_red.b, 0.126, 100) is less than 5)
    Return 1
End Process

Process called "test_oklab_green_kat" takes results as Integer returns Integer:
    T.begin_suite(results, "oklab.rgb_to_oklab green KAT")
    Let lab_green be Oklab.rgb_to_oklab(0.0, 1.0, 0.0)
    Note: Reference: rgb(0,1,0) -> oklab ~ (0.866, -0.234, 0.179)
    T.assert_true(results, "oklab.L ~ 0.866", abs_diff_q(lab_green.l, 0.866, 100) is less than 5)
    T.assert_true(results, "oklab.a ~ -0.234", abs_diff_q(lab_green.a, 0.0 minus 0.234, 100) is less than 5)
    T.assert_true(results, "oklab.b ~ 0.179", abs_diff_q(lab_green.b, 0.179, 100) is less than 5)
    Return 1
End Process

Process called "test_oklab_blue_kat" takes results as Integer returns Integer:
    T.begin_suite(results, "oklab.rgb_to_oklab blue KAT")
    Let lab_blue be Oklab.rgb_to_oklab(0.0, 0.0, 1.0)
    Note: Reference: rgb(0,0,1) -> oklab ~ (0.452, -0.032, -0.312)
    T.assert_true(results, "oklab.L ~ 0.452", abs_diff_q(lab_blue.l, 0.452, 100) is less than 5)
    Return 1
End Process

Process called "test_oklab_black" takes results as Integer returns Integer:
    T.begin_suite(results, "oklab.rgb_to_oklab black")
    Let lab_black be Oklab.rgb_to_oklab(0.0, 0.0, 0.0)
    T.assert_true(results, "oklab.L ~ 0", abs_diff_q(lab_black.l, 0.0, 100) is less than 5)
    T.assert_true(results, "oklab.a ~ 0", abs_diff_q(lab_black.a, 0.0, 100) is less than 5)
    T.assert_true(results, "oklab.b ~ 0", abs_diff_q(lab_black.b, 0.0, 100) is less than 5)
    Return 1
End Process

Process called "test_oklab_to_oklch" takes results as Integer returns Integer:
    T.begin_suite(results, "oklab.oklab_to_oklch")
    Let lab_red be Oklab.rgb_to_oklab(1.0, 0.0, 0.0)
    Let lch_red be Oklab.oklab_to_oklch(lab_red)
    Note: Chroma = sqrt(0.225^2 + 0.126^2) ~ 0.258
    T.assert_true(results, "oklch.C ~ 0.258", abs_diff_q(lch_red.c, 0.258, 100) is less than 5)
    Return 1
End Process

Process called "test_oklab_delta_e" takes results as Integer returns Integer:
    T.begin_suite(results, "oklab.oklab_delta_e")
    Let a be Oklab.oklab_create(0.5, 0.0, 0.0)
    Let b be Oklab.oklab_create(0.5, 0.0, 0.0)
    Let d_same be Oklab.oklab_delta_e(a, b)
    T.assert_equal(results, "delta_e(equal) = 0", Arith.float_to_int(d_same), 0)
    Let c be Oklab.oklab_create(0.5, 0.1, 0.0)
    Let d_simple be Oklab.oklab_delta_e(a, c)
    T.assert_equal(results, "delta_e a=(0.5,0,0) vs (0.5,0.1,0) = 0.1 (~100 milli)", Arith.float_to_int(d_simple multiplied by 1000.0), 100)
    Return 1
End Process

Process called "test_oklch_rotate_hue" takes results as Integer returns Integer:
    T.begin_suite(results, "oklab.oklch_rotate_hue")
    Let base be Oklab.oklch_create(0.5, 0.2, 0.0)
    Let rotated be Oklab.oklch_rotate_hue(base, 180.0)
    T.assert_equal(results, "rotate 0+180 = 180", Arith.float_to_int(rotated.h), 180)
    Let wrapped be Oklab.oklch_rotate_hue(base, 400.0)
    T.assert_equal(results, "rotate 0+400 wraps to 40", Arith.float_to_int(wrapped.h), 40)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_oklab_red_kat(results)
    test_oklab_green_kat(results)
    test_oklab_blue_kat(results)
    test_oklab_black(results)
    test_oklab_to_oklch(results)
    test_oklab_delta_e(results)
    test_oklch_rotate_hue(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
