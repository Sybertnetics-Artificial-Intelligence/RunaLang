Note:
Unit tests for compiler/frontend/primitives/core/bytes.runa.
Covers: hex/base64/base58 round-trip, slicing, comparison.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/core/bytes.runa" as B
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Process called "test_bytes_create_and_length" that takes results as Integer returns Integer:
    T.begin_suite(results, "bytes.create_and_length")
    Let b1 be B.bytes_create(5, 0)
    T.assert_not_null(results, "create(5)", b1)
    T.assert_equal(results, "length(5)", B.bytes_length(b1), 5)
    T.assert_equal(results, "first byte is 0", B.bytes_at(b1, 0), 0)
    T.assert_equal(results, "last byte is 0", B.bytes_at(b1, 4), 0)
    T.assert_equal(results, "out-of-bounds returns -1", B.bytes_at(b1, 5), -1)
    B.bytes_destroy(b1)

    Let b2 be B.bytes_create(3, 65)
    T.assert_equal(results, "filled byte 0", B.bytes_at(b2, 0), 65)
    T.assert_equal(results, "filled byte 1", B.bytes_at(b2, 1), 65)
    T.assert_equal(results, "filled byte 2", B.bytes_at(b2, 2), 65)
    B.bytes_destroy(b2)
    Return 1
End Process

Process called "test_bytes_from_array" that takes results as Integer returns Integer:
    T.begin_suite(results, "bytes.from_array")
    Let raw be allocate(4)
    Memory.memory_set_byte(raw, 0, 1)
    Memory.memory_set_byte(raw, 1, 2)
    Memory.memory_set_byte(raw, 2, 3)
    Memory.memory_set_byte(raw, 3, 4)
    Let b be B.bytes_from_array(raw, 4)
    T.assert_equal(results, "len=4", B.bytes_length(b), 4)
    T.assert_equal(results, "b[0]=1", B.bytes_at(b, 0), 1)
    T.assert_equal(results, "b[1]=2", B.bytes_at(b, 1), 2)
    T.assert_equal(results, "b[3]=4", B.bytes_at(b, 3), 4)
    B.bytes_destroy(b)
    deallocate(raw)
    Return 1
End Process

Process called "test_bytes_hex_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "bytes.hex_roundtrip")
    Note: Deadbeef = 0xDE 0xAD 0xBE 0xEF
    Let b be B.bytes_from_hex_string("deadbeef")
    T.assert_not_null(results, "parsed deadbeef", b)
    T.assert_equal(results, "len=4", B.bytes_length(b), 4)
    T.assert_equal(results, "b[0]=0xDE", B.bytes_at(b, 0), 222)
    T.assert_equal(results, "b[1]=0xAD", B.bytes_at(b, 1), 173)
    T.assert_equal(results, "b[2]=0xBE", B.bytes_at(b, 2), 190)
    T.assert_equal(results, "b[3]=0xEF", B.bytes_at(b, 3), 239)

    Let s be B.bytes_to_hex_string(b)
    T.assert_not_null(results, "got hex string", s)
    Let dst_first be Memory.memory_get_byte(s, 0)
    T.assert_equal(results, "char 0 = 'd'", dst_first, 100)
    Let dst_last be Memory.memory_get_byte(s, 7)
    T.assert_equal(results, "char 7 = 'f'", dst_last, 102)

    Let b2 be B.bytes_from_hex_string(s)
    T.assert_equal(results, "round-trip equal", B.bytes_equal(b, b2), 1)

    B.bytes_destroy(b)
    B.bytes_destroy(b2)
    deallocate(s)

    Note: Mixed case
    Let b3 be B.bytes_from_hex_string("DeAdBeEf")
    T.assert_not_null(results, "mixed-case parse", b3)
    T.assert_equal(results, "mixed-case b[0]", B.bytes_at(b3, 0), 222)
    B.bytes_destroy(b3)

    Note: Odd-length rejected
    Let b4 be B.bytes_from_hex_string("abc")
    T.assert_equal(results, "odd length rejected", b4, 0)

    Note: Invalid char rejected
    Let b5 be B.bytes_from_hex_string("zz")
    T.assert_equal(results, "invalid char rejected", b5, 0)
    Return 1
End Process

Process called "test_bytes_base64_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "bytes.base64_roundtrip")
    Note: "Man" -> "TWFu"
    Let raw be allocate(3)
    Memory.memory_set_byte(raw, 0, 77)
    Memory.memory_set_byte(raw, 1, 97)
    Memory.memory_set_byte(raw, 2, 110)
    Let b be B.bytes_from_array(raw, 3)
    Let s be B.bytes_to_base64(b)
    T.assert_not_null(results, "encoded", s)
    T.assert_equal(results, "char 0 = 'T'", Memory.memory_get_byte(s, 0), 84)
    T.assert_equal(results, "char 1 = 'W'", Memory.memory_get_byte(s, 1), 87)
    T.assert_equal(results, "char 2 = 'F'", Memory.memory_get_byte(s, 2), 70)
    T.assert_equal(results, "char 3 = 'u'", Memory.memory_get_byte(s, 3), 117)
    T.assert_equal(results, "char 4 = NUL", Memory.memory_get_byte(s, 4), 0)

    Note: "Ma" -> "TWE="
    Let raw2 be allocate(2)
    Memory.memory_set_byte(raw2, 0, 77)
    Memory.memory_set_byte(raw2, 1, 97)
    Let b2 be B.bytes_from_array(raw2, 2)
    Let s2 be B.bytes_to_base64(b2)
    T.assert_equal(results, "padding 1 = '='", Memory.memory_get_byte(s2, 3), 61)

    Note: Round-trip
    Let b3 be B.bytes_from_base64(s)
    T.assert_equal(results, "round-trip equal (Man)", B.bytes_equal(b, b3), 1)

    B.bytes_destroy(b)
    B.bytes_destroy(b2)
    B.bytes_destroy(b3)
    deallocate(raw)
    deallocate(raw2)
    deallocate(s)
    deallocate(s2)
    Return 1
End Process

Process called "test_bytes_base58" that takes results as Integer returns Integer:
    T.begin_suite(results, "bytes.base58")
    Note: Bytes [0x00, 0x00, 0x01] should produce "112" in base58
    Note: (two leading zero bytes -> two '1's, then 0x01 -> '2')
    Let raw be allocate(3)
    Memory.memory_set_byte(raw, 0, 0)
    Memory.memory_set_byte(raw, 1, 0)
    Memory.memory_set_byte(raw, 2, 1)
    Let b be B.bytes_from_array(raw, 3)
    Let s be B.bytes_to_base58(b)
    T.assert_not_null(results, "encoded", s)
    T.assert_equal(results, "char 0 = '1'", Memory.memory_get_byte(s, 0), 49)
    T.assert_equal(results, "char 1 = '1'", Memory.memory_get_byte(s, 1), 49)
    T.assert_equal(results, "char 2 = '2'", Memory.memory_get_byte(s, 2), 50)
    B.bytes_destroy(b)
    deallocate(raw)
    deallocate(s)
    Return 1
End Process

Process called "test_bytes_slice" that takes results as Integer returns Integer:
    T.begin_suite(results, "bytes.slice")
    Let raw be allocate(6)
    Memory.memory_set_byte(raw, 0, 10)
    Memory.memory_set_byte(raw, 1, 20)
    Memory.memory_set_byte(raw, 2, 30)
    Memory.memory_set_byte(raw, 3, 40)
    Memory.memory_set_byte(raw, 4, 50)
    Memory.memory_set_byte(raw, 5, 60)
    Let b be B.bytes_from_array(raw, 6)

    Let s1 be B.bytes_slice(b, 1, 4)
    T.assert_equal(results, "slice len = 3", B.bytes_length(s1), 3)
    T.assert_equal(results, "slice[0] = 20", B.bytes_at(s1, 0), 20)
    T.assert_equal(results, "slice[1] = 30", B.bytes_at(s1, 1), 30)
    T.assert_equal(results, "slice[2] = 40", B.bytes_at(s1, 2), 40)

    Let s_empty be B.bytes_slice(b, 2, 2)
    T.assert_equal(results, "empty slice len = 0", B.bytes_length(s_empty), 0)

    Let s_bad be B.bytes_slice(b, 4, 2)
    T.assert_equal(results, "reversed slice = null", s_bad, 0)

    B.bytes_destroy(b)
    B.bytes_destroy(s1)
    B.bytes_destroy(s_empty)
    deallocate(raw)
    Return 1
End Process

Process called "test_bytes_equal_compare" that takes results as Integer returns Integer:
    T.begin_suite(results, "bytes.equal_and_compare")
    Let b1 be B.bytes_from_hex_string("0102")
    Let b2 be B.bytes_from_hex_string("0102")
    Let b3 be B.bytes_from_hex_string("0103")
    Let b4 be B.bytes_from_hex_string("010203")

    T.assert_equal(results, "b1 == b2", B.bytes_equal(b1, b2), 1)
    T.assert_equal(results, "b1 != b3", B.bytes_equal(b1, b3), 0)
    T.assert_equal(results, "b1 != b4 (length)", B.bytes_equal(b1, b4), 0)

    T.assert_equal(results, "ct b1 == b2", B.bytes_equal_constant_time(b1, b2), 1)
    T.assert_equal(results, "ct b1 != b3", B.bytes_equal_constant_time(b1, b3), 0)

    T.assert_equal(results, "compare b1,b2 = 0", B.bytes_compare(b1, b2), 0)
    T.assert_equal(results, "compare b1,b3 = -1", B.bytes_compare(b1, b3), -1)
    T.assert_equal(results, "compare b3,b1 = 1", B.bytes_compare(b3, b1), 1)
    T.assert_equal(results, "compare b1,b4 = -1 (shorter)", B.bytes_compare(b1, b4), -1)

    B.bytes_destroy(b1)
    B.bytes_destroy(b2)
    B.bytes_destroy(b3)
    B.bytes_destroy(b4)
    Return 1
End Process

Process called "test_byte_buffer" that takes results as Integer returns Integer:
    T.begin_suite(results, "byte_buffer")
    Let buf be B.byte_buffer_create(0)
    T.assert_not_null(results, "create", buf)
    T.assert_equal(results, "initial length", B.byte_buffer_length(buf), 0)

    B.byte_buffer_append_byte(buf, 1)
    B.byte_buffer_append_byte(buf, 2)
    B.byte_buffer_append_byte(buf, 3)
    T.assert_equal(results, "after 3 appends", B.byte_buffer_length(buf), 3)
    T.assert_equal(results, "at(0)", B.byte_buffer_at(buf, 0), 1)
    T.assert_equal(results, "at(2)", B.byte_buffer_at(buf, 2), 3)

    B.byte_buffer_append_u32_le(buf, 305419896)
    T.assert_equal(results, "after u32_le", B.byte_buffer_length(buf), 7)
    Note: 0x12345678 LE = 78 56 34 12
    T.assert_equal(results, "u32 b0=0x78", B.byte_buffer_at(buf, 3), 120)
    T.assert_equal(results, "u32 b1=0x56", B.byte_buffer_at(buf, 4), 86)
    T.assert_equal(results, "u32 b2=0x34", B.byte_buffer_at(buf, 5), 52)
    T.assert_equal(results, "u32 b3=0x12", B.byte_buffer_at(buf, 6), 18)

    Let frozen be B.byte_buffer_to_bytes(buf)
    T.assert_equal(results, "frozen length", B.bytes_length(frozen), 7)
    T.assert_equal(results, "frozen[6]", B.bytes_at(frozen, 6), 18)
    B.bytes_destroy(frozen)

    B.byte_buffer_clear(buf)
    T.assert_equal(results, "after clear", B.byte_buffer_length(buf), 0)

    B.byte_buffer_destroy(buf)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_bytes_create_and_length(results)
    test_bytes_from_array(results)
    test_bytes_hex_roundtrip(results)
    test_bytes_base64_roundtrip(results)
    test_bytes_base58(results)
    test_bytes_slice(results)
    test_bytes_equal_compare(results)
    test_byte_buffer(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
