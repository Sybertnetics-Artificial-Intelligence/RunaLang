Note:
Unit tests for compiler/frontend/primitives/core/string_core.runa
char_to_string - the canonical RFC 3629 UTF-8 encoder (task #465).
Known-answer tests covering every encoder branch: 1-byte ASCII,
2-byte (U+0080..U+07FF), 3-byte (U+0800..U+FFFF), 4-byte
(U+10000..U+10FFFF), the exact range boundaries on both sides of
each width transition, UTF-16 surrogate rejection (U+D800..U+DFFF
to U+FFFD), out-of-range rejection (negative and above U+10FFFF to
U+FFFD), and NUL (code point 0) handling.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/core/string_core.runa" as SC
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Process called "test_ascii_one_byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_to_string.ascii_one_byte")

    Note: KAT: 'A' (U+0041) encodes as the single byte 0x41
    Let s be SC.char_to_string(65)
    T.assert_not_null(results, "A: allocation", s)
    T.assert_equal(results, "A: byte0=0x41", Memory.memory_get_byte(s, 0), 65)
    T.assert_equal(results, "A: NUL terminator", Memory.memory_get_byte(s, 1), 0)
    T.assert_equal(results, "A: string_length=1", SC.string_length(s), 1)
    Layout.deallocate(s)

    Note: KAT: U+007F (DEL) is the upper boundary of the 1-byte range
    Let hi1 be SC.char_to_string(127)
    T.assert_equal(results, "U+007F: byte0=0x7F", Memory.memory_get_byte(hi1, 0), 127)
    T.assert_equal(results, "U+007F: NUL terminator", Memory.memory_get_byte(hi1, 1), 0)
    Layout.deallocate(hi1)
    Return 1
End Process

Process called "test_two_byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_to_string.two_byte")

    Note: KAT: U+00E9 (e-acute) encodes as 0xC3 0xA9
    Let s be SC.char_to_string(233)
    T.assert_not_null(results, "U+00E9: allocation", s)
    T.assert_equal(results, "U+00E9: byte0=0xC3", Memory.memory_get_byte(s, 0), 195)
    T.assert_equal(results, "U+00E9: byte1=0xA9", Memory.memory_get_byte(s, 1), 169)
    T.assert_equal(results, "U+00E9: NUL terminator", Memory.memory_get_byte(s, 2), 0)
    T.assert_equal(results, "U+00E9: string_length=2", SC.string_length(s), 2)
    Layout.deallocate(s)

    Note: KAT: U+0080 is the lower boundary of the 2-byte range: 0xC2 0x80
    Let lo2 be SC.char_to_string(128)
    T.assert_equal(results, "U+0080: byte0=0xC2", Memory.memory_get_byte(lo2, 0), 194)
    T.assert_equal(results, "U+0080: byte1=0x80", Memory.memory_get_byte(lo2, 1), 128)
    Layout.deallocate(lo2)

    Note: KAT: U+07FF is the upper boundary of the 2-byte range: 0xDF 0xBF
    Let hi2 be SC.char_to_string(2047)
    T.assert_equal(results, "U+07FF: byte0=0xDF", Memory.memory_get_byte(hi2, 0), 223)
    T.assert_equal(results, "U+07FF: byte1=0xBF", Memory.memory_get_byte(hi2, 1), 191)
    Layout.deallocate(hi2)
    Return 1
End Process

Process called "test_three_byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_to_string.three_byte")

    Note: KAT: U+20AC (Euro sign) encodes as 0xE2 0x82 0xAC
    Let s be SC.char_to_string(8364)
    T.assert_not_null(results, "U+20AC: allocation", s)
    T.assert_equal(results, "U+20AC: byte0=0xE2", Memory.memory_get_byte(s, 0), 226)
    T.assert_equal(results, "U+20AC: byte1=0x82", Memory.memory_get_byte(s, 1), 130)
    T.assert_equal(results, "U+20AC: byte2=0xAC", Memory.memory_get_byte(s, 2), 172)
    T.assert_equal(results, "U+20AC: NUL terminator", Memory.memory_get_byte(s, 3), 0)
    T.assert_equal(results, "U+20AC: string_length=3", SC.string_length(s), 3)
    Layout.deallocate(s)

    Note: KAT: U+0800 is the lower boundary of the 3-byte range: 0xE0 0xA0 0x80
    Let lo3 be SC.char_to_string(2048)
    T.assert_equal(results, "U+0800: byte0=0xE0", Memory.memory_get_byte(lo3, 0), 224)
    T.assert_equal(results, "U+0800: byte1=0xA0", Memory.memory_get_byte(lo3, 1), 160)
    T.assert_equal(results, "U+0800: byte2=0x80", Memory.memory_get_byte(lo3, 2), 128)
    Layout.deallocate(lo3)

    Note: KAT: U+FFFF is the upper boundary of the 3-byte range: 0xEF 0xBF 0xBF
    Let hi3 be SC.char_to_string(65535)
    T.assert_equal(results, "U+FFFF: byte0=0xEF", Memory.memory_get_byte(hi3, 0), 239)
    T.assert_equal(results, "U+FFFF: byte1=0xBF", Memory.memory_get_byte(hi3, 1), 191)
    T.assert_equal(results, "U+FFFF: byte2=0xBF", Memory.memory_get_byte(hi3, 2), 191)
    Layout.deallocate(hi3)
    Return 1
End Process

Process called "test_four_byte" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_to_string.four_byte")

    Note: KAT: U+1F600 (grinning face emoji) encodes as 0xF0 0x9F 0x98 0x80
    Let s be SC.char_to_string(128512)
    T.assert_not_null(results, "U+1F600: allocation", s)
    T.assert_equal(results, "U+1F600: byte0=0xF0", Memory.memory_get_byte(s, 0), 240)
    T.assert_equal(results, "U+1F600: byte1=0x9F", Memory.memory_get_byte(s, 1), 159)
    T.assert_equal(results, "U+1F600: byte2=0x98", Memory.memory_get_byte(s, 2), 152)
    T.assert_equal(results, "U+1F600: byte3=0x80", Memory.memory_get_byte(s, 3), 128)
    T.assert_equal(results, "U+1F600: NUL terminator", Memory.memory_get_byte(s, 4), 0)
    T.assert_equal(results, "U+1F600: string_length=4", SC.string_length(s), 4)
    Layout.deallocate(s)

    Note: KAT: U+10000 is the lower boundary of the 4-byte range: 0xF0 0x90 0x80 0x80
    Let lo4 be SC.char_to_string(65536)
    T.assert_equal(results, "U+10000: byte0=0xF0", Memory.memory_get_byte(lo4, 0), 240)
    T.assert_equal(results, "U+10000: byte1=0x90", Memory.memory_get_byte(lo4, 1), 144)
    T.assert_equal(results, "U+10000: byte2=0x80", Memory.memory_get_byte(lo4, 2), 128)
    T.assert_equal(results, "U+10000: byte3=0x80", Memory.memory_get_byte(lo4, 3), 128)
    Layout.deallocate(lo4)

    Note: KAT: U+10FFFF is the absolute Unicode ceiling: 0xF4 0x8F 0xBF 0xBF
    Let hi4 be SC.char_to_string(1114111)
    T.assert_equal(results, "U+10FFFF: byte0=0xF4", Memory.memory_get_byte(hi4, 0), 244)
    T.assert_equal(results, "U+10FFFF: byte1=0x8F", Memory.memory_get_byte(hi4, 1), 143)
    T.assert_equal(results, "U+10FFFF: byte2=0xBF", Memory.memory_get_byte(hi4, 2), 191)
    T.assert_equal(results, "U+10FFFF: byte3=0xBF", Memory.memory_get_byte(hi4, 3), 191)
    Layout.deallocate(hi4)
    Return 1
End Process

Process called "test_surrogates_to_replacement" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_to_string.surrogates")

    Note: KAT: U+D800 (high surrogate floor) must encode as U+FFFD (0xEF 0xBF 0xBD)
    Let lo_s be SC.char_to_string(55296)
    T.assert_not_null(results, "U+D800: allocation", lo_s)
    T.assert_equal(results, "U+D800: byte0=0xEF", Memory.memory_get_byte(lo_s, 0), 239)
    T.assert_equal(results, "U+D800: byte1=0xBF", Memory.memory_get_byte(lo_s, 1), 191)
    T.assert_equal(results, "U+D800: byte2=0xBD", Memory.memory_get_byte(lo_s, 2), 189)
    T.assert_equal(results, "U+D800: NUL terminator", Memory.memory_get_byte(lo_s, 3), 0)
    Layout.deallocate(lo_s)

    Note: KAT: U+DFFF (low surrogate ceiling) must also encode as U+FFFD
    Let hi_s be SC.char_to_string(57343)
    T.assert_equal(results, "U+DFFF: byte0=0xEF", Memory.memory_get_byte(hi_s, 0), 239)
    T.assert_equal(results, "U+DFFF: byte1=0xBF", Memory.memory_get_byte(hi_s, 1), 191)
    T.assert_equal(results, "U+DFFF: byte2=0xBD", Memory.memory_get_byte(hi_s, 2), 189)
    Layout.deallocate(hi_s)

    Note: KAT: U+D7FF (just below the surrogate block) is a VALID 3-byte char: 0xED 0x9F 0xBF
    Let below be SC.char_to_string(55295)
    T.assert_equal(results, "U+D7FF: byte0=0xED", Memory.memory_get_byte(below, 0), 237)
    T.assert_equal(results, "U+D7FF: byte1=0x9F", Memory.memory_get_byte(below, 1), 159)
    T.assert_equal(results, "U+D7FF: byte2=0xBF", Memory.memory_get_byte(below, 2), 191)
    Layout.deallocate(below)

    Note: KAT: U+E000 (just above the surrogate block) is a VALID 3-byte char: 0xEE 0x80 0x80
    Let above be SC.char_to_string(57344)
    T.assert_equal(results, "U+E000: byte0=0xEE", Memory.memory_get_byte(above, 0), 238)
    T.assert_equal(results, "U+E000: byte1=0x80", Memory.memory_get_byte(above, 1), 128)
    T.assert_equal(results, "U+E000: byte2=0x80", Memory.memory_get_byte(above, 2), 128)
    Layout.deallocate(above)
    Return 1
End Process

Process called "test_out_of_range_to_replacement" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_to_string.out_of_range")

    Note: KAT: U+110000 (one past the Unicode ceiling) must encode as U+FFFD
    Let just_over be SC.char_to_string(1114112)
    T.assert_not_null(results, "U+110000: allocation", just_over)
    T.assert_equal(results, "U+110000: byte0=0xEF", Memory.memory_get_byte(just_over, 0), 239)
    T.assert_equal(results, "U+110000: byte1=0xBF", Memory.memory_get_byte(just_over, 1), 191)
    T.assert_equal(results, "U+110000: byte2=0xBD", Memory.memory_get_byte(just_over, 2), 189)
    Layout.deallocate(just_over)

    Note: KAT: an arbitrary huge value must also encode as U+FFFD
    Let huge be SC.char_to_string(2097152)
    T.assert_equal(results, "huge: byte0=0xEF", Memory.memory_get_byte(huge, 0), 239)
    T.assert_equal(results, "huge: byte1=0xBF", Memory.memory_get_byte(huge, 1), 191)
    T.assert_equal(results, "huge: byte2=0xBD", Memory.memory_get_byte(huge, 2), 189)
    Layout.deallocate(huge)

    Note: KAT: negative code points must encode as U+FFFD
    Let negative be SC.char_to_string(0 minus 1)
    T.assert_equal(results, "negative: byte0=0xEF", Memory.memory_get_byte(negative, 0), 239)
    T.assert_equal(results, "negative: byte1=0xBF", Memory.memory_get_byte(negative, 1), 191)
    T.assert_equal(results, "negative: byte2=0xBD", Memory.memory_get_byte(negative, 2), 189)
    Layout.deallocate(negative)
    Return 1
End Process

Process called "test_nul_handling" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_to_string.nul")

    Note: KAT: code point 0 yields a real allocation whose first byte is NUL,
    Note: so string_length sees an empty C string but the buffer is valid and owned.
    Let s be SC.char_to_string(0)
    T.assert_not_null(results, "NUL: allocation is non-null", s)
    T.assert_equal(results, "NUL: byte0=0x00", Memory.memory_get_byte(s, 0), 0)
    T.assert_equal(results, "NUL: byte1=0x00 terminator", Memory.memory_get_byte(s, 1), 0)
    T.assert_equal(results, "NUL: string_length=0", SC.string_length(s), 0)
    Layout.deallocate(s)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_ascii_one_byte(results)
    test_two_byte(results)
    test_three_byte(results)
    test_four_byte(results)
    test_surrogates_to_replacement(results)
    test_out_of_range_to_replacement(results)
    test_nul_handling(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
