Note:
Bitwise shift-operation probe (Task #496 internal-primitive batch).

This probe exercises the REAL behavior of the canonical shift operations added
to bitwise_core.runa (bitwise_shift_left / bitwise_shift_right) — not merely
that they link — to prove the shift semantics are correct, including the edge
cases that matter for the hash_utils.hash_compute_combine caller and for any
logical-unsigned shift consumer:

  1. Left shift basic: 1 << 4 = 16, 3 << 5 = 96.
  2. Right shift basic (logical, zero-filled): 256 >> 4 = 16, 96 >> 5 = 3.
  3. Edge case shift by 0: x << 0 == x and x >> 0 == x (identity).
  4. Edge case shift by 63: 1 << 63 produces the high-bit pattern
     0x8000000000000000 (the most-negative two's-complement value), and that
     same value >> 63 (LOGICAL) yields 1 (NOT -1 — logical fill, not sign fill).
  5. Logical right-shift of a high-bit value: 0x8000000000000000 >> 1 ==
     0x4000000000000000 (zero-filled high bit, stays positive). An arithmetic
     shift would have produced 0xC000000000000000 (negative); proving the high
     bit is zero-filled is the load-bearing distinction.
  6. Round-trip with the hash combine pattern: (h << 5) recovered by (>> 5).

PASS criterion: every assertion passes and the suite prints its summary with a
clean exit code.
:End Note

Import "tests/test_utils.runa" as TestUtils
Import "compiler/frontend/primitives/core/bitwise_core.runa" as BitwiseCore

Process called "main" returns Integer:
    Let results be proc create_test_results from TestUtils
    proc begin_suite from TestUtils with results, "bitwise_shift_probe"

    Note: ---- 1. Left shift basic ----
    Let ls1 be proc bitwise_shift_left from BitwiseCore with 1, 4
    proc assert_equal from TestUtils with results, "1 << 4 == 16", ls1, 16

    Let ls2 be proc bitwise_shift_left from BitwiseCore with 3, 5
    proc assert_equal from TestUtils with results, "3 << 5 == 96", ls2, 96

    Note: ---- 2. Right shift basic (logical) ----
    Let rs1 be proc bitwise_shift_right from BitwiseCore with 256, 4
    proc assert_equal from TestUtils with results, "256 >> 4 == 16", rs1, 16

    Let rs2 be proc bitwise_shift_right from BitwiseCore with 96, 5
    proc assert_equal from TestUtils with results, "96 >> 5 == 3", rs2, 3

    Note: ---- 3. Edge case: shift by 0 is identity ----
    Let id_left be proc bitwise_shift_left from BitwiseCore with 12345, 0
    proc assert_equal from TestUtils with results, "x << 0 == x", id_left, 12345

    Let id_right be proc bitwise_shift_right from BitwiseCore with 12345, 0
    proc assert_equal from TestUtils with results, "x >> 0 == x", id_right, 12345

    Note: ---- 4. Edge case: shift by 63 ----
    Note: 1 << 63 sets the high bit -> 0x8000000000000000, the most-negative
    Note: two's-complement 64-bit value.
    Let high_bit be proc bitwise_shift_left from BitwiseCore with 1, 63
    Let expected_high be 0x8000000000000000
    proc assert_equal from TestUtils with results, "1 << 63 == 0x8000000000000000", high_bit, expected_high

    Note: That high-bit value logically shifted right by 63 yields 1 (zero-fill),
    Note: NOT -1 (which an arithmetic/sign-extending shift would give).
    Let back_to_one be proc bitwise_shift_right from BitwiseCore with high_bit, 63
    proc assert_equal from TestUtils with results, "0x8000000000000000 >> 63 == 1 (logical)", back_to_one, 1

    Note: ---- 5. Logical right-shift of a high-bit value (zero-fill proof) ----
    Let half_high be proc bitwise_shift_right from BitwiseCore with high_bit, 1
    Let expected_half be 0x4000000000000000
    proc assert_equal from TestUtils with results, "0x8000000000000000 >> 1 == 0x4000000000000000 (zero-fill)", half_high, expected_half

    Note: The zero-filled result must be positive (high bit cleared), which is
    Note: the distinction from an arithmetic shift that keeps the sign bit.
    proc assert_greater_than from TestUtils with results, "logical right-shift result is positive", half_high, 0

    Note: ---- 6. hash_compute_combine round-trip: (h << 5) >> 5 == h ----
    Let h be 1337
    Let shifted be proc bitwise_shift_left from BitwiseCore with h, 5
    proc assert_equal from TestUtils with results, "1337 << 5 == 42784", shifted, 42784
    Let recovered be proc bitwise_shift_right from BitwiseCore with shifted, 5
    proc assert_equal from TestUtils with results, "(1337 << 5) >> 5 == 1337", recovered, h

    proc print_summary from TestUtils with results
    Let ok be proc all_passed from TestUtils with results
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
