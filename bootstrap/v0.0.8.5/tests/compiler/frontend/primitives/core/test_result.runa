Note:
Known-answer tests for compiler/frontend/primitives/core/result.runa.

Coverage:
- Result construction, is_ok / is_err, unwrap, unwrap_or, unwrap_err
- Option construction, is_some / is_none, unwrap, unwrap_or
- Maybe aliases mirror Option behaviour
- Either left / right, is_left, is_right, unwrap_left, unwrap_right, swap
- Try ok / err with cause chain, accessors
- Free routines remain safe on NULL

The higher-order helpers (result_map, option_map, etc.) defer to
__builtin_call_indirect_1 which is a documented stage1 stub.  These
tests verify the *dispatch shape* (OK->map branch, ERR->passthrough)
rather than the inner mapper's return, since the mapper invocation
itself is stubbed at this stage1 version.  Once the codegen wires
up real indirect dispatch the tests will be extended in place.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/core/result.runa" as R

Note: ============================================================================
Note: Result<T, E>
Note: ============================================================================

Process called "test_result_ok_err" that takes results as Integer returns Integer:
    T.begin_suite(results, "result.ok_err")

    Let ok_res be R.ok(42)
    T.assert_equal(results, "ok(42) is_ok = 1", R.is_ok(ok_res), 1)
    T.assert_equal(results, "ok(42) is_err = 0", R.is_err(ok_res), 0)
    T.assert_equal(results, "ok(42) unwrap = 42", R.result_unwrap(ok_res), 42)
    T.assert_equal(results, "ok(42) unwrap_or(99) = 42", R.result_unwrap_or(ok_res, 99), 42)
    T.assert_equal(results, "ok(42) unwrap_err = 0", R.result_unwrap_err(ok_res), 0)
    R.result_free(ok_res)

    Let err_res be R.err(7)
    T.assert_equal(results, "err(7) is_ok = 0", R.is_ok(err_res), 0)
    T.assert_equal(results, "err(7) is_err = 1", R.is_err(err_res), 1)
    T.assert_equal(results, "err(7) unwrap = 0", R.result_unwrap(err_res), 0)
    T.assert_equal(results, "err(7) unwrap_or(99) = 99", R.result_unwrap_or(err_res, 99), 99)
    T.assert_equal(results, "err(7) unwrap_err = 7", R.result_unwrap_err(err_res), 7)
    R.result_free(err_res)

    T.assert_equal(results, "is_ok(NULL) = 0", R.is_ok(0), 0)
    T.assert_equal(results, "is_err(NULL) = 0", R.is_err(0), 0)
    T.assert_equal(results, "unwrap(NULL) = 0", R.result_unwrap(0), 0)
    T.assert_equal(results, "unwrap_or(NULL, 5) = 5", R.result_unwrap_or(0, 5), 5)

    Return 1
End Process

Process called "test_result_payload_pointer" that takes results as Integer returns Integer:
    T.begin_suite(results, "result.payload_pointer")
    Let buf be allocate(8)
    __store(buf, 0, 0xCAFE)
    Let ok_buf be R.ok(buf)
    T.assert_equal(results, "ok(ptr) unwrap = ptr", R.result_unwrap(ok_buf), buf)
    R.result_free(ok_buf)
    deallocate(buf)
    Return 1
End Process

Note: ============================================================================
Note: Option<T> / Maybe<T>
Note: ============================================================================

Process called "test_option" that takes results as Integer returns Integer:
    T.begin_suite(results, "option.basic")

    Let some_x be R.some(123)
    T.assert_equal(results, "some(123) is_some = 1", R.is_some(some_x), 1)
    T.assert_equal(results, "some(123) is_none = 0", R.is_none(some_x), 0)
    T.assert_equal(results, "some(123) unwrap = 123", R.option_unwrap(some_x), 123)
    T.assert_equal(results, "some(123) unwrap_or(0) = 123", R.option_unwrap_or(some_x, 0), 123)
    R.option_free(some_x)

    Let none_x be R.none()
    T.assert_equal(results, "none is_some = 0", R.is_some(none_x), 0)
    T.assert_equal(results, "none is_none = 1", R.is_none(none_x), 1)
    T.assert_equal(results, "none unwrap = 0", R.option_unwrap(none_x), 0)
    T.assert_equal(results, "none unwrap_or(99) = 99", R.option_unwrap_or(none_x, 99), 99)
    R.option_free(none_x)

    T.assert_equal(results, "is_some(NULL) = 0", R.is_some(0), 0)
    T.assert_equal(results, "is_none(NULL) = 1", R.is_none(0), 1)

    Return 1
End Process

Process called "test_maybe_aliases" that takes results as Integer returns Integer:
    T.begin_suite(results, "maybe.aliases")

    Let m1 be R.maybe_some(77)
    T.assert_equal(results, "maybe_some(77) is_some", R.maybe_is_some(m1), 1)
    T.assert_equal(results, "maybe_some(77) unwrap", R.maybe_unwrap(m1), 77)
    T.assert_equal(results, "maybe_some(77) unwrap_or(0)", R.maybe_unwrap_or(m1, 0), 77)
    R.maybe_free(m1)

    Let m2 be R.maybe_none()
    T.assert_equal(results, "maybe_none is_none", R.maybe_is_none(m2), 1)
    T.assert_equal(results, "maybe_none unwrap_or(9) = 9", R.maybe_unwrap_or(m2, 9), 9)
    R.maybe_free(m2)
    Return 1
End Process

Note: ============================================================================
Note: Either<L, R>
Note: ============================================================================

Process called "test_either" that takes results as Integer returns Integer:
    T.begin_suite(results, "either.basic")

    Let l be R.left(10)
    T.assert_equal(results, "left(10) is_left", R.is_left(l), 1)
    T.assert_equal(results, "left(10) is_right = 0", R.is_right(l), 0)
    T.assert_equal(results, "left(10) unwrap_left = 10", R.either_unwrap_left(l), 10)
    T.assert_equal(results, "left(10) unwrap_right = 0", R.either_unwrap_right(l), 0)

    Let l_swapped be R.either_swap(l)
    T.assert_equal(results, "swap(left) is_right", R.is_right(l_swapped), 1)
    T.assert_equal(results, "swap(left).unwrap_right = 10", R.either_unwrap_right(l_swapped), 10)
    R.either_free(l_swapped)

    Let r be R.right(20)
    T.assert_equal(results, "right(20) is_right", R.is_right(r), 1)
    T.assert_equal(results, "right(20) unwrap_right = 20", R.either_unwrap_right(r), 20)
    T.assert_equal(results, "right(20) unwrap_left = 0", R.either_unwrap_left(r), 0)

    Let r_swapped be R.either_swap(r)
    T.assert_equal(results, "swap(right) is_left", R.is_left(r_swapped), 1)
    T.assert_equal(results, "swap(right).unwrap_left = 20", R.either_unwrap_left(r_swapped), 20)
    R.either_free(r_swapped)

    R.either_free(l)
    R.either_free(r)

    T.assert_equal(results, "is_left(NULL) = 0", R.is_left(0), 0)
    T.assert_equal(results, "is_right(NULL) = 0", R.is_right(0), 0)
    Return 1
End Process

Note: ============================================================================
Note: Try<T>
Note: ============================================================================

Process called "test_try" that takes results as Integer returns Integer:
    T.begin_suite(results, "try.basic")

    Let t_ok be R.try_ok(500)
    T.assert_equal(results, "try_ok(500) is_ok = 1", R.try_is_ok(t_ok), 1)
    T.assert_equal(results, "try_ok(500) is_err = 0", R.try_is_err(t_ok), 0)
    T.assert_equal(results, "try_ok(500) get_value = 500", R.try_get_value(t_ok), 500)
    T.assert_equal(results, "try_ok(500) get_message = 0", R.try_get_message(t_ok), 0)
    T.assert_equal(results, "try_ok(500) get_cause = 0", R.try_get_cause(t_ok), 0)
    T.assert_equal(results, "try_ok(500) or_else(-1) = 500", R.try_or_else(t_ok, -1), 500)
    R.try_free(t_ok)

    Note: Build a message buffer for the err.
    Let msg be allocate(8)
    __store_byte(msg, 0, 102)
    __store_byte(msg, 1, 97)
    __store_byte(msg, 2, 105)
    __store_byte(msg, 3, 108)
    __store_byte(msg, 4, 0)

    Let t_err be R.try_err(msg, 0)
    T.assert_equal(results, "try_err(msg, 0) is_err = 1", R.try_is_err(t_err), 1)
    T.assert_equal(results, "try_err(msg, 0) is_ok = 0", R.try_is_ok(t_err), 0)
    T.assert_equal(results, "try_err(msg, 0) get_message = msg", R.try_get_message(t_err), msg)
    T.assert_equal(results, "try_err(msg, 0) get_cause = 0", R.try_get_cause(t_err), 0)
    T.assert_equal(results, "try_err or_else(-1) = -1", R.try_or_else(t_err, -1), -1)

    Note: Chain: outer carries inner as cause.
    Let outer_msg be allocate(8)
    __store_byte(outer_msg, 0, 119)
    __store_byte(outer_msg, 1, 114)
    __store_byte(outer_msg, 2, 97)
    __store_byte(outer_msg, 3, 112)
    __store_byte(outer_msg, 4, 0)

    Let t_chained be R.try_err(outer_msg, t_err)
    T.assert_equal(results, "chained is_err = 1", R.try_is_err(t_chained), 1)
    T.assert_equal(results, "chained get_cause = t_err", R.try_get_cause(t_chained), t_err)
    T.assert_equal(results, "chained get_message = outer_msg", R.try_get_message(t_chained), outer_msg)

    R.try_free(t_chained)
    R.try_free(t_err)
    deallocate(msg)
    deallocate(outer_msg)

    T.assert_equal(results, "try_is_ok(NULL) = 0", R.try_is_ok(0), 0)
    T.assert_equal(results, "try_is_err(NULL) = 0", R.try_is_err(0), 0)
    T.assert_equal(results, "try_or_else(NULL, 7) = 7", R.try_or_else(0, 7), 7)
    Return 1
End Process

Note: ============================================================================
Note: Free safety
Note: ============================================================================

Process called "test_free_null_safe" that takes results as Integer returns Integer:
    T.begin_suite(results, "free.null_safe")
    T.assert_equal(results, "result_free(NULL) = 0", R.result_free(0), 0)
    T.assert_equal(results, "option_free(NULL) = 0", R.option_free(0), 0)
    T.assert_equal(results, "maybe_free(NULL) = 0", R.maybe_free(0), 0)
    T.assert_equal(results, "either_free(NULL) = 0", R.either_free(0), 0)
    T.assert_equal(results, "try_free(NULL) = 0", R.try_free(0), 0)
    Return 1
End Process

Note: ============================================================================
Note: MAIN ENTRY POINT
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_result_ok_err(results)
    test_result_payload_pointer(results)
    test_option(results)
    test_maybe_aliases(results)
    test_either(results)
    test_try(results)
    test_free_null_safe(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
