Note:
Unit tests for compiler/frontend/primitives/io/file_io.runa.
Tests cover pure helpers (path handling, line counting, newline search,
constant exposure). Syscall-backed read/write are exercised by integration
tests since they require a real filesystem and are platform-sensitive.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/io/file_io.runa" as FIO

Note: ============================================================================
Note: CONSTANTS
Note: ============================================================================

Process called "test_mode_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "file_io.mode constants match POSIX flags")
    T.assert_equal(results, "READ_ONLY = 0", FIO.FILE_MODE_READ_ONLY, 0)
    T.assert_equal(results, "WRITE_ONLY = 1", FIO.FILE_MODE_WRITE_ONLY, 1)
    T.assert_equal(results, "READ_WRITE = 2", FIO.FILE_MODE_READ_WRITE, 2)
    T.assert_equal(results, "CREATE = 64 (O_CREAT)", FIO.FILE_MODE_CREATE, 64)
    T.assert_equal(results, "EXCLUSIVE = 128 (O_EXCL)", FIO.FILE_MODE_EXCLUSIVE, 128)
    T.assert_equal(results, "TRUNCATE = 512 (O_TRUNC)", FIO.FILE_MODE_TRUNCATE, 512)
    T.assert_equal(results, "APPEND = 1024 (O_APPEND)", FIO.FILE_MODE_APPEND, 1024)
    T.assert_equal(results, "DEFAULT_PERMS = 0644", FIO.FILE_DEFAULT_PERMS, 420)
    Return 1
End Process

Note: ============================================================================
Note: PATH HELPERS
Note: ============================================================================

Process called "test_is_absolute_path" that takes results as Integer returns Integer:
    T.begin_suite(results, "file_io.is_absolute_path")
    T.assert_equal(results, "/etc/passwd is absolute", FIO.is_absolute_path("/etc/passwd"), 1)
    T.assert_equal(results, "/ is absolute", FIO.is_absolute_path("/"), 1)
    T.assert_equal(results, "relative path", FIO.is_absolute_path("foo/bar"), 0)
    T.assert_equal(results, "./foo", FIO.is_absolute_path("./foo"), 0)
    T.assert_equal(results, "../foo", FIO.is_absolute_path("../foo"), 0)
    T.assert_equal(results, "C: drive (Windows)", FIO.is_absolute_path("C:\\Windows"), 1)
    T.assert_equal(results, "D: drive lowercase", FIO.is_absolute_path("d:\\src"), 1)
    T.assert_equal(results, "null pointer", FIO.is_absolute_path(0), 0)
    Return 1
End Process

Process called "test_last_separator_offset" that takes results as Integer returns Integer:
    T.begin_suite(results, "file_io.last_separator_offset")
    T.assert_equal(results, "/foo/bar last '/' at 4", FIO.last_separator_offset("/foo/bar"), 4)
    T.assert_equal(results, "no separator returns -1", FIO.last_separator_offset("filename"), 0 minus 1)
    T.assert_equal(results, "/ alone", FIO.last_separator_offset("/"), 0)
    T.assert_equal(results, "a/b/c last at 3", FIO.last_separator_offset("a/b/c"), 3)
    T.assert_equal(results, "windows \\ separator", FIO.last_separator_offset("a\\b\\c"), 3)
    Return 1
End Process

Note: ============================================================================
Note: LINE COUNTING
Note: ============================================================================

Process called "test_count_lines" that takes results as Integer returns Integer:
    T.begin_suite(results, "file_io.count_lines")
    T.assert_equal(results, "empty string -> 0", FIO.count_lines(""), 0)
    T.assert_equal(results, "no newlines -> 1", FIO.count_lines("hello"), 1)
    T.assert_equal(results, "trailing newline -> 1", FIO.count_lines("hello\n"), 1)
    T.assert_equal(results, "two lines no trailing", FIO.count_lines("a\nb"), 2)
    T.assert_equal(results, "two lines trailing newline", FIO.count_lines("a\nb\n"), 2)
    T.assert_equal(results, "three lines", FIO.count_lines("a\nb\nc"), 3)
    Return 1
End Process

Note: ============================================================================
Note: MAIN
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_mode_constants(results)
    test_is_absolute_path(results)
    test_last_separator_offset(results)
    test_count_lines(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
