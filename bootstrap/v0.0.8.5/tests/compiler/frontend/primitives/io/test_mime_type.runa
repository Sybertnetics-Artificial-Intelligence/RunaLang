Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/io/mime_type.runa" as M
Import "compiler/frontend/primitives/core/string_core.runa" as Str

Process called "test_mime_simple" that takes results as Integer returns Integer:
    T.begin_suite(results, "mime.simple")
    Let m be M.mimetype_parse("text/plain")
    T.assert_not_null(results, "parsed", m)
    T.assert_equal(results, "type=text", Str.string_equals(M.mimetype_type(m), "text"), 1)
    T.assert_equal(results, "subtype=plain", Str.string_equals(M.mimetype_subtype(m), "plain"), 1)
    T.assert_equal(results, "no params", M.mimetype_parameter_count(m), 0)
    M.mimetype_destroy(m)
    Return 1
End Process

Process called "test_mime_with_param" that takes results as Integer returns Integer:
    T.begin_suite(results, "mime.with_param")
    Let m be M.mimetype_parse("text/html; charset=UTF-8")
    T.assert_not_null(results, "parsed", m)
    T.assert_equal(results, "type=text", Str.string_equals(M.mimetype_type(m), "text"), 1)
    T.assert_equal(results, "subtype=html", Str.string_equals(M.mimetype_subtype(m), "html"), 1)
    T.assert_equal(results, "1 param", M.mimetype_parameter_count(m), 1)
    Let charset be M.mimetype_parameter(m, "charset")
    T.assert_equal(results, "charset=UTF-8", Str.string_equals(charset, "UTF-8"), 1)
    Note: Case-insensitive name lookup
    Let charset2 be M.mimetype_parameter(m, "Charset")
    T.assert_equal(results, "case-insensitive name", Str.string_equals(charset2, "UTF-8"), 1)
    M.mimetype_destroy(m)
    Return 1
End Process

Process called "test_mime_case_normalization" that takes results as Integer returns Integer:
    T.begin_suite(results, "mime.case_normalization")
    Let m be M.mimetype_parse("APPLICATION/JSON")
    T.assert_equal(results, "type lowercased", Str.string_equals(M.mimetype_type(m), "application"), 1)
    T.assert_equal(results, "subtype lowercased", Str.string_equals(M.mimetype_subtype(m), "json"), 1)
    M.mimetype_destroy(m)
    Return 1
End Process

Process called "test_mime_quoted_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "mime.quoted_value")
    Let m be M.mimetype_parse("text/html; boundary=\"abc def\"")
    Let val be M.mimetype_parameter(m, "boundary")
    T.assert_equal(results, "quoted value unwrapped", Str.string_equals(val, "abc def"), 1)
    M.mimetype_destroy(m)
    Return 1
End Process

Process called "test_mime_multiple_params" that takes results as Integer returns Integer:
    T.begin_suite(results, "mime.multiple_params")
    Let m be M.mimetype_parse("multipart/form-data; boundary=----xyz; charset=us-ascii")
    T.assert_equal(results, "2 params", M.mimetype_parameter_count(m), 2)
    Let b be M.mimetype_parameter(m, "boundary")
    T.assert_equal(results, "boundary", Str.string_equals(b, "----xyz"), 1)
    Let c be M.mimetype_parameter(m, "charset")
    T.assert_equal(results, "charset", Str.string_equals(c, "us-ascii"), 1)
    M.mimetype_destroy(m)
    Return 1
End Process

Process called "test_mime_invalid" that takes results as Integer returns Integer:
    T.begin_suite(results, "mime.invalid")
    Let m1 be M.mimetype_parse("noSlash")
    T.assert_equal(results, "missing slash rejected", m1, 0)
    Let m2 be M.mimetype_parse("")
    T.assert_equal(results, "empty rejected", m2, 0)
    Let m3 be M.mimetype_parse("/empty")
    T.assert_equal(results, "no type rejected", m3, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_mime_simple(results)
    test_mime_with_param(results)
    test_mime_case_normalization(results)
    test_mime_quoted_value(results)
    test_mime_multiple_params(results)
    test_mime_invalid(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
