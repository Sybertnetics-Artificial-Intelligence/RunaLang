Note:
ByteBuffer primitive KAT.

Coverage:
- Lifecycle: create / destroy with both endianness modes.
- Round-trip of int16/int32/int64 in both byte orders.
- write_string_utf8 / read_string_utf8 round-trip.
- Capacity exhaustion: write_byte past capacity returns BYTEBUF_ERR_OVERFLOW.
- Flip pattern: 8 bytes written, flip, 8 bytes read back.
- Compact pattern: 8 bytes written, 4 read, compact, 4 more written,
  full 8 read back.
- slice produces an independent buffer (mutating one does not affect
  the other).

Exit code legend:
  0   All assertions passed.
  10  create with capacity <= 0 must return 0.
  11  create with invalid byte_order must return 0.
  12  fresh buffer's remaining_write != capacity.
  13  fresh buffer's remaining_read != 0.
  20  write_int32 LE round-trip wrong.
  21  read_int32 cursor not advanced.
  22  write_int32 BE round-trip wrong.
  23  write_int16 LE round-trip wrong.
  24  write_int64 LE round-trip wrong.
  25  write_int64 BE round-trip wrong.
  30  write_string_utf8/read_string_utf8 round-trip wrong.
  31  empty-string round-trip wrong.
  40  capacity exhaustion: write_byte should have failed.
  41  remaining_write should be 0 at capacity.
  50  flip pattern: read after flip wrong value.
  51  flip pattern: read past flipped high water mark not UNDERFLOW.
  60  compact pattern: post-compact read_position not 0.
  61  compact pattern: post-compact write_position wrong.
  62  compact pattern: final read returned wrong byte.
  70  slice: returned 0 unexpectedly.
  71  slice: slice contents differ from source.
  72  slice independence: mutating slice changed source.
:End Note

Import "compiler/frontend/primitives/io/byte_buffer.runa" as BB
Import "compiler/frontend/primitives/core/string_core.runa" as Str
Import "compiler/frontend/primitives/core/memory_core.runa" as Mem
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Process called "main" returns Integer:
    Note: ----- Case 10: invalid capacity -----
    Let bad_cap be proc byte_buffer_create from BB with 0, 0
    If bad_cap is not equal to 0:
        Return 10
    End If
    Let bad_cap2 be proc byte_buffer_create from BB with -8, 0
    If bad_cap2 is not equal to 0:
        Return 10
    End If

    Note: ----- Case 11: invalid byte_order -----
    Let bad_order be proc byte_buffer_create from BB with 16, 2
    If bad_order is not equal to 0:
        Return 11
    End If
    Let bad_order2 be proc byte_buffer_create from BB with 16, -1
    If bad_order2 is not equal to 0:
        Return 11
    End If

    Note: ----- Case 12: fresh buffer remaining_write == capacity -----
    Let bb_le be proc byte_buffer_create from BB with 32, 0
    If bb_le is equal to 0:
        Return 12
    End If
    Let rw be proc byte_buffer_remaining_write from BB with bb_le
    If rw is not equal to 32:
        Return 12
    End If

    Note: ----- Case 13: fresh buffer remaining_read == 0 -----
    Let rr0 be proc byte_buffer_remaining_read from BB with bb_le
    If rr0 is not equal to 0:
        Return 13
    End If

    Note: ----- Case 20: int32 LE round-trip -----
    Let wrc1 be proc byte_buffer_write_int32 from BB with bb_le, 305419896
    If wrc1 is not equal to 4:
        Return 20
    End If
    Note: After flip the reader sees the 4 bytes just written.
    proc byte_buffer_flip from BB with bb_le
    Let v_back be proc byte_buffer_read_int32 from BB with bb_le
    If v_back is not equal to 305419896:
        Return 20
    End If

    Note: ----- Case 21: read cursor advanced -----
    Let rpos_after be proc byte_buffer_read_position from BB with bb_le
    If rpos_after is not equal to 4:
        Return 21
    End If
    proc byte_buffer_destroy from BB with bb_le

    Note: ----- Case 22: int32 BE round-trip -----
    Let bb_be be proc byte_buffer_create from BB with 32, 1
    If bb_be is equal to 0:
        Return 22
    End If
    proc byte_buffer_write_int32 from BB with bb_be, 305419896
    proc byte_buffer_flip from BB with bb_be
    Let v_be_back be proc byte_buffer_read_int32 from BB with bb_be
    If v_be_back is not equal to 305419896:
        Return 22
    End If
    proc byte_buffer_destroy from BB with bb_be

    Note: ----- Case 22b: cross-endian payload differs -----
    Note: Writing 0x12345678 LE then reading bytes 0..3 produces 0x78
    Note: at index 0; the BE encoding puts 0x12 at index 0. Verify by
    Note: writing in one buffer LE, then transferring bytes verbatim
    Note: into a BE-ordered buffer and reading as int32 - the result
    Note: must be byte-reversed (0x78563412 == 2018915346).
    Let bb_xfer_le be proc byte_buffer_create from BB with 8, 0
    proc byte_buffer_write_int32 from BB with bb_xfer_le, 305419896
    Let scratch4 be proc allocate from Layout with 4
    proc byte_buffer_flip from BB with bb_xfer_le
    proc byte_buffer_read_bytes from BB with bb_xfer_le, scratch4, 4
    proc byte_buffer_destroy from BB with bb_xfer_le

    Let bb_xfer_be be proc byte_buffer_create from BB with 8, 1
    proc byte_buffer_write_bytes from BB with bb_xfer_be, scratch4, 4
    proc byte_buffer_flip from BB with bb_xfer_be
    Let v_swapped be proc byte_buffer_read_int32 from BB with bb_xfer_be
    If v_swapped is not equal to 2018915346:
        Return 22
    End If
    proc byte_buffer_destroy from BB with bb_xfer_be
    proc deallocate from Layout with scratch4

    Note: ----- Case 23: int16 LE round-trip -----
    Let bb16 be proc byte_buffer_create from BB with 16, 0
    proc byte_buffer_write_int16 from BB with bb16, 41394
    proc byte_buffer_flip from BB with bb16
    Let v16_back be proc byte_buffer_read_int16 from BB with bb16
    If v16_back is not equal to 41394:
        Return 23
    End If
    proc byte_buffer_destroy from BB with bb16

    Note: ----- Case 24: int64 LE round-trip -----
    Let bb64 be proc byte_buffer_create from BB with 16, 0
    Let big64 be 1311768467463790320
    proc byte_buffer_write_int64 from BB with bb64, big64
    proc byte_buffer_flip from BB with bb64
    Let v64_back be proc byte_buffer_read_int64 from BB with bb64
    If v64_back is not equal to big64:
        Return 24
    End If
    proc byte_buffer_destroy from BB with bb64

    Note: ----- Case 25: int64 BE round-trip -----
    Let bb64be be proc byte_buffer_create from BB with 16, 1
    proc byte_buffer_write_int64 from BB with bb64be, big64
    proc byte_buffer_flip from BB with bb64be
    Let v64be_back be proc byte_buffer_read_int64 from BB with bb64be
    If v64be_back is not equal to big64:
        Return 25
    End If
    proc byte_buffer_destroy from BB with bb64be

    Note: ----- Case 30: string round-trip -----
    Let bbs be proc byte_buffer_create from BB with 64, 0
    proc byte_buffer_write_string_utf8 from BB with bbs, "Hello"
    proc byte_buffer_flip from BB with bbs
    Let recovered be proc byte_buffer_read_string_utf8 from BB with bbs
    If recovered is equal to 0:
        Return 30
    End If
    Let eq be proc string_equals from Str with recovered, "Hello"
    If eq is not equal to 1:
        Return 30
    End If
    proc byte_buffer_destroy from BB with bbs

    Note: ----- Case 31: empty-string round-trip -----
    Let bbe be proc byte_buffer_create from BB with 16, 0
    proc byte_buffer_write_string_utf8 from BB with bbe, ""
    proc byte_buffer_flip from BB with bbe
    Let rec_empty be proc byte_buffer_read_string_utf8 from BB with bbe
    If rec_empty is equal to 0:
        Return 31
    End If
    Let elen be proc string_length from Str with rec_empty
    If elen is not equal to 0:
        Return 31
    End If
    proc byte_buffer_destroy from BB with bbe

    Note: ----- Case 40: capacity exhaustion -----
    Let bbcap be proc byte_buffer_create from BB with 4, 0
    proc byte_buffer_write_byte from BB with bbcap, 1
    proc byte_buffer_write_byte from BB with bbcap, 2
    proc byte_buffer_write_byte from BB with bbcap, 3
    proc byte_buffer_write_byte from BB with bbcap, 4
    Note: 5th byte must fail with overflow (-2)
    Let exhausted be proc byte_buffer_write_byte from BB with bbcap, 5
    Let exp_overflow be 0 minus 2
    If exhausted is not equal to exp_overflow:
        Return 40
    End If
    Let rw0 be proc byte_buffer_remaining_write from BB with bbcap
    If rw0 is not equal to 0:
        Return 41
    End If
    proc byte_buffer_destroy from BB with bbcap

    Note: ----- Case 50: flip pattern -----
    Let bbflip be proc byte_buffer_create from BB with 16, 0
    Let bi be 0
    While bi is less than 8:
        proc byte_buffer_write_byte from BB with bbflip, bi plus 100
        Set bi to bi plus 1
    End While
    proc byte_buffer_flip from BB with bbflip
    Let ri be 0
    While ri is less than 8:
        Let v be proc byte_buffer_read_byte from BB with bbflip
        If v is not equal to ri plus 100:
            Return 50
        End If
        Set ri to ri plus 1
    End While
    Note: One more read past write_position must underflow
    Let underflow be proc byte_buffer_read_byte from BB with bbflip
    Let exp_underflow be 0 minus 3
    If underflow is not equal to exp_underflow:
        Return 51
    End If
    proc byte_buffer_destroy from BB with bbflip

    Note: ----- Case 60-62: compact pattern -----
    Let bbcomp be proc byte_buffer_create from BB with 8, 0
    Let ci be 0
    While ci is less than 8:
        proc byte_buffer_write_byte from BB with bbcomp, ci plus 1
        Set ci to ci plus 1
    End While
    Note: Move read past first 4 bytes
    Let di be 0
    While di is less than 4:
        proc byte_buffer_read_byte from BB with bbcomp
        Set di to di plus 1
    End While
    proc byte_buffer_compact from BB with bbcomp
    Let rpos_post be proc byte_buffer_read_position from BB with bbcomp
    If rpos_post is not equal to 0:
        Return 60
    End If
    Let wpos_post be proc byte_buffer_write_position from BB with bbcomp
    If wpos_post is not equal to 4:
        Return 61
    End If
    Note: Write 4 more bytes (values 50..53), then read all 8 back.
    Let ai be 0
    While ai is less than 4:
        proc byte_buffer_write_byte from BB with bbcomp, ai plus 50
        Set ai to ai plus 1
    End While
    Note: We should now read 5, 6, 7, 8, 50, 51, 52, 53.
    Let r0 be proc byte_buffer_read_byte from BB with bbcomp
    If r0 is not equal to 5:
        Return 62
    End If
    Let r1 be proc byte_buffer_read_byte from BB with bbcomp
    If r1 is not equal to 6:
        Return 62
    End If
    Let r2 be proc byte_buffer_read_byte from BB with bbcomp
    If r2 is not equal to 7:
        Return 62
    End If
    Let r3 be proc byte_buffer_read_byte from BB with bbcomp
    If r3 is not equal to 8:
        Return 62
    End If
    Let r4 be proc byte_buffer_read_byte from BB with bbcomp
    If r4 is not equal to 50:
        Return 62
    End If
    Let r5 be proc byte_buffer_read_byte from BB with bbcomp
    If r5 is not equal to 51:
        Return 62
    End If
    Let r6 be proc byte_buffer_read_byte from BB with bbcomp
    If r6 is not equal to 52:
        Return 62
    End If
    Let r7 be proc byte_buffer_read_byte from BB with bbcomp
    If r7 is not equal to 53:
        Return 62
    End If
    proc byte_buffer_destroy from BB with bbcomp

    Note: ----- Case 70-72: slice independence -----
    Let bborig be proc byte_buffer_create from BB with 16, 0
    Let si be 0
    While si is less than 8:
        proc byte_buffer_write_byte from BB with bborig, si plus 10
        Set si to si plus 1
    End While
    Let sliced be proc byte_buffer_slice from BB with bborig, 2, 4
    If sliced is equal to 0:
        Return 70
    End If
    Note: Slice should contain bytes at indices 2..5 = 12, 13, 14, 15
    Let sr0 be proc byte_buffer_read_byte from BB with sliced
    If sr0 is not equal to 12:
        Return 71
    End If
    Let sr1 be proc byte_buffer_read_byte from BB with sliced
    If sr1 is not equal to 13:
        Return 71
    End If
    Let sr2 be proc byte_buffer_read_byte from BB with sliced
    If sr2 is not equal to 14:
        Return 71
    End If
    Let sr3 be proc byte_buffer_read_byte from BB with sliced
    If sr3 is not equal to 15:
        Return 71
    End If

    Note: Mutate the slice's data; ensure source is untouched.
    Note: Slice cursors are now exhausted on the read side, but the
    Note: underlying memory still has the original 4 bytes. Write
    Note: a sentinel into the slice by clearing it and writing
    Note: distinct bytes, then re-read the source slice (bytes 2..5)
    Note: through a fresh copy.
    proc byte_buffer_clear from BB with sliced
    proc byte_buffer_write_byte from BB with sliced, 255
    proc byte_buffer_write_byte from BB with sliced, 255
    proc byte_buffer_write_byte from BB with sliced, 255
    proc byte_buffer_write_byte from BB with sliced, 255

    Note: Read source bytes 2..5 to confirm independence.
    Let verify be proc byte_buffer_slice from BB with bborig, 2, 4
    Let vr0 be proc byte_buffer_read_byte from BB with verify
    If vr0 is not equal to 12:
        Return 72
    End If
    Let vr1 be proc byte_buffer_read_byte from BB with verify
    If vr1 is not equal to 13:
        Return 72
    End If
    proc byte_buffer_destroy from BB with verify
    proc byte_buffer_destroy from BB with sliced
    proc byte_buffer_destroy from BB with bborig

    Return 0
End Process
