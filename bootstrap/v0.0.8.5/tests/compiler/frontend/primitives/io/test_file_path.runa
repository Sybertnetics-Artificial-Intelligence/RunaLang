Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/io/file_path.runa" as P
Import "compiler/frontend/primitives/core/string_core.runa" as Str

Process called "test_filepath_construction" that takes results as Integer returns Integer:
    T.begin_suite(results, "filepath.construction")
    Let p1 be P.filepath_from_string("/tmp/test.txt")
    T.assert_not_null(results, "absolute parsed", p1)
    T.assert_equal(results, "absolute flag", P.filepath_is_absolute(p1), 1)
    T.assert_equal(results, "relative inverse", P.filepath_is_relative(p1), 0)
    Let s1 be P.filepath_to_string(p1)
    T.assert_equal(results, "string matches", Str.string_equals(s1, "/tmp/test.txt"), 1)
    P.filepath_destroy(p1)

    Let p2 be P.filepath_from_string("relative/path.txt")
    T.assert_equal(results, "relative flag", P.filepath_is_relative(p2), 1)
    T.assert_equal(results, "absolute=0", P.filepath_is_absolute(p2), 0)
    P.filepath_destroy(p2)
    Return 1
End Process

Process called "test_filepath_windows_normalize" that takes results as Integer returns Integer:
    T.begin_suite(results, "filepath.windows_normalize")
    Note: Backslashes get normalized to forward slashes
    Let p1 be P.filepath_from_string("C:\\Users\\test")
    T.assert_not_null(results, "windows parsed", p1)
    Let s1 be P.filepath_to_string(p1)
    T.assert_equal(results, "drive rewritten", Str.string_equals(s1, "/c/Users/test"), 1)
    T.assert_equal(results, "absolute=1", P.filepath_is_absolute(p1), 1)
    P.filepath_destroy(p1)
    Return 1
End Process

Process called "test_filepath_join" that takes results as Integer returns Integer:
    T.begin_suite(results, "filepath.join")
    Let p1 be P.filepath_from_string("/usr/local")
    Let p2 be P.filepath_join(p1, "bin")
    Let s2 be P.filepath_to_string(p2)
    T.assert_equal(results, "join", Str.string_equals(s2, "/usr/local/bin"), 1)
    P.filepath_destroy(p1)
    P.filepath_destroy(p2)

    Let p3 be P.filepath_from_string("/etc/")
    Let p4 be P.filepath_join(p3, "hosts")
    Let s4 be P.filepath_to_string(p4)
    T.assert_equal(results, "join no double slash", Str.string_equals(s4, "/etc/hosts"), 1)
    P.filepath_destroy(p3)
    P.filepath_destroy(p4)

    Note: Absolute segment replaces
    Let p5 be P.filepath_from_string("/foo")
    Let p6 be P.filepath_join(p5, "/bar")
    Let s6 be P.filepath_to_string(p6)
    T.assert_equal(results, "abs segment replaces", Str.string_equals(s6, "/bar"), 1)
    P.filepath_destroy(p5)
    P.filepath_destroy(p6)
    Return 1
End Process

Process called "test_filepath_parent" that takes results as Integer returns Integer:
    T.begin_suite(results, "filepath.parent")
    Let p be P.filepath_from_string("/usr/local/bin")
    Let par be P.filepath_parent(p)
    Let s be P.filepath_to_string(par)
    T.assert_equal(results, "parent of /usr/local/bin", Str.string_equals(s, "/usr/local"), 1)
    P.filepath_destroy(p)
    P.filepath_destroy(par)

    Let p2 be P.filepath_from_string("/foo")
    Let par2 be P.filepath_parent(p2)
    Let s2 be P.filepath_to_string(par2)
    T.assert_equal(results, "parent of /foo = /", Str.string_equals(s2, "/"), 1)
    P.filepath_destroy(p2)
    P.filepath_destroy(par2)

    Let p3 be P.filepath_from_string("foo")
    Let par3 be P.filepath_parent(p3)
    Let s3 be P.filepath_to_string(par3)
    T.assert_equal(results, "parent of foo = .", Str.string_equals(s3, "."), 1)
    P.filepath_destroy(p3)
    P.filepath_destroy(par3)
    Return 1
End Process

Process called "test_filepath_filename_ext_stem" that takes results as Integer returns Integer:
    T.begin_suite(results, "filepath.filename_ext_stem")
    Let p be P.filepath_from_string("/home/user/archive.tar.gz")
    Let fname be P.filepath_filename(p)
    T.assert_equal(results, "filename", Str.string_equals(fname, "archive.tar.gz"), 1)
    Let ext be P.filepath_extension(p)
    T.assert_equal(results, "ext = 'gz'", Str.string_equals(ext, "gz"), 1)
    Let stem be P.filepath_stem(p)
    T.assert_equal(results, "stem = 'archive.tar'", Str.string_equals(stem, "archive.tar"), 1)
    P.filepath_destroy(p)
    deallocate(fname)
    deallocate(ext)
    deallocate(stem)

    Let p2 be P.filepath_from_string("/etc/.bashrc")
    Let ext2 be P.filepath_extension(p2)
    T.assert_equal(results, ".bashrc has no ext", Str.string_equals(ext2, ""), 1)
    P.filepath_destroy(p2)
    deallocate(ext2)
    Return 1
End Process

Process called "test_filepath_canonicalize" that takes results as Integer returns Integer:
    T.begin_suite(results, "filepath.canonicalize")
    Let p1 be P.filepath_from_string("/usr/./local/../bin")
    Let c1 be P.filepath_canonicalize(p1)
    Let s1 be P.filepath_to_string(c1)
    T.assert_equal(results, "resolve .. and .", Str.string_equals(s1, "/usr/bin"), 1)
    P.filepath_destroy(p1)
    P.filepath_destroy(c1)

    Let p2 be P.filepath_from_string("/a//b/c")
    Let c2 be P.filepath_canonicalize(p2)
    Let s2 be P.filepath_to_string(c2)
    T.assert_equal(results, "collapse double slash", Str.string_equals(s2, "/a/b/c"), 1)
    P.filepath_destroy(p2)
    P.filepath_destroy(c2)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_filepath_construction(results)
    test_filepath_windows_normalize(results)
    test_filepath_join(results)
    test_filepath_parent(results)
    test_filepath_filename_ext_stem(results)
    test_filepath_canonicalize(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
