Note:
Unit tests for compiler/frontend/primitives/char_core.runa.

Verifies the ASCII character classification predicates, case conversion,
digit-value extraction, and identifier/whitespace rules used by lexers
throughout the compiler.

ASCII reference values exercised:
  '0'=48  '9'=57  'A'=65  'Z'=90  'a'=97  'z'=122  '_'=95
  space=32  tab=9   LF=10   CR=13   DEL=127
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/char_core.runa" as Char

Note: ============================================================================
Note: DIGIT TESTS
Note: ============================================================================

Process called "test_is_digit" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_digit")

    T.assert_equal(results, "'0' is digit", Char.is_digit(48), 1)
    T.assert_equal(results, "'5' is digit", Char.is_digit(53), 1)
    T.assert_equal(results, "'9' is digit", Char.is_digit(57), 1)
    T.assert_equal(results, "'/' (47) is not digit", Char.is_digit(47), 0)
    T.assert_equal(results, "':' (58) is not digit", Char.is_digit(58), 0)
    T.assert_equal(results, "'a' is not digit", Char.is_digit(97), 0)
    T.assert_equal(results, "'A' is not digit", Char.is_digit(65), 0)
    T.assert_equal(results, "null byte is not digit", Char.is_digit(0), 0)
    Return 1
End Process

Process called "test_is_hex_digit" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_hex_digit")

    T.assert_equal(results, "'0' is hex", Char.is_hex_digit(48), 1)
    T.assert_equal(results, "'9' is hex", Char.is_hex_digit(57), 1)
    T.assert_equal(results, "'a' is hex", Char.is_hex_digit(97), 1)
    T.assert_equal(results, "'f' is hex", Char.is_hex_digit(102), 1)
    T.assert_equal(results, "'A' is hex", Char.is_hex_digit(65), 1)
    T.assert_equal(results, "'F' is hex", Char.is_hex_digit(70), 1)
    T.assert_equal(results, "'g' is not hex", Char.is_hex_digit(103), 0)
    T.assert_equal(results, "'G' is not hex", Char.is_hex_digit(71), 0)
    T.assert_equal(results, "':' is not hex", Char.is_hex_digit(58), 0)
    Return 1
End Process

Process called "test_is_octal_digit" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_octal_digit")

    T.assert_equal(results, "'0' is octal", Char.is_octal_digit(48), 1)
    T.assert_equal(results, "'7' is octal", Char.is_octal_digit(55), 1)
    T.assert_equal(results, "'8' is not octal", Char.is_octal_digit(56), 0)
    T.assert_equal(results, "'9' is not octal", Char.is_octal_digit(57), 0)
    T.assert_equal(results, "'/' is not octal", Char.is_octal_digit(47), 0)
    Return 1
End Process

Process called "test_is_binary_digit" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_binary_digit")

    T.assert_equal(results, "'0' is binary", Char.is_binary_digit(48), 1)
    T.assert_equal(results, "'1' is binary", Char.is_binary_digit(49), 1)
    T.assert_equal(results, "'2' is not binary", Char.is_binary_digit(50), 0)
    T.assert_equal(results, "'/' is not binary", Char.is_binary_digit(47), 0)
    Return 1
End Process

Note: ============================================================================
Note: LETTER TESTS
Note: ============================================================================

Process called "test_is_uppercase" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_uppercase")

    T.assert_equal(results, "'A' is uppercase", Char.is_uppercase(65), 1)
    T.assert_equal(results, "'Z' is uppercase", Char.is_uppercase(90), 1)
    T.assert_equal(results, "'M' is uppercase", Char.is_uppercase(77), 1)
    T.assert_equal(results, "'a' is not uppercase", Char.is_uppercase(97), 0)
    T.assert_equal(results, "'@' (64) is not uppercase", Char.is_uppercase(64), 0)
    T.assert_equal(results, "'[' (91) is not uppercase", Char.is_uppercase(91), 0)
    Return 1
End Process

Process called "test_is_lowercase" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_lowercase")

    T.assert_equal(results, "'a' is lowercase", Char.is_lowercase(97), 1)
    T.assert_equal(results, "'z' is lowercase", Char.is_lowercase(122), 1)
    T.assert_equal(results, "'m' is lowercase", Char.is_lowercase(109), 1)
    T.assert_equal(results, "'A' is not lowercase", Char.is_lowercase(65), 0)
    T.assert_equal(results, "'`' (96) is not lowercase", Char.is_lowercase(96), 0)
    T.assert_equal(results, "'{' (123) is not lowercase", Char.is_lowercase(123), 0)
    Return 1
End Process

Process called "test_is_alpha" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_alpha")

    T.assert_equal(results, "'A' is alpha", Char.is_alpha(65), 1)
    T.assert_equal(results, "'z' is alpha", Char.is_alpha(122), 1)
    T.assert_equal(results, "'5' is not alpha", Char.is_alpha(53), 0)
    T.assert_equal(results, "'_' is not alpha", Char.is_alpha(95), 0)
    T.assert_equal(results, "space is not alpha", Char.is_alpha(32), 0)
    Return 1
End Process

Process called "test_is_alphanumeric" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_alphanumeric")

    T.assert_equal(results, "'A' is alphanumeric", Char.is_alphanumeric(65), 1)
    T.assert_equal(results, "'5' is alphanumeric", Char.is_alphanumeric(53), 1)
    T.assert_equal(results, "'z' is alphanumeric", Char.is_alphanumeric(122), 1)
    T.assert_equal(results, "'_' is not alphanumeric", Char.is_alphanumeric(95), 0)
    T.assert_equal(results, "'-' is not alphanumeric", Char.is_alphanumeric(45), 0)
    Return 1
End Process

Note: ============================================================================
Note: IDENTIFIER TESTS
Note: ============================================================================

Process called "test_is_identifier_start" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_identifier_start")

    T.assert_equal(results, "'A' starts identifier", Char.is_identifier_start(65), 1)
    T.assert_equal(results, "'a' starts identifier", Char.is_identifier_start(97), 1)
    T.assert_equal(results, "'_' starts identifier", Char.is_identifier_start(95), 1)
    T.assert_equal(results, "'5' does not start identifier", Char.is_identifier_start(53), 0)
    T.assert_equal(results, "'$' does not start identifier", Char.is_identifier_start(36), 0)
    T.assert_equal(results, "'-' does not start identifier", Char.is_identifier_start(45), 0)
    Return 1
End Process

Process called "test_is_identifier_continue" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_identifier_continue")

    T.assert_equal(results, "'A' continues identifier", Char.is_identifier_continue(65), 1)
    T.assert_equal(results, "'5' continues identifier", Char.is_identifier_continue(53), 1)
    T.assert_equal(results, "'_' continues identifier", Char.is_identifier_continue(95), 1)
    T.assert_equal(results, "'-' does not continue identifier", Char.is_identifier_continue(45), 0)
    T.assert_equal(results, "'.' does not continue identifier", Char.is_identifier_continue(46), 0)
    Return 1
End Process

Note: ============================================================================
Note: WHITESPACE TESTS
Note: ============================================================================

Process called "test_is_whitespace" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_whitespace")

    T.assert_equal(results, "space is whitespace", Char.is_whitespace(32), 1)
    T.assert_equal(results, "tab is whitespace", Char.is_whitespace(9), 1)
    T.assert_equal(results, "LF is whitespace", Char.is_whitespace(10), 1)
    T.assert_equal(results, "CR is whitespace", Char.is_whitespace(13), 1)
    T.assert_equal(results, "VT is whitespace", Char.is_whitespace(11), 1)
    T.assert_equal(results, "FF is whitespace", Char.is_whitespace(12), 1)
    T.assert_equal(results, "'A' is not whitespace", Char.is_whitespace(65), 0)
    T.assert_equal(results, "null is not whitespace", Char.is_whitespace(0), 0)
    Return 1
End Process

Process called "test_is_inline_whitespace" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_inline_whitespace")

    T.assert_equal(results, "space is inline ws", Char.is_inline_whitespace(32), 1)
    T.assert_equal(results, "tab is inline ws", Char.is_inline_whitespace(9), 1)
    T.assert_equal(results, "LF is not inline ws", Char.is_inline_whitespace(10), 0)
    T.assert_equal(results, "CR is not inline ws", Char.is_inline_whitespace(13), 0)
    Return 1
End Process

Process called "test_is_line_terminator" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_line_terminator")

    T.assert_equal(results, "LF terminates line", Char.is_line_terminator(10), 1)
    T.assert_equal(results, "CR terminates line", Char.is_line_terminator(13), 1)
    T.assert_equal(results, "space does not terminate", Char.is_line_terminator(32), 0)
    T.assert_equal(results, "tab does not terminate", Char.is_line_terminator(9), 0)
    Return 1
End Process

Note: ============================================================================
Note: CASE CONVERSION TESTS
Note: ============================================================================

Process called "test_to_lower" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.to_lower")

    T.assert_equal(results, "'A' -> 'a'", Char.to_lower(65), 97)
    T.assert_equal(results, "'Z' -> 'z'", Char.to_lower(90), 122)
    T.assert_equal(results, "'M' -> 'm'", Char.to_lower(77), 109)
    T.assert_equal(results, "'a' unchanged", Char.to_lower(97), 97)
    T.assert_equal(results, "'5' unchanged", Char.to_lower(53), 53)
    T.assert_equal(results, "'_' unchanged", Char.to_lower(95), 95)
    Return 1
End Process

Process called "test_to_upper" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.to_upper")

    T.assert_equal(results, "'a' -> 'A'", Char.to_upper(97), 65)
    T.assert_equal(results, "'z' -> 'Z'", Char.to_upper(122), 90)
    T.assert_equal(results, "'m' -> 'M'", Char.to_upper(109), 77)
    T.assert_equal(results, "'A' unchanged", Char.to_upper(65), 65)
    T.assert_equal(results, "'5' unchanged", Char.to_upper(53), 53)
    T.assert_equal(results, "'_' unchanged", Char.to_upper(95), 95)
    Return 1
End Process

Note: ============================================================================
Note: DIGIT VALUE TESTS
Note: ============================================================================

Process called "test_digit_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.digit_value")

    T.assert_equal(results, "'0' -> 0", Char.digit_value(48), 0)
    T.assert_equal(results, "'5' -> 5", Char.digit_value(53), 5)
    T.assert_equal(results, "'9' -> 9", Char.digit_value(57), 9)
    T.assert_equal(results, "'a' -> -1", Char.digit_value(97), 0 minus 1)
    T.assert_equal(results, "'/' -> -1", Char.digit_value(47), 0 minus 1)
    Return 1
End Process

Process called "test_hex_digit_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.hex_digit_value")

    T.assert_equal(results, "'0' -> 0", Char.hex_digit_value(48), 0)
    T.assert_equal(results, "'9' -> 9", Char.hex_digit_value(57), 9)
    T.assert_equal(results, "'a' -> 10", Char.hex_digit_value(97), 10)
    T.assert_equal(results, "'f' -> 15", Char.hex_digit_value(102), 15)
    T.assert_equal(results, "'A' -> 10", Char.hex_digit_value(65), 10)
    T.assert_equal(results, "'F' -> 15", Char.hex_digit_value(70), 15)
    T.assert_equal(results, "'g' -> -1", Char.hex_digit_value(103), 0 minus 1)
    Return 1
End Process

Process called "test_octal_digit_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.octal_digit_value")

    T.assert_equal(results, "'0' -> 0", Char.octal_digit_value(48), 0)
    T.assert_equal(results, "'7' -> 7", Char.octal_digit_value(55), 7)
    T.assert_equal(results, "'8' -> -1", Char.octal_digit_value(56), 0 minus 1)
    Return 1
End Process

Process called "test_binary_digit_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.binary_digit_value")

    T.assert_equal(results, "'0' -> 0", Char.binary_digit_value(48), 0)
    T.assert_equal(results, "'1' -> 1", Char.binary_digit_value(49), 1)
    T.assert_equal(results, "'2' -> -1", Char.binary_digit_value(50), 0 minus 1)
    Return 1
End Process

Note: ============================================================================
Note: PRINTABLE / CONTROL TESTS
Note: ============================================================================

Process called "test_is_printable" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_printable")

    T.assert_equal(results, "space is printable", Char.is_printable(32), 1)
    T.assert_equal(results, "'A' is printable", Char.is_printable(65), 1)
    T.assert_equal(results, "'~' (126) is printable", Char.is_printable(126), 1)
    T.assert_equal(results, "DEL (127) is not printable", Char.is_printable(127), 0)
    T.assert_equal(results, "tab is not printable", Char.is_printable(9), 0)
    T.assert_equal(results, "null is not printable", Char.is_printable(0), 0)
    Return 1
End Process

Process called "test_is_control" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_control")

    T.assert_equal(results, "null is control", Char.is_control(0), 1)
    T.assert_equal(results, "tab is control", Char.is_control(9), 1)
    T.assert_equal(results, "LF is control", Char.is_control(10), 1)
    T.assert_equal(results, "ESC (27) is control", Char.is_control(27), 1)
    T.assert_equal(results, "DEL (127) is control", Char.is_control(127), 1)
    T.assert_equal(results, "space is not control", Char.is_control(32), 0)
    T.assert_equal(results, "'A' is not control", Char.is_control(65), 0)
    Return 1
End Process

Process called "test_is_punctuation" that takes results as Integer returns Integer:
    T.begin_suite(results, "char_core.is_punctuation")

    T.assert_equal(results, "'.' is punctuation", Char.is_punctuation(46), 1)
    T.assert_equal(results, "',' is punctuation", Char.is_punctuation(44), 1)
    T.assert_equal(results, "';' is punctuation", Char.is_punctuation(59), 1)
    T.assert_equal(results, "'_' is punctuation", Char.is_punctuation(95), 1)
    T.assert_equal(results, "'A' is not punctuation", Char.is_punctuation(65), 0)
    T.assert_equal(results, "'5' is not punctuation", Char.is_punctuation(53), 0)
    T.assert_equal(results, "space is not punctuation", Char.is_punctuation(32), 0)
    T.assert_equal(results, "null is not punctuation", Char.is_punctuation(0), 0)
    Return 1
End Process

Note: ============================================================================
Note: MAIN ENTRY POINT
Note: ============================================================================

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_is_digit(results)
    test_is_hex_digit(results)
    test_is_octal_digit(results)
    test_is_binary_digit(results)
    test_is_uppercase(results)
    test_is_lowercase(results)
    test_is_alpha(results)
    test_is_alphanumeric(results)
    test_is_identifier_start(results)
    test_is_identifier_continue(results)
    test_is_whitespace(results)
    test_is_inline_whitespace(results)
    test_is_line_terminator(results)
    test_to_lower(results)
    test_to_upper(results)
    test_digit_value(results)
    test_hex_digit_value(results)
    test_octal_digit_value(results)
    test_binary_digit_value(results)
    test_is_printable(results)
    test_is_control(results)
    test_is_punctuation(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
