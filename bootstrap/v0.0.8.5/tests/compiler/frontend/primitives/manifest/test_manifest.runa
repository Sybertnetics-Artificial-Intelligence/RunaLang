Note:
Unit tests for compiler/frontend/primitives/manifest/manifest.runa.

KAT: manifest parse with dep serde = "^1.0" extracts spec correctly.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/manifest/manifest.runa" as Manifest
Import "compiler/frontend/primitives/config/config.runa" as Cfg
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_parse_minimal_manifest" that takes results as Integer returns Integer:
    T.begin_suite(results, "manifest.parse minimal")
    Let source be "Configuration:\n    Section \"package\":\n        name as \"my-crate\"\n        version as \"0.1.0\"\n    End Section\nEnd Configuration\n"
    Let m be proc manifest_parse from Manifest with source
    T.assert_not_null(results, "parsed", m)
    Let name be proc manifest_name from Manifest with m
    T.assert_not_null(results, "name extracted", name)
    Let name_eq be proc string_equals from StringCore with name, "my-crate"
    T.assert_equal(results, "name = my-crate", name_eq, 1)
    Let v be proc manifest_version from Manifest with m
    Let v_eq be proc string_equals from StringCore with v, "0.1.0"
    T.assert_equal(results, "version = 0.1.0", v_eq, 1)
    proc config_value_destroy from Cfg with m
    Return 1
End Process

Process called "test_parse_with_dependencies" that takes results as Integer returns Integer:
    T.begin_suite(results, "manifest.parse with dependencies KAT")
    Let source be "Configuration:\n    Section \"package\":\n        name as \"test\"\n        version as \"0.1.0\"\n    End Section\n    Section \"dependencies\":\n        serde as \"^1.0\"\n    End Section\nEnd Configuration\n"
    Let m be proc manifest_parse from Manifest with source
    T.assert_not_null(results, "parsed", m)
    Let deps be proc manifest_dependencies from Manifest with m
    T.assert_not_null(results, "dependencies section present", deps)
    Let spec be proc manifest_dep_version_spec from Manifest with m, "serde"
    T.assert_not_null(results, "serde version spec extracted", spec)
    Let eq be proc string_equals from StringCore with spec, "^1.0"
    T.assert_equal(results, "spec is ^1.0", eq, 1)
    proc config_value_destroy from Cfg with m
    Return 1
End Process

Process called "test_validate_minimal" that takes results as Integer returns Integer:
    T.begin_suite(results, "manifest.validate minimal")
    Let source be "Configuration:\n    Section \"package\":\n        name as \"ok\"\n        version as \"1.0.0\"\n    End Section\nEnd Configuration\n"
    Let m be proc manifest_parse from Manifest with source
    Let issues be proc manifest_validate from Manifest with m
    T.assert_not_null(results, "issues list non-null", issues)
    T.assert_equal(results, "no issues", proc length from List with issues, 0)
    proc manifest_issues_destroy from Manifest with issues
    proc config_value_destroy from Cfg with m
    Return 1
End Process

Process called "test_validate_missing_name" that takes results as Integer returns Integer:
    T.begin_suite(results, "manifest.validate missing name")
    Let source be "Configuration:\n    Section \"package\":\n        version as \"1.0.0\"\n    End Section\nEnd Configuration\n"
    Let m be proc manifest_parse from Manifest with source
    Let issues be proc manifest_validate from Manifest with m
    T.assert_greater_than(results, "missing name causes issue", proc length from List with issues, 0)
    proc manifest_issues_destroy from Manifest with issues
    proc config_value_destroy from Cfg with m
    Return 1
End Process

Process called "test_serialize" that takes results as Integer returns Integer:
    T.begin_suite(results, "manifest.serialize")
    Let source be "Configuration:\n    Section \"package\":\n        name as \"sx\"\n        version as \"2.0.0\"\n    End Section\nEnd Configuration\n"
    Let m be proc manifest_parse from Manifest with source
    Let out be proc manifest_serialize from Manifest with m
    T.assert_not_null(results, "serialize non-null", out)
    proc config_value_destroy from Cfg with m
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_parse_minimal_manifest(results)
    test_parse_with_dependencies(results)
    test_validate_minimal(results)
    test_validate_missing_name(results)
    test_serialize(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
