Note:
Unit tests for compiler/frontend/primitives/manifest/version_spec.runa.

KAT: SemVer "^1.2.3" satisfies "1.5.0" but not "2.0.0".
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/manifest/version_spec.runa" as VS

Process called "test_parse_and_destroy" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_spec.parse / destroy")
    Let v be proc version_parse from VS with "1.2.3"
    T.assert_not_null(results, "1.2.3 parsed", v)
    proc version_destroy from VS with v

    Let bad be proc version_parse from VS with "invalid"
    T.assert_equal(results, "invalid rejected", bad, 0)
    Return 1
End Process

Process called "test_compare" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_spec.compare")
    Let a be proc version_parse from VS with "1.0.0"
    Let b be proc version_parse from VS with "2.0.0"
    T.assert_equal(results, "1<2", (proc version_compare from VS with a, b), 0 minus 1)
    T.assert_equal(results, "2>1", (proc version_compare from VS with b, a), 1)
    T.assert_equal(results, "1==1", (proc version_compare from VS with a, a), 0)
    proc version_destroy from VS with a
    proc version_destroy from VS with b
    Return 1
End Process

Process called "test_satisfies_caret_KAT" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_spec.KAT: ^1.2.3 satisfies 1.5.0 but not 2.0.0")
    Let v_150 be proc version_parse from VS with "1.5.0"
    T.assert_equal(results, "1.5.0 satisfies ^1.2.3", (proc version_satisfies from VS with v_150, "^1.2.3"), 1)
    Let v_200 be proc version_parse from VS with "2.0.0"
    T.assert_equal(results, "2.0.0 NOT satisfies ^1.2.3", (proc version_satisfies from VS with v_200, "^1.2.3"), 0)
    Let v_122 be proc version_parse from VS with "1.2.2"
    T.assert_equal(results, "1.2.2 NOT satisfies ^1.2.3", (proc version_satisfies from VS with v_122, "^1.2.3"), 0)
    proc version_destroy from VS with v_150
    proc version_destroy from VS with v_200
    proc version_destroy from VS with v_122
    Return 1
End Process

Process called "test_satisfies_range" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_spec.satisfies range")
    Let v be proc version_parse from VS with "1.5.0"
    T.assert_equal(results, "1.5.0 satisfies >=1.0 <2.0", (proc version_satisfies from VS with v, ">=1.0.0 <2.0.0"), 1)
    T.assert_equal(results, "1.5.0 NOT satisfies >=2.0", (proc version_satisfies from VS with v, ">=2.0.0"), 0)
    proc version_destroy from VS with v
    Return 1
End Process

Process called "test_satisfies_any" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_spec.satisfies *")
    Let v be proc version_parse from VS with "9.9.9"
    T.assert_equal(results, "any version satisfies *", (proc version_satisfies from VS with v, "*"), 1)
    proc version_destroy from VS with v
    Return 1
End Process

Process called "test_range_intersect" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_spec.range_intersect")
    Let r1 be proc version_range_intersect from VS with ">=1.0.0 <3.0.0", ">=2.0.0 <4.0.0"
    T.assert_not_null(results, "intersect non-null", r1)
    Let r2 be proc version_range_intersect from VS with "*", ">=2.0.0"
    T.assert_not_null(results, "* intersect range", r2)
    Return 1
End Process

Process called "test_range_to_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_spec.range_to_string")
    Let s be proc version_range_to_string from VS with ">=1.0.0 <2.0.0"
    T.assert_not_null(results, "non-null output", s)
    Let s2 be proc version_range_to_string from VS with "*"
    T.assert_not_null(results, "any output", s2)
    Return 1
End Process

Process called "test_to_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_spec.to_string")
    Let v be proc version_parse from VS with "1.2.3"
    Let s be proc version_to_string from VS with v
    T.assert_not_null(results, "to_string non-null", s)
    proc version_destroy from VS with v
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_parse_and_destroy(results)
    test_compare(results)
    test_satisfies_caret_KAT(results)
    test_satisfies_range(results)
    test_satisfies_any(results)
    test_range_intersect(results)
    test_range_to_string(results)
    test_to_string(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
