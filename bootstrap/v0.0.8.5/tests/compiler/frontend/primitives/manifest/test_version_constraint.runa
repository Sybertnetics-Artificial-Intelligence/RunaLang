Note:
Unit tests for compiler/frontend/primitives/manifest/version_constraint.runa.

Covers:
  - version_create / version_destroy / accessor round-trips
  - version_parse on canonical SemVer 2.0.0 strings
  - version_parse rejection of malformed inputs
  - version_compare full ordering (numeric, prerelease, build-ignore)
  - constraint_parse for caret, tilde, range, exact, wildcard, any
  - version_satisfies for each constraint kind
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/manifest/version_constraint.runa" as VC

Process called "test_version_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.version_create")

    Let v be proc version_create from VC with 1, 2, 3, 0, 0
    T.assert_not_null(results, "create 1.2.3", v)
    T.assert_equal(results, "major", (proc version_major from VC with v),1)
    T.assert_equal(results, "minor", (proc version_minor from VC with v),2)
    T.assert_equal(results, "patch", (proc version_patch from VC with v),3)
    T.assert_equal(results, "no prerelease", (proc version_is_prerelease from VC with v),0)
    proc version_destroy from VC with v

    Let bad be proc version_create from VC with 0 minus 1, 0, 0, 0, 0
    T.assert_equal(results, "negative major rejected", bad, 0)
    Return 1
End Process

Process called "test_version_parse_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.version_parse basic")

    Let v be proc version_parse from VC with "1.2.3"
    T.assert_not_null(results, "parse 1.2.3", v)
    T.assert_equal(results, "major", (proc version_major from VC with v),1)
    T.assert_equal(results, "minor", (proc version_minor from VC with v),2)
    T.assert_equal(results, "patch", (proc version_patch from VC with v),3)
    proc version_destroy_deep from VC with v

    Let v2 be proc version_parse from VC with "0.1.0"
    T.assert_not_null(results, "parse 0.1.0", v2)
    proc version_destroy_deep from VC with v2

    Let v3 be proc version_parse from VC with "10.20.30"
    T.assert_not_null(results, "parse 10.20.30", v3)
    T.assert_equal(results, "major 10", (proc version_major from VC with v3),10)
    T.assert_equal(results, "minor 20", (proc version_minor from VC with v3),20)
    T.assert_equal(results, "patch 30", (proc version_patch from VC with v3),30)
    proc version_destroy_deep from VC with v3
    Return 1
End Process

Process called "test_version_parse_prerelease" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.version_parse prerelease")

    Let v be proc version_parse from VC with "1.0.0-alpha"
    T.assert_not_null(results, "parse 1.0.0-alpha", v)
    T.assert_equal(results, "has prerelease", (proc version_is_prerelease from VC with v),1)
    proc version_destroy_deep from VC with v

    Let v2 be proc version_parse from VC with "1.0.0-alpha.1"
    T.assert_not_null(results, "parse 1.0.0-alpha.1", v2)
    proc version_destroy_deep from VC with v2

    Let v3 be proc version_parse from VC with "1.0.0-rc.1+build.456"
    T.assert_not_null(results, "parse with build metadata", v3)
    proc version_destroy_deep from VC with v3
    Return 1
End Process

Process called "test_version_parse_rejects" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.version_parse rejection")

    T.assert_equal(results, "reject 1.2", (proc version_parse from VC with "1.2"), 0)
    T.assert_equal(results, "reject 1.2.3.4", (proc version_parse from VC with "1.2.3.4"), 0)
    T.assert_equal(results, "reject 01.2.3", (proc version_parse from VC with "01.2.3"), 0)
    T.assert_equal(results, "reject 1.02.3", (proc version_parse from VC with "1.02.3"), 0)
    T.assert_equal(results, "reject 1.2.3-", (proc version_parse from VC with "1.2.3-"), 0)
    T.assert_equal(results, "reject empty", (proc version_parse from VC with ""), 0)
    T.assert_equal(results, "reject v1.2.3", (proc version_parse from VC with "v1.2.3"), 0)
    Return 1
End Process

Process called "test_version_compare_numeric" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.version_compare numeric")

    Let a be proc version_parse from VC with "1.0.0"
    Let b be proc version_parse from VC with "2.0.0"
    T.assert_equal(results, "1.0.0 < 2.0.0", (proc version_compare from VC with a, b), 0 minus 1)
    T.assert_equal(results, "2.0.0 > 1.0.0", (proc version_compare from VC with b, a), 1)
    T.assert_equal(results, "1.0.0 == 1.0.0", (proc version_compare from VC with a, a), 0)

    Let c be proc version_parse from VC with "1.2.0"
    Let d be proc version_parse from VC with "1.10.0"
    T.assert_equal(results, "1.2.0 < 1.10.0", (proc version_compare from VC with c, d), 0 minus 1)

    proc version_destroy_deep from VC with a
    proc version_destroy_deep from VC with b
    proc version_destroy_deep from VC with c
    proc version_destroy_deep from VC with d
    Return 1
End Process

Process called "test_version_compare_prerelease" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.version_compare prerelease")

    Let release be proc version_parse from VC with "1.0.0"
    Let alpha be proc version_parse from VC with "1.0.0-alpha"
    T.assert_equal(results, "alpha < release", (proc version_compare from VC with alpha, release), 0 minus 1)
    T.assert_equal(results, "release > alpha", (proc version_compare from VC with release, alpha), 1)

    Let alpha1 be proc version_parse from VC with "1.0.0-alpha.1"
    T.assert_equal(results, "alpha < alpha.1", (proc version_compare from VC with alpha, alpha1), 0 minus 1)

    proc version_destroy_deep from VC with release
    proc version_destroy_deep from VC with alpha
    proc version_destroy_deep from VC with alpha1
    Return 1
End Process

Process called "test_constraint_exact" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.constraint_parse exact")

    Let c be proc constraint_parse from VC with "1.2.3"
    T.assert_not_null(results, "parse exact", c)
    T.assert_equal(results, "kind is EXACT", (proc constraint_kind from VC with c),1)

    Let v be proc version_parse from VC with "1.2.3"
    Let v2 be proc version_parse from VC with "1.2.4"
    T.assert_equal(results, "1.2.3 satisfies", (proc version_satisfies from VC with v, c),1)
    T.assert_equal(results, "1.2.4 not satisfies", (proc version_satisfies from VC with v2, c),0)

    proc constraint_destroy_deep from VC with c
    proc version_destroy_deep from VC with v
    proc version_destroy_deep from VC with v2
    Return 1
End Process

Process called "test_constraint_caret" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.constraint_parse caret")

    Let c be proc constraint_parse from VC with "^1.2.3"
    T.assert_not_null(results, "parse caret", c)

    Let v_match1 be proc version_parse from VC with "1.2.3"
    Let v_match2 be proc version_parse from VC with "1.2.4"
    Let v_match3 be proc version_parse from VC with "1.3.0"
    Let v_reject1 be proc version_parse from VC with "2.0.0"
    Let v_reject2 be proc version_parse from VC with "1.2.2"
    Let v_reject3 be proc version_parse from VC with "0.9.9"

    T.assert_equal(results, "1.2.3 satisfies ^1.2.3", (proc version_satisfies from VC with v_match1, c),1)
    T.assert_equal(results, "1.2.4 satisfies ^1.2.3", (proc version_satisfies from VC with v_match2, c),1)
    T.assert_equal(results, "1.3.0 satisfies ^1.2.3", (proc version_satisfies from VC with v_match3, c),1)
    T.assert_equal(results, "2.0.0 rejected", (proc version_satisfies from VC with v_reject1, c),0)
    T.assert_equal(results, "1.2.2 rejected", (proc version_satisfies from VC with v_reject2, c),0)
    T.assert_equal(results, "0.9.9 rejected", (proc version_satisfies from VC with v_reject3, c),0)

    proc constraint_destroy_deep from VC with c
    proc version_destroy_deep from VC with v_match1
    proc version_destroy_deep from VC with v_match2
    proc version_destroy_deep from VC with v_match3
    proc version_destroy_deep from VC with v_reject1
    proc version_destroy_deep from VC with v_reject2
    proc version_destroy_deep from VC with v_reject3
    Return 1
End Process

Process called "test_constraint_tilde" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.constraint_parse tilde")

    Let c be proc constraint_parse from VC with "~1.2.3"
    T.assert_not_null(results, "parse tilde", c)

    Let v_match1 be proc version_parse from VC with "1.2.3"
    Let v_match2 be proc version_parse from VC with "1.2.99"
    Let v_reject1 be proc version_parse from VC with "1.3.0"
    Let v_reject2 be proc version_parse from VC with "1.2.2"

    T.assert_equal(results, "1.2.3 satisfies ~1.2.3", (proc version_satisfies from VC with v_match1, c),1)
    T.assert_equal(results, "1.2.99 satisfies ~1.2.3", (proc version_satisfies from VC with v_match2, c),1)
    T.assert_equal(results, "1.3.0 rejected", (proc version_satisfies from VC with v_reject1, c),0)
    T.assert_equal(results, "1.2.2 rejected", (proc version_satisfies from VC with v_reject2, c),0)

    proc constraint_destroy_deep from VC with c
    proc version_destroy_deep from VC with v_match1
    proc version_destroy_deep from VC with v_match2
    proc version_destroy_deep from VC with v_reject1
    proc version_destroy_deep from VC with v_reject2
    Return 1
End Process

Process called "test_constraint_range" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.constraint_parse range")

    Let c be proc constraint_parse from VC with ">=1.0.0 <2.0.0"
    T.assert_not_null(results, "parse range", c)
    T.assert_equal(results, "kind is RANGE", (proc constraint_kind from VC with c),4)

    Let v1 be proc version_parse from VC with "1.0.0"
    Let v2 be proc version_parse from VC with "1.5.3"
    Let v3 be proc version_parse from VC with "2.0.0"
    Let v4 be proc version_parse from VC with "0.9.9"

    T.assert_equal(results, "1.0.0 satisfies", (proc version_satisfies from VC with v1, c),1)
    T.assert_equal(results, "1.5.3 satisfies", (proc version_satisfies from VC with v2, c),1)
    T.assert_equal(results, "2.0.0 rejected", (proc version_satisfies from VC with v3, c),0)
    T.assert_equal(results, "0.9.9 rejected", (proc version_satisfies from VC with v4, c),0)

    proc constraint_destroy_deep from VC with c
    proc version_destroy_deep from VC with v1
    proc version_destroy_deep from VC with v2
    proc version_destroy_deep from VC with v3
    proc version_destroy_deep from VC with v4
    Return 1
End Process

Process called "test_constraint_wildcard" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.constraint_parse wildcard")

    Let c be proc constraint_parse from VC with "1.2.*"
    T.assert_not_null(results, "parse 1.2.*", c)
    T.assert_equal(results, "kind is WILDCARD", (proc constraint_kind from VC with c),7)

    Let v1 be proc version_parse from VC with "1.2.0"
    Let v2 be proc version_parse from VC with "1.2.99"
    Let v3 be proc version_parse from VC with "1.3.0"
    Let v4 be proc version_parse from VC with "2.2.0"

    T.assert_equal(results, "1.2.0 satisfies 1.2.*", (proc version_satisfies from VC with v1, c),1)
    T.assert_equal(results, "1.2.99 satisfies 1.2.*", (proc version_satisfies from VC with v2, c),1)
    T.assert_equal(results, "1.3.0 rejected", (proc version_satisfies from VC with v3, c),0)
    T.assert_equal(results, "2.2.0 rejected", (proc version_satisfies from VC with v4, c),0)

    proc constraint_destroy_deep from VC with c
    proc version_destroy_deep from VC with v1
    proc version_destroy_deep from VC with v2
    proc version_destroy_deep from VC with v3
    proc version_destroy_deep from VC with v4
    Return 1
End Process

Process called "test_constraint_any" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.constraint_parse any")

    Let c be proc constraint_parse from VC with "*"
    T.assert_not_null(results, "parse *", c)
    T.assert_equal(results, "kind is ANY", (proc constraint_kind from VC with c),8)

    Let v1 be proc version_parse from VC with "0.0.1"
    Let v2 be proc version_parse from VC with "999.999.999"
    T.assert_equal(results, "0.0.1 satisfies *", (proc version_satisfies from VC with v1, c),1)
    T.assert_equal(results, "999.999.999 satisfies *", (proc version_satisfies from VC with v2, c),1)

    proc constraint_destroy_deep from VC with c
    proc version_destroy_deep from VC with v1
    proc version_destroy_deep from VC with v2
    Return 1
End Process

Process called "test_version_to_string_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "version_constraint.version_to_string roundtrip")

    Let v be proc version_parse from VC with "1.2.3"
    Let s be proc version_to_string from VC with v
    T.assert_not_null(results, "to_string non-null", s)
    proc version_destroy_deep from VC with v

    Let v2 be proc version_parse from VC with "1.0.0-alpha.1"
    Let s2 be proc version_to_string from VC with v2
    T.assert_not_null(results, "to_string prerelease non-null", s2)
    proc version_destroy_deep from VC with v2
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_version_create(results)
    test_version_parse_basic(results)
    test_version_parse_prerelease(results)
    test_version_parse_rejects(results)
    test_version_compare_numeric(results)
    test_version_compare_prerelease(results)
    test_constraint_exact(results)
    test_constraint_caret(results)
    test_constraint_tilde(results)
    test_constraint_range(results)
    test_constraint_wildcard(results)
    test_constraint_any(results)
    test_version_to_string_roundtrip(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
