Note:
Unit tests for compiler/frontend/primitives/database/transaction.runa.

We validate the wrapper's input handling and state machine. The full
begin/commit path requires a live driver, which is covered by driver
integration tests; here we focus on null-safety, isolation clamping
and savepoint name-comparison helpers.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/database/transaction.runa" as Tx

Process called "test_transaction_begin_null_returns_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "transaction.begin_null")
    Let rc be Tx.transaction_begin(0, 0)
    T.assert_equal(results, "begin on null returns 0", rc, 0)
    Return 1
End Process

Process called "test_transaction_helpers_with_null" that takes results as Integer returns Integer:
    T.begin_suite(results, "transaction.helpers_null")
    T.assert_equal(results, "state(0) is ROLLED_BACK", Tx.transaction_state(0), 3)
    T.assert_equal(results, "isolation(0) is READ_UNCOMMITTED", Tx.transaction_isolation(0), 0)
    T.assert_equal(results, "connection(0) is 0", Tx.transaction_connection(0), 0)
    T.assert_equal(results, "savepoint_count(0) is 0", Tx.transaction_savepoint_count(0), 0)
    T.assert_equal(results, "commit(0) returns INVALID", Tx.transaction_commit(0), 0)
    T.assert_equal(results, "rollback(0) returns INVALID", Tx.transaction_rollback(0), 0)
    T.assert_equal(results, "savepoint(0) returns INVALID", Tx.transaction_savepoint(0, 0, 0), 0)
    T.assert_equal(results, "release_savepoint(0) returns INVALID", Tx.transaction_release_savepoint(0, 0, 0), 0)
    T.assert_equal(results, "rollback_to_savepoint(0) returns INVALID", Tx.transaction_rollback_to_savepoint(0, 0, 0), 0)
    Return 1
End Process

Process called "test_isolation_level_name_round_trip" that takes results as Integer returns Integer:
    T.begin_suite(results, "transaction.isolation_name")
    T.assert_equal(results, "READ_UNCOMMITTED -> 1001", Tx.isolation_level_name(0), 1001)
    T.assert_equal(results, "READ_COMMITTED -> 1002", Tx.isolation_level_name(1), 1002)
    T.assert_equal(results, "REPEATABLE_READ -> 1003", Tx.isolation_level_name(2), 1003)
    T.assert_equal(results, "SERIALIZABLE -> 1004", Tx.isolation_level_name(3), 1004)
    T.assert_equal(results, "out-of-range -> 1000", Tx.isolation_level_name(99), 1000)
    Return 1
End Process

Process called "test_with_transaction_null_args" that takes results as Integer returns Integer:
    T.begin_suite(results, "transaction.with_transaction_null")
    Let rc1 be Tx.with_transaction(0, 0, 1)
    T.assert_equal(results, "null connection returns INVALID", rc1, 0)
    Let rc2 be Tx.with_transaction(1, 0, 0)
    T.assert_equal(results, "null fn returns INVALID", rc2, 0)
    Return 1
End Process

Process called "test_install_savepoint_drivers_null" that takes results as Integer returns Integer:
    T.begin_suite(results, "transaction.install_drivers_null")
    Let rc be Tx.transaction_install_savepoint_drivers(0, 0, 0, 0)
    T.assert_equal(results, "install on null tx returns INVALID", rc, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_transaction_begin_null_returns_zero(results)
    test_transaction_helpers_with_null(results)
    test_isolation_level_name_round_trip(results)
    test_with_transaction_null_args(results)
    test_install_savepoint_drivers_null(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
