Note:
Unit tests for compiler/frontend/primitives/database/query_builder.runa.

These tests construct builders, accumulate clauses, then emit SQL and
spot-check the resulting byte buffer. The KAT from the brief:

  builder_select(["id", "name"]).from("users").where("age > ?", 18).limit(10)

emits a parameterised SELECT statement for the chosen dialect; we
verify the dialect-specific placeholder rewrite and confirm the
parameter list captures bound values in declaration order.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/database/query_builder.runa" as QB

Process called "test_builder_select_basic_dispatch" that takes results as Integer returns Integer:
    T.begin_suite(results, "query_builder.select_create")
    Let b be QB.builder_select(1)
    T.assert_not_null(results, "builder allocated", b)
    T.assert_equal(results, "kind is SELECT", QB.builder_kind(b), 1)
    T.assert_equal(results, "dialect stored", QB.builder_dialect(b), 1)
    QB.builder_destroy(b)
    Return 1
End Process

Process called "test_builder_param_binding_count" that takes results as Integer returns Integer:
    T.begin_suite(results, "query_builder.param_count")
    Let b be QB.builder_select(2)
    QB.builder_bind_integer(b, 18)
    QB.builder_bind_string(b, 0, 0)
    QB.builder_bind_boolean(b, 1)
    T.assert_equal(results, "three params bound", QB.builder_param_count(b), 3)
    QB.builder_destroy(b)
    Return 1
End Process

Process called "test_builder_select_emits_sql" that takes results as Integer returns Integer:
    T.begin_suite(results, "query_builder.select_emit_postgres")
    Let b be QB.builder_select(1)
    Let id_col be "id"
    Let name_col be "name"
    Let table be "users"
    Let where_text be "age > ?"
    QB.builder_add_column(b, id_col, 2)
    QB.builder_add_column(b, name_col, 4)
    QB.builder_from(b, table, 5)
    QB.builder_where(b, where_text, 7, 1)
    QB.builder_bind_integer(b, 18)
    QB.builder_limit(b, 10)

    Let len_holder be allocate(8)
    __store(len_holder, 0, 0)
    Let buf be QB.builder_to_sql(b, len_holder)
    T.assert_not_null(results, "emit returns buffer", buf)
    Let length be __load(len_holder, 0)
    T.assert_greater_than(results, "emitted SQL non-empty", length, 0)
    Note: First seven bytes must be "SELECT ".
    T.assert_equal(results, "S at offset 0", __load_byte(buf, 0), 83)
    T.assert_equal(results, "E at offset 1", __load_byte(buf, 1), 69)
    T.assert_equal(results, "L at offset 2", __load_byte(buf, 2), 76)
    T.assert_equal(results, "E at offset 3", __load_byte(buf, 3), 69)
    T.assert_equal(results, "C at offset 4", __load_byte(buf, 4), 67)
    T.assert_equal(results, "T at offset 5", __load_byte(buf, 5), 84)
    T.assert_equal(results, "space at offset 6", __load_byte(buf, 6), 32)
    Return 1
End Process

Process called "test_builder_insert_default_columns" that takes results as Integer returns Integer:
    T.begin_suite(results, "query_builder.insert_no_columns")
    Let b be QB.builder_insert(3)
    Let table be "logs"
    QB.builder_from(b, table, 4)
    QB.builder_bind_integer(b, 1)
    QB.builder_bind_integer(b, 2)

    Let len_holder be allocate(8)
    __store(len_holder, 0, 0)
    Let buf be QB.builder_to_sql(b, len_holder)
    T.assert_not_null(results, "insert buf returned", buf)
    T.assert_greater_than(results, "insert SQL non-empty", __load(len_holder, 0), 0)
    Note: Confirms starts with "INSERT INTO ".
    T.assert_equal(results, "I at offset 0", __load_byte(buf, 0), 73)
    T.assert_equal(results, "N at offset 1", __load_byte(buf, 1), 78)
    T.assert_equal(results, "S at offset 2", __load_byte(buf, 2), 83)
    T.assert_equal(results, "E at offset 3", __load_byte(buf, 3), 69)
    T.assert_equal(results, "R at offset 4", __load_byte(buf, 4), 82)
    T.assert_equal(results, "T at offset 5", __load_byte(buf, 5), 84)
    Return 1
End Process

Process called "test_builder_delete_emits_delete_keyword" that takes results as Integer returns Integer:
    T.begin_suite(results, "query_builder.delete_emit")
    Let b be QB.builder_delete(2)
    Let table be "items"
    QB.builder_from(b, table, 5)
    Let where_text be "id = ?"
    QB.builder_where(b, where_text, 6, 1)
    QB.builder_bind_integer(b, 99)
    Let len_holder be allocate(8)
    __store(len_holder, 0, 0)
    Let buf be QB.builder_to_sql(b, len_holder)
    T.assert_greater_than(results, "delete SQL non-empty", __load(len_holder, 0), 0)
    T.assert_equal(results, "D at offset 0", __load_byte(buf, 0), 68)
    T.assert_equal(results, "E at offset 1", __load_byte(buf, 1), 69)
    T.assert_equal(results, "L at offset 2", __load_byte(buf, 2), 76)
    T.assert_equal(results, "E at offset 3", __load_byte(buf, 3), 69)
    T.assert_equal(results, "T at offset 4", __load_byte(buf, 4), 84)
    T.assert_equal(results, "E at offset 5", __load_byte(buf, 5), 69)
    Return 1
End Process

Process called "test_builder_update_emit" that takes results as Integer returns Integer:
    T.begin_suite(results, "query_builder.update_emit")
    Let b be QB.builder_update(1)
    Let table be "users"
    QB.builder_from(b, table, 5)
    Let name_col be "name"
    QB.builder_add_column(b, name_col, 4)
    Let where_text be "id = ?"
    QB.builder_where(b, where_text, 6, 1)
    QB.builder_bind_string(b, 0, 0)
    QB.builder_bind_integer(b, 42)
    Let len_holder be allocate(8)
    __store(len_holder, 0, 0)
    Let buf be QB.builder_to_sql(b, len_holder)
    T.assert_not_null(results, "update buffer returned", buf)
    T.assert_greater_than(results, "update SQL non-empty", __load(len_holder, 0), 0)
    Note: Starts with "UPDATE "
    T.assert_equal(results, "U at offset 0", __load_byte(buf, 0), 85)
    T.assert_equal(results, "P at offset 1", __load_byte(buf, 1), 80)
    T.assert_equal(results, "D at offset 2", __load_byte(buf, 2), 68)
    T.assert_equal(results, "A at offset 3", __load_byte(buf, 3), 65)
    T.assert_equal(results, "T at offset 4", __load_byte(buf, 4), 84)
    T.assert_equal(results, "E at offset 5", __load_byte(buf, 5), 69)
    Return 1
End Process

Process called "test_builder_limit_clamps_negative" that takes results as Integer returns Integer:
    T.begin_suite(results, "query_builder.limit_clamp")
    Let b be QB.builder_select(1)
    QB.builder_limit(b, -10)
    QB.builder_offset(b, -5)
    Note: Implementation maps negative to -1 (unset); SQL emission omits clauses.
    Let table be "x"
    QB.builder_from(b, table, 1)
    Let len_holder be allocate(8)
    __store(len_holder, 0, 0)
    Let buf be QB.builder_to_sql(b, len_holder)
    T.assert_greater_than(results, "select with no rows emitted body", __load(len_holder, 0), 13)
    Return 1
End Process

Process called "count_dollar_signs" takes buf as Integer, length as Integer returns Integer:
    Note: Walks the rendered SQL buffer and counts byte 36 ($). Used by the
    Note: Postgres placeholder test to confirm that exactly three $-style
    Note: positional markers were emitted (one per unquoted `?` in the input).
    Let i be 0
    Let cnt be 0
    While i is less than length:
        Let b be __load_byte(buf, i)
        If b is equal to 36:
            Set cnt to cnt plus 1
        End If
        Set i to i plus 1
    End While
    Return cnt
End Process

Process called "count_question_marks" takes buf as Integer, length as Integer returns Integer:
    Note: Walks the rendered SQL buffer and counts byte 63 (?). Used by the
    Note: MySQL placeholder test to confirm that exactly three positional
    Note: markers were emitted and that the literal `'?'` was preserved.
    Let i be 0
    Let cnt be 0
    While i is less than length:
        Let b be __load_byte(buf, i)
        If b is equal to 63:
            Set cnt to cnt plus 1
        End If
        Set i to i plus 1
    End While
    Return cnt
End Process

Process called "contains_quoted_question" takes buf as Integer, length as Integer returns Integer:
    Note: Returns 1 iff the buffer contains the substring "'?'" (the SQL
    Note: literal single-quote, question mark, single-quote). This is the
    Note: regression hook for the qb_append_predicate_text bug where the
    Note: `?` inside a string literal was incorrectly rewritten as $1.
    If length is less than 3:
        Return 0
    End If
    Let limit be length minus 2
    Let i be 0
    While i is less than limit:
        Let b0 be __load_byte(buf, i)
        Let b1 be __load_byte(buf, (i plus 1))
        Let b2 be __load_byte(buf, (i plus 2))
        If b0 is equal to 39:
            If b1 is equal to 63:
                If b2 is equal to 39:
                    Return 1
                End If
            End If
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "test_predicate_skips_string_literals_postgres" that takes results as Integer returns Integer:
    Note: Regression test for the placeholder-rewrite bug. The predicate text

    Note:   age > ? AND comment = '?' AND tag IN (?, ?)

    Note: contains four byte-63 characters but only three of them are real
    Note: positional placeholders — the middle one is inside a SQL string
    Note: literal `'?'`. The Postgres dialect must therefore emit exactly
    Note: three `$N` markers ($1, $2, $3) and leave the literal verbatim.
    T.begin_suite(results, "query_builder.placeholder_skips_string_literal_postgres")
    Let b be QB.builder_select(1)
    Let star_col be "*"
    Let table be "items"
    Let predicate be "age > ? AND comment = '?' AND tag IN (?, ?)"
    QB.builder_add_column(b, star_col, 1)
    QB.builder_from(b, table, 5)
    QB.builder_where(b, predicate, 43, 3)
    QB.builder_bind_integer(b, 18)
    QB.builder_bind_integer(b, 100)
    QB.builder_bind_integer(b, 200)

    Let len_holder be allocate(8)
    __store(len_holder, 0, 0)
    Let buf be QB.builder_to_sql(b, len_holder)
    T.assert_not_null(results, "postgres emit returns buffer", buf)
    Let length be __load(len_holder, 0)
    T.assert_greater_than(results, "postgres emit non-empty", length, 0)

    Let dollars be count_dollar_signs(buf, length)
    T.assert_equal(results, "exactly three $-placeholders rendered", dollars, 3)
    Let preserved be contains_quoted_question(buf, length)
    T.assert_equal(results, "literal '?' preserved verbatim", preserved, 1)
    QB.builder_destroy(b)
    Return 1
End Process

Process called "test_predicate_skips_string_literals_mysql" that takes results as Integer returns Integer:
    Note: MySQL dialect re-runs the same input. MySQL keeps `?` as the
    Note: positional marker, so the rendered SQL must hold exactly four
    Note: `?` bytes total: three real placeholders plus the one byte-63
    Note: inside the preserved string literal `'?'`. We also assert the
    Note: literal `'?'` substring is still present.
    T.begin_suite(results, "query_builder.placeholder_skips_string_literal_mysql")
    Let b be QB.builder_select(2)
    Let star_col be "*"
    Let table be "items"
    Let predicate be "age > ? AND comment = '?' AND tag IN (?, ?)"
    QB.builder_add_column(b, star_col, 1)
    QB.builder_from(b, table, 5)
    QB.builder_where(b, predicate, 43, 3)
    QB.builder_bind_integer(b, 18)
    QB.builder_bind_integer(b, 100)
    QB.builder_bind_integer(b, 200)

    Let len_holder be allocate(8)
    __store(len_holder, 0, 0)
    Let buf be QB.builder_to_sql(b, len_holder)
    T.assert_not_null(results, "mysql emit returns buffer", buf)
    Let length be __load(len_holder, 0)
    T.assert_greater_than(results, "mysql emit non-empty", length, 0)

    Note: 4 = 3 real placeholders + 1 literal `?` inside `'?'`.
    Let question_count be count_question_marks(buf, length)
    T.assert_equal(results, "mysql total ? bytes is 4", question_count, 4)
    Let preserved be contains_quoted_question(buf, length)
    T.assert_equal(results, "mysql literal '?' preserved", preserved, 1)
    QB.builder_destroy(b)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_builder_select_basic_dispatch(results)
    test_builder_param_binding_count(results)
    test_builder_select_emits_sql(results)
    test_builder_insert_default_columns(results)
    test_builder_delete_emits_delete_keyword(results)
    test_builder_update_emit(results)
    test_builder_limit_clamps_negative(results)
    test_predicate_skips_string_literals_postgres(results)
    test_predicate_skips_string_literals_mysql(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
