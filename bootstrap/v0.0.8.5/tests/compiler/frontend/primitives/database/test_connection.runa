Note:
Unit tests for compiler/frontend/primitives/database/connection.runa.

We exercise the configuration builder and the connection state machine
without engaging a live driver. The validation paths (missing connect
callback, double begin, etc.) are the load-bearing behaviour for the
generic abstraction layer.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/database/connection.runa" as DB

Process called "test_config_create_and_set" that takes results as Integer returns Integer:
    T.begin_suite(results, "connection.config_create")
    Let cfg be DB.config_create(1)
    T.assert_not_null(results, "config allocated", cfg)
    T.assert_equal(results, "driver kind stored", DB.config_driver_kind(cfg), 1)

    DB.config_set_endpoint(cfg, 0, 5432)
    DB.config_set_database(cfg, 0)
    DB.config_set_credentials(cfg, 0, 0)
    DB.config_set_driver_callbacks(cfg, 0, 0, 0, 0)
    DB.config_set_prepare_callback(cfg, 0)
    DB.config_set_begin_callback(cfg, 0)

    DB.config_destroy(cfg)
    Return 1
End Process

Process called "test_connection_open_without_connect_callback_returns_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "connection.open_missing_callback")
    Let cfg be DB.config_create(3)
    Let conn be DB.connection_open(cfg)
    T.assert_equal(results, "open without connect_fn returns 0", conn, 0)
    DB.config_destroy(cfg)
    Return 1
End Process

Process called "test_connection_state_for_null" that takes results as Integer returns Integer:
    T.begin_suite(results, "connection.state_for_null")
    T.assert_equal(results, "null connection reports CLOSED", DB.connection_state(0), 3)
    T.assert_equal(results, "null connection not open", DB.connection_is_open(0), 0)
    T.assert_equal(results, "null connection no error", DB.connection_last_error(0), 0)
    T.assert_equal(results, "null connection handle is 0", DB.connection_handle(0), 0)
    T.assert_equal(results, "null connection not in tx", DB.connection_in_transaction(0), 0)
    Return 1
End Process

Process called "test_connection_close_null_is_invalid" that takes results as Integer returns Integer:
    T.begin_suite(results, "connection.close_null")
    Let rc be DB.connection_close(0)
    T.assert_equal(results, "close(0) returns INVALID", rc, 0)
    Return 1
End Process

Process called "test_connection_execute_on_null_returns_invalid" that takes results as Integer returns Integer:
    T.begin_suite(results, "connection.execute_null")
    Let rc be DB.connection_execute(0, 0, 0, 0, 0)
    T.assert_equal(results, "execute on null returns INVALID", rc, 0)
    Return 1
End Process

Process called "test_connection_begin_on_null_returns_invalid" that takes results as Integer returns Integer:
    T.begin_suite(results, "connection.begin_null")
    Let rc be DB.connection_begin(0, 0)
    T.assert_equal(results, "begin on null returns INVALID", rc, 0)
    Return 1
End Process

Process called "test_prepared_statement_with_null" that takes results as Integer returns Integer:
    T.begin_suite(results, "connection.prepared_null")
    T.assert_equal(results, "execute on null stmt returns INVALID", DB.prepared_statement_execute(0, 0, 0), 0)
    T.assert_equal(results, "query on null stmt returns 0", DB.prepared_statement_query(0, 0, 0), 0)
    T.assert_equal(results, "destroy on null stmt returns INVALID", DB.prepared_statement_destroy(0), 0)
    T.assert_equal(results, "param count on null stmt is 0", DB.prepared_statement_param_count(0), 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_config_create_and_set(results)
    test_connection_open_without_connect_callback_returns_zero(results)
    test_connection_state_for_null(results)
    test_connection_close_null_is_invalid(results)
    test_connection_execute_on_null_returns_invalid(results)
    test_connection_begin_on_null_returns_invalid(results)
    test_prepared_statement_with_null(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
