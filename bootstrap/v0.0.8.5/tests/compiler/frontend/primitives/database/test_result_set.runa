Note:
Unit tests for compiler/frontend/primitives/database/result_set.runa.

Tests focus on the in-memory row construction primitives - the
materialisation API drivers use to populate values. The lazy fetch
path against a real database is covered by driver integration tests.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/database/result_set.runa" as R

Process called "test_row_allocate_buffers" that takes results as Integer returns Integer:
    T.begin_suite(results, "result_set.row_allocate")
    Let row be R.row_allocate_buffers(0, 3)
    T.assert_not_null(results, "row allocated", row)
    T.assert_equal(results, "column count stored", R.row_column_count(row), 3)
    T.assert_equal(results, "all columns null by default", R.row_is_null(row, 0), 1)
    T.assert_equal(results, "data slot zero", R.row_get_data(row, 0), 0)
    T.assert_equal(results, "value tag null", R.row_value_tag(row, 0), 0)
    R.row_destroy(row)
    Return 1
End Process

Process called "test_row_set_and_get_integer" that takes results as Integer returns Integer:
    T.begin_suite(results, "result_set.set_integer")
    Let row be R.row_allocate_buffers(0, 2)
    R.row_set_value(row, 0, 1, 4242)
    T.assert_equal(results, "value not null after set", R.row_is_null(row, 0), 0)
    T.assert_equal(results, "row_get_integer returns 4242", R.row_get_integer(row, 0), 4242)
    T.assert_equal(results, "tag is INTEGER", R.row_value_tag(row, 0), 1)
    R.row_destroy(row)
    Return 1
End Process

Process called "test_row_set_null_marks_column" that takes results as Integer returns Integer:
    T.begin_suite(results, "result_set.set_null")
    Let row be R.row_allocate_buffers(0, 2)
    R.row_set_value(row, 1, 1, 99)
    T.assert_equal(results, "column 1 not null after set", R.row_is_null(row, 1), 0)
    R.row_set_value(row, 1, 0, 0)
    T.assert_equal(results, "column 1 null after re-set", R.row_is_null(row, 1), 1)
    T.assert_equal(results, "row_get_integer on null returns 0", R.row_get_integer(row, 1), 0)
    R.row_destroy(row)
    Return 1
End Process

Process called "test_row_out_of_range_returns_null" that takes results as Integer returns Integer:
    T.begin_suite(results, "result_set.out_of_range")
    Let row be R.row_allocate_buffers(0, 1)
    T.assert_equal(results, "index 5 is_null returns 1", R.row_is_null(row, 5), 1)
    T.assert_equal(results, "index 5 tag is NULL", R.row_value_tag(row, 5), 0)
    T.assert_equal(results, "negative index is_null returns 1", R.row_is_null(row, -1), 1)
    R.row_destroy(row)
    Return 1
End Process

Process called "test_row_type_mismatch_returns_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "result_set.type_mismatch")
    Let row be R.row_allocate_buffers(0, 1)
    R.row_set_value(row, 0, 3, 1234)
    T.assert_equal(results, "row_get_integer on string tag returns 0", R.row_get_integer(row, 0), 0)
    T.assert_equal(results, "row_get_string returns stored pointer", R.row_get_string(row, 0), 1234)
    R.row_destroy(row)
    Return 1
End Process

Process called "test_result_set_helpers_for_null" that takes results as Integer returns Integer:
    T.begin_suite(results, "result_set.null_helpers")
    T.assert_equal(results, "column_count on null rs is 0", R.result_set_column_count(0), 0)
    T.assert_equal(results, "rows_fetched on null rs is 0", R.result_set_rows_fetched(0), 0)
    T.assert_equal(results, "is_exhausted on null rs returns 1", R.result_set_is_exhausted(0), 1)
    T.assert_equal(results, "current_row on null rs is 0", R.result_set_current_row(0), 0)
    T.assert_equal(results, "column_name on null rs is 0", R.result_set_column_name(0, 0), 0)
    T.assert_equal(results, "column_type on null rs is NULL", R.result_set_column_type(0, 0), 0)
    Return 1
End Process

Process called "test_row_get_boolean" that takes results as Integer returns Integer:
    T.begin_suite(results, "result_set.get_boolean")
    Let row be R.row_allocate_buffers(0, 1)
    R.row_set_value(row, 0, 5, 1)
    T.assert_equal(results, "boolean true round-trips", R.row_get_boolean(row, 0), 1)
    R.row_set_value(row, 0, 5, 0)
    T.assert_equal(results, "boolean false round-trips", R.row_get_boolean(row, 0), 0)
    R.row_destroy(row)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_row_allocate_buffers(results)
    test_row_set_and_get_integer(results)
    test_row_set_null_marks_column(results)
    test_row_out_of_range_returns_null(results)
    test_row_type_mismatch_returns_zero(results)
    test_result_set_helpers_for_null(results)
    test_row_get_boolean(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
