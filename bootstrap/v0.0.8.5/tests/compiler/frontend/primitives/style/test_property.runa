Note:
KAT - style/property.runa registry, lookup, initial values, typed parse.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/style/property.runa" as Prop
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_registry_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.property.registry_create")
    Let registry be Prop.property_registry_create()
    T.assert_not_null(results, "registry_create", registry)
    Prop.property_registry_destroy(registry)
    Return 1
End Process

Process called "test_lookup_color" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.property.lookup_color")
    Let registry be Prop.property_registry_create()
    Let spec be Prop.property_lookup(registry, "color")
    T.assert_not_null(results, "color found", spec)
    T.assert_equal(results, "color is inherited", Prop.property_spec_is_inherited(spec), 1)
    Prop.property_registry_destroy(registry)
    Return 1
End Process

Process called "test_lookup_display" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.property.lookup_display")
    Let registry be Prop.property_registry_create()
    Let spec be Prop.property_lookup(registry, "display")
    T.assert_not_null(results, "display found", spec)
    T.assert_equal(results, "display not inherited", Prop.property_spec_is_inherited(spec), 0)
    Let initial be Prop.property_initial_value(registry, "display")
    Let eq be StringCore.string_equals(initial, "inline")
    T.assert_equal(results, "display initial is inline", eq, 1)
    Prop.property_registry_destroy(registry)
    Return 1
End Process

Process called "test_lookup_unknown" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.property.lookup_unknown")
    Let registry be Prop.property_registry_create()
    Let spec be Prop.property_lookup(registry, "nonexistent-property")
    T.assert_equal(results, "unknown returns 0", spec, 0)
    Prop.property_registry_destroy(registry)
    Return 1
End Process

Process called "test_font_size_inherited" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.property.font_size_inherited")
    Let registry be Prop.property_registry_create()
    Let spec be Prop.property_lookup(registry, "font-size")
    T.assert_not_null(results, "font-size found", spec)
    T.assert_equal(results, "font-size is inherited", Prop.property_spec_is_inherited(spec), 1)
    T.assert_equal(results, "font-size is animatable", Prop.property_spec_is_animatable(spec), 1)
    Prop.property_registry_destroy(registry)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_registry_create(results)
    test_lookup_color(results)
    test_lookup_display(results)
    test_lookup_unknown(results)
    test_font_size_inherited(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
