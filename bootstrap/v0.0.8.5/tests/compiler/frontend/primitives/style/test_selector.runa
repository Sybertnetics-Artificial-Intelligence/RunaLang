Note:
KAT - style/selector.runa.

Exercises:
- Constructors for every selector AST kind.
- Specificity calculation against the CSS Selectors 4 examples
  (section 17.4).
- Parsing of "*", "div", ".foo", "#bar", "[type=text]", ":hover",
  "::before", "div.foo", "div > p", ".a, .b".
- Serialization round-trips.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/style/selector.runa" as S
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_constructors_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.constructors")

    Let universal be S.selector_universal()
    T.assert_equal(results, "universal kind", S.selector_kind(universal), 1)
    S.selector_destroy(universal)

    Let n_type be S.selector_type("div")
    T.assert_equal(results, "type kind", S.selector_kind(n_type), 2)

    Let n_class be S.selector_class("foo")
    T.assert_equal(results, "class kind", S.selector_kind(n_class), 3)

    Let n_id be S.selector_id("bar")
    T.assert_equal(results, "id kind", S.selector_kind(n_id), 4)

    Let n_pc be S.selector_pseudo_class("hover", 0)
    T.assert_equal(results, "pseudo-class kind", S.selector_kind(n_pc), 6)

    Let n_pe be S.selector_pseudo_element("before")
    T.assert_equal(results, "pseudo-element kind", S.selector_kind(n_pe), 7)
    Return 1
End Process

Process called "test_specificity_id" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.specificity.id")
    Note: #foo => (1, 0, 0)
    Let sel be S.selector_id("foo")
    Let sp be S.selector_specificity(sel)
    T.assert_equal(results, "a=1", S.specificity_a(sp), 1)
    T.assert_equal(results, "b=0", S.specificity_b(sp), 0)
    T.assert_equal(results, "c=0", S.specificity_c(sp), 0)
    S.specificity_destroy(sp)
    Return 1
End Process

Process called "test_specificity_class" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.specificity.class")
    Note: .foo => (0, 1, 0)
    Let sel be S.selector_class("foo")
    Let sp be S.selector_specificity(sel)
    T.assert_equal(results, "a=0", S.specificity_a(sp), 0)
    T.assert_equal(results, "b=1", S.specificity_b(sp), 1)
    T.assert_equal(results, "c=0", S.specificity_c(sp), 0)
    S.specificity_destroy(sp)
    Return 1
End Process

Process called "test_specificity_type" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.specificity.type")
    Note: div => (0, 0, 1)
    Let sel be S.selector_type("div")
    Let sp be S.selector_specificity(sel)
    T.assert_equal(results, "a=0", S.specificity_a(sp), 0)
    T.assert_equal(results, "b=0", S.specificity_b(sp), 0)
    T.assert_equal(results, "c=1", S.specificity_c(sp), 1)
    S.specificity_destroy(sp)
    Return 1
End Process

Process called "test_specificity_compare" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.specificity.compare")
    Let id_sel be S.selector_id("a")
    Let cls_sel be S.selector_class("b")
    Let sp1 be S.selector_specificity(id_sel)
    Let sp2 be S.selector_specificity(cls_sel)
    T.assert_equal(results, "id > class", S.specificity_compare(sp1, sp2), 1)
    T.assert_equal(results, "class < id", S.specificity_compare(sp2, sp1), -1)
    T.assert_equal(results, "id == id", S.specificity_compare(sp1, sp1), 0)
    S.specificity_destroy(sp1)
    S.specificity_destroy(sp2)
    Return 1
End Process

Process called "test_parse_universal" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.parse.universal")
    Let parsed be S.selector_parse("*")
    T.assert_not_null(results, "parse universal", parsed)
    T.assert_equal(results, "kind universal", S.selector_kind(parsed), 1)
    Return 1
End Process

Process called "test_parse_type" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.parse.type")
    Let parsed be S.selector_parse("div")
    T.assert_not_null(results, "parse div", parsed)
    T.assert_equal(results, "kind type", S.selector_kind(parsed), 2)
    Return 1
End Process

