Process called "test_parse_pseudo_element" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.parse.pseudo_element")
    Let parsed be S.selector_parse("::before")
    T.assert_not_null(results, "parse ::before", parsed)
    T.assert_equal(results, "kind pseudo-element", S.selector_kind(parsed), 7)
    Return 1
End Process

Process called "test_parse_attribute" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.parse.attribute")
    Let parsed be S.selector_parse("[type=text]")
    T.assert_not_null(results, "parse [type=text]", parsed)
    T.assert_equal(results, "kind attribute", S.selector_kind(parsed), 5)
    T.assert_equal(results, "op equals", S.selector_attr_op(parsed), 1)
    Return 1
End Process

Process called "test_parse_attribute_present" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.parse.attribute_present")
    Let parsed be S.selector_parse("[disabled]")
    T.assert_not_null(results, "parse [disabled]", parsed)
    T.assert_equal(results, "kind attribute", S.selector_kind(parsed), 5)
    T.assert_equal(results, "op present", S.selector_attr_op(parsed), 0)
    Return 1
End Process

Process called "test_parse_compound" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.parse.compound")
    Let parsed be S.selector_parse("div.foo")
    T.assert_not_null(results, "parse div.foo", parsed)
    T.assert_equal(results, "kind compound", S.selector_kind(parsed), 8)
    Return 1
End Process

Process called "test_parse_complex_child" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.parse.complex_child")
    Let parsed be S.selector_parse("div > p")
    T.assert_not_null(results, "parse div > p", parsed)
    T.assert_equal(results, "kind complex", S.selector_kind(parsed), 9)
    Return 1
End Process

Process called "test_parse_list" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.selector.parse.list")
    Let parsed be S.selector_parse(".a, .b")
    T.assert_not_null(results, "parse .a, .b", parsed)
    T.assert_equal(results, "kind list", S.selector_kind(parsed), 10)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_constructors_basic(results)
    test_specificity_id(results)
    test_specificity_class(results)
    test_specificity_type(results)
    test_specificity_compare(results)
    test_parse_universal(results)
    test_parse_type(results)
    test_parse_class(results)
    test_parse_id(results)
    test_parse_pseudo_class(results)
    test_parse_pseudo_element(results)
    test_parse_attribute(results)
    test_parse_attribute_present(results)
    test_parse_compound(results)
    test_parse_complex_child(results)
    test_parse_list(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
