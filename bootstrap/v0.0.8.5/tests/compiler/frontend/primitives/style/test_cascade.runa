Note:
KAT - style/cascade.runa.

Validates the cascade resolution: A.foo (spec 0,1,1,0) overrides bare A
(spec 0,0,1,0).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/style/cascade.runa" as Cascade
Import "compiler/frontend/primitives/style/style_rule.runa" as Rule
Import "compiler/frontend/primitives/style/property.runa" as Prop
Import "compiler/frontend/primitives/markup/element.runa" as Elem
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_computed_create_get_set" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.cascade.computed_basic")
    Let elem be Elem.element_create("div", 0)
    Let cs be Cascade.computed_create(elem)
    T.assert_not_null(results, "create", cs)
    Cascade.computed_set(cs, "color", "red")
    Let val be Cascade.computed_get(cs, "color")
    Let eq be StringCore.string_equals(val, "red")
    T.assert_equal(results, "round-trip color", eq, 1)
    Cascade.computed_destroy(cs)
    Elem.element_destroy(elem)
    Return 1
End Process

Process called "test_cascade_class_beats_type" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.cascade.class_beats_type")
    Let elem be Elem.element_create("a", 0)
    Elem.element_append_attribute(elem, Elem.attribute_create("class", "foo", 0))
    Let source be "a { color: blue; } .foo { color: red; }"
    Let sheet be Rule.stylesheet_parse(source)
    Let sheets be List.list_create()
    List.list_push(sheets, sheet)
    Let registry be Prop.property_registry_create()
    Let computed be Cascade.cascade_apply(elem, sheets, 0, 0, registry)
    T.assert_not_null(results, "cascade_apply", computed)
    Let val be Cascade.computed_get(computed, "color")
    Let is_red be StringCore.string_equals(val, "red")
    T.assert_equal(results, "class overrides type (red wins)", is_red, 1)
    Cascade.computed_destroy(computed)
    Prop.property_registry_destroy(registry)
    Rule.stylesheet_destroy(sheet)
    List.list_destroy(sheets)
    Elem.element_destroy(elem)
    Return 1
End Process

Process called "test_cascade_initial_value" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.cascade.initial_value")
    Let elem be Elem.element_create("div", 0)
    Let sheets be List.list_create()
    Let registry be Prop.property_registry_create()
    Let computed be Cascade.cascade_apply(elem, sheets, 0, 0, registry)
    T.assert_not_null(results, "cascade_apply with empty sheet", computed)
    Let display be Cascade.computed_get(computed, "display")
    Let eq be StringCore.string_equals(display, "inline")
    T.assert_equal(results, "display defaults to inline", eq, 1)
    Cascade.computed_destroy(computed)
    Prop.property_registry_destroy(registry)
    List.list_destroy(sheets)
    Elem.element_destroy(elem)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_computed_create_get_set(results)
    test_cascade_class_beats_type(results)
    test_cascade_initial_value(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
