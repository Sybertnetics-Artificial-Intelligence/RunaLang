Note:
KAT - style/style_rule.runa CSS parsing and serialization.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/style/style_rule.runa" as Rule
Import "compiler/frontend/primitives/style/selector.runa" as Sel
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_declaration_basics" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.style_rule.declaration")
    Let d be Rule.declaration_create("color", "red", 0)
    T.assert_not_null(results, "create", d)
    Let n be Rule.declaration_get_name(d)
    Let eq be StringCore.string_equals(n, "color")
    T.assert_equal(results, "name", eq, 1)
    T.assert_equal(results, "not important", Rule.declaration_is_important(d), 0)
    Rule.declaration_destroy(d)
    Let imp be Rule.declaration_create("display", "none", 1)
    T.assert_equal(results, "important", Rule.declaration_is_important(imp), 1)
    Rule.declaration_destroy(imp)
    Return 1
End Process

Process called "test_rule_create_and_access" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.style_rule.create")
    Let sel be Sel.selector_class("foo")
    Let decls be List.list_create()
    Let d1 be Rule.declaration_create("color", "red", 0)
    List.list_push(decls, d1)
    Let rule be Rule.rule_create(sel, decls)
    T.assert_not_null(results, "create", rule)
    T.assert_equal(results, "decl count", Rule.rule_declaration_count(rule), 1)
    T.assert_equal(results, "selector accessor", Rule.rule_get_selector(rule), sel)
    Rule.rule_destroy(rule)
    Return 1
End Process

Process called "test_stylesheet_parse_simple" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.style_rule.parse")
    Let source be ".foo { color: red; font-size: 14px; }"
    Let sheet be Rule.stylesheet_parse(source)
    T.assert_not_null(results, "parse", sheet)
    T.assert_equal(results, "one entry", Rule.stylesheet_entry_count(sheet), 1)
    T.assert_equal(results, "entry is rule (kind=1)", Rule.stylesheet_get_kind_at(sheet, 0), 1)
    Let entry be Rule.stylesheet_get_entry_at(sheet, 0)
    T.assert_equal(results, "rule has 2 declarations", Rule.rule_declaration_count(entry), 2)
    Rule.stylesheet_destroy(sheet)
    Return 1
End Process

Process called "test_stylerule_serialize" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.style_rule.serialize")
    Let sel be Sel.selector_class("foo")
    Let decls be List.list_create()
    Let d be Rule.declaration_create("color", "red", 0)
    List.list_push(decls, d)
    Let rule be Rule.rule_create(sel, decls)
    Let serialized be Rule.stylerule_serialize(rule)
    T.assert_not_null(results, "serialize", serialized)
    Let len be StringCore.string_length(serialized)
    T.assert_greater_than(results, "non-empty", len, 0)
    Rule.rule_destroy(rule)
    Return 1
End Process

Process called "test_at_rule_with_nested_body" that takes results as Integer returns Integer:
    T.begin_suite(results, "style.style_rule.at_rule_body")
    Let source be "@media (max-width: 600px) { .foo { color: red; } }"
    Let sheet be Rule.stylesheet_parse(source)
    T.assert_not_null(results, "parse at-rule sheet", sheet)
    T.assert_equal(results, "one top-level entry", Rule.stylesheet_entry_count(sheet), 1)
    T.assert_equal(results, "entry is at-rule (kind=2)", Rule.stylesheet_get_kind_at(sheet, 0), 2)
    Let at be Rule.stylesheet_get_entry_at(sheet, 0)
    T.assert_not_null(results, "at-rule pointer", at)
    T.assert_equal(results, "has_block", Rule.at_rule_has_block(at), 1)
    T.assert_equal(results, "body has one nested entry", Rule.at_rule_body_count(at), 1)
    T.assert_equal(results, "nested entry kind is RULE", Rule.at_rule_get_body_kind_at(at, 0), 1)
    Let nested_rule be Rule.at_rule_get_body_entry_at(at, 0)
    T.assert_not_null(results, "nested rule pointer", nested_rule)
    T.assert_equal(results, "nested rule has one declaration", Rule.rule_declaration_count(nested_rule), 1)
    Rule.stylesheet_destroy(sheet)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_declaration_basics(results)
    test_rule_create_and_access(results)
    test_stylesheet_parse_simple(results)
    test_stylerule_serialize(results)
    test_at_rule_with_nested_body(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
