Note:
KAT - query/rql.runa parse, serialize, SQL emission.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/query/rql.runa" as RQL
Import "compiler/frontend/primitives/query/query_ast.runa" as QA
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_parse_minimal" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.rql.parse_minimal")
    Let source be "Query:\n    Select id\n    From users\nEnd Query"
    Let root be RQL.rql_parse(source)
    T.assert_not_null(results, "parse", root)
    T.assert_equal(results, "root is SELECT", QA.query_ast_get_kind(root), 1)
    Let from_clause be QA.query_ast_find_clause(root, 11)
    T.assert_not_null(results, "FROM clause present", from_clause)
    Let select_clause be QA.query_ast_find_clause(root, 10)
    T.assert_not_null(results, "SELECT list present", select_clause)
    QA.query_ast_destroy(root)
    Return 1
End Process

Process called "test_parse_with_where" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.rql.parse_where")
    Let source be "Query:\n    Select id, name\n    From users\n    Where age is greater than 21\nEnd Query"
    Let root be RQL.rql_parse(source)
    T.assert_not_null(results, "parse", root)
    Let where_clause be QA.query_ast_find_clause(root, 12)
    T.assert_not_null(results, "WHERE present", where_clause)
    Let pred be QA.query_ast_get_child(where_clause, 0)
    T.assert_not_null(results, "predicate present", pred)
    T.assert_equal(results, "predicate is CMP", QA.query_ast_get_kind(pred), 30)
    QA.query_ast_destroy(root)
    Return 1
End Process

Process called "test_parse_with_order_limit" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.rql.parse_order_limit")
    Let source be "Query:\n    Select id\n    From users\n    Order By signup_date descending\n    Limit 100\nEnd Query"
    Let root be RQL.rql_parse(source)
    T.assert_not_null(results, "parse", root)
    Let order_clause be QA.query_ast_find_clause(root, 15)
    T.assert_not_null(results, "ORDER BY present", order_clause)
    Let limit_clause be QA.query_ast_find_clause(root, 16)
    T.assert_not_null(results, "LIMIT present", limit_clause)
    T.assert_equal(results, "limit value is 100", QA.query_ast_get_secondary(limit_clause), 100)
    QA.query_ast_destroy(root)
    Return 1
End Process

Process called "test_to_sql" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.rql.to_sql")
    Let source be "Query:\n    Select id\n    From users\n    Where age is greater than 21\nEnd Query"
    Let root be RQL.rql_parse(source)
    Let sql be RQL.rql_to_sql(root)
    T.assert_not_null(results, "to_sql returns string", sql)
    Let len be StringCore.string_length(sql)
    T.assert_greater_than(results, "sql non-empty", len, 0)
    Let starts_select be StringCore.string_starts_with(sql, "SELECT ")
    T.assert_equal(results, "starts with SELECT", starts_select, 1)
    QA.query_ast_destroy(root)
    Return 1
End Process

Process called "test_validate" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.rql.validate")
    Let source be "Query:\n    Select id\n    From users\nEnd Query"
    Let root be RQL.rql_parse(source)
    Let issues be RQL.rql_validate(root, 0)
    T.assert_not_null(results, "issues list", issues)
    T.assert_equal(results, "valid query has no issues", List.list_length(issues), 0)
    QA.query_ast_destroy(root)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_parse_minimal(results)
    test_parse_with_where(results)
    test_parse_with_order_limit(results)
    test_to_sql(results)
    test_validate(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
