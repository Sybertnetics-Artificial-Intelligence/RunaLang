Note:
KAT - query/query_ast.runa node construction, walk, and serialization.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/query/query_ast.runa" as QA
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_node_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.query_ast.create")
    Let node be QA.query_ast_create(1, "test", 0)
    T.assert_not_null(results, "create", node)
    T.assert_equal(results, "kind", QA.query_ast_get_kind(node), 1)
    Let prim be QA.query_ast_get_primary(node)
    Let eq be StringCore.string_equals(prim, "test")
    T.assert_equal(results, "primary string", eq, 1)
    QA.query_ast_destroy(node)
    Return 1
End Process

Process called "test_select_skeleton" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.query_ast.select_skeleton")
    Let root be QA.qa_select()
    T.assert_not_null(results, "qa_select", root)
    T.assert_equal(results, "kind is SELECT", QA.query_ast_get_kind(root), 1)
    Let sl be QA.qa_clause(10)
    QA.query_ast_add_child(root, sl)
    T.assert_equal(results, "added child", QA.query_ast_child_count(root), 1)
    Let found be QA.query_ast_find_clause(root, 10)
    T.assert_equal(results, "find_clause returns added", found, sl)
    QA.query_ast_destroy(root)
    Return 1
End Process

Process called "test_literal_integer" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.query_ast.literal_integer")
    Let lit be QA.qa_literal_integer(42)
    T.assert_not_null(results, "create", lit)
    T.assert_equal(results, "kind is LITERAL", QA.query_ast_get_kind(lit), 21)
    T.assert_equal(results, "payload is 42", QA.query_ast_get_payload(lit), 42)
    QA.query_ast_destroy(lit)
    Return 1
End Process

Process called "test_cmp_construct" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.query_ast.cmp_construct")
    Let lhs be QA.qa_column("age", 0)
    Let rhs be QA.qa_literal_integer(21)
    Let cmp be QA.qa_cmp(">", lhs, rhs)
    T.assert_not_null(results, "cmp create", cmp)
    T.assert_equal(results, "kind is CMP", QA.query_ast_get_kind(cmp), 30)
    T.assert_equal(results, "child count is 2", QA.query_ast_child_count(cmp), 2)
    QA.query_ast_destroy(cmp)
    Return 1
End Process

Process called "test_walk" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.query_ast.walk")
    Let root be QA.qa_select()
    QA.query_ast_add_child(root, QA.qa_clause(10))
    QA.query_ast_add_child(root, QA.qa_clause(11))
    QA.query_ast_add_child(root, QA.qa_clause(12))
    Let out be List.list_create()
    QA.query_ast_walk(root, out)
    T.assert_equal(results, "walk visits 4 nodes", List.list_length(out), 4)
    List.list_destroy(out)
    QA.query_ast_destroy(root)
    Return 1
End Process

Process called "test_to_string" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.query_ast.to_string")
    Let root be QA.qa_select()
    Let sl be QA.qa_clause(10)
    QA.query_ast_add_child(sl, QA.qa_column("user_name", 0))
    QA.query_ast_add_child(root, sl)
    Let str be QA.query_ast_to_string(root)
    T.assert_not_null(results, "to_string", str)
    Let len be StringCore.string_length(str)
    T.assert_greater_than(results, "non-empty", len, 0)
    QA.query_ast_destroy(root)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_node_create(results)
    test_select_skeleton(results)
    test_literal_integer(results)
    test_cmp_construct(results)
    test_walk(results)
    test_to_string(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
