Note:
KAT - query/query_planner.runa logical/physical plan construction and
explain rendering.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/query/query_planner.runa" as Planner
Import "compiler/frontend/primitives/query/rql.runa" as RQL
Import "compiler/frontend/primitives/query/query_ast.runa" as QA
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "test_lp_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.planner.lp_create")
    Let scan be Planner.lp_create(1, "users")
    T.assert_not_null(results, "create scan", scan)
    T.assert_equal(results, "kind is SCAN", Planner.lp_get_kind(scan), 1)
    Planner.lp_destroy(scan)
    Return 1
End Process

Process called "test_pp_create" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.planner.pp_create")
    Let pp be Planner.pp_create(1, "users", 1)
    T.assert_not_null(results, "create", pp)
    T.assert_equal(results, "access_path is SEQ", Planner.pp_get_access_path(pp), 1)
    Planner.pp_destroy(pp)
    Return 1
End Process

Process called "test_logical_build" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.planner.logical_build")
    Let source be "Query:\n    Select id\n    From users\n    Where age is greater than 21\nEnd Query"
    Let root be RQL.rql_parse(source)
    T.assert_not_null(results, "parse", root)
    Let plan be Planner.logical_build(root, 0)
    T.assert_not_null(results, "logical_build", plan)
    QA.query_ast_destroy(root)
    Planner.lp_destroy(plan)
    Return 1
End Process

Process called "test_logical_to_physical_and_explain" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.planner.explain")
    Let source be "Query:\n    Select id\n    From users\nEnd Query"
    Let root be RQL.rql_parse(source)
    Let logical be Planner.logical_build(root, 0)
    Planner.planner_optimize(logical)
    Let physical be Planner.logical_to_physical(logical, 0)
    T.assert_not_null(results, "physical plan", physical)
    Let explain be Planner.explain_plan(physical)
    T.assert_not_null(results, "explain output", explain)
    Let len be StringCore.string_length(explain)
    T.assert_greater_than(results, "explain non-empty", len, 0)
    Let has_scan be StringCore.string_starts_with(explain, "-> ")
    T.assert_equal(results, "starts with arrow", has_scan, 1)
    QA.query_ast_destroy(root)
    Planner.lp_destroy(logical)
    Planner.pp_destroy(physical)
    Return 1
End Process

Process called "test_cost_estimate" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.planner.cost_estimate")
    Let scan be Planner.pp_create(1, "users", 1)
    Planner.pp_set_cost(scan, 100)
    Let filter be Planner.pp_create(3, 0, 0)
    Planner.pp_set_cost(filter, 50)
    Planner.pp_add_child(filter, scan)
    Let cost be Planner.cost_estimate(filter, 0)
    T.assert_equal(results, "total = 100 + 50", cost, 150)
    Planner.pp_destroy(filter)
    Return 1
End Process

Process called "test_projection_pushdown" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.planner.projection_pushdown")
    Let scan be Planner.lp_create(1, "users")
    Let project be Planner.lp_create(3, 0)
    Let proj_list be List.list_create()
    List.list_push(proj_list, "a")
    List.list_push(proj_list, "b")
    Planner.lp_set_projection(project, proj_list)
    Planner.lp_add_child(project, scan)
    Planner.planner_optimize(project)
    T.assert_equal(results, "root collapsed to scan", Planner.lp_get_kind(project), 1)
    Let scan_proj be Planner.lp_get_projection(project)
    T.assert_not_null(results, "scan has projection list", scan_proj)
    T.assert_equal(results, "projection has 2 entries", List.list_length(scan_proj), 2)
    Planner.lp_destroy(project)
    Return 1
End Process

Process called "test_predicate_pushdown_filter_over_filter" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.planner.predicate_pushdown_chain")
    Let scan be Planner.lp_create(1, "users")
    Let inner_pred be QA.query_ast_create(30, "=", 0)
    Let inner_filter be Planner.lp_create(2, 0)
    Planner.lp_set_predicate(inner_filter, inner_pred)
    Planner.lp_add_child(inner_filter, scan)
    Let outer_pred be QA.query_ast_create(30, ">", 0)
    Let outer_filter be Planner.lp_create(2, 0)
    Planner.lp_set_predicate(outer_filter, outer_pred)
    Planner.lp_add_child(outer_filter, inner_filter)
    Planner.predicate_pushdown(outer_filter)
    Let children be Planner.lp_get_children(outer_filter)
    Let cc be List.list_length(children)
    T.assert_equal(results, "outer filter has one child", cc, 1)
    Let new_child be List.list_get(children, 0)
    T.assert_equal(results, "child is the scan now", Planner.lp_get_kind(new_child), 1)
    Planner.lp_destroy(outer_filter)
    Return 1
End Process

Process called "test_predicate_pushdown_across_join" that takes results as Integer returns Integer:
    T.begin_suite(results, "query.planner.predicate_pushdown_join")
    Let scan_a be Planner.lp_create(1, "a")
    Let scan_b be Planner.lp_create(1, "b")
    Let join_on be QA.query_ast_create(30, "=", 0)
    QA.query_ast_add_child(join_on, QA.qa_column("id", "a"))
    QA.query_ast_add_child(join_on, QA.qa_column("id", "b"))
    Let join be Planner.lp_create(4, 0)
    Planner.lp_set_predicate(join, join_on)
    Planner.lp_add_child(join, scan_a)
    Planner.lp_add_child(join, scan_b)
    Let left_pred be QA.query_ast_create(30, "=", 0)
    QA.query_ast_add_child(left_pred, QA.qa_column("x", "a"))
    QA.query_ast_add_child(left_pred, QA.qa_literal_integer(1))
    Let right_pred be QA.query_ast_create(30, "=", 0)
    QA.query_ast_add_child(right_pred, QA.qa_column("y", "b"))
    QA.query_ast_add_child(right_pred, QA.qa_literal_integer(2))
    Let combined be QA.query_ast_create(31, "AND", 0)
    QA.query_ast_add_child(combined, left_pred)
    QA.query_ast_add_child(combined, right_pred)
    Let filter be Planner.lp_create(2, 0)
    Planner.lp_set_predicate(filter, combined)
    Planner.lp_add_child(filter, join)
    Planner.predicate_pushdown(filter)
    T.assert_equal(results, "root is now LOP_JOIN (filter morphed)", Planner.lp_get_kind(filter), 4)
    Let jc be Planner.lp_get_children(filter)
    T.assert_equal(results, "join has 2 children", List.list_length(jc), 2)
    Let nl be List.list_get(jc, 0)
    Let nr be List.list_get(jc, 1)
    T.assert_equal(results, "left input wrapped in filter", Planner.lp_get_kind(nl), 2)
    T.assert_equal(results, "right input wrapped in filter", Planner.lp_get_kind(nr), 2)
    Planner.lp_destroy(filter)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_lp_create(results)
    test_pp_create(results)
    test_logical_build(results)
    test_logical_to_physical_and_explain(results)
    test_cost_estimate(results)
    test_projection_pushdown(results)
    test_predicate_pushdown_filter_over_filter(results)
    test_predicate_pushdown_across_join(results)
    T.print_summary(results)
    Let ok be T.all_passed(results)
    T.destroy_test_results(results)
    If ok is equal to 1:
        Return 0
    End If
    Return 1
End Process
