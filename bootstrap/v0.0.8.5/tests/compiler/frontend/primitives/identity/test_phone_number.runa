Note:
KAT tests for compiler/frontend/primitives/identity/phone_number.runa.

Verifies E.164 parse of "+12025551234", country-code detection to US,
and national-form formatting "(202) 555-1234".
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/identity/phone_number.runa" as PHONE

Process called "test_parse_us" that takes results as Integer returns Integer:
    T.begin_suite(results, "phone.parse_us")
    Let p be proc phone_from_e164_string from PHONE with "+12025551234"
    T.assert_not_null(results, "+12025551234 parsed", p)
    Let cc be proc phone_get_country_code from PHONE with p
    T.assert_equal(results, "country code = 1", cc, 1)
    Let region be proc phone_get_region from PHONE with p
    T.assert_equal(results, "region = US", (proc string_equals from StringCore with region, "US"), 1)
    Let national be proc phone_get_national_number from PHONE with p
    T.assert_equal(results, "national = 2025551234", (proc string_equals from StringCore with national, "2025551234"), 1)
    proc phone_destroy from PHONE with p
    Return 1
End Process

Process called "test_to_national_us" that takes results as Integer returns Integer:
    T.begin_suite(results, "phone.to_national_us")
    Let p be proc phone_from_e164_string from PHONE with "+12025551234"
    Let nat_fmt be proc phone_to_national from PHONE with p
    T.assert_equal(results, "national format (202) 555-1234", (proc string_equals from StringCore with nat_fmt, "(202) 555-1234"), 1)
    proc phone_destroy from PHONE with p
    Return 1
End Process

Process called "test_to_international_us" that takes results as Integer returns Integer:
    T.begin_suite(results, "phone.to_international_us")
    Let p be proc phone_from_e164_string from PHONE with "+12025551234"
    Let intl be proc phone_to_international from PHONE with p
    T.assert_equal(results, "international format +1 202-555-1234", (proc string_equals from StringCore with intl, "+1 202-555-1234"), 1)
    proc phone_destroy from PHONE with p
    Return 1
End Process

Process called "test_to_e164_round_trip" that takes results as Integer returns Integer:
    T.begin_suite(results, "phone.to_e164_round_trip")
    Let p be proc phone_from_e164_string from PHONE with "+12025551234"
    Let e164 be proc phone_to_e164 from PHONE with p
    T.assert_equal(results, "round-trip E.164", (proc string_equals from StringCore with e164, "+12025551234"), 1)
    proc phone_destroy from PHONE with p
    Return 1
End Process

Process called "test_to_rfc3966" that takes results as Integer returns Integer:
    T.begin_suite(results, "phone.to_rfc3966")
    Let p be proc phone_from_e164_string from PHONE with "+12025551234"
    Let uri be proc phone_to_rfc3966 from PHONE with p
    T.assert_equal(results, "tel: URI format", (proc string_equals from StringCore with uri, "tel:+1-202-555-1234"), 1)
    proc phone_destroy from PHONE with p
    Return 1
End Process

Process called "test_toll_free" that takes results as Integer returns Integer:
    T.begin_suite(results, "phone.toll_free")
    Let p be proc phone_from_e164_string from PHONE with "+18005551234"
    T.assert_not_null(results, "+18005551234 parsed", p)
    T.assert_equal(results, "800 is toll-free", (proc phone_is_toll_free from PHONE with p), 1)
    proc phone_destroy from PHONE with p
    Return 1
End Process

Process called "test_reject_malformed" that takes results as Integer returns Integer:
    T.begin_suite(results, "phone.reject_malformed")
    Let r1 be proc phone_from_e164_string from PHONE with "2025551234"
    T.assert_equal(results, "missing + rejected", r1, 0)
    Let r2 be proc phone_from_e164_string from PHONE with "+"
    T.assert_equal(results, "+ only rejected", r2, 0)
    Let r3 be proc phone_from_e164_string from PHONE with "+abc"
    T.assert_equal(results, "non-digits rejected", r3, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_parse_us(results)
    test_to_national_us(results)
    test_to_international_us(results)
    test_to_e164_round_trip(results)
    test_to_rfc3966(results)
    test_toll_free(results)
    test_reject_malformed(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
