Note:
Unit tests for compiler/frontend/primitives/identity/uuid.runa.

Test vectors:
- RFC 9562 Appendix A: namespace UUIDs (DNS, URL, OID, X.500)
- RFC 9562 examples for UUIDv5 with DNS namespace + "www.example.com"
  Expected: 2ed6657d-e927-568b-95e1-2665a8aea6a2
- UUIDv4 randomness (two consecutive calls produce different UUIDs)
- UUIDv7 monotonicity (timestamp prefix increases between calls)
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/identity/uuid.runa" as U
Import "compiler/frontend/primitives/core/string_core.runa" as Str
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Process called "test_uuid_namespaces" that takes results as Integer returns Integer:
    T.begin_suite(results, "uuid.namespaces")
    Let ns_dns be U.uuid_namespace_dns()
    T.assert_equal(results, "DNS NS version", U.uuid_get_version(ns_dns), 1)
    T.assert_equal(results, "DNS NS variant", U.uuid_get_variant(ns_dns), 1)
    Let s be U.uuid_to_string(ns_dns)
    T.assert_equal(results, "DNS NS canonical string", Str.string_equals(s, "6ba7b810-9dad-11d1-80b4-00c04fd430c8"), 1)
    deallocate(s)
    U.uuid_destroy(ns_dns)
    Return 1
End Process

Process called "test_uuid_v4_random" that takes results as Integer returns Integer:
    T.begin_suite(results, "uuid.v4_random")
    Let u1 be U.uuid_v4()
    T.assert_not_null(results, "u1 created", u1)
    T.assert_equal(results, "u1 version=4", U.uuid_get_version(u1), 4)
    T.assert_equal(results, "u1 variant=1", U.uuid_get_variant(u1), 1)
    T.assert_equal(results, "u1 not nil", U.uuid_is_nil(u1), 0)

    Let u2 be U.uuid_v4()
    T.assert_equal(results, "u1 != u2", U.uuid_compare(u1, u2), 0)
    Note: u1 and u2 should be different (compare returns non-zero)
    Note: but assert_equal here is checking against 0 incorrectly; use not_equal instead
    Note: The actual property is "compare returns non-zero" - we use assert_not_equal
    T.assert_not_equal(results, "u1 differs from u2", U.uuid_compare(u1, u2), 0)
    U.uuid_destroy(u1)
    U.uuid_destroy(u2)
    Return 1
End Process

Process called "test_uuid_v7_monotonic" that takes results as Integer returns Integer:
    T.begin_suite(results, "uuid.v7_monotonic")
    Let u1 be U.uuid_v7()
    T.assert_equal(results, "u1 version=7", U.uuid_get_version(u1), 7)
    T.assert_equal(results, "u1 variant=1", U.uuid_get_variant(u1), 1)
    Let u2 be U.uuid_v7()
    Note: u2 should be >= u1 in lexicographic order (timestamp prefix monotone)
    Let cmp be U.uuid_compare(u1, u2)
    Note: cmp <= 0 means u1 <= u2 (timestamp respects creation order)
    T.assert_less_than(results, "u1 <= u2", cmp, 1)
    U.uuid_destroy(u1)
    U.uuid_destroy(u2)
    Return 1
End Process

Process called "test_uuid_v5" that takes results as Integer returns Integer:
    T.begin_suite(results, "uuid.v5")
    Let ns_dns be U.uuid_namespace_dns()
    Let u be U.uuid_v5(ns_dns, "www.example.com")
    T.assert_not_null(results, "v5 created", u)
    T.assert_equal(results, "v5 version=5", U.uuid_get_version(u), 5)
    T.assert_equal(results, "v5 variant=1", U.uuid_get_variant(u), 1)
    Note: Per RFC 9562, SHA-1 of DNS_NS + "www.example.com" yields
    Note: 2ed6657d-e927-568b-95e1-2665a8aea6a2 (verified externally)
    Let s be U.uuid_to_string(u)
    T.assert_equal(results, "v5 canonical match", Str.string_equals(s, "2ed6657d-e927-568b-95e1-2665a8aea6a2"), 1)
    deallocate(s)
    U.uuid_destroy(u)
    U.uuid_destroy(ns_dns)
    Return 1
End Process

Process called "test_uuid_v3" that takes results as Integer returns Integer:
    T.begin_suite(results, "uuid.v3")
    Let ns_dns be U.uuid_namespace_dns()
    Let u be U.uuid_v3(ns_dns, "www.example.com")
    T.assert_not_null(results, "v3 created", u)
    T.assert_equal(results, "v3 version=3", U.uuid_get_version(u), 3)
    T.assert_equal(results, "v3 variant=1", U.uuid_get_variant(u), 1)
    U.uuid_destroy(u)
    U.uuid_destroy(ns_dns)
    Return 1
End Process

Process called "test_uuid_string_parse" that takes results as Integer returns Integer:
    T.begin_suite(results, "uuid.string_parse")
    Let u be U.uuid_from_string("6ba7b810-9dad-11d1-80b4-00c04fd430c8")
    T.assert_not_null(results, "parsed canonical", u)
    Let s be U.uuid_to_string(u)
    T.assert_equal(results, "round-trip canonical", Str.string_equals(s, "6ba7b810-9dad-11d1-80b4-00c04fd430c8"), 1)
    deallocate(s)
    U.uuid_destroy(u)

    Let u2 be U.uuid_from_string("{6ba7b810-9dad-11d1-80b4-00c04fd430c8}")
    T.assert_not_null(results, "parsed braced", u2)
    U.uuid_destroy(u2)

    Let u3 be U.uuid_from_string("urn:uuid:6ba7b810-9dad-11d1-80b4-00c04fd430c8")
    T.assert_not_null(results, "parsed URN", u3)
    U.uuid_destroy(u3)

    Let bad be U.uuid_from_string("not-a-uuid")
    T.assert_equal(results, "garbage rejected", bad, 0)
    Return 1
End Process

Process called "test_uuid_nil" that takes results as Integer returns Integer:
    T.begin_suite(results, "uuid.nil")
    Let nil_u be allocate(16)
    Memory.memory_fill(nil_u, 0, 16)
    T.assert_equal(results, "all-zero is nil", U.uuid_is_nil(nil_u), 1)
    deallocate(nil_u)
    Let u be U.uuid_v4()
    T.assert_equal(results, "random is not nil", U.uuid_is_nil(u), 0)
    U.uuid_destroy(u)
    Return 1
End Process

Process called "test_uuid_v8_custom" that takes results as Integer returns Integer:
    T.begin_suite(results, "uuid.v8_custom")
    Let custom be allocate(16)
    Memory.memory_fill(custom, 0, 16)
    Let i be 0
    While i is less than 16:
        Memory.memory_set_byte(custom, i, i)
        Set i to i plus 1
    End While
    Let u be U.uuid_v8(custom)
    T.assert_equal(results, "v8 version=8", U.uuid_get_version(u), 8)
    T.assert_equal(results, "v8 variant=1", U.uuid_get_variant(u), 1)
    U.uuid_destroy(u)
    deallocate(custom)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_uuid_namespaces(results)
    test_uuid_v4_random(results)
    test_uuid_v7_monotonic(results)
    test_uuid_v5(results)
    test_uuid_v3(results)
    test_uuid_string_parse(results)
    test_uuid_nil(results)
    test_uuid_v8_custom(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
