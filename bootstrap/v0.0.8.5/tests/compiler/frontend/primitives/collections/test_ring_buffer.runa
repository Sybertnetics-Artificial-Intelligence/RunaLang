Note:
Unit tests for compiler/frontend/primitives/collections/ring_buffer.runa.

KAT coverage:
  - Empty buffer state, is_empty / is_full predicates
  - Byte-level write_byte / read_byte ordering
  - peek_byte does not advance the cursor
  - available_read / available_write accounting
  - Bulk write/read of contiguous bytes
  - Wrap-around: write enough to wrap, then read across the boundary
  - Capacity exhaustion: write returns short count, write_byte returns 0
  - read_byte on empty returns -1; peek_byte on empty returns -1
  - rb_reset returns to empty state
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/ring_buffer.runa" as RB
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Process called "test_rb_empty_state" that takes results as Integer returns Integer:
    T.begin_suite(results, "ring_buffer.empty_state")
    Let rb be proc rb_create from RB with 16
    T.assert_not_null(results, "rb created", rb)
    T.assert_equal(results, "capacity is 16", (proc rb_capacity from RB with rb),16)
    T.assert_equal(results, "is_empty is 1", (proc rb_is_empty from RB with rb),1)
    T.assert_equal(results, "is_full is 0", (proc rb_is_full from RB with rb),0)
    T.assert_equal(results, "available_read is 0", (proc rb_available_read from RB with rb),0)
    T.assert_equal(results, "available_write is 16", (proc rb_available_write from RB with rb),16)
    proc rb_destroy from RB with rb
    Return 1
End Process

Process called "test_rb_byte_ordering" that takes results as Integer returns Integer:
    T.begin_suite(results, "ring_buffer.byte_ordering")
    Let rb be proc rb_create from RB with 16
    proc rb_write_byte from RB with rb, 65
    proc rb_write_byte from RB with rb, 66
    proc rb_write_byte from RB with rb, 67
    T.assert_equal(results, "available_read 3", (proc rb_available_read from RB with rb),3)
    T.assert_equal(results, "peek_byte is 65", (proc rb_peek_byte from RB with rb),65)
    T.assert_equal(results, "available unchanged by peek", (proc rb_available_read from RB with rb),3)
    T.assert_equal(results, "read 65", (proc rb_read_byte from RB with rb),65)
    T.assert_equal(results, "read 66", (proc rb_read_byte from RB with rb),66)
    T.assert_equal(results, "read 67", (proc rb_read_byte from RB with rb),67)
    T.assert_equal(results, "empty after drain", (proc rb_is_empty from RB with rb),1)
    proc rb_destroy from RB with rb
    Return 1
End Process

Process called "test_rb_bulk_write_read" that takes results as Integer returns Integer:
    T.begin_suite(results, "ring_buffer.bulk_write_read")
    Let rb be proc rb_create from RB with 32
    Let src be proc allocate from Layout with 10
    Let i be 0
    While i is less than 10:
        proc memory_set_byte from Memory with src, i, 100 plus i
        Set i to i plus 1
    End While
    Let wrote be proc rb_write from RB with rb, src, 10
    T.assert_equal(results, "wrote 10 bytes", wrote, 10)
    T.assert_equal(results, "available_read 10", (proc rb_available_read from RB with rb),10)
    Let dst be proc allocate from Layout with 10
    Let read_count be proc rb_read from RB with rb, dst, 10
    T.assert_equal(results, "read 10 bytes", read_count, 10)
    Let ok be 1
    Let j be 0
    While j is less than 10:
        Let v be proc memory_get_byte from Memory with dst, j
        If v is not equal to 100 plus j:
            Set ok to 0
        End If
        Set j to j plus 1
    End While
    T.assert_equal(results, "all bytes round-tripped", ok, 1)
    proc deallocate from Layout with src
    proc deallocate from Layout with dst
    proc rb_destroy from RB with rb
    Return 1
End Process

Process called "test_rb_wrap_around" that takes results as Integer returns Integer:
    T.begin_suite(results, "ring_buffer.wrap_around")
    Let rb be proc rb_create from RB with 16
    Let i be 0
    While i is less than 10:
        proc rb_write_byte from RB with rb, 200 plus i
        Set i to i plus 1
    End While
    Let drain be 0
    While drain is less than 8:
        proc rb_read_byte from RB with rb
        Set drain to drain plus 1
    End While
    Let j be 0
    While j is less than 10:
        proc rb_write_byte from RB with rb, j
        Set j to j plus 1
    End While
    T.assert_equal(results, "available_read 12 after wrap", (proc rb_available_read from RB with rb),12)
    T.assert_equal(results, "first remaining is 208", (proc rb_read_byte from RB with rb),208)
    T.assert_equal(results, "second remaining is 209", (proc rb_read_byte from RB with rb),209)
    Let next_expected be 0
    Let ok be 1
    While next_expected is less than 10:
        Let got be proc rb_read_byte from RB with rb
        If got is not equal to next_expected:
            Set ok to 0
        End If
        Set next_expected to next_expected plus 1
    End While
    T.assert_equal(results, "wrap-around bytes intact", ok, 1)
    proc rb_destroy from RB with rb
    Return 1
End Process

Process called "test_rb_capacity_exhaustion" that takes results as Integer returns Integer:
    T.begin_suite(results, "ring_buffer.capacity_exhaustion")
    Let rb be proc rb_create from RB with 16
    Let i be 0
    While i is less than 16:
        proc rb_write_byte from RB with rb, i
        Set i to i plus 1
    End While
    T.assert_equal(results, "is_full after capacity reached", (proc rb_is_full from RB with rb),1)
    T.assert_equal(results, "available_write is 0", (proc rb_available_write from RB with rb),0)
    T.assert_equal(results, "write_byte on full -> 0", (proc rb_write_byte from RB with rb, 99), 0)
    proc rb_destroy from RB with rb
    Return 1
End Process

Process called "test_rb_empty_returns_minus_one" that takes results as Integer returns Integer:
    T.begin_suite(results, "ring_buffer.empty_returns_minus_one")
    Let rb be proc rb_create from RB with 16
    T.assert_equal(results, "read_byte on empty -> -1", (proc rb_read_byte from RB with rb),-1)
    T.assert_equal(results, "peek_byte on empty -> -1", (proc rb_peek_byte from RB with rb),-1)
    proc rb_destroy from RB with rb
    Return 1
End Process

Process called "test_rb_reset" that takes results as Integer returns Integer:
    T.begin_suite(results, "ring_buffer.reset")
    Let rb be proc rb_create from RB with 16
    proc rb_write_byte from RB with rb, 1
    proc rb_write_byte from RB with rb, 2
    T.assert_equal(results, "not empty before reset", (proc rb_is_empty from RB with rb),0)
    proc rb_reset from RB with rb
    T.assert_equal(results, "empty after reset", (proc rb_is_empty from RB with rb),1)
    T.assert_equal(results, "available_read 0 after reset", (proc rb_available_read from RB with rb),0)
    T.assert_equal(results, "full capacity after reset", (proc rb_available_write from RB with rb),16)
    proc rb_destroy from RB with rb
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_rb_empty_state(results)
    test_rb_byte_ordering(results)
    test_rb_bulk_write_read(results)
    test_rb_wrap_around(results)
    test_rb_capacity_exhaustion(results)
    test_rb_empty_returns_minus_one(results)
    test_rb_reset(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
