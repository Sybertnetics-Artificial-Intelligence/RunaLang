Note:
Unit tests for compiler/frontend/primitives/collections/bitset.runa.

KAT coverage:
  - bitset_create / size / word_count for whole-word and partial-word
    bit counts
  - set / clear / toggle / test bit-level invariants
  - clear_all / set_all bulk ops including the partial-word mask
  - popcount on known patterns
  - find_first_set / find_first_clear / find_next_set
  - union / intersection / difference / xor (in_place forms)
  - new-result union / intersection / difference / xor
  - complement and complement_in_place
  - equals and clone
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/bitset.runa" as BS

Process called "test_bitset_create_state" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.create_state")
    Let bs be proc bitset_create from BS with 128
    T.assert_not_null(results, "128-bit bitset", bs)
    T.assert_equal(results, "size 128", (proc bitset_size from BS with bs),128)
    T.assert_equal(results, "word_count 2", (proc bitset_word_count from BS with bs),2)
    T.assert_equal(results, "popcount 0 on fresh", (proc bitset_popcount from BS with bs),0)
    proc bitset_destroy from BS with bs
    Let bs2 be proc bitset_create from BS with 100
    T.assert_equal(results, "size 100", (proc bitset_size from BS with bs2),100)
    T.assert_equal(results, "word_count 2 for 100 bits", (proc bitset_word_count from BS with bs2),2)
    proc bitset_destroy from BS with bs2
    Return 1
End Process

Process called "test_bitset_set_test_clear" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.set_test_clear")
    Let bs be proc bitset_create from BS with 200
    proc bitset_set from BS with bs, 0
    proc bitset_set from BS with bs, 63
    proc bitset_set from BS with bs, 64
    proc bitset_set from BS with bs, 199
    T.assert_equal(results, "bit 0 set", (proc bitset_test from BS with bs, 0), 1)
    T.assert_equal(results, "bit 63 set", (proc bitset_test from BS with bs, 63), 1)
    T.assert_equal(results, "bit 64 set", (proc bitset_test from BS with bs, 64), 1)
    T.assert_equal(results, "bit 199 set", (proc bitset_test from BS with bs, 199), 1)
    T.assert_equal(results, "bit 1 unset", (proc bitset_test from BS with bs, 1), 0)
    T.assert_equal(results, "bit 100 unset", (proc bitset_test from BS with bs, 100), 0)
    T.assert_equal(results, "popcount is 4", (proc bitset_popcount from BS with bs),4)
    proc bitset_clear from BS with bs, 63
    T.assert_equal(results, "bit 63 cleared", (proc bitset_test from BS with bs, 63), 0)
    T.assert_equal(results, "popcount is 3", (proc bitset_popcount from BS with bs),3)
    proc bitset_destroy from BS with bs
    Return 1
End Process

Process called "test_bitset_toggle" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.toggle")
    Let bs be proc bitset_create from BS with 64
    proc bitset_toggle from BS with bs, 7
    T.assert_equal(results, "bit 7 toggled to 1", (proc bitset_test from BS with bs, 7), 1)
    proc bitset_toggle from BS with bs, 7
    T.assert_equal(results, "bit 7 toggled back to 0", (proc bitset_test from BS with bs, 7), 0)
    proc bitset_destroy from BS with bs
    Return 1
End Process

Process called "test_bitset_bulk_ops" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.bulk_ops")
    Let bs be proc bitset_create from BS with 130
    proc bitset_set_all from BS with bs
    T.assert_equal(results, "popcount after set_all is 130", (proc bitset_popcount from BS with bs),130)
    T.assert_equal(results, "bit 129 set", (proc bitset_test from BS with bs, 129), 1)
    T.assert_equal(results, "bit 130 out of range is 0", (proc bitset_test from BS with bs, 130), 0)
    proc bitset_clear_all from BS with bs
    T.assert_equal(results, "popcount 0 after clear_all", (proc bitset_popcount from BS with bs),0)
    proc bitset_destroy from BS with bs
    Return 1
End Process

Process called "test_bitset_find_first_set_clear" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.find_first")
    Let bs be proc bitset_create from BS with 128
    T.assert_equal(results, "empty find_first_set -> -1", (proc bitset_find_first_set from BS with bs),-1)
    proc bitset_set from BS with bs, 73
    T.assert_equal(results, "find_first_set finds 73", (proc bitset_find_first_set from BS with bs),73)
    proc bitset_set from BS with bs, 5
    T.assert_equal(results, "find_first_set finds 5 (lower)", (proc bitset_find_first_set from BS with bs),5)
    proc bitset_set_all from BS with bs
    T.assert_equal(results, "all-set find_first_clear -> -1", (proc bitset_find_first_clear from BS with bs),-1)
    proc bitset_clear from BS with bs, 17
    T.assert_equal(results, "find_first_clear finds 17", (proc bitset_find_first_clear from BS with bs),17)
    proc bitset_destroy from BS with bs
    Return 1
End Process

Process called "test_bitset_find_next_set" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.find_next_set")
    Let bs be proc bitset_create from BS with 128
    proc bitset_set from BS with bs, 3
    proc bitset_set from BS with bs, 8
    proc bitset_set from BS with bs, 65
    T.assert_equal(results, "next from 0 -> 3", (proc bitset_find_next_set from BS with bs, 0), 3)
    T.assert_equal(results, "next from 4 -> 8", (proc bitset_find_next_set from BS with bs, 4), 8)
    T.assert_equal(results, "next from 9 -> 65", (proc bitset_find_next_set from BS with bs, 9), 65)
    T.assert_equal(results, "next from 66 -> -1", (proc bitset_find_next_set from BS with bs, 66), -1)
    proc bitset_destroy from BS with bs
    Return 1
End Process

Process called "test_bitset_union_intersection_inplace" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.union_intersection_in_place")
    Let a be proc bitset_create from BS with 64
    Let b be proc bitset_create from BS with 64
    proc bitset_set from BS with a, 1
    proc bitset_set from BS with a, 3
    proc bitset_set from BS with b, 3
    proc bitset_set from BS with b, 5
    proc bitset_union_in_place from BS with a, b
    T.assert_equal(results, "union has bit 1", (proc bitset_test from BS with a, 1), 1)
    T.assert_equal(results, "union has bit 3", (proc bitset_test from BS with a, 3), 1)
    T.assert_equal(results, "union has bit 5", (proc bitset_test from BS with a, 5), 1)
    T.assert_equal(results, "union popcount 3", (proc bitset_popcount from BS with a),3)
    Let c be proc bitset_create from BS with 64
    Let d be proc bitset_create from BS with 64
    proc bitset_set from BS with c, 1
    proc bitset_set from BS with c, 3
    proc bitset_set from BS with d, 3
    proc bitset_set from BS with d, 5
    proc bitset_intersection_in_place from BS with c, d
    T.assert_equal(results, "intersection has only bit 3", (proc bitset_popcount from BS with c),1)
    T.assert_equal(results, "bit 3 in intersection", (proc bitset_test from BS with c, 3), 1)
    proc bitset_destroy from BS with a
    proc bitset_destroy from BS with b
    proc bitset_destroy from BS with c
    proc bitset_destroy from BS with d
    Return 1
End Process

Process called "test_bitset_difference_xor_inplace" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.difference_xor_in_place")
    Let a be proc bitset_create from BS with 64
    Let b be proc bitset_create from BS with 64
    proc bitset_set from BS with a, 1
    proc bitset_set from BS with a, 3
    proc bitset_set from BS with a, 5
    proc bitset_set from BS with b, 3
    proc bitset_set from BS with b, 7
    proc bitset_difference_in_place from BS with a, b
    T.assert_equal(results, "diff has bit 1", (proc bitset_test from BS with a, 1), 1)
    T.assert_equal(results, "diff has bit 5", (proc bitset_test from BS with a, 5), 1)
    T.assert_equal(results, "diff lacks bit 3", (proc bitset_test from BS with a, 3), 0)
    T.assert_equal(results, "diff popcount 2", (proc bitset_popcount from BS with a),2)
    Let c be proc bitset_create from BS with 64
    Let d be proc bitset_create from BS with 64
    proc bitset_set from BS with c, 1
    proc bitset_set from BS with c, 3
    proc bitset_set from BS with d, 3
    proc bitset_set from BS with d, 5
    proc bitset_xor_in_place from BS with c, d
    T.assert_equal(results, "xor has bit 1", (proc bitset_test from BS with c, 1), 1)
    T.assert_equal(results, "xor has bit 5", (proc bitset_test from BS with c, 5), 1)
    T.assert_equal(results, "xor lacks bit 3", (proc bitset_test from BS with c, 3), 0)
    T.assert_equal(results, "xor popcount 2", (proc bitset_popcount from BS with c),2)
    proc bitset_destroy from BS with a
    proc bitset_destroy from BS with b
    proc bitset_destroy from BS with c
    proc bitset_destroy from BS with d
    Return 1
End Process

Process called "test_bitset_new_result_ops" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.new_result_ops")
    Let a be proc bitset_create from BS with 64
    Let b be proc bitset_create from BS with 64
    proc bitset_set from BS with a, 2
    proc bitset_set from BS with a, 4
    proc bitset_set from BS with b, 4
    proc bitset_set from BS with b, 6
    Let u be proc bitset_union from BS with a, b
    T.assert_equal(results, "new union popcount 3", (proc bitset_popcount from BS with u),3)
    Let i be proc bitset_intersection from BS with a, b
    T.assert_equal(results, "new intersection popcount 1", (proc bitset_popcount from BS with i),1)
    Let d be proc bitset_difference from BS with a, b
    T.assert_equal(results, "new difference popcount 1", (proc bitset_popcount from BS with d),1)
    Let x be proc bitset_xor from BS with a, b
    T.assert_equal(results, "new xor popcount 2", (proc bitset_popcount from BS with x),2)
    proc bitset_destroy from BS with a
    proc bitset_destroy from BS with b
    proc bitset_destroy from BS with u
    proc bitset_destroy from BS with i
    proc bitset_destroy from BS with d
    proc bitset_destroy from BS with x
    Return 1
End Process

Process called "test_bitset_complement_equals_clone" that takes results as Integer returns Integer:
    T.begin_suite(results, "bitset.complement_equals_clone")
    Let a be proc bitset_create from BS with 130
    proc bitset_set from BS with a, 0
    proc bitset_set from BS with a, 65
    proc bitset_set from BS with a, 129
    Let c be proc bitset_complement from BS with a
    T.assert_equal(results, "complement popcount 127", (proc bitset_popcount from BS with c),127)
    T.assert_equal(results, "complement bit 0 is 0", (proc bitset_test from BS with c, 0), 0)
    T.assert_equal(results, "complement bit 1 is 1", (proc bitset_test from BS with c, 1), 1)
    T.assert_equal(results, "complement bit 129 is 0", (proc bitset_test from BS with c, 129), 0)
    Let clone be proc bitset_clone from BS with a
    T.assert_equal(results, "clone equals source", (proc bitset_equals from BS with a, clone), 1)
    proc bitset_set from BS with clone, 10
    T.assert_equal(results, "clone diverges after mutation", (proc bitset_equals from BS with a, clone), 0)
    proc bitset_destroy from BS with a
    proc bitset_destroy from BS with c
    proc bitset_destroy from BS with clone
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_bitset_create_state(results)
    test_bitset_set_test_clear(results)
    test_bitset_toggle(results)
    test_bitset_bulk_ops(results)
    test_bitset_find_first_set_clear(results)
    test_bitset_find_next_set(results)
    test_bitset_union_intersection_inplace(results)
    test_bitset_difference_xor_inplace(results)
    test_bitset_new_result_ops(results)
    test_bitset_complement_equals_clone(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
