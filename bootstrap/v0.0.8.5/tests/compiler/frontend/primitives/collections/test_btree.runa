Note:
Unit tests for compiler/frontend/primitives/collections/btree.runa.

Coverage:
  - Empty tree state
  - Single insert/search round-trip
  - Bulk insert preserves search property
  - Delete from leaf root (no underflow path)
  - Delete absent key returns 0, size unchanged
  - Delete forcing borrow_from_right (sibling is rich)
  - Delete forcing borrow_from_left (left sibling is rich)
  - Delete forcing merge (both siblings minimal)
  - Delete from internal node (predecessor / successor / merge paths)
  - Delete that collapses root and reduces tree height
  - Bulk insert + bulk delete leaves expected survivors and tree
    remains valid
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/btree.runa" as BT

Process called "test_btree_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "btree.empty")
    Let tr be proc btree_create from BT
    T.assert_not_null(results, "create non-null", tr)
    T.assert_equal(results, "size is 0", proc btree_size from BT with tr, 0)
    T.assert_equal(results, "search absent returns 0", proc btree_search from BT with tr, 100, 0)
    T.assert_equal(results, "contains absent returns 0", proc btree_contains from BT with tr, 100, 0)
    proc btree_destroy from BT with tr
    Return 1
End Process

Process called "test_btree_single_insert" that takes results as Integer returns Integer:
    T.begin_suite(results, "btree.single_insert")
    Let tr be proc btree_create from BT
    proc btree_insert from BT with tr, 42, 4200
    T.assert_equal(results, "size 1", proc btree_size from BT with tr, 1)
    T.assert_equal(results, "search returns value", proc btree_search from BT with tr, 42, 4200)
    T.assert_equal(results, "contains returns 1", proc btree_contains from BT with tr, 42, 1)
    proc btree_destroy from BT with tr
    Return 1
End Process

Process called "test_btree_bulk_insert_search" that takes results as Integer returns Integer:
    T.begin_suite(results, "btree.bulk_insert_search")
    Let tr be proc btree_create from BT
    Let i be 0
    While i is less than 200:
        proc btree_insert from BT with tr, i, i multiplied by 7
        Set i to i plus 1
    End While
    T.assert_equal(results, "size 200", proc btree_size from BT with tr, 200)
    Note: spot check a sample of keys
    T.assert_equal(results, "search 0", proc btree_search from BT with tr, 0, 0)
    T.assert_equal(results, "search 1", proc btree_search from BT with tr, 1, 7)
    T.assert_equal(results, "search 100", proc btree_search from BT with tr, 100, 700)
    T.assert_equal(results, "search 199", proc btree_search from BT with tr, 199, 1393)
    T.assert_equal(results, "absent returns 0", proc btree_contains from BT with tr, 250, 0)
    proc btree_destroy from BT with tr
    Return 1
End Process

Process called "test_btree_delete_leaf_root" that takes results as Integer returns Integer:
    T.begin_suite(results, "btree.delete_leaf_root")
    Let tr be proc btree_create from BT
    proc btree_insert from BT with tr, 10, 100
    proc btree_insert from BT with tr, 20, 200
    proc btree_insert from BT with tr, 30, 300
    T.assert_equal(results, "size 3", proc btree_size from BT with tr, 3)
    Let ok be proc btree_delete from BT with tr, 20
    T.assert_equal(results, "delete returns 1", ok, 1)
    T.assert_equal(results, "size 2", proc btree_size from BT with tr, 2)
    T.assert_equal(results, "20 absent", proc btree_contains from BT with tr, 20, 0)
    T.assert_equal(results, "10 still present", proc btree_search from BT with tr, 10, 100)
    T.assert_equal(results, "30 still present", proc btree_search from BT with tr, 30, 300)
    proc btree_destroy from BT with tr
    Return 1
End Process

Process called "test_btree_delete_absent" that takes results as Integer returns Integer:
    T.begin_suite(results, "btree.delete_absent")
    Let tr be proc btree_create from BT
    proc btree_insert from BT with tr, 1, 10
    proc btree_insert from BT with tr, 2, 20
    proc btree_insert from BT with tr, 3, 30
    Let ok be proc btree_delete from BT with tr, 99
    T.assert_equal(results, "delete absent returns 0", ok, 0)
    T.assert_equal(results, "size unchanged", proc btree_size from BT with tr, 3)
    proc btree_destroy from BT with tr
    Return 1
End Process

Process called "test_btree_delete_internal" that takes results as Integer returns Integer:
    T.begin_suite(results, "btree.delete_internal")
    Let tr be proc btree_create from BT
    Note: Insert enough keys to force at least one internal node above
    Note: the leaves (need > 2t-1 = 63 keys to split the root). With
    Note: 250 keys we are guaranteed multiple levels.
    Let i be 0
    While i is less than 250:
        proc btree_insert from BT with tr, i, i plus 1000
        Set i to i plus 1
    End While
    T.assert_equal(results, "size 250", proc btree_size from BT with tr, 250)
    Note: Delete every fifth key, exercising the borrow + merge paths.
    Let j be 0
    Let removed be 0
    While j is less than 250:
        Let ok be proc btree_delete from BT with tr, j
        If ok is equal to 1:
            Set removed to removed plus 1
        End If
        Set j to j plus 5
    End While
    T.assert_equal(results, "removed 50 keys", removed, 50)
    T.assert_equal(results, "size 200", proc btree_size from BT with tr, 200)
    Note: Verify the deleted keys are gone and survivors are still indexed.
    Let k be 0
    Let evens_gone be 1
    Let survivors_present be 1
    While k is less than 250:
        Let c be proc btree_contains from BT with tr, k
        Let rem be k modulo by 5
        If rem is equal to 0:
            If c is not equal to 0:
                Set evens_gone to 0
            End If
        Otherwise:
            If c is not equal to 1:
                Set survivors_present to 0
            End If
        End If
        Set k to k plus 1
    End While
    T.assert_equal(results, "all multiples-of-5 removed", evens_gone, 1)
    T.assert_equal(results, "all survivors still present", survivors_present, 1)
    proc btree_destroy from BT with tr
    Return 1
End Process

Process called "test_btree_delete_all" that takes results as Integer returns Integer:
    T.begin_suite(results, "btree.delete_all")
    Let tr be proc btree_create from BT
    Let i be 0
    While i is less than 100:
        proc btree_insert from BT with tr, i, i
        Set i to i plus 1
    End While
    Note: Delete every key; the tree should end empty and remain valid.
    Let j be 0
    Let removed be 0
    While j is less than 100:
        Let ok be proc btree_delete from BT with tr, j
        If ok is equal to 1:
            Set removed to removed plus 1
        End If
        Set j to j plus 1
    End While
    T.assert_equal(results, "removed 100 keys", removed, 100)
    T.assert_equal(results, "size 0 after drain", proc btree_size from BT with tr, 0)
    T.assert_equal(results, "no key 0", proc btree_contains from BT with tr, 0, 0)
    T.assert_equal(results, "no key 50", proc btree_contains from BT with tr, 50, 0)
    T.assert_equal(results, "no key 99", proc btree_contains from BT with tr, 99, 0)
    proc btree_destroy from BT with tr
    Return 1
End Process

Process called "test_btree_reverse_order_delete" that takes results as Integer returns Integer:
    T.begin_suite(results, "btree.reverse_order_delete")
    Let tr be proc btree_create from BT
    Let i be 0
    While i is less than 150:
        proc btree_insert from BT with tr, i, i
        Set i to i plus 1
    End While
    Note: Delete from highest to lowest. This exercises borrow_from_left
    Note: and left-side merges since the right siblings progressively
    Note: empty out.
    Let j be 149
    Let removed be 0
    While j is greater than or equal to 0:
        Let ok be proc btree_delete from BT with tr, j
        If ok is equal to 1:
            Set removed to removed plus 1
        End If
        Set j to j minus 1
    End While
    T.assert_equal(results, "removed 150", removed, 150)
    T.assert_equal(results, "size 0", proc btree_size from BT with tr, 0)
    proc btree_destroy from BT with tr
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_btree_empty(results)
    test_btree_single_insert(results)
    test_btree_bulk_insert_search(results)
    test_btree_delete_leaf_root(results)
    test_btree_delete_absent(results)
    test_btree_delete_internal(results)
    test_btree_delete_all(results)
    test_btree_reverse_order_delete(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
