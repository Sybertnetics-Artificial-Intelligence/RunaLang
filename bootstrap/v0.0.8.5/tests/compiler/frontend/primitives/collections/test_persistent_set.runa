Note:
Unit tests for compiler/frontend/primitives/collections/persistent_set.runa.

Coverage:
  - Empty set state
  - pset_add: single, multiple, immutability of source
  - pset_remove: present key, absent key, becomes empty
  - pset_union: empty + empty, disjoint, overlapping, equal,
    one empty
  - pset_intersect: disjoint -> empty, overlapping, equal -> equal,
    one empty -> empty
  - pset_diff: A\\A -> empty, A\\B disjoint -> A, A\\B overlapping
  - Source sets are unchanged across all operations
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/persistent_set.runa" as PS

Process called "test_pset_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.empty")
    Let s be proc pset_create from PS
    T.assert_not_null(results, "create non-null", s)
    T.assert_equal(results, "size 0", (proc pset_size from PS with s),0)
    T.assert_equal(results, "is_empty 1", (proc pset_is_empty from PS with s),1)
    T.assert_equal(results, "contains absent 0", (proc pset_contains from PS with s, 42), 0)
    proc pset_destroy from PS with s
    Return 1
End Process

Process called "test_pset_add_single" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.add_single")
    Let s0 be proc pset_create from PS
    Let s1 be proc pset_add from PS with s0, 10
    T.assert_not_null(results, "add returns new set", s1)
    T.assert_equal(results, "s1 size 1", (proc pset_size from PS with s1),1)
    T.assert_equal(results, "s1 contains 10", (proc pset_contains from PS with s1, 10), 1)
    T.assert_equal(results, "s0 still empty", (proc pset_size from PS with s0),0)
    T.assert_equal(results, "s0 does not contain 10", (proc pset_contains from PS with s0, 10), 0)
    proc pset_destroy from PS with s0
    proc pset_destroy from PS with s1
    Return 1
End Process

Process called "test_pset_add_many" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.add_many")
    Let s be proc pset_create from PS
    Let i be 0
    While i is less than 50:
        Let next be proc pset_add from PS with s, i
        proc pset_destroy from PS with s
        Set s to next
        Set i to i plus 1
    End While
    T.assert_equal(results, "size 50 after additions", (proc pset_size from PS with s),50)
    T.assert_equal(results, "contains 0", (proc pset_contains from PS with s, 0), 1)
    T.assert_equal(results, "contains 25", (proc pset_contains from PS with s, 25), 1)
    T.assert_equal(results, "contains 49", (proc pset_contains from PS with s, 49), 1)
    T.assert_equal(results, "absent 50", (proc pset_contains from PS with s, 50), 0)
    proc pset_destroy from PS with s
    Return 1
End Process

Process called "test_pset_remove_present" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.remove_present")
    Let s0 be proc pset_create from PS
    Let s1 be proc pset_add from PS with s0, 10
    Let s2 be proc pset_add from PS with s1, 20
    Let s3 be proc pset_remove from PS with s2, 10
    T.assert_not_null(results, "remove non-null", s3)
    T.assert_equal(results, "s3 size 1", (proc pset_size from PS with s3),1)
    T.assert_equal(results, "s3 missing 10", (proc pset_contains from PS with s3, 10), 0)
    T.assert_equal(results, "s3 has 20", (proc pset_contains from PS with s3, 20), 1)
    T.assert_equal(results, "s2 still has 10", (proc pset_contains from PS with s2, 10), 1)
    T.assert_equal(results, "s2 size still 2", (proc pset_size from PS with s2),2)
    proc pset_destroy from PS with s0
    proc pset_destroy from PS with s1
    proc pset_destroy from PS with s2
    proc pset_destroy from PS with s3
    Return 1
End Process

Process called "test_pset_remove_absent" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.remove_absent")
    Let s0 be proc pset_create from PS
    Let s1 be proc pset_add from PS with s0, 1
    Let s2 be proc pset_remove from PS with s1, 99
    T.assert_equal(results, "size unchanged", (proc pset_size from PS with s2),1)
    T.assert_equal(results, "still has 1", (proc pset_contains from PS with s2, 1), 1)
    proc pset_destroy from PS with s0
    proc pset_destroy from PS with s1
    proc pset_destroy from PS with s2
    Return 1
End Process

Process called "test_pset_remove_to_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.remove_to_empty")
    Let s0 be proc pset_create from PS
    Let s1 be proc pset_add from PS with s0, 7
    Let s2 be proc pset_remove from PS with s1, 7
    T.assert_equal(results, "empty after removal", (proc pset_size from PS with s2),0)
    T.assert_equal(results, "is_empty true", (proc pset_is_empty from PS with s2),1)
    proc pset_destroy from PS with s0
    proc pset_destroy from PS with s1
    proc pset_destroy from PS with s2
    Return 1
End Process

Process called "build_set_from_range" that takes lo as Integer, hi as Integer returns Integer:
    Note: Returns a freshly-allocated set containing every integer
    Note: in [lo, hi). Intermediate maps are destroyed.
    Let s be proc pset_create from PS
    Let i be lo
    While i is less than hi:
        Let next be proc pset_add from PS with s, i
        proc pset_destroy from PS with s
        Set s to next
        Set i to i plus 1
    End While
    Return s
End Process

Process called "test_pset_union_disjoint" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.union_disjoint")
    Let a be build_set_from_range(0, 5)
    Let b be build_set_from_range(100, 105)
    Let u be proc pset_union from PS with a, b
    T.assert_not_null(results, "union non-null", u)
    T.assert_equal(results, "union size 10", (proc pset_size from PS with u),10)
    T.assert_equal(results, "has 0", (proc pset_contains from PS with u, 0), 1)
    T.assert_equal(results, "has 4", (proc pset_contains from PS with u, 4), 1)
    T.assert_equal(results, "has 100", (proc pset_contains from PS with u, 100), 1)
    T.assert_equal(results, "has 104", (proc pset_contains from PS with u, 104), 1)
    T.assert_equal(results, "missing 50", (proc pset_contains from PS with u, 50), 0)
    T.assert_equal(results, "a still size 5", (proc pset_size from PS with a),5)
    T.assert_equal(results, "b still size 5", (proc pset_size from PS with b),5)
    proc pset_destroy from PS with a
    proc pset_destroy from PS with b
    proc pset_destroy from PS with u
    Return 1
End Process

Process called "test_pset_union_overlapping" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.union_overlapping")
    Let a be build_set_from_range(0, 10)
    Let b be build_set_from_range(5, 15)
    Let u be proc pset_union from PS with a, b
    T.assert_equal(results, "union size 15", (proc pset_size from PS with u),15)
    T.assert_equal(results, "has 0", (proc pset_contains from PS with u, 0), 1)
    T.assert_equal(results, "has 7", (proc pset_contains from PS with u, 7), 1)
    T.assert_equal(results, "has 14", (proc pset_contains from PS with u, 14), 1)
    T.assert_equal(results, "missing 15", (proc pset_contains from PS with u, 15), 0)
    proc pset_destroy from PS with a
    proc pset_destroy from PS with b
    proc pset_destroy from PS with u
    Return 1
End Process

Process called "test_pset_union_equal" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.union_equal")
    Let a be build_set_from_range(0, 8)
    Let b be build_set_from_range(0, 8)
    Let u be proc pset_union from PS with a, b
    T.assert_equal(results, "union size 8", (proc pset_size from PS with u),8)
    proc pset_destroy from PS with a
    proc pset_destroy from PS with b
    proc pset_destroy from PS with u
    Return 1
End Process

Process called "test_pset_union_with_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.union_with_empty")
    Let empty be proc pset_create from PS
    Let a be build_set_from_range(0, 5)
    Let u be proc pset_union from PS with a, empty
    T.assert_equal(results, "union with empty == a", (proc pset_size from PS with u),5)
    T.assert_equal(results, "has 3", (proc pset_contains from PS with u, 3), 1)
    proc pset_destroy from PS with empty
    proc pset_destroy from PS with a
    proc pset_destroy from PS with u
    Return 1
End Process

Process called "test_pset_intersect_disjoint" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.intersect_disjoint")
    Let a be build_set_from_range(0, 5)
    Let b be build_set_from_range(10, 15)
    Let it be proc pset_intersect from PS with a, b
    T.assert_equal(results, "disjoint -> empty", (proc pset_size from PS with it),0)
    T.assert_equal(results, "is_empty 1", (proc pset_is_empty from PS with it),1)
    proc pset_destroy from PS with a
    proc pset_destroy from PS with b
    proc pset_destroy from PS with it
    Return 1
End Process

Process called "test_pset_intersect_overlapping" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.intersect_overlapping")
    Let a be build_set_from_range(0, 10)
    Let b be build_set_from_range(5, 15)
    Let it be proc pset_intersect from PS with a, b
    T.assert_equal(results, "intersect size 5", (proc pset_size from PS with it),5)
    T.assert_equal(results, "has 5", (proc pset_contains from PS with it, 5), 1)
    T.assert_equal(results, "has 9", (proc pset_contains from PS with it, 9), 1)
    T.assert_equal(results, "missing 4", (proc pset_contains from PS with it, 4), 0)
    T.assert_equal(results, "missing 10", (proc pset_contains from PS with it, 10), 0)
    proc pset_destroy from PS with a
    proc pset_destroy from PS with b
    proc pset_destroy from PS with it
    Return 1
End Process

Process called "test_pset_intersect_equal" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.intersect_equal")
    Let a be build_set_from_range(0, 6)
    Let b be build_set_from_range(0, 6)
    Let it be proc pset_intersect from PS with a, b
    T.assert_equal(results, "intersect size 6", (proc pset_size from PS with it),6)
    proc pset_destroy from PS with a
    proc pset_destroy from PS with b
    proc pset_destroy from PS with it
    Return 1
End Process

Process called "test_pset_intersect_with_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.intersect_with_empty")
    Let empty be proc pset_create from PS
    Let a be build_set_from_range(0, 5)
    Let it be proc pset_intersect from PS with a, empty
    T.assert_equal(results, "intersect with empty -> empty", (proc pset_size from PS with it),0)
    proc pset_destroy from PS with empty
    proc pset_destroy from PS with a
    proc pset_destroy from PS with it
    Return 1
End Process

Process called "test_pset_diff_equal" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.diff_equal")
    Let a be build_set_from_range(0, 5)
    Let b be build_set_from_range(0, 5)
    Let d be proc pset_diff from PS with a, b
    T.assert_equal(results, "A \\ A -> empty", (proc pset_size from PS with d),0)
    proc pset_destroy from PS with a
    proc pset_destroy from PS with b
    proc pset_destroy from PS with d
    Return 1
End Process

Process called "test_pset_diff_disjoint" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.diff_disjoint")
    Let a be build_set_from_range(0, 5)
    Let b be build_set_from_range(100, 105)
    Let d be proc pset_diff from PS with a, b
    T.assert_equal(results, "A \\ B disjoint = A", (proc pset_size from PS with d),5)
    T.assert_equal(results, "has 0", (proc pset_contains from PS with d, 0), 1)
    T.assert_equal(results, "has 4", (proc pset_contains from PS with d, 4), 1)
    proc pset_destroy from PS with a
    proc pset_destroy from PS with b
    proc pset_destroy from PS with d
    Return 1
End Process

Process called "test_pset_diff_overlapping" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.diff_overlapping")
    Let a be build_set_from_range(0, 10)
    Let b be build_set_from_range(5, 15)
    Let d be proc pset_diff from PS with a, b
    T.assert_equal(results, "A \\ B size 5", (proc pset_size from PS with d),5)
    T.assert_equal(results, "has 0", (proc pset_contains from PS with d, 0), 1)
    T.assert_equal(results, "has 4", (proc pset_contains from PS with d, 4), 1)
    T.assert_equal(results, "missing 5", (proc pset_contains from PS with d, 5), 0)
    T.assert_equal(results, "missing 9", (proc pset_contains from PS with d, 9), 0)
    proc pset_destroy from PS with a
    proc pset_destroy from PS with b
    proc pset_destroy from PS with d
    Return 1
End Process

Process called "test_pset_diff_with_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "persistent_set.diff_with_empty")
    Let empty be proc pset_create from PS
    Let a be build_set_from_range(0, 5)
    Let d be proc pset_diff from PS with a, empty
    T.assert_equal(results, "A \\ empty = A", (proc pset_size from PS with d),5)
    Let d2 be proc pset_diff from PS with empty, a
    T.assert_equal(results, "empty \\ A = empty", (proc pset_size from PS with d2),0)
    proc pset_destroy from PS with empty
    proc pset_destroy from PS with a
    proc pset_destroy from PS with d
    proc pset_destroy from PS with d2
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_pset_empty(results)
    test_pset_add_single(results)
    test_pset_add_many(results)
    test_pset_remove_present(results)
    test_pset_remove_absent(results)
    test_pset_remove_to_empty(results)
    test_pset_union_disjoint(results)
    test_pset_union_overlapping(results)
    test_pset_union_equal(results)
    test_pset_union_with_empty(results)
    test_pset_intersect_disjoint(results)
    test_pset_intersect_overlapping(results)
    test_pset_intersect_equal(results)
    test_pset_intersect_with_empty(results)
    test_pset_diff_equal(results)
    test_pset_diff_disjoint(results)
    test_pset_diff_overlapping(results)
    test_pset_diff_with_empty(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
