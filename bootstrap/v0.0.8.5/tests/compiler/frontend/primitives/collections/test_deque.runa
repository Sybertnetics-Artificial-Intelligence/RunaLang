Note:
Unit tests for compiler/frontend/primitives/collections/deque.runa.

KAT coverage:
  - Empty deque state
  - Symmetric push_front / push_back ordering
  - FIFO via push_back / pop_front (queue mode)
  - LIFO via push_back / pop_back (stack mode)
  - Mixed-end operations
  - Drain to empty and pop on empty returns 0
  - Block-spanning load: more elements than a single backing block
    capacity to exercise the multi-block deque allocator.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/deque.runa" as DQ

Process called "test_deque_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "deque.empty")
    Let dq be proc deque_create from DQ
    T.assert_not_null(results, "create non-null", dq)
    T.assert_equal(results, "empty size is 0", proc deque_size from DQ with dq, 0)
    T.assert_equal(results, "is_empty is 1", proc deque_is_empty from DQ with dq, 1)
    proc deque_destroy from DQ with dq
    Return 1
End Process

Process called "test_deque_push_back_fifo" that takes results as Integer returns Integer:
    T.begin_suite(results, "deque.push_back_fifo")
    Let dq be proc deque_create from DQ
    proc deque_push_back from DQ with dq, 1
    proc deque_push_back from DQ with dq, 2
    proc deque_push_back from DQ with dq, 3
    T.assert_equal(results, "size after 3 push_back", proc deque_size from DQ with dq, 3)
    T.assert_equal(results, "front is 1", proc deque_peek_front from DQ with dq, 1)
    T.assert_equal(results, "back is 3", proc deque_peek_back from DQ with dq, 3)
    T.assert_equal(results, "pop_front 1", proc deque_pop_front from DQ with dq, 1)
    T.assert_equal(results, "pop_front 2", proc deque_pop_front from DQ with dq, 2)
    T.assert_equal(results, "pop_front 3", proc deque_pop_front from DQ with dq, 3)
    T.assert_equal(results, "empty after drain", proc deque_is_empty from DQ with dq, 1)
    proc deque_destroy from DQ with dq
    Return 1
End Process

Process called "test_deque_push_back_lifo" that takes results as Integer returns Integer:
    T.begin_suite(results, "deque.push_back_lifo")
    Let dq be proc deque_create from DQ
    proc deque_push_back from DQ with dq, 1
    proc deque_push_back from DQ with dq, 2
    proc deque_push_back from DQ with dq, 3
    T.assert_equal(results, "pop_back 3", proc deque_pop_back from DQ with dq, 3)
    T.assert_equal(results, "pop_back 2", proc deque_pop_back from DQ with dq, 2)
    T.assert_equal(results, "pop_back 1", proc deque_pop_back from DQ with dq, 1)
    T.assert_equal(results, "empty after drain", proc deque_is_empty from DQ with dq, 1)
    proc deque_destroy from DQ with dq
    Return 1
End Process

Process called "test_deque_push_front" that takes results as Integer returns Integer:
    T.begin_suite(results, "deque.push_front")
    Let dq be proc deque_create from DQ
    proc deque_push_front from DQ with dq, 1
    proc deque_push_front from DQ with dq, 2
    proc deque_push_front from DQ with dq, 3
    T.assert_equal(results, "size after 3 push_front", proc deque_size from DQ with dq, 3)
    T.assert_equal(results, "front is 3", proc deque_peek_front from DQ with dq, 3)
    T.assert_equal(results, "back is 1", proc deque_peek_back from DQ with dq, 1)
    proc deque_destroy from DQ with dq
    Return 1
End Process

Process called "test_deque_mixed_ends" that takes results as Integer returns Integer:
    T.begin_suite(results, "deque.mixed_ends")
    Let dq be proc deque_create from DQ
    proc deque_push_back from DQ with dq, 5
    proc deque_push_front from DQ with dq, 4
    proc deque_push_back from DQ with dq, 6
    proc deque_push_front from DQ with dq, 3
    T.assert_equal(results, "size is 4", proc deque_size from DQ with dq, 4)
    T.assert_equal(results, "front is 3", proc deque_peek_front from DQ with dq, 3)
    T.assert_equal(results, "back is 6", proc deque_peek_back from DQ with dq, 6)
    T.assert_equal(results, "pop_front 3", proc deque_pop_front from DQ with dq, 3)
    T.assert_equal(results, "pop_back 6", proc deque_pop_back from DQ with dq, 6)
    T.assert_equal(results, "pop_front 4", proc deque_pop_front from DQ with dq, 4)
    T.assert_equal(results, "pop_back 5", proc deque_pop_back from DQ with dq, 5)
    proc deque_destroy from DQ with dq
    Return 1
End Process

Process called "test_deque_pop_empty_returns_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "deque.pop_empty")
    Let dq be proc deque_create from DQ
    T.assert_equal(results, "pop_front empty -> 0", proc deque_pop_front from DQ with dq, 0)
    T.assert_equal(results, "pop_back empty -> 0", proc deque_pop_back from DQ with dq, 0)
    T.assert_equal(results, "size remains 0", proc deque_size from DQ with dq, 0)
    proc deque_destroy from DQ with dq
    Return 1
End Process

Process called "test_deque_block_spanning_load" that takes results as Integer returns Integer:
    T.begin_suite(results, "deque.block_spanning_load")
    Let dq be proc deque_create from DQ
    Let i be 0
    While i is less than 200:
        proc deque_push_back from DQ with dq, i
        Set i to i plus 1
    End While
    T.assert_equal(results, "size 200 after bulk push", proc deque_size from DQ with dq, 200)
    T.assert_equal(results, "front is 0", proc deque_peek_front from DQ with dq, 0)
    T.assert_equal(results, "back is 199", proc deque_peek_back from DQ with dq, 199)
    Let expected be 0
    Let ok be 1
    While expected is less than 200:
        Let got be proc deque_pop_front from DQ with dq
        If got is not equal to expected:
            Set ok to 0
        End If
        Set expected to expected plus 1
    End While
    T.assert_equal(results, "FIFO order preserved over 200 elements", ok, 1)
    T.assert_equal(results, "empty after drain", proc deque_is_empty from DQ with dq, 1)
    proc deque_destroy from DQ with dq
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_deque_empty(results)
    test_deque_push_back_fifo(results)
    test_deque_push_back_lifo(results)
    test_deque_push_front(results)
    test_deque_mixed_ends(results)
    test_deque_pop_empty_returns_zero(results)
    test_deque_block_spanning_load(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
