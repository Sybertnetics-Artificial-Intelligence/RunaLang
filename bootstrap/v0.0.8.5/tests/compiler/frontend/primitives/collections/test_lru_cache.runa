Note:
Unit tests for compiler/frontend/primitives/collections/lru_cache.runa.

KAT coverage:
  - Construction and empty state
  - put / get round trip
  - get promotes to MRU
  - peek does not promote
  - Capacity-bounded eviction follows LRU order
  - Updating an existing key replaces the value AND promotes it
  - lru_remove evicts the entry; contains returns 0 after
  - clear empties the cache while preserving the structure
  - MRU / LRU keys reflect the recency order
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/lru_cache.runa" as LRU

Process called "test_lru_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "lru_cache.empty")
    Let c be proc lru_create from LRU with 8
    T.assert_not_null(results, "lru_create non-null", c)
    T.assert_equal(results, "size 0", (proc lru_size from LRU with c),0)
    T.assert_equal(results, "capacity 8", (proc lru_capacity from LRU with c),8)
    T.assert_equal(results, "contains miss yields 0", (proc lru_contains from LRU with c, 42), 0)
    T.assert_equal(results, "get miss yields 0", (proc lru_get from LRU with c, 42), 0)
    proc lru_destroy from LRU with c
    Return 1
End Process

Process called "test_lru_put_get_roundtrip" that takes results as Integer returns Integer:
    T.begin_suite(results, "lru_cache.put_get_roundtrip")
    Let c be proc lru_create from LRU with 8
    proc lru_put from LRU with c, 1, 100
    proc lru_put from LRU with c, 2, 200
    proc lru_put from LRU with c, 3, 300
    T.assert_equal(results, "size is 3", (proc lru_size from LRU with c),3)
    T.assert_equal(results, "get(1) = 100", (proc lru_get from LRU with c, 1), 100)
    T.assert_equal(results, "get(2) = 200", (proc lru_get from LRU with c, 2), 200)
    T.assert_equal(results, "get(3) = 300", (proc lru_get from LRU with c, 3), 300)
    T.assert_equal(results, "contains(2) = 1", (proc lru_contains from LRU with c, 2), 1)
    proc lru_destroy from LRU with c
    Return 1
End Process

Process called "test_lru_get_promotes" that takes results as Integer returns Integer:
    T.begin_suite(results, "lru_cache.get_promotes")
    Let c be proc lru_create from LRU with 8
    proc lru_put from LRU with c, 1, 100
    proc lru_put from LRU with c, 2, 200
    proc lru_put from LRU with c, 3, 300
    T.assert_equal(results, "MRU is 3 after inserts", (proc lru_mru_key from LRU with c),3)
    T.assert_equal(results, "LRU is 1 after inserts", (proc lru_lru_key from LRU with c),1)
    proc lru_get from LRU with c, 1
    T.assert_equal(results, "MRU is 1 after get(1)", (proc lru_mru_key from LRU with c),1)
    T.assert_equal(results, "LRU is 2 after get(1)", (proc lru_lru_key from LRU with c),2)
    proc lru_destroy from LRU with c
    Return 1
End Process

Process called "test_lru_peek_does_not_promote" that takes results as Integer returns Integer:
    T.begin_suite(results, "lru_cache.peek_does_not_promote")
    Let c be proc lru_create from LRU with 8
    proc lru_put from LRU with c, 1, 100
    proc lru_put from LRU with c, 2, 200
    proc lru_put from LRU with c, 3, 300
    Let v be proc lru_peek from LRU with c, 1
    T.assert_equal(results, "peek value 100", v, 100)
    T.assert_equal(results, "MRU still 3 after peek(1)", (proc lru_mru_key from LRU with c),3)
    T.assert_equal(results, "LRU still 1 after peek(1)", (proc lru_lru_key from LRU with c),1)
    proc lru_destroy from LRU with c
    Return 1
End Process

Process called "test_lru_eviction_order" that takes results as Integer returns Integer:
    T.begin_suite(results, "lru_cache.eviction_order")
    Let c be proc lru_create from LRU with 3
    proc lru_put from LRU with c, 1, 100
    proc lru_put from LRU with c, 2, 200
    proc lru_put from LRU with c, 3, 300
    T.assert_equal(results, "full size 3", (proc lru_size from LRU with c),3)
    proc lru_put from LRU with c, 4, 400
    T.assert_equal(results, "size still 3 after insert past cap", (proc lru_size from LRU with c),3)
    T.assert_equal(results, "1 evicted", (proc lru_contains from LRU with c, 1), 0)
    T.assert_equal(results, "2 still present", (proc lru_contains from LRU with c, 2), 1)
    T.assert_equal(results, "3 still present", (proc lru_contains from LRU with c, 3), 1)
    T.assert_equal(results, "4 present", (proc lru_contains from LRU with c, 4), 1)
    proc lru_get from LRU with c, 2
    proc lru_put from LRU with c, 5, 500
    T.assert_equal(results, "5 evicted 3 (oldest after 2 promoted)", (proc lru_contains from LRU with c, 3), 0)
    T.assert_equal(results, "2 still present", (proc lru_contains from LRU with c, 2), 1)
    proc lru_destroy from LRU with c
    Return 1
End Process

Process called "test_lru_update_existing_key" that takes results as Integer returns Integer:
    T.begin_suite(results, "lru_cache.update_existing_key")
    Let c be proc lru_create from LRU with 8
    proc lru_put from LRU with c, 1, 100
    proc lru_put from LRU with c, 2, 200
    proc lru_put from LRU with c, 1, 999
    T.assert_equal(results, "size still 2", (proc lru_size from LRU with c),2)
    T.assert_equal(results, "peek(1) is now 999", (proc lru_peek from LRU with c, 1), 999)
    T.assert_equal(results, "1 promoted to MRU", (proc lru_mru_key from LRU with c),1)
    proc lru_destroy from LRU with c
    Return 1
End Process

Process called "test_lru_remove" that takes results as Integer returns Integer:
    T.begin_suite(results, "lru_cache.remove")
    Let c be proc lru_create from LRU with 8
    proc lru_put from LRU with c, 1, 100
    proc lru_put from LRU with c, 2, 200
    proc lru_remove from LRU with c, 1
    T.assert_equal(results, "size 1 after remove", (proc lru_size from LRU with c),1)
    T.assert_equal(results, "contains(1) = 0", (proc lru_contains from LRU with c, 1), 0)
    T.assert_equal(results, "remove miss returns 0", (proc lru_remove from LRU with c, 999), 0)
    proc lru_destroy from LRU with c
    Return 1
End Process

Process called "test_lru_clear" that takes results as Integer returns Integer:
    T.begin_suite(results, "lru_cache.clear")
    Let c be proc lru_create from LRU with 8
    proc lru_put from LRU with c, 1, 100
    proc lru_put from LRU with c, 2, 200
    proc lru_put from LRU with c, 3, 300
    proc lru_clear from LRU with c
    T.assert_equal(results, "size 0 after clear", (proc lru_size from LRU with c),0)
    T.assert_equal(results, "contains(1) = 0", (proc lru_contains from LRU with c, 1), 0)
    T.assert_equal(results, "contains(2) = 0", (proc lru_contains from LRU with c, 2), 0)
    proc lru_put from LRU with c, 7, 7000
    T.assert_equal(results, "post-clear put works", (proc lru_get from LRU with c, 7), 7000)
    proc lru_destroy from LRU with c
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_lru_empty(results)
    test_lru_put_get_roundtrip(results)
    test_lru_get_promotes(results)
    test_lru_peek_does_not_promote(results)
    test_lru_eviction_order(results)
    test_lru_update_existing_key(results)
    test_lru_remove(results)
    test_lru_clear(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
