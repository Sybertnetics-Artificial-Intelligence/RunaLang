Note:
Unit tests for compiler/frontend/primitives/collections/linked_list.runa.

Validates the doubly-linked list API. The singly-linked list shares
the same module but is left covered by integration use sites; this
file targets the dlist surface that supports node-level insertion
and the LRU cache's intrusive node pattern.

KAT coverage:
  - Empty list creation and predicates
  - Push head / tail in interleaved order
  - Pop head / tail recovers FIFO and LIFO orderings respectively
  - Node lookup via dlist_find_node
  - Sequential index access via dlist_get
  - Single-element edge case (push then pop leaves the list empty)
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/linked_list.runa" as LL

Process called "test_dlist_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "linked_list.dlist_empty")
    Let list be proc dlist_create from LL
    T.assert_not_null(results, "dlist_create non-null", list)
    T.assert_equal(results, "empty list size is 0", (proc dlist_size from LL with list),0)
    T.assert_equal(results, "empty list is_empty is 1", (proc dlist_is_empty from LL with list),1)
    proc dlist_destroy from LL with list
    Return 1
End Process

Process called "test_dlist_push_head_order" that takes results as Integer returns Integer:
    T.begin_suite(results, "linked_list.dlist_push_head_order")
    Let list be proc dlist_create from LL
    proc dlist_push_head from LL with list, 10
    proc dlist_push_head from LL with list, 20
    proc dlist_push_head from LL with list, 30
    T.assert_equal(results, "size is 3", (proc dlist_size from LL with list),3)
    T.assert_equal(results, "head is 30", (proc dlist_peek_head from LL with list),30)
    T.assert_equal(results, "tail is 10", (proc dlist_peek_tail from LL with list),10)
    T.assert_equal(results, "index 0 is 30", (proc dlist_get from LL with list, 0), 30)
    T.assert_equal(results, "index 1 is 20", (proc dlist_get from LL with list, 1), 20)
    T.assert_equal(results, "index 2 is 10", (proc dlist_get from LL with list, 2), 10)
    proc dlist_destroy from LL with list
    Return 1
End Process

Process called "test_dlist_push_tail_order" that takes results as Integer returns Integer:
    T.begin_suite(results, "linked_list.dlist_push_tail_order")
    Let list be proc dlist_create from LL
    proc dlist_push_tail from LL with list, 10
    proc dlist_push_tail from LL with list, 20
    proc dlist_push_tail from LL with list, 30
    T.assert_equal(results, "size is 3", (proc dlist_size from LL with list),3)
    T.assert_equal(results, "head is 10", (proc dlist_peek_head from LL with list),10)
    T.assert_equal(results, "tail is 30", (proc dlist_peek_tail from LL with list),30)
    proc dlist_destroy from LL with list
    Return 1
End Process

Process called "test_dlist_pop_head" that takes results as Integer returns Integer:
    T.begin_suite(results, "linked_list.dlist_pop_head")
    Let list be proc dlist_create from LL
    proc dlist_push_tail from LL with list, 1
    proc dlist_push_tail from LL with list, 2
    proc dlist_push_tail from LL with list, 3
    T.assert_equal(results, "pop yields 1", (proc dlist_pop_head from LL with list),1)
    T.assert_equal(results, "pop yields 2", (proc dlist_pop_head from LL with list),2)
    T.assert_equal(results, "pop yields 3", (proc dlist_pop_head from LL with list),3)
    T.assert_equal(results, "empty after drain", (proc dlist_is_empty from LL with list),1)
    proc dlist_destroy from LL with list
    Return 1
End Process

Process called "test_dlist_pop_tail" that takes results as Integer returns Integer:
    T.begin_suite(results, "linked_list.dlist_pop_tail")
    Let list be proc dlist_create from LL
    proc dlist_push_tail from LL with list, 1
    proc dlist_push_tail from LL with list, 2
    proc dlist_push_tail from LL with list, 3
    T.assert_equal(results, "pop tail yields 3", (proc dlist_pop_tail from LL with list),3)
    T.assert_equal(results, "pop tail yields 2", (proc dlist_pop_tail from LL with list),2)
    T.assert_equal(results, "pop tail yields 1", (proc dlist_pop_tail from LL with list),1)
    T.assert_equal(results, "empty after drain", (proc dlist_is_empty from LL with list),1)
    proc dlist_destroy from LL with list
    Return 1
End Process

Process called "test_dlist_single_element" that takes results as Integer returns Integer:
    T.begin_suite(results, "linked_list.dlist_single_element")
    Let list be proc dlist_create from LL
    proc dlist_push_head from LL with list, 42
    T.assert_equal(results, "size 1", (proc dlist_size from LL with list),1)
    T.assert_equal(results, "head == tail value", (proc dlist_peek_head from LL with list),42)
    T.assert_equal(results, "tail value", (proc dlist_peek_tail from LL with list),42)
    T.assert_equal(results, "pop yields 42", (proc dlist_pop_head from LL with list),42)
    T.assert_equal(results, "empty after pop", (proc dlist_is_empty from LL with list),1)
    proc dlist_destroy from LL with list
    Return 1
End Process

Process called "test_dlist_find_and_remove" that takes results as Integer returns Integer:
    T.begin_suite(results, "linked_list.dlist_find_and_remove")
    Let list be proc dlist_create from LL
    proc dlist_push_tail from LL with list, 10
    proc dlist_push_tail from LL with list, 20
    proc dlist_push_tail from LL with list, 30
    Let node be proc dlist_find_node from LL with list, 20
    T.assert_not_null(results, "find existing node", node)
    Let absent be proc dlist_find_node from LL with list, 99
    T.assert_null(results, "absent value yields null", absent)
    proc dlist_remove_node from LL with list, node
    T.assert_equal(results, "size after remove is 2", (proc dlist_size from LL with list),2)
    T.assert_equal(results, "head still 10", (proc dlist_peek_head from LL with list),10)
    T.assert_equal(results, "tail still 30", (proc dlist_peek_tail from LL with list),30)
    proc dlist_destroy from LL with list
    Return 1
End Process

Process called "test_dlist_pop_empty_returns_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "linked_list.dlist_pop_empty")
    Let list be proc dlist_create from LL
    T.assert_equal(results, "pop_head on empty -> 0", (proc dlist_pop_head from LL with list),0)
    T.assert_equal(results, "pop_tail on empty -> 0", (proc dlist_pop_tail from LL with list),0)
    T.assert_equal(results, "size remains 0", (proc dlist_size from LL with list),0)
    proc dlist_destroy from LL with list
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_dlist_empty(results)
    test_dlist_push_head_order(results)
    test_dlist_push_tail_order(results)
    test_dlist_pop_head(results)
    test_dlist_pop_tail(results)
    test_dlist_single_element(results)
    test_dlist_find_and_remove(results)
    test_dlist_pop_empty_returns_zero(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
