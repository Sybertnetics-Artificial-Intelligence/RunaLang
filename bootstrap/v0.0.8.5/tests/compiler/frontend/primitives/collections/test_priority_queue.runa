Note:
Unit tests for compiler/frontend/primitives/collections/priority_queue.runa.

Validates the indexable PQ with MIN/MAX ordering and update_priority
via handles.

KAT coverage:
  - Construction and state queries
  - MIN-heap ordering: pop order ascending
  - MAX-heap ordering: pop order descending
  - update_priority sift-up
  - update_priority sift-down
  - pq_handle_value / pq_handle_priority on live handles
  - Removed handle invalidates handle table
  - Clear resets size and invalidates all handles
  - Capacity growth past initial capacity
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/priority_queue.runa" as PQ

Process called "test_pq_create_and_state" that takes results as Integer returns Integer:
    T.begin_suite(results, "priority_queue.create_and_state")
    Let pq be proc pq_create_min from PQ with 16
    T.assert_not_null(results, "pq created", pq)
    T.assert_equal(results, "size is 0", proc pq_size from PQ with pq, 0)
    T.assert_equal(results, "is_empty is 1", proc pq_is_empty from PQ with pq, 1)
    T.assert_equal(results, "ordering is MIN (0)", proc pq_ordering from PQ with pq, 0)
    proc pq_destroy from PQ with pq
    Return 1
End Process

Process called "test_pq_min_ordering" that takes results as Integer returns Integer:
    T.begin_suite(results, "priority_queue.min_ordering")
    Let pq be proc pq_create_min from PQ with 16
    proc pq_push from PQ with pq, 30, 300
    proc pq_push from PQ with pq, 10, 100
    proc pq_push from PQ with pq, 20, 200
    proc pq_push from PQ with pq, 5, 50
    T.assert_equal(results, "size 4", proc pq_size from PQ with pq, 4)
    T.assert_equal(results, "peek is value 50", proc pq_peek from PQ with pq, 50)
    T.assert_equal(results, "peek_priority is 5", proc pq_peek_priority from PQ with pq, 5)
    T.assert_equal(results, "pop 50", proc pq_pop from PQ with pq, 50)
    T.assert_equal(results, "pop 100", proc pq_pop from PQ with pq, 100)
    T.assert_equal(results, "pop 200", proc pq_pop from PQ with pq, 200)
    T.assert_equal(results, "pop 300", proc pq_pop from PQ with pq, 300)
    T.assert_equal(results, "empty after drain", proc pq_is_empty from PQ with pq, 1)
    proc pq_destroy from PQ with pq
    Return 1
End Process

Process called "test_pq_max_ordering" that takes results as Integer returns Integer:
    T.begin_suite(results, "priority_queue.max_ordering")
    Let pq be proc pq_create_max from PQ with 16
    proc pq_push from PQ with pq, 30, 300
    proc pq_push from PQ with pq, 10, 100
    proc pq_push from PQ with pq, 20, 200
    proc pq_push from PQ with pq, 5, 50
    T.assert_equal(results, "ordering is MAX (1)", proc pq_ordering from PQ with pq, 1)
    T.assert_equal(results, "pop 300", proc pq_pop from PQ with pq, 300)
    T.assert_equal(results, "pop 200", proc pq_pop from PQ with pq, 200)
    T.assert_equal(results, "pop 100", proc pq_pop from PQ with pq, 100)
    T.assert_equal(results, "pop 50", proc pq_pop from PQ with pq, 50)
    proc pq_destroy from PQ with pq
    Return 1
End Process

Process called "test_pq_handle_resolution" that takes results as Integer returns Integer:
    T.begin_suite(results, "priority_queue.handle_resolution")
    Let pq be proc pq_create_min from PQ with 16
    Let h1 be proc pq_push from PQ with pq, 50, 500
    Let h2 be proc pq_push from PQ with pq, 30, 300
    Let h3 be proc pq_push from PQ with pq, 70, 700
    T.assert_equal(results, "h1 still valid", proc pq_handle_is_valid from PQ with pq, h1, 1)
    T.assert_equal(results, "h2 still valid", proc pq_handle_is_valid from PQ with pq, h2, 1)
    T.assert_equal(results, "h3 still valid", proc pq_handle_is_valid from PQ with pq, h3, 1)
    T.assert_equal(results, "h1 value is 500", proc pq_handle_value from PQ with pq, h1, 500)
    T.assert_equal(results, "h2 priority is 30", proc pq_handle_priority from PQ with pq, h2, 30)
    proc pq_destroy from PQ with pq
    Return 1
End Process

Process called "test_pq_update_sift_up" that takes results as Integer returns Integer:
    T.begin_suite(results, "priority_queue.update_sift_up")
    Let pq be proc pq_create_min from PQ with 16
    Let h_a be proc pq_push from PQ with pq, 50, 5000
    proc pq_push from PQ with pq, 30, 3000
    proc pq_push from PQ with pq, 70, 7000
    T.assert_equal(results, "current root is 3000", proc pq_peek from PQ with pq, 3000)
    proc pq_update_priority from PQ with pq, h_a, 1
    T.assert_equal(results, "after update root is 5000", proc pq_peek from PQ with pq, 5000)
    T.assert_equal(results, "updated priority is 1", proc pq_handle_priority from PQ with pq, h_a, 1)
    proc pq_destroy from PQ with pq
    Return 1
End Process

Process called "test_pq_update_sift_down" that takes results as Integer returns Integer:
    T.begin_suite(results, "priority_queue.update_sift_down")
    Let pq be proc pq_create_min from PQ with 16
    Let h_a be proc pq_push from PQ with pq, 10, 100
    proc pq_push from PQ with pq, 20, 200
    proc pq_push from PQ with pq, 30, 300
    T.assert_equal(results, "root is 100", proc pq_peek from PQ with pq, 100)
    proc pq_update_priority from PQ with pq, h_a, 999
    T.assert_equal(results, "after demote root is 200", proc pq_peek from PQ with pq, 200)
    T.assert_equal(results, "updated priority is 999", proc pq_handle_priority from PQ with pq, h_a, 999)
    proc pq_destroy from PQ with pq
    Return 1
End Process

Process called "test_pq_remove" that takes results as Integer returns Integer:
    T.begin_suite(results, "priority_queue.remove")
    Let pq be proc pq_create_min from PQ with 16
    Let h_a be proc pq_push from PQ with pq, 10, 100
    proc pq_push from PQ with pq, 20, 200
    proc pq_push from PQ with pq, 30, 300
    proc pq_remove from PQ with pq, h_a
    T.assert_equal(results, "size 2 after remove", proc pq_size from PQ with pq, 2)
    T.assert_equal(results, "handle invalid after remove", proc pq_handle_is_valid from PQ with pq, h_a, 0)
    T.assert_equal(results, "new root is 200", proc pq_peek from PQ with pq, 200)
    proc pq_destroy from PQ with pq
    Return 1
End Process

Process called "test_pq_clear" that takes results as Integer returns Integer:
    T.begin_suite(results, "priority_queue.clear")
    Let pq be proc pq_create_min from PQ with 16
    Let h1 be proc pq_push from PQ with pq, 10, 100
    Let h2 be proc pq_push from PQ with pq, 20, 200
    proc pq_clear from PQ with pq
    T.assert_equal(results, "size 0 after clear", proc pq_size from PQ with pq, 0)
    T.assert_equal(results, "is_empty after clear", proc pq_is_empty from PQ with pq, 1)
    T.assert_equal(results, "h1 invalid after clear", proc pq_handle_is_valid from PQ with pq, h1, 0)
    T.assert_equal(results, "h2 invalid after clear", proc pq_handle_is_valid from PQ with pq, h2, 0)
    proc pq_destroy from PQ with pq
    Return 1
End Process

Process called "test_pq_capacity_growth" that takes results as Integer returns Integer:
    T.begin_suite(results, "priority_queue.capacity_growth")
    Let pq be proc pq_create_min from PQ with 4
    Let i be 0
    While i is less than 50:
        proc pq_push from PQ with pq, 100 minus i, i
        Set i to i plus 1
    End While
    T.assert_equal(results, "size 50 after bulk push", proc pq_size from PQ with pq, 50)
    T.assert_equal(results, "smallest priority is 51 -> value 49", proc pq_peek from PQ with pq, 49)
    Let expected_value be 49
    Let ok be 1
    While expected_value is greater than or equal to 0:
        Let got be proc pq_pop from PQ with pq
        If got is not equal to expected_value:
            Set ok to 0
        End If
        Set expected_value to expected_value minus 1
    End While
    T.assert_equal(results, "MIN order preserved over 50 elements", ok, 1)
    proc pq_destroy from PQ with pq
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_pq_create_and_state(results)
    test_pq_min_ordering(results)
    test_pq_max_ordering(results)
    test_pq_handle_resolution(results)
    test_pq_update_sift_up(results)
    test_pq_update_sift_down(results)
    test_pq_remove(results)
    test_pq_clear(results)
    test_pq_capacity_growth(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
