Note:
Unit tests for compiler/frontend/primitives/collections/avl_tree.runa.

Coverage:
  - Empty tree behavior
  - Single insert / lookup / size
  - Multiple inserts maintaining BST and AVL invariants
  - Search returning value for present key and 0 for absent key
  - Contains predicate
  - Min / max key
  - Delete: leaf node (no children)
  - Delete: node with one (left only / right only) child
  - Delete: node with two children (in-order successor swap)
  - Delete: root node in various configurations
  - Delete: absent key returns 0, size unchanged
  - Bulk insert/delete preserves balance and traversal property
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/avl_tree.runa" as AVL
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Note: Recursive validators for AVL invariants. Returns 1 if the subtree
Note: rooted at node satisfies:
Note:   - BST ordering (left.key <= node.key < right.key for distinct keys
Note:     in the simple-integer tests below)
Note:   - |balance_factor| <= 1 for every node
Note:   - Stored height field matches recomputed height
Process called "avl_validate_subtree" that takes node as Integer returns Integer:
    If node is equal to 0:
        Return 1
    End If
    Let left be proc memory_get_int64 from Memory with node, 16
    Let right be proc memory_get_int64 from Memory with node, 24
    Let lh be proc avl_height from AVL with left
    Let rh be proc avl_height from AVL with right
    Let diff be lh minus rh
    If diff is less than 0:
        Set diff to 0 minus diff
    End If
    If diff is greater than 1:
        Return 0
    End If
    Let stored_h be proc memory_get_int64 from Memory with node, 32
    Let computed_h be 1 plus (proc avl_max from AVL with lh, rh)
    If stored_h is not equal to computed_h:
        Return 0
    End If
    Let key be proc memory_get_int64 from Memory with node, 0
    If left is not equal to 0:
        Let lk be proc memory_get_int64 from Memory with left, 0
        If lk is greater than key:
            Return 0
        End If
        Let ok_l be proc avl_validate_subtree with left
        If ok_l is equal to 0:
            Return 0
        End If
    End If
    If right is not equal to 0:
        Let rk be proc memory_get_int64 from Memory with right, 0
        If rk is less than key:
            Return 0
        End If
        Let ok_r be proc avl_validate_subtree with right
        If ok_r is equal to 0:
            Return 0
        End If
    End If
    Return 1
End Process

Process called "avl_validate_tree" that takes tree as Integer returns Integer:
    If tree is equal to 0:
        Return 0
    End If
    Let root be proc memory_get_int64 from Memory with tree, 0
    Return proc avl_validate_subtree with root
End Process

Process called "test_avl_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "avl_tree.empty")
    Let tree be proc avl_tree_create from AVL
    T.assert_not_null(results, "create non-null", tree)
    T.assert_equal(results, "empty size is 0", proc avl_tree_size from AVL with tree, 0)
    T.assert_equal(results, "search absent returns 0", proc avl_tree_search from AVL with tree, 42, 0)
    T.assert_equal(results, "contains absent returns 0", proc avl_tree_contains from AVL with tree, 42, 0)
    T.assert_equal(results, "validator accepts empty", proc avl_validate_tree with tree, 1)
    proc avl_tree_destroy from AVL with tree
    Return 1
End Process

Process called "test_avl_single_insert" that takes results as Integer returns Integer:
    T.begin_suite(results, "avl_tree.single_insert")
    Let tree be proc avl_tree_create from AVL
    proc avl_tree_insert from AVL with tree, 10, 100
    T.assert_equal(results, "size 1 after insert", proc avl_tree_size from AVL with tree, 1)
    T.assert_equal(results, "search returns value", proc avl_tree_search from AVL with tree, 10, 100)
    T.assert_equal(results, "contains returns 1", proc avl_tree_contains from AVL with tree, 10, 1)
    T.assert_equal(results, "min equals key", proc avl_tree_min from AVL with tree, 10)
    T.assert_equal(results, "max equals key", proc avl_tree_max from AVL with tree, 10)
    T.assert_equal(results, "tree valid", proc avl_validate_tree with tree, 1)
    proc avl_tree_destroy from AVL with tree
    Return 1
End Process

Process called "test_avl_ascending_inserts" that takes results as Integer returns Integer:
    T.begin_suite(results, "avl_tree.ascending_inserts")
    Let tree be proc avl_tree_create from AVL
    Let i be 1
    While i is less than or equal to 31:
        proc avl_tree_insert from AVL with tree, i, i multiplied by 10
        Set i to i plus 1
    End While
    T.assert_equal(results, "size 31", proc avl_tree_size from AVL with tree, 31)
    T.assert_equal(results, "min is 1", proc avl_tree_min from AVL with tree, 1)
    T.assert_equal(results, "max is 31", proc avl_tree_max from AVL with tree, 31)
    T.assert_equal(results, "ascending tree is balanced", proc avl_validate_tree with tree, 1)
    Note: probe a handful of keys
    T.assert_equal(results, "search 1", proc avl_tree_search from AVL with tree, 1, 10)
    T.assert_equal(results, "search 15", proc avl_tree_search from AVL with tree, 15, 150)
    T.assert_equal(results, "search 31", proc avl_tree_search from AVL with tree, 31, 310)
    proc avl_tree_destroy from AVL with tree
    Return 1
End Process

Process called "test_avl_delete_leaf" that takes results as Integer returns Integer:
    T.begin_suite(results, "avl_tree.delete_leaf")
    Let tree be proc avl_tree_create from AVL
    proc avl_tree_insert from AVL with tree, 20, 200
    proc avl_tree_insert from AVL with tree, 10, 100
    proc avl_tree_insert from AVL with tree, 30, 300
    T.assert_equal(results, "size 3", proc avl_tree_size from AVL with tree, 3)
    T.assert_equal(results, "valid before delete", proc avl_validate_tree with tree, 1)
    Let ok be proc avl_tree_delete from AVL with tree, 10
    T.assert_equal(results, "delete leaf returns 1", ok, 1)
    T.assert_equal(results, "size 2 after delete", proc avl_tree_size from AVL with tree, 2)
    T.assert_equal(results, "10 absent after delete", proc avl_tree_contains from AVL with tree, 10, 0)
    T.assert_equal(results, "20 still present", proc avl_tree_search from AVL with tree, 20, 200)
    T.assert_equal(results, "30 still present", proc avl_tree_search from AVL with tree, 30, 300)
    T.assert_equal(results, "valid after delete", proc avl_validate_tree with tree, 1)
    proc avl_tree_destroy from AVL with tree
    Return 1
End Process

Process called "test_avl_delete_single_child" that takes results as Integer returns Integer:
    T.begin_suite(results, "avl_tree.delete_single_child")
    Let tree be proc avl_tree_create from AVL
    Note: Build a tree where node 20 has one child (10). After balancing
    Note: this scenario, deleting 20 should hoist 10 up.
    proc avl_tree_insert from AVL with tree, 30, 300
    proc avl_tree_insert from AVL with tree, 20, 200
    proc avl_tree_insert from AVL with tree, 40, 400
    proc avl_tree_insert from AVL with tree, 10, 100
    T.assert_equal(results, "size 4", proc avl_tree_size from AVL with tree, 4)
    T.assert_equal(results, "valid before delete", proc avl_validate_tree with tree, 1)
    Let ok be proc avl_tree_delete from AVL with tree, 20
    T.assert_equal(results, "delete returns 1", ok, 1)
    T.assert_equal(results, "size 3", proc avl_tree_size from AVL with tree, 3)
    T.assert_equal(results, "20 gone", proc avl_tree_contains from AVL with tree, 20, 0)
    T.assert_equal(results, "10 still present", proc avl_tree_search from AVL with tree, 10, 100)
    T.assert_equal(results, "30 still present", proc avl_tree_search from AVL with tree, 30, 300)
    T.assert_equal(results, "40 still present", proc avl_tree_search from AVL with tree, 40, 400)
    T.assert_equal(results, "valid after delete", proc avl_validate_tree with tree, 1)
    proc avl_tree_destroy from AVL with tree
    Return 1
End Process

Process called "test_avl_delete_two_children" that takes results as Integer returns Integer:
    T.begin_suite(results, "avl_tree.delete_two_children")
    Let tree be proc avl_tree_create from AVL
    proc avl_tree_insert from AVL with tree, 50, 500
    proc avl_tree_insert from AVL with tree, 30, 300
    proc avl_tree_insert from AVL with tree, 70, 700
    proc avl_tree_insert from AVL with tree, 20, 200
    proc avl_tree_insert from AVL with tree, 40, 400
    proc avl_tree_insert from AVL with tree, 60, 600
    proc avl_tree_insert from AVL with tree, 80, 800
    T.assert_equal(results, "size 7", proc avl_tree_size from AVL with tree, 7)
    T.assert_equal(results, "valid before delete", proc avl_validate_tree with tree, 1)
    Note: Delete the root 50, which has two children. In-order successor
    Note: is 60. After deletion the tree should still have 6 entries
    Note: with 60 reachable and 50 absent.
    Let ok be proc avl_tree_delete from AVL with tree, 50
    T.assert_equal(results, "delete root returns 1", ok, 1)
    T.assert_equal(results, "size 6", proc avl_tree_size from AVL with tree, 6)
    T.assert_equal(results, "50 absent", proc avl_tree_contains from AVL with tree, 50, 0)
    T.assert_equal(results, "60 still present", proc avl_tree_search from AVL with tree, 60, 600)
    T.assert_equal(results, "20 still present", proc avl_tree_search from AVL with tree, 20, 200)
    T.assert_equal(results, "80 still present", proc avl_tree_search from AVL with tree, 80, 800)
    T.assert_equal(results, "valid after delete", proc avl_validate_tree with tree, 1)
    proc avl_tree_destroy from AVL with tree
    Return 1
End Process

Process called "test_avl_delete_absent" that takes results as Integer returns Integer:
    T.begin_suite(results, "avl_tree.delete_absent")
    Let tree be proc avl_tree_create from AVL
    proc avl_tree_insert from AVL with tree, 1, 10
    proc avl_tree_insert from AVL with tree, 2, 20
    proc avl_tree_insert from AVL with tree, 3, 30
    Let ok be proc avl_tree_delete from AVL with tree, 99
    T.assert_equal(results, "delete absent returns 0", ok, 0)
    T.assert_equal(results, "size unchanged", proc avl_tree_size from AVL with tree, 3)
    T.assert_equal(results, "valid", proc avl_validate_tree with tree, 1)
    proc avl_tree_destroy from AVL with tree
    Return 1
End Process

Process called "test_avl_delete_root_no_children" that takes results as Integer returns Integer:
    T.begin_suite(results, "avl_tree.delete_root_no_children")
    Let tree be proc avl_tree_create from AVL
    proc avl_tree_insert from AVL with tree, 42, 420
    Let ok be proc avl_tree_delete from AVL with tree, 42
    T.assert_equal(results, "delete returns 1", ok, 1)
    T.assert_equal(results, "size 0", proc avl_tree_size from AVL with tree, 0)
    T.assert_equal(results, "42 absent", proc avl_tree_contains from AVL with tree, 42, 0)
    T.assert_equal(results, "valid empty", proc avl_validate_tree with tree, 1)
    proc avl_tree_destroy from AVL with tree
    Return 1
End Process

Process called "test_avl_bulk_insert_delete" that takes results as Integer returns Integer:
    T.begin_suite(results, "avl_tree.bulk_insert_delete")
    Let tree be proc avl_tree_create from AVL
    Let i be 0
    While i is less than 64:
        proc avl_tree_insert from AVL with tree, i, i plus 1000
        Set i to i plus 1
    End While
    T.assert_equal(results, "size 64 after bulk insert", proc avl_tree_size from AVL with tree, 64)
    T.assert_equal(results, "valid after bulk insert", proc avl_validate_tree with tree, 1)
    Note: Delete every even key.
    Let j be 0
    Let removed be 0
    While j is less than 64:
        Let ok be proc avl_tree_delete from AVL with tree, j
        If ok is equal to 1:
            Set removed to removed plus 1
        End If
        Set j to j plus 2
    End While
    T.assert_equal(results, "removed 32 even keys", removed, 32)
    T.assert_equal(results, "size 32 after even-delete", proc avl_tree_size from AVL with tree, 32)
    T.assert_equal(results, "valid after even-delete", proc avl_validate_tree with tree, 1)
    Note: Verify every odd key is still present and every even key is gone.
    Let k be 0
    Let evens_gone be 1
    Let odds_present be 1
    While k is less than 64:
        Let c be proc avl_tree_contains from AVL with tree, k
        Let is_even be k bitwise and 1
        If is_even is equal to 0:
            If c is not equal to 0:
                Set evens_gone to 0
            End If
        Otherwise:
            If c is not equal to 1:
                Set odds_present to 0
            End If
        End If
        Set k to k plus 1
    End While
    T.assert_equal(results, "all evens removed", evens_gone, 1)
    T.assert_equal(results, "all odds present", odds_present, 1)
    proc avl_tree_destroy from AVL with tree
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_avl_empty(results)
    test_avl_single_insert(results)
    test_avl_ascending_inserts(results)
    test_avl_delete_leaf(results)
    test_avl_delete_single_child(results)
    test_avl_delete_two_children(results)
    test_avl_delete_absent(results)
    test_avl_delete_root_no_children(results)
    test_avl_bulk_insert_delete(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
