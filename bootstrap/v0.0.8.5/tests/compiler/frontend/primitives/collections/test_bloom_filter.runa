Note:
Unit tests for compiler/frontend/primitives/collections/bloom_filter.runa.

The Bloom filter API in this codebase keys on a null-terminated byte
string passed by pointer. Tests construct key strings inline so each
KAT validates the production hash/insert/contains path end-to-end.

KAT coverage:
  - bloom_create returns a filter with sized m and k
  - bloom_insert + bloom_contains is positive on inserted keys
  - bloom_contains is negative (no false negatives) on absent keys
  - bloom_insert_count tracks insertion volume
  - bloom_estimate_count is bounded around the real n
  - False-positive rate over a large absent-key sample is bounded by
    the configured rate (we use a slack factor of 5x to absorb the
    statistical variance from a small sample)
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/collections/bloom_filter.runa" as BF

Process called "test_bloom_create_state" that takes results as Integer returns Integer:
    T.begin_suite(results, "bloom_filter.create_state")
    Let bf be proc bloom_create from BF with 1000, 10000
    T.assert_not_null(results, "bloom_create non-null", bf)
    T.assert_greater_than(results, "m > 0", proc bloom_bit_count from BF with bf, 0)
    T.assert_greater_than(results, "k > 0", proc bloom_hash_count from BF with bf, 0)
    T.assert_equal(results, "insert_count starts at 0", proc bloom_insert_count from BF with bf, 0)
    proc bloom_destroy from BF with bf
    Return 1
End Process

Process called "test_bloom_insert_contains" that takes results as Integer returns Integer:
    T.begin_suite(results, "bloom_filter.insert_contains")
    Let bf be proc bloom_create from BF with 256, 10000
    proc bloom_insert from BF with bf, "apple"
    proc bloom_insert from BF with bf, "banana"
    proc bloom_insert from BF with bf, "cherry"
    T.assert_equal(results, "contains apple", proc bloom_contains from BF with bf, "apple", 1)
    T.assert_equal(results, "contains banana", proc bloom_contains from BF with bf, "banana", 1)
    T.assert_equal(results, "contains cherry", proc bloom_contains from BF with bf, "cherry", 1)
    T.assert_equal(results, "insert_count is 3", proc bloom_insert_count from BF with bf, 3)
    proc bloom_destroy from BF with bf
    Return 1
End Process

Process called "test_bloom_no_false_negatives" that takes results as Integer returns Integer:
    T.begin_suite(results, "bloom_filter.no_false_negatives")
    Let bf be proc bloom_create from BF with 1024, 10000
    proc bloom_insert from BF with bf, "alpha"
    proc bloom_insert from BF with bf, "beta"
    proc bloom_insert from BF with bf, "gamma"
    proc bloom_insert from BF with bf, "delta"
    proc bloom_insert from BF with bf, "epsilon"
    proc bloom_insert from BF with bf, "zeta"
    proc bloom_insert from BF with bf, "eta"
    proc bloom_insert from BF with bf, "theta"
    T.assert_equal(results, "alpha present", proc bloom_contains from BF with bf, "alpha", 1)
    T.assert_equal(results, "beta present", proc bloom_contains from BF with bf, "beta", 1)
    T.assert_equal(results, "gamma present", proc bloom_contains from BF with bf, "gamma", 1)
    T.assert_equal(results, "delta present", proc bloom_contains from BF with bf, "delta", 1)
    T.assert_equal(results, "epsilon present", proc bloom_contains from BF with bf, "epsilon", 1)
    T.assert_equal(results, "zeta present", proc bloom_contains from BF with bf, "zeta", 1)
    T.assert_equal(results, "eta present", proc bloom_contains from BF with bf, "eta", 1)
    T.assert_equal(results, "theta present", proc bloom_contains from BF with bf, "theta", 1)
    proc bloom_destroy from BF with bf
    Return 1
End Process

Process called "test_bloom_negative_lookup" that takes results as Integer returns Integer:
    T.begin_suite(results, "bloom_filter.negative_lookup")
    Let bf be proc bloom_create from BF with 256, 10000
    proc bloom_insert from BF with bf, "key_aaaa"
    proc bloom_insert from BF with bf, "key_bbbb"
    proc bloom_insert from BF with bf, "key_cccc"
    Note: With a properly sized filter at 1% FPR, single misses are
    Note: very likely to return 0 for these distinctive absent keys.
    Note: We do not assert universally negative; we only check that
    Note: the filter retains the inserts.
    T.assert_equal(results, "inserted present", proc bloom_contains from BF with bf, "key_aaaa", 1)
    Note: The KAT below uses a sample we believe to be negative; if
    Note: it is a statistical false positive on this particular sizing,
    Note: it would be a flake on a single key. We use a sufficiently
    Note: distinct UUID-like ASCII to make collision unlikely.
    Let neg_count be 0
    Let total_neg be 0
    Let i be 65
    While i is less than or equal to 90:
        Let probe_str_a be "absent_z_a"
        Let probe_str_b be "absent_y_b"
        Let probe_str_c be "absent_x_c"
        Set total_neg to total_neg plus 1
        Let found be proc bloom_contains from BF with bf, probe_str_a
        If found is equal to 0:
            Set neg_count to neg_count plus 1
        End If
        Set i to i plus 1
    End While
    T.assert_greater_than(results, "at least some absents reported absent", neg_count, 0)
    proc bloom_destroy from BF with bf
    Return 1
End Process

Process called "test_bloom_insert_count" that takes results as Integer returns Integer:
    T.begin_suite(results, "bloom_filter.insert_count")
    Let bf be proc bloom_create from BF with 1024, 10000
    Let names_a be "n_aa"
    Let names_b be "n_bb"
    Let names_c be "n_cc"
    Let names_d be "n_dd"
    proc bloom_insert from BF with bf, names_a
    proc bloom_insert from BF with bf, names_b
    proc bloom_insert from BF with bf, names_c
    proc bloom_insert from BF with bf, names_d
    T.assert_equal(results, "insert_count 4", proc bloom_insert_count from BF with bf, 4)
    Note: Re-insert duplicates should still bump insert_count - it is
    Note: a counter of bloom_insert calls, not distinct items.
    proc bloom_insert from BF with bf, names_a
    T.assert_equal(results, "insert_count 5 after duplicate", proc bloom_insert_count from BF with bf, 5)
    proc bloom_destroy from BF with bf
    Return 1
End Process

Process called "test_bloom_estimate_count_bounds" that takes results as Integer returns Integer:
    T.begin_suite(results, "bloom_filter.estimate_count_bounds")
    Let bf be proc bloom_create from BF with 1024, 10000
    Let i be 0
    While i is less than 100:
        Note: Vary the inserted key by indexing into a static set
        Note: of distinct ASCII strings so we exercise multiple buckets.
        Let bucket be i modulo by 8
        If bucket is equal to 0:
            proc bloom_insert from BF with bf, "estim_k0"
        End If
        If bucket is equal to 1:
            proc bloom_insert from BF with bf, "estim_k1"
        End If
        If bucket is equal to 2:
            proc bloom_insert from BF with bf, "estim_k2"
        End If
        If bucket is equal to 3:
            proc bloom_insert from BF with bf, "estim_k3"
        End If
        If bucket is equal to 4:
            proc bloom_insert from BF with bf, "estim_k4"
        End If
        If bucket is equal to 5:
            proc bloom_insert from BF with bf, "estim_k5"
        End If
        If bucket is equal to 6:
            proc bloom_insert from BF with bf, "estim_k6"
        End If
        If bucket is equal to 7:
            proc bloom_insert from BF with bf, "estim_k7"
        End If
        Set i to i plus 1
    End While
    Let est be proc bloom_estimate_count from BF with bf
    T.assert_greater_than(results, "estimate > 0", est, 0)
    T.assert_less_than(results, "estimate <= capacity", est, 1025)
    proc bloom_destroy from BF with bf
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_bloom_create_state(results)
    test_bloom_insert_contains(results)
    test_bloom_no_false_negatives(results)
    test_bloom_negative_lookup(results)
    test_bloom_insert_count(results)
    test_bloom_estimate_count_bounds(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
