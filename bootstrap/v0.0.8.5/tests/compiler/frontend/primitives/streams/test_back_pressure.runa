Note:
Unit tests for compiler/frontend/primitives/streams/back_pressure.runa.

Covers BoundedBuffer lifecycle plus the basic FIFO and capacity
properties without multi-threading. Reactive subscription primitives
are tested via subscription_request returning OK with no work to do.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/streams/back_pressure.runa" as BP

Process called "test_bounded_buffer_create_invalid" that takes results as Integer returns Integer:
    T.begin_suite(results, "back_pressure.create_invalid")
    Let zero_cap be BP.bounded_buffer_create(0)
    T.assert_equal(results, "0 capacity rejected", zero_cap, 0)
    Let neg_cap be BP.bounded_buffer_create(-4)
    T.assert_equal(results, "negative capacity rejected", neg_cap, 0)
    Return 1
End Process

Process called "test_bounded_buffer_basic_lifecycle" that takes results as Integer returns Integer:
    T.begin_suite(results, "back_pressure.lifecycle")
    Let b be BP.bounded_buffer_create(4)
    T.assert_not_null(results, "buffer allocated", b)
    T.assert_equal(results, "capacity reported", BP.bounded_buffer_capacity(b), 4)
    T.assert_equal(results, "empty after create", BP.bounded_buffer_count(b), 0)
    T.assert_equal(results, "not closed after create", BP.bounded_buffer_is_closed(b), 0)
    BP.bounded_buffer_destroy(b)
    Return 1
End Process

Process called "test_bounded_buffer_push_pop_fifo" that takes results as Integer returns Integer:
    T.begin_suite(results, "back_pressure.fifo_order")
    Let b be BP.bounded_buffer_create(4)
    BP.bounded_buffer_push(b, 11)
    BP.bounded_buffer_push(b, 22)
    BP.bounded_buffer_push(b, 33)
    T.assert_equal(results, "3 items buffered", BP.bounded_buffer_count(b), 3)

    Let holder be allocate(8)
    __store(holder, 0, 0)
    BP.bounded_buffer_pop(b, holder)
    T.assert_equal(results, "first pop = 11", __load(holder, 0), 11)
    __store(holder, 0, 0)
    BP.bounded_buffer_pop(b, holder)
    T.assert_equal(results, "second pop = 22", __load(holder, 0), 22)
    __store(holder, 0, 0)
    BP.bounded_buffer_pop(b, holder)
    T.assert_equal(results, "third pop = 33", __load(holder, 0), 33)
    T.assert_equal(results, "buffer empty after drain", BP.bounded_buffer_count(b), 0)
    BP.bounded_buffer_destroy(b)
    Return 1
End Process

Process called "test_bounded_buffer_try_push_full" that takes results as Integer returns Integer:
    T.begin_suite(results, "back_pressure.try_push_full")
    Let b be BP.bounded_buffer_create(2)
    Let rc1 be BP.bounded_buffer_try_push(b, 1)
    Let rc2 be BP.bounded_buffer_try_push(b, 2)
    Let rc3 be BP.bounded_buffer_try_push(b, 3)
    T.assert_equal(results, "first try_push OK", rc1, 1)
    T.assert_equal(results, "second try_push OK", rc2, 1)
    T.assert_equal(results, "third try_push reports FULL", rc3, -2)
    BP.bounded_buffer_destroy(b)
    Return 1
End Process

Process called "test_bounded_buffer_close_drains_then_closes" that takes results as Integer returns Integer:
    T.begin_suite(results, "back_pressure.close_drain")
    Let b be BP.bounded_buffer_create(3)
    BP.bounded_buffer_push(b, 5)
    BP.bounded_buffer_close(b)
    T.assert_equal(results, "close sets the closed flag", BP.bounded_buffer_is_closed(b), 1)

    Let holder be allocate(8)
    __store(holder, 0, 0)
    Let rc1 be BP.bounded_buffer_pop(b, holder)
    T.assert_equal(results, "pop after close returns OK", rc1, 1)
    T.assert_equal(results, "drained value 5", __load(holder, 0), 5)

    Let rc2 be BP.bounded_buffer_try_pop(b, holder)
    T.assert_equal(results, "subsequent try_pop returns CLOSED", rc2, -1)

    Let rc3 be BP.bounded_buffer_push(b, 7)
    T.assert_equal(results, "push on closed buffer rejected", rc3, -1)

    BP.bounded_buffer_destroy(b)
    Return 1
End Process

Process called "test_publisher_subscription_lifecycle" that takes results as Integer returns Integer:
    T.begin_suite(results, "back_pressure.publisher_subscribe")
    Note: source_fn=0 means there is nothing to pull; subscription_request
    Note: still runs but immediately exits because pull returns COMPLETE.
    Let pub be BP.publisher_create(0, 0)
    T.assert_not_null(results, "publisher allocated", pub)
    T.assert_equal(results, "no subscriptions yet", BP.publisher_subscription_count(pub), 0)

    Let sub be BP.subscriber_create(0, 0, 0, 0)
    T.assert_not_null(results, "subscriber allocated", sub)

    Let subn be BP.publisher_subscribe(pub, sub)
    T.assert_not_null(results, "subscribe returns subscription handle", subn)
    T.assert_equal(results, "subscription count is 1", BP.publisher_subscription_count(pub), 1)
    T.assert_equal(results, "pending demand starts 0", BP.subscription_pending_demand(subn), 0)
    T.assert_equal(results, "subscription not cancelled", BP.subscription_is_cancelled(subn), 0)

    BP.subscription_cancel(subn)
    T.assert_equal(results, "cancel flips the flag", BP.subscription_is_cancelled(subn), 1)
    T.assert_equal(results, "cancel zeroes outstanding demand", BP.subscription_pending_demand(subn), 0)

    BP.subscriber_destroy(sub)
    BP.publisher_destroy(pub)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_bounded_buffer_create_invalid(results)
    test_bounded_buffer_basic_lifecycle(results)
    test_bounded_buffer_push_pop_fifo(results)
    test_bounded_buffer_try_push_full(results)
    test_bounded_buffer_close_drains_then_closes(results)
    test_publisher_subscription_lifecycle(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
