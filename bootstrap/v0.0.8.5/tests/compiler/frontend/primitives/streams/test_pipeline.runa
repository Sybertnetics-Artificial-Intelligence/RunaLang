Note:
Unit tests for compiler/frontend/primitives/streams/pipeline.runa.

Validates stage registration, batch-stream construction, batch counter
behaviour and pipeline_run on an empty pipeline (which must return the
input unchanged).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/streams/pipeline.runa" as P
Import "compiler/frontend/primitives/streams/stream.runa" as S

Process called "test_pipeline_create_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "pipeline.create_empty")
    Let p be P.pipeline_create()
    T.assert_not_null(results, "pipeline allocated", p)
    T.assert_equal(results, "empty pipeline reports 0 stages", P.pipeline_count(p), 0)
    P.pipeline_destroy(p)
    Return 1
End Process

Process called "test_pipeline_add_stages_increments_count" that takes results as Integer returns Integer:
    T.begin_suite(results, "pipeline.add_stages")
    Let p be P.pipeline_create()
    P.pipeline_add_map(p, 1)
    P.pipeline_add_filter(p, 2)
    P.pipeline_add_batch(p, 4)
    T.assert_equal(results, "stage count is 3", P.pipeline_count(p), 3)
    P.pipeline_destroy(p)
    Return 1
End Process

Process called "test_pipeline_add_batch_invalid_size" that takes results as Integer returns Integer:
    T.begin_suite(results, "pipeline.add_batch_invalid")
    Let p be P.pipeline_create()
    Let rc be P.pipeline_add_batch(p, 0)
    T.assert_equal(results, "batch size 0 rejected", rc, 0)
    Let rc2 be P.pipeline_add_batch(p, -3)
    T.assert_equal(results, "negative batch size rejected", rc2, 0)
    P.pipeline_destroy(p)
    Return 1
End Process

Process called "test_pipeline_run_empty_returns_input" that takes results as Integer returns Integer:
    T.begin_suite(results, "pipeline.run_empty")
    Let p be P.pipeline_create()
    Let source be S.stream_from_range(0, 3, 1)
    Let output be P.pipeline_run(p, source)
    T.assert_equal(results, "empty pipeline returns input unchanged", output, source)
    T.assert_equal(results, "passthrough still iterates", S.stream_count(output), 3)
    S.stream_destroy(output)
    P.pipeline_destroy(p)
    Return 1
End Process

Process called "test_pipeline_batch_stream_size_initial_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "pipeline.batch_stream_initial_size")
    Let source be S.stream_from_range(0, 0, 1)
    Let bs be P.pipeline_make_batch_stream(source, 4)
    T.assert_not_null(results, "batch stream allocated", bs)
    T.assert_equal(results, "freshly built batch reports 0", P.pipeline_batch_size(bs), 0)
    S.stream_destroy(bs)
    Return 1
End Process

Process called "test_pipeline_destroy_null" that takes results as Integer returns Integer:
    T.begin_suite(results, "pipeline.destroy_null")
    Let rc be P.pipeline_destroy(0)
    T.assert_equal(results, "destroy(0) returns INVALID", rc, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_pipeline_create_empty(results)
    test_pipeline_add_stages_increments_count(results)
    test_pipeline_add_batch_invalid_size(results)
    test_pipeline_run_empty_returns_input(results)
    test_pipeline_batch_stream_size_initial_zero(results)
    test_pipeline_destroy_null(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
