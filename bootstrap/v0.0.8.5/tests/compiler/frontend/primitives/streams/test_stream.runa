Note:
Unit tests for compiler/frontend/primitives/streams/stream.runa.

Validates the pull protocol on the built-in source builders (range,
list, repeat) and the count terminal operation. Predicate-driven
transformers (map / filter / fold) require Process pointers that are
filled in by the runtime indirect-call shim; we exercise enough of the
API surface to verify the next-fn protocol contract through count.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/primitives/streams/stream.runa" as S

Process called "test_stream_from_range_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.from_range")
    Let s be S.stream_from_range(0, 5, 1)
    T.assert_not_null(results, "range stream allocated", s)
    T.assert_equal(results, "range count is 5", S.stream_count(s), 5)
    S.stream_destroy(s)
    Return 1
End Process

Process called "test_stream_range_with_step" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.range_step")
    Let s be S.stream_from_range(0, 10, 2)
    T.assert_equal(results, "step 2 from 0..10 yields 5", S.stream_count(s), 5)
    S.stream_destroy(s)
    Return 1
End Process

Process called "test_stream_range_negative_step" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.range_negative_step")
    Let s be S.stream_from_range(10, 0, -2)
    T.assert_equal(results, "10 down to 0 step -2 yields 5", S.stream_count(s), 5)
    S.stream_destroy(s)
    Return 1
End Process

Process called "test_stream_range_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.range_empty")
    Let s be S.stream_from_range(5, 5, 1)
    T.assert_equal(results, "empty range has 0 elements", S.stream_count(s), 0)
    S.stream_destroy(s)
    Return 1
End Process

Process called "test_stream_from_repeat_finite" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.repeat_finite")
    Let s be S.stream_from_repeat(7, 3)
    T.assert_equal(results, "repeat count of 3", S.stream_count(s), 3)
    S.stream_destroy(s)
    Return 1
End Process

Process called "test_stream_take_subset_of_range" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.take_subset")
    Let s be S.stream_from_range(0, 100, 1)
    Let limited be S.stream_take(s, 5)
    T.assert_equal(results, "take(5) yields 5", S.stream_count(limited), 5)
    S.stream_destroy(limited)
    Return 1
End Process

Process called "test_stream_drop_advances_cursor" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.drop")
    Let s be S.stream_from_range(0, 10, 1)
    Let dropped be S.stream_drop(s, 3)
    T.assert_equal(results, "drop(3) leaves 7", S.stream_count(dropped), 7)
    S.stream_destroy(dropped)
    Return 1
End Process

Process called "test_stream_chain_two_ranges" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.chain")
    Let s1 be S.stream_from_range(0, 3, 1)
    Let s2 be S.stream_from_range(10, 13, 1)
    Let chained be S.stream_chain(s1, s2)
    T.assert_equal(results, "chain of (3,3) yields 6", S.stream_count(chained), 6)
    S.stream_destroy(chained)
    Return 1
End Process

Process called "test_stream_next_protocol" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.next_protocol")
    Let s be S.stream_from_range(40, 43, 1)
    Let holder be allocate(8)

    __store(holder, 0, 0)
    Let rc1 be S.stream_next(s, holder)
    T.assert_equal(results, "first next returns OK", rc1, 1)
    T.assert_equal(results, "first next returns 40", __load(holder, 0), 40)

    __store(holder, 0, 0)
    Let rc2 be S.stream_next(s, holder)
    T.assert_equal(results, "second next returns OK", rc2, 1)
    T.assert_equal(results, "second next returns 41", __load(holder, 0), 41)

    __store(holder, 0, 0)
    Let rc3 be S.stream_next(s, holder)
    T.assert_equal(results, "third next returns OK", rc3, 1)
    T.assert_equal(results, "third next returns 42", __load(holder, 0), 42)

    Let rc4 be S.stream_next(s, holder)
    T.assert_equal(results, "fourth next returns END", rc4, 0)
    T.assert_equal(results, "exhausted flag set", S.stream_is_exhausted(s), 1)

    S.stream_destroy(s)
    Return 1
End Process

Process called "test_stream_collect_to_list" that takes results as Integer returns Integer:
    T.begin_suite(results, "stream.collect_to_list")
    Let s be S.stream_from_range(10, 14, 1)
    Let len_holder be allocate(8)
    __store(len_holder, 0, 0)
    Let buf be S.stream_collect_to_list(s, len_holder)
    T.assert_not_null(results, "collect returns buffer", buf)
    T.assert_equal(results, "collected length is 4", __load(len_holder, 0), 4)
    T.assert_equal(results, "first element 10", __load(buf, 0), 10)
    T.assert_equal(results, "second element 11", __load(buf, 8), 11)
    T.assert_equal(results, "third element 12", __load(buf, 16), 12)
    T.assert_equal(results, "fourth element 13", __load(buf, 24), 13)
    S.stream_destroy(s)
    Return 1
End Process

Note: User-supplied counter source. State layout: [ next_value ].
Note: Each call writes the current cursor to the holder and advances; protocol
Note: returns STREAM_OK (1) as long as we have not exceeded ten emissions.

Process called "counter_next_fn" takes state as Integer, out_holder as Integer returns Integer:
    Let v be __load(state, 0)
    If v is greater than 10:
        Return 0
    End If
    __store(out_holder, 0, v)
    __store(state, 0, (v plus 1))
    Return 1
End Process

Process called "counter_next_fn_addr" returns Integer:
    Note: Take the address of counter_next_fn so it can be installed as a
    Note: stream callback. Without a real indirect-call primitive backing the
    Note: streams runtime, stream_next would short-circuit to STREAM_END and
    Note: this test would fail.
    Let result be 0
    Inline Assembly:
        .intel_syntax noprefix
        lea rax, qword ptr [rip + counter_next_fn]
        mov qword ptr [rbp-8], rax
        .att_syntax prefix
    End Assembly
    Return result
End Process

Process called "test_stream_user_callback_invoked_through_indirect" that takes results as Integer returns Integer:
    Note: Regression for the previously-stubbed `stream_runtime_call_indirect_2`.
    Note: We register a Process pointer as the stream source, call stream_next
    Note: ten times, and verify the source receives each call and returns the
    Note: incrementing values 1..10. Before this fix the indirect-call shim
    Note: returned 0 unconditionally, so every stream_next call would have
    Note: returned STREAM_END on the first iteration.
    T.begin_suite(results, "stream.user_callback_via_indirect_call")
    Let state be allocate(8)
    __store(state, 0, 1)
    Let fn_ptr be counter_next_fn_addr()
    T.assert_greater_than(results, "callback address is non-zero", fn_ptr, 0)
    Let s be S.stream_create(fn_ptr, state, 0)
    T.assert_not_null(results, "stream allocated", s)

    Let holder be allocate(8)
    Let i be 1
    Let observed be 0
    While i is less than or equal to 10:
        __store(holder, 0, 0)
        Let rc be S.stream_next(s, holder)
        T.assert_equal(results, "iteration returns OK", rc, 1)
        Let v be __load(holder, 0)
        T.assert_equal(results, "value increments through indirect call", v, i)
        Set observed to observed plus 1
        Set i to i plus 1
    End While
    T.assert_equal(results, "observed ten emissions", observed, 10)

    Note: After ten values the source must signal END.
    __store(holder, 0, 0)
    Let rc_end be S.stream_next(s, holder)
    T.assert_equal(results, "eleventh next returns END", rc_end, 0)

    S.stream_destroy(s)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_stream_from_range_basic(results)
    test_stream_range_with_step(results)
    test_stream_range_negative_step(results)
    test_stream_range_empty(results)
    test_stream_from_repeat_finite(results)
    test_stream_take_subset_of_range(results)
    test_stream_drop_advances_cursor(results)
    test_stream_chain_two_ranges(results)
    test_stream_next_protocol(results)
    test_stream_collect_to_list(results)
    test_stream_user_callback_invoked_through_indirect(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
