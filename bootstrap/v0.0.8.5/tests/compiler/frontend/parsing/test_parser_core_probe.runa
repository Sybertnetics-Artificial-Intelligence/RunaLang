Note:
End-to-end probe of the v0.0.8.5 modular PARSER CORE (task #494).

This probe drives the reconciled statement_parsers + expression_parsers through
the real parser state, on hand-built token streams, and asserts the produced
AST structure -- node types, nesting, and operator-precedence grouping.
Compile-pass is not correctness; the AST assertions are the evidence that the
expression/statement parsers were ported faithfully.

Token streams are constructed directly (via the lexical Token constructor +
TokenStream) rather than by running the lexer, because the modular lexer's
keyword table does not yet register the process-signature words (called/takes)
and tokenizes word-form operators (plus/multiplied) in a different code range
than the precedence table keys on -- two cross-cutting lexical gaps outside the
parser core. Driving the parser over explicit token streams isolates and tests
exactly the ported parser logic: the precedence-climbing expression parser, the
statement dispatch, and the AST builders.

Coverage:
  - parse_expression on `a + b * c` -> binary(+) whose RIGHT operand is binary(*),
    proving multiplicative binds tighter than additive (a + (b*c)).
  - parse_let_statement on `Let total be a + b * c` -> AST_LET_STATEMENT carrying
    the additive expression.
  - parse_if_statement on `If cond: Return x End If` -> AST_IF_STATEMENT.
  - parse_while_statement on `While cond: Return x End While` -> AST_WHILE_STATEMENT.
  - parse_return_statement on `Return total` -> AST_RETURN_STATEMENT.
  - parse_type_definition on a struct `Type called "Point": x as Integer ... End Type`.
:End Note

Import "compiler/frontend/parsing/parser.runa" as Parser
Import "compiler/frontend/parsing/expression_parsers.runa" as ExpressionParsers
Import "compiler/frontend/parsing/statement_parsers.runa" as StatementParsers
Import "compiler/frontend/parsing/ast.runa" as AST
Import "compiler/frontend/lexical/syntax_transformer.runa" as SyntaxTransformer
Import "compiler/frontend/lexical/token_stream.runa" as TokenStream
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "tests/test_utils.runa" as TestUtils

Note: Token type codes the parser consumes (lexer + math-symbol scheme).
Constant TOKEN_EOF as Integer is 0
Constant TOKEN_IDENTIFIER as Integer is 150
Constant TOKEN_INTEGER_LITERAL as Integer is 110
Constant TOKEN_LET as Integer is 300
Constant TOKEN_BE as Integer is 389
Constant TOKEN_IF as Integer is 310
Constant TOKEN_WHILE as Integer is 316
Constant TOKEN_RETURN as Integer is 323
Constant TOKEN_TYPE as Integer is 321
Constant TOKEN_CALLED as Integer is 626
Constant TOKEN_AS as Integer is 332
Constant TOKEN_END as Integer is 430
Constant TOKEN_COLON as Integer is 206
Constant TOKEN_GREATER_THAN as Integer is 513
Constant TOKEN_PLUS as Integer is 500
Constant TOKEN_MULTIPLY as Integer is 502

Note: AST node-type discriminants (mirroring ast.runa).
Constant AST_BINARY_EXPRESSION as Integer is 1002
Constant AST_LET_STATEMENT as Integer is 2000
Constant AST_IF_STATEMENT as Integer is 2003
Constant AST_WHILE_STATEMENT as Integer is 2008
Constant AST_RETURN_STATEMENT as Integer is 2010
Constant AST_TYPE_DEFINITION as Integer is 3001

Note: The token-stream layout used by create_token_stream: an array of qword
Note: Token pointers. We allocate the array and fill it, then wrap it.
Process called "stream_of" takes token_array as Integer, count as Integer returns Integer:
    Return proc create_token_stream from TokenStream with token_array, count
End Process

Process called "tok" takes token_type as Integer, value as Integer returns Integer:
    Note: Construct a Token at line 1, column 1, length 1 with the given type/value.
    Return proc create_token from SyntaxTransformer with token_type, value, 1, 1, 1
End Process

Process called "make_parser" takes token_array as Integer, count as Integer, arena as Integer returns Integer:
    Let stream be proc stream_of with token_array, count
    If stream is equal to 0:
        Return 0
    End If
    Return proc parser_create from Parser with stream, arena
End Process

Process called "main" returns Integer:
    Let results be proc create_test_results from TestUtils
    proc begin_suite from TestUtils with results, "parser core end-to-end probe"

    Let arena be proc arena_create from Layout with 1048576
    proc assert_not_null from TestUtils with results, "arena created", arena

    Let v_a be proc create_from_literal from StringCore with "a"
    Let v_b be proc create_from_literal from StringCore with "b"
    Let v_c be proc create_from_literal from StringCore with "c"
    Let v_total be proc create_from_literal from StringCore with "total"
    Let v_cond be proc create_from_literal from StringCore with "cond"
    Let v_point be proc create_from_literal from StringCore with "Point"
    Let v_x be proc create_from_literal from StringCore with "x"
    Let v_y be proc create_from_literal from StringCore with "y"
    Let v_int be proc create_from_literal from StringCore with "Integer"

    Note: -------------------------------------------------------------------
    Note: 1. Expression precedence: a + b * c  ->  a + (b * c).
    Note: Tokens: a + b * c EOF
    Note: -------------------------------------------------------------------
    Let expr_arr be proc allocate from Layout with 48
    proc memory_set_qword from Layout with expr_arr, 0, proc tok with TOKEN_IDENTIFIER, v_a
    proc memory_set_qword from Layout with expr_arr, 8, proc tok with TOKEN_PLUS, 0
    proc memory_set_qword from Layout with expr_arr, 16, proc tok with TOKEN_IDENTIFIER, v_b
    proc memory_set_qword from Layout with expr_arr, 24, proc tok with TOKEN_MULTIPLY, 0
    proc memory_set_qword from Layout with expr_arr, 32, proc tok with TOKEN_IDENTIFIER, v_c
    proc memory_set_qword from Layout with expr_arr, 40, proc tok with TOKEN_EOF, 0

    Let expr_parser be proc make_parser with expr_arr, 6, arena
    proc assert_not_null from TestUtils with results, "expression parser created", expr_parser

    Let expr be proc parse_expression from ExpressionParsers with expr_parser
    proc assert_not_null from TestUtils with results, "a + b * c parsed", expr

    Let expr_type be proc ast_node_get_type from AST with expr
    proc assert_equal from TestUtils with results, "root of a + b * c is a binary expression", expr_type, AST_BINARY_EXPRESSION

    Let expr_right be proc ast_node_get_binary_right from AST with expr
    proc assert_not_null from TestUtils with results, "additive expression has a right operand", expr_right

    Let right_type be proc ast_node_get_type from AST with expr_right
    proc assert_equal from TestUtils with results, "a + b * c groups as a + (b*c): right operand is itself binary", right_type, AST_BINARY_EXPRESSION

    Let expr_left be proc ast_node_get_binary_left from AST with expr
    proc assert_not_null from TestUtils with results, "additive expression has a left operand", expr_left

    Note: -------------------------------------------------------------------
    Note: 2. Let statement: Let total be a + b * c
    Note: Tokens: Let total be a + b * c EOF
    Note: -------------------------------------------------------------------
    Let let_arr be proc allocate from Layout with 72
    proc memory_set_qword from Layout with let_arr, 0, proc tok with TOKEN_LET, 0
    proc memory_set_qword from Layout with let_arr, 8, proc tok with TOKEN_IDENTIFIER, v_total
    proc memory_set_qword from Layout with let_arr, 16, proc tok with TOKEN_BE, 0
    proc memory_set_qword from Layout with let_arr, 24, proc tok with TOKEN_IDENTIFIER, v_a
    proc memory_set_qword from Layout with let_arr, 32, proc tok with TOKEN_PLUS, 0
    proc memory_set_qword from Layout with let_arr, 40, proc tok with TOKEN_IDENTIFIER, v_b
    proc memory_set_qword from Layout with let_arr, 48, proc tok with TOKEN_MULTIPLY, 0
    proc memory_set_qword from Layout with let_arr, 56, proc tok with TOKEN_IDENTIFIER, v_c
    proc memory_set_qword from Layout with let_arr, 64, proc tok with TOKEN_EOF, 0

    Let let_parser be proc make_parser with let_arr, 9, arena
    Let let_stmt be proc parse_let_statement from StatementParsers with let_parser
    proc assert_not_null from TestUtils with results, "Let statement parsed", let_stmt

    Let let_type be proc ast_node_get_type from AST with let_stmt
    proc assert_equal from TestUtils with results, "Let node type is AST_LET_STATEMENT", let_type, AST_LET_STATEMENT

    Note: -------------------------------------------------------------------
    Note: 3. Return statement: Return total
    Note: -------------------------------------------------------------------
    Let ret_arr be proc allocate from Layout with 24
    proc memory_set_qword from Layout with ret_arr, 0, proc tok with TOKEN_RETURN, 0
    proc memory_set_qword from Layout with ret_arr, 8, proc tok with TOKEN_IDENTIFIER, v_total
    proc memory_set_qword from Layout with ret_arr, 16, proc tok with TOKEN_EOF, 0

    Let ret_parser be proc make_parser with ret_arr, 3, arena
    Let ret_stmt be proc parse_return_statement from StatementParsers with ret_parser
    proc assert_not_null from TestUtils with results, "Return statement parsed", ret_stmt
    Let ret_type be proc ast_node_get_type from AST with ret_stmt
    proc assert_equal from TestUtils with results, "Return node type is AST_RETURN_STATEMENT", ret_type, AST_RETURN_STATEMENT

    Note: -------------------------------------------------------------------
    Note: 4. If statement: If cond > a: Return total End If
    Note: Tokens: If cond > a : Return total End If EOF
    Note: (the closing "End If" is two tokens -- TOKEN_END followed by TOKEN_IF --
    Note:  exactly as the lexer emits them; the parser expects both.)
    Note: -------------------------------------------------------------------
    Let if_arr be proc allocate from Layout with 80
    proc memory_set_qword from Layout with if_arr, 0, proc tok with TOKEN_IF, 0
    proc memory_set_qword from Layout with if_arr, 8, proc tok with TOKEN_IDENTIFIER, v_cond
    proc memory_set_qword from Layout with if_arr, 16, proc tok with TOKEN_GREATER_THAN, 0
    proc memory_set_qword from Layout with if_arr, 24, proc tok with TOKEN_IDENTIFIER, v_a
    proc memory_set_qword from Layout with if_arr, 32, proc tok with TOKEN_COLON, 0
    proc memory_set_qword from Layout with if_arr, 40, proc tok with TOKEN_RETURN, 0
    proc memory_set_qword from Layout with if_arr, 48, proc tok with TOKEN_IDENTIFIER, v_total
    proc memory_set_qword from Layout with if_arr, 56, proc tok with TOKEN_END, 0
    proc memory_set_qword from Layout with if_arr, 64, proc tok with TOKEN_IF, 0
    proc memory_set_qword from Layout with if_arr, 72, proc tok with TOKEN_EOF, 0

    Let if_parser be proc make_parser with if_arr, 10, arena
    Let if_stmt be proc parse_if_statement from StatementParsers with if_parser
    proc assert_not_null from TestUtils with results, "If statement parsed", if_stmt
    Let if_type be proc ast_node_get_type from AST with if_stmt
    proc assert_equal from TestUtils with results, "If node type is AST_IF_STATEMENT", if_type, AST_IF_STATEMENT

    Note: -------------------------------------------------------------------
    Note: 5. While statement: While cond > a: Return total End While
    Note: Tokens: While cond > a : Return total End While EOF
    Note: (the closing "End While" is two tokens -- TOKEN_END followed by
    Note:  TOKEN_WHILE -- exactly as the lexer emits them; the parser expects both.)
    Note: -------------------------------------------------------------------
    Let wh_arr be proc allocate from Layout with 80
    proc memory_set_qword from Layout with wh_arr, 0, proc tok with TOKEN_WHILE, 0
    proc memory_set_qword from Layout with wh_arr, 8, proc tok with TOKEN_IDENTIFIER, v_cond
    proc memory_set_qword from Layout with wh_arr, 16, proc tok with TOKEN_GREATER_THAN, 0
    proc memory_set_qword from Layout with wh_arr, 24, proc tok with TOKEN_IDENTIFIER, v_a
    proc memory_set_qword from Layout with wh_arr, 32, proc tok with TOKEN_COLON, 0
    proc memory_set_qword from Layout with wh_arr, 40, proc tok with TOKEN_RETURN, 0
    proc memory_set_qword from Layout with wh_arr, 48, proc tok with TOKEN_IDENTIFIER, v_total
    proc memory_set_qword from Layout with wh_arr, 56, proc tok with TOKEN_END, 0
    proc memory_set_qword from Layout with wh_arr, 64, proc tok with TOKEN_WHILE, 0
    proc memory_set_qword from Layout with wh_arr, 72, proc tok with TOKEN_EOF, 0

    Let wh_parser be proc make_parser with wh_arr, 10, arena
    Let wh_stmt be proc parse_while_statement from StatementParsers with wh_parser
    proc assert_not_null from TestUtils with results, "While statement parsed", wh_stmt
    Let wh_type be proc ast_node_get_type from AST with wh_stmt
    proc assert_equal from TestUtils with results, "While node type is AST_WHILE_STATEMENT", wh_type, AST_WHILE_STATEMENT

    Note: -------------------------------------------------------------------
    Note: 6. Type definition (struct): Type called Point: x as Integer  y as Integer End Type
    Note: Tokens: Type called Point : x as Integer y as Integer End Type EOF
    Note: -------------------------------------------------------------------
    Let ty_arr be proc allocate from Layout with 104
    proc memory_set_qword from Layout with ty_arr, 0, proc tok with TOKEN_TYPE, 0
    proc memory_set_qword from Layout with ty_arr, 8, proc tok with TOKEN_CALLED, 0
    proc memory_set_qword from Layout with ty_arr, 16, proc tok with TOKEN_IDENTIFIER, v_point
    proc memory_set_qword from Layout with ty_arr, 24, proc tok with TOKEN_COLON, 0
    proc memory_set_qword from Layout with ty_arr, 32, proc tok with TOKEN_IDENTIFIER, v_x
    proc memory_set_qword from Layout with ty_arr, 40, proc tok with TOKEN_AS, 0
    proc memory_set_qword from Layout with ty_arr, 48, proc tok with TOKEN_IDENTIFIER, v_int
    proc memory_set_qword from Layout with ty_arr, 56, proc tok with TOKEN_IDENTIFIER, v_y
    proc memory_set_qword from Layout with ty_arr, 64, proc tok with TOKEN_AS, 0
    proc memory_set_qword from Layout with ty_arr, 72, proc tok with TOKEN_IDENTIFIER, v_int
    proc memory_set_qword from Layout with ty_arr, 80, proc tok with TOKEN_END, 0
    proc memory_set_qword from Layout with ty_arr, 88, proc tok with TOKEN_TYPE, 0
    proc memory_set_qword from Layout with ty_arr, 96, proc tok with TOKEN_EOF, 0

    Let ty_parser be proc make_parser with ty_arr, 13, arena
    Let ty_stmt be proc parse_type_definition from StatementParsers with ty_parser
    proc assert_not_null from TestUtils with results, "Type definition parsed", ty_stmt
    Let ty_type be proc ast_node_get_type from AST with ty_stmt
    proc assert_equal from TestUtils with results, "Type def node type is AST_TYPE_DEFINITION", ty_type, AST_TYPE_DEFINITION

    proc print_summary from TestUtils with results

    Let failed be proc get_failed from TestUtils with results
    Return failed
End Process
