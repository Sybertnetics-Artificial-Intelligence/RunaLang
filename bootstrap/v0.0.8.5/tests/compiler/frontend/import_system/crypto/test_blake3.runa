Process called "test_blake3_L0" that takes results as Integer returns Integer:
    T.begin_suite(results, "blake3 official vectors len=0")

    Let arena be Arena.arena_create(262144)
    T.assert_not_null(results, "arena created", arena)

    Let inp be 0

    Let digest be Arena.arena_allocate(arena, 32)
    Let rc be Blake3.blake3_hash(arena, inp, 0, digest)
    T.assert_equal(results, "blake3_hash returned 1", rc, 1)
    Let h0 be Memory.memory_get_byte(digest, 0)
    T.assert_equal(results, "L0 hash byte 0", h0, 175)
