Process called "test_blake3_L1" that takes results as Integer returns Integer:
    T.begin_suite(results, "blake3 official vectors len=1")

    Let arena be Arena.arena_create(262144)
    T.assert_not_null(results, "arena created", arena)

    Let inp be Arena.arena_allocate(arena, 1)
    T.assert_not_null(results, "input allocated", inp)
    fill_input_pattern(inp, 1)

    Let digest be Arena.arena_allocate(arena, 32)
    Let rc be Blake3.blake3_hash(arena, inp, 1, digest)
    T.assert_equal(results, "blake3_hash returned 1", rc, 1)
    Let h0 be Memory.memory_get_byte(digest, 0)
    T.assert_equal(results, "L1 hash byte 0", h0, 45)
    Let h1 be Memory.memory_get_byte(digest, 1)
    T.assert_equal(results, "L1 hash byte 1", h1, 58)
    Let h2 be Memory.memory_get_byte(digest, 2)
    T.assert_equal(results, "L1 hash byte 2", h2, 222)
    Let h3 be Memory.memory_get_byte(digest, 3)
    T.assert_equal(results, "L1 hash byte 3", h3, 223)
    Let h4 be Memory.memory_get_byte(digest, 4)
    T.assert_equal(results, "L1 hash byte 4", h4, 241)
    Let h5 be Memory.memory_get_byte(digest, 5)
    T.assert_equal(results, "L1 hash byte 5", h5, 27)
