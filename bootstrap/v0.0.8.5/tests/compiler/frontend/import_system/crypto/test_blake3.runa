    Let x126 be Memory.memory_get_byte(out, 126)
    T.assert_equal(results, "XOF byte 126", x126, 237)
    Let x127 be Memory.memory_get_byte(out, 127)
    T.assert_equal(results, "XOF byte 127", x127, 154)
    Let x128 be Memory.memory_get_byte(out, 128)
    T.assert_equal(results, "XOF byte 128", x128, 250)
    Let x129 be Memory.memory_get_byte(out, 129)
    T.assert_equal(results, "XOF byte 129", x129, 104)
    Let x130 be Memory.memory_get_byte(out, 130)
    T.assert_equal(results, "XOF byte 130", x130, 78)

    Arena.arena_destroy(arena)
    Return 1
End Process

