    Let key32 be Arena.arena_allocate(arena, 32)
    fill_test_key(key32)
    Let kdigest be Arena.arena_allocate(arena, 32)
    Let krc be Blake3.blake3_keyed_hash(arena, key32, inp, 1, kdigest)
    T.assert_equal(results, "blake3_keyed_hash returned 1", krc, 1)
