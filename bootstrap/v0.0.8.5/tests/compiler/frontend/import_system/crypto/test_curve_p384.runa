Note:
Unit tests for compiler/frontend/import_system/crypto/curve_p384.runa.

Verifies:
- Generator G is on the curve (FIPS 186-4 D.1.2.4 self-test).
- Public-key validation accepts G, rejects infinity.
- 2*G is on the curve.
- Scalar mul 1*G == G.
- SEC1 uncompressed encode/decode round-trip.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/bigint.runa" as BigInt
Import "compiler/frontend/import_system/crypto/curve_p384.runa" as P384
Import "compiler/frontend/import_system/crypto/field_p384.runa" as F384

Process called "test_curve_p384_generator_on_curve" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p384 generator on-curve self-test")
    Let arena be Arena.arena_create(1048576)
    Let gx be P384.curve_p384_gx(arena)
    Let gy be P384.curve_p384_gy(arena)
    Let on_curve be P384.curve_p384_is_on_curve_affine(arena, gx, gy)
    T.assert_equal(results, "G on curve", on_curve, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p384_validate_generator" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p384 validate generator")
    Let arena be Arena.arena_create(1048576)
    Let g be P384.curve_p384_generator(arena)
    T.assert_not_null(results, "generator allocated", g)
    Let valid be P384.curve_p384_validate_public_key(arena, g)
    T.assert_equal(results, "generator validates", valid, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p384_double_on_curve" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p384 doubling on-curve")
    Let arena be Arena.arena_create(1048576)
    Let g be P384.curve_p384_generator(arena)
    Let dbl be P384.curve_p384_point_alloc(arena)
    P384.curve_p384_double(arena, dbl, g)

    Let ax be F384.field_p384_zero(arena)
    Let ay be F384.field_p384_zero(arena)
    Let aff_rc be P384.curve_p384_to_affine(arena, dbl, ax, ay)
    T.assert_equal(results, "2*G converts to affine", aff_rc, 1)
    Let on_curve be P384.curve_p384_is_on_curve_affine(arena, ax, ay)
    T.assert_equal(results, "2*G is on curve", on_curve, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p384_scalar_mul_one" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p384 scalar mul 1*G == G")
    Let arena be Arena.arena_create(16777216)
    Let g be P384.curve_p384_generator(arena)
    Let one_scalar be BigInt.bigint_from_u64(arena, 1)
    Let result be P384.curve_p384_point_alloc(arena)
    P384.curve_p384_scalar_mul(arena, result, one_scalar, g)

    Let ax be F384.field_p384_zero(arena)
    Let ay be F384.field_p384_zero(arena)
    P384.curve_p384_to_affine(arena, result, ax, ay)
    Let gx be P384.curve_p384_gx(arena)
    Let gy be P384.curve_p384_gy(arena)
    T.assert_equal(results, "1*G x = Gx", F384.field_p384_equal(ax, gx), 1)
    T.assert_equal(results, "1*G y = Gy", F384.field_p384_equal(ay, gy), 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p384_uncompressed_round_trip" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p384 uncompressed encode/decode")
    Let arena be Arena.arena_create(1048576)
    Let g be P384.curve_p384_generator(arena)

    Let enc_buf be Arena.arena_allocate(arena, 97)
    Let enc_len be P384.curve_p384_encode_uncompressed(arena, g, enc_buf)
    T.assert_equal(results, "encoded length 97", enc_len, 97)
    Let tag_byte be Memory.memory_get_byte(enc_buf, 0)
    T.assert_equal(results, "tag 0x04", tag_byte, 4)

    Let recovered be P384.curve_p384_point_alloc(arena)
    Let dec_rc be P384.curve_p384_decode_uncompressed(arena, enc_buf, 97, recovered)
    T.assert_equal(results, "decode succeeded", dec_rc, 1)

    Let ax be F384.field_p384_zero(arena)
    Let ay be F384.field_p384_zero(arena)
    P384.curve_p384_to_affine(arena, recovered, ax, ay)
    Let gx be P384.curve_p384_gx(arena)
    Let gy be P384.curve_p384_gy(arena)
    T.assert_equal(results, "round-trip x = Gx", F384.field_p384_equal(ax, gx), 1)
    T.assert_equal(results, "round-trip y = Gy", F384.field_p384_equal(ay, gy), 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_curve_p384_generator_on_curve(results)
    test_curve_p384_validate_generator(results)
    test_curve_p384_double_on_curve(results)
    test_curve_p384_scalar_mul_one(results)
    test_curve_p384_uncompressed_round_trip(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
