Note:
Unit tests for compiler/frontend/import_system/crypto/aes.runa.

Test vectors from FIPS 197:
  Appendix B: AES-128 example with the Rijndael "0x32 0x43 0xf6 0xa8 ..."
              plaintext and the "Thomas J. Wei" key 0x2b7e1516.... Expected
              ciphertext is 0x3925841d02dc09fbdc118597196a0b32.
  Appendix C.1: AES-128 with key=000102...0f and plaintext=00112233...ff,
                expected ciphertext=69c4e0d86a7b0430d8cdb78070b4c55a.
  Appendix C.2: AES-192 with key=000102...17 and plaintext=00112233...ff,
                expected ciphertext=dda97ca4864cdfe06eaf70a0ec0d7191.
  Appendix C.3: AES-256 with key=000102...1f and plaintext=00112233...ff,
                expected ciphertext=8ea2b7ca516745bfeafc49904b496089.

For every key size we verify both encrypt and decrypt (decrypt of the
expected ciphertext yields the original plaintext).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/aes.runa" as AES

Process called "compare_bytes" takes a as Integer, b as Integer, length as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Let ba be Memory.memory_get_byte(a, i)
        Let bb be Memory.memory_get_byte(b, i)
        If ba is not equal to bb:
            Return 0
        End If
        Set i to i plus 1
    End While
    Return 1
End Process

Note: ============================================================================
Note: FIPS 197 Appendix B: AES-128 worked example
Note: Key:        2b 7e 15 16 28 ae d2 a6 ab f7 15 88 09 cf 4f 3c
Note: Plaintext:  32 43 f6 a8 88 5a 30 8d 31 31 98 a2 e0 37 07 34
Note: Ciphertext: 39 25 84 1d 02 dc 09 fb dc 11 85 97 19 6a 0b 32
Note: ============================================================================

Process called "test_aes128_fips197_appendix_b" that takes results as Integer returns Integer:
    T.begin_suite(results, "AES-128 FIPS 197 Appendix B")

    Let arena be Arena.arena_create(131072)
    T.assert_not_null(results, "arena created", arena)

    Let key be Arena.arena_allocate(arena, 16)
    Memory.memory_set_byte(key, 0, 43)
    Memory.memory_set_byte(key, 1, 126)
    Memory.memory_set_byte(key, 2, 21)
    Memory.memory_set_byte(key, 3, 22)
    Memory.memory_set_byte(key, 4, 40)
    Memory.memory_set_byte(key, 5, 174)
    Memory.memory_set_byte(key, 6, 210)
    Memory.memory_set_byte(key, 7, 166)
    Memory.memory_set_byte(key, 8, 171)
    Memory.memory_set_byte(key, 9, 247)
    Memory.memory_set_byte(key, 10, 21)
    Memory.memory_set_byte(key, 11, 136)
    Memory.memory_set_byte(key, 12, 9)
    Memory.memory_set_byte(key, 13, 207)
    Memory.memory_set_byte(key, 14, 79)
    Memory.memory_set_byte(key, 15, 60)

    Let plaintext be Arena.arena_allocate(arena, 16)
    Memory.memory_set_byte(plaintext, 0, 50)
    Memory.memory_set_byte(plaintext, 1, 67)
    Memory.memory_set_byte(plaintext, 2, 246)
    Memory.memory_set_byte(plaintext, 3, 168)
    Memory.memory_set_byte(plaintext, 4, 136)
    Memory.memory_set_byte(plaintext, 5, 90)
    Memory.memory_set_byte(plaintext, 6, 48)
    Memory.memory_set_byte(plaintext, 7, 141)
    Memory.memory_set_byte(plaintext, 8, 49)
    Memory.memory_set_byte(plaintext, 9, 49)
    Memory.memory_set_byte(plaintext, 10, 152)
    Memory.memory_set_byte(plaintext, 11, 162)
    Memory.memory_set_byte(plaintext, 12, 224)
    Memory.memory_set_byte(plaintext, 13, 55)
    Memory.memory_set_byte(plaintext, 14, 7)
    Memory.memory_set_byte(plaintext, 15, 52)

    Let expected_ct be Arena.arena_allocate(arena, 16)
    Memory.memory_set_byte(expected_ct, 0, 57)
    Memory.memory_set_byte(expected_ct, 1, 37)
    Memory.memory_set_byte(expected_ct, 2, 132)
    Memory.memory_set_byte(expected_ct, 3, 29)
    Memory.memory_set_byte(expected_ct, 4, 2)
    Memory.memory_set_byte(expected_ct, 5, 220)
    Memory.memory_set_byte(expected_ct, 6, 9)
    Memory.memory_set_byte(expected_ct, 7, 251)
    Memory.memory_set_byte(expected_ct, 8, 220)
    Memory.memory_set_byte(expected_ct, 9, 17)
    Memory.memory_set_byte(expected_ct, 10, 133)
    Memory.memory_set_byte(expected_ct, 11, 151)
    Memory.memory_set_byte(expected_ct, 12, 25)
    Memory.memory_set_byte(expected_ct, 13, 106)
    Memory.memory_set_byte(expected_ct, 14, 11)
    Memory.memory_set_byte(expected_ct, 15, 50)

    Let schedule be Arena.arena_allocate(arena, 176)
    Let kx be AES.aes128_key_expand(arena, key, schedule)
    T.assert_equal(results, "aes128 key expansion", kx, 1)

    Let ct be Arena.arena_allocate(arena, 16)
    Let erc be AES.aes_encrypt_block(arena, schedule, 176, plaintext, ct)
    T.assert_equal(results, "aes128 encrypt block rc=1", erc, 1)

    Let match be compare_bytes(ct, expected_ct, 16)
    T.assert_equal(results, "aes128 ciphertext matches FIPS 197 App B", match, 1)

    Let restored be Arena.arena_allocate(arena, 16)
    Let drc be AES.aes_decrypt_block(arena, schedule, 176, ct, restored)
    T.assert_equal(results, "aes128 decrypt block rc=1", drc, 1)

    Let pt_match be compare_bytes(restored, plaintext, 16)
    T.assert_equal(results, "aes128 decrypt restores plaintext", pt_match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note: ============================================================================
Note: FIPS 197 Appendix C.1: AES-128 with sequential 00..0f key
Note: Plaintext:  00 11 22 33 44 55 66 77 88 99 aa bb cc dd ee ff
Note: Ciphertext: 69 c4 e0 d8 6a 7b 04 30 d8 cd b7 80 70 b4 c5 5a
Note: ============================================================================

Process called "test_aes128_fips197_appendix_c1" that takes results as Integer returns Integer:
    T.begin_suite(results, "AES-128 FIPS 197 Appendix C.1")

    Let arena be Arena.arena_create(131072)

    Let key be Arena.arena_allocate(arena, 16)
    Let ki be 0
    While ki is less than 16:
        Memory.memory_set_byte(key, ki, ki)
        Set ki to ki plus 1
    End While

    Let plaintext be Arena.arena_allocate(arena, 16)
    Memory.memory_set_byte(plaintext, 0, 0)
    Memory.memory_set_byte(plaintext, 1, 17)
    Memory.memory_set_byte(plaintext, 2, 34)
    Memory.memory_set_byte(plaintext, 3, 51)
    Memory.memory_set_byte(plaintext, 4, 68)
    Memory.memory_set_byte(plaintext, 5, 85)
    Memory.memory_set_byte(plaintext, 6, 102)
    Memory.memory_set_byte(plaintext, 7, 119)
    Memory.memory_set_byte(plaintext, 8, 136)
    Memory.memory_set_byte(plaintext, 9, 153)
    Memory.memory_set_byte(plaintext, 10, 170)
    Memory.memory_set_byte(plaintext, 11, 187)
    Memory.memory_set_byte(plaintext, 12, 204)
    Memory.memory_set_byte(plaintext, 13, 221)
    Memory.memory_set_byte(plaintext, 14, 238)
    Memory.memory_set_byte(plaintext, 15, 255)

    Let expected_ct be Arena.arena_allocate(arena, 16)
    Memory.memory_set_byte(expected_ct, 0, 105)
    Memory.memory_set_byte(expected_ct, 1, 196)
    Memory.memory_set_byte(expected_ct, 2, 224)
    Memory.memory_set_byte(expected_ct, 3, 216)
    Memory.memory_set_byte(expected_ct, 4, 106)
    Memory.memory_set_byte(expected_ct, 5, 123)
    Memory.memory_set_byte(expected_ct, 6, 4)
    Memory.memory_set_byte(expected_ct, 7, 48)
    Memory.memory_set_byte(expected_ct, 8, 216)
    Memory.memory_set_byte(expected_ct, 9, 205)
    Memory.memory_set_byte(expected_ct, 10, 183)
    Memory.memory_set_byte(expected_ct, 11, 128)
    Memory.memory_set_byte(expected_ct, 12, 112)
    Memory.memory_set_byte(expected_ct, 13, 180)
    Memory.memory_set_byte(expected_ct, 14, 197)
    Memory.memory_set_byte(expected_ct, 15, 90)

    Let schedule be Arena.arena_allocate(arena, 176)
    Let kx be AES.aes128_key_expand(arena, key, schedule)
    T.assert_equal(results, "aes128 C.1 key expansion", kx, 1)

    Let ct be Arena.arena_allocate(arena, 16)
    Let erc be AES.aes_encrypt_block(arena, schedule, 176, plaintext, ct)
    T.assert_equal(results, "aes128 C.1 encrypt rc=1", erc, 1)

    Let match be compare_bytes(ct, expected_ct, 16)
    T.assert_equal(results, "aes128 C.1 ciphertext matches", match, 1)

    Let restored be Arena.arena_allocate(arena, 16)
    Let drc be AES.aes_decrypt_block(arena, schedule, 176, ct, restored)
    T.assert_equal(results, "aes128 C.1 decrypt rc=1", drc, 1)

    Let pt_match be compare_bytes(restored, plaintext, 16)
    T.assert_equal(results, "aes128 C.1 decrypt restores plaintext", pt_match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

