Note:
Unit tests for compiler/frontend/import_system/crypto/argon2id.runa.

Primary vector: RFC 9106 Appendix B (Argon2id Test Vector).
  Password   = 32 bytes of 0x01
  Salt       = 16 bytes of 0x02
  Secret K   = 8 bytes of 0x03
  AD X       = 12 bytes of 0x04
  m_cost     = 32 KB
  t          = 3 iterations
  p          = 4 lanes
  Output     = 32 bytes
  Expected tag (hex):
    0d 64 0d f5 8d 78 76 6c 08 c0 37 a3 4a 8b 53 c9
    d0 1e f0 45 2d 75 b6 5e b5 25 20 e9 6b 01 e6 59

Plus structural validation tests:
  - reject when m < 8 * p
  - reject when t < 1
  - reject when output_len < 4
  - reject when salt_len < 8
  - reject when output is null
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/argon2id.runa" as A2

Note: ============================================================================
Note: Helper: fill buffer with a byte pattern
Note: ============================================================================

Process called "fill_buffer" takes buf as Integer, length as Integer, byte_value as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Memory.memory_set_byte(buf, i, byte_value)
        Set i to i plus 1
    End While
    Return 1
End Process

Note: ============================================================================
Note: Set expected RFC 9106 Appendix B Argon2id tag (32 bytes) into buffer
Note: ============================================================================

Process called "set_rfc9106_expected" takes buf as Integer returns Integer:
    Memory.memory_set_byte(buf, 0, 13)
    Memory.memory_set_byte(buf, 1, 100)
    Memory.memory_set_byte(buf, 2, 13)
    Memory.memory_set_byte(buf, 3, 245)
    Memory.memory_set_byte(buf, 4, 141)
    Memory.memory_set_byte(buf, 5, 120)
    Memory.memory_set_byte(buf, 6, 118)
    Memory.memory_set_byte(buf, 7, 108)
    Memory.memory_set_byte(buf, 8, 8)
    Memory.memory_set_byte(buf, 9, 192)
    Memory.memory_set_byte(buf, 10, 55)
    Memory.memory_set_byte(buf, 11, 163)
    Memory.memory_set_byte(buf, 12, 74)
    Memory.memory_set_byte(buf, 13, 139)
    Memory.memory_set_byte(buf, 14, 83)
    Memory.memory_set_byte(buf, 15, 201)
    Memory.memory_set_byte(buf, 16, 208)
    Memory.memory_set_byte(buf, 17, 30)
    Memory.memory_set_byte(buf, 18, 240)
    Memory.memory_set_byte(buf, 19, 69)
    Memory.memory_set_byte(buf, 20, 45)
    Memory.memory_set_byte(buf, 21, 117)
    Memory.memory_set_byte(buf, 22, 182)
    Memory.memory_set_byte(buf, 23, 94)
    Memory.memory_set_byte(buf, 24, 181)
    Memory.memory_set_byte(buf, 25, 37)
    Memory.memory_set_byte(buf, 26, 32)
    Memory.memory_set_byte(buf, 27, 233)
    Memory.memory_set_byte(buf, 28, 107)
    Memory.memory_set_byte(buf, 29, 1)
    Memory.memory_set_byte(buf, 30, 230)
    Memory.memory_set_byte(buf, 31, 89)
    Return 1
End Process

Process called "compare_bytes" takes a as Integer, b as Integer, length as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Let ba be Memory.memory_get_byte(a, i)
        Let bb be Memory.memory_get_byte(b, i)
        If ba is not equal to bb:
            Return 0
        End If
        Set i to i plus 1
    End While
    Return 1
End Process

Note: ============================================================================
Note: Test 1: RFC 9106 Appendix B Argon2id KAT
Note: ============================================================================

Process called "test_argon2id_rfc9106_appendix_b" that takes results as Integer returns Integer:
    T.begin_suite(results, "argon2id RFC 9106 Appendix B KAT")

    Let arena be Arena.arena_create(65536)
    T.assert_not_null(results, "arena created", arena)

    Let password be Arena.arena_allocate(arena, 32)
    fill_buffer(password, 32, 1)

    Let salt be Arena.arena_allocate(arena, 16)
    fill_buffer(salt, 16, 2)

    Let secret be Arena.arena_allocate(arena, 8)
    fill_buffer(secret, 8, 3)

    Let ad be Arena.arena_allocate(arena, 12)
    fill_buffer(ad, 12, 4)

    Let tag be Arena.arena_allocate(arena, 32)
    Memory.memory_zero(tag, 32)

    Let expected be Arena.arena_allocate(arena, 32)
    set_rfc9106_expected(expected)

    Note: argon2id_hash takes 13 arguments. Dotted-call A2.x(...) form
    Note: is used here per crypto test convention.
    Let rc be A2.argon2id_hash(password, 32, salt, 16, secret, 8, ad, 12, 32, 3, 4, tag, 32)
    T.assert_equal(results, "argon2id_hash returned 1", rc, 1)

    Let b0 be Memory.memory_get_byte(tag, 0)
    Let b1 be Memory.memory_get_byte(tag, 1)
    Let b2 be Memory.memory_get_byte(tag, 2)
    Let b3 be Memory.memory_get_byte(tag, 3)
    T.assert_equal(results, "tag[0] = 0x0d", b0, 13)
    T.assert_equal(results, "tag[1] = 0x64", b1, 100)
    T.assert_equal(results, "tag[2] = 0x0d", b2, 13)
    T.assert_equal(results, "tag[3] = 0xf5", b3, 245)

    Let b28 be Memory.memory_get_byte(tag, 28)
    Let b29 be Memory.memory_get_byte(tag, 29)
    Let b30 be Memory.memory_get_byte(tag, 30)
    Let b31 be Memory.memory_get_byte(tag, 31)
    T.assert_equal(results, "tag[28] = 0x6b", b28, 107)
    T.assert_equal(results, "tag[29] = 0x01", b29, 1)
    T.assert_equal(results, "tag[30] = 0xe6", b30, 230)
    T.assert_equal(results, "tag[31] = 0x59", b31, 89)

    Let match be compare_bytes(tag, expected, 32)
    T.assert_equal(results, "full 32-byte tag matches RFC 9106 Appendix B", match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note: ============================================================================
Note: Test 2: parameter validation
Note: ============================================================================

Process called "test_argon2id_param_validation" that takes results as Integer returns Integer:
    T.begin_suite(results, "argon2id parameter validation")

    Let arena be Arena.arena_create(65536)
    T.assert_not_null(results, "arena created", arena)

    Let password be Arena.arena_allocate(arena, 32)
    fill_buffer(password, 32, 1)
    Let salt be Arena.arena_allocate(arena, 16)
    fill_buffer(salt, 16, 2)
    Let tag be Arena.arena_allocate(arena, 32)

    Note: m < 8*p should reject
    Let rc1 be A2.argon2id_hash(password, 32, salt, 16, 0, 0, 0, 0, 16, 3, 4, tag, 32)
    T.assert_equal(results, "rejects m < 8*p", rc1, 0)

    Note: t < 1 should reject
    Let rc2 be A2.argon2id_hash(password, 32, salt, 16, 0, 0, 0, 0, 32, 0, 4, tag, 32)
    T.assert_equal(results, "rejects t < 1", rc2, 0)

    Note: p < 1 should reject
    Let rc3 be A2.argon2id_hash(password, 32, salt, 16, 0, 0, 0, 0, 32, 3, 0, tag, 32)
    T.assert_equal(results, "rejects p < 1", rc3, 0)

    Note: output_len < 4 should reject
    Let rc4 be A2.argon2id_hash(password, 32, salt, 16, 0, 0, 0, 0, 32, 3, 4, tag, 3)
    T.assert_equal(results, "rejects output_len < 4", rc4, 0)

    Note: salt_len < 8 should reject
    Let short_salt be Arena.arena_allocate(arena, 4)
    fill_buffer(short_salt, 4, 2)
    Let rc5 be A2.argon2id_hash(password, 32, short_salt, 4, 0, 0, 0, 0, 32, 3, 4, tag, 32)
    T.assert_equal(results, "rejects salt_len < 8", rc5, 0)

    Note: null output should reject
    Let rc6 be A2.argon2id_hash(password, 32, salt, 16, 0, 0, 0, 0, 32, 3, 4, 0, 32)
    T.assert_equal(results, "rejects null output", rc6, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_argon2id_rfc9106_appendix_b(results)
    test_argon2id_param_validation(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
