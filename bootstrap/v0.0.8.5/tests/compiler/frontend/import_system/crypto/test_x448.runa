Process called "test_clamp" takes results as Integer returns Integer:
    T.begin_suite(results, "x448_clamp: clears low 2 bits and sets top bit")
    Let arena be Arena.arena_create(131072)
    Let scalar be Arena.arena_allocate(arena, 56)
    Let i be 0
    While i is less than 56:
        Memory.memory_set_byte(scalar, i, 255)
        Set i to i plus 1
    End While
    X.x448_clamp(scalar)
    Let b0 be Memory.memory_get_byte(scalar, 0)
    Let b55 be Memory.memory_get_byte(scalar, 55)
    Note: 0xFF & 252 = 252
    T.assert_equal(results, "clamp: byte 0 = 252", b0, 252)
    Note: 0xFF | 128 = 255
    T.assert_equal(results, "clamp: byte 55 = 255", b55, 255)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_alice_bob_exchange" takes results as Integer returns Integer:
    T.begin_suite(results, "RFC 7748 6.2 X448 Alice -> Bob scalarmult (first byte check)")
    Let arena be Arena.arena_create(4194304)
    Let alice_priv be Arena.arena_allocate(arena, 56)
    Let bob_pub be Arena.arena_allocate(arena, 56)
    Let shared be Arena.arena_allocate(arena, 56)
    set_alice_private(alice_priv)
    set_bob_public(bob_pub)
    Let rc be X.x448_scalarmult(arena, alice_priv, bob_pub, shared)
    T.assert_equal(results, "x448_scalarmult returned 1", rc, 1)
    Note: Expected shared secret first byte: 0x07
    Let b0 be Memory.memory_get_byte(shared, 0)
    T.assert_equal(results, "shared[0] = 0x07", b0, 7)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_clamp(results)
    test_alice_bob_exchange(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
