Note:
Unit tests for compiler/frontend/import_system/crypto/hmac.runa.

Test vectors are taken from RFC 4231 "Identifiers and Test Vectors for
HMAC-SHA-224, HMAC-SHA-256, HMAC-SHA-384, and HMAC-SHA-512". Each test
case lists the canonical key, message, and expected MAC bytes; this
file exercises the SHA-256, SHA-384, SHA-512 outputs.

RFC 4231 vectors implemented:
  Test Case 1: 20-byte all-0x0b key, "Hi There" message.
  Test Case 2: "Jefe" key, "what do ya want for nothing?" message.
  Test Case 3: 20-byte all-0xaa key, 50-byte all-0xdd message.
  Test Case 4: 25-byte counting key 0x01..0x19, 50-byte all-0xcd message.
  Test Case 6: 131-byte all-0xaa key (longer than block, exercises
               long-key hash-down path), short "Test Using Larger Than
               Block-Size Key..." message.
  Test Case 7: 131-byte all-0xaa key, 152-byte message.

Plus structural tests on constant-time-verify:
  - verify of correct tag returns 1
  - verify of mutated tag returns 0
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/hmac.runa" as Hmac

Note: ============================================================================
Note: Helper: fill buffer with a byte pattern
Note: ============================================================================

Process called "fill_buffer" takes buf as Integer, length as Integer, byte_value as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Memory.memory_set_byte(buf, i, byte_value)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "compare_bytes" takes a as Integer, b as Integer, length as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Let ba be Memory.memory_get_byte(a, i)
        Let bb be Memory.memory_get_byte(b, i)
        If ba is not equal to bb:
            Return 0
        End If
        Set i to i plus 1
    End While
    Return 1
End Process

Note: ============================================================================
Note: RFC 4231 Test Case 1: 20-byte 0x0b key, "Hi There"
Note: Expected HMAC-SHA256:
Note:   b0344c61 d8db3853 5ca8afce af0bf12b
Note:   881dc200 c9833da7 26e9376c 2e32cff7
Note: ============================================================================

Process called "test_hmac_sha256_rfc4231_case1" that takes results as Integer returns Integer:
    T.begin_suite(results, "hmac_sha256 RFC 4231 case 1")

    Let arena be Arena.arena_create(65536)
    T.assert_not_null(results, "arena created", arena)

    Note: Key: 20 bytes of 0x0b
    Let key be Arena.arena_allocate(arena, 20)
    fill_buffer(key, 20, 11)

    Note: Message: "Hi There" (8 bytes)
    Let msg be Arena.arena_allocate(arena, 8)
    Memory.memory_set_byte(msg, 0, 72)
    Memory.memory_set_byte(msg, 1, 105)
    Memory.memory_set_byte(msg, 2, 32)
    Memory.memory_set_byte(msg, 3, 84)
    Memory.memory_set_byte(msg, 4, 104)
    Memory.memory_set_byte(msg, 5, 101)
    Memory.memory_set_byte(msg, 6, 114)
    Memory.memory_set_byte(msg, 7, 101)

    Let tag be Arena.arena_allocate(arena, 32)
    Let rc be Hmac.hmac_sha256(arena, key, 20, msg, 8, tag)
    T.assert_equal(results, "hmac_sha256 returned 1", rc, 1)

    Note: Expected first 4 bytes: 0xb0 0x34 0x4c 0x61
    Let b0 be Memory.memory_get_byte(tag, 0)
    Let b1 be Memory.memory_get_byte(tag, 1)
    Let b2 be Memory.memory_get_byte(tag, 2)
    Let b3 be Memory.memory_get_byte(tag, 3)
    T.assert_equal(results, "byte 0 = 0xb0", b0, 176)
    T.assert_equal(results, "byte 1 = 0x34", b1, 52)
    T.assert_equal(results, "byte 2 = 0x4c", b2, 76)
    T.assert_equal(results, "byte 3 = 0x61", b3, 97)

    Note: Expected last 4 bytes: 0x2e 0x32 0xcf 0xf7
    Let b28 be Memory.memory_get_byte(tag, 28)
    Let b29 be Memory.memory_get_byte(tag, 29)
    Let b30 be Memory.memory_get_byte(tag, 30)
    Let b31 be Memory.memory_get_byte(tag, 31)
    T.assert_equal(results, "byte 28 = 0x2e", b28, 46)
    T.assert_equal(results, "byte 29 = 0x32", b29, 50)
    T.assert_equal(results, "byte 30 = 0xcf", b30, 207)
    T.assert_equal(results, "byte 31 = 0xf7", b31, 247)

    Note: Build the expected full tag and verify by constant-time compare
    Let expected be Arena.arena_allocate(arena, 32)
    Memory.memory_set_byte(expected, 0, 176)
    Memory.memory_set_byte(expected, 1, 52)
    Memory.memory_set_byte(expected, 2, 76)
    Memory.memory_set_byte(expected, 3, 97)
    Memory.memory_set_byte(expected, 4, 216)
    Memory.memory_set_byte(expected, 5, 219)
    Memory.memory_set_byte(expected, 6, 56)
    Memory.memory_set_byte(expected, 7, 83)
    Memory.memory_set_byte(expected, 8, 92)
    Memory.memory_set_byte(expected, 9, 168)
    Memory.memory_set_byte(expected, 10, 175)
    Memory.memory_set_byte(expected, 11, 206)
    Memory.memory_set_byte(expected, 12, 175)
    Memory.memory_set_byte(expected, 13, 11)
    Memory.memory_set_byte(expected, 14, 241)
    Memory.memory_set_byte(expected, 15, 43)
    Memory.memory_set_byte(expected, 16, 136)
    Memory.memory_set_byte(expected, 17, 29)
    Memory.memory_set_byte(expected, 18, 194)
    Memory.memory_set_byte(expected, 19, 0)
    Memory.memory_set_byte(expected, 20, 201)
    Memory.memory_set_byte(expected, 21, 131)
    Memory.memory_set_byte(expected, 22, 61)
    Memory.memory_set_byte(expected, 23, 167)
    Memory.memory_set_byte(expected, 24, 38)
    Memory.memory_set_byte(expected, 25, 233)
    Memory.memory_set_byte(expected, 26, 55)
    Memory.memory_set_byte(expected, 27, 108)
    Memory.memory_set_byte(expected, 28, 46)
    Memory.memory_set_byte(expected, 29, 50)
    Memory.memory_set_byte(expected, 30, 207)
    Memory.memory_set_byte(expected, 31, 247)

    Let full_match be compare_bytes(tag, expected, 32)
    T.assert_equal(results, "full HMAC-SHA256 matches RFC 4231 case 1", full_match, 1)

    Note: Verify path: correct tag returns 1
    Let v_ok be Hmac.hmac_sha256_verify(arena, key, 20, msg, 8, expected)
    T.assert_equal(results, "verify of correct tag returns 1", v_ok, 1)

    Note: Verify path: mutated tag returns 0
    Memory.memory_set_byte(expected, 0, 0)
    Let v_bad be Hmac.hmac_sha256_verify(arena, key, 20, msg, 8, expected)
    T.assert_equal(results, "verify of mutated tag returns 0", v_bad, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

