    Let tag be Arena.arena_allocate(arena, 32)
    Let rc be Hmac.hmac_sha256(arena, key, 131, msg, 54, tag)
    T.assert_equal(results, "hmac_sha256 returned 1", rc, 1)

    Note: Expected first 4 bytes: 0x60 0xe4 0x31 0x59
    Let b0 be Memory.memory_get_byte(tag, 0)
