    Let match be compare_bytes(tag, expected, 32)
    T.assert_equal(results, "full HMAC-SHA256 matches RFC 4231 case 6", match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_hmac_sha256_rfc4231_case1(results)
    test_hmac_sha256_rfc4231_case2(results)
    test_hmac_sha256_rfc4231_case6_longkey(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
