Note: ============================================================================
Note: Structural tests
Note: ============================================================================

Process called "test_verify_rejects_null_pubkey" takes results as Integer returns Integer:
    T.begin_suite(results, "ed25519_verify: rejects null public key")
    Let arena be Arena.arena_create(2097152)
    Let signature be Arena.arena_allocate(arena, 64)
    Let i be 0
    While i is less than 64:
        Memory.memory_set_byte(signature, i, 0)
        Set i to i plus 1
    End While
    Let rc be Ed.ed25519_verify(arena, 0, signature, 0, 64)
    T.assert_equal(results, "verify(NULL, sig) = 0", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_verify_rejects_null_signature" takes results as Integer returns Integer:
    T.begin_suite(results, "ed25519_verify: rejects null signature")
    Let arena be Arena.arena_create(2097152)
    Let pubkey be Arena.arena_allocate(arena, 32)
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(pubkey, i, 0)
        Set i to i plus 1
    End While
    Memory.memory_set_byte(pubkey, 0, 1)
    Let rc be Ed.ed25519_verify(arena, pubkey, 0, 0, 0)
    T.assert_equal(results, "verify(pubkey, NULL) = 0", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_verify_rejects_identity_pubkey" takes results as Integer returns Integer:
    T.begin_suite(results, "ed25519_verify: rejects identity (small-order) public key")
    Let arena be Arena.arena_create(2097152)
    Let pubkey be Arena.arena_allocate(arena, 32)
    Let signature be Arena.arena_allocate(arena, 64)

    Note: Identity encoding: 01 followed by 31 zeros.
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(pubkey, i, 0)
        Set i to i plus 1
    End While
    Memory.memory_set_byte(pubkey, 0, 1)
    Let j be 0
    While j is less than 64:
        Memory.memory_set_byte(signature, j, 0)
        Set j to j plus 1
    End While

    Let rc be Ed.ed25519_verify(arena, pubkey, signature, 0, 64)
    T.assert_equal(results, "verify(identity, sig) = 0", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_keygen_structure" takes results as Integer returns Integer:
    T.begin_suite(results, "ed25519_keygen: RFC 8032 7.1 Test 1 seed -> pubkey")
    Let arena be Arena.arena_create(4194304)
    Let seed be Arena.arena_allocate(arena, 32)
    Let pubkey be Arena.arena_allocate(arena, 32)
    Let secret_64 be Arena.arena_allocate(arena, 64)
    Let expected_pk be Arena.arena_allocate(arena, 32)

    set_test1_secret_seed(seed)
    set_test1_expected_pk(expected_pk)

    Let rc be Ed.ed25519_keygen(arena, seed, pubkey, secret_64)
    T.assert_equal(results, "keygen returned 1", rc, 1)

    Note: First byte of pubkey: expect 0xd7 = 215
    Let b0 be Memory.memory_get_byte(pubkey, 0)
    T.assert_equal(results, "pubkey[0] = 0xd7", b0, 215)

    Note: secret_key[32..63] should equal pubkey
    Let s32 be Memory.memory_get_byte(secret_64, 32)
    T.assert_equal(results, "secret[32] = pubkey[0]", s32, b0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_sign_verify_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "ed25519 sign then verify roundtrip on RFC 8032 7.1 Test 1")
    Let arena be Arena.arena_create(8388608)
    Let seed be Arena.arena_allocate(arena, 32)
    Let pubkey be Arena.arena_allocate(arena, 32)
    Let secret_64 be Arena.arena_allocate(arena, 64)
    Let signature be Arena.arena_allocate(arena, 64)

    set_test1_secret_seed(seed)

    Let kg be Ed.ed25519_keygen(arena, seed, pubkey, secret_64)
    T.assert_equal(results, "keygen success", kg, 1)

    Note: Empty message: pointer can be any non-null since length is 0.
    Let empty_msg be Arena.arena_allocate(arena, 1)
    Memory.memory_set_byte(empty_msg, 0, 0)

    Let sg be Ed.ed25519_sign(arena, secret_64, empty_msg, 0, signature)
    T.assert_equal(results, "sign returned 1", sg, 1)

    Let vf be Ed.ed25519_verify(arena, pubkey, empty_msg, 0, signature)
    T.assert_equal(results, "verify of self-signed empty-message = 1", vf, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_verify_rejects_null_pubkey(results)
    test_verify_rejects_null_signature(results)
    test_verify_rejects_identity_pubkey(results)
    test_keygen_structure(results)
    test_sign_verify_roundtrip(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
