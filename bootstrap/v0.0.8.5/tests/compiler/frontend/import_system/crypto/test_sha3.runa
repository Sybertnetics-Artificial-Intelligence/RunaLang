Note:
==============================================================================
Unit tests for compiler/frontend/import_system/crypto/sha3.runa
==============================================================================

Coverage:
  - SHA3-256 fixed-output hash: NIST CAVP empty-string vector.
  - SHA3-256 fixed-output hash: NIST CAVP "abc" vector.
  - Keccak-256 (Ethereum variant): empty-string vector.
  - SHAKE256 XOF empty input, 32-byte output: NIST CAVP vector.
  - SHAKE256 XOF "abc" input, 32-byte output: NIST CAVP vector.
  - SHAKE256 XOF "abc" input, 64-byte output: NIST CAVP vector (first 32
    bytes match the 32-byte vector and next 32 bytes extend the stream).
  - SHAKE256 incremental: init + absorb("ab") + absorb("c") + finalize
    + squeeze(32) equals the single-shot SHAKE256("abc", 32) hash.
  - SHAKE256 destroy zeroes the context.

Test vectors are from the NIST Cryptographic Algorithm Validation Program
(CAVP) SHA-3 / SHAKE response files. Byte values are expressed as
unsigned decimal in the assertions for direct comparison with
memory_get_byte output (which returns unsigned 0..255).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/sha3.runa" as Sha3

Process called "compare_bytes" takes a as Integer, b as Integer, length as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Let ba be Memory.memory_get_byte(a, i)
        Let bb be Memory.memory_get_byte(b, i)
        If ba is not equal to bb:
            Return 0
        End If
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "fill_zero" takes buf as Integer, length as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Memory.memory_set_byte(buf, i, 0)
        Set i to i plus 1
    End While
    Return 1
End Process

Note:
==============================================================================
SHAKE256 KAT: empty input, 32-byte output
==============================================================================
NIST CAVP vector:
  msg = "" (0 bytes)
  out_len = 32
  expected = 46 b9 dd 2b 0b a8 8d 13 23 3b 3f eb 74 3e eb 24
             3f cd 52 ea 62 b8 1b 82 b5 0c 27 64 6e d5 76 2f
:End Note

Process called "test_shake256_empty_32" takes results as Integer returns Integer:
    T.begin_suite(results, "shake256 empty input, 32-byte output")

    Let arena be Arena.arena_create(65536)
    T.assert_not_null(results, "arena created", arena)

    Let input be Arena.arena_allocate(arena, 1)
    Let out be Arena.arena_allocate(arena, 32)
    fill_zero(out, 32)

    Let rc be Sha3.shake256_hash(arena, input, 0, out, 32)
    T.assert_equal(results, "shake256_hash rc=32", rc, 32)

    T.assert_equal(results, "byte 0  = 0x46", Memory.memory_get_byte(out, 0), 70)
    T.assert_equal(results, "byte 1  = 0xb9", Memory.memory_get_byte(out, 1), 185)
    T.assert_equal(results, "byte 2  = 0xdd", Memory.memory_get_byte(out, 2), 221)
    T.assert_equal(results, "byte 3  = 0x2b", Memory.memory_get_byte(out, 3), 43)
    T.assert_equal(results, "byte 4  = 0x0b", Memory.memory_get_byte(out, 4), 11)
    T.assert_equal(results, "byte 5  = 0xa8", Memory.memory_get_byte(out, 5), 168)
    T.assert_equal(results, "byte 6  = 0x8d", Memory.memory_get_byte(out, 6), 141)
    T.assert_equal(results, "byte 7  = 0x13", Memory.memory_get_byte(out, 7), 19)
    T.assert_equal(results, "byte 28 = 0x6e", Memory.memory_get_byte(out, 28), 110)
    T.assert_equal(results, "byte 29 = 0xd5", Memory.memory_get_byte(out, 29), 213)
    T.assert_equal(results, "byte 30 = 0x76", Memory.memory_get_byte(out, 30), 118)
    T.assert_equal(results, "byte 31 = 0x2f", Memory.memory_get_byte(out, 31), 47)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note:
==============================================================================
SHAKE256 KAT: "abc" input, 32-byte output
==============================================================================
NIST CAVP vector:
  msg = "abc"  (3 bytes: 0x61 0x62 0x63)
  out_len = 32
  expected = 48 33 66 60 13 60 a8 77 1c 68 63 08 0c c4 11 4d
             8d b4 45 30 f8 f1 e1 ee 4f 94 ea 37 e7 8b 57 39
:End Note

Process called "test_shake256_abc_32" takes results as Integer returns Integer:
    T.begin_suite(results, "shake256 abc input, 32-byte output")

    Let arena be Arena.arena_create(65536)
    T.assert_not_null(results, "arena created", arena)

    Let input be Arena.arena_allocate(arena, 3)
    Memory.memory_set_byte(input, 0, 97)
    Memory.memory_set_byte(input, 1, 98)
    Memory.memory_set_byte(input, 2, 99)

    Let out be Arena.arena_allocate(arena, 32)
    fill_zero(out, 32)

    Let rc be Sha3.shake256_hash(arena, input, 3, out, 32)
    T.assert_equal(results, "shake256_hash rc=32", rc, 32)

    T.assert_equal(results, "byte 0  = 0x48", Memory.memory_get_byte(out, 0), 72)
    T.assert_equal(results, "byte 1  = 0x33", Memory.memory_get_byte(out, 1), 51)
    T.assert_equal(results, "byte 2  = 0x66", Memory.memory_get_byte(out, 2), 102)
    T.assert_equal(results, "byte 3  = 0x60", Memory.memory_get_byte(out, 3), 96)
    T.assert_equal(results, "byte 4  = 0x13", Memory.memory_get_byte(out, 4), 19)
    T.assert_equal(results, "byte 5  = 0x60", Memory.memory_get_byte(out, 5), 96)
    T.assert_equal(results, "byte 6  = 0xa8", Memory.memory_get_byte(out, 6), 168)
    T.assert_equal(results, "byte 7  = 0x77", Memory.memory_get_byte(out, 7), 119)
    T.assert_equal(results, "byte 28 = 0xe7", Memory.memory_get_byte(out, 28), 231)
    T.assert_equal(results, "byte 29 = 0x8b", Memory.memory_get_byte(out, 29), 139)
    T.assert_equal(results, "byte 30 = 0x57", Memory.memory_get_byte(out, 30), 87)
    T.assert_equal(results, "byte 31 = 0x39", Memory.memory_get_byte(out, 31), 57)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note:
==============================================================================
SHAKE256 KAT: "abc" input, 64-byte output
==============================================================================
NIST CAVP vector first 32 bytes match the 32-byte test above; the next
32 bytes continue the deterministic squeeze stream:
  bytes 32..63 = d5 a1 5b ef 18 6a 53 86 c7 57 44 c0 52 7e 1f aa
                 9f 87 26 e4 62 a1 2a 4f eb 06 bd 88 01 e7 51 e4
:End Note

Process called "test_shake256_abc_64" takes results as Integer returns Integer:
    T.begin_suite(results, "shake256 abc input, 64-byte output")

    Let arena be Arena.arena_create(65536)
    T.assert_not_null(results, "arena created", arena)

    Let input be Arena.arena_allocate(arena, 3)
    Memory.memory_set_byte(input, 0, 97)
    Memory.memory_set_byte(input, 1, 98)
    Memory.memory_set_byte(input, 2, 99)

    Let out be Arena.arena_allocate(arena, 64)
    fill_zero(out, 64)

    Let rc be Sha3.shake256_hash(arena, input, 3, out, 64)
    T.assert_equal(results, "shake256_hash rc=64", rc, 64)

    Note: First 32 bytes must match the 32-byte vector
    T.assert_equal(results, "byte 0  = 0x48", Memory.memory_get_byte(out, 0), 72)
    T.assert_equal(results, "byte 1  = 0x33", Memory.memory_get_byte(out, 1), 51)
    T.assert_equal(results, "byte 30 = 0x57", Memory.memory_get_byte(out, 30), 87)
    T.assert_equal(results, "byte 31 = 0x39", Memory.memory_get_byte(out, 31), 57)

    Note: Bytes 32..63 extend the stream
    T.assert_equal(results, "byte 32 = 0xd5", Memory.memory_get_byte(out, 32), 213)
    T.assert_equal(results, "byte 33 = 0xa1", Memory.memory_get_byte(out, 33), 161)
    T.assert_equal(results, "byte 34 = 0x5b", Memory.memory_get_byte(out, 34), 91)
    T.assert_equal(results, "byte 35 = 0xef", Memory.memory_get_byte(out, 35), 239)
    T.assert_equal(results, "byte 60 = 0x01", Memory.memory_get_byte(out, 60), 1)
    T.assert_equal(results, "byte 61 = 0xe7", Memory.memory_get_byte(out, 61), 231)
    T.assert_equal(results, "byte 62 = 0x51", Memory.memory_get_byte(out, 62), 81)
    T.assert_equal(results, "byte 63 = 0xe4", Memory.memory_get_byte(out, 63), 228)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note:
==============================================================================
SHAKE256 incremental absorb test
==============================================================================
shake256_init + shake256_absorb("ab") + shake256_absorb("c") +
shake256_finalize + shake256_squeeze(32)

must equal

shake256_hash("abc", 32)

byte-for-byte. This verifies the streaming absorb correctly accumulates
state across multiple absorb calls.
:End Note

Process called "test_shake256_incremental" takes results as Integer returns Integer:
    T.begin_suite(results, "shake256 incremental absorb")

    Let arena be Arena.arena_create(65536)
    T.assert_not_null(results, "arena created", arena)

    Note: One-shot reference
    Let abc be Arena.arena_allocate(arena, 3)
    Memory.memory_set_byte(abc, 0, 97)
    Memory.memory_set_byte(abc, 1, 98)
    Memory.memory_set_byte(abc, 2, 99)

    Let expected be Arena.arena_allocate(arena, 32)
    fill_zero(expected, 32)
    Sha3.shake256_hash(arena, abc, 3, expected, 32)

    Note: Incremental path
    Let ctx be Sha3.shake256_init(arena)
    T.assert_not_null(results, "context allocated", ctx)

    Let ab be Arena.arena_allocate(arena, 2)
    Memory.memory_set_byte(ab, 0, 97)
    Memory.memory_set_byte(ab, 1, 98)
    Sha3.shake256_absorb(ctx, ab, 2)

    Let c be Arena.arena_allocate(arena, 1)
    Memory.memory_set_byte(c, 0, 99)
    Sha3.shake256_absorb(ctx, c, 1)

    Let fin_rc be Sha3.shake256_finalize(ctx)
    T.assert_equal(results, "finalize returns 1", fin_rc, 1)

    Let actual be Arena.arena_allocate(arena, 32)
    fill_zero(actual, 32)
    Sha3.shake256_squeeze(ctx, actual, 32)

    Let match be compare_bytes(expected, actual, 32)
    T.assert_equal(results, "incremental matches one-shot", match, 1)

    Sha3.shake256_destroy(ctx)
    Note: After destroy, every byte of ctx (504 total) must be zero
    Let post_destroy_byte0 be Memory.memory_get_byte(ctx, 0)
    Let post_destroy_byte250 be Memory.memory_get_byte(ctx, 250)
    Let post_destroy_byte503 be Memory.memory_get_byte(ctx, 503)
    T.assert_equal(results, "destroyed ctx byte 0 = 0", post_destroy_byte0, 0)
    T.assert_equal(results, "destroyed ctx byte 250 = 0", post_destroy_byte250, 0)
    T.assert_equal(results, "destroyed ctx byte 503 = 0", post_destroy_byte503, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note:
==============================================================================
SHAKE256 streaming squeeze across rate boundary
==============================================================================
Squeeze 200 bytes (more than one rate=136 block) from a known-input
context and verify continuity: the first 136 bytes come directly from
the post-finalize state; bytes 136..199 come from the state after one
internal Keccak-f permutation. Equivalent to a single 200-byte squeeze.
:End Note

Process called "test_shake256_squeeze_across_block" takes results as Integer returns Integer:
    T.begin_suite(results, "shake256 squeeze across rate boundary")

    Let arena be Arena.arena_create(65536)
    T.assert_not_null(results, "arena created", arena)

    Let input be Arena.arena_allocate(arena, 3)
    Memory.memory_set_byte(input, 0, 97)
    Memory.memory_set_byte(input, 1, 98)
    Memory.memory_set_byte(input, 2, 99)

    Note: One-shot 200-byte squeeze
    Let out_oneshot be Arena.arena_allocate(arena, 200)
    fill_zero(out_oneshot, 200)
    Sha3.shake256_hash(arena, input, 3, out_oneshot, 200)

    Note: Two-step squeeze: first 100 bytes then next 100 bytes
    Let ctx be Sha3.shake256_init(arena)
    Sha3.shake256_absorb(ctx, input, 3)
    Sha3.shake256_finalize(ctx)

    Let part_a be Arena.arena_allocate(arena, 100)
    Let part_b be Arena.arena_allocate(arena, 100)
    fill_zero(part_a, 100)
    fill_zero(part_b, 100)
    Sha3.shake256_squeeze(ctx, part_a, 100)
    Sha3.shake256_squeeze(ctx, part_b, 100)

    Note: out_oneshot[0..100) == part_a
    Let match_a be compare_bytes(out_oneshot, part_a, 100)
    T.assert_equal(results, "first 100 bytes match", match_a, 1)

    Note: out_oneshot[100..200) == part_b
    Let oneshot_tail be out_oneshot plus 100
    Let match_b be compare_bytes(oneshot_tail, part_b, 100)
    T.assert_equal(results, "second 100 bytes match", match_b, 1)

    Sha3.shake256_destroy(ctx)
    Arena.arena_destroy(arena)
    Return 1
End Process

Note:
==============================================================================
SHA3-256 KAT: empty-string vector
==============================================================================
NIST FIPS 202 vector:
  msg = "" (0 bytes)
  expected = a7 ff c6 f8 bf 1e d7 66 51 c1 47 56 a0 61 d6 62
             f5 80 ff 4d e4 3b 49 fa 82 d8 0a 4b 80 f8 43 4a
:End Note

Process called "test_sha3_256_empty" takes results as Integer returns Integer:
    T.begin_suite(results, "sha3_256 empty input")

    Let arena be Arena.arena_create(65536)
    Let input be Arena.arena_allocate(arena, 1)
    Let out be Arena.arena_allocate(arena, 32)
    fill_zero(out, 32)

    Let rc be Sha3.sha3_256_hash(arena, input, 0, out)
    T.assert_equal(results, "sha3_256_hash rc=32", rc, 32)

    T.assert_equal(results, "byte 0 = 0xa7", Memory.memory_get_byte(out, 0), 167)
    T.assert_equal(results, "byte 1 = 0xff", Memory.memory_get_byte(out, 1), 255)
    T.assert_equal(results, "byte 30 = 0x43", Memory.memory_get_byte(out, 30), 67)
    T.assert_equal(results, "byte 31 = 0x4a", Memory.memory_get_byte(out, 31), 74)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_sha3_256_empty(results)
    test_shake256_empty_32(results)
    test_shake256_abc_32(results)
    test_shake256_abc_64(results)
    test_shake256_incremental(results)
    test_shake256_squeeze_across_block(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
