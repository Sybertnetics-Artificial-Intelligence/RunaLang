Process called "test_clamp_low_bits" takes results as Integer returns Integer:
    T.begin_suite(results, "x25519_clamp: clears low 3 bits and sets bit 254")
    Let arena be Arena.arena_create(65536)
    Let scalar be Arena.arena_allocate(arena, 32)
    Note: Fill with 0xFF so we can observe the masking.
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(scalar, i, 255)
        Set i to i plus 1
    End While
    X.x25519_clamp(scalar)
    Let b0 be Memory.memory_get_byte(scalar, 0)
    Let b31 be Memory.memory_get_byte(scalar, 31)
    Note: After clamp: b0 = 0xFF & 248 = 248. b31 = (0xFF & 127) | 64 = 127.
    T.assert_equal(results, "clamp: byte 0 = 248", b0, 248)
    T.assert_equal(results, "clamp: byte 31 = 127", b31, 127)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_alice_to_bob_exchange" takes results as Integer returns Integer:
    T.begin_suite(results, "RFC 7748 6.1 Alice -> Bob X25519 scalarmult")
    Let arena be Arena.arena_create(2097152)

    Let alice_private be Arena.arena_allocate(arena, 32)
    Let bob_public be Arena.arena_allocate(arena, 32)
    Let shared be Arena.arena_allocate(arena, 32)

    set_alice_private(alice_private)
    set_bob_public(bob_public)

    Let rc be X.x25519_scalarmult(arena, alice_private, bob_public, shared)
    T.assert_equal(results, "x25519_scalarmult returned 1", rc, 1)

    Note: Expected shared secret first byte: 0x4a (= 74)
    Let b0 be Memory.memory_get_byte(shared, 0)
    Let b31 be Memory.memory_get_byte(shared, 31)
    T.assert_equal(results, "shared[0] = 0x4a", b0, 74)
    T.assert_equal(results, "shared[31] = 0x42", b31, 66)

    Note: A few more byte checks across the secret:
    Let b15 be Memory.memory_get_byte(shared, 15)
    Note: expected: 4a5d9d5ba4ce2de1728e3bf480350f25e07e21c947d19e3376f09b3c1e161742
    Note: shared[15] = 0x25 = 37
    T.assert_equal(results, "shared[15] = 0x25", b15, 37)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_clamp_low_bits(results)
    test_alice_to_bob_exchange(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
