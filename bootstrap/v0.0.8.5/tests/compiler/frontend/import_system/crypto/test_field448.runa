Note:
Unit tests for compiler/frontend/import_system/crypto/field448.runa.

Property tests for the Goldilocks field operations.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/field448.runa" as Fe

Process called "test_alloc_zero" takes results as Integer returns Integer:
    T.begin_suite(results, "fe448_alloc + fe448_set_zero")
    Let arena be Arena.arena_create(131072)
    Let fe be Fe.fe448_alloc(arena)
    T.assert_not_null(results, "alloc returned non-null", fe)
    Let limb0 be Memory.memory_get_int64(fe, 0)
    Let limb15 be Memory.memory_get_int64(fe, 120)
    T.assert_equal(results, "fresh limb 0 = 0", limb0, 0)
    T.assert_equal(results, "fresh limb 15 = 0", limb15, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_set_one" takes results as Integer returns Integer:
    T.begin_suite(results, "fe448_set_one")
    Let arena be Arena.arena_create(131072)
    Let fe be Fe.fe448_alloc(arena)
    Fe.fe448_set_one(fe)
    Let limb0 be Memory.memory_get_int64(fe, 0)
    Let limb1 be Memory.memory_get_int64(fe, 8)
    T.assert_equal(results, "set_one: limb 0 = 1", limb0, 1)
    T.assert_equal(results, "set_one: limb 1 = 0", limb1, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_pack_unpack_one" takes results as Integer returns Integer:
    T.begin_suite(results, "fe448 pack(unpack(1)) = 1")
    Let arena be Arena.arena_create(131072)
    Let fe be Fe.fe448_alloc(arena)
    Let in_bytes be Arena.arena_allocate(arena, 56)
    Let out_bytes be Arena.arena_allocate(arena, 56)
    Memory.memory_set_byte(in_bytes, 0, 1)
    Let i be 1
    While i is less than 56:
        Memory.memory_set_byte(in_bytes, i, 0)
        Set i to i plus 1
    End While
    Fe.fe448_unpack(fe, in_bytes)
    Fe.fe448_pack(fe, out_bytes)
    Let b0 be Memory.memory_get_byte(out_bytes, 0)
    Let b1 be Memory.memory_get_byte(out_bytes, 1)
    Let b55 be Memory.memory_get_byte(out_bytes, 55)
    T.assert_equal(results, "out[0] = 1", b0, 1)
    T.assert_equal(results, "out[1] = 0", b1, 0)
    T.assert_equal(results, "out[55] = 0", b55, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_sub_self" takes results as Integer returns Integer:
    T.begin_suite(results, "fe448_sub: a - a = 0")
    Let arena be Arena.arena_create(131072)
    Let a be Fe.fe448_alloc(arena)
    Let r be Fe.fe448_alloc(arena)
    Fe.fe448_set_one(a)
    Fe.fe448_sub(r, a, a)
    Let iz be Fe.fe448_is_zero(r)
    T.assert_equal(results, "1 - 1 = 0", iz, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_mul_one_identity" takes results as Integer returns Integer:
    T.begin_suite(results, "fe448_mul: 7 * 1 = 7")
    Let arena be Arena.arena_create(131072)
    Let a be Fe.fe448_alloc(arena)
    Let one_fe be Fe.fe448_alloc(arena)
    Let r be Fe.fe448_alloc(arena)
    Memory.memory_set_qword(a, 0, 7)
    Fe.fe448_set_one(one_fe)
    Fe.fe448_mul(r, a, one_fe)
    Let limb0 be Memory.memory_get_int64(r, 0)
    T.assert_equal(results, "7 * 1 limb 0 = 7", limb0, 7)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_mul_by_zero" takes results as Integer returns Integer:
    T.begin_suite(results, "fe448_mul: a * 0 = 0")
    Let arena be Arena.arena_create(131072)
    Let a be Fe.fe448_alloc(arena)
    Let z be Fe.fe448_alloc(arena)
    Let r be Fe.fe448_alloc(arena)
    Fe.fe448_set_one(a)
    Fe.fe448_mul(r, a, z)
    Let iz be Fe.fe448_is_zero(r)
    T.assert_equal(results, "1 * 0 = 0", iz, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_cswap" takes results as Integer returns Integer:
    T.begin_suite(results, "fe448_cswap")
    Let arena be Arena.arena_create(131072)
    Let a be Fe.fe448_alloc(arena)
    Let b be Fe.fe448_alloc(arena)
    Memory.memory_set_qword(a, 0, 100)
    Memory.memory_set_qword(b, 0, 200)
    Fe.fe448_cswap(a, b, 0)
    Let a_v0 be Memory.memory_get_int64(a, 0)
    Let b_v0 be Memory.memory_get_int64(b, 0)
    T.assert_equal(results, "cswap(0): a stays", a_v0, 100)
    T.assert_equal(results, "cswap(0): b stays", b_v0, 200)
    Fe.fe448_cswap(a, b, 1)
    Let a_v1 be Memory.memory_get_int64(a, 0)
    Let b_v1 be Memory.memory_get_int64(b, 0)
    T.assert_equal(results, "cswap(1): a becomes 200", a_v1, 200)
    T.assert_equal(results, "cswap(1): b becomes 100", b_v1, 100)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_alloc_zero(results)
    test_set_one(results)
    test_pack_unpack_one(results)
    test_sub_self(results)
    test_mul_one_identity(results)
    test_mul_by_zero(results)
    test_cswap(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
