End Process

Process called "test_hkdf_sha256_expand_a1" that takes results as Integer returns Integer:
    T.begin_suite(results, "hkdf_sha256_expand RFC 5869 A.1")

    Let arena be Arena.arena_create(65536)

    Let prk be Arena.arena_allocate(arena, 32)
    build_a1_prk(prk)

    Let info be Arena.arena_allocate(arena, 10)
    fill_range(info, 10, 240)

    Let okm be Arena.arena_allocate(arena, 42)
    Let rc be Hkdf.hkdf_sha256_expand(arena, prk, info, 10, 42, okm)
    T.assert_equal(results, "expand returned 1", rc, 1)

    Let b0 be Memory.memory_get_byte(okm, 0)
    Let b1 be Memory.memory_get_byte(okm, 1)
    Let b2 be Memory.memory_get_byte(okm, 2)
    Let b3 be Memory.memory_get_byte(okm, 3)
    T.assert_equal(results, "OKM[0] = 0x3c", b0, 60)
    T.assert_equal(results, "OKM[1] = 0xb2", b1, 178)
    T.assert_equal(results, "OKM[2] = 0x5f", b2, 95)
    T.assert_equal(results, "OKM[3] = 0x25", b3, 37)

    Let b39 be Memory.memory_get_byte(okm, 39)
    Let b40 be Memory.memory_get_byte(okm, 40)
    Let b41 be Memory.memory_get_byte(okm, 41)
    Note: OKM[39] is 0x18 (24) per RFC 5869 A.1 hex listing
    Note: ("...d5 b8 87 18 58 65"). Earlier "0x88" was a transcription error.
    T.assert_equal(results, "OKM[39] = 0x18", b39, 24)
    T.assert_equal(results, "OKM[40] = 0x58", b40, 88)
    T.assert_equal(results, "OKM[41] = 0x65", b41, 101)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note: ============================================================================
Note: RFC 5869 A.1: combined extract+expand
Note: ============================================================================

Process called "test_hkdf_sha256_combined_a1" that takes results as Integer returns Integer:
    T.begin_suite(results, "hkdf_sha256 combined RFC 5869 A.1")

    Let arena be Arena.arena_create(65536)

    Let ikm be Arena.arena_allocate(arena, 22)
    fill_buffer(ikm, 22, 11)

    Let salt be Arena.arena_allocate(arena, 13)
    fill_range(salt, 13, 0)

    Let info be Arena.arena_allocate(arena, 10)
    fill_range(info, 10, 240)

    Let okm be Arena.arena_allocate(arena, 42)
    Note: Stage1 v4 cannot codegen 9-argument dotted proc calls
    Note: (the parser accepts them but the codegen rejects the AST
    Note: node). We exercise the combined extract+expand path by
    Note: invoking the two-step API instead, which produces identical
    Note: output by construction (hkdf_sha256 is literally the
    Note: composition of extract and expand internally).
    Let prk be Arena.arena_allocate(arena, 32)
    Let er be Hkdf.hkdf_sha256_extract(arena, salt, 13, ikm, 22, prk)
    T.assert_equal(results, "extract returned 1", er, 1)
    Let rc be Hkdf.hkdf_sha256_expand(arena, prk, info, 10, 42, okm)
    T.assert_equal(results, "expand returned 1", rc, 1)

    Note: Same OKM as A.1
    Let b0 be Memory.memory_get_byte(okm, 0)
    T.assert_equal(results, "OKM[0] matches", b0, 60)
    Let b41 be Memory.memory_get_byte(okm, 41)
    T.assert_equal(results, "OKM[41] matches", b41, 101)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_hkdf_sha256_extract_a1(results)
    test_hkdf_sha256_expand_a1(results)
    test_hkdf_sha256_combined_a1(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
