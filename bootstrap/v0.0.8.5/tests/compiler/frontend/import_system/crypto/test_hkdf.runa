Note:
Unit tests for compiler/frontend/import_system/crypto/hkdf.runa.

Test vectors from RFC 5869 "HMAC-based Extract-and-Expand Key
Derivation Function (HKDF)" appendix A.

A.1 Basic test case with SHA-256:
  IKM  = 0x0b * 22 bytes
  salt = 0x00..0x0c (13 bytes)
  info = 0xf0..0xf9 (10 bytes)
  L    = 42
  PRK  = 077709362c2e32df0ddc3f0dc47bba63
         90b6c73bb50f9c3122ec844ad7c2b3e5
  OKM  = 3cb25f25faacd57a90434f64d0362f2a
         2d2d0a90cf1a5a4c5db02d56ecc4c5bf
         34007208d5b887185865

A.2 Test case with SHA-256 + longer inputs:
  IKM  = 0x00..0x4f (80 bytes)
  salt = 0x60..0xaf (80 bytes)
  info = 0xb0..0xff (80 bytes)
  L    = 82
  PRK  = 06a6b88c5853361a06104c9ceb35b45c
         ef760014904671014a193f40c15fc244
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/hkdf.runa" as Hkdf

Process called "fill_buffer" takes buf as Integer, length as Integer, byte_value as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Memory.memory_set_byte(buf, i, byte_value)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "fill_range" takes buf as Integer, length as Integer, start as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Memory.memory_set_byte(buf, i, start plus i)
        Set i to i plus 1
    End While
    Return 1
End Process

Note: ============================================================================
Note: RFC 5869 A.1: extract step
Note: ============================================================================

Process called "test_hkdf_sha256_extract_a1" that takes results as Integer returns Integer:
    T.begin_suite(results, "hkdf_sha256_extract RFC 5869 A.1")

    Let arena be Arena.arena_create(65536)

    Note: IKM = 22 bytes of 0x0b
    Let ikm be Arena.arena_allocate(arena, 22)
    fill_buffer(ikm, 22, 11)

    Note: salt = 13 bytes 0x00 0x01 .. 0x0c
    Let salt be Arena.arena_allocate(arena, 13)
    fill_range(salt, 13, 0)

    Let prk be Arena.arena_allocate(arena, 32)
    Let rc be Hkdf.hkdf_sha256_extract(arena, salt, 13, ikm, 22, prk)
    T.assert_equal(results, "extract returned 1", rc, 1)

    Note: Expected PRK first 4 bytes: 0x07 0x77 0x09 0x36
    Let b0 be Memory.memory_get_byte(prk, 0)
    Let b1 be Memory.memory_get_byte(prk, 1)
    Let b2 be Memory.memory_get_byte(prk, 2)
    Let b3 be Memory.memory_get_byte(prk, 3)
    T.assert_equal(results, "PRK[0] = 0x07", b0, 7)
    T.assert_equal(results, "PRK[1] = 0x77", b1, 119)
    T.assert_equal(results, "PRK[2] = 0x09", b2, 9)
    T.assert_equal(results, "PRK[3] = 0x36", b3, 54)

    Note: Last 4 bytes of PRK: 0xd7 0xc2 0xb3 0xe5
    Let b28 be Memory.memory_get_byte(prk, 28)
    Let b29 be Memory.memory_get_byte(prk, 29)
    Let b30 be Memory.memory_get_byte(prk, 30)
    Let b31 be Memory.memory_get_byte(prk, 31)
    T.assert_equal(results, "PRK[28] = 0xd7", b28, 215)
    T.assert_equal(results, "PRK[29] = 0xc2", b29, 194)
    T.assert_equal(results, "PRK[30] = 0xb3", b30, 179)
    T.assert_equal(results, "PRK[31] = 0xe5", b31, 229)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note: ============================================================================
Note: RFC 5869 A.1: expand step (uses the PRK derived above)
Note: ============================================================================

Process called "build_a1_prk" takes prk as Integer returns Integer:
    Memory.memory_set_byte(prk, 0, 7)
    Memory.memory_set_byte(prk, 1, 119)
    Memory.memory_set_byte(prk, 2, 9)
    Memory.memory_set_byte(prk, 3, 54)
    Memory.memory_set_byte(prk, 4, 44)
    Memory.memory_set_byte(prk, 5, 46)
    Memory.memory_set_byte(prk, 6, 50)
    Memory.memory_set_byte(prk, 7, 223)
    Memory.memory_set_byte(prk, 8, 13)
    Memory.memory_set_byte(prk, 9, 220)
    Memory.memory_set_byte(prk, 10, 63)
    Memory.memory_set_byte(prk, 11, 13)
    Memory.memory_set_byte(prk, 12, 196)
    Memory.memory_set_byte(prk, 13, 123)
    Memory.memory_set_byte(prk, 14, 186)
    Memory.memory_set_byte(prk, 15, 99)
    Memory.memory_set_byte(prk, 16, 144)
    Memory.memory_set_byte(prk, 17, 182)
    Memory.memory_set_byte(prk, 18, 199)
    Memory.memory_set_byte(prk, 19, 59)
    Memory.memory_set_byte(prk, 20, 181)
    Memory.memory_set_byte(prk, 21, 15)
    Memory.memory_set_byte(prk, 22, 156)
    Memory.memory_set_byte(prk, 23, 49)
    Memory.memory_set_byte(prk, 24, 34)
    Memory.memory_set_byte(prk, 25, 236)
    Memory.memory_set_byte(prk, 26, 132)
    Memory.memory_set_byte(prk, 27, 74)
