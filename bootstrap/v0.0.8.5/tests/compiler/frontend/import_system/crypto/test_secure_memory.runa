Note:
Unit tests for compiler/frontend/import_system/crypto/secure_memory.runa.

Exercises the constant-time comparison, branchless select, normalization,
and wipe primitives that the rest of the crypto stack depends on.

Test vector sources:
  - RFC 2104 (HMAC) Appendix A vectors are NOT in this file; see
    test_hmac for those. This file tests structural correctness of
    the secure_memory primitives only.
  - Coda Hale "A Lesson in Timing Attacks" (the canonical
    constant-time-compare correctness illustration).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/secure_memory.runa" as SM

Note: ============================================================================
Note: SECTION 1: secure_zero
Note: ============================================================================

Process called "test_secure_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "secure_memory.secure_zero")

    Let arena be Arena.arena_create(4096)
    T.assert_not_null(results, "arena created", arena)

    Let buf be Arena.arena_allocate(arena, 64)
    T.assert_not_null(results, "buffer allocated", buf)

    Note: Fill with non-zero pattern (0xAB)
    Let i be 0
    While i is less than 64:
        Memory.memory_set_byte(buf, i, 171)
        Set i to i plus 1
    End While

    Note: Wipe
    Let rc be SM.secure_zero(buf, 64)
    T.assert_equal(results, "wipe returns 1", rc, 1)

    Note: Verify every byte is zero
    Let all_zero be 1
    Let j be 0
    While j is less than 64:
        Let b be Memory.memory_get_byte(buf, j)
        If b is not equal to 0:
            Set all_zero to 0
        End If
        Set j to j plus 1
    End While
    T.assert_equal(results, "all bytes zeroed", all_zero, 1)

    Note: Edge case: zero length is success
    Let rc2 be SM.secure_zero(buf, 0)
    T.assert_equal(results, "zero length returns 1", rc2, 1)

    Note: Edge case: null pointer fails
    Let rc3 be SM.secure_zero(0, 32)
    T.assert_equal(results, "null pointer returns 0", rc3, 0)

    Note: Edge case: negative length fails
    Let rc4 be SM.secure_zero(buf, 0 minus 1)
    T.assert_equal(results, "negative length returns 0", rc4, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note: ============================================================================
Note: SECTION 2: constant_time_compare
Note: ============================================================================

Process called "test_ct_compare_equal" that takes results as Integer returns Integer:
    T.begin_suite(results, "secure_memory.constant_time_compare equal")

    Let arena be Arena.arena_create(4096)
    Let a be Arena.arena_allocate(arena, 32)
    Let b be Arena.arena_allocate(arena, 32)

    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(a, i, i)
        Memory.memory_set_byte(b, i, i)
        Set i to i plus 1
    End While

    Let eq be SM.constant_time_compare(a, b, 32)
    T.assert_equal(results, "identical buffers compare equal", eq, 1)

    Note: Self-compare is equal
    Let eq2 be SM.constant_time_compare(a, a, 32)
    T.assert_equal(results, "self-compare equal", eq2, 1)

    Note: Empty length is equal
    Let eq3 be SM.constant_time_compare(a, b, 0)
    T.assert_equal(results, "zero length equal", eq3, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_ct_compare_differ" that takes results as Integer returns Integer:
    T.begin_suite(results, "secure_memory.constant_time_compare differ")

    Let arena be Arena.arena_create(4096)
    Let a be Arena.arena_allocate(arena, 32)
    Let b be Arena.arena_allocate(arena, 32)

    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(a, i, i)
        Memory.memory_set_byte(b, i, i)
        Set i to i plus 1
    End While

    Note: Differ at first byte
    Memory.memory_set_byte(b, 0, 255)
    Let eq1 be SM.constant_time_compare(a, b, 32)
    T.assert_equal(results, "differ at first byte returns 0", eq1, 0)

    Note: Reset b, differ at last byte
    Memory.memory_set_byte(b, 0, 0)
    Memory.memory_set_byte(b, 31, 255)
    Let eq2 be SM.constant_time_compare(a, b, 32)
    T.assert_equal(results, "differ at last byte returns 0", eq2, 0)

    Note: Reset, differ in middle
    Memory.memory_set_byte(b, 31, 31)
    Memory.memory_set_byte(b, 16, 200)
    Let eq3 be SM.constant_time_compare(a, b, 32)
    T.assert_equal(results, "differ at middle returns 0", eq3, 0)

    Note: Null pointers return 0
    Let eq4 be SM.constant_time_compare(0, b, 32)
    T.assert_equal(results, "null a returns 0", eq4, 0)
    Let eq5 be SM.constant_time_compare(a, 0, 32)
    T.assert_equal(results, "null b returns 0", eq5, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note: ============================================================================
Note: SECTION 3: constant_time_select
Note: ============================================================================

Process called "test_ct_select" that takes results as Integer returns Integer:
    T.begin_suite(results, "secure_memory.constant_time_select")

    Note: select(1, a, b) = a
    Let r1 be SM.constant_time_select(1, 42, 17)
    T.assert_equal(results, "select(1, 42, 17) = 42", r1, 42)

    Note: select(0, a, b) = b
    Let r2 be SM.constant_time_select(0, 42, 17)
    T.assert_equal(results, "select(0, 42, 17) = 17", r2, 17)

    Note: With large values
    Let r3 be SM.constant_time_select(1, 1000000, 2000000)
    T.assert_equal(results, "select(1, large_a, large_b) = a", r3, 1000000)

    Let r4 be SM.constant_time_select(0, 1000000, 2000000)
    T.assert_equal(results, "select(0, large_a, large_b) = b", r4, 2000000)

    Note: Zero values
    Let r5 be SM.constant_time_select(1, 0, 99)
    T.assert_equal(results, "select(1, 0, 99) = 0", r5, 0)

    Let r6 be SM.constant_time_select(0, 99, 0)
    T.assert_equal(results, "select(0, 99, 0) = 0", r6, 0)
    Return 1
End Process

Process called "test_normalize_to_bool" that takes results as Integer returns Integer:
    T.begin_suite(results, "secure_memory.normalize_to_bool")

    T.assert_equal(results, "normalize(0) = 0", SM.normalize_to_bool(0), 0)
    T.assert_equal(results, "normalize(1) = 1", SM.normalize_to_bool(1), 1)
    T.assert_equal(results, "normalize(2) = 1", SM.normalize_to_bool(2), 1)
    T.assert_equal(results, "normalize(100) = 1", SM.normalize_to_bool(100), 1)
    T.assert_equal(results, "normalize(-1) = 1", SM.normalize_to_bool(0 minus 1), 1)
    T.assert_equal(results, "normalize(large) = 1", SM.normalize_to_bool(123456789), 1)
    Return 1
End Process

Note: ============================================================================
Note: SECTION 4: secure_zero_qwords (aligned fast path)
Note: ============================================================================

Process called "test_secure_zero_qwords" that takes results as Integer returns Integer:
    T.begin_suite(results, "secure_memory.secure_zero_qwords")

    Let arena be Arena.arena_create(4096)
    Let buf be Arena.arena_allocate(arena, 128)
    T.assert_not_null(results, "buffer allocated", buf)

    Note: Fill with 0xFF pattern in qwords
    Let i be 0
    While i is less than 16:
        Memory.memory_set_qword(buf, i multiplied by 8, 0 minus 1)
        Set i to i plus 1
    End While

    Let rc be SM.secure_zero_qwords(buf, 16)
    T.assert_equal(results, "qword wipe returns 1", rc, 1)

    Note: Verify
    Let all_zero be 1
    Let j be 0
    While j is less than 16:
        Let q be Memory.memory_get_qword(buf, j multiplied by 8)
        If q is not equal to 0:
            Set all_zero to 0
        End If
        Set j to j plus 1
    End While
    T.assert_equal(results, "all qwords zeroed", all_zero, 1)

    T.assert_equal(results, "null returns 0", SM.secure_zero_qwords(0, 1), 0)
    T.assert_equal(results, "negative returns 0", SM.secure_zero_qwords(buf, 0 minus 1), 0)
    T.assert_equal(results, "zero count returns 1", SM.secure_zero_qwords(buf, 0), 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_secure_zero(results)
    test_ct_compare_equal(results)
    test_ct_compare_differ(results)
    test_ct_select(results)
    test_normalize_to_bool(results)
    test_secure_zero_qwords(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
