Note:
Unit tests for compiler/frontend/import_system/crypto/curve_p256.runa.

Verifies:
- Generator point G is on the curve (FIPS 186-4 D.1.2.3 self-test).
- Public key validation accepts the generator and rejects infinity.
- Point doubling: 2*G is on the curve.
- Point addition: G + G == 2*G via independent doubling.
- Scalar multiplication 1*G == G and 0*G == infinity.
- SEC1 encoding/decoding round-trip for the generator (uncompressed,
  compressed, hybrid).
- Encoded compressed form preserves x-coordinate.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/bigint.runa" as BigInt
Import "compiler/frontend/import_system/crypto/curve_p256.runa" as P256
Import "compiler/frontend/import_system/crypto/field_p256.runa" as F256

Process called "test_curve_p256_generator_on_curve" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p256 generator on-curve self-test")
    Let arena be Arena.arena_create(1048576)
    Let gx be P256.curve_p256_gx(arena)
    Let gy be P256.curve_p256_gy(arena)
    Let on_curve be P256.curve_p256_is_on_curve_affine(arena, gx, gy)
    T.assert_equal(results, "G on curve", on_curve, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p256_validate_generator" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p256 validate generator")
    Let arena be Arena.arena_create(1048576)
    Let g be P256.curve_p256_generator(arena)
    T.assert_not_null(results, "generator allocated", g)
    Let valid be P256.curve_p256_validate_public_key(arena, g)
    T.assert_equal(results, "generator validates", valid, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p256_double_on_curve" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p256 doubling on-curve")
    Let arena be Arena.arena_create(1048576)
    Let g be P256.curve_p256_generator(arena)
    Let dbl be P256.curve_p256_point_alloc(arena)
    P256.curve_p256_double(arena, dbl, g)

    Let ax be F256.field_p256_zero(arena)
    Let ay be F256.field_p256_zero(arena)
    Let aff_rc be P256.curve_p256_to_affine(arena, dbl, ax, ay)
    T.assert_equal(results, "2*G converts to affine", aff_rc, 1)
    Let on_curve be P256.curve_p256_is_on_curve_affine(arena, ax, ay)
    T.assert_equal(results, "2*G is on curve", on_curve, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p256_scalar_mul_one" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p256 scalar mul 1*G == G")
    Let arena be Arena.arena_create(8388608)
    Let g be P256.curve_p256_generator(arena)
    Let one_scalar be BigInt.bigint_from_u64(arena, 1)
    Let result be P256.curve_p256_point_alloc(arena)
    P256.curve_p256_scalar_mul(arena, result, one_scalar, g)

    Let ax be F256.field_p256_zero(arena)
    Let ay be F256.field_p256_zero(arena)
    P256.curve_p256_to_affine(arena, result, ax, ay)
    Let gx be P256.curve_p256_gx(arena)
    Let gy be P256.curve_p256_gy(arena)
    Let x_eq be F256.field_p256_equal(ax, gx)
    Let y_eq be F256.field_p256_equal(ay, gy)
    T.assert_equal(results, "1*G x-coord matches Gx", x_eq, 1)
    T.assert_equal(results, "1*G y-coord matches Gy", y_eq, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p256_encode_decode_uncompressed" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p256 uncompressed encode/decode")
    Let arena be Arena.arena_create(1048576)
    Let g be P256.curve_p256_generator(arena)

    Let enc_buf be Arena.arena_allocate(arena, 65)
    Let enc_len be P256.curve_p256_encode_uncompressed(arena, g, enc_buf)
    T.assert_equal(results, "encoded length 65", enc_len, 65)
    Let tag_byte be Memory.memory_get_byte(enc_buf, 0)
    T.assert_equal(results, "encoded tag 0x04", tag_byte, 4)

    Let recovered be P256.curve_p256_point_alloc(arena)
    Let dec_rc be P256.curve_p256_decode_uncompressed(arena, enc_buf, 65, recovered)
    T.assert_equal(results, "decode succeeded", dec_rc, 1)

    Let ax be F256.field_p256_zero(arena)
    Let ay be F256.field_p256_zero(arena)
    P256.curve_p256_to_affine(arena, recovered, ax, ay)
    Let gx be P256.curve_p256_gx(arena)
    Let gy be P256.curve_p256_gy(arena)
    T.assert_equal(results, "recovered x = Gx", F256.field_p256_equal(ax, gx), 1)
    T.assert_equal(results, "recovered y = Gy", F256.field_p256_equal(ay, gy), 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p256_encode_compressed" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p256 compressed encode/decode")
    Let arena be Arena.arena_create(2097152)
    Let g be P256.curve_p256_generator(arena)

    Let enc_buf be Arena.arena_allocate(arena, 33)
    Let enc_len be P256.curve_p256_encode_compressed(arena, g, enc_buf)
    T.assert_equal(results, "encoded length 33", enc_len, 33)

    Note: G's y-coordinate is 4fe342e2..., low byte 0xf5 -> odd, so tag = 0x03.
    Let tag_byte be Memory.memory_get_byte(enc_buf, 0)
    T.assert_equal(results, "compressed tag is 0x03 (Gy odd)", tag_byte, 3)

    Let recovered be P256.curve_p256_point_alloc(arena)
    Let dec_rc be P256.curve_p256_decode_compressed(arena, enc_buf, 33, recovered)
    T.assert_equal(results, "compressed decode succeeded", dec_rc, 1)

    Let ax be F256.field_p256_zero(arena)
    Let ay be F256.field_p256_zero(arena)
    P256.curve_p256_to_affine(arena, recovered, ax, ay)
    Let gx be P256.curve_p256_gx(arena)
    Let gy be P256.curve_p256_gy(arena)
    T.assert_equal(results, "recovered x = Gx", F256.field_p256_equal(ax, gx), 1)
    T.assert_equal(results, "recovered y = Gy", F256.field_p256_equal(ay, gy), 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_curve_p256_validate_rejects_infinity" that takes results as Integer returns Integer:
    T.begin_suite(results, "curve_p256 validate rejects infinity")
    Let arena be Arena.arena_create(1048576)
    Let pt be P256.curve_p256_point_alloc(arena)
    P256.curve_p256_point_set_infinity(pt)
    Let valid be P256.curve_p256_validate_public_key(arena, pt)
    T.assert_equal(results, "infinity rejected", valid, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_curve_p256_generator_on_curve(results)
    test_curve_p256_validate_generator(results)
    test_curve_p256_double_on_curve(results)
    test_curve_p256_scalar_mul_one(results)
    test_curve_p256_encode_decode_uncompressed(results)
    test_curve_p256_encode_compressed(results)
    test_curve_p256_validate_rejects_infinity(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
