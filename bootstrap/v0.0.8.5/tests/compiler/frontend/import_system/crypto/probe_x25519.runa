    Memory.memory_set_byte(bin, 14, 53)
    Memory.memory_set_byte(bin, 15, 55)
    Memory.memory_set_byte(bin, 16, 63)
    Memory.memory_set_byte(bin, 17, 131)
    Memory.memory_set_byte(bin, 18, 67)
    Memory.memory_set_byte(bin, 19, 200)
    Memory.memory_set_byte(bin, 20, 91)
    Memory.memory_set_byte(bin, 21, 120)
    Memory.memory_set_byte(bin, 22, 103)
    Memory.memory_set_byte(bin, 23, 74)
    Memory.memory_set_byte(bin, 24, 218)
    Memory.memory_set_byte(bin, 25, 223)
    Memory.memory_set_byte(bin, 26, 199)
    Memory.memory_set_byte(bin, 27, 225)
    Memory.memory_set_byte(bin, 28, 70)
    Memory.memory_set_byte(bin, 29, 248)
    Memory.memory_set_byte(bin, 30, 130)
    Memory.memory_set_byte(bin, 31, 79)
    Fe.fe25519_unpack(fe, bin)
    Fe.fe25519_pack(fe, bout)
    Let mismatch be 0
    Let k be 0
    While k is less than 32:
        Let bi be Memory.memory_get_byte(bin, k)
        Let bo be Memory.memory_get_byte(bout, k)
        If bi is not equal to bo:
            Set mismatch to mismatch plus 1
        End If
        Set k to k plus 1
    End While
    proc print_string with "unpack/pack mismatches="
    proc print_integer with mismatch
    proc print_string with "\n"
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_dh_symmetry" returns Integer:
    Note: A*B*G == B*A*G should hold (DH symmetry).
    Let arena be Arena.arena_create(4194304)

    Let A_priv be Arena.arena_allocate(arena, 32)
    Let B_priv be Arena.arena_allocate(arena, 32)
    Let base_G be Arena.arena_allocate(arena, 32)
    Let A_pub be Arena.arena_allocate(arena, 32)
    Let B_pub be Arena.arena_allocate(arena, 32)
    Let A_then_B be Arena.arena_allocate(arena, 32)
    Let B_then_A be Arena.arena_allocate(arena, 32)

    Note: zero everything
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(A_priv, i, 0)
        Memory.memory_set_byte(B_priv, i, 0)
        Memory.memory_set_byte(base_G, i, 0)
        Set i to i plus 1
    End While

    Note: A_priv = 16 (will be clamped to 16, since 16 & 248 = 16, bit 254 set)
    Memory.memory_set_byte(A_priv, 0, 16)
    Memory.memory_set_byte(A_priv, 31, 64)
    Note: B_priv = 24 (will be clamped to 24, since 24 & 248 = 24)
    Memory.memory_set_byte(B_priv, 0, 24)
    Memory.memory_set_byte(B_priv, 31, 64)
    Note: base_G u=9
    Memory.memory_set_byte(base_G, 0, 9)

    X.x25519_scalarmult(arena, A_priv, base_G, A_pub)
    X.x25519_scalarmult(arena, B_priv, base_G, B_pub)
    X.x25519_scalarmult(arena, A_priv, B_pub, A_then_B)
    X.x25519_scalarmult(arena, B_priv, A_pub, B_then_A)

    Note: A_then_B should equal B_then_A
    Let k be 0
    Let mismatch be 0
    While k is less than 32:
        Let ab be Memory.memory_get_byte(A_then_B, k)
        Let ba be Memory.memory_get_byte(B_then_A, k)
        If ab is not equal to ba:
            Set mismatch to mismatch plus 1
        End If
        Set k to k plus 1
    End While
    proc print_string with "DH symmetry mismatches="
    proc print_integer with mismatch
    proc print_string with " A_pub[0]="
    Let ap0 be Memory.memory_get_byte(A_pub, 0)
    proc print_integer with ap0
    proc print_string with " A_then_B[0]="
    Let atb0 be Memory.memory_get_byte(A_then_B, 0)
    proc print_integer with atb0
    proc print_string with " B_then_A[0]="
    Let bta0 be Memory.memory_get_byte(B_then_A, 0)
    proc print_integer with bta0
    proc print_string with "\n"
    Arena.arena_destroy(arena)
    Return 1
End Process

