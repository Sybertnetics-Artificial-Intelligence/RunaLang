Note: probe test - isolate x25519 ladder bug

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/x25519.runa" as X
Import "compiler/frontend/import_system/crypto/field25519.runa" as Fe

Process called "test_inv_of_2" returns Integer:
    Note: inv(2) should be (p+1)/2 = 2^254 - 9 = 0x3FFFFFFF...F7 little-endian
    Let arena be Arena.arena_create(1048576)
    Let two_fe be Fe.fe25519_alloc(arena)
    Let inv_fe be Fe.fe25519_alloc(arena)
    Let prod_fe be Fe.fe25519_alloc(arena)
    Memory.memory_set_qword(two_fe, 0, 2)
    Fe.fe25519_inv(arena, inv_fe, two_fe)
    Fe.fe25519_mul(prod_fe, two_fe, inv_fe)
    Fe.fe25519_freeze(prod_fe)
    Let bytes_out be Arena.arena_allocate(arena, 32)
    Fe.fe25519_pack(prod_fe, bytes_out)
    Let b0 be Memory.memory_get_byte(bytes_out, 0)
    Let b1 be Memory.memory_get_byte(bytes_out, 1)
    Let b31 be Memory.memory_get_byte(bytes_out, 31)
    Note: print "inv(2)*2 = "
    proc print_string with "inv(2)*2 b0="
    proc print_integer with b0
    proc print_string with " b1="
    proc print_integer with b1
    proc print_string with " b31="
    proc print_integer with b31
    proc print_string with "\n"
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_inv_of_9" returns Integer:
    Let arena be Arena.arena_create(1048576)
    Let nine_fe be Fe.fe25519_alloc(arena)
    Let inv_fe be Fe.fe25519_alloc(arena)
    Let prod_fe be Fe.fe25519_alloc(arena)
    Memory.memory_set_qword(nine_fe, 0, 9)
    Fe.fe25519_inv(arena, inv_fe, nine_fe)
    Fe.fe25519_mul(prod_fe, nine_fe, inv_fe)
    Fe.fe25519_freeze(prod_fe)
    Let bytes_out be Arena.arena_allocate(arena, 32)
    Fe.fe25519_pack(prod_fe, bytes_out)
    Let b0 be Memory.memory_get_byte(bytes_out, 0)
    Let b31 be Memory.memory_get_byte(bytes_out, 31)
    proc print_string with "inv(9)*9 b0="
    proc print_integer with b0
    proc print_string with " b31="
    proc print_integer with b31
    proc print_string with "\n"
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_simple_ladder" returns Integer:
    Note: Use scalar=8 (smallest valid clamped scalar), base=9
    Let arena be Arena.arena_create(2097152)
    Let scalar be Arena.arena_allocate(arena, 32)
    Let i be 0
    While i is less than 32:
        Memory.memory_set_byte(scalar, i, 0)
        Set i to i plus 1
    End While
    Memory.memory_set_byte(scalar, 0, 8)
    Memory.memory_set_byte(scalar, 31, 64)

    Let base be Arena.arena_allocate(arena, 32)
    Let i2 be 0
    While i2 is less than 32:
        Memory.memory_set_byte(base, i2, 0)
        Set i2 to i2 plus 1
    End While
    Memory.memory_set_byte(base, 0, 9)

    Let out be Arena.arena_allocate(arena, 32)
    X.x25519_scalarmult(arena, scalar, base, out)
    Let o0 be Memory.memory_get_byte(out, 0)
    Let o1 be Memory.memory_get_byte(out, 1)
    Let o31 be Memory.memory_get_byte(out, 31)
    proc print_string with "scalar=8(clamped) base=9 -> b0="
    proc print_integer with o0
    proc print_string with " b1="
    proc print_integer with o1
    proc print_string with " b31="
    proc print_integer with o31
    proc print_string with "\n"
    Arena.arena_destroy(arena)
    Return 1
End Process

