Note:
Structural tests for SLH-DSA (FIPS 205).

Tests:
  1. Parameter accessors per FIPS 205 Table 2 for all six SHA-2 parameter sets.
  2. Key sizes per FIPS 205 Table 2.
  3. ADRS helpers produce expected byte layout per FIPS 205 sec 4.2.1.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/pq/slh_dsa.runa" as SLH

Process called "test_param_accessors" that takes results as Integer returns Integer:
    T.begin_suite(results, "slh_dsa: parameter accessors")
    T.assert_equal(results, "128s n=16", SLH.slhdsa_n(1), 16)
    T.assert_equal(results, "128s h=63", SLH.slhdsa_h(1), 63)
    T.assert_equal(results, "128s d=7", SLH.slhdsa_d(1), 7)
    T.assert_equal(results, "128s a=12", SLH.slhdsa_a(1), 12)
    T.assert_equal(results, "128s k=14", SLH.slhdsa_k(1), 14)
    T.assert_equal(results, "128s pk=32", SLH.slhdsa_pk_size(1), 32)
    T.assert_equal(results, "128s sk=64", SLH.slhdsa_sk_size(1), 64)

    T.assert_equal(results, "128f n=16", SLH.slhdsa_n(2), 16)
    T.assert_equal(results, "128f h=66", SLH.slhdsa_h(2), 66)
    T.assert_equal(results, "128f d=22", SLH.slhdsa_d(2), 22)
    T.assert_equal(results, "128f a=6", SLH.slhdsa_a(2), 6)
    T.assert_equal(results, "128f k=33", SLH.slhdsa_k(2), 33)

    T.assert_equal(results, "192s n=24", SLH.slhdsa_n(3), 24)
    T.assert_equal(results, "192s h=63", SLH.slhdsa_h(3), 63)

    T.assert_equal(results, "256s n=32", SLH.slhdsa_n(5), 32)
    T.assert_equal(results, "256s h=64", SLH.slhdsa_h(5), 64)
    T.assert_equal(results, "256s d=8", SLH.slhdsa_d(5), 8)

    T.assert_equal(results, "256f n=32", SLH.slhdsa_n(6), 32)
    T.assert_equal(results, "256f h=68", SLH.slhdsa_h(6), 68)
    T.assert_equal(results, "256f d=17", SLH.slhdsa_d(6), 17)

    T.assert_equal(results, "lg_w=4", SLH.slhdsa_lg_w(), 4)
    T.assert_equal(results, "w=16", SLH.slhdsa_w(), 16)

    T.assert_equal(results, "128s len1=32", SLH.slhdsa_len1(1), 32)
    T.assert_equal(results, "192s len1=48", SLH.slhdsa_len1(3), 48)
    T.assert_equal(results, "256s len1=64", SLH.slhdsa_len1(5), 64)
    T.assert_equal(results, "len2=3", SLH.slhdsa_len2(), 3)
    Return 1
End Process

Process called "test_adrs_layout" that takes results as Integer returns Integer:
    T.begin_suite(results, "slh_dsa: ADRS layout")
    Let arena be Arena.arena_create(1024)
    Let adrs be Arena.arena_allocate(arena, 32)
    SLH.slhdsa_adrs_zero(adrs)
    SLH.slhdsa_adrs_set_layer(adrs, 5)
    Let b3 be Memory.memory_get_byte(adrs, 3)
    T.assert_equal(results, "ADRS layer byte 3 == 5", b3, 5)

    SLH.slhdsa_adrs_set_type_and_clear(adrs, 3)
    Let b12 be Memory.memory_get_byte(adrs, 12)
    T.assert_equal(results, "ADRS type byte 12 == 3", b12, 3)

    SLH.slhdsa_adrs_set_keypair(adrs, 7)
    Let b23 be Memory.memory_get_byte(adrs, 23)
    T.assert_equal(results, "ADRS keypair byte 23 == 7", b23, 7)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_param_accessors(results)
    test_adrs_layout(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
