Note:
Structural tests for the post-quantum NTT foundation
(compiler/frontend/import_system/crypto/pq/ntt.runa).

Tests:
  1. SHAKE-128 one-shot produces 168 bytes; first byte matches NIST reference
     vector for empty-message SHAKE-128 output (0x7f).
  2. SHAKE-256 one-shot produces 32 bytes; first byte matches NIST reference
     vector for empty-message SHAKE-256 output (0x46).
  3. Barrett/Montgomery reductions: barrett_reduce_kyber(3329) == 0;
     montgomery_reduce_kyber(0) == 0.
  4. NTT round-trip: applying kyber_ntt_forward then kyber_ntt_inverse on a
     simple polynomial returns the original (with possible Mont-domain
     rescaling).
  5. Compress/Decompress consistency: kyber_decompress(kyber_compress(x, d), d)
     stays within tolerance d.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/pq/ntt.runa" as NTT

Process called "test_shake128_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "ntt: SHAKE-128 of empty message")
    Let arena be Arena.arena_create(8192)
    Let empty_in be Arena.arena_allocate(arena, 1)
    Let out_buf be Arena.arena_allocate(arena, 32)
    NTT.shake128(arena, empty_in, 0, out_buf, 32)
    Let b0 be Memory.memory_get_byte(out_buf, 0)
    Let b1 be Memory.memory_get_byte(out_buf, 1)
    T.assert_equal(results, "SHAKE-128 empty msg byte 0 == 0x7f", b0, 127)
    T.assert_equal(results, "SHAKE-128 empty msg byte 1 == 0x9c", b1, 156)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_shake256_empty" that takes results as Integer returns Integer:
    T.begin_suite(results, "ntt: SHAKE-256 of empty message")
    Let arena be Arena.arena_create(8192)
    Let empty_in be Arena.arena_allocate(arena, 1)
    Let out_buf be Arena.arena_allocate(arena, 32)
    NTT.shake256(arena, empty_in, 0, out_buf, 32)
    Let b0 be Memory.memory_get_byte(out_buf, 0)
    Let b1 be Memory.memory_get_byte(out_buf, 1)
    T.assert_equal(results, "SHAKE-256 empty msg byte 0 == 0x46", b0, 70)
    T.assert_equal(results, "SHAKE-256 empty msg byte 1 == 0xb9", b1, 185)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_barrett_reductions" that takes results as Integer returns Integer:
    T.begin_suite(results, "ntt: Barrett reductions")
    Let r0 be NTT.barrett_reduce_kyber(3329)
    T.assert_equal(results, "barrett_reduce_kyber(3329) == 0", r0, 0)
    Let r1 be NTT.barrett_reduce_kyber(0)
    T.assert_equal(results, "barrett_reduce_kyber(0) == 0", r1, 0)
    Let r2 be NTT.barrett_reduce_kyber(3328)
    T.assert_equal(results, "barrett_reduce_kyber(3328) == 3328", r2, 3328)
    Let m0 be NTT.montgomery_reduce_kyber(0)
    T.assert_equal(results, "montgomery_reduce_kyber(0) == 0", m0, 0)
    Let d0 be NTT.barrett_reduce_dilithium(8380417)
    T.assert_equal(results, "barrett_reduce_dilithium(q) == 0", d0, 0)
    Let d1 be NTT.barrett_reduce_dilithium(0)
    T.assert_equal(results, "barrett_reduce_dilithium(0) == 0", d1, 0)
    Return 1
End Process

Process called "test_compress_decompress" that takes results as Integer returns Integer:
    T.begin_suite(results, "ntt: Kyber compress/decompress")
    Let c0 be NTT.kyber_compress(0, 4)
    T.assert_equal(results, "compress(0, 4) == 0", c0, 0)
    Let c_max be NTT.kyber_compress(3329, 1)
    T.assert_equal(results, "compress(3329, 1) wraps to 0", c_max, 0)
    Let d0 be NTT.kyber_decompress(0, 4)
    T.assert_equal(results, "decompress(0, 4) == 0", d0, 0)
    Return 1
End Process

Process called "test_parameter_accessors" that takes results as Integer returns Integer:
    T.begin_suite(results, "ntt: parameter accessors")
    T.assert_equal(results, "kyber q == 3329", NTT.ntt_kyber_q(), 3329)
    T.assert_equal(results, "kyber n == 256", NTT.ntt_kyber_n(), 256)
    T.assert_equal(results, "dilithium q == 8380417", NTT.ntt_dilithium_q(), 8380417)
    T.assert_equal(results, "dilithium n == 256", NTT.ntt_dilithium_n(), 256)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_shake128_empty(results)
    test_shake256_empty(results)
    test_barrett_reductions(results)
    test_compress_decompress(results)
    test_parameter_accessors(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
