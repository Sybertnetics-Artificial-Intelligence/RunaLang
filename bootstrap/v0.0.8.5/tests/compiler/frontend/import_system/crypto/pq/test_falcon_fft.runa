Note:
Tests for falcon_fft.runa complex Float64 FFT over Z[X]/(X^n+1).

Test 1: FFT n=4 round-trip
  - Input: polynomial f(X) = 1 + 2X + 3X^2 + 4X^3 in coefficient form
  - Forward FFT, then inverse FFT, must recover the original coefficients
    to within 1e-3 absolute tolerance per coefficient.

Test 2: FFT n=8 round-trip
  - Polynomial of degree 7 with diverse coefficients, same round-trip
    invariant.

Test 3: Pointwise multiplication identity
  - Polynomial f(X) = X + 1, polynomial g(X) = 1 (constant), their product
    must equal f in coefficient form after FFT/iFFT through fft_mul_pointwise.

Test 4: Polynomial multiplication via FFT round-trip (n=4)
  - Multiply f(X) = 1 + X by g(X) = 1 + X in Z[X]/(X^4+1). Expected:
    (1+X)*(1+X) = 1 + 2X + X^2 (degree 2, well below n=4 anti-cyclic wrap).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/pq/falcon_fp.runa" as FP
Import "compiler/frontend/import_system/crypto/pq/falcon_fft.runa" as FFT

Process called "abs_diff_under_tol" that takes a as Float, b as Float, tol_int as Integer returns Integer:
    Note: Returns 1 if |a - b| * 1e3 < tol_int (treating tol_int as the
    Note: integer count of 1e-3 units we allow).
    Let diff be FP.fp_sub(a, b)
    Let abs_d be FP.fp_abs(diff)
    Let scale be FP.fp_from_int(1000)
    Let scaled be FP.fp_mul(abs_d, scale)
    Let v be FP.fp_to_int_round(scaled)
    If v is less than tol_int:
        Return 1
    End If
    Return 0
End Process

Process called "test_fft_roundtrip_n4" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: FFT n=4 round-trip")
    Let arena be Arena.arena_create(16384)
    Let buf be Arena.arena_allocate(arena, 64)
    Note: Load [1, 2, 3, 4] as real coefficients, zero imag.
    FFT.fft_zero(buf, 4)
    Let v1 be FP.fp_from_int(1)
    Let v2 be FP.fp_from_int(2)
    Let v3 be FP.fp_from_int(3)
    Let v4 be FP.fp_from_int(4)
    FFT.fft_set_real(buf, 0, v1)
    FFT.fft_set_real(buf, 1, v2)
    FFT.fft_set_real(buf, 2, v3)
    FFT.fft_set_real(buf, 3, v4)
    FFT.fft_forward(arena, buf, 4)
    FFT.fft_inverse(arena, buf, 4)
    Let r0 be FFT.fft_get_real(buf, 0)
    Let r1 be FFT.fft_get_real(buf, 1)
    Let r2 be FFT.fft_get_real(buf, 2)
    Let r3 be FFT.fft_get_real(buf, 3)
    T.assert_equal(results, "round-trip r0 ~= 1", abs_diff_under_tol(r0, v1, 2), 1)
    T.assert_equal(results, "round-trip r1 ~= 2", abs_diff_under_tol(r1, v2, 2), 1)
    T.assert_equal(results, "round-trip r2 ~= 3", abs_diff_under_tol(r2, v3, 2), 1)
    T.assert_equal(results, "round-trip r3 ~= 4", abs_diff_under_tol(r3, v4, 2), 1)
    Let i0 be FFT.fft_get_imag(buf, 0)
    Let i1 be FFT.fft_get_imag(buf, 1)
    Let i2 be FFT.fft_get_imag(buf, 2)
    Let i3 be FFT.fft_get_imag(buf, 3)
    Let zero_v be FP.fp_zero()
    T.assert_equal(results, "round-trip i0 ~= 0", abs_diff_under_tol(i0, zero_v, 2), 1)
    T.assert_equal(results, "round-trip i1 ~= 0", abs_diff_under_tol(i1, zero_v, 2), 1)
    T.assert_equal(results, "round-trip i2 ~= 0", abs_diff_under_tol(i2, zero_v, 2), 1)
    T.assert_equal(results, "round-trip i3 ~= 0", abs_diff_under_tol(i3, zero_v, 2), 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_fft_roundtrip_n8" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: FFT n=8 round-trip")
    Let arena be Arena.arena_create(32768)
    Let buf be Arena.arena_allocate(arena, 128)
    FFT.fft_zero(buf, 8)
    Let i be 0
    While i is less than 8:
        Let v_int be i plus 1
        Let v_f be FP.fp_from_int(v_int)
        FFT.fft_set_real(buf, i, v_f)
        Set i to i plus 1
    End While
    FFT.fft_forward(arena, buf, 8)
    FFT.fft_inverse(arena, buf, 8)
    Let k be 0
    Let passed be 1
    While k is less than 8:
        Let expected_int be k plus 1
        Let expected_f be FP.fp_from_int(expected_int)
        Let actual be FFT.fft_get_real(buf, k)
        Let ok be abs_diff_under_tol(actual, expected_f, 3)
        If ok is not equal to 1:
            Set passed to 0
        End If
        Set k to k plus 1
    End While
    T.assert_equal(results, "n=8 round-trip all 8 coeffs ~= input", passed, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_fft_multiply_identity" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: pointwise multiply by 1 (n=4)")
    Let arena be Arena.arena_create(32768)
    Note: Two int16 polynomials, multiplied via FFT round-trip.
    Note: f = [3, 1, 0, 0] (3 + X), g = [1, 0, 0, 0] (constant 1).
    Note: Product f*g = f = [3, 1, 0, 0].
    Let f_int be Arena.arena_allocate(arena, 8)
    Let g_int be Arena.arena_allocate(arena, 8)
    Let c_int be Arena.arena_allocate(arena, 8)
    Memory.memory_set_int16(f_int, 0, 3)
    Memory.memory_set_int16(f_int, 2, 1)
    Memory.memory_set_int16(f_int, 4, 0)
    Memory.memory_set_int16(f_int, 6, 0)
    Memory.memory_set_int16(g_int, 0, 1)
    Memory.memory_set_int16(g_int, 2, 0)
    Memory.memory_set_int16(g_int, 4, 0)
    Memory.memory_set_int16(g_int, 6, 0)
    FFT.fft_poly_multiply_int_via_fft(arena, f_int, g_int, c_int, 4)
    Let c0 be Memory.memory_get_int16(c_int, 0)
    Let c1 be Memory.memory_get_int16(c_int, 2)
    Let c2 be Memory.memory_get_int16(c_int, 4)
    Let c3 be Memory.memory_get_int16(c_int, 6)
    T.assert_equal(results, "f*1 coef0 == 3", c0, 3)
    T.assert_equal(results, "f*1 coef1 == 1", c1, 1)
    T.assert_equal(results, "f*1 coef2 == 0", c2, 0)
    T.assert_equal(results, "f*1 coef3 == 0", c3, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_fft_multiply_general" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: (1+X)*(1+X) (n=4)")
    Let arena be Arena.arena_create(32768)
    Note: f = [1, 1, 0, 0] (1 + X). g = [1, 1, 0, 0] (1 + X).
    Note: Product in Z[X]/(X^4+1) = 1 + 2X + X^2 (no wrap since deg < 4).
    Note: Expected output = [1, 2, 1, 0].
    Let f_int be Arena.arena_allocate(arena, 8)
    Let g_int be Arena.arena_allocate(arena, 8)
    Let c_int be Arena.arena_allocate(arena, 8)
    Memory.memory_set_int16(f_int, 0, 1)
    Memory.memory_set_int16(f_int, 2, 1)
    Memory.memory_set_int16(f_int, 4, 0)
    Memory.memory_set_int16(f_int, 6, 0)
    Memory.memory_set_int16(g_int, 0, 1)
    Memory.memory_set_int16(g_int, 2, 1)
    Memory.memory_set_int16(g_int, 4, 0)
    Memory.memory_set_int16(g_int, 6, 0)
    FFT.fft_poly_multiply_int_via_fft(arena, f_int, g_int, c_int, 4)
    Let c0 be Memory.memory_get_int16(c_int, 0)
    Let c1 be Memory.memory_get_int16(c_int, 2)
    Let c2 be Memory.memory_get_int16(c_int, 4)
    Let c3 be Memory.memory_get_int16(c_int, 6)
    T.assert_equal(results, "(1+X)^2 coef0 == 1", c0, 1)
    T.assert_equal(results, "(1+X)^2 coef1 == 2", c1, 2)
    T.assert_equal(results, "(1+X)^2 coef2 == 1", c2, 1)
    T.assert_equal(results, "(1+X)^2 coef3 == 0", c3, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_fft_multiply_anticyclic_wrap" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: anti-cyclic wrap X^4 = -1 (n=4)")
    Let arena be Arena.arena_create(32768)
    Note: f = X^3 = [0, 0, 0, 1]. g = X = [0, 1, 0, 0].
    Note: In Z[X]/(X^4+1): X^3 * X = X^4 = -1. Expected = [-1, 0, 0, 0].
    Let f_int be Arena.arena_allocate(arena, 8)
    Let g_int be Arena.arena_allocate(arena, 8)
    Let c_int be Arena.arena_allocate(arena, 8)
    Memory.memory_set_int16(f_int, 0, 0)
    Memory.memory_set_int16(f_int, 2, 0)
    Memory.memory_set_int16(f_int, 4, 0)
    Memory.memory_set_int16(f_int, 6, 1)
    Memory.memory_set_int16(g_int, 0, 0)
    Memory.memory_set_int16(g_int, 2, 1)
    Memory.memory_set_int16(g_int, 4, 0)
    Memory.memory_set_int16(g_int, 6, 0)
    FFT.fft_poly_multiply_int_via_fft(arena, f_int, g_int, c_int, 4)
    Let c0 be Memory.memory_get_int16(c_int, 0)
    Let c1 be Memory.memory_get_int16(c_int, 2)
    Let c2 be Memory.memory_get_int16(c_int, 4)
    Let c3 be Memory.memory_get_int16(c_int, 6)
    Let neg_one be 0 minus 1
    T.assert_equal(results, "X^3 * X coef0 == -1", c0, neg_one)
    T.assert_equal(results, "X^3 * X coef1 == 0", c1, 0)
    T.assert_equal(results, "X^3 * X coef2 == 0", c2, 0)
    T.assert_equal(results, "X^3 * X coef3 == 0", c3, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_fft_roundtrip_n4(results)
    test_fft_roundtrip_n8(results)
    test_fft_multiply_identity(results)
    test_fft_multiply_general(results)
    test_fft_multiply_anticyclic_wrap(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
