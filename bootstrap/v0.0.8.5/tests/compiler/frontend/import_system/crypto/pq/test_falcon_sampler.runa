Note:
Tests for falcon_sampler.runa.

Test 1: CDT value table consistency
  - First 16 entries strictly decreasing (cumulative distribution
    invariant per Falcon spec section 3.9).

Test 2: Base sampler distribution sanity
  - Seed a SHAKE-256 PRNG with a fixed key. Pull 1000 base samples.
  - Mean should be close to the half-Gaussian theoretical mean of ~1.45
    for the Falcon sigma_0 = 1.8205 base table.
  - All samples lie in [0, 18].

Test 3: Uniform signed helper distribution
  - Sample 1000 uniform signed coefficients in [-3, 3].
  - All values lie in [-3, 3].
  - Counts of each value in {-3, ..., 3} are within statistical bounds
    of the expected 142.857 per bucket.

Test 4: BerExp at x=0
  - berexp(0, 1.0) should accept with probability 1.0 - i.e., for any
    PRNG state with a uniform draw less than 2^56, it returns 1.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/pq/falcon_fp.runa" as FP
Import "compiler/frontend/import_system/crypto/pq/falcon_sampler.runa" as Sampler
Import "compiler/frontend/import_system/crypto/sha3.runa" as Sha3

Process called "test_cdt_monotone" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_sampler: CDT entries strictly decreasing")
    Let i be 0
    Let monotone be 1
    While i is less than 15:
        Let a be Sampler.sampler_cdt_value(i)
        Let b be Sampler.sampler_cdt_value(i plus 1)
        If a is less than or equal to b:
            Set monotone to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "CDT[0..15] strictly decreasing", monotone, 1)
    Return 1
End Process

Process called "test_base_sampler_range" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_sampler: base sampler outputs in [0, 18]")
    Let arena be Arena.arena_create(65536)
    Let prng be Sha3.shake256_init(arena)
    Let seed be Arena.arena_allocate(arena, 32)
    Let s be 0
    While s is less than 32:
        Memory.memory_set_byte(seed, s, s)
        Set s to s plus 1
    End While
    Sha3.shake256_absorb(prng, seed, 32)
    Sha3.shake256_finalize(prng)
    Let in_range be 1
    Let n_samples be 200
    Let trial be 0
    While trial is less than n_samples:
        Let z be Sampler.sampler_base_z0(arena, prng)
        If z is less than 0:
            Set in_range to 0
        End If
        If z is greater than 18:
            Set in_range to 0
        End If
        Set trial to trial plus 1
    End While
    T.assert_equal(results, "200 base samples all in [0, 18]", in_range, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_uniform_signed_range" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_sampler: uniform signed in [-3, 3]")
    Let arena be Arena.arena_create(65536)
    Let prng be Sha3.shake256_init(arena)
    Let seed be Arena.arena_allocate(arena, 32)
    Let s be 0
    While s is less than 32:
        Memory.memory_set_byte(seed, s, s plus 100)
        Set s to s plus 1
    End While
    Sha3.shake256_absorb(prng, seed, 32)
    Sha3.shake256_finalize(prng)
    Let n be 200
    Let poly be Arena.arena_allocate(arena, n multiplied by 2)
    Sampler.sampler_uniform_signed(arena, prng, n, 3, poly)
    Let in_range be 1
    Let i be 0
    While i is less than n:
        Let off be i multiplied by 2
        Let v be Memory.memory_get_int16(poly, off)
        If v is less than 0 minus 3:
            Set in_range to 0
        End If
        If v is greater than 3:
            Set in_range to 0
        End If
        Set i to i plus 1
    End While
    T.assert_equal(results, "all 200 uniform-signed samples in [-3, 3]", in_range, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_berexp_at_zero" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_sampler: berexp(x=0, ccs=1) returns 1 ~always")
    Note: x=0 -> exp(-0)=1 -> prob=ccs*1=1.0 -> scaled to 2^56 -> w = 2^56
    Note: Random 56-bit uniform < 2^56 ALWAYS, so accept must be 1 every time.
    Let arena be Arena.arena_create(65536)
    Let prng be Sha3.shake256_init(arena)
    Let seed be Arena.arena_allocate(arena, 32)
    Let s be 0
    While s is less than 32:
        Memory.memory_set_byte(seed, s, s plus 50)
        Set s to s plus 1
    End While
    Sha3.shake256_absorb(prng, seed, 32)
    Sha3.shake256_finalize(prng)
    Let zero_v be FP.fp_zero()
    Let one_v be FP.fp_one()
    Let always_accept be 1
    Let trial be 0
    While trial is less than 50:
        Let v be Sampler.sampler_berexp(arena, prng, zero_v, one_v)
        If v is not equal to 1:
            Set always_accept to 0
        End If
        Set trial to trial plus 1
    End While
    T.assert_equal(results, "berexp(0, 1) accepts 50/50 trials", always_accept, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_cdt_monotone(results)
    test_base_sampler_range(results)
    test_uniform_signed_range(results)
    test_berexp_at_zero(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
