Note:
Tests for falcon_fp.runa hardware Float64 primitives.

Each test uses bit-exact comparison against the IEEE 754 binary64
encoding of the expected result. Bit patterns are computed offline:

  1.0       = 0x3FF0000000000000 = 4607182418800017408
  2.0       = 0x4000000000000000 = 4611686018427387904
  3.0       = 0x4008000000000000 = 4613937818241073152
  4.0       = 0x4010000000000000 = 4616189618054758400
  5.0       = 0x4014000000000000 = 4617315517961601024
  6.0       = 0x4018000000000000 = 4618441417868443648
  1.5       = 0x3FF8000000000000 = 4609434218613702656
  2.5       = 0x4004000000000000 = 4612811918334230528
  0.5       = 0x3FE0000000000000 = 4602678819172646912
  0.0       = 0                  = 0
  pi        = 0x400921FB54442D18 = 4614256656552045848
  -1.0      = bits sign-flipped from 1.0 (test computes via fp_neg)

Algorithmic tests:
  - fp_cos(0)  ~= 1.0     (within Taylor remainder ~2^-50)
  - fp_sin(0) ~= 0.0
  - fp_cos(pi) ~= -1.0
  - fp_exp(0)  == 1.0     (special case, exact)

For approximate Float comparisons we test bit-equality of the integer
truncation: floor(result * 2^k) for a chosen k = 40 (1e-12 tolerance).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/frontend/import_system/crypto/pq/falcon_fp.runa" as FP

Process called "test_field_ops" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fp: field operations")
    Let r1 be FP.fp_add(4609434218613702656, 4612811918334230528)
    T.assert_equal(results, "fp_add(1.5, 2.5) == 4.0", r1, 4616189618054758400)

    Let r2 be FP.fp_mul(4611686018427387904, 4613937818241073152)
    T.assert_equal(results, "fp_mul(2.0, 3.0) == 6.0", r2, 4618441417868443648)

    Let r3 be FP.fp_sub(4616189618054758400, 4611686018427387904)
    T.assert_equal(results, "fp_sub(4.0, 2.0) == 2.0", r3, 4611686018427387904)

    Let r4 be FP.fp_div(4618441417868443648, 4613937818241073152)
    T.assert_equal(results, "fp_div(6.0, 3.0) == 2.0", r4, 4611686018427387904)
    Return 1
End Process

Process called "test_sqrt" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fp: sqrt")
    Let r1 be FP.fp_sqrt(4616189618054758400)
    T.assert_equal(results, "fp_sqrt(4.0) == 2.0", r1, 4611686018427387904)

    Note: sqrt(16) = 4.0, 16.0 bits = 0x4030000000000000 = 4624633867356078080
    Let r2 be FP.fp_sqrt(4624633867356078080)
    T.assert_equal(results, "fp_sqrt(16.0) == 4.0", r2, 4616189618054758400)

    Note: sqrt(1.0) = 1.0
    Let r3 be FP.fp_sqrt(4607182418800017408)
    T.assert_equal(results, "fp_sqrt(1.0) == 1.0", r3, 4607182418800017408)
    Return 1
End Process

Process called "test_conversions" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fp: integer / float conversions")
    Let f5 be FP.fp_from_int(5)
    T.assert_equal(results, "fp_from_int(5) == 5.0", f5, 4617315517961601024)

    Let f0 be FP.fp_from_int(0)
    T.assert_equal(results, "fp_from_int(0) == 0.0", f0, 0)

    Let i5 be FP.fp_to_int_trunc(4617315517961601024)
    T.assert_equal(results, "fp_to_int_trunc(5.0) == 5", i5, 5)

    Note: fp_to_int_trunc(3.7) should give 3
    Note: 3.7 bits = 0x400D999999999999
    Note: but exact 3.7 isn't representable; 3.7 -> 3
    Note: We use 3.0 + 0.7 via fp_add.
    Let three be FP.fp_from_int(3)
    Note: 0.7 ~= 0x3FE6666666666666 = 4604480259023595110
    Let seven_tenths be 4604480259023595110
    Let f37 be FP.fp_add(three, seven_tenths)
    Let i37 be FP.fp_to_int_trunc(f37)
    T.assert_equal(results, "fp_to_int_trunc(3.7) == 3", i37, 3)

    Let i_neg37 be FP.fp_to_int_trunc(FP.fp_neg(f37))
    T.assert_equal(results, "fp_to_int_trunc(-3.7) == -3", i_neg37, 0 minus 3)

    Note: fp_to_int_round(3.7) should give 4 (round-half-up)
    Let i37_round be FP.fp_to_int_round(f37)
    T.assert_equal(results, "fp_to_int_round(3.7) == 4", i37_round, 4)
    Return 1
End Process

Process called "test_neg_abs" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fp: neg and abs")
    Let sign_mask be 1 shifted left by 63
    Let one_v be 4607182418800017408
    Let neg_one_expected be one_v bitwise_xor sign_mask
    Let neg_one_actual be FP.fp_neg(one_v)
    T.assert_equal(results, "fp_neg(1.0) flips sign bit", neg_one_actual, neg_one_expected)

    Let abs_neg_one be FP.fp_abs(neg_one_actual)
    T.assert_equal(results, "fp_abs(-1.0) == 1.0", abs_neg_one, one_v)

    Let abs_pos be FP.fp_abs(one_v)
    T.assert_equal(results, "fp_abs(1.0) == 1.0", abs_pos, one_v)
    Return 1
End Process

Process called "test_compare" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fp: compare")
    Let one_v be 4607182418800017408
    Let two_v be 4611686018427387904

    Let lt12 be FP.fp_lt(one_v, two_v)
    T.assert_equal(results, "fp_lt(1.0, 2.0) == 1", lt12, 1)
    Let lt21 be FP.fp_lt(two_v, one_v)
    T.assert_equal(results, "fp_lt(2.0, 1.0) == 0", lt21, 0)
    Let lt11 be FP.fp_lt(one_v, one_v)
    T.assert_equal(results, "fp_lt(1.0, 1.0) == 0", lt11, 0)

    Let le11 be FP.fp_le(one_v, one_v)
    T.assert_equal(results, "fp_le(1.0, 1.0) == 1", le11, 1)
    Let le12 be FP.fp_le(one_v, two_v)
    T.assert_equal(results, "fp_le(1.0, 2.0) == 1", le12, 1)

    Let eq11 be FP.fp_eq(one_v, one_v)
    T.assert_equal(results, "fp_eq(1.0, 1.0) == 1", eq11, 1)
    Let eq12 be FP.fp_eq(one_v, two_v)
    T.assert_equal(results, "fp_eq(1.0, 2.0) == 0", eq12, 0)
    Return 1
End Process

Process called "test_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fp: constants")
    Let pi_v be FP.fp_pi()
    T.assert_equal(results, "fp_pi == 4614256656552045848", pi_v, 4614256656552045848)
    Let two_pi be FP.fp_two_pi()
    T.assert_equal(results, "fp_two_pi == 4618760256179416344", two_pi, 4618760256179416344)
    Let half_pi be FP.fp_half_pi()
    T.assert_equal(results, "fp_half_pi == 4609753056924675352", half_pi, 4609753056924675352)
    Let one_v be FP.fp_one()
    T.assert_equal(results, "fp_one == 4607182418800017408", one_v, 4607182418800017408)
    Let half_v be FP.fp_half()
    T.assert_equal(results, "fp_half == 4602678819172646912", half_v, 4602678819172646912)
    Return 1
End Process

Process called "test_round_floor" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fp: round and floor")
    Note: fp_round_nearest(2.5) -> 2 (round-half-to-even), so result is 2.0
    Let f25 be 4612811918334230528
    Note: round_nearest(2.5) on x86 default = 2 (banker's rounding)
    Let r be FP.fp_round_nearest(f25)
    Let two_f be FP.fp_from_int(2)
    T.assert_equal(results, "fp_round_nearest(2.5) == 2.0", r, two_f)

    Note: fp_floor(2.5) == 2.0
    Let fl be FP.fp_floor(f25)
    T.assert_equal(results, "fp_floor(2.5) == 2.0", fl, two_f)

    Note: fp_floor(-2.5) == -3.0
    Let neg_f25 be FP.fp_neg(f25)
    Let fl_neg be FP.fp_floor(neg_f25)
    Let neg_three be FP.fp_neg(FP.fp_from_int(3))
    T.assert_equal(results, "fp_floor(-2.5) == -3.0", fl_neg, neg_three)
    Return 1
End Process

Process called "near_zero" that takes a as Float returns Integer:
    Note: Returns 1 if |a| * 1e12 rounds to 0 (i.e., |a| < ~5e-13).
    Let abs_a be FP.fp_abs(a)
    Let scale be FP.fp_from_int(1000000000000)
    Let scaled be FP.fp_mul(abs_a, scale)
    Let v be FP.fp_to_int_round(scaled)
    If v is equal to 0:
        Return 1
    End If
    Return 0
End Process

Process called "test_sin_cos_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fp: sin/cos at exact values")
    Note: Each test checks |error| < 5e-13 by scaling the error to int via 1e12.

    Let zero_v be FP.fp_zero()
    Let one_v be FP.fp_one()
    Let pi_v be FP.fp_pi()
    Let half_pi_v be FP.fp_half_pi()

    Let c0 be FP.fp_cos(zero_v)
    Let d0 be FP.fp_sub(c0, one_v)
    T.assert_equal(results, "|cos(0) - 1| < 5e-13", near_zero(d0), 1)

    Let s0 be FP.fp_sin(zero_v)
    T.assert_equal(results, "|sin(0)| < 5e-13", near_zero(s0), 1)

    Let cpi be FP.fp_cos(pi_v)
    Let neg_one_v be FP.fp_neg(one_v)
    Let dpi be FP.fp_sub(cpi, neg_one_v)
    T.assert_equal(results, "|cos(pi) - (-1)| < 5e-13", near_zero(dpi), 1)

    Let s_half be FP.fp_sin(half_pi_v)
    Let dshalf be FP.fp_sub(s_half, one_v)
    T.assert_equal(results, "|sin(pi/2) - 1| < 5e-13", near_zero(dshalf), 1)

    Let c_half be FP.fp_cos(half_pi_v)
    T.assert_equal(results, "|cos(pi/2)| < 5e-13", near_zero(c_half), 1)

    Let s_pi be FP.fp_sin(pi_v)
    T.assert_equal(results, "|sin(pi)| < 5e-13", near_zero(s_pi), 1)
    Return 1
End Process

Process called "test_exp_basic" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fp: exp")
    Let zero_v be FP.fp_zero()
    Let one_v be FP.fp_one()

    Let e0 be FP.fp_exp(zero_v)
    Let d0 be FP.fp_sub(e0, one_v)
    T.assert_equal(results, "|exp(0) - 1| < 5e-13", near_zero(d0), 1)

    Note: e binary64 bits = 0x4005BF0A8B145769 = 4613303441197561673
    Let e_const be 4613303441197561673
    Let e1 be FP.fp_exp(one_v)
    Let de be FP.fp_sub(e1, e_const)
    Note: exp accuracy is roughly ~1e-12 from 10-term Taylor at x=1
    Note: with range reduction. Use 1e-10 absolute tolerance.
    Let abs_de be FP.fp_abs(de)
    Let scale_1e10 be FP.fp_from_int(10000000000)
    Let scaled be FP.fp_mul(abs_de, scale_1e10)
    Let v be FP.fp_to_int_round(scaled)
    T.assert_equal(results, "|exp(1) - e| < 5e-11", v, 0)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_field_ops(results)
    test_sqrt(results)
    test_conversions(results)
    test_neg_abs(results)
    test_compare(results)
    test_constants(results)
    test_round_floor(results)
    test_sin_cos_basic(results)
    test_exp_basic(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
