Note:
FALCON-FFT n=512 PRECISION DIAGNOSTIC

Loads int16 coefficients into a 512-coefficient FFT buffer, runs forward FFT
then inverse FFT, and reports the worst-case absolute error between the
recovered real parts and the original integer coefficients.

For Falcon's pipeline to work, max coefficient error must be << 0.5 so that
fft_extract_real_round produces the exact original integers.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/pq/falcon_fp.runa" as FP
Import "compiler/frontend/import_system/crypto/pq/falcon_fft.runa" as FFT

Process called "run_roundtrip" that takes seed_a as Integer, seed_b as Integer, n as Integer returns Integer:
    Note: Run a single n-coefficient FFT round-trip with a deterministic
    Note: small-integer polynomial driven by seeds. Returns scaled max
    Note: absolute error in units of 1e6 (so 1.0 -> 1000000 units).

    Let arena be Arena.arena_create(65536)

    Let int_buf be Arena.arena_allocate(arena, n multiplied by 2)
    Let fft_buf be Arena.arena_allocate(arena, n multiplied by 16)

    Note: Fill int_buf with int16 coefs in [-200,200] driven by a tiny LCG.
    Let state be seed_a bitwise_xor 305419896
    Let k be 0
    While k is less than n:
        Set state to state multiplied by 1103515245
        Set state to state plus 12345
        Set state to state plus seed_b
        Let v be state bitwise_and 511
        Set v to v minus 256
        Note: keep in [-200,200] range
        If v is greater than 200:
            Set v to 200
        End If
        If v is less than 0 minus 200:
            Set v to 0 minus 200
        End If
        Let off be k multiplied by 2
        Memory.memory_set_int16(int_buf, off, v)
        Set k to k plus 1
    End While

    Note: Load int16 -> FFT real parts, zero imag.
    FFT.fft_load_from_int16_signed(int_buf, fft_buf, n)

    Note: Round-trip
    FFT.fft_forward(arena, fft_buf, n)
    FFT.fft_inverse(arena, fft_buf, n)

    Note: Compute max absolute error of (recovered_real - original_int).
    Let max_abs be FP.fp_zero()
    Let max_imag_abs be FP.fp_zero()
    Let i be 0
    While i is less than n:
        Let off be i multiplied by 2
        Let orig_int be Memory.memory_get_int16(int_buf, off)
        Let orig_f be FP.fp_from_int(orig_int)
        Let recovered be FFT.fft_get_real(fft_buf, i)
        Let imag be FFT.fft_get_imag(fft_buf, i)
        Let diff be FP.fp_sub(recovered, orig_f)
        Let abs_d be FP.fp_abs(diff)
        Let abs_i be FP.fp_abs(imag)
        Let bigger be FP.fp_lt(max_abs, abs_d)
        If bigger is equal to 1:
            Set max_abs to abs_d
        End If
        Let bigger_i be FP.fp_lt(max_imag_abs, abs_i)
        If bigger_i is equal to 1:
            Set max_imag_abs to abs_i
        End If
        Set i to i plus 1
    End While

    Note: Scale max_abs by 1e6 -> integer.
    Let scale be FP.fp_from_int(1000000)
    Let scaled be FP.fp_mul(max_abs, scale)
    Let max_int be FP.fp_to_int_round(scaled)
    Let scaled_i be FP.fp_mul(max_imag_abs, scale)
    Let max_imag_int be FP.fp_to_int_round(scaled_i)

    Display "  n="
    Display n
    Display "  max_real_err_x1e6="
    Display max_int
    Display "  max_imag_err_x1e6="
    Display max_imag_int

    Arena.arena_destroy(arena)
    Return max_int
End Process

Process called "test_fft_n4_precision" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: n=4 precision baseline")
    Let max_err_x1e6 be run_roundtrip(1, 2, 4)
    Note: Tolerance: 1e-9 -> 1 unit at 1e6 scale. We expect < 100 (1e-4).
    T.assert_less_than(results, "n=4 max round-trip error x1e6 < 100", max_err_x1e6, 100)
    Return 1
End Process

Process called "test_fft_n16_precision" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: n=16 precision")
    Let max_err_x1e6 be run_roundtrip(3, 7, 16)
    T.assert_less_than(results, "n=16 max round-trip error x1e6 < 1000", max_err_x1e6, 1000)
    Return 1
End Process

Process called "test_fft_n64_precision" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: n=64 precision")
    Let max_err_x1e6 be run_roundtrip(11, 13, 64)
    T.assert_less_than(results, "n=64 max round-trip error x1e6 < 10000", max_err_x1e6, 10000)
    Return 1
End Process

Process called "test_fft_n128_precision" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: n=128 precision")
    Let max_err_x1e6 be run_roundtrip(17, 19, 128)
    T.assert_less_than(results, "n=128 max round-trip error x1e6 < 50000", max_err_x1e6, 50000)
    Return 1
End Process

Process called "test_fft_n256_precision" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: n=256 precision")
    Let max_err_x1e6 be run_roundtrip(23, 29, 256)
    T.assert_less_than(results, "n=256 max round-trip error x1e6 < 100000", max_err_x1e6, 100000)
    Return 1
End Process

Process called "test_fft_n512_precision_seed_1_3" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: n=512 round-trip seed1/3")
    Let max_err_x1e6 be run_roundtrip(1, 3, 512)
    Note: We REQUIRE < 0.5 absolute error per coefficient for Falcon to work.
    Note: < 500000 means < 0.5 absolute. We'd really like < 100000 (~ 0.1).
    T.assert_less_than(results, "n=512 max round-trip error x1e6 < 500000", max_err_x1e6, 500000)
    Return 1
End Process

Process called "test_fft_n512_precision_seed_2_7" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: n=512 round-trip seed2/7")
    Let max_err_x1e6 be run_roundtrip(2, 7, 512)
    T.assert_less_than(results, "n=512 max round-trip error x1e6 < 500000", max_err_x1e6, 500000)
    Return 1
End Process

Process called "test_fft_n512_precision_seed_5_11" that takes results as Integer returns Integer:
    T.begin_suite(results, "falcon_fft: n=512 round-trip seed5/11")
    Let max_err_x1e6 be run_roundtrip(5, 11, 512)
    T.assert_less_than(results, "n=512 max round-trip error x1e6 < 500000", max_err_x1e6, 500000)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_fft_n4_precision(results)
    test_fft_n16_precision(results)
    test_fft_n64_precision(results)
    test_fft_n128_precision(results)
    test_fft_n256_precision(results)
    test_fft_n512_precision_seed_1_3(results)
    test_fft_n512_precision_seed_2_7(results)
    test_fft_n512_precision_seed_5_11(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
