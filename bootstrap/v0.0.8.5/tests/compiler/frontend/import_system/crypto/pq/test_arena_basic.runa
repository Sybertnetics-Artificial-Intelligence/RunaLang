Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Process called "main" returns Integer:
    Let results be T.create_test_results()
    T.begin_suite(results, "arena basic")

    Let arena be Arena.arena_create(4194304)
    T.assert_not_null(results, "arena created", arena)

    Let buf1 be Arena.arena_allocate(arena, 48)
    T.assert_not_null(results, "alloc 48 bytes", buf1)

    Let buf2 be Arena.arena_allocate(arena, 504)
    T.assert_not_null(results, "alloc 504 bytes", buf2)

    Note: Write to buf2 then read back
    Memory.memory_set_qword(buf2, 0, 12345)
    Let v1 be Memory.memory_get_qword(buf2, 0)
    T.assert_equal(results, "read back 12345", v1, 12345)

    Memory.memory_set_qword(buf2, 496, 999)
    Let v2 be Memory.memory_get_qword(buf2, 496)
    T.assert_equal(results, "read back 999 at 496", v2, 999)

    T.print_summary(results)
    Return T.get_failed(results)
End Process
