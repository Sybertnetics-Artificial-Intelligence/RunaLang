Note:
==============================================================================
HYBRID zint <-> FFT-fp53 INTERCONVERSION ROUND-TRIP TESTS
==============================================================================
These tests cover the Pornin-style hybrid Babai support in falcon_zint_poly:

  zint_poly_to_fft : zint K_n polynomial -> Float64 FFT buffer
  fft_to_zint_poly : Float64 FFT buffer  -> zint K_n polynomial

Identity expected: for any zint polynomial whose coefficients fit safely
inside Float64 mantissa (we use the conservative 50-bit threshold the
hybrid Babai uses), forward-FFT then inverse-FFT then round must recover
the original coefficients exactly.

Precision rejection expected: a coefficient whose bit length exceeds the
50-bit threshold must cause zint_poly_to_fft to return 0 so the caller
falls back to the exact-zint kernel.

Hybrid Babai parity: build (f, g, F, G) with small coefficients where the
exact-zint Babai converges in O(1) iterations and the hybrid path also
converges; assert that both produce the same final (F, G) pair (modulo
identical Babai termination conditions).
:End Note

Process called "test_zint_to_fft_identity_small" that takes results as Integer returns Integer:
    @Reasoning
    Verify zint_poly_to_fft followed by fft_to_zint_poly recovers the
    original polynomial when coefficients are small enough to fit safely
    in fp53.
    @End Reasoning
    @Implementation
    n = 8.  Build a zint polynomial from a hand-chosen Int64 array of
    small signed coefficients.  Allocate a 16*n FFT buffer.  Call
    zint_poly_to_fft (forward FFT inside).  Then call fft_to_zint_poly
    (inverse FFT inside) and compare each recovered coefficient against
    the input.
    @End Implementation
    @Performance_Hints
    Constant for n = 8.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: zint <-> FFT round-trip n=8")
    Let arena be Arena.arena_create(4194304)
    Let n be 8

    Note: Test coefficients: a mix of positive, negative, and zero.
    Let coeffs_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(coeffs_int, 0, 3)
    Memory.memory_set_int64(coeffs_int, 8, 0 minus 5)
    Memory.memory_set_int64(coeffs_int, 16, 0)
    Memory.memory_set_int64(coeffs_int, 24, 17)
    Memory.memory_set_int64(coeffs_int, 32, 0 minus 12)
    Memory.memory_set_int64(coeffs_int, 40, 7)
    Memory.memory_set_int64(coeffs_int, 48, 0 minus 1)
    Memory.memory_set_int64(coeffs_int, 56, 99)
    Let in_poly be ZP.zint_poly_from_int_array(arena, coeffs_int, n, 8)

    Let fft_bytes be n multiplied by 16
    Let fft_buf be Arena.arena_allocate(arena, fft_bytes)

    Note: baseline_used = 2 limbs: exact representation for these
    Note: 7-bit-or-smaller coefficients.
    Let to_fft_rc be ZP.zint_poly_to_fft(arena, in_poly, n, fft_buf, 2)
    T.assert_equal(results, "zint_poly_to_fft rc == 1", to_fft_rc, 1)

    Let rec_poly be ZP.fft_to_zint_poly(arena, fft_buf, n)
    T.assert_not_null(results, "fft_to_zint_poly returned poly", rec_poly)

    Let i be 0
    While i is less than n:
        Let expected be Memory.memory_get_int64(coeffs_int, i multiplied by 8)
        Let actual be Z.zint_to_int(ZP.zint_poly_get(rec_poly, i))
        T.assert_equal(results, "round-trip coefficient matches", actual, expected)
        Set i to i plus 1
    End While

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_to_fft_identity_n16" that takes results as Integer returns Integer:
    @Reasoning
    Same round-trip identity at n = 16 with coefficients that exercise
    multiple bit widths (single-digit, two-digit, three-digit).
    @End Reasoning
    @Implementation
    n = 16.  Coefficients chosen so the sum_squared exceeds 2^16,
    forcing the FFT to operate on slot magnitudes in the thousands.
    Verify each coefficient round-trips byte-exact.
    @End Implementation
    @Performance_Hints
    Constant for n = 16.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: zint <-> FFT round-trip n=16")
    Let arena be Arena.arena_create(4194304)
    Let n be 16

    Let coeffs_int be Arena.arena_allocate(arena, n multiplied by 8)
    Let pattern be 1
    Let i be 0
    While i is less than n:
        Let sign be 1
        If (i bitwise_and 1) is equal to 1:
            Set sign to 0 minus 1
        End If
        Let val be (i plus 1) multiplied by 137 multiplied by sign
        Memory.memory_set_int64(coeffs_int, i multiplied by 8, val)
        Set i to i plus 1
    End While

    Let in_poly be ZP.zint_poly_from_int_array(arena, coeffs_int, n, 8)

    Let fft_bytes be n multiplied by 16
    Let fft_buf be Arena.arena_allocate(arena, fft_bytes)

    Let to_fft_rc be ZP.zint_poly_to_fft(arena, in_poly, n, fft_buf, 2)
    T.assert_equal(results, "zint_poly_to_fft rc == 1", to_fft_rc, 1)

    Let rec_poly be ZP.fft_to_zint_poly(arena, fft_buf, n)
    T.assert_not_null(results, "fft_to_zint_poly returned poly", rec_poly)

    Let j be 0
    While j is less than n:
        Let expected be Memory.memory_get_int64(coeffs_int, j multiplied by 8)
        Let actual be Z.zint_to_int(ZP.zint_poly_get(rec_poly, j))
        T.assert_equal(results, "n=16 round-trip coefficient matches", actual, expected)
        Set j to j plus 1
    End While

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_to_fft_large_coeff_scaling" that takes results as Integer returns Integer:
    @Reasoning
    Verify that the uniform-scaling lift handles a coefficient larger
    than Int64.  Under Pornin's scheme each coefficient lifts to its top
    62 bits at the polynomial-wide baseline; there is no rejection.
    @End Reasoning
    @Implementation
    Build a zint coefficient of magnitude 1 << 80 (81-bit, 3 limbs of
    31 bits).  Call zint_poly_max_used and confirm it reports 3.  Call
    zint_poly_to_fft with baseline_used = 3.  Then run fft_to_zint_poly
    and verify the recovered slot-0 coefficient equals the top 62 bits
    of (1 << 80).  Specifically: limb 2 = 1, limbs 1 and 0 = 0; top 62
    bits encode 1 * 2^31 = 2147483648.
    @End Implementation
    @Performance_Hints
    Single shift_left + a handful of FFT operations; trivial.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: zint -> FFT large-coefficient scaling")
    Let arena be Arena.arena_create(4194304)
    Let n be 4

    Note: Build big_z = 1 << 80 (3 limbs of 31 bits each).
    Let one_z be Z.zint_from_int(arena, 1)
    Let shifted be Z.zint_shift_left(arena, one_z, 80)
    Let bits be Z.zint_bit_length(shifted)
    T.assert_equal(results, "bit length of 1<<80 = 81", bits, 81)

    Note: Build poly = [shifted, 0, 0, 0].
    Let poly_bytes be n multiplied by 8
    Let poly be Arena.arena_allocate(arena, poly_bytes)
    Memory.memory_zero(poly, poly_bytes)
    ZP.zint_poly_set(poly, 0, shifted)
    ZP.zint_poly_set(poly, 1, Z.zint_from_int(arena, 0))
    ZP.zint_poly_set(poly, 2, Z.zint_from_int(arena, 0))
    ZP.zint_poly_set(poly, 3, Z.zint_from_int(arena, 0))

    Let mu be ZP.zint_poly_max_used(poly, n)
    T.assert_greater_than(results, "max_used >= 3", mu, 2)

    Let fft_bytes be n multiplied by 16
    Let fft_buf be Arena.arena_allocate(arena, fft_bytes)

    Note: 80 = 2*31 + 18, so 1<<80 has limb[2] = 2^18 = 262144 and
    Note: limbs 0, 1 = 0.  With baseline_used = 3 we extract
    Note: top62 = limb[2] << 31 + limb[1] = 262144 << 31 + 0 = 2^49 =
    Note: 562949953421312.  The lifted Float64 rounds-trip exactly
    Note: through the FFT, recovering 2^49 at slot 0.
    Let rc_lift be ZP.zint_poly_to_fft(arena, poly, n, fft_buf, 3)
    T.assert_equal(results, "zint_poly_to_fft accepts large coefficient", rc_lift, 1)

    Let rec_poly be ZP.fft_to_zint_poly(arena, fft_buf, n)
    T.assert_not_null(results, "fft_to_zint_poly returned poly", rec_poly)
    Let recovered_0 be Z.zint_to_int(ZP.zint_poly_get(rec_poly, 0))
    T.assert_equal(results, "scaled coeff [0] = 2^49", recovered_0, 562949953421312)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_hybrid_babai_matches_zint_n4" that takes results as Integer returns Integer:
    @Reasoning
    Hybrid-Babai-parity test.  Build a small NTRU instance where the
    Babai reduction is well-defined and both paths converge to a
    Bezout solution.  Run ntru_solve and verify the returned (F, G)
    satisfies f*G - g*F = q in K_n.  This is the strongest
    correctness check: if the hybrid path silently produces wrong k
    rounding, the final identity will fail.
    @End Reasoning
    @Implementation
    n = 4.  f, g chosen to be small and to produce a feasible NTRU
    solution at the base case.  After ntru_solve we compute
    delta = f*G - g*F in K_n via zint poly mul and assert it equals
    the constant polynomial q (12289, then zero in all other slots).
    @End Implementation
    @Performance_Hints
    n = 4 NTRU descent costs are milliseconds.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_ntrusolve: hybrid Babai f*G - g*F == q at n=4")
    Let arena be Arena.arena_create(67108864)
    Let n be 4
    Let q be 12289

    Note: f, g must produce an invertible base case.  Use the same
    Note: hand-chosen small polynomials as the existing test_ntru_solve_n4
    Note: which the pure-zint path is already known to solve.
    Let f_int be Arena.arena_allocate(arena, n multiplied by 2)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 2)
    Memory.memory_set_int16(f_int, 0, 3)
    Memory.memory_set_int16(f_int, 2, 1)
    Memory.memory_set_int16(f_int, 4, 0 minus 2)
    Memory.memory_set_int16(f_int, 6, 1)
    Memory.memory_set_int16(g_int, 0, 2)
    Memory.memory_set_int16(g_int, 2, 0 minus 1)
    Memory.memory_set_int16(g_int, 4, 1)
    Memory.memory_set_int16(g_int, 6, 0 minus 1)

    Let F_out be Arena.arena_allocate(arena, n multiplied by 2)
    Let G_out be Arena.arena_allocate(arena, n multiplied by 2)

    Let rc be NS.ntru_solve(arena, f_int, g_int, n, F_out, G_out)
    T.assert_equal(results, "ntru_solve rc == 1", rc, 1)

    Note: Verify f*G - g*F = q in K_n.  Convert all four into zint
    Note: polynomials, compute fG and gF via zint K_n mul, subtract,
    Note: and check that the result is q at index 0 and zero elsewhere.
    Let f_p be ZP.zint_poly_from_int_array(arena, f_int, n, 2)
    Let g_p be ZP.zint_poly_from_int_array(arena, g_int, n, 2)
    Let F_p be ZP.zint_poly_from_int_array(arena, F_out, n, 2)
    Let G_p be ZP.zint_poly_from_int_array(arena, G_out, n, 2)
    Let fG be ZP.zint_poly_mul(arena, f_p, G_p, n)
    Let gF be ZP.zint_poly_mul(arena, g_p, F_p, n)
    Let delta be ZP.zint_poly_sub(arena, fG, gF, n)

    Let d0 be Z.zint_to_int(ZP.zint_poly_get(delta, 0))
    T.assert_equal(results, "(f*G - g*F)[0] = q", d0, q)
    Let i be 1
    While i is less than n:
        Let di be Z.zint_to_int(ZP.zint_poly_get(delta, i))
        T.assert_equal(results, "(f*G - g*F)[i>=1] = 0", di, 0)
        Set i to i plus 1
    End While

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_hybrid_babai_matches_zint_n16" that takes results as Integer returns Integer:
    @Reasoning
    Same hybrid-Babai-parity check but at n = 16 where the FFT path
    has meaningful work to do (4 forward FFTs of size 16 per
    iteration).  Confirms the hybrid kernel preserves the NTRU
    invariant at moderate sizes.
    @End Reasoning
    @Implementation
    Use the same f, g pattern as test_ntru_solve_n16 (already known
    to succeed under the pure-zint kernel) and assert the same NTRU
    invariant holds with the hybrid kernel.
    @End Implementation
    @Performance_Hints
    n = 16 NTRU descent is fractions of a second.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_ntrusolve: hybrid Babai f*G - g*F == q at n=16")
    Let arena be Arena.arena_create(134217728)
    Let n be 16
    Let q be 12289

    Let f_int be Arena.arena_allocate(arena, n multiplied by 2)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 2)
    Memory.memory_zero(f_int, n multiplied by 2)
    Memory.memory_zero(g_int, n multiplied by 2)

    Note: Pick f, g with mixed small coefficients; same pattern shape
    Note: as the existing pure-zint n=16 test.
    Memory.memory_set_int16(f_int, 0, 3)
    Memory.memory_set_int16(f_int, 2, 1)
    Memory.memory_set_int16(f_int, 4, 0 minus 1)
    Memory.memory_set_int16(f_int, 8, 1)
    Memory.memory_set_int16(f_int, 12, 0 minus 1)
    Memory.memory_set_int16(g_int, 0, 1)
    Memory.memory_set_int16(g_int, 2, 0 minus 2)
    Memory.memory_set_int16(g_int, 6, 1)
    Memory.memory_set_int16(g_int, 10, 0 minus 1)
    Memory.memory_set_int16(g_int, 14, 1)

    Let F_out be Arena.arena_allocate(arena, n multiplied by 2)
    Let G_out be Arena.arena_allocate(arena, n multiplied by 2)

    Let rc be NS.ntru_solve(arena, f_int, g_int, n, F_out, G_out)
    T.assert_equal(results, "ntru_solve rc == 1", rc, 1)

    Let f_p be ZP.zint_poly_from_int_array(arena, f_int, n, 2)
    Let g_p be ZP.zint_poly_from_int_array(arena, g_int, n, 2)
    Let F_p be ZP.zint_poly_from_int_array(arena, F_out, n, 2)
    Let G_p be ZP.zint_poly_from_int_array(arena, G_out, n, 2)
    Let fG be ZP.zint_poly_mul(arena, f_p, G_p, n)
    Let gF be ZP.zint_poly_mul(arena, g_p, F_p, n)
    Let delta be ZP.zint_poly_sub(arena, fG, gF, n)

    Let d0 be Z.zint_to_int(ZP.zint_poly_get(delta, 0))
    T.assert_equal(results, "(f*G - g*F)[0] = q", d0, q)
    Let i be 1
    While i is less than n:
        Let di be Z.zint_to_int(ZP.zint_poly_get(delta, i))
        T.assert_equal(results, "(f*G - g*F)[i>=1] = 0", di, 0)
        Set i to i plus 1
    End While

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_ntru_solve_n4" that takes results as Integer returns Integer:
    @Reasoning
    End-to-end NTRUSolve test at n = 4 with hand-crafted f, g.  This
    verifies the full descent + lift + Babai pipeline on a small
    instance.
    @End Reasoning
    @Implementation
    Pick f = 1 + 2X, g = -1 + 3X (length 4 with trailing zeros).
    Compute f*G - g*F = 12289 expected to hold.  Call ntru_solve
    public entry; ensure rc == 1.  Then verify the identity by
    polynomial multiplication.
    @End Implementation
    @Performance_Hints
    n = 4 with tiny coefficients: completes in milliseconds.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "ntrusolve: end-to-end n=4")
    Let arena be Arena.arena_create(67108864)
    Let n be 4

    Note: Sample f, g that satisfy NTRU norm bound.  Use coefficients
    Note: in range [-3, 3] so ||(f,g)||^2 stays small.
    Let f_int be Arena.arena_allocate(arena, n multiplied by 2)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 2)
    Memory.memory_set_int16(f_int, 0, 1)
    Memory.memory_set_int16(f_int, 2, 2)
    Memory.memory_set_int16(f_int, 4, 0)
    Memory.memory_set_int16(f_int, 6, 0)
    Memory.memory_set_int16(g_int, 0, 0 minus 1)
    Memory.memory_set_int16(g_int, 2, 3)
    Memory.memory_set_int16(g_int, 4, 0)
    Memory.memory_set_int16(g_int, 6, 0)

    Let F_int be Arena.arena_allocate(arena, n multiplied by 2)
    Let G_int be Arena.arena_allocate(arena, n multiplied by 2)
    Memory.memory_zero(F_int, n multiplied by 2)
    Memory.memory_zero(G_int, n multiplied by 2)

    Let rc be NS.ntru_solve(arena, f_int, g_int, n, F_int, G_int)
    T.assert_equal(results, "ntru_solve rc == 1", rc, 1)

    Note: Verify f*G - g*F = q (where q=12289) in K_4.
    Note: Use zint_poly for multiplication.
    Let f_poly be ZP.zint_poly_from_int_array(arena, f_int, n, 2)
    Let g_poly be ZP.zint_poly_from_int_array(arena, g_int, n, 2)
    Let F_poly be ZP.zint_poly_from_int_array(arena, F_int, n, 2)
    Let G_poly be ZP.zint_poly_from_int_array(arena, G_int, n, 2)

    Let fG be ZP.zint_poly_mul(arena, f_poly, G_poly, n)
    Let gF be ZP.zint_poly_mul(arena, g_poly, F_poly, n)
    Let identity be ZP.zint_poly_sub(arena, fG, gF, n)

    T.assert_equal(results, "(f*G - g*F)[0] = 12289", Z.zint_to_int(ZP.zint_poly_get(identity, 0)), 12289)
    T.assert_equal(results, "(f*G - g*F)[1] = 0",     Z.zint_to_int(ZP.zint_poly_get(identity, 1)), 0)
    T.assert_equal(results, "(f*G - g*F)[2] = 0",     Z.zint_to_int(ZP.zint_poly_get(identity, 2)), 0)
    T.assert_equal(results, "(f*G - g*F)[3] = 0",     Z.zint_to_int(ZP.zint_poly_get(identity, 3)), 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

