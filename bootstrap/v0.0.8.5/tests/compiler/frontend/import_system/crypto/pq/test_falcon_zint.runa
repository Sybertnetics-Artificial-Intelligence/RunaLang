Process called "test_ntru_solve_n16" that takes results as Integer returns Integer:
    @Reasoning
    End-to-end NTRUSolve at n = 16 by calling ntru_solve_zint
    directly.  This avoids the int16 range check in ntru_solve and
    lets us inspect the zint output coefficients regardless of size.
    @End Reasoning
    @Implementation
    Hand-crafted f, g with small coefficients.  Build zint polys.
    Call ntru_solve_zint.  Check rc and verify f*G - g*F = q in K_16
    even if individual F, G coefficients exceed int16 range.  This
    isolates whether the descent is computing the wrong (F, G) versus
    whether they merely don't fit in int16.
    @End Implementation
    @Performance_Hints
    n = 16: expected sub-second on modest hardware.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "ntrusolve: end-to-end n=16 (zint inspection)")
    Let arena be Arena.arena_create(67108864)
    Let n be 16

    Let f_int be Arena.arena_allocate(arena, n multiplied by 2)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 2)
    Note: Use Falcon-style sample: small Gaussian-ish coefficients.
    Memory.memory_set_int16(f_int, 0, 2)
    Memory.memory_set_int16(f_int, 2, 0 minus 1)
    Memory.memory_set_int16(f_int, 4, 3)
    Memory.memory_set_int16(f_int, 6, 1)
    Memory.memory_set_int16(f_int, 8, 0 minus 2)
    Memory.memory_set_int16(f_int, 10, 0)
    Memory.memory_set_int16(f_int, 12, 1)
    Memory.memory_set_int16(f_int, 14, 0 minus 1)
    Memory.memory_set_int16(f_int, 16, 2)
    Memory.memory_set_int16(f_int, 18, 0 minus 1)
    Memory.memory_set_int16(f_int, 20, 0)
    Memory.memory_set_int16(f_int, 22, 1)
    Memory.memory_set_int16(f_int, 24, 0 minus 1)
    Memory.memory_set_int16(f_int, 26, 2)
    Memory.memory_set_int16(f_int, 28, 0)
    Memory.memory_set_int16(f_int, 30, 1)
    Memory.memory_set_int16(g_int, 0, 1)
    Memory.memory_set_int16(g_int, 2, 2)
    Memory.memory_set_int16(g_int, 4, 0 minus 1)
    Memory.memory_set_int16(g_int, 6, 0)
    Memory.memory_set_int16(g_int, 8, 1)
    Memory.memory_set_int16(g_int, 10, 0 minus 2)
    Memory.memory_set_int16(g_int, 12, 1)
    Memory.memory_set_int16(g_int, 14, 0 minus 1)
    Memory.memory_set_int16(g_int, 16, 0)
    Memory.memory_set_int16(g_int, 18, 2)
    Memory.memory_set_int16(g_int, 20, 0 minus 1)
    Memory.memory_set_int16(g_int, 22, 1)
    Memory.memory_set_int16(g_int, 24, 0)
    Memory.memory_set_int16(g_int, 26, 0 minus 1)
    Memory.memory_set_int16(g_int, 28, 2)
    Memory.memory_set_int16(g_int, 30, 1)

    Let f_poly be ZP.zint_poly_from_int_array(arena, f_int, n, 2)
    Let g_poly be ZP.zint_poly_from_int_array(arena, g_int, n, 2)
    Let F_poly be ZP.zint_poly_create(arena, n, 1)
    Let G_poly be ZP.zint_poly_create(arena, n, 1)

    Let solve_rc be NS.ntru_solve_zint(arena, f_poly, g_poly, n, F_poly, G_poly)
    T.assert_equal(results, "ntru_solve_zint n=16 rc == 1", solve_rc, 1)

    If solve_rc is equal to 1:
        Note: Compute identity in K_16
        Let fG be ZP.zint_poly_mul(arena, f_poly, G_poly, n)
        Let gF be ZP.zint_poly_mul(arena, g_poly, F_poly, n)
        Let identity be ZP.zint_poly_sub(arena, fG, gF, n)

        T.assert_equal(results, "n=16 identity [0] = 12289", Z.zint_to_int(ZP.zint_poly_get(identity, 0)), 12289)
        Let i be 1
        While i is less than n:
            T.assert_equal(results, "n=16 identity zero", Z.zint_to_int(ZP.zint_poly_get(identity, i)), 0)
            Set i to i plus 1
        End While

        Note: Also report bit length of F[0] for diagnostic purposes.
        Let bits_F0 be Z.zint_bit_length(ZP.zint_poly_get(F_poly, 0))
        T.assert_less_than(results, "F[0] bit length < 16 (sanity)", bits_F0, 16)
    End If

    Arena.arena_destroy(arena)
    Return 1
End Process

