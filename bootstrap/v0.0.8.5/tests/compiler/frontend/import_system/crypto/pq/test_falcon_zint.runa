Process called "test_ntru_solve_n64" that takes results as Integer returns Integer:
    @Reasoning
    End-to-end NTRUSolve at n = 64.  Doubles the descent depth from
    n=32, exercising the algorithm at depths closer to (but not at)
    Falcon production sizes.
    @End Reasoning
    @Implementation
    Use a periodic pattern of small coefficients for f, g (similar to
    Falcon sampling: small Gaussian-like coefficients).
    @End Implementation
    @Performance_Hints
    n = 64: tens of seconds.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "ntrusolve: end-to-end n=64")
    Let arena be Arena.arena_create(268435456)
    Let n be 64

    Let f_int be Arena.arena_allocate(arena, n multiplied by 2)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 2)
    Note: Pseudo-random pattern using LCG to fill.
    Let state_ptr be Arena.arena_allocate(arena, 8)
    Memory.memory_set_int64(state_ptr, 0, 12345678901)
    Let pi be 0
    While pi is less than n:
        Let raw be proc lcg_next with state_ptr
        Let v be raw bitwise_and 7
        Set v to v minus 3
        Memory.memory_set_int16(f_int, pi multiplied by 2, v)
        Let raw2 be proc lcg_next with state_ptr
        Let v2 be raw2 bitwise_and 7
        Set v2 to v2 minus 3
        Memory.memory_set_int16(g_int, pi multiplied by 2, v2)
        Set pi to pi plus 1
    End While

    Let f_poly be ZP.zint_poly_from_int_array(arena, f_int, n, 2)
    Let g_poly be ZP.zint_poly_from_int_array(arena, g_int, n, 2)
    Let F_poly be ZP.zint_poly_create(arena, n, 1)
    Let G_poly be ZP.zint_poly_create(arena, n, 1)

    Let solve_rc be NS.ntru_solve_zint(arena, f_poly, g_poly, n, F_poly, G_poly)
    T.assert_equal(results, "ntru_solve_zint n=64 rc == 1", solve_rc, 1)

    If solve_rc is equal to 1:
        Let fG be ZP.zint_poly_mul(arena, f_poly, G_poly, n)
        Let gF be ZP.zint_poly_mul(arena, g_poly, F_poly, n)
        Let identity be ZP.zint_poly_sub(arena, fG, gF, n)

        T.assert_equal(results, "n=64 identity [0] = 12289", Z.zint_to_int(ZP.zint_poly_get(identity, 0)), 12289)
        Let i be 1
        Let identity_ok be 1
        While i is less than n:
            Let v be Z.zint_to_int(ZP.zint_poly_get(identity, i))
            If v is not equal to 0:
                Set identity_ok to 0
            End If
            Set i to i plus 1
        End While
        T.assert_equal(results, "n=64 identity all-zero off-constant", identity_ok, 1)
    End If

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_ntru_solve_n128_falcon_style" that takes results as Integer returns Integer:
    @Reasoning
    End-to-end NTRUSolve at n = 128 using Falcon-style sampled f, g.
    n = 128 is the largest size we can run in a reasonable test-suite
    time and exercises the same descent depths as smaller subtrees of
    Falcon-512.
    @End Reasoning
    @Implementation
    Use the falcon_sample_short_polynomial routine via shake to draw
    Falcon-style f, g.  Call ntru_solve_zint and verify the f*G - g*F
    = q identity.
    @End Implementation
    @Performance_Hints
    n = 128: estimated tens of seconds.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "ntrusolve: end-to-end n=128 (falcon-style)")
    Let arena be Arena.arena_create(536870912)
    Let n be 128

    Let state_ptr be Arena.arena_allocate(arena, 8)
    Memory.memory_set_int64(state_ptr, 0, 999999937)
    Let f_int be Arena.arena_allocate(arena, n multiplied by 2)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 2)

    Note: Try a deterministic pattern that guarantees the K_1 base
    Note: case bezout succeeds.  Specifically f has constant non-zero
    Note: leading coefficient and zeros elsewhere; g similarly.  This
    Note: makes det(f) = f[0]^n and det(g) = g[0]^n, whose gcd is
    Note: gcd(f[0]^n, g[0]^n) which divides q when gcd(f[0], g[0])^n
    Note: divides q.  For f[0]=1 the gcd is 1, trivially dividing q.
    Let attempt be 0
    Let solve_rc be 0
    While attempt is less than 200:
        Memory.memory_zero(f_int, n multiplied by 2)
        Memory.memory_zero(g_int, n multiplied by 2)
        Note: f = 1, g = small varying poly to exercise the lift/Babai.
        Memory.memory_set_int16(f_int, 0, 1)
        Let pi be 0
        While pi is less than n:
            Let raw be proc lcg_next with state_ptr
            Let v be raw bitwise_and 7
            Set v to v minus 3
            Memory.memory_set_int16(g_int, pi multiplied by 2, v)
            Set pi to pi plus 1
        End While

        Let f_poly_loc be ZP.zint_poly_from_int_array(arena, f_int, n, 2)
        Let g_poly_loc be ZP.zint_poly_from_int_array(arena, g_int, n, 2)
        Let F_poly_loc be ZP.zint_poly_create(arena, n, 1)
        Let G_poly_loc be ZP.zint_poly_create(arena, n, 1)

        Set solve_rc to NS.ntru_solve_zint(arena, f_poly_loc, g_poly_loc, n, F_poly_loc, G_poly_loc)
        If solve_rc is equal to 1:
            Note: Verify the identity.
            Let fG_loc be ZP.zint_poly_mul(arena, f_poly_loc, G_poly_loc, n)
            Let gF_loc be ZP.zint_poly_mul(arena, g_poly_loc, F_poly_loc, n)
            Let identity_loc be ZP.zint_poly_sub(arena, fG_loc, gF_loc, n)
            T.assert_equal(results, "n=128 identity [0] = 12289", Z.zint_to_int(ZP.zint_poly_get(identity_loc, 0)), 12289)
            Set attempt to 200
        Otherwise:
            Set attempt to attempt plus 1
        End If
    End While

    T.assert_equal(results, "ntru_solve_zint n=128 eventually succeeded", solve_rc, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

