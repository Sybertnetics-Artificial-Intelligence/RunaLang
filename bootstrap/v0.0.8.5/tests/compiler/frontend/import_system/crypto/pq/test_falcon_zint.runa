Note:
==============================================================================
Unit tests for falcon_zint (multi-precision integers) and falcon_zint_poly
==============================================================================

Coverage:
  1. zint round-trip via zint_from_int -> zint_to_int over small and
     boundary Int64 values.
  2. zint addition / subtraction sanity vs hand-computed expected.
  3. zint multiplication vs hand-computed expected (small and
     Karatsuba-threshold-crossing sizes).
  4. zint divmod: a = q*b + r with |r| < |b|, sign(r) = sign(a).
  5. zint polynomial multiplication in K_n: degree wrap with sign flip.
  6. zint field-norm: N(a) computed both via explicit a*a_bar and via
     zint_poly_field_norm must match.
  7. Stress: pseudo-random Int64 pairs through add/sub/mul/divmod
     identity check (q*b + r == a, |r| < |b|).
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/pq/falcon_zint.runa" as Z
Import "compiler/frontend/import_system/crypto/pq/falcon_zint_poly.runa" as ZP
Import "compiler/frontend/import_system/crypto/pq/falcon_ntrusolve.runa" as NS
Import "compiler/frontend/import_system/crypto/pq/falcon_fp.runa" as FP
Import "compiler/frontend/import_system/crypto/pq/falcon_fft.runa" as FFT

Note: Pseudo-random LCG state lives in a single int64 cell so the
Note: stress loop can advance it deterministically.

Process called "lcg_next" takes state_ptr as Integer returns Integer:
    @Reasoning
    Advance a 64-bit LCG and return the new state.
    @End Reasoning
    @Implementation
    Numerical Recipes 64-bit constants: state = state * 6364136223846793005 + 1442695040888963407.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test PRNG.
    @End Security_Scope
    Let cur be Memory.memory_get_int64(state_ptr, 0)
    Let mul be 6364136223846793005
    Let add be 1442695040888963407
    Set cur to cur multiplied by mul
    Set cur to cur plus add
    Memory.memory_set_int64(state_ptr, 0, cur)
    Return cur
End Process

Process called "test_zint_roundtrip" that takes results as Integer returns Integer:
    @Reasoning
    Round-trip Int64 values through zint_from_int / zint_to_int.
    @End Reasoning
    @Implementation
    Construct zints for 0, 1, -1, 2^30-1, 2^31, 2^31+5, -(2^31+5),
    a 2-limb positive, and a 2-limb negative; verify zint_to_int
    recovers the original.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint: from_int / to_int round trip")
    Let arena be Arena.arena_create(1048576)
    T.assert_not_null(results, "arena", arena)

    Let z0 be Z.zint_from_int(arena, 0)
    T.assert_equal(results, "0", Z.zint_to_int(z0), 0)

    Let z1 be Z.zint_from_int(arena, 1)
    T.assert_equal(results, "1", Z.zint_to_int(z1), 1)

    Let z_neg1 be Z.zint_from_int(arena, 0 minus 1)
    T.assert_equal(results, "-1", Z.zint_to_int(z_neg1), 0 minus 1)

    Let v_30_max be 1073741823
    Let z_30 be Z.zint_from_int(arena, v_30_max)
    T.assert_equal(results, "2^30 - 1", Z.zint_to_int(z_30), v_30_max)

    Let v_31 be 2147483648
    Let z_31 be Z.zint_from_int(arena, v_31)
    T.assert_equal(results, "2^31", Z.zint_to_int(z_31), v_31)

    Let v_big be 5000000000
    Let z_big be Z.zint_from_int(arena, v_big)
    T.assert_equal(results, "5e9", Z.zint_to_int(z_big), v_big)

    Let z_big_neg be Z.zint_from_int(arena, 0 minus v_big)
    T.assert_equal(results, "-5e9", Z.zint_to_int(z_big_neg), 0 minus v_big)

    Let v_huge be 9223372036854775000
    Let z_huge be Z.zint_from_int(arena, v_huge)
    T.assert_equal(results, "near max Int64", Z.zint_to_int(z_huge), v_huge)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_add_sub" that takes results as Integer returns Integer:
    @Reasoning
    Verify zint_add and zint_sub on a handful of cases including
    sign cross-overs.
    @End Reasoning
    @Implementation
    For each (a, b) pair compute expected = a +/- b via Int64 arithmetic
    (kept within range), then build zints, run the primitive, and
    confirm round-trip.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint: add / sub")
    Let arena be Arena.arena_create(1048576)

    Let cases be 8
    Let ai be 0
    Let xs be Arena.arena_allocate(arena, cases multiplied by 8)
    Let ys be Arena.arena_allocate(arena, cases multiplied by 8)
    Memory.memory_set_int64(xs, 0, 5)
    Memory.memory_set_int64(ys, 0, 3)
    Memory.memory_set_int64(xs, 8, 100000000000)
    Memory.memory_set_int64(ys, 8, 17)
    Memory.memory_set_int64(xs, 16, 0 minus 42)
    Memory.memory_set_int64(ys, 16, 0 minus 1)
    Memory.memory_set_int64(xs, 24, 0 minus 9999)
    Memory.memory_set_int64(ys, 24, 10000)
    Memory.memory_set_int64(xs, 32, 2147483648)
    Memory.memory_set_int64(ys, 32, 2147483648)
    Memory.memory_set_int64(xs, 40, 0 minus 2147483647)
    Memory.memory_set_int64(ys, 40, 2147483646)
    Memory.memory_set_int64(xs, 48, 1)
    Memory.memory_set_int64(ys, 48, 0 minus 1)
    Memory.memory_set_int64(xs, 56, 0)
    Memory.memory_set_int64(ys, 56, 42)

    Let i be 0
    While i is less than cases:
        Let off be i multiplied by 8
        Let xv be Memory.memory_get_int64(xs, off)
        Let yv be Memory.memory_get_int64(ys, off)
        Let xz be Z.zint_from_int(arena, xv)
        Let yz be Z.zint_from_int(arena, yv)
        Let out be Z.zint_create(arena, 8)
        Z.zint_add(out, xz, yz)
        T.assert_equal(results, "add", Z.zint_to_int(out), xv plus yv)
        Let out2 be Z.zint_create(arena, 8)
        Z.zint_sub(out2, xz, yz)
        T.assert_equal(results, "sub", Z.zint_to_int(out2), xv minus yv)
        Set i to i plus 1
    End While
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_mul" that takes results as Integer returns Integer:
    @Reasoning
    Verify zint_mul on small cases (schoolbook path) and a wider case
    that exercises multi-limb carry.
    @End Reasoning
    @Implementation
    Compute expected via Int64 wrap; for the wide case, multiply two
    factors that exactly fit and verify the wrapped product.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint: mul")
    Let arena be Arena.arena_create(2097152)

    Let xz be Z.zint_from_int(arena, 7)
    Let yz be Z.zint_from_int(arena, 11)
    Let p be Z.zint_mul(arena, xz, yz)
    T.assert_equal(results, "7 * 11", Z.zint_to_int(p), 77)

    Let xz2 be Z.zint_from_int(arena, 0 minus 12345)
    Let yz2 be Z.zint_from_int(arena, 6789)
    Let p2 be Z.zint_mul(arena, xz2, yz2)
    T.assert_equal(results, "-12345 * 6789", Z.zint_to_int(p2), 0 minus (12345 multiplied by 6789))

    Let xz3 be Z.zint_from_int(arena, 1000000007)
    Let yz3 be Z.zint_from_int(arena, 998244353)
    Let p3 be Z.zint_mul(arena, xz3, yz3)
    T.assert_equal(results, "two ~30b primes", Z.zint_to_int(p3), 1000000007 multiplied by 998244353)

    Note: Symmetric case: (2^31) * (2^31) = 2^62 fits in Int64.
    Let xz4 be Z.zint_from_int(arena, 2147483648)
    Let yz4 be Z.zint_from_int(arena, 2147483648)
    Let p4 be Z.zint_mul(arena, xz4, yz4)
    T.assert_equal(results, "2^31 * 2^31 = 2^62", Z.zint_to_int(p4), 4611686018427387904)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_divmod" that takes results as Integer returns Integer:
    @Reasoning
    Verify the divmod identity a = q*b + r with |r| < |b| and
    sign(r) = sign(a).
    @End Reasoning
    @Implementation
    A few targeted cases plus a stress loop using the LCG.
    @End Implementation
    @Performance_Hints
    Linear in iteration count.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint: divmod identity")
    Let arena be Arena.arena_create(4194304)

    Let q_ptr be Arena.arena_allocate(arena, 8)
    Let r_ptr be Arena.arena_allocate(arena, 8)
    Let state_ptr be Arena.arena_allocate(arena, 8)
    Memory.memory_set_int64(state_ptr, 0, 0xCAFEBABEFACEFEED)

    Note: Targeted cases.
    Let cases be 6
    Let xs be Arena.arena_allocate(arena, cases multiplied by 8)
    Let ys be Arena.arena_allocate(arena, cases multiplied by 8)
    Memory.memory_set_int64(xs, 0, 100)
    Memory.memory_set_int64(ys, 0, 7)
    Memory.memory_set_int64(xs, 8, 0 minus 100)
    Memory.memory_set_int64(ys, 8, 7)
    Memory.memory_set_int64(xs, 16, 100)
    Memory.memory_set_int64(ys, 16, 0 minus 7)
    Memory.memory_set_int64(xs, 24, 0 minus 100)
    Memory.memory_set_int64(ys, 24, 0 minus 7)
    Memory.memory_set_int64(xs, 32, 1000000000000)
    Memory.memory_set_int64(ys, 32, 999999)
    Memory.memory_set_int64(xs, 40, 1234567890)
    Memory.memory_set_int64(ys, 40, 7919)

    Let i be 0
    While i is less than cases:
        Let off be i multiplied by 8
        Let xv be Memory.memory_get_int64(xs, off)
        Let yv be Memory.memory_get_int64(ys, off)
        Let xz be Z.zint_from_int(arena, xv)
        Let yz be Z.zint_from_int(arena, yv)
        Z.zint_divmod(arena, xz, yz, q_ptr, r_ptr)
        Let qz be Memory.memory_get_int64(q_ptr, 0)
        Let rz be Memory.memory_get_int64(r_ptr, 0)
        Let qv be Z.zint_to_int(qz)
        Let rv be Z.zint_to_int(rz)
        Let reconstructed be (qv multiplied by yv) plus rv
        T.assert_equal(results, "a = q*b + r", reconstructed, xv)
        Set i to i plus 1
    End While

    Note: Random stress.
    Let iters be 200
    Let j be 0
    While j is less than iters:
        Let a_raw be proc lcg_next with state_ptr
        Let b_raw be proc lcg_next with state_ptr
        Note: Confine magnitudes to fit (q * b + r) within Int64 with margin.
        Let a_clip be a_raw bitwise_and 0x7FFFFFFF
        Let b_clip be b_raw bitwise_and 0xFFFF
        If b_clip is equal to 0:
            Set b_clip to 1
        End If
        Let sign_a be a_raw bitwise_and 1
        Let sign_b be (a_raw shifted right by 1) bitwise_and 1
        Let av be a_clip
        If sign_a is equal to 1:
            Set av to 0 minus av
        End If
        Let bv be b_clip
        If sign_b is equal to 1:
            Set bv to 0 minus bv
        End If
        Let xz be Z.zint_from_int(arena, av)
        Let yz be Z.zint_from_int(arena, bv)
        Z.zint_divmod(arena, xz, yz, q_ptr, r_ptr)
        Let qz be Memory.memory_get_int64(q_ptr, 0)
        Let rz be Memory.memory_get_int64(r_ptr, 0)
        Let qv be Z.zint_to_int(qz)
        Let rv be Z.zint_to_int(rz)
        Let reconstructed be (qv multiplied by bv) plus rv
        T.assert_equal(results, "stress a = q*b + r", reconstructed, av)
        Set j to j plus 1
    End While

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_poly_basics" that takes results as Integer returns Integer:
    @Reasoning
    Verify zint polynomial add / sub / mul over K_n.
    @End Reasoning
    @Implementation
    n = 4 example:
      a = 1 + 2X + 3X^2 + 4X^3
      b = 5 + 6X + 7X^2 + 8X^3
    Compute c = a * b in Z[X]/(X^4 + 1) by hand:
      coefficient of X^0: 1*5 - (2*8 + 3*7 + 4*6) = 5 - (16 + 21 + 24) = -56
      coefficient of X^1: 1*6 + 2*5 - (3*8 + 4*7) = 6 + 10 - (24 + 28) = -36
      coefficient of X^2: 1*7 + 2*6 + 3*5 - (4*8) = 7 + 12 + 15 - 32 = 2
      coefficient of X^3: 1*8 + 2*7 + 3*6 + 4*5 = 8 + 14 + 18 + 20 = 60
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: add / sub / mul")
    Let arena be Arena.arena_create(2097152)
    Let n be 4

    Let a_int be Arena.arena_allocate(arena, n multiplied by 8)
    Let b_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(a_int, 0, 1)
    Memory.memory_set_int64(a_int, 8, 2)
    Memory.memory_set_int64(a_int, 16, 3)
    Memory.memory_set_int64(a_int, 24, 4)
    Memory.memory_set_int64(b_int, 0, 5)
    Memory.memory_set_int64(b_int, 8, 6)
    Memory.memory_set_int64(b_int, 16, 7)
    Memory.memory_set_int64(b_int, 24, 8)
    Let a be ZP.zint_poly_from_int_array(arena, a_int, n, 8)
    Let b be ZP.zint_poly_from_int_array(arena, b_int, n, 8)

    Let sum be ZP.zint_poly_add(arena, a, b, n)
    T.assert_equal(results, "(a+b)[0] = 6", Z.zint_to_int(ZP.zint_poly_get(sum, 0)), 6)
    T.assert_equal(results, "(a+b)[1] = 8", Z.zint_to_int(ZP.zint_poly_get(sum, 1)), 8)
    T.assert_equal(results, "(a+b)[2] = 10", Z.zint_to_int(ZP.zint_poly_get(sum, 2)), 10)
    T.assert_equal(results, "(a+b)[3] = 12", Z.zint_to_int(ZP.zint_poly_get(sum, 3)), 12)

    Let diff be ZP.zint_poly_sub(arena, a, b, n)
    T.assert_equal(results, "(a-b)[0] = -4", Z.zint_to_int(ZP.zint_poly_get(diff, 0)), 0 minus 4)
    T.assert_equal(results, "(a-b)[3] = -4", Z.zint_to_int(ZP.zint_poly_get(diff, 3)), 0 minus 4)

    Let prod be ZP.zint_poly_mul(arena, a, b, n)
    T.assert_equal(results, "(a*b)[0] = -56", Z.zint_to_int(ZP.zint_poly_get(prod, 0)), 0 minus 56)
    T.assert_equal(results, "(a*b)[1] = -36", Z.zint_to_int(ZP.zint_poly_get(prod, 1)), 0 minus 36)
    T.assert_equal(results, "(a*b)[2] = 2", Z.zint_to_int(ZP.zint_poly_get(prod, 2)), 2)
    T.assert_equal(results, "(a*b)[3] = 60", Z.zint_to_int(ZP.zint_poly_get(prod, 3)), 60)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_poly_field_norm" that takes results as Integer returns Integer:
    @Reasoning
    Verify the field norm map by computing N(f) two different ways
    and comparing.
    @End Reasoning
    @Implementation
    For n=4, f = 1 + 2X + 3X^2 + 4X^3:
      adj(f) = 1 - 2X + 3X^2 - 4X^3
      f * adj(f) in K_4 only has even-degree terms; substituting
      Y = X^2 gives a polynomial in K_2 = Q[Y]/(Y^2+1).
    We compute the K_4 product directly, extract the even-indexed
    coefficients (which form N(f) in K_2 with the substitution),
    then compare with zint_poly_field_norm output.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: field norm")
    Let arena be Arena.arena_create(2097152)
    Let n be 4

    Let f_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(f_int, 0, 1)
    Memory.memory_set_int64(f_int, 8, 2)
    Memory.memory_set_int64(f_int, 16, 3)
    Memory.memory_set_int64(f_int, 24, 4)
    Let f be ZP.zint_poly_from_int_array(arena, f_int, n, 8)
    Let adj_f be ZP.zint_poly_conjugate(arena, f, n)

    Let prod be ZP.zint_poly_mul(arena, f, adj_f, n)
    T.assert_equal(results, "(f*adj(f))[1] == 0", Z.zint_to_int(ZP.zint_poly_get(prod, 1)), 0)
    T.assert_equal(results, "(f*adj(f))[3] == 0", Z.zint_to_int(ZP.zint_poly_get(prod, 3)), 0)

    Let expected0 be Z.zint_to_int(ZP.zint_poly_get(prod, 0))
    Let expected1 be Z.zint_to_int(ZP.zint_poly_get(prod, 2))

    Let nf be ZP.zint_poly_field_norm(arena, f, n)
    Let actual0 be Z.zint_to_int(ZP.zint_poly_get(nf, 0))
    Let actual1 be Z.zint_to_int(ZP.zint_poly_get(nf, 1))

    T.assert_equal(results, "N(f)[0] == (f*adj(f))[0]", actual0, expected0)
    T.assert_equal(results, "N(f)[1] == (f*adj(f))[2]", actual1, expected1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_poly_split_merge_roundtrip" that takes results as Integer returns Integer:
    @Reasoning
    Verify zint_poly_split_even_odd composed with zint_poly_merge_even_odd
    is the identity over a K_n polynomial.
    @End Reasoning
    @Implementation
    Build a K_8 polynomial with distinct integer coefficients (0..7).
    Split into K_4 even/odd halves; assert each half holds the right
    coefficients.  Merge back and assert every coefficient matches the
    original.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: split/merge even-odd round trip")
    Let arena be Arena.arena_create(1048576)
    Let n be 8

    Let src_int be Arena.arena_allocate(arena, n multiplied by 8)
    Let i be 0
    While i is less than n:
        Memory.memory_set_int64(src_int, i multiplied by 8, i)
        Set i to i plus 1
    End While
    Let src be ZP.zint_poly_from_int_array(arena, src_int, n, 8)

    Let e_ptr be Arena.arena_allocate(arena, 8)
    Let o_ptr be Arena.arena_allocate(arena, 8)
    ZP.zint_poly_split_even_odd(arena, src, n, e_ptr, o_ptr)
    Let e be Memory.memory_get_int64(e_ptr, 0)
    Let o be Memory.memory_get_int64(o_ptr, 0)

    Note: Even part holds [0, 2, 4, 6], odd part holds [1, 3, 5, 7]
    T.assert_equal(results, "even[0] = 0", Z.zint_to_int(ZP.zint_poly_get(e, 0)), 0)
    T.assert_equal(results, "even[1] = 2", Z.zint_to_int(ZP.zint_poly_get(e, 1)), 2)
    T.assert_equal(results, "even[2] = 4", Z.zint_to_int(ZP.zint_poly_get(e, 2)), 4)
    T.assert_equal(results, "even[3] = 6", Z.zint_to_int(ZP.zint_poly_get(e, 3)), 6)
    T.assert_equal(results, "odd[0] = 1",  Z.zint_to_int(ZP.zint_poly_get(o, 0)), 1)
    T.assert_equal(results, "odd[1] = 3",  Z.zint_to_int(ZP.zint_poly_get(o, 1)), 3)
    T.assert_equal(results, "odd[2] = 5",  Z.zint_to_int(ZP.zint_poly_get(o, 2)), 5)
    T.assert_equal(results, "odd[3] = 7",  Z.zint_to_int(ZP.zint_poly_get(o, 3)), 7)

    Let merged be ZP.zint_poly_merge_even_odd(arena, e, o, n)
    Let j be 0
    While j is less than n:
        T.assert_equal(results, "merge round trip", Z.zint_to_int(ZP.zint_poly_get(merged, j)), j)
        Set j to j plus 1
    End While

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_poly_substitute_x_squared" that takes results as Integer returns Integer:
    @Reasoning
    Verify zint_poly_substitute_x_squared inverts zint_poly_extract_even
    when the source has only even-degree coefficients.
    @End Reasoning
    @Implementation
    Build K_4 polynomial p_y = [10, 20, 30, 40] (in Y).  Substitute
    Y = X^2 to get K_8 polynomial: [10, 0, 20, 0, 30, 0, 40, 0].  Then
    extract_even on the K_8 result must give back the original K_4.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: substitute X^2 / extract_even")
    Let arena be Arena.arena_create(1048576)
    Let half_n be 4
    Let n be half_n multiplied by 2

    Let p_y_int be Arena.arena_allocate(arena, half_n multiplied by 8)
    Memory.memory_set_int64(p_y_int, 0, 10)
    Memory.memory_set_int64(p_y_int, 8, 20)
    Memory.memory_set_int64(p_y_int, 16, 30)
    Memory.memory_set_int64(p_y_int, 24, 40)
    Let p_y be ZP.zint_poly_from_int_array(arena, p_y_int, half_n, 8)

    Let p_x be ZP.zint_poly_substitute_x_squared(arena, p_y, half_n)
    T.assert_equal(results, "p_x[0] = 10", Z.zint_to_int(ZP.zint_poly_get(p_x, 0)), 10)
    T.assert_equal(results, "p_x[1] = 0",  Z.zint_to_int(ZP.zint_poly_get(p_x, 1)), 0)
    T.assert_equal(results, "p_x[2] = 20", Z.zint_to_int(ZP.zint_poly_get(p_x, 2)), 20)
    T.assert_equal(results, "p_x[3] = 0",  Z.zint_to_int(ZP.zint_poly_get(p_x, 3)), 0)
    T.assert_equal(results, "p_x[4] = 30", Z.zint_to_int(ZP.zint_poly_get(p_x, 4)), 30)
    T.assert_equal(results, "p_x[5] = 0",  Z.zint_to_int(ZP.zint_poly_get(p_x, 5)), 0)
    T.assert_equal(results, "p_x[6] = 40", Z.zint_to_int(ZP.zint_poly_get(p_x, 6)), 40)
    T.assert_equal(results, "p_x[7] = 0",  Z.zint_to_int(ZP.zint_poly_get(p_x, 7)), 0)

    Let extracted be ZP.zint_poly_extract_even(arena, p_x, n)
    T.assert_equal(results, "extracted[0] = 10", Z.zint_to_int(ZP.zint_poly_get(extracted, 0)), 10)
    T.assert_equal(results, "extracted[1] = 20", Z.zint_to_int(ZP.zint_poly_get(extracted, 1)), 20)
    T.assert_equal(results, "extracted[2] = 30", Z.zint_to_int(ZP.zint_poly_get(extracted, 2)), 30)
    T.assert_equal(results, "extracted[3] = 40", Z.zint_to_int(ZP.zint_poly_get(extracted, 3)), 40)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_poly_field_norm_sum" that takes results as Integer returns Integer:
    @Reasoning
    Verify zint_poly_field_norm_sum returns f*adj(f) + g*adj(g) and the
    result has zero coefficients at every odd index.
    @End Reasoning
    @Implementation
    n = 4.  f = 1 + 2X + 3X^2 + 4X^3, g = 5 + 6X + 7X^2 + 8X^3.
    Compute f*adj(f), g*adj(g), and (f*adj(f) + g*adj(g)) by hand and
    cross-check.

    Hand computation in K_4:
      adj(f) = 1 - 2X + 3X^2 - 4X^3
      f * adj(f) [0] = 1*1 - (2*(-4) + 3*3 + 4*(-2)) = 1 - (-8 + 9 - 8) = 1 - (-7) = 8
        Wait, let me redo: f*adj(f) = sum_{i,j} f[i]*adj(f)[j] X^{i+j} reduced
        adj(f)[j] = (-1)^j * f[j]; so f*adj(f) [d] = sum_{i+j=d or i+j=d+n} f[i]*f[j]*(-1)^j*(-1)^{wrap}
      We already verified in the existing field_norm test that
      f*adj(f) in K_4 has zero at indices 1 and 3.  Use that property
      directly: assert the sum's [1] and [3] are zero.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: field_norm_sum")
    Let arena be Arena.arena_create(2097152)
    Let n be 4

    Let f_int be Arena.arena_allocate(arena, n multiplied by 8)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(f_int, 0, 1)
    Memory.memory_set_int64(f_int, 8, 2)
    Memory.memory_set_int64(f_int, 16, 3)
    Memory.memory_set_int64(f_int, 24, 4)
    Memory.memory_set_int64(g_int, 0, 5)
    Memory.memory_set_int64(g_int, 8, 6)
    Memory.memory_set_int64(g_int, 16, 7)
    Memory.memory_set_int64(g_int, 24, 8)
    Let f be ZP.zint_poly_from_int_array(arena, f_int, n, 8)
    Let g be ZP.zint_poly_from_int_array(arena, g_int, n, 8)

    Let denom be ZP.zint_poly_field_norm_sum(arena, f, g, n)
    T.assert_equal(results, "denom[1] = 0", Z.zint_to_int(ZP.zint_poly_get(denom, 1)), 0)
    T.assert_equal(results, "denom[3] = 0", Z.zint_to_int(ZP.zint_poly_get(denom, 3)), 0)

    Note: Verify against direct computation.
    Let af be ZP.zint_poly_conjugate(arena, f, n)
    Let ag be ZP.zint_poly_conjugate(arena, g, n)
    Let ff be ZP.zint_poly_mul(arena, f, af, n)
    Let gg be ZP.zint_poly_mul(arena, g, ag, n)
    Let expected be ZP.zint_poly_add(arena, ff, gg, n)
    Let k be 0
    While k is less than n:
        Let exp_c be Z.zint_to_int(ZP.zint_poly_get(expected, k))
        Let act_c be Z.zint_to_int(ZP.zint_poly_get(denom, k))
        T.assert_equal(results, "denom matches direct", act_c, exp_c)
        Set k to k plus 1
    End While

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_poly_divide_kn_identity_n2" that takes results as Integer returns Integer:
    @Reasoning
    Verify the K_n polynomial division identity D * (N / D) = N for
    a hand-picked numerator that is exactly a multiple of the K_n
    denominator at n = 2.
    @End Reasoning
    @Implementation
    n = 2.  Choose f = 1 + 0*X, g = 0 + 1*X.  Then
      adj(f) = 1, adj(g) = -X.
      f*adj(f) = 1; g*adj(g) = -X * X = -X^2 = +1 (since X^2 = -1).
      Denom = 1 + 1 = 2 (constant 2 in K_2).
    Take numerator = 6 + 4*X.  Then numer / 2 = 3 + 2*X exactly (no
    rounding needed).  Assert the result.

    Also assert: D * (N/D) = N.  Multiply 2 * (3 + 2X) in K_2:
      = 6 + 4X.  Matches.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: K_n divide identity n=2")
    Let arena be Arena.arena_create(2097152)
    Let n be 2

    Let f_int be Arena.arena_allocate(arena, n multiplied by 8)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(f_int, 0, 1)
    Memory.memory_set_int64(f_int, 8, 0)
    Memory.memory_set_int64(g_int, 0, 0)
    Memory.memory_set_int64(g_int, 8, 1)
    Let f be ZP.zint_poly_from_int_array(arena, f_int, n, 8)
    Let g be ZP.zint_poly_from_int_array(arena, g_int, n, 8)

    Let num_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(num_int, 0, 6)
    Memory.memory_set_int64(num_int, 8, 4)
    Let numer be ZP.zint_poly_from_int_array(arena, num_int, n, 8)

    Let quotient be ZP.zint_poly_divide_by_kn_denominator(arena, numer, f, g, n)
    T.assert_equal(results, "Q[0] = 3", Z.zint_to_int(ZP.zint_poly_get(quotient, 0)), 3)
    T.assert_equal(results, "Q[1] = 2", Z.zint_to_int(ZP.zint_poly_get(quotient, 1)), 2)

    Note: Verify D * Q = N.
    Let denom be ZP.zint_poly_field_norm_sum(arena, f, g, n)
    Let recon be ZP.zint_poly_mul(arena, denom, quotient, n)
    T.assert_equal(results, "D*Q [0] = 6", Z.zint_to_int(ZP.zint_poly_get(recon, 0)), 6)
    T.assert_equal(results, "D*Q [1] = 4", Z.zint_to_int(ZP.zint_poly_get(recon, 1)), 4)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_poly_divide_kn_identity_n4" that takes results as Integer returns Integer:
    @Reasoning
    Verify K_n polynomial division at n = 4 with an exact-multiple
    numerator.
    @End Reasoning
    @Implementation
    n = 4.  f = 1 + X + X^2 + X^3, g = 1 - X + X^2 - X^3 (= adj(f)).
      adj(f) = 1 - X + X^2 - X^3 = g
      adj(g) = 1 + X + X^2 + X^3 = f
      f * adj(f) = f * g in K_4
      g * adj(g) = g * f = same
      Denom = 2 * f * g.
    Choose any Q = [Q0, Q1, Q2, Q3] and set numer = denom * Q (K_4
    product).  Then divide and assert the quotient matches Q.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: K_n divide identity n=4")
    Let arena be Arena.arena_create(4194304)
    Let n be 4

    Let f_int be Arena.arena_allocate(arena, n multiplied by 8)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(f_int, 0, 1)
    Memory.memory_set_int64(f_int, 8, 1)
    Memory.memory_set_int64(f_int, 16, 1)
    Memory.memory_set_int64(f_int, 24, 1)
    Memory.memory_set_int64(g_int, 0, 1)
    Memory.memory_set_int64(g_int, 8, 0 minus 1)
    Memory.memory_set_int64(g_int, 16, 1)
    Memory.memory_set_int64(g_int, 24, 0 minus 1)
    Let f be ZP.zint_poly_from_int_array(arena, f_int, n, 8)
    Let g be ZP.zint_poly_from_int_array(arena, g_int, n, 8)

    Let denom be ZP.zint_poly_field_norm_sum(arena, f, g, n)
    Note: Confirm denom only has even-X coefficients.
    T.assert_equal(results, "denom[1] = 0", Z.zint_to_int(ZP.zint_poly_get(denom, 1)), 0)
    T.assert_equal(results, "denom[3] = 0", Z.zint_to_int(ZP.zint_poly_get(denom, 3)), 0)

    Note: Choose quotient Q = 3 + 5X + 7X^2 + 11X^3.
    Let Q_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(Q_int, 0, 3)
    Memory.memory_set_int64(Q_int, 8, 5)
    Memory.memory_set_int64(Q_int, 16, 7)
    Memory.memory_set_int64(Q_int, 24, 11)
    Let Q_orig be ZP.zint_poly_from_int_array(arena, Q_int, n, 8)

    Let numer be ZP.zint_poly_mul(arena, denom, Q_orig, n)

    Let Q_recovered be ZP.zint_poly_divide_by_kn_denominator(arena, numer, f, g, n)

    T.assert_equal(results, "Q[0] = 3",  Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 0)), 3)
    T.assert_equal(results, "Q[1] = 5",  Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 1)), 5)
    T.assert_equal(results, "Q[2] = 7",  Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 2)), 7)
    T.assert_equal(results, "Q[3] = 11", Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 3)), 11)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_poly_divide_kn_identity_n8" that takes results as Integer returns Integer:
    @Reasoning
    Verify K_n polynomial division at n = 8 with an exact-multiple
    numerator and small but varied coefficients.
    @End Reasoning
    @Implementation
    n = 8.  f = small symbolic [2, 1, 0, -1, 1, 0, -1, 1],
            g = [1, -1, 1, 0, -1, 1, 0, 1].
    Compute denom = f*adj(f) + g*adj(g) (must have odd indices zero).
    Choose Q = [1, 2, -1, 3, -2, 4, 1, -3].
    numer = denom * Q in K_8.
    Divide numer by (f, g)-denom and recover Q.
    @End Implementation
    @Performance_Hints
    Constant.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: K_n divide identity n=8")
    Let arena be Arena.arena_create(8388608)
    Let n be 8

    Let f_int be Arena.arena_allocate(arena, n multiplied by 8)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(f_int, 0, 2)
    Memory.memory_set_int64(f_int, 8, 1)
    Memory.memory_set_int64(f_int, 16, 0)
    Memory.memory_set_int64(f_int, 24, 0 minus 1)
    Memory.memory_set_int64(f_int, 32, 1)
    Memory.memory_set_int64(f_int, 40, 0)
    Memory.memory_set_int64(f_int, 48, 0 minus 1)
    Memory.memory_set_int64(f_int, 56, 1)
    Memory.memory_set_int64(g_int, 0, 1)
    Memory.memory_set_int64(g_int, 8, 0 minus 1)
    Memory.memory_set_int64(g_int, 16, 1)
    Memory.memory_set_int64(g_int, 24, 0)
    Memory.memory_set_int64(g_int, 32, 0 minus 1)
    Memory.memory_set_int64(g_int, 40, 1)
    Memory.memory_set_int64(g_int, 48, 0)
    Memory.memory_set_int64(g_int, 56, 1)
    Let f be ZP.zint_poly_from_int_array(arena, f_int, n, 8)
    Let g be ZP.zint_poly_from_int_array(arena, g_int, n, 8)

    Let denom be ZP.zint_poly_field_norm_sum(arena, f, g, n)
    T.assert_equal(results, "denom[1] = 0", Z.zint_to_int(ZP.zint_poly_get(denom, 1)), 0)
    T.assert_equal(results, "denom[3] = 0", Z.zint_to_int(ZP.zint_poly_get(denom, 3)), 0)
    T.assert_equal(results, "denom[5] = 0", Z.zint_to_int(ZP.zint_poly_get(denom, 5)), 0)
    T.assert_equal(results, "denom[7] = 0", Z.zint_to_int(ZP.zint_poly_get(denom, 7)), 0)

    Let Q_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_set_int64(Q_int, 0, 1)
    Memory.memory_set_int64(Q_int, 8, 2)
    Memory.memory_set_int64(Q_int, 16, 0 minus 1)
    Memory.memory_set_int64(Q_int, 24, 3)
    Memory.memory_set_int64(Q_int, 32, 0 minus 2)
    Memory.memory_set_int64(Q_int, 40, 4)
    Memory.memory_set_int64(Q_int, 48, 1)
    Memory.memory_set_int64(Q_int, 56, 0 minus 3)
    Let Q_orig be ZP.zint_poly_from_int_array(arena, Q_int, n, 8)

    Let numer be ZP.zint_poly_mul(arena, denom, Q_orig, n)
    Let Q_recovered be ZP.zint_poly_divide_by_kn_denominator(arena, numer, f, g, n)

    T.assert_equal(results, "Q[0] = 1",  Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 0)), 1)
    T.assert_equal(results, "Q[1] = 2",  Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 1)), 2)
    T.assert_equal(results, "Q[2] = -1", Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 2)), 0 minus 1)
    T.assert_equal(results, "Q[3] = 3",  Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 3)), 3)
    T.assert_equal(results, "Q[4] = -2", Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 4)), 0 minus 2)
    T.assert_equal(results, "Q[5] = 4",  Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 5)), 4)
    T.assert_equal(results, "Q[6] = 1",  Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 6)), 1)
    T.assert_equal(results, "Q[7] = -3", Z.zint_to_int(ZP.zint_poly_get(Q_recovered, 7)), 0 minus 3)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_zint_poly_divide_kn_identity_n16" that takes results as Integer returns Integer:
    @Reasoning
    Verify K_16 division identity to validate the divider at larger n.
    @End Reasoning
    @Implementation
    Use f, g with small coefficients in K_16; compute denom = f*adj(f) +
    g*adj(g); pick Q with small coefficients; numer = denom*Q.  Divide
    and recover Q.
    @End Implementation
    @Performance_Hints
    n=16 with small coefficients.
    @End Performance_Hints
    @Security_Scope
    Public test data.
    @End Security_Scope
    T.begin_suite(results, "falcon_zint_poly: K_n divide identity n=16")
    Let arena be Arena.arena_create(67108864)
    Let n be 16

    Let f_int be Arena.arena_allocate(arena, n multiplied by 8)
    Let g_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_zero(f_int, n multiplied by 8)
    Memory.memory_zero(g_int, n multiplied by 8)
    Memory.memory_set_int64(f_int, 0, 3)
    Memory.memory_set_int64(f_int, 8, 1)
    Memory.memory_set_int64(f_int, 16, 0 minus 1)
    Memory.memory_set_int64(g_int, 0, 1)
    Memory.memory_set_int64(g_int, 8, 0 minus 1)
    Memory.memory_set_int64(g_int, 24, 1)
    Let f be ZP.zint_poly_from_int_array(arena, f_int, n, 8)
    Let g be ZP.zint_poly_from_int_array(arena, g_int, n, 8)

    Let denom be ZP.zint_poly_field_norm_sum(arena, f, g, n)

    Note: Q with small coefficients
    Let Q_int be Arena.arena_allocate(arena, n multiplied by 8)
    Memory.memory_zero(Q_int, n multiplied by 8)
    Memory.memory_set_int64(Q_int, 0, 1)
    Memory.memory_set_int64(Q_int, 8, 2)
    Memory.memory_set_int64(Q_int, 16, 0 minus 1)
    Memory.memory_set_int64(Q_int, 24, 3)
    Memory.memory_set_int64(Q_int, 32, 0 minus 2)
    Memory.memory_set_int64(Q_int, 40, 1)
    Memory.memory_set_int64(Q_int, 48, 0)
    Memory.memory_set_int64(Q_int, 56, 0 minus 1)
    Memory.memory_set_int64(Q_int, 64, 2)
    Memory.memory_set_int64(Q_int, 72, 1)
    Memory.memory_set_int64(Q_int, 80, 0)
    Memory.memory_set_int64(Q_int, 88, 0 minus 3)
    Memory.memory_set_int64(Q_int, 96, 1)
    Memory.memory_set_int64(Q_int, 104, 0)
    Memory.memory_set_int64(Q_int, 112, 0 minus 1)
    Memory.memory_set_int64(Q_int, 120, 2)
    Let Q_orig be ZP.zint_poly_from_int_array(arena, Q_int, n, 8)

    Let numer be ZP.zint_poly_mul(arena, denom, Q_orig, n)

    Let Q_recovered be ZP.zint_poly_divide_by_kn_denominator(arena, numer, f, g, n)

    Let i be 0
    Let all_match be 1
    While i is less than n:
        Let expected be Z.zint_to_int(ZP.zint_poly_get(Q_orig, i))
        Let actual be Z.zint_to_int(ZP.zint_poly_get(Q_recovered, i))
        If expected is not equal to actual:
            Set all_match to 0
        End If
        T.assert_equal(results, "n=16 Q[i] matches", actual, expected)
        Set i to i plus 1
    End While

    Arena.arena_destroy(arena)
    Return 1
End Process

