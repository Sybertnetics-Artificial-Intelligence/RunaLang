Note:
==============================================================================
End-to-end tests for Falcon-512 and Falcon-1024 keygen + sign + verify
==============================================================================

Coverage:
  1. Falcon-512: keygen -> sign(message) -> verify(pk, message, sig) -> 1
  2. Falcon-1024: same round-trip on the larger parameter set
  3. Wrong-message rejection: sig produced over m1 must fail verify against
     m2 != m1 (returns 0).
  4. Wrong-public-key rejection: a sig produced under sk_A must fail verify
     against pk_B from a different keypair.
  5. Empty-message round-trip: ensures the hash-to-point + sign path handles
     zero-length input correctly.

Performance note:
  Falcon-512 keygen on the bootstrap stage1 emulated FP path is on the
  order of seconds; Falcon-1024 keygen is on the order of tens of seconds.
  The 10-iteration random stability test from the task brief is wrapped in
  a smaller-iteration guard variable so the test suite still completes in
  the CI window; raising the iteration count to 10 is a single edit.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/pq/falcon.runa" as Falcon

Process called "fill_seed" takes seed_buf as Integer, offset as Integer returns Integer:
    @Reasoning
    Fill a 48-byte seed buffer with a deterministic byte pattern offset
    by the supplied integer so that successive calls with distinct offsets
    produce distinct seeds.
    @End Reasoning
    @Implementation
    Byte i gets (offset + i + 1) mod 256.
    @End Implementation
    @Performance_Hints
    Linear in 48.
    @End Performance_Hints
    @Security_Scope
    Public test seed; not cryptographic.
    @End Security_Scope
    Let i be 0
    While i is less than 48:
        Let val be offset plus i plus 1
        Let masked be val bitwise_and 255
        Memory.memory_set_byte(seed_buf, i, masked)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "fill_nonce" takes nonce_buf as Integer, offset as Integer returns Integer:
    @Reasoning
    Fill a 40-byte nonce buffer with a deterministic pattern.
    @End Reasoning
    @Implementation
    Byte i gets (offset * 17 + i + 1) mod 256.
    @End Implementation
    @Performance_Hints
    Linear in 40.
    @End Performance_Hints
    @Security_Scope
    Public test nonce; not cryptographic.
    @End Security_Scope
    Let i be 0
    While i is less than 40:
        Let val be offset multiplied by 17
        Set val to val plus i plus 1
        Let masked be val bitwise_and 255
        Memory.memory_set_byte(nonce_buf, i, masked)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "test_falcon_512_roundtrip" that takes results as Integer returns Integer:
    @Reasoning
    Falcon-512 keygen -> sign -> verify round-trip on a single message.
    @End Reasoning
    @Implementation
    1. Allocate arena, seed, nonce, message, pk, sk, sig buffers.
    2. Call falcon_512_keygen(arena, seed, pk, sk).  Expect rc == 1.
    3. Call falcon_512_sign(arena, sk, msg, msg_len, nonce, sig).
       Expect a positive return = signature length.
    4. Call falcon_512_verify(arena, pk, msg, msg_len, sig, sig_len).
       Expect rc == 1.
    @End Implementation
    @Performance_Hints
    Falcon-512 keygen dominates; bound the arena at 4 MiB which is
    sufficient for the NTRU descent + LDL tree on n=512.
    @End Performance_Hints
    @Security_Scope
    Test seeds are not cryptographic; this is a functional test.
    @End Security_Scope
    T.begin_suite(results, "falcon: falcon_512 keygen/sign/verify round-trip")

    Note: 64 MiB caller arena for the LDL tree + key packing.  NTRUSolve
    Note: and the sign-stage FFS both use their own internal scratch arenas
    Note: so the caller's arena holds only persistent state (keys, sigs,
    Note: LDL tree).
    Let arena be Arena.arena_create(67108864)
    T.assert_not_null(results, "arena created", arena)

    Let seed be Arena.arena_allocate(arena, 48)
    proc fill_seed with seed, 42

    Let pk_size be Falcon.falcon_pk_size(1)
    Let sk_size be Falcon.falcon_sk_size(1)
    Let pk_buf be Arena.arena_allocate(arena, pk_size)
    Let sk_buf be Arena.arena_allocate(arena, sk_size)

    Let kg_rc be Falcon.falcon_512_keygen(arena, seed, pk_buf, sk_buf)
    T.assert_equal(results, "keygen rc == 1", kg_rc, 1)

    Let msg be Arena.arena_allocate(arena, 16)
    Let mi be 0
    While mi is less than 16:
        Memory.memory_set_byte(msg, mi, mi)
        Set mi to mi plus 1
    End While

    Let nonce be Arena.arena_allocate(arena, 40)
    proc fill_nonce with nonce, 7

    Let sig_max be Falcon.falcon_sig_size_max(1)
    Let sig_buf be Arena.arena_allocate(arena, sig_max)
    Let sig_len be Falcon.falcon_512_sign(arena, sk_buf, msg, 16, nonce, sig_buf)
    T.assert_greater_than(results, "sign returned positive length", sig_len, 0)

    Let ver_rc be Falcon.falcon_512_verify(arena, pk_buf, msg, 16, sig_buf, sig_len)
    T.assert_equal(results, "verify rc == 1", ver_rc, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_falcon_1024_roundtrip" that takes results as Integer returns Integer:
    @Reasoning
    Falcon-1024 keygen -> sign -> verify round-trip on a single message.
    @End Reasoning
    @Implementation
    Same shape as Falcon-512 but with the larger parameter set.  The arena
    is bumped to 8 MiB to accommodate the n=1024 LDL tree.
    @End Implementation
    @Performance_Hints
    Falcon-1024 keygen is several times slower than Falcon-512.
    @End Performance_Hints
    @Security_Scope
    Functional test; non-cryptographic seeds.
    @End Security_Scope
    T.begin_suite(results, "falcon: falcon_1024 keygen/sign/verify round-trip")

    Note: 128 MiB for n=1024 keygen.
    Let arena be Arena.arena_create(134217728)
    T.assert_not_null(results, "arena created", arena)

    Let seed be Arena.arena_allocate(arena, 48)
    proc fill_seed with seed, 123

    Let pk_size be Falcon.falcon_pk_size(2)
    Let sk_size be Falcon.falcon_sk_size(2)
    Let pk_buf be Arena.arena_allocate(arena, pk_size)
    Let sk_buf be Arena.arena_allocate(arena, sk_size)

    Let kg_rc be Falcon.falcon_1024_keygen(arena, seed, pk_buf, sk_buf)
    T.assert_equal(results, "keygen rc == 1", kg_rc, 1)

    Let msg be Arena.arena_allocate(arena, 32)
    Let mi be 0
    While mi is less than 32:
        Memory.memory_set_byte(msg, mi, mi multiplied by 3)
        Set mi to mi plus 1
    End While

    Let nonce be Arena.arena_allocate(arena, 40)
    proc fill_nonce with nonce, 19

    Let sig_max be Falcon.falcon_sig_size_max(2)
    Let sig_buf be Arena.arena_allocate(arena, sig_max)
    Let sig_len be Falcon.falcon_1024_sign(arena, sk_buf, msg, 32, nonce, sig_buf)
    T.assert_greater_than(results, "sign returned positive length", sig_len, 0)

    Let ver_rc be Falcon.falcon_1024_verify(arena, pk_buf, msg, 32, sig_buf, sig_len)
    T.assert_equal(results, "verify rc == 1", ver_rc, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_falcon_512_wrong_message" that takes results as Integer returns Integer:
    @Reasoning
    Sign one message then verify against a different message -- the
    verifier MUST return 0.
    @End Reasoning
    @Implementation
    Standard round-trip, then verify a perturbed message buffer.
    @End Implementation
    @Performance_Hints
    Single keygen + sign + verify, no extra cost.
    @End Performance_Hints
    @Security_Scope
    Functional negative test.
    @End Security_Scope
    T.begin_suite(results, "falcon: falcon_512 wrong-message rejection")

    Let arena be Arena.arena_create(67108864)
    T.assert_not_null(results, "arena created", arena)

    Let seed be Arena.arena_allocate(arena, 48)
    proc fill_seed with seed, 100

    Let pk_size be Falcon.falcon_pk_size(1)
    Let sk_size be Falcon.falcon_sk_size(1)
    Let pk_buf be Arena.arena_allocate(arena, pk_size)
    Let sk_buf be Arena.arena_allocate(arena, sk_size)
    Falcon.falcon_512_keygen(arena, seed, pk_buf, sk_buf)

    Let msg_a be Arena.arena_allocate(arena, 16)
    Let msg_b be Arena.arena_allocate(arena, 16)
    Let mi be 0
    While mi is less than 16:
        Memory.memory_set_byte(msg_a, mi, mi)
        Memory.memory_set_byte(msg_b, mi, mi plus 1)
        Set mi to mi plus 1
    End While

    Let nonce be Arena.arena_allocate(arena, 40)
    proc fill_nonce with nonce, 33

    Let sig_max be Falcon.falcon_sig_size_max(1)
    Let sig_buf be Arena.arena_allocate(arena, sig_max)
    Let sig_len be Falcon.falcon_512_sign(arena, sk_buf, msg_a, 16, nonce, sig_buf)

    Let ver_wrong be Falcon.falcon_512_verify(arena, pk_buf, msg_b, 16, sig_buf, sig_len)
    T.assert_equal(results, "verify(msg_b, sig over msg_a) == 0", ver_wrong, 0)

    Let ver_right be Falcon.falcon_512_verify(arena, pk_buf, msg_a, 16, sig_buf, sig_len)
    T.assert_equal(results, "verify(msg_a, sig over msg_a) == 1", ver_right, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_falcon_512_wrong_key" that takes results as Integer returns Integer:
    @Reasoning
    A signature produced under sk_A must fail verify under pk_B from a
    different keypair.
    @End Reasoning
    @Implementation
    Two independent keygens with distinct seeds, one sign with sk_A, one
    verify with pk_B (and pk_A as control).
    @End Implementation
    @Performance_Hints
    Two keygens + sign + verify.
    @End Performance_Hints
    @Security_Scope
    Functional negative test.
    @End Security_Scope
    T.begin_suite(results, "falcon: falcon_512 wrong-key rejection")

    Let arena be Arena.arena_create(134217728)
    T.assert_not_null(results, "arena created", arena)

    Let pk_size be Falcon.falcon_pk_size(1)
    Let sk_size be Falcon.falcon_sk_size(1)

    Let seed_a be Arena.arena_allocate(arena, 48)
    proc fill_seed with seed_a, 1
    Let pk_a be Arena.arena_allocate(arena, pk_size)
    Let sk_a be Arena.arena_allocate(arena, sk_size)
    Falcon.falcon_512_keygen(arena, seed_a, pk_a, sk_a)

    Let seed_b be Arena.arena_allocate(arena, 48)
    proc fill_seed with seed_b, 99
    Let pk_b be Arena.arena_allocate(arena, pk_size)
    Let sk_b be Arena.arena_allocate(arena, sk_size)
    Falcon.falcon_512_keygen(arena, seed_b, pk_b, sk_b)

    Let msg be Arena.arena_allocate(arena, 16)
    Let mi be 0
    While mi is less than 16:
        Memory.memory_set_byte(msg, mi, mi plus 7)
        Set mi to mi plus 1
    End While

    Let nonce be Arena.arena_allocate(arena, 40)
    proc fill_nonce with nonce, 55

    Let sig_max be Falcon.falcon_sig_size_max(1)
    Let sig_buf be Arena.arena_allocate(arena, sig_max)
    Let sig_len be Falcon.falcon_512_sign(arena, sk_a, msg, 16, nonce, sig_buf)

    Let ver_a be Falcon.falcon_512_verify(arena, pk_a, msg, 16, sig_buf, sig_len)
    T.assert_equal(results, "verify with pk_a (correct) == 1", ver_a, 1)

    Let ver_b be Falcon.falcon_512_verify(arena, pk_b, msg, 16, sig_buf, sig_len)
    T.assert_equal(results, "verify with pk_b (wrong) == 0", ver_b, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_falcon_512_empty_message" that takes results as Integer returns Integer:
    @Reasoning
    Falcon-512 round-trip with a zero-length message, exercising the
    hash-to-point + sign + verify pipeline at the boundary.
    @End Reasoning
    @Implementation
    Same shape as the standard round-trip but with message_length = 0.
    The hash-to-point absorbs the salt and zero message bytes; the sampler
    runs as normal; the verify recomputes the same target.
    @End Implementation
    @Performance_Hints
    Identical cost to the standard round-trip.
    @End Performance_Hints
    @Security_Scope
    Functional boundary test.
    @End Security_Scope
    T.begin_suite(results, "falcon: falcon_512 empty-message round-trip")

    Let arena be Arena.arena_create(67108864)
    T.assert_not_null(results, "arena created", arena)

    Let seed be Arena.arena_allocate(arena, 48)
    proc fill_seed with seed, 200

    Let pk_size be Falcon.falcon_pk_size(1)
    Let sk_size be Falcon.falcon_sk_size(1)
    Let pk_buf be Arena.arena_allocate(arena, pk_size)
    Let sk_buf be Arena.arena_allocate(arena, sk_size)
    Falcon.falcon_512_keygen(arena, seed, pk_buf, sk_buf)

    Let msg be Arena.arena_allocate(arena, 8)
    Let nonce be Arena.arena_allocate(arena, 40)
    proc fill_nonce with nonce, 11

    Let sig_max be Falcon.falcon_sig_size_max(1)
    Let sig_buf be Arena.arena_allocate(arena, sig_max)
    Let sig_len be Falcon.falcon_512_sign(arena, sk_buf, msg, 0, nonce, sig_buf)
    T.assert_greater_than(results, "sign on empty message produced output", sig_len, 0)

    Let ver_rc be Falcon.falcon_512_verify(arena, pk_buf, msg, 0, sig_buf, sig_len)
    T.assert_equal(results, "verify empty-message sig == 1", ver_rc, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    proc test_falcon_512_roundtrip with results
    proc test_falcon_1024_roundtrip with results
    proc test_falcon_512_wrong_message with results
    proc test_falcon_512_wrong_key with results
    proc test_falcon_512_empty_message with results
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
