Note:
Structural tests for ML-DSA (FIPS 204).

Tests:
  1. Parameter accessors per FIPS 204 Table 1 for all three parameter sets.
  2. Key/signature sizes per FIPS 204 Table 2.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/pq/ml_dsa.runa" as MLDSA

Process called "test_param_accessors" that takes results as Integer returns Integer:
    T.begin_suite(results, "ml_dsa: parameter accessors")
    T.assert_equal(results, "ML-DSA-44 k=4", MLDSA.mldsa_k(1), 4)
    T.assert_equal(results, "ML-DSA-44 l=4", MLDSA.mldsa_l(1), 4)
    T.assert_equal(results, "ML-DSA-44 eta=2", MLDSA.mldsa_eta(1), 2)
    T.assert_equal(results, "ML-DSA-44 tau=39", MLDSA.mldsa_tau(1), 39)
    T.assert_equal(results, "ML-DSA-44 pk=1312", MLDSA.mldsa_pk_size(1), 1312)
    T.assert_equal(results, "ML-DSA-44 sk=2560", MLDSA.mldsa_sk_size(1), 2560)
    T.assert_equal(results, "ML-DSA-44 sig=2420", MLDSA.mldsa_sig_size(1), 2420)

    T.assert_equal(results, "ML-DSA-65 k=6", MLDSA.mldsa_k(2), 6)
    T.assert_equal(results, "ML-DSA-65 l=5", MLDSA.mldsa_l(2), 5)
    T.assert_equal(results, "ML-DSA-65 eta=4", MLDSA.mldsa_eta(2), 4)
    T.assert_equal(results, "ML-DSA-65 tau=49", MLDSA.mldsa_tau(2), 49)
    T.assert_equal(results, "ML-DSA-65 pk=1952", MLDSA.mldsa_pk_size(2), 1952)
    T.assert_equal(results, "ML-DSA-65 sig=3309", MLDSA.mldsa_sig_size(2), 3309)

    T.assert_equal(results, "ML-DSA-87 k=8", MLDSA.mldsa_k(3), 8)
    T.assert_equal(results, "ML-DSA-87 l=7", MLDSA.mldsa_l(3), 7)
    T.assert_equal(results, "ML-DSA-87 eta=2", MLDSA.mldsa_eta(3), 2)
    T.assert_equal(results, "ML-DSA-87 tau=60", MLDSA.mldsa_tau(3), 60)
    T.assert_equal(results, "ML-DSA-87 pk=2592", MLDSA.mldsa_pk_size(3), 2592)
    T.assert_equal(results, "ML-DSA-87 sig=4627", MLDSA.mldsa_sig_size(3), 4627)
    Return 1
End Process

Process called "test_decompose_round_trip" that takes results as Integer returns Integer:
    T.begin_suite(results, "ml_dsa: Decompose round-trip")
    Let gamma2 be 95232
    Let h1 be MLDSA.mldsa_decompose_high(123456, gamma2)
    Let l1 be MLDSA.mldsa_decompose_low(123456, gamma2)
    Let reconstructed be h1 multiplied by 2 multiplied by gamma2 plus l1
    Let q be 8380417
    Let rr be reconstructed modulo by q
    If rr is less than 0:
        Set rr to rr plus q
    End If
    T.assert_equal(results, "Decompose(123456) reconstructs", rr, 123456)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_param_accessors(results)
    test_decompose_round_trip(results)
    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
