    Memory.memory_set_byte(pt, 100, 110)
    Memory.memory_set_byte(pt, 101, 32)
    Memory.memory_set_byte(pt, 102, 119)
    Memory.memory_set_byte(pt, 103, 111)
    Memory.memory_set_byte(pt, 104, 117)
    Memory.memory_set_byte(pt, 105, 108)
    Memory.memory_set_byte(pt, 106, 100)
    Memory.memory_set_byte(pt, 107, 32)
    Memory.memory_set_byte(pt, 108, 98)
    Memory.memory_set_byte(pt, 109, 101)
    Memory.memory_set_byte(pt, 110, 32)
    Memory.memory_set_byte(pt, 111, 105)
    Memory.memory_set_byte(pt, 112, 116)
    Memory.memory_set_byte(pt, 113, 46)

    Let ct be Arena.arena_allocate(arena, pt_len)
    Let rc be ChaCha20.chacha20_encrypt(arena, key, nonce, 1, pt, pt_len, ct)
    T.assert_equal(results, "chacha20_encrypt returned 1", rc, 1)

    Note: Expected first 8 ciphertext bytes: 6e 2e 35 9a 25 68 f9 80
    Let c0 be Memory.memory_get_byte(ct, 0)
    Let c1 be Memory.memory_get_byte(ct, 1)
    Let c2 be Memory.memory_get_byte(ct, 2)
    Let c3 be Memory.memory_get_byte(ct, 3)
    Let c4 be Memory.memory_get_byte(ct, 4)
    Let c5 be Memory.memory_get_byte(ct, 5)
    Let c6 be Memory.memory_get_byte(ct, 6)
    Let c7 be Memory.memory_get_byte(ct, 7)
    T.assert_equal(results, "ct byte 0 = 0x6e", c0, 110)
    T.assert_equal(results, "ct byte 1 = 0x2e", c1, 46)
    T.assert_equal(results, "ct byte 2 = 0x35", c2, 53)
    T.assert_equal(results, "ct byte 3 = 0x9a", c3, 154)
    T.assert_equal(results, "ct byte 4 = 0x25", c4, 37)
    T.assert_equal(results, "ct byte 5 = 0x68", c5, 104)
    T.assert_equal(results, "ct byte 6 = 0xf9", c6, 249)
    T.assert_equal(results, "ct byte 7 = 0x80", c7, 128)

    Note: Expected last 2 ciphertext bytes: 87 4d
    Let c112 be Memory.memory_get_byte(ct, 112)
    Let c113 be Memory.memory_get_byte(ct, 113)
    T.assert_equal(results, "ct byte 112 = 0x87", c112, 135)
    T.assert_equal(results, "ct byte 113 = 0x4d", c113, 77)

    Note: Decrypt = re-encrypt with same params, restoring plaintext
    Let restored be Arena.arena_allocate(arena, pt_len)
    Let drc be ChaCha20.chacha20_encrypt(arena, key, nonce, 1, ct, pt_len, restored)
    T.assert_equal(results, "chacha20 decrypt returned 1", drc, 1)
    Let pt_match be compare_bytes(restored, pt, pt_len)
    T.assert_equal(results, "decryption matches original plaintext", pt_match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_chacha20_rfc8439_block_function(results)
    test_chacha20_rfc8439_encrypt_sunscreen(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
