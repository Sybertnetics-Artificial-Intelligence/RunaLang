Process called "compare_bigints" takes a as Integer, b as Integer returns Integer:
    Return BigInt.bigint_equals(a, b)
End Process

Note: KAT 1 - RFC 6979 P-256/SHA-256 sample vector r/s match
Process called "test_ecdsa_p256_rfc6979_sample_vector" that takes results as Integer returns Integer:
    T.begin_suite(results, "ECDSA P-256 RFC 6979 sample vector")
    Let arena be Arena.arena_create(33554432)
    Let priv be load_priv_key_x(arena)
    Let msg be load_message_sample(arena)
    Let sig_r be BigInt.bigint_alloc(arena, 20)
    Let sig_s be BigInt.bigint_alloc(arena, 20)
    Let sign_rc be ECDSA.ecdsa_p256_sign(arena, priv, msg, 6, sig_r, sig_s)
    T.assert_equal(results, "sign returned 1", sign_rc, 1)

    Let expected_r be load_expected_r_sample(arena)
    Let expected_s be load_expected_s_sample(arena)
    Let r_match be compare_bigints(sig_r, expected_r)
    Let s_match be compare_bigints(sig_s, expected_s)
    T.assert_equal(results, "r matches RFC 6979", r_match, 1)
    T.assert_equal(results, "s matches RFC 6979", s_match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note: KAT 2 - sign + verify self-consistency
Process called "test_ecdsa_p256_sign_verify_self" that takes results as Integer returns Integer:
    T.begin_suite(results, "ECDSA P-256 sign+verify self-consistency")
    Let arena be Arena.arena_create(33554432)
    Let priv be load_priv_key_x(arena)
    Let g be P256.curve_p256_generator(arena)
    Let pub be P256.curve_p256_point_alloc(arena)
    P256.curve_p256_scalar_mul(arena, pub, priv, g)

    Let msg be load_message_sample(arena)
    Let sig_r be BigInt.bigint_alloc(arena, 20)
    Let sig_s be BigInt.bigint_alloc(arena, 20)
    Let sign_rc be ECDSA.ecdsa_p256_sign(arena, priv, msg, 6, sig_r, sig_s)
    T.assert_equal(results, "sign returned 1", sign_rc, 1)

    Let verify_rc be ECDSA.ecdsa_p256_verify(arena, pub, msg, 6, sig_r, sig_s)
    T.assert_equal(results, "verify returned 1", verify_rc, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Note: KAT 3 - DER signature round-trip
Process called "test_ecdsa_signature_der_round_trip" that takes results as Integer returns Integer:
    T.begin_suite(results, "ECDSA signature DER round-trip")
    Let arena be Arena.arena_create(33554432)
    Let priv be load_priv_key_x(arena)
    Let msg be load_message_sample(arena)
    Let sig_r be BigInt.bigint_alloc(arena, 20)
    Let sig_s be BigInt.bigint_alloc(arena, 20)
    ECDSA.ecdsa_p256_sign(arena, priv, msg, 6, sig_r, sig_s)

    Let der_buf be Arena.arena_allocate(arena, 80)
    Let der_len be ECDSA.ecdsa_signature_to_der(arena, sig_r, sig_s, der_buf, 80)
    T.assert_greater_than(results, "DER length > 0", der_len, 0)

    Let outer_tag be Memory.memory_get_byte(der_buf, 0)
    T.assert_equal(results, "DER outer tag SEQUENCE 0x30", outer_tag, 48)

    Let recovered_r be BigInt.bigint_alloc(arena, 20)
    Let recovered_s be BigInt.bigint_alloc(arena, 20)
    Let parse_rc be ECDSA.ecdsa_signature_from_der(arena, der_buf, der_len, recovered_r, recovered_s)
    T.assert_equal(results, "DER parse returned 1", parse_rc, 1)

    Let r_match be compare_bigints(sig_r, recovered_r)
    Let s_match be compare_bigints(sig_s, recovered_s)
    T.assert_equal(results, "round-trip r preserved", r_match, 1)
    T.assert_equal(results, "round-trip s preserved", s_match, 1)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_ecdsa_p256_rfc6979_sample_vector(results)
    test_ecdsa_p256_sign_verify_self(results)
    test_ecdsa_signature_der_round_trip(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
