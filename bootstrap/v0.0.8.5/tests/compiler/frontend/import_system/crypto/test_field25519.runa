Note:
Unit tests for compiler/frontend/import_system/crypto/field25519.runa.

These tests exercise the radix-2^25.5 field arithmetic against simple
sanity properties (0+a=a, a-a=0, 1*a=a, freeze idempotence) and against
known test vectors that mediate the X25519 / Ed25519 surface tests in
test_x25519.runa and test_ed25519.runa.
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/field25519.runa" as Fe

Process called "fill_bytes" takes buf as Integer, length as Integer, value as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Memory.memory_set_byte(buf, i, value)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "test_alloc_and_zero" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_alloc + fe25519_set_zero")
    Let arena be Arena.arena_create(65536)
    Let fe be Fe.fe25519_alloc(arena)
    T.assert_not_null(results, "fe25519_alloc returns non-null", fe)

    Note: All limbs should be 0 right after allocation.
    Let limb0 be Memory.memory_get_int64(fe, 0)
    Let limb5 be Memory.memory_get_int64(fe, 40)
    T.assert_equal(results, "fresh fe limb 0 = 0", limb0, 0)
    T.assert_equal(results, "fresh fe limb 5 = 0", limb5, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_set_one" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_set_one")
    Let arena be Arena.arena_create(65536)
    Let fe be Fe.fe25519_alloc(arena)
    Fe.fe25519_set_one(fe)
    Let limb0 be Memory.memory_get_int64(fe, 0)
    Let limb1 be Memory.memory_get_int64(fe, 8)
    T.assert_equal(results, "fe25519_set_one: limb0 = 1", limb0, 1)
    T.assert_equal(results, "fe25519_set_one: limb1 = 0", limb1, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_pack_unpack_zero" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_pack / fe25519_unpack: zero round-trip")
    Let arena be Arena.arena_create(65536)
    Let fe be Fe.fe25519_alloc(arena)
    Let bytes_in be Arena.arena_allocate(arena, 32)
    Let bytes_out be Arena.arena_allocate(arena, 32)
    fill_bytes(bytes_in, 32, 0)
    Fe.fe25519_unpack(fe, bytes_in)
    Fe.fe25519_pack(fe, bytes_out)
    Let b0 be Memory.memory_get_byte(bytes_out, 0)
    Let b15 be Memory.memory_get_byte(bytes_out, 15)
    Let b31 be Memory.memory_get_byte(bytes_out, 31)
    T.assert_equal(results, "pack(unpack(0))[0] = 0", b0, 0)
    T.assert_equal(results, "pack(unpack(0))[15] = 0", b15, 0)
    T.assert_equal(results, "pack(unpack(0))[31] = 0", b31, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_pack_unpack_one" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_pack / fe25519_unpack: one round-trip")
    Let arena be Arena.arena_create(65536)
    Let fe be Fe.fe25519_alloc(arena)
    Let bytes_in be Arena.arena_allocate(arena, 32)
    Let bytes_out be Arena.arena_allocate(arena, 32)
    Memory.memory_set_byte(bytes_in, 0, 1)
    Let i be 1
    While i is less than 32:
        Memory.memory_set_byte(bytes_in, i, 0)
        Set i to i plus 1
    End While
    Fe.fe25519_unpack(fe, bytes_in)
    Fe.fe25519_pack(fe, bytes_out)
    Let b0 be Memory.memory_get_byte(bytes_out, 0)
    Let b1 be Memory.memory_get_byte(bytes_out, 1)
    Let b31 be Memory.memory_get_byte(bytes_out, 31)
    T.assert_equal(results, "pack(unpack(1))[0] = 1", b0, 1)
    T.assert_equal(results, "pack(unpack(1))[1] = 0", b1, 0)
    T.assert_equal(results, "pack(unpack(1))[31] = 0", b31, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_add_identity" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_add identity (a + 0 = a)")
    Let arena be Arena.arena_create(65536)
    Let a be Fe.fe25519_alloc(arena)
    Let zero be Fe.fe25519_alloc(arena)
    Let r be Fe.fe25519_alloc(arena)
    Fe.fe25519_set_one(a)
    Fe.fe25519_add(r, a, zero)
    Let limb0 be Memory.memory_get_int64(r, 0)
    T.assert_equal(results, "1 + 0 = 1 (limb 0)", limb0, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_sub_self" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_sub self (a - a = 0)")
    Let arena be Arena.arena_create(65536)
    Let a be Fe.fe25519_alloc(arena)
    Let r be Fe.fe25519_alloc(arena)
    Fe.fe25519_set_one(a)
    Fe.fe25519_sub(r, a, a)
    Let iz be Fe.fe25519_is_zero(r)
    T.assert_equal(results, "1 - 1 = 0", iz, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_mul_identity" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_mul identity (a * 1 = a)")
    Let arena be Arena.arena_create(65536)
    Let a be Fe.fe25519_alloc(arena)
    Let one_fe be Fe.fe25519_alloc(arena)
    Let r be Fe.fe25519_alloc(arena)
    Note: a = 7 stored as limb 0
    Memory.memory_set_qword(a, 0, 7)
    Fe.fe25519_set_one(one_fe)
    Fe.fe25519_mul(r, a, one_fe)
    Note: After mul, r should reduce to 7 in limb 0.
    Let limb0 be Memory.memory_get_int64(r, 0)
    T.assert_equal(results, "7 * 1 = 7 (limb 0)", limb0, 7)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_mul_by_zero" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_mul: a * 0 = 0")
    Let arena be Arena.arena_create(65536)
    Let a be Fe.fe25519_alloc(arena)
    Let zero be Fe.fe25519_alloc(arena)
    Let r be Fe.fe25519_alloc(arena)
    Fe.fe25519_set_one(a)
    Fe.fe25519_mul(r, a, zero)
    Let iz be Fe.fe25519_is_zero(r)
    T.assert_equal(results, "1 * 0 = 0", iz, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_inv_of_one" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_inv: 1^-1 = 1")
    Let arena be Arena.arena_create(262144)
    Let one_fe be Fe.fe25519_alloc(arena)
    Let inv_fe be Fe.fe25519_alloc(arena)
    Fe.fe25519_set_one(one_fe)
    Fe.fe25519_inv(arena, inv_fe, one_fe)
    Fe.fe25519_freeze(inv_fe)
    Let limb0 be Memory.memory_get_int64(inv_fe, 0)
    Let limb1 be Memory.memory_get_int64(inv_fe, 8)
    T.assert_equal(results, "inv(1) limb 0 = 1", limb0, 1)
    T.assert_equal(results, "inv(1) limb 1 = 0", limb1, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_cswap_zero_bit" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_cswap: bit=0 keeps both")
    Let arena be Arena.arena_create(65536)
    Let a be Fe.fe25519_alloc(arena)
    Let b be Fe.fe25519_alloc(arena)
    Memory.memory_set_qword(a, 0, 100)
    Memory.memory_set_qword(b, 0, 200)
    Fe.fe25519_cswap(a, b, 0)
    Let a_limb0 be Memory.memory_get_int64(a, 0)
    Let b_limb0 be Memory.memory_get_int64(b, 0)
    T.assert_equal(results, "cswap(0): a unchanged", a_limb0, 100)
    T.assert_equal(results, "cswap(0): b unchanged", b_limb0, 200)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_cswap_one_bit" takes results as Integer returns Integer:
    T.begin_suite(results, "fe25519_cswap: bit=1 swaps both")
    Let arena be Arena.arena_create(65536)
    Let a be Fe.fe25519_alloc(arena)
    Let b be Fe.fe25519_alloc(arena)
    Memory.memory_set_qword(a, 0, 100)
    Memory.memory_set_qword(b, 0, 200)
    Fe.fe25519_cswap(a, b, 1)
    Let a_limb0 be Memory.memory_get_int64(a, 0)
    Let b_limb0 be Memory.memory_get_int64(b, 0)
    T.assert_equal(results, "cswap(1): a now holds 200", a_limb0, 200)
    T.assert_equal(results, "cswap(1): b now holds 100", b_limb0, 100)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_alloc_and_zero(results)
    test_set_one(results)
    test_pack_unpack_zero(results)
    test_pack_unpack_one(results)
    test_add_identity(results)
    test_sub_self(results)
    test_mul_identity(results)
    test_mul_by_zero(results)
    test_inv_of_one(results)
    test_cswap_zero_bit(results)
    test_cswap_one_bit(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
