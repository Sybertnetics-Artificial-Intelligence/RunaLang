Process called "test_verify_rejects_null_pubkey" takes results as Integer returns Integer:
    T.begin_suite(results, "ed448_verify: rejects null public key")
    Let arena be Arena.arena_create(2097152)
    Let signature be Arena.arena_allocate(arena, 114)
    Let i be 0
    While i is less than 114:
        Memory.memory_set_byte(signature, i, 0)
        Set i to i plus 1
    End While
    Let rc be Ed.ed448_verify(arena, 0, signature, 0, signature, 0, signature)
    T.assert_equal(results, "verify(NULL pubkey) = 0", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_verify_rejects_oversized_context" takes results as Integer returns Integer:
    T.begin_suite(results, "ed448_verify: rejects context length > 255")
    Let arena be Arena.arena_create(2097152)
    Let pubkey be Arena.arena_allocate(arena, 57)
    Let signature be Arena.arena_allocate(arena, 114)
    Memory.memory_set_byte(pubkey, 0, 1)
    Let i be 1
    While i is less than 57:
        Memory.memory_set_byte(pubkey, i, 0)
        Set i to i plus 1
    End While
    Let j be 0
    While j is less than 114:
        Memory.memory_set_byte(signature, j, 0)
        Set j to j plus 1
    End While
    Let dummy_ctx be Arena.arena_allocate(arena, 1)
    Let rc be Ed.ed448_verify(arena, pubkey, signature, 0, dummy_ctx, 256, signature)
    T.assert_equal(results, "ctx_len > 255 rejected", rc, 0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_keygen_returns_one" takes results as Integer returns Integer:
    T.begin_suite(results, "ed448_keygen: RFC 8032 7.4 Test 1 seed succeeds")
    Let arena be Arena.arena_create(8388608)
    Let seed be Arena.arena_allocate(arena, 57)
    Let pubkey be Arena.arena_allocate(arena, 57)
    Let secret_114 be Arena.arena_allocate(arena, 114)
    set_test1_seed(seed)
    Let rc be Ed.ed448_keygen(arena, seed, pubkey, secret_114)
    T.assert_equal(results, "ed448_keygen returned 1", rc, 1)
    Note: Confirm secret[57..113] is the pubkey (per RFC 8032 5.2.5)
    Let p0 be Memory.memory_get_byte(pubkey, 0)
    Let s57 be Memory.memory_get_byte(secret_114, 57)
    T.assert_equal(results, "secret_114[57] = pubkey[0]", s57, p0)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "test_sign_verify_roundtrip" takes results as Integer returns Integer:
    T.begin_suite(results, "ed448 sign then verify roundtrip on RFC 8032 7.4 Test 1")
    Let arena be Arena.arena_create(16777216)
    Let seed be Arena.arena_allocate(arena, 57)
    Let pubkey be Arena.arena_allocate(arena, 57)
    Let secret_114 be Arena.arena_allocate(arena, 114)
    Let signature be Arena.arena_allocate(arena, 114)

    set_test1_seed(seed)
    Let kg be Ed.ed448_keygen(arena, seed, pubkey, secret_114)
    T.assert_equal(results, "keygen succeeded", kg, 1)

    Note: Empty message, empty context
    Let empty_msg be Arena.arena_allocate(arena, 1)
    Memory.memory_set_byte(empty_msg, 0, 0)
    Let empty_ctx be Arena.arena_allocate(arena, 1)
    Memory.memory_set_byte(empty_ctx, 0, 0)

    Let sg be Ed.ed448_sign(arena, secret_114, empty_msg, 0, empty_ctx, 0, signature)
    T.assert_equal(results, "sign returned 1", sg, 1)

    Let vf be Ed.ed448_verify(arena, pubkey, empty_msg, 0, empty_ctx, 0, signature)
    T.assert_equal(results, "verify of self-signed empty msg = 1", vf, 1)
    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()
    test_verify_rejects_null_pubkey(results)
    test_verify_rejects_oversized_context(results)
    test_keygen_returns_one(results)
    test_sign_verify_roundtrip(results)
    T.print_summary(results)
    Let failed be T.get_failed(results)
    T.destroy_test_results(results)
    Return failed
End Process
