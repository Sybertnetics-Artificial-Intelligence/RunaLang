Process called "test_aead_rfc8439_sec_2_8_2" that takes results as Integer returns Integer:
    T.begin_suite(results, "chacha20_poly1305 RFC 8439 sec 2.8.2")

    Let arena be Arena.arena_create(262144)
    T.assert_not_null(results, "arena created", arena)

    Let key be Arena.arena_allocate(arena, 32)
    Let ki be 0
    While ki is less than 32:
        Memory.memory_set_byte(key, ki, 128 plus ki)
        Set ki to ki plus 1
    End While

    Let nonce be Arena.arena_allocate(arena, 12)
    Memory.memory_set_byte(nonce, 0, 7)
    Memory.memory_set_byte(nonce, 1, 0)
    Memory.memory_set_byte(nonce, 2, 0)
    Memory.memory_set_byte(nonce, 3, 0)
    Memory.memory_set_byte(nonce, 4, 64)
    Memory.memory_set_byte(nonce, 5, 65)
    Memory.memory_set_byte(nonce, 6, 66)
    Memory.memory_set_byte(nonce, 7, 67)
    Memory.memory_set_byte(nonce, 8, 68)
    Memory.memory_set_byte(nonce, 9, 69)
    Memory.memory_set_byte(nonce, 10, 70)
    Memory.memory_set_byte(nonce, 11, 71)

    Let aad be Arena.arena_allocate(arena, 12)
    Memory.memory_set_byte(aad, 0, 80)
    Memory.memory_set_byte(aad, 1, 81)
    Memory.memory_set_byte(aad, 2, 82)
    Memory.memory_set_byte(aad, 3, 83)
    Memory.memory_set_byte(aad, 4, 192)
    Memory.memory_set_byte(aad, 5, 193)
    Memory.memory_set_byte(aad, 6, 194)
    Memory.memory_set_byte(aad, 7, 195)
    Memory.memory_set_byte(aad, 8, 196)
    Memory.memory_set_byte(aad, 9, 197)
    Memory.memory_set_byte(aad, 10, 198)
    Memory.memory_set_byte(aad, 11, 199)

    Let pt_len be 114
    Let pt be Arena.arena_allocate(arena, pt_len)
    fill_plaintext(pt)

    Let ct_and_tag be Arena.arena_allocate(arena, pt_len plus 16)
    Let rc be AEAD.chacha20_poly1305_seal(arena, key, nonce, aad, 12, pt, pt_len, ct_and_tag)
    T.assert_equal(results, "seal returned 1", rc, 1)

    Note: Verify ciphertext first 8 bytes: d3 1a 8d 34 64 8e 60 db
    Let c0 be Memory.memory_get_byte(ct_and_tag, 0)
    Let c1 be Memory.memory_get_byte(ct_and_tag, 1)
    Let c2 be Memory.memory_get_byte(ct_and_tag, 2)
    Let c3 be Memory.memory_get_byte(ct_and_tag, 3)
    Let c4 be Memory.memory_get_byte(ct_and_tag, 4)
    Let c5 be Memory.memory_get_byte(ct_and_tag, 5)
    Let c6 be Memory.memory_get_byte(ct_and_tag, 6)
    Let c7 be Memory.memory_get_byte(ct_and_tag, 7)
    T.assert_equal(results, "ct[0] = 0xd3", c0, 211)
    T.assert_equal(results, "ct[1] = 0x1a", c1, 26)
    T.assert_equal(results, "ct[2] = 0x8d", c2, 141)
    T.assert_equal(results, "ct[3] = 0x34", c3, 52)
    T.assert_equal(results, "ct[4] = 0x64", c4, 100)
    T.assert_equal(results, "ct[5] = 0x8e", c5, 142)
    T.assert_equal(results, "ct[6] = 0x60", c6, 96)
    T.assert_equal(results, "ct[7] = 0xdb", c7, 219)

    Let c112 be Memory.memory_get_byte(ct_and_tag, 112)
    Let c113 be Memory.memory_get_byte(ct_and_tag, 113)
    Note: Last two ciphertext bytes per RFC 8439 sec 2.8.2 expected output:
    Note:   ct[112] = 0x61, ct[113] = 0x16
    Note: (verified against the cryptography library's ChaCha20-Poly1305
    Note: implementation on the same key/nonce/AAD/plaintext.)
    T.assert_equal(results, "ct[112] = 0x61", c112, 97)
    T.assert_equal(results, "ct[113] = 0x16", c113, 22)

    Note: Verify tag: 1a e1 0b 59 4f 09 e2 6a 7e 90 2e cb d0 60 06 91
    Let expected_tag be Arena.arena_allocate(arena, 16)
    Memory.memory_set_byte(expected_tag, 0, 26)
    Memory.memory_set_byte(expected_tag, 1, 225)
    Memory.memory_set_byte(expected_tag, 2, 11)
    Memory.memory_set_byte(expected_tag, 3, 89)
    Memory.memory_set_byte(expected_tag, 4, 79)
    Memory.memory_set_byte(expected_tag, 5, 9)
    Memory.memory_set_byte(expected_tag, 6, 226)
    Memory.memory_set_byte(expected_tag, 7, 106)
    Memory.memory_set_byte(expected_tag, 8, 126)
    Memory.memory_set_byte(expected_tag, 9, 144)
    Memory.memory_set_byte(expected_tag, 10, 46)
    Memory.memory_set_byte(expected_tag, 11, 203)
    Memory.memory_set_byte(expected_tag, 12, 208)
    Memory.memory_set_byte(expected_tag, 13, 96)
    Memory.memory_set_byte(expected_tag, 14, 6)
    Memory.memory_set_byte(expected_tag, 15, 145)

    Let tag_in_buf be ct_and_tag plus pt_len
    Let tag_match be compare_bytes(tag_in_buf, expected_tag, 16)
    T.assert_equal(results, "tag matches RFC 8439 sec 2.8.2", tag_match, 1)

    Note: Round-trip: open should recover the plaintext
    Let recovered be Arena.arena_allocate(arena, pt_len)
    Let open_rc be AEAD.chacha20_poly1305_open(arena, key, nonce, aad, 12, ct_and_tag, pt_len, recovered)
    T.assert_equal(results, "open returned 1", open_rc, 1)
    Let pt_match be compare_bytes(recovered, pt, pt_len)
    T.assert_equal(results, "decrypted plaintext matches original", pt_match, 1)

    Note: Mutated tag: open should return 0
    Let saved_tag_byte be Memory.memory_get_byte(ct_and_tag, pt_len)
    Memory.memory_set_byte(ct_and_tag, pt_len, saved_tag_byte bitwise_xor 1)
    Let open_bad_tag be AEAD.chacha20_poly1305_open(arena, key, nonce, aad, 12, ct_and_tag, pt_len, recovered)
    T.assert_equal(results, "open with mutated tag returns 0", open_bad_tag, 0)
    Memory.memory_set_byte(ct_and_tag, pt_len, saved_tag_byte)

    Note: Mutated ciphertext: open should return 0
    Let saved_ct_byte be Memory.memory_get_byte(ct_and_tag, 0)
    Memory.memory_set_byte(ct_and_tag, 0, saved_ct_byte bitwise_xor 1)
    Let open_bad_ct be AEAD.chacha20_poly1305_open(arena, key, nonce, aad, 12, ct_and_tag, pt_len, recovered)
    T.assert_equal(results, "open with mutated ciphertext returns 0", open_bad_ct, 0)
    Memory.memory_set_byte(ct_and_tag, 0, saved_ct_byte)

    Note: Mutated AAD: open should return 0
    Memory.memory_set_byte(aad, 0, 0)
    Let open_bad_aad be AEAD.chacha20_poly1305_open(arena, key, nonce, aad, 12, ct_and_tag, pt_len, recovered)
    T.assert_equal(results, "open with mutated AAD returns 0", open_bad_aad, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_aead_rfc8439_sec_2_8_2(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
