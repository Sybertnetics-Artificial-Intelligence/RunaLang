    Let tag_match be compare_bytes(tag, expected_tag, 16)
    T.assert_equal(results, "TC16 tag matches McGrew TC16", tag_match, 1)

    Note: Round-trip: open with valid tag yields original plaintext
    Let recovered be Arena.arena_allocate(arena, 60)
    zero_buffer(recovered, 60)
    Let open_rc be GCM.aes_gcm_open(arena, key, 32, iv, aad, 20, ct, 60, tag, recovered)
    T.assert_equal(results, "TC16 open with valid tag returns 1", open_rc, 1)
    Let pt_match be compare_bytes(recovered, pt, 60)
    T.assert_equal(results, "TC16 decrypt restores plaintext", pt_match, 1)

    Note: Open with mutated tag returns 0
    Let bad_tag be Arena.arena_allocate(arena, 16)
    Let bi be 0
    While bi is less than 16:
        Let tb be Memory.memory_get_byte(tag, bi)
        Memory.memory_set_byte(bad_tag, bi, tb)
        Set bi to bi plus 1
    End While
    Let orig0 be Memory.memory_get_byte(bad_tag, 0)
    Memory.memory_set_byte(bad_tag, 0, orig0 bitwise_xor 1)
    Let recovered2 be Arena.arena_allocate(arena, 60)
    zero_buffer(recovered2, 60)
    Let bad_open be GCM.aes_gcm_open(arena, key, 32, iv, aad, 20, ct, 60, bad_tag, recovered2)
    T.assert_equal(results, "TC16 open with mutated tag returns 0", bad_open, 0)

    Note: Open with mutated ciphertext returns 0
    Let bad_ct be Arena.arena_allocate(arena, 60)
    Let ci be 0
    While ci is less than 60:
        Let cb be Memory.memory_get_byte(ct, ci)
        Memory.memory_set_byte(bad_ct, ci, cb)
        Set ci to ci plus 1
    End While
    Let orig_c0 be Memory.memory_get_byte(bad_ct, 0)
    Memory.memory_set_byte(bad_ct, 0, orig_c0 bitwise_xor 1)
    Let recovered3 be Arena.arena_allocate(arena, 60)
    zero_buffer(recovered3, 60)
    Let bad_open_ct be GCM.aes_gcm_open(arena, key, 32, iv, aad, 20, bad_ct, 60, tag, recovered3)
    T.assert_equal(results, "TC16 open with mutated CT returns 0", bad_open_ct, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_aes256_gcm_mcgrew_tc13_empty(results)
    test_aes256_gcm_cavp_aad_only(results)
    test_aes256_gcm_mcgrew_tc16_full(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
