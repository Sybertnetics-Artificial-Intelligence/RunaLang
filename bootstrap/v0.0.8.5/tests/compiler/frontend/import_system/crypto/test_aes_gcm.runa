    Memory.memory_set_byte(aad, 15, 243)

    Let tag be Arena.arena_allocate(arena, 16)
    zero_buffer(tag, 16)

    Let rc be GCM.aes_gcm_seal(arena, key, 32, iv, aad, 16, 0, 0, 0, tag)
    T.assert_equal(results, "CAVP AAD-only seal rc=1", rc, 1)

    Let expected_tag be Arena.arena_allocate(arena, 16)
    Memory.memory_set_byte(expected_tag, 0, 173)
    Memory.memory_set_byte(expected_tag, 1, 164)
    Memory.memory_set_byte(expected_tag, 2, 71)
    Memory.memory_set_byte(expected_tag, 3, 179)
    Memory.memory_set_byte(expected_tag, 4, 231)
    Memory.memory_set_byte(expected_tag, 5, 44)
    Memory.memory_set_byte(expected_tag, 6, 199)
    Memory.memory_set_byte(expected_tag, 7, 43)
    Memory.memory_set_byte(expected_tag, 8, 19)
    Memory.memory_set_byte(expected_tag, 9, 145)
    Memory.memory_set_byte(expected_tag, 10, 196)
    Memory.memory_set_byte(expected_tag, 11, 241)
    Memory.memory_set_byte(expected_tag, 12, 238)
    Memory.memory_set_byte(expected_tag, 13, 45)
    Memory.memory_set_byte(expected_tag, 14, 164)
    Memory.memory_set_byte(expected_tag, 15, 103)

    Let tag_match be compare_bytes(tag, expected_tag, 16)
    T.assert_equal(results, "CAVP AAD-only tag matches", tag_match, 1)

    Let open_rc be GCM.aes_gcm_open(arena, key, 32, iv, aad, 16, 0, 0, tag, 0)
    T.assert_equal(results, "CAVP AAD-only open with valid tag returns 1", open_rc, 1)

    Note: Mutate tag and verify open fails
    Let bad_tag be Arena.arena_allocate(arena, 16)
    Let bi be 0
    While bi is less than 16:
        Let tb be Memory.memory_get_byte(tag, bi)
        Memory.memory_set_byte(bad_tag, bi, tb)
        Set bi to bi plus 1
    End While
    Let orig0 be Memory.memory_get_byte(bad_tag, 0)
    Memory.memory_set_byte(bad_tag, 0, orig0 bitwise_xor 1)
    Let bad_open be GCM.aes_gcm_open(arena, key, 32, iv, aad, 16, 0, 0, bad_tag, 0)
    T.assert_equal(results, "open with mutated tag returns 0", bad_open, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

