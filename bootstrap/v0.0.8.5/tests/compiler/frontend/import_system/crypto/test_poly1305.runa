Note:
Unit tests for compiler/frontend/import_system/crypto/poly1305.runa.

Test vectors:
  RFC 8439 section 2.5.2 (Poly1305 example)
    Key: 85:d6:be:78:57:55:6d:33:7f:44:52:fe:42:d5:06:a8
         01:03:80:8a:fb:0d:b2:fd:4a:bf:f6:af:41:49:f5:1b
    Message: "Cryptographic Forum Research Group" (34 bytes ASCII)
    Tag:  a8:06:1d:c1:30:51:36:c6:c2:2b:8b:af:0c:01:27:a9
:End Note

Import "tests/test_utils.runa" as T
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/import_system/crypto/poly1305.runa" as Poly

Process called "compare_bytes" takes a as Integer, b as Integer, length as Integer returns Integer:
    Let i be 0
    While i is less than length:
        Let ba be Memory.memory_get_byte(a, i)
        Let bb be Memory.memory_get_byte(b, i)
        If ba is not equal to bb:
            Return 0
        End If
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "test_poly1305_rfc8439_sec_2_5_2" that takes results as Integer returns Integer:
    T.begin_suite(results, "poly1305 RFC 8439 sec 2.5.2")

    Let arena be Arena.arena_create(65536)
    T.assert_not_null(results, "arena created", arena)

    Let key be Arena.arena_allocate(arena, 32)
    Memory.memory_set_byte(key, 0, 133)
    Memory.memory_set_byte(key, 1, 214)
    Memory.memory_set_byte(key, 2, 190)
    Memory.memory_set_byte(key, 3, 120)
    Memory.memory_set_byte(key, 4, 87)
    Memory.memory_set_byte(key, 5, 85)
    Memory.memory_set_byte(key, 6, 109)
    Memory.memory_set_byte(key, 7, 51)
    Memory.memory_set_byte(key, 8, 127)
    Memory.memory_set_byte(key, 9, 68)
    Memory.memory_set_byte(key, 10, 82)
    Memory.memory_set_byte(key, 11, 254)
    Memory.memory_set_byte(key, 12, 66)
    Memory.memory_set_byte(key, 13, 213)
    Memory.memory_set_byte(key, 14, 6)
    Memory.memory_set_byte(key, 15, 168)
    Memory.memory_set_byte(key, 16, 1)
    Memory.memory_set_byte(key, 17, 3)
    Memory.memory_set_byte(key, 18, 128)
    Memory.memory_set_byte(key, 19, 138)
    Memory.memory_set_byte(key, 20, 251)
    Memory.memory_set_byte(key, 21, 13)
    Memory.memory_set_byte(key, 22, 178)
    Memory.memory_set_byte(key, 23, 253)
    Memory.memory_set_byte(key, 24, 74)
    Memory.memory_set_byte(key, 25, 191)
    Memory.memory_set_byte(key, 26, 246)
    Memory.memory_set_byte(key, 27, 175)
    Memory.memory_set_byte(key, 28, 65)
    Memory.memory_set_byte(key, 29, 73)
    Memory.memory_set_byte(key, 30, 245)
    Memory.memory_set_byte(key, 31, 27)

    Note: Message "Cryptographic Forum Research Group" - 34 bytes ASCII
    Let msg_len be 34
    Let msg be Arena.arena_allocate(arena, msg_len)
    Memory.memory_set_byte(msg, 0, 67)
    Memory.memory_set_byte(msg, 1, 114)
    Memory.memory_set_byte(msg, 2, 121)
    Memory.memory_set_byte(msg, 3, 112)
    Memory.memory_set_byte(msg, 4, 116)
    Memory.memory_set_byte(msg, 5, 111)
    Memory.memory_set_byte(msg, 6, 103)
    Memory.memory_set_byte(msg, 7, 114)
    Memory.memory_set_byte(msg, 8, 97)
    Memory.memory_set_byte(msg, 9, 112)
    Memory.memory_set_byte(msg, 10, 104)
    Memory.memory_set_byte(msg, 11, 105)
    Memory.memory_set_byte(msg, 12, 99)
    Memory.memory_set_byte(msg, 13, 32)
    Memory.memory_set_byte(msg, 14, 70)
    Memory.memory_set_byte(msg, 15, 111)
    Memory.memory_set_byte(msg, 16, 114)
    Memory.memory_set_byte(msg, 17, 117)
    Memory.memory_set_byte(msg, 18, 109)
    Memory.memory_set_byte(msg, 19, 32)
    Memory.memory_set_byte(msg, 20, 82)
    Memory.memory_set_byte(msg, 21, 101)
    Memory.memory_set_byte(msg, 22, 115)
    Memory.memory_set_byte(msg, 23, 101)
    Memory.memory_set_byte(msg, 24, 97)
    Memory.memory_set_byte(msg, 25, 114)
    Memory.memory_set_byte(msg, 26, 99)
    Memory.memory_set_byte(msg, 27, 104)
    Memory.memory_set_byte(msg, 28, 32)
    Memory.memory_set_byte(msg, 29, 71)
    Memory.memory_set_byte(msg, 30, 114)
    Memory.memory_set_byte(msg, 31, 111)
    Memory.memory_set_byte(msg, 32, 117)
    Memory.memory_set_byte(msg, 33, 112)

    Let tag be Arena.arena_allocate(arena, 16)
    Let rc be Poly.poly1305_mac(arena, key, msg, msg_len, tag)
    T.assert_equal(results, "poly1305_mac returned 1", rc, 1)

    Let expected be Arena.arena_allocate(arena, 16)
    Memory.memory_set_byte(expected, 0, 168)
    Memory.memory_set_byte(expected, 1, 6)
    Memory.memory_set_byte(expected, 2, 29)
    Memory.memory_set_byte(expected, 3, 193)
    Memory.memory_set_byte(expected, 4, 48)
    Memory.memory_set_byte(expected, 5, 81)
    Memory.memory_set_byte(expected, 6, 54)
    Memory.memory_set_byte(expected, 7, 198)
    Memory.memory_set_byte(expected, 8, 194)
    Memory.memory_set_byte(expected, 9, 43)
    Memory.memory_set_byte(expected, 10, 139)
    Memory.memory_set_byte(expected, 11, 175)
    Memory.memory_set_byte(expected, 12, 12)
    Memory.memory_set_byte(expected, 13, 1)
    Memory.memory_set_byte(expected, 14, 39)
    Memory.memory_set_byte(expected, 15, 169)

    Let t0 be Memory.memory_get_byte(tag, 0)
    Let t1 be Memory.memory_get_byte(tag, 1)
    Let t2 be Memory.memory_get_byte(tag, 2)
    Let t3 be Memory.memory_get_byte(tag, 3)
    T.assert_equal(results, "tag byte 0 = 0xa8", t0, 168)
    T.assert_equal(results, "tag byte 1 = 0x06", t1, 6)
    T.assert_equal(results, "tag byte 2 = 0x1d", t2, 29)
    T.assert_equal(results, "tag byte 3 = 0xc1", t3, 193)
    Let t15 be Memory.memory_get_byte(tag, 15)
    T.assert_equal(results, "tag byte 15 = 0xa9", t15, 169)

    Let match be compare_bytes(tag, expected, 16)
    T.assert_equal(results, "full 16-byte tag matches RFC 8439 sec 2.5.2", match, 1)

    Note: Verify path: correct tag returns 1
    Let v_ok be Poly.poly1305_verify(arena, key, msg, msg_len, expected)
    T.assert_equal(results, "verify of correct tag returns 1", v_ok, 1)

    Note: Verify path: mutated tag returns 0
    Memory.memory_set_byte(expected, 0, 0)
    Let v_bad be Poly.poly1305_verify(arena, key, msg, msg_len, expected)
    T.assert_equal(results, "verify of mutated tag returns 0", v_bad, 0)

    Arena.arena_destroy(arena)
    Return 1
End Process

Process called "main" returns Integer:
    Let results be T.create_test_results()

    test_poly1305_rfc8439_sec_2_5_2(results)

    T.print_summary(results)
    Let exit_code be T.get_failed(results)
    T.destroy_test_results(results)
    Return exit_code
End Process
