Note: ============================================================================
Note: Round-Trip Tests (CMake→HIR→CMake)
Note: ============================================================================

Process called "test_round_trip_simple" takes suite as Integer returns Integer:
    Note: Test round-trip translation preserves semantics

    Let source be proc string_from_cstring from StringCore with "set(VAR value)"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser
    Let hir be proc translate_cmake_to_hir from Translator with ast
    Let output be proc translate_hir_to_cmake from Backend with hir

    Return proc assert_contains from suite, "Round-trip simple command", output, "set"
End Process

Process called "test_round_trip_if_else" takes suite as Integer returns Integer:
    Note: Test round-trip with if/else

    Let source be proc string_from_cstring from StringCore with "if(CONDITION)\n  set(VAR1 value1)\nelse()\n  set(VAR2 value2)\nendif()"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser
    Let hir be proc translate_cmake_to_hir from Translator with ast
    Let output be proc translate_hir_to_cmake from Backend with hir

    Let has_if be proc string_contains from StringCore with output, "if"
    Let has_else be proc string_contains from StringCore with output, "else"
    Let has_endif be proc string_contains from StringCore with output, "endif"
    Let all_present be has_if

    If has_else is equal to 1:
        If has_endif is equal to 1:
            Set all_present to 1
        Otherwise:
            Set all_present to 0
        End If
    Otherwise:
        Set all_present to 0
    End If

    Return proc assert_true from suite, "Round-trip if/else structure", all_present, "if/else/endif present"
End Process

Process called "test_round_trip_foreach" takes suite as Integer returns Integer:
    Note: Test round-trip with foreach loop

    Let source be proc string_from_cstring from StringCore with "foreach(item items)\n  message(${item})\nendforeach()"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser
    Let hir be proc translate_cmake_to_hir from Translator with ast
    Let output be proc translate_hir_to_cmake from Backend with hir

    Let has_foreach be proc string_contains from StringCore with output, "foreach"
    Let has_endforeach be proc string_contains from StringCore with output, "endforeach"
    Let both_present be has_foreach

    If has_endforeach is equal to 1:
        Set both_present to 1
    Otherwise:
        Set both_present to 0
    End If

    Return proc assert_true from suite, "Round-trip foreach loop", both_present, "foreach/endforeach present"
End Process

Process called "run_round_trip_tests" returns Integer:
    Note: Run all round-trip tests

    Let suite_name be proc string_from_cstring from StringCore with "CMake Round-Trip Tests"
    Let suite be proc create_test_suite from suite_name

    proc test_log from Test with "=== CMake Round-Trip Tests ==="
    proc test_round_trip_simple from suite
    proc test_round_trip_if_else from suite
    proc test_round_trip_foreach from suite

    Return suite
End Process

Note: ============================================================================
Note: Integration Tests (Complete CMake Files)
Note: ============================================================================

Process called "test_integration_basic_project" takes suite as Integer returns Integer:
    Note: Test complete basic CMake project

    Let source be proc string_from_cstring from StringCore with "cmake_minimum_required(VERSION 3.10)\nproject(MyProject)\nset(CMAKE_CXX_STANDARD 17)\nadd_executable(myapp main.cpp)"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser
    Let hir be proc translate_cmake_to_hir from Translator with ast
    Let output be proc translate_hir_to_cmake from Backend with hir

    Let is_valid be proc string_length from StringCore with output is greater than 0

    Return proc assert_true from suite, "Integration: basic project", is_valid, "Non-empty output"
End Process

Process called "test_integration_with_functions" takes suite as Integer returns Integer:
    Note: Test CMake file with functions

    Let source be proc string_from_cstring from StringCore with "function(add_lib name)\n  add_library(${name} ${ARGN})\nendfunction()\nadd_lib(mylib src1.cpp src2.cpp)"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser
    Let hir be proc translate_cmake_to_hir from Translator with ast
    Let output be proc translate_hir_to_cmake from Backend with hir

    Let is_valid be proc string_length from StringCore with output is greater than 0

    Return proc assert_true from suite, "Integration: with functions", is_valid, "Non-empty output"
End Process

Process called "run_integration_tests" returns Integer:
    Note: Run all integration tests

    Let suite_name be proc string_from_cstring from StringCore with "CMake Integration Tests"
    Let suite be proc create_test_suite from suite_name

    proc test_log from Test with "=== CMake Integration Tests ==="
    proc test_integration_basic_project from suite
    proc test_integration_with_functions from suite

    Return suite
End Process

Note: ============================================================================
Note: Main Test Runner
Note: ============================================================================

Process called "print_test_results" takes all_suites as Integer returns Integer:
    Note: Print summary of all test results

    proc test_log from Test with "\n=== Test Results Summary ===\n"

    Let total_passed be 0
    Let total_failed be 0
    Let suite_count be proc length from List with all_suites
    Let i be 0

    While i is less than suite_count:
        Let suite be proc get from List with all_suites, i

        If suite is not equal to 0:
            Let suite_name be proc memory_get_int64 from Layout with suite, 0
            Let passed be proc memory_get_int64 from Layout with suite, 8
            Let failed be proc memory_get_int64 from Layout with suite, 16

            proc test_log from Test with suite_name
            proc test_log from Test with ": "
            Let passed_str be proc int_to_string from StringCore with passed
            proc test_log from Test with passed_str
            proc test_log from Test with " passed, "
            Let failed_str be proc int_to_string from StringCore with failed
            proc test_log from Test with failed_str
            proc test_log from Test with " failed\n"

            Set total_passed to total_passed plus passed
            Set total_failed to total_failed plus failed
        End If

        Set i to i plus 1
    End While

    proc test_log from Test with "\nTotal: "
    Let total_passed_str be proc int_to_string from StringCore with total_passed
    proc test_log from Test with total_passed_str
    proc test_log from Test with " passed, "
    Let total_failed_str be proc int_to_string from StringCore with total_failed
    proc test_log from Test with total_failed_str
    proc test_log from Test with " failed\n"

    Return 1
End Process

Process called "check_all_passed" takes all_suites as Integer returns Integer:
    Note: Check if all tests passed

    Let suite_count be proc length from List with all_suites
    Let i be 0

    While i is less than suite_count:
        Let suite be proc get from List with all_suites, i

        If suite is not equal to 0:
            Let failed be proc memory_get_int64 from Layout with suite, 16

            If failed is greater than 0:
                Return 0  Note: At least one test failed
            End If
        End If

        Set i to i plus 1
    End While

    Return 1  Note: All tests passed
End Process

Process called "run_all_tests" returns Integer:
    Note: Run all CMake Translation test suites

    proc test_log from Test with "\n╔════════════════════════════════════════╗\n"
    proc test_log from Test with "║  CMake Translation Test Suite      ║\n"
    proc test_log from Test with "╚════════════════════════════════════════╝\n\n"

    Let all_suites be proc create from List

    Let lexer_suite be proc run_lexer_tests
    proc append from List with all_suites, lexer_suite

    Let parser_suite be proc run_parser_tests
    proc append from List with all_suites, parser_suite

    Let translator_suite be proc run_translator_tests
    proc append from List with all_suites, translator_suite

    Let backend_suite be proc run_backend_tests
    proc append from List with all_suites, backend_suite

    Let round_trip_suite be proc run_round_trip_tests
    proc append from List with all_suites, round_trip_suite

    Let integration_suite be proc run_integration_tests
    proc append from List with all_suites, integration_suite

    proc print_test_results from all_suites

    Return proc check_all_passed from all_suites
End Process

Note: Entry point
proc run_all_tests
