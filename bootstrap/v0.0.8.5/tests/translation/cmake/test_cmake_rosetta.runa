Note:
CMake Translation Tests - Comprehensive test suite

This file provides complete testing for the CMake translation system:
- Lexer tests (tokenization of all CMake syntax)
- Parser tests (AST construction for all CMake constructs)
- Translator tests (CMake→HIR translation)
- Backend tests (HIR→CMake generation)
- Round-trip tests (CMake→HIR→CMake)
- Integration tests (complete CMake files)

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/cmake/cmake_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/cmake/cmake_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/cmake/cmake_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/cmake/hir_to_cmake.runa
- compiler/frontend/primitives/test_framework.runa
- compiler/frontend/primitives/collections/list.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/cmake/cmake_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/cmake/cmake_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/cmake/cmake_to_hir.runa" as Translator
Import "compiler/middle/gungnir/hir/translation/backends/cmake/hir_to_cmake.runa" as Backend
Import "compiler/frontend/primitives/test_framework.runa" as Test
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test Result Tracking
Note: ============================================================================

Type called "TestSuite":
    name as Integer
    tests_passed as Integer
    tests_failed as Integer
    test_names as Integer  Note: List of test names
End Type

Type called "TestResult":
    test_name as Integer
    passed as Integer
    message as Integer
End Type

Process called "create_test_suite" takes suite_name as Integer returns Integer:
    Note: Create test suite

    Let suite be proc allocate from Layout with 32

    If suite is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with suite, 0, suite_name
    proc memory_set_int64 from Layout with suite, 8, 0  Note: tests_passed
    proc memory_set_int64 from Layout with suite, 16, 0  Note: tests_failed
    Let test_names be proc create from List
    proc memory_set_int64 from Layout with suite, 24, test_names

    Return suite
End Process

Process called "assert_true" takes suite as Integer, test_name as Integer, condition as Integer, message as Integer returns Integer:
    Note: Assert that condition is true

    If condition is equal to 1:
        Let passed be proc memory_get_int64 from Layout with suite, 8
        Set passed to passed plus 1
        proc memory_set_int64 from Layout with suite, 8, passed
        proc test_log from Test with test_name
        proc test_log from Test with " PASSED"
        Return 1
    Otherwise:
        Let failed be proc memory_get_int64 from Layout with suite, 16
        Set failed to failed plus 1
        proc memory_set_int64 from Layout with suite, 16, failed
        proc test_log from Test with test_name
        proc test_log from Test with " FAILED: "
        proc test_log from Test with message
        Return 0
    End If
End Process

Process called "assert_contains" takes suite as Integer, test_name as Integer, haystack as Integer, needle as Integer returns Integer:
    Note: Assert that haystack contains needle

    If haystack is equal to 0:
        Return proc assert_true from suite, test_name, 0, "Haystack is null"
    End If

    If needle is equal to 0:
        Return proc assert_true from suite, test_name, 1, "Needle is null (vacuous truth)"
    End If

    Let contains be proc string_contains from StringCore with haystack, needle

    If contains is equal to 1:
        Return proc assert_true from suite, test_name, 1, "Contains needle"
    Otherwise:
        Return proc assert_true from suite, test_name, 0, "Does not contain needle"
    End If
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_lexer_keywords" takes suite as Integer returns Integer:
    Note: Test CMake keyword tokenization

    Let source be proc string_from_cstring from StringCore with "cmake_minimum_required set if else endif foreach endforeach while endwhile function endfunction macro endmacro"
    Let lexer be proc create_lexer from Lexer with source

    Note: Should tokenize multiple keywords
    Let token_count be 0
    Let token be proc next_token from Lexer with lexer

    While token is not equal to 0:
        Let token_type be proc memory_get_int64 from Layout with token, 0

        If token_type is not equal to Lexer::TOKEN_EOF:
            Set token_count to token_count plus 1
        End If

        If token_type is equal to Lexer::TOKEN_EOF:
            Set token to 0
        Otherwise:
            Set token to proc next_token from Lexer with lexer
        End If
    End While

    Return proc assert_true from suite, "Lexer tokenizes keywords", token_count is greater than 10, "Token count > 10"
End Process

Process called "test_lexer_identifiers" takes suite as Integer returns Integer:
    Note: Test identifier tokenization

    Let source be proc string_from_cstring from StringCore with "MY_VAR Project_Name _internal"
    Let lexer be proc create_lexer from Lexer with source

    Let token be proc next_token from Lexer with lexer
    Let token_type be proc memory_get_int64 from Layout with token, 0

    Return proc assert_true from suite, "Lexer tokenizes identifiers", token_type is equal to Lexer::TOKEN_IDENTIFIER, "First token is identifier"
End Process

Process called "test_lexer_strings" takes suite as Integer returns Integer:
    Note: Test string literal tokenization

    Let source be proc string_from_cstring from StringCore with "\"Hello World\" \"Path/To/File\""
    Let lexer be proc create_lexer from Lexer with source

    Let token be proc next_token from Lexer with lexer
    Let token_type be proc memory_get_int64 from Layout with token, 0

    Return proc assert_true from suite, "Lexer tokenizes strings", token_type is equal to Lexer::TOKEN_STRING, "First token is string"
End Process

Process called "test_lexer_variables" takes suite as Integer returns Integer:
    Note: Test variable reference tokenization

    Let source be proc string_from_cstring from StringCore with "${VAR_NAME} ${PROJECT_VERSION}"
    Let lexer be proc create_lexer from Lexer with source

    Let token be proc next_token from Lexer with lexer
    Let token_type be proc memory_get_int64 from Layout with token, 0

    Return proc assert_true from suite, "Lexer tokenizes variables", token_type is equal to Lexer::TOKEN_VARIABLE, "First token is variable"
End Process

Process called "run_lexer_tests" returns Integer:
    Note: Run all lexer tests

    Let suite_name be proc string_from_cstring from StringCore with "CMake Lexer Tests"
    Let suite be proc create_test_suite from suite_name

    proc test_log from Test with "=== CMake Lexer Tests ==="
    proc test_lexer_keywords from suite
    proc test_lexer_identifiers from suite
    proc test_lexer_strings from suite
    proc test_lexer_variables from suite

    Return suite
End Process

Note: ============================================================================
Note: Parser Tests
Note: ============================================================================

Process called "test_parser_simple_command" takes suite as Integer returns Integer:
    Note: Test parsing simple command

    Let source be proc string_from_cstring from StringCore with "set(VAR value)"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Return proc assert_true from suite, "Parser handles simple command", ast is not equal to 0, "AST created"
End Process

Process called "test_parser_if_statement" takes suite as Integer returns Integer:
    Note: Test parsing if statement

    Let source be proc string_from_cstring from StringCore with "if(CONDITION)\n  set(VAR value)\nendif()"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Return proc assert_true from suite, "Parser handles if statement", ast is not equal to 0, "AST created for if"
End Process

Process called "test_parser_foreach_loop" takes suite as Integer returns Integer:
    Note: Test parsing foreach loop

    Let source be proc string_from_cstring from StringCore with "foreach(item IN LISTS items)\n  message(${item})\nendforeach()"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Return proc assert_true from suite, "Parser handles foreach loop", ast is not equal to 0, "AST created for foreach"
End Process

Process called "test_parser_function_definition" takes suite as Integer returns Integer:
    Note: Test parsing function definition

    Let source be proc string_from_cstring from StringCore with "function(my_function arg1 arg2)\n  set(RESULT ${arg1})\nendfunction()"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Return proc assert_true from suite, "Parser handles function definition", ast is not equal to 0, "AST created for function"
End Process

Process called "test_parser_cmake_minimum_required" takes suite as Integer returns Integer:
    Note: Test parsing cmake_minimum_required

    Let source be proc string_from_cstring from StringCore with "cmake_minimum_required(VERSION 3.10)"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Return proc assert_true from suite, "Parser handles cmake_minimum_required", ast is not equal to 0, "AST created"
End Process

Process called "run_parser_tests" returns Integer:
    Note: Run all parser tests

    Let suite_name be proc string_from_cstring from StringCore with "CMake Parser Tests"
    Let suite be proc create_test_suite from suite_name

    proc test_log from Test with "=== CMake Parser Tests ==="
    proc test_parser_simple_command from suite
    proc test_parser_if_statement from suite
    proc test_parser_foreach_loop from suite
    proc test_parser_function_definition from suite
    proc test_parser_cmake_minimum_required from suite

    Return suite
End Process

