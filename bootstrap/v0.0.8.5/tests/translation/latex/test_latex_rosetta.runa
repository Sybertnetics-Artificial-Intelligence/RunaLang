    Let ast be proc parse from LaTeXParser with parser_ptr

    proc assert_true from suite_ptr, "Parser handles preamble", ast is not equal to 0

    Let preamble_ptr be proc read_integer from Memory at ast with 8
    proc assert_true from suite_ptr, "Document has preamble", preamble_ptr is not equal to 0

    Return 1
End Process

Process called "test_parser_sections" that takes suite_ptr as Integer returns Integer:
