    Let hir_module be proc latex_to_hir from LaTeXEmitter with source

    proc assert_true from suite_ptr, "Translation creates HIR module", hir_module is not equal to 0

    Let node_type be proc read_integer from Memory at hir_module with 0
    proc assert_true from suite_ptr, "HIR module is LATEX_DOCUMENT type", node_type is equal to LaTeXToHIR.HIR_LATEX_DOCUMENT

    Return 1
End Process

Process called "test_translate_sections" that takes suite_ptr as Integer returns Integer:
    Let source be "\\section{Test}Content"
    Let lexer_ptr be proc create_lexer from LaTeXLexer with source
    proc tokenize from LaTeXLexer with lexer_ptr

    Let tokens be proc get_tokens from LaTeXLexer with lexer_ptr
    Let parser_ptr be proc create_parser from LaTeXParser with tokens
    Let section_ast be proc parse_section from LaTeXParser with parser_ptr

    Let translator_ptr be proc create_translator from LaTeXToHIR
    Let hir_section be proc translate_section from LaTeXToHIR with translator_ptr, section_ast, LaTeXToHIR.HIR_LATEX_SECTION

    proc assert_true from suite_ptr, "Section translates to HIR", hir_section is not equal to 0

    Let node_type be proc read_integer from Memory at hir_section with 0
    proc assert_true from suite_ptr, "HIR node is SECTION type", node_type is equal to LaTeXToHIR.HIR_LATEX_SECTION

    Return 1
End Process

