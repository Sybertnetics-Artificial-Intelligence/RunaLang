Note: ================================================================
Note: LaTeX Translation - Comprehensive Test Suite
Note: ================================================================
Note: Tests all components of the LaTeX translation system:
Note: - Lexer (tokenization)
Note: - Parser (AST construction)
Note: - Translator (LaTeX -> HIR)
Note: - Backend (HIR -> LaTeX)
Note: - Emitter (round-trip translation)
Note: ================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/latex/latex_lexer.runa" as LaTeXLexer
Import "compiler/middle/gungnir/hir/translation/frontends/latex/latex_parser.runa" as LaTeXParser
Import "compiler/middle/gungnir/hir/translation/frontends/latex/latex_to_hir.runa" as LaTeXToHIR
Import "compiler/middle/gungnir/hir/translation/backends/latex/hir_to_latex.runa" as HIRToLaTeX
Import "compiler/middle/gungnir/hir/translation/backends/latex/latex_emitter.runa" as LaTeXEmitter
Import "core/memory.runa" as Memory
Import "core/string.runa" as StringCore
Import "core/list.runa" as ListCore

Note: ================================================================
Note: Test Framework Types
Note: ================================================================

Type called "TestResult":
    test_name as String
    passed as Integer
    error_message as String
    expected as String
    actual as String
End Type

Type called "TestSuite":
    suite_name as String
    tests_run as Integer
    tests_passed as Integer
    tests_failed as Integer
    results as Integer
End Type

Note: ================================================================
Note: Test Suite Creation
Note: ================================================================

Process called "create_test_suite" that takes suite_name as String returns Integer:
    Let suite_ptr be proc allocate from Memory with 40

    proc write_string from Memory at suite_ptr with 0, suite_name
    proc write_integer from Memory at suite_ptr with 8, 0
    proc write_integer from Memory at suite_ptr with 16, 0
    proc write_integer from Memory at suite_ptr with 24, 0

    Let results_list be proc create_list from ListCore
    proc write_integer from Memory at suite_ptr with 32, results_list

    Return suite_ptr
End Process

Note: ================================================================
Note: Assertion Helpers
Note: ================================================================

Process called "assert_equals" that takes suite_ptr as Integer, test_name as String, expected as String, actual as String returns Integer:
    Let result_ptr be proc allocate from Memory with 40

    proc write_string from Memory at result_ptr with 0, test_name

    Let is_equal be proc string_equals from StringCore with expected, actual

    If is_equal is equal to 1:
        proc write_integer from Memory at result_ptr with 8, 1
        proc write_string from Memory at result_ptr with 16, ""

        Let passed be proc read_integer from Memory at suite_ptr with 16
        proc write_integer from Memory at suite_ptr with 16, passed + 1
    Otherwise:
        proc write_integer from Memory at result_ptr with 8, 0
        proc write_string from Memory at result_ptr with 16, "Values not equal"

        Let failed be proc read_integer from Memory at suite_ptr with 24
        proc write_integer from Memory at suite_ptr with 24, failed + 1
    End If

    proc write_string from Memory at result_ptr with 24, expected
    proc write_string from Memory at result_ptr with 32, actual

    Let run_count be proc read_integer from Memory at suite_ptr with 8
    proc write_integer from Memory at suite_ptr with 8, run_count + 1

    Let results_list be proc read_integer from Memory at suite_ptr with 32
    proc add_to_list from ListCore with results_list, result_ptr

    Return is_equal
End Process

Process called "assert_true" that takes suite_ptr as Integer, test_name as String, condition as Integer returns Integer:
    If condition is equal to 1:
        Return proc assert_equals from suite_ptr, test_name, "true", "true"
    Otherwise:
        Return proc assert_equals from suite_ptr, test_name, "true", "false"
    End If
End Process

Process called "assert_not_equal" that takes suite_ptr as Integer, test_name as String, not_expected as String, actual as String returns Integer:
    Let is_equal be proc string_equals from StringCore with not_expected, actual

    If is_equal is equal to 0:
        Return proc assert_true from suite_ptr, test_name, 1
    Otherwise:
        Return proc assert_true from suite_ptr, test_name, 0
    End If
End Process

Process called "assert_token_type" that takes suite_ptr as Integer, test_name as String, expected_type as Integer, token_ptr as Integer returns Integer:
    Let actual_type be proc read_integer from Memory at token_ptr with 0

    If actual_type is equal to expected_type:
        Return proc assert_true from suite_ptr, test_name, 1
    Otherwise:
        Return proc assert_true from suite_ptr, test_name, 0
    End If
End Process

Note: ================================================================
Note: Lexer Tests
Note: ================================================================

Process called "test_lexer_basic_commands" that takes suite_ptr as Integer returns Integer:
    Let source be "\\documentclass{article}"
    Let lexer_ptr be proc create_lexer from LaTeXLexer with source
    proc tokenize from LaTeXLexer with lexer_ptr

    Let tokens be proc get_tokens from LaTeXLexer with lexer_ptr
    Let count be proc get_list_size from ListCore with tokens

    proc assert_true from suite_ptr, "Lexer produces tokens for documentclass", count is greater than 0

    Let first_token be proc get_from_list from ListCore with tokens, 0
    proc assert_token_type from suite_ptr, "First token is DOCUMENTCLASS", LaTeXLexer.TOKEN_DOCUMENTCLASS, first_token

    Return 1
End Process

Process called "test_lexer_section_commands" that takes suite_ptr as Integer returns Integer:
