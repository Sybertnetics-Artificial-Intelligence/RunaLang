    proc assert_true from suite_ptr, "Lexer tokenizes section command", count is greater than 0

    Let first_token be proc get_from_list from ListCore with tokens, 0
    proc assert_token_type from suite_ptr, "Token is SECTION", LaTeXLexer.TOKEN_SECTION, first_token

    Return 1
End Process

