Note: ================================================================
Note: Backend Tests (HIR -> LaTeX)
Note: ================================================================

Process called "test_generate_documentclass" that takes suite_ptr as Integer returns Integer:
    Note: Create HIR documentclass node
    Let hir_docclass be proc allocate from Memory with 32
    proc write_integer from Memory at hir_docclass with 0, LaTeXToHIR.HIR_LATEX_DOCUMENTCLASS
    proc write_string from Memory at hir_docclass with 8, "article"
    proc write_string from Memory at hir_docclass with 16, ""

    Let backend_ptr be proc create_backend from HIRToLaTeX
    proc generate_documentclass from HIRToLaTeX with backend_ptr, hir_docclass

    Let output be proc read_string from Memory at backend_ptr with 0
    Let expected be "\\documentclass{article}\n"

    proc assert_equals from suite_ptr, "Backend generates documentclass", expected, output

    Return 1
End Process

Process called "test_generate_section" that takes suite_ptr as Integer returns Integer:
    Note: Create HIR section node
    Let hir_section be proc allocate from Memory with 40
    proc write_integer from Memory at hir_section with 0, LaTeXToHIR.HIR_LATEX_SECTION
    proc write_string from Memory at hir_section with 8, "Introduction"
    proc write_string from Memory at hir_section with 16, ""
    proc write_integer from Memory at hir_section with 24, 0

    Let backend_ptr be proc create_backend from HIRToLaTeX
    proc generate_section from HIRToLaTeX with backend_ptr, hir_section, "section"

    Let output be proc read_string from Memory at backend_ptr with 0
    Let expected be "\\section{Introduction}\n"

    proc assert_equals from suite_ptr, "Backend generates section", expected, output

    Return 1
End Process

Process called "test_generate_math_inline" that takes suite_ptr as Integer returns Integer:
    Note: Create HIR math inline node with empty content
    Let hir_math be proc allocate from Memory with 32
    proc write_integer from Memory at hir_math with 0, LaTeXToHIR.HIR_LATEX_MATH_INLINE
    Let empty_list be proc create_list from ListCore
    proc write_integer from Memory at hir_math with 8, empty_list

    Let backend_ptr be proc create_backend from HIRToLaTeX
    proc generate_math_inline from HIRToLaTeX with backend_ptr, hir_math

    Let output be proc read_string from Memory at backend_ptr with 0
    Let expected be "$$"

    proc assert_equals from suite_ptr, "Backend generates inline math delimiters", expected, output

    Return 1
End Process

Process called "test_generate_citation" that takes suite_ptr as Integer returns Integer:
    Note: Create HIR citation node
    Let hir_cite be proc allocate from Memory with 32
    proc write_integer from Memory at hir_cite with 0, LaTeXToHIR.HIR_LATEX_CITATION
    proc write_string from Memory at hir_cite with 8, "smith2020"
    proc write_string from Memory at hir_cite with 16, ""

    Let backend_ptr be proc create_backend from HIRToLaTeX
    proc generate_citation from HIRToLaTeX with backend_ptr, hir_cite

    Let output be proc read_string from Memory at backend_ptr with 0
    Let expected be "\\cite{smith2020}"

    proc assert_equals from suite_ptr, "Backend generates citation", expected, output

    Return 1
End Process

