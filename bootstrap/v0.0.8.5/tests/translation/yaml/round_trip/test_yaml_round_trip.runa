Note: ============================================================================
Note: Mapping Round-Trip Tests
Note: ============================================================================

Process called "test_round_trip_empty_mapping" returns Integer:
    Note: Test empty mapping round-trip preservation

    Let input be "{}"
    Let output be proc round_trip_yaml from input

    If output is equal to 0:
        Return 0
    End If

    Return proc yaml_contains_value from output, "{}"
End Process

Process called "test_round_trip_simple_mapping" returns Integer:
    Note: Test simple mapping round-trip preservation

    Let input be "name: Alice"
    Let output be proc round_trip_yaml from input

    If output is equal to 0:
        Return 0
    End If

    Let has_name be proc yaml_contains_value from output, "name"
    Let has_alice be proc yaml_contains_value from output, "Alice"

    If has_name is equal to 1:
        If has_alice is equal to 1:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "test_round_trip_multi_field_mapping" returns Integer:
    Note: Test multi-field mapping round-trip preservation

    Let input be "name: Bob\nage: 30"
    Let output be proc round_trip_yaml from input

    If output is equal to 0:
        Return 0
    End If

    Let has_name be proc yaml_contains_value from output, "name"
    Let has_age be proc yaml_contains_value from output, "age"
    Let has_30 be proc yaml_contains_value from output, "30"

    If has_name is equal to 1:
        If has_age is equal to 1:
            If has_30 is equal to 1:
                Return 1
            End If
        End If
    End If

    Return 0
End Process

Process called "test_round_trip_nested_mapping" returns Integer:
    Note: Test nested mapping round-trip preservation

    Let input be "outer:\n  inner:\n    value: nested"
    Let output be proc round_trip_yaml from input

    If output is equal to 0:
        Return 0
    End If

    Let has_outer be proc yaml_contains_value from output, "outer"
    Let has_inner be proc yaml_contains_value from output, "inner"
    Let has_value be proc yaml_contains_value from output, "value"
    Let has_nested be proc yaml_contains_value from output, "nested"

    If has_outer is equal to 1:
        If has_inner is equal to 1:
            If has_value is equal to 1:
                If has_nested is equal to 1:
                    Return 1
                End If
            End If
        End If
    End If

    Return 0
End Process

