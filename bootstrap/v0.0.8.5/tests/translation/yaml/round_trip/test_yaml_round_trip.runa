Note: ============================================================================
Note: Complex Structure Round-Trip Tests
Note: ============================================================================

Process called "test_round_trip_sequence_of_mappings" returns Integer:
    Note: Test sequence of mappings round-trip preservation

    Let input be "- id: 1\n  name: Alice\n- id: 2\n  name: Bob"
    Let output be proc round_trip_yaml from input

    If output is equal to 0:
        Return 0
    End If

    Let has_id be proc yaml_contains_value from output, "id"
    Let has_name be proc yaml_contains_value from output, "name"
    Let has_alice be proc yaml_contains_value from output, "Alice"
    Let has_bob be proc yaml_contains_value from output, "Bob"

    If has_id is equal to 1:
        If has_name is equal to 1:
            If has_alice is equal to 1:
                If has_bob is equal to 1:
                    Return 1
                End If
            End If
        End If
    End If

    Return 0
End Process

Process called "test_round_trip_mapping_with_sequence" returns Integer:
    Note: Test mapping with sequence round-trip preservation

    Let input be "name: Student\nscores:\n  - 95\n  - 87\n  - 92"
    Let output be proc round_trip_yaml from input

    If output is equal to 0:
        Return 0
    End If

    Let has_name be proc yaml_contains_value from output, "name"
    Let has_scores be proc yaml_contains_value from output, "scores"
    Let has_95 be proc yaml_contains_value from output, "95"

    If has_name is equal to 1:
        If has_scores is equal to 1:
            If has_95 is equal to 1:
                Return 1
            End If
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_yaml_round_trip_tests" returns Integer:
    Note: Run all YAML round-trip tests

    Let total_tests be 0
    Let passed_tests be 0

    Note: Basic type tests
    Set total_tests to total_tests plus 1
    If proc test_round_trip_string_plain is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_string_quoted is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_integer is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_negative_integer is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_boolean_true is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_boolean_false is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_null is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Mapping tests
    Set total_tests to total_tests plus 1
    If proc test_round_trip_empty_mapping is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_simple_mapping is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_multi_field_mapping is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_nested_mapping is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Sequence tests
    Set total_tests to total_tests plus 1
    If proc test_round_trip_empty_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_integer_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_string_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_mixed_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_flow_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Complex structure tests
    Set total_tests to total_tests plus 1
    If proc test_round_trip_sequence_of_mappings is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_mapping_with_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Print results
    proc print from "YAML Round-Trip Tests:", passed_tests, "/", total_tests, "passed"

    Return passed_tests
End Process

Note: End of YAML Round-Trip Test Suite
