Note:
YAML Round-Trip Test Suite

Tests bidirectional YAML translation:
YAML → HIR → YAML

Verifies that YAML structures can be parsed, converted to HIR,
and then regenerated as YAML while preserving semantic meaning.

Test Coverage:
- Basic types preserve values
- Mappings preserve structure and key-value pairs
- Sequences preserve order and elements
- Nested structures preserve hierarchy
- Special characters properly escaped/unescaped
- Numbers preserve values
- Indentation and formatting may differ, but semantics preserved

Success Criteria:
- Semantic equivalence (not necessarily string equality)
- No data loss
- Type preservation
- Structure preservation
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/yaml/yaml_parser.runa" as YAMLParser
Import "compiler/middle/gungnir/hir/translation/frontends/yaml/yaml_to_hir.runa" as YAMLToHIR
Import "compiler/middle/gungnir/hir/translation/backends/yaml/hir_to_yaml.runa" as HIRToYAML
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Round-Trip Test Utilities
Note: ============================================================================

Process called "round_trip_yaml" takes yaml_input as Integer returns Integer:
    Note: Perform YAML→HIR→YAML round-trip translation

    @Reasoning:
    Parse YAML to AST, translate to HIR, regenerate YAML.
    Returns generated YAML or 0 on failure.
    @End Reasoning

    Note: Parse YAML to AST
    Let yaml_ast be proc parse_yaml from YAMLParser with yaml_input

    If yaml_ast is equal to 0:
        proc print from "Failed to parse YAML"
        Return 0
    End If

    Note: Translate YAML AST to HIR
    Let context be proc create_translation_context from YAMLToHIR
    Let hir be proc translate_yaml_node_to_hir from YAMLToHIR with context, yaml_ast

    If hir is equal to 0:
        proc print from "Failed to translate YAML to HIR"
        proc destroy_translation_context from YAMLToHIR with context
        Return 0
    End If

    proc destroy_translation_context from YAMLToHIR with context

    Note: Generate YAML from HIR
    Let yaml_output be proc translate_hir_to_yaml from HIRToYAML with hir

    If yaml_output is equal to 0:
        proc print from "Failed to generate YAML from HIR"
        Return 0
    End If

    Return yaml_output
End Process

Process called "yaml_contains_value" takes yaml as Integer, value as Integer returns Integer:
    Note: Check if YAML output contains a value (for semantic comparison)

    Let yaml_len be proc string_length from StringCore with yaml
    Let value_len be proc string_length from StringCore with value

    If value_len is greater than yaml_len:
        Return 0
    End If

    Let search_end be yaml_len minus value_len
    Let index be 0

    While index is less than or equal to search_end:
        Let match be 1
        Let check_index be 0

        While check_index is less than value_len:
            Let value_char be proc memory_get_byte from Layout with value, check_index
            Let yaml_char be proc memory_get_byte from Layout with yaml, index plus check_index

            If value_char is not equal to yaml_char:
                Set match to 0
                Break
            End If

            Set check_index to check_index plus 1
        End While

        If match is equal to 1:
            Return 1
        End If

        Set index to index plus 1
    End While

    Return 0
End Process

Note: ============================================================================
Note: Basic Type Round-Trip Tests
Note: ============================================================================

Process called "test_round_trip_string_plain" returns Integer:
    Note: Test plain string round-trip preservation

    Let input be "hello"
    Let output be proc round_trip_yaml from input

    If output is equal to 0:
        Return 0
    End If

    Return proc yaml_contains_value from output, "hello"
End Process

Process called "test_round_trip_string_quoted" returns Integer:
    Note: Test quoted string round-trip preservation

    Let input be "\"hello world\""
    Let output be proc round_trip_yaml from input

    If output is equal to 0:
        Return 0
    End If

    Return proc yaml_contains_value from output, "hello world"
End Process

