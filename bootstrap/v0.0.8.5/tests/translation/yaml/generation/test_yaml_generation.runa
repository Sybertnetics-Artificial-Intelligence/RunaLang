Note:
YAML Generation Test Suite

Tests HIR→YAML code generation functionality.
Verifies that Runa data structures can be properly
exported as YAML.

Test Coverage:
- Basic type literals (strings, integers, booleans, null)
- Mapping/dictionary generation (block style)
- Sequence/list generation (block style)
- Nested structures
- String quoting when necessary
- Edge cases (empty collections, special characters)
- Pretty printing and indentation
:End Note

Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/backends/yaml/hir_to_yaml.runa" as YAMLGen
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test Utilities
Note: ============================================================================

Process called "assert_yaml_contains" takes expected_substring as Integer, actual as Integer returns Integer:
    Note: Assert that YAML output contains expected substring

    Let expected_len be proc string_length from StringCore with expected_substring
    Let actual_len be proc string_length from StringCore with actual

    If expected_len is greater than actual_len:
        proc print_error from "Expected substring longer than actual string"
        Return 0
    End If

    Note: Simple substring search
    Let search_end be actual_len minus expected_len
    Let index be 0

    While index is less than or equal to search_end:
        Let match be 1
        Let check_index be 0

        While check_index is less than expected_len:
            Let expected_char be proc memory_get_byte from Layout with expected_substring, check_index
            Let actual_char be proc memory_get_byte from Layout with actual, index plus check_index

            If expected_char is not equal to actual_char:
                Set match to 0
                Break
            End If

            Set check_index to check_index plus 1
        End While

        If match is equal to 1:
            Return 1
        End If

        Set index to index plus 1
    End While

    proc print_error from "Expected substring not found in YAML output"
    Return 0
End Process

Note: ============================================================================
Note: Basic Type Generation Tests
Note: ============================================================================

Process called "test_generate_string_plain" returns Integer:
    Note: Test YAML plain string generation

    Let hir_string be proc create_hir_string_literal from HIR with "hello"
    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_string

    Return proc assert_yaml_contains from "hello", yaml
End Process

Process called "test_generate_string_quoted" returns Integer:
    Note: Test YAML quoted string generation (contains special chars)

    Let hir_string be proc create_hir_string_literal from HIR with "hello: world"
    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_string

    Note: String should be quoted because it contains colon
    Return proc assert_yaml_contains from "\"", yaml
End Process

Process called "test_generate_integer_positive" returns Integer:
    Note: Test YAML integer generation

    Let hir_int be proc create_hir_integer_literal from HIR with 42
    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_int

    Return proc assert_yaml_contains from "42", yaml
End Process

Process called "test_generate_integer_negative" returns Integer:
    Note: Test YAML negative integer generation

    Let hir_int be proc create_hir_integer_literal from HIR with -17
    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_int

    Return proc assert_yaml_contains from "-17", yaml
End Process

Process called "test_generate_boolean_true" returns Integer:
    Note: Test YAML true generation

    Let hir_bool be proc create_hir_boolean_literal from HIR with 1
    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_bool

    Return proc assert_yaml_contains from "true", yaml
End Process

Process called "test_generate_boolean_false" returns Integer:
    Note: Test YAML false generation

    Let hir_bool be proc create_hir_boolean_literal from HIR with 0
    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_bool

    Return proc assert_yaml_contains from "false", yaml
End Process

Process called "test_generate_null" returns Integer:
    Note: Test YAML null generation

    Let hir_null be proc create_hir_null_literal from HIR
    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_null

    Return proc assert_yaml_contains from "null", yaml
End Process

Note: ============================================================================
Note: Mapping Generation Tests
Note: ============================================================================

Process called "test_generate_empty_mapping" returns Integer:
    Note: Test YAML empty mapping generation

    Let hir_dict be proc create_hir_dictionary_literal from HIR
    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_dict

    Return proc assert_yaml_contains from "{}", yaml
End Process

Process called "test_generate_simple_mapping" returns Integer:
    Note: Test YAML mapping with one key-value pair

    Let hir_dict be proc create_hir_dictionary_literal from HIR
    Let key be "name"
    Let value be proc create_hir_string_literal from HIR with "Alice"

    proc add_dictionary_entry from HIR with hir_dict, key, value

    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_dict

    Note: Should contain key: value
    Let contains_key be proc assert_yaml_contains from "name:", yaml
    Let contains_value be proc assert_yaml_contains from "Alice", yaml

    If contains_key is equal to 1:
        If contains_value is equal to 1:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "test_generate_mapping_multiple_fields" returns Integer:
    Note: Test YAML mapping with multiple fields

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    proc add_dictionary_entry from HIR with hir_dict, "name", proc create_hir_string_literal from HIR with "Bob"
    proc add_dictionary_entry from HIR with hir_dict, "age", proc create_hir_integer_literal from HIR with 30

    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_dict

    Let has_name be proc assert_yaml_contains from "name:", yaml
    Let has_age be proc assert_yaml_contains from "age:", yaml
    Let has_30 be proc assert_yaml_contains from "30", yaml

    If has_name is equal to 1:
        If has_age is equal to 1:
            If has_30 is equal to 1:
                Return 1
            End If
        End If
    End If

    Return 0
End Process

Process called "test_generate_nested_mapping" returns Integer:
    Note: Test YAML nested mapping generation

    Let hir_outer be proc create_hir_dictionary_literal from HIR
    Let hir_inner be proc create_hir_dictionary_literal from HIR

    proc add_dictionary_entry from HIR with hir_inner, "value", proc create_hir_string_literal from HIR with "nested"
    proc add_dictionary_entry from HIR with hir_outer, "inner", hir_inner

    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_outer

    Let has_inner be proc assert_yaml_contains from "inner:", yaml
    Let has_value be proc assert_yaml_contains from "value:", yaml
    Let has_nested be proc assert_yaml_contains from "nested", yaml

    If has_inner is equal to 1:
        If has_value is equal to 1:
            If has_nested is equal to 1:
                Return 1
            End If
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: Sequence Generation Tests
Note: ============================================================================

Process called "test_generate_empty_sequence" returns Integer:
    Note: Test YAML empty sequence generation

    Let hir_list be proc create_hir_list_literal from HIR
    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_list

    Return proc assert_yaml_contains from "[]", yaml
End Process

Process called "test_generate_integer_sequence" returns Integer:
    Note: Test YAML integer sequence generation

    Let hir_list be proc create_hir_list_literal from HIR

    proc add_list_element from HIR with hir_list, proc create_hir_integer_literal from HIR with 1
    proc add_list_element from HIR with hir_list, proc create_hir_integer_literal from HIR with 2
    proc add_list_element from HIR with hir_list, proc create_hir_integer_literal from HIR with 3

    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_list

    Note: Should contain - indicators and values
    Let has_dash be proc assert_yaml_contains from "- ", yaml
    Let has_1 be proc assert_yaml_contains from "1", yaml
    Let has_2 be proc assert_yaml_contains from "2", yaml
    Let has_3 be proc assert_yaml_contains from "3", yaml

    If has_dash is equal to 1:
        If has_1 is equal to 1:
            If has_2 is equal to 1:
                If has_3 is equal to 1:
                    Return 1
                End If
            End If
        End If
    End If

    Return 0
End Process

Process called "test_generate_string_sequence" returns Integer:
    Note: Test YAML string sequence generation

    Let hir_list be proc create_hir_list_literal from HIR

    proc add_list_element from HIR with hir_list, proc create_hir_string_literal from HIR with "apple"
    proc add_list_element from HIR with hir_list, proc create_hir_string_literal from HIR with "banana"

    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_list

    Let has_apple be proc assert_yaml_contains from "apple", yaml
    Let has_banana be proc assert_yaml_contains from "banana", yaml

    If has_apple is equal to 1:
        If has_banana is equal to 1:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "test_generate_mixed_sequence" returns Integer:
    Note: Test YAML mixed-type sequence generation

    Let hir_list be proc create_hir_list_literal from HIR

    proc add_list_element from HIR with hir_list, proc create_hir_integer_literal from HIR with 1
    proc add_list_element from HIR with hir_list, proc create_hir_string_literal from HIR with "two"
    proc add_list_element from HIR with hir_list, proc create_hir_boolean_literal from HIR with 1
    proc add_list_element from HIR with hir_list, proc create_hir_null_literal from HIR

    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_list

    Let has_1 be proc assert_yaml_contains from "1", yaml
    Let has_two be proc assert_yaml_contains from "two", yaml
    Let has_true be proc assert_yaml_contains from "true", yaml
    Let has_null be proc assert_yaml_contains from "null", yaml

    If has_1 is equal to 1:
        If has_two is equal to 1:
            If has_true is equal to 1:
                If has_null is equal to 1:
                    Return 1
                End If
            End If
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: Complex Structure Generation Tests
Note: ============================================================================

Process called "test_generate_sequence_of_mappings" returns Integer:
    Note: Test YAML sequence of mappings generation

    Let hir_list be proc create_hir_list_literal from HIR

    Let obj1 be proc create_hir_dictionary_literal from HIR
    proc add_dictionary_entry from HIR with obj1, "id", proc create_hir_integer_literal from HIR with 1
    proc add_dictionary_entry from HIR with obj1, "name", proc create_hir_string_literal from HIR with "Alice"

    Let obj2 be proc create_hir_dictionary_literal from HIR
    proc add_dictionary_entry from HIR with obj2, "id", proc create_hir_integer_literal from HIR with 2
    proc add_dictionary_entry from HIR with obj2, "name", proc create_hir_string_literal from HIR with "Bob"

    proc add_list_element from HIR with hir_list, obj1
    proc add_list_element from HIR with hir_list, obj2

    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_list

    Let has_dash be proc assert_yaml_contains from "- ", yaml
    Let has_id be proc assert_yaml_contains from "id:", yaml
    Let has_name be proc assert_yaml_contains from "name:", yaml

    If has_dash is equal to 1:
        If has_id is equal to 1:
            If has_name is equal to 1:
                Return 1
            End If
        End If
    End If

    Return 0
End Process

Process called "test_generate_mapping_with_sequences" returns Integer:
    Note: Test YAML mapping containing sequences

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let scores be proc create_hir_list_literal from HIR
    proc add_list_element from HIR with scores, proc create_hir_integer_literal from HIR with 95
    proc add_list_element from HIR with scores, proc create_hir_integer_literal from HIR with 87

    proc add_dictionary_entry from HIR with hir_dict, "name", proc create_hir_string_literal from HIR with "Student"
    proc add_dictionary_entry from HIR with hir_dict, "scores", scores

    Let yaml be proc translate_hir_to_yaml from YAMLGen with hir_dict

    Let has_name be proc assert_yaml_contains from "name:", yaml
    Let has_scores be proc assert_yaml_contains from "scores:", yaml
    Let has_95 be proc assert_yaml_contains from "95", yaml

    If has_name is equal to 1:
        If has_scores is equal to 1:
            If has_95 is equal to 1:
                Return 1
            End If
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_yaml_generation_tests" returns Integer:
    Note: Run all YAML generation tests

    Let total_tests be 0
    Let passed_tests be 0

    Note: Basic type tests
    Set total_tests to total_tests plus 1
    If proc test_generate_string_plain is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_string_quoted is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_integer_positive is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_integer_negative is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_boolean_true is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_boolean_false is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_null is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Mapping tests
    Set total_tests to total_tests plus 1
    If proc test_generate_empty_mapping is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_simple_mapping is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_mapping_multiple_fields is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_nested_mapping is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Sequence tests
    Set total_tests to total_tests plus 1
    If proc test_generate_empty_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_integer_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_string_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_mixed_sequence is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Complex structure tests
    Set total_tests to total_tests plus 1
    If proc test_generate_sequence_of_mappings is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_mapping_with_sequences is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Print results
    proc print from "YAML Generation Tests:", passed_tests, "/", total_tests, "passed"

    Return passed_tests
End Process

Note: End of YAML Generation Test Suite
