Process called "test_csharp_to_hir_class" returns Integer:
    Note: Test C# class translation to HIR

    Let test_name be "C# to HIR - Class"
    proc test_start from Test with test_name

    Let source be "public class Person { public string Name { get; set; } }"
    Let lexer be proc create_csharp_lexer from Lexer with source
    Let parser be proc create_csharp_parser from Parser with lexer
    Let ast be proc parse_csharp from Parser with parser

    If ast is equal to 0:
        proc test_fail from Test with test_name, "Failed to parse C# source"
        Return 0
    End If

    Let arena be proc create_arena from Layout with 8192
    Let hir be proc translate_csharp_to_hir from ToHIR with ast, arena

    If hir is equal to 0:
        proc test_fail from Test with test_name, "Failed to translate to HIR"
        proc destroy_arena from Layout with arena
        proc destroy_csharp_parser from Parser with parser
        Return 0
    End If

    proc destroy_arena from Layout with arena
    proc destroy_csharp_parser from Parser with parser

    proc test_pass from Test with test_name
    Return 1
End Process

