Process called "test_csharp_lexer_literals" returns Integer:
    Note: Test C# literal recognition

    Let test_name be "C# Lexer - Literals"
    proc test_start from Test with test_name

    Let source be "42 3.14 \"hello\" @\"verbatim\" $\"interpolated\" true false null"
    Let lexer be proc create_csharp_lexer from Lexer with source

    If lexer is equal to 0:
        proc test_fail from Test with test_name, "Failed to create lexer"
        Return 0
