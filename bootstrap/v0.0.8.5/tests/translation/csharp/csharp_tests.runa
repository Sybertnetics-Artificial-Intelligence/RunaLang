Note:
C# Translation Tests - Comprehensive test suite for C# language translation

This file provides comprehensive tests for the complete C# translation pipeline:
lexer → parser → semantic analysis → HIR translation → code generation.

Test Coverage:
- Lexer: Keywords, operators, literals
- Parser: All C# constructs (classes, methods, properties, statements)
- Translation: C# → HIR conversion
- Generation: HIR → C# code generation
- Round-trip: C# → HIR → C# preservation

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/csharp/hir_to_csharp.runa
- tests/test_framework.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/csharp/hir_to_csharp.runa" as FromHIR
Import "tests/test_framework.runa" as Test
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Lexer Tests - C# Tokenization
Note: ============================================================================

Process called "test_csharp_lexer_keywords" returns Integer:
    Note: Test C# keyword recognition

    Let test_name be "C# Lexer - Keywords"
    proc test_start from Test with test_name

    Let source be "using namespace class struct interface enum delegate event async await"
    Let lexer be proc create_csharp_lexer from Lexer with source

    If lexer is equal to 0:
        proc test_fail from Test with test_name, "Failed to create lexer"
        Return 0
    End If

    Let token_type be proc next_token from Lexer with lexer
    Let is_using be token_type is equal to TOKEN_USING from Lexer
    If is_using is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_USING"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_namespace be token_type is equal to TOKEN_NAMESPACE from Lexer
    If is_namespace is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_NAMESPACE"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_class be token_type is equal to TOKEN_CLASS from Lexer
    If is_class is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_CLASS"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_struct be token_type is equal to TOKEN_STRUCT from Lexer
    If is_struct is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_STRUCT"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_interface be token_type is equal to TOKEN_INTERFACE from Lexer
    If is_interface is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_INTERFACE"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_enum be token_type is equal to TOKEN_ENUM from Lexer
    If is_enum is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_ENUM"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_delegate be token_type is equal to TOKEN_DELEGATE from Lexer
    If is_delegate is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_DELEGATE"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_event be token_type is equal to TOKEN_EVENT from Lexer
    If is_event is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_EVENT"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_async be token_type is equal to TOKEN_ASYNC from Lexer
    If is_async is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_ASYNC"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_await be token_type is equal to TOKEN_AWAIT from Lexer
    If is_await is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_AWAIT"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    proc destroy_csharp_lexer from Lexer with lexer

    proc test_pass from Test with test_name
    Return 1
End Process

