    If is_float is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_FLOAT"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_string be token_type is equal to TOKEN_STRING from Lexer
    If is_string is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_STRING"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_verbatim be token_type is equal to TOKEN_STRING from Lexer
    If is_verbatim is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_STRING (verbatim)"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    Set token_type to proc next_token from Lexer with lexer
    Let is_interpolated be token_type is equal to TOKEN_STRING from Lexer
    If is_interpolated is equal to 0:
        proc test_fail from Test with test_name, "Expected TOKEN_STRING (interpolated)"
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If

    proc destroy_csharp_lexer from Lexer with lexer

    proc test_pass from Test with test_name
    Return 1
End Process

