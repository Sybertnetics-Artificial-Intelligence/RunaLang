Process called "test_csharp_parser_class" returns Integer:
    Note: Test C# class parsing

    Let test_name be "C# Parser - Class Declaration"
    proc test_start from Test with test_name

    Let source be "public class MyClass { }"
    Let lexer be proc create_csharp_lexer from Lexer with source
    Let parser be proc create_csharp_parser from Parser with lexer

    If parser is equal to 0:
        proc test_fail from Test with test_name, "Failed to create parser"
        Return 0
    End If

    Let ast be proc parse_csharp from Parser with parser

    If ast is equal to 0:
        proc test_fail from Test with test_name, "Failed to parse class"
        proc destroy_csharp_parser from Parser with parser
        Return 0
    End If

    Let node_type be proc get_node_type from Parser with ast
    Let is_program be node_type is equal to CSHARP_PROGRAM from Parser

    If is_program is equal to 0:
        proc test_fail from Test with test_name, "Expected CSHARP_PROGRAM node"
        proc destroy_csharp_parser from Parser with parser
        Return 0
    End If

    proc destroy_csharp_parser from Parser with parser

    proc test_pass from Test with test_name
    Return 1
End Process

