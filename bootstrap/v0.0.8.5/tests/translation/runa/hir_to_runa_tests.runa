Note: ============================================================================
Note: Full Round-Trip Translation Tests
Note: ============================================================================

Process called "test_roundtrip_simple_function" returns Integer:
    Note: Test full C → HIR → Runa translation

    Let c_source be "int main() { return 0; }"
    Let parser be proc create_c_parser from CParser with c_source
    Let c_ast be proc parse_program from CParser with parser
    Let hir be proc translate_c_to_hir from CToHIR with c_ast

    Let runa_code be proc generate_runa_from_hir from RunaGen with hir

    Let is_valid be runa_code is not equal to 0

    If runa_code is not equal to 0:
        Let has_process be proc string_contains from StringCore with runa_code, "Process"
        Let has_main be proc string_contains from StringCore with runa_code, "main"
        Let has_return be proc string_contains from StringCore with runa_code, "Return"

        Set is_valid to has_process
        If is_valid is equal to 1:
            Set is_valid to has_main
        End If
        If is_valid is equal to 1:
            Set is_valid to has_return
        End If

        proc deallocate from Layout with runa_code
    End If

    proc destroy_c_parser from CParser with parser

    Return proc print_test_result from "Round-trip: C main() \u2192 Runa Process", is_valid
End Process

Process called "test_roundtrip_arithmetic" returns Integer:
    Note: Test C arithmetic → Runa arithmetic

    Let c_source be "int calc() { return 2 + 3 * 4; }"
    Let parser be proc create_c_parser from CParser with c_source
    Let c_ast be proc parse_program from CParser with parser
    Let hir be proc translate_c_to_hir from CToHIR with c_ast

    Let runa_code be proc generate_runa_from_hir from RunaGen with hir

