        Let has_times be proc string_contains from StringCore with runa_code, "times"

        Set is_valid to has_plus
        If is_valid is equal to 1:
            Set is_valid to has_times
        End If

        proc deallocate from Layout with runa_code
    End If

    proc destroy_c_parser from CParser with parser

