End Process

Process called "test_roundtrip_control_flow" returns Integer:
    Note: Test C control flow → Runa control flow

    Let c_source be "void test(int x) { if (x > 0) x = x + 1; }"
    Let parser be proc create_c_parser from CParser with c_source
    Let c_ast be proc parse_program from CParser with parser
    Let hir be proc translate_c_to_hir from CToHIR with c_ast

    Let runa_code be proc generate_runa_from_hir from RunaGen with hir

    Let is_valid be runa_code is not equal to 0

    If runa_code is not equal to 0:
        Let has_if be proc string_contains from StringCore with runa_code, "If"
        Let has_greater be proc string_contains from StringCore with runa_code, "is greater than"
        Let has_set be proc string_contains from StringCore with runa_code, "Set"

        Set is_valid to has_if
        If is_valid is equal to 1:
            Set is_valid to has_greater
        End If
        If is_valid is equal to 1:
            Set is_valid to has_set
        End If

        proc deallocate from Layout with runa_code
    End If

    proc destroy_c_parser from CParser with parser

    Return proc print_test_result from "Round-trip: C if statement \u2192 Runa If", is_valid
End Process

Process called "test_roundtrip_loop" returns Integer:
    Note: Test C loop → Runa loop

    Let c_source be "void loop() { while (i < 10) i = i + 1; }"
    Let parser be proc create_c_parser from CParser with c_source
    Let c_ast be proc parse_program from CParser with parser
    Let hir be proc translate_c_to_hir from CToHIR with c_ast

    Let runa_code be proc generate_runa_from_hir from RunaGen with hir

    Let is_valid be runa_code is not equal to 0

    If runa_code is not equal to 0:
        Let has_while be proc string_contains from StringCore with runa_code, "While"
        Let has_less be proc string_contains from StringCore with runa_code, "is less than"
        Let has_end_while be proc string_contains from StringCore with runa_code, "End While"

        Set is_valid to has_while
        If is_valid is equal to 1:
            Set is_valid to has_less
        End If
        If is_valid is equal to 1:
            Set is_valid to has_end_while
        End If

        proc deallocate from Layout with runa_code
    End If

    proc destroy_c_parser from CParser with parser

    Return proc print_test_result from "Round-trip: C while \u2192 Runa While", is_valid
End Process

Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Note: Run all HIR → Runa generator tests

    proc println from StringCore with "========================================"
    proc println from StringCore with "HIR \u2192 Runa Generator Test Suite"
    proc println from StringCore with "CRITICAL: Universal Translation TO Runa"
    proc println from StringCore with "========================================"
    proc println from StringCore with ""

    Let total_tests be 0
    Let passed_tests be 0

    Note: Type mapping tests
    proc println from StringCore with "Type Mapping Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_type_mapping
    proc println from StringCore with ""

    Note: Operator mapping tests
    proc println from StringCore with "Operator Mapping Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_operator_mapping
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_comparison_operators
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_arithmetic_operators
    proc println from StringCore with ""

    Note: Statement generation tests
    proc println from StringCore with "Statement Generation Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_if_statement_generation
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_while_statement_generation
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_return_statement_generation
    proc println from StringCore with ""

    Note: Declaration generation tests
    proc println from StringCore with "Declaration Generation Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_function_declaration_generation
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_variable_declaration_generation
    proc println from StringCore with ""

    Note: Round-trip translation tests
    proc println from StringCore with "Round-Trip Translation Tests (C \u2192 HIR \u2192 Runa):"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_roundtrip_simple_function
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_roundtrip_arithmetic
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_roundtrip_control_flow
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_roundtrip_loop
    proc println from StringCore with ""

    Note: Print summary
    proc println from StringCore with "========================================"
    proc print from StringCore with "Tests Passed: "
    proc print_int from StringCore with passed_tests
    proc print from StringCore with " / "
    proc println_int from StringCore with total_tests
    proc println from StringCore with "========================================"
    proc println from StringCore with ""
    proc println from StringCore with "UNIVERSAL TRANSLATION NOW ENABLED:"
    proc println from StringCore with "  \u2713 C \u2192 Runa"
    proc println from StringCore with "  \u2713 Python \u2192 Runa (ready)"
    proc println from StringCore with "  \u2713 JavaScript \u2192 Runa (ready)"
    proc println from StringCore with "  \u2713 ALL languages \u2192 Runa (ready)"
    proc println from StringCore with "========================================"

    Return passed_tests
End Process

Note: ============================================================================
Note: Main Entry Point
Note: ============================================================================

Process called "main" returns Integer:
    Note: Main entry point for HIR → Runa generator tests

    Let passed be proc run_all_tests

    Return 0
End Process
