Note:
HIR to Runa Generator Tests - Comprehensive test suite for HIR → Runa translation

This file contains comprehensive tests for the HIR → Runa generator, the CRITICAL
component that enables universal translation TO Runa from ANY language.

Test Coverage:
- Type mapping (foreign types → Runa types)
- Operator mapping (symbolic → English)
- Expression generation
- Statement generation (if, while, return, etc.)
- Function and variable declarations
- Full round-trip translation tests (C → HIR → Runa)

This enables:
- C → Runa translation
- Python → Runa translation
- JavaScript → Runa translation
- ALL languages → Runa translation

Dependencies:
- compiler/middle/gungnir/hir/translation/backends/runa/hir_to_runa.runa
- compiler/middle/gungnir/hir/translation/frontends/c/c_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/c/c_to_hir.runa
- compiler/middle/gungnir/hir/hir.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/backends/runa/hir_to_runa.runa" as RunaGen
Import "compiler/middle/gungnir/hir/translation/frontends/c/c_parser.runa" as CParser
Import "compiler/middle/gungnir/hir/translation/frontends/c/c_to_hir.runa" as CToHIR
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test Utilities
Note: ============================================================================

Process called "print_test_result" takes test_name as Integer, passed as Integer returns Integer:
    Note: Print test result

    If passed is equal to 1:
        proc print from StringCore with "✓ "
        proc print from StringCore with test_name
        proc println from StringCore with " - PASSED"
    End If

    If passed is equal to 0:
        proc print from StringCore with "✗ "
        proc print from StringCore with test_name
        proc println from StringCore with " - FAILED"
    End If

    Return passed
End Process

Note: ============================================================================
Note: Type Mapping Tests
Note: ============================================================================

Process called "test_type_mapping" returns Integer:
    Note: Test foreign type mapping to Runa types

    Note: Create simple HIR with C function using various types
    Let c_source be "int add(int a, float b) { return 0; }"
    Let parser be proc create_c_parser from CParser with c_source
    Let c_ast be proc parse_program from CParser with parser
    Let hir be proc translate_c_to_hir from CToHIR with c_ast

    Let runa_code be proc generate_runa_from_hir from RunaGen with hir

    Let is_valid be runa_code is not equal to 0

    If runa_code is not equal to 0:
        Note: Verify contains "Integer" (mapped from int)
        Let has_integer be proc string_contains from StringCore with runa_code, "Integer"
        Note: Verify contains "Float" (mapped from float)
        Let has_float be proc string_contains from StringCore with runa_code, "Float"
        Note: Verify contains "Process" (Runa function keyword)
        Let has_process be proc string_contains from StringCore with runa_code, "Process"

        Set is_valid to has_integer
        If is_valid is equal to 1:
            Set is_valid to has_float
        End If
        If is_valid is equal to 1:
            Set is_valid to has_process
        End If

        proc deallocate from Layout with runa_code
    End If

    proc destroy_c_parser from CParser with parser

    Return proc print_test_result from "Type mapping: C types \u2192 Runa types", is_valid
End Process

Note: ============================================================================
Note: Operator Mapping Tests
Note: ============================================================================

Process called "test_operator_mapping" returns Integer:
    Note: Test symbolic operator mapping to Runa English operators

    Let c_source be "int test() { if (x == 5) return 1; }"
    Let parser be proc create_c_parser from CParser with c_source
    Let c_ast be proc parse_program from CParser with parser
    Let hir be proc translate_c_to_hir from CToHIR with c_ast

    Let runa_code be proc generate_runa_from_hir from RunaGen with hir

    Let is_valid be runa_code is not equal to 0

    If runa_code is not equal to 0:
        Note: Verify == mapped to "is equal to"
        Let has_equals be proc string_contains from StringCore with runa_code, "is equal to"

        Set is_valid to has_equals

        proc deallocate from Layout with runa_code
    End If

    proc destroy_c_parser from CParser with parser

    Return proc print_test_result from "Operator mapping: == \u2192 is equal to", is_valid
End Process

Process called "test_comparison_operators" returns Integer:
    Note: Test all comparison operator mappings

    Let c_source be "int test() { if (x > 0 && y < 10) return 1; }"
    Let parser be proc create_c_parser from CParser with c_source
    Let c_ast be proc parse_program from CParser with parser
    Let hir be proc translate_c_to_hir from CToHIR with c_ast

    Let runa_code be proc generate_runa_from_hir from RunaGen with hir

    Let is_valid be runa_code is not equal to 0

    If runa_code is not equal to 0:
        Let has_gt be proc string_contains from StringCore with runa_code, "is greater than"
        Let has_lt be proc string_contains from StringCore with runa_code, "is less than"

        Set is_valid to has_gt
        If is_valid is equal to 1:
            Set is_valid to has_lt
        End If

        proc deallocate from Layout with runa_code
    End If

    proc destroy_c_parser from CParser with parser

    Return proc print_test_result from "Operator mapping: <, > \u2192 English", is_valid
End Process

Process called "test_arithmetic_operators" returns Integer:
    Note: Test arithmetic operator mappings

    Let c_source be "int calc() { return x + y * z; }"
    Let parser be proc create_c_parser from CParser with c_source
    Let c_ast be proc parse_program from CParser with parser
    Let hir be proc translate_c_to_hir from CToHIR with c_ast

    Let runa_code be proc generate_runa_from_hir from RunaGen with hir

    Let is_valid be runa_code is not equal to 0

    If runa_code is not equal to 0:
        Let has_plus be proc string_contains from StringCore with runa_code, "plus"
        Let has_times be proc string_contains from StringCore with runa_code, "times"

        Set is_valid to has_plus
        If is_valid is equal to 1:
            Set is_valid to has_times
        End If

        proc deallocate from Layout with runa_code
    End If

    proc destroy_c_parser from CParser with parser

    Return proc print_test_result from "Operator mapping: +, * \u2192 plus, times", is_valid
End Process

