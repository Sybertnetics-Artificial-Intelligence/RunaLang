Process called "test_function_declaration_generation" returns Integer:
    Note: Test function declaration generation

    Let c_source be "int add(int a, int b) { return a + b; }"
    Let parser be proc create_c_parser from CParser with c_source
    Let c_ast be proc parse_program from CParser with parser
    Let hir be proc translate_c_to_hir from CToHIR with c_ast

    Let runa_code be proc generate_runa_from_hir from RunaGen with hir

    Let is_valid be runa_code is not equal to 0

    If runa_code is not equal to 0:
        Let has_process be proc string_contains from StringCore with runa_code, "Process called"
        Let has_takes be proc string_contains from StringCore with runa_code, "takes"
        Let has_returns be proc string_contains from StringCore with runa_code, "returns"
        Let has_end_process be proc string_contains from StringCore with runa_code, "End Process"

        Set is_valid to has_process
        If is_valid is equal to 1:
            Set is_valid to has_takes
        End If
        If is_valid is equal to 1:
            Set is_valid to has_returns
        End If
        If is_valid is equal to 1:
            Set is_valid to has_end_process
        End If

        proc deallocate from Layout with runa_code
    End If

    proc destroy_c_parser from CParser with parser

    Return proc print_test_result from "Declaration: function \u2192 Process", is_valid
End Process

