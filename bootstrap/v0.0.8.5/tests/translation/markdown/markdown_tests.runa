Note: ============================================================================
Note: Round-Trip Tests
Note: ============================================================================

Note: Test 22: Round-Trip Simple Document
Note: ============================================================================

Process called "test_roundtrip_simple" returns Integer:
    Note: Test Markdown → HIR → Markdown round-trip

    Let md_input be "# Title\n\nThis is a paragraph with **bold** and *italic* text."

    Let translation_context be 0
    Let hir_root be proc translate_markdown_to_hir from Frontend with md_input, translation_context

    If hir_root is equal to 0:
        Return proc create_test_result from "test_roundtrip_simple", 0, "Failed to translate to HIR"
    End If

    Let md_output be proc generate_markdown_from_hir from Backend with hir_root, translation_context

    If md_output is equal to 0:
        Return proc create_test_result from "test_roundtrip_simple", 0, "Failed to generate Markdown"
    End If

    Let hir_root2 be proc translate_markdown_to_hir from Frontend with md_output, translation_context

    If hir_root2 is equal to 0:
        Return proc create_test_result from "test_roundtrip_simple", 0, "Failed to re-parse generated Markdown"
    End If

    Return proc create_test_result from "test_roundtrip_simple", 1, 0
End Process

