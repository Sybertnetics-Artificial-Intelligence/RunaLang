    If md_output is equal to 0:
        Return proc create_test_result from "test_roundtrip_complex", 0, "Failed to generate Markdown"
    End If

    Let hir_root2 be proc translate_markdown_to_hir from Frontend with md_output, translation_context

    If hir_root2 is equal to 0:
        Return proc create_test_result from "test_roundtrip_complex", 0, "Failed to re-parse generated Markdown"
    End If

    Return proc create_test_result from "test_roundtrip_complex", 1, 0
End Process

Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_all_markdown_tests" returns Integer:
    Note: Run all Markdown tests and report results

    @Reasoning:
    Executes all test cases and counts passed/failed tests.
    Returns 1 if all tests pass, 0 if any fail.
    @End Reasoning

    Let total_tests be 23
    Let passed_tests be 0

    Note: Parsing Tests (1-18)
    Let result be proc test_atx_headings
    Let result_passed be proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_setext_headings
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_unordered_lists
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_ordered_lists
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_nested_lists
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_emphasis
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_strong
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_combined_emphasis_strong
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_links
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_images
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_inline_code
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_code_blocks
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_blockquotes
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_nested_blockquotes
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_horizontal_rules
