Note:
Markdown Translator Tests

Comprehensive test suite for Markdown frontend and backend translators.
Tests parsing, generation, round-trip translation, and edge cases.

Test Categories:
- Headings (ATX and Setext)
- Lists (ordered, unordered, nested)
- Emphasis and strong (italic, bold)
- Links and images
- Code blocks and inline code
- Blockquotes
- Tables (GFM)
- Horizontal rules
- Mixed content and complex documents
- Round-trip translation (Markdown → HIR → Markdown)
- Edge cases (escaping, nested structures)

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/markdown/markdown_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/markdown/markdown_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/markdown/markdown_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/markdown/markdown_emitter.runa
- compiler/middle/gungnir/hir/translation/backends/markdown/hir_to_markdown.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/memory/layout.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/markdown/markdown_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/markdown/markdown_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/markdown/markdown_to_hir.runa" as Frontend
Import "compiler/middle/gungnir/hir/translation/backends/markdown/hir_to_markdown.runa" as Backend
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Test Infrastructure
Note: ============================================================================

Type called "MarkdownTestResult":
    test_name as Integer        Note: Test name
    passed as Integer           Note: Boolean: 1 if passed
    error_message as Integer    Note: Error message (if failed)
End Type

Process called "create_test_result" takes test_name as Integer, passed as Integer, error_message as Integer returns Integer:
    Note: Create test result

    Let result_size be 24  Note: MarkdownTestResult: 3 fields × 8 bytes
    Let result be proc allocate from Layout with result_size

    If result is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with result, 0, test_name
    proc memory_set_int64 from Layout with result, 8, passed
    proc memory_set_int64 from Layout with result, 16, error_message

    Return result
End Process

Process called "strings_equal" takes str1 as Integer, str2 as Integer returns Integer:
    Note: Compare two null-terminated strings for equality

    If str1 is equal to 0:
        If str2 is equal to 0:
            Return 1
        End If
        Return 0
    End If

    If str2 is equal to 0:
        Return 0
    End If

    Let len1 be proc string_length from StringCore with str1
    Let len2 be proc string_length from StringCore with str2

    If len1 is not equal to len2:
        Return 0
    End If

    Let index be 0
    While index is less than len1:
        Let c1 be proc memory_get_byte from Layout with str1, index
        Let c2 be proc memory_get_byte from Layout with str2, index

        If c1 is not equal to c2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Test 1: ATX Headings
Note: ============================================================================

Process called "test_atx_headings" returns Integer:
    Note: Test parsing ATX headings

    Let md_input be "# Heading 1\n## Heading 2\n### Heading 3\n#### Heading 4\n##### Heading 5\n###### Heading 6"

    Note: Parse Markdown
    Let md_ast be proc parse_markdown from Parser with md_input

    If md_ast is equal to 0:
        Return proc create_test_result from "test_atx_headings", 0, "Failed to parse Markdown"
    End If

    Note: Translate to HIR
    Let translation_context be 0  Note: Null context for testing
    Let hir_root be proc translate_markdown_to_hir from Frontend with md_input, translation_context

    If hir_root is equal to 0:
        Return proc create_test_result from "test_atx_headings", 0, "Failed to translate to HIR"
    End If

    Return proc create_test_result from "test_atx_headings", 1, 0
End Process

