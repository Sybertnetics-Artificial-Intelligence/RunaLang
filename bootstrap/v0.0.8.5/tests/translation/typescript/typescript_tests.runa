Note:
TypeScript Language Translator Tests - Comprehensive test suite

This file provides comprehensive tests for the TypeScript language translator,
covering lexing, parsing, TypeScript→HIR translation, HIR→TypeScript generation,
and round-trip translation preservation.

Test Coverage:
- Lexer: Keywords (including TypeScript-specific), operators, literals
- Parser: Interfaces, type aliases, enums, classes with TypeScript features
- Translation: TypeScript→HIR→TypeScript round-trip preservation
- Generation: HIR→TypeScript code generation with proper type annotations
- Integration: Complete translation pipeline validation

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/typescript/typescript_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/typescript/typescript_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/typescript/typescript_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/typescript/typescript_emitter.runa
- compiler/middle/gungnir/hir/translation/backends/typescript/hir_to_typescript.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/typescript/typescript_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/typescript/typescript_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/typescript/typescript_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/typescript/typescript_emitter.runa" as Emitter
Import "compiler/middle/gungnir/hir/translation/backends/typescript/hir_to_typescript.runa" as FromHIR
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Test Utilities
Note: ============================================================================

Process called "test_assert" takes condition as Integer, message as Integer returns Integer:
    Note: Assert condition is true, print message if false

    If condition is equal to 0:
        proc print_string from StringCore with "FAIL: "
        proc print_string from StringCore with message
        proc print_newline from StringCore
        Return 0
    End If

    Return 1
End Process

Process called "test_assert_equal" takes actual as Integer, expected as Integer, message as Integer returns Integer:
    Note: Assert two values are equal

    If actual is not equal to expected:
        proc print_string from StringCore with "FAIL: "
        proc print_string from StringCore with message
        proc print_string from StringCore with " (expected "
        proc print_int from StringCore with expected
        proc print_string from StringCore with ", got "
        proc print_int from StringCore with actual
        proc print_string from StringCore with ")"
        proc print_newline from StringCore
        Return 0
    End If

    Return 1
End Process

Process called "test_assert_string_equal" takes actual as Integer, expected as Integer, message as Integer returns Integer:
    Note: Assert two strings are equal

    Let are_equal be proc strings_equal from StringCore with actual, expected

    If are_equal is equal to 0:
        proc print_string from StringCore with "FAIL: "
        proc print_string from StringCore with message
        proc print_newline from StringCore
        proc print_string from StringCore with "  Expected: "
        proc print_string from StringCore with expected
        proc print_newline from StringCore
        proc print_string from StringCore with "  Got: "
        proc print_string from StringCore with actual
        proc print_newline from StringCore
        Return 0
    End If

    Return 1
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_lexer_typescript_keywords" returns Integer:
    Note: Test TypeScript-specific keyword tokenization

    proc print_string from StringCore with "Testing TypeScript lexer keywords..."
    proc print_newline from StringCore

    Let source be "interface type enum abstract readonly private public protected"
    Let lexer be proc create_lexer from Lexer with source

    Let token1 be proc next_token from Lexer with lexer
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc test_assert_equal from type1, TOKEN_INTERFACE from Lexer, "Expected TOKEN_INTERFACE"

    Let token2 be proc next_token from Lexer with lexer
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc test_assert_equal from type2, TOKEN_TYPE from Lexer, "Expected TOKEN_TYPE"

    Let token3 be proc next_token from Lexer with lexer
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc test_assert_equal from type3, TOKEN_ENUM from Lexer, "Expected TOKEN_ENUM"

    Let token4 be proc next_token from Lexer with lexer
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc test_assert_equal from type4, TOKEN_ABSTRACT from Lexer, "Expected TOKEN_ABSTRACT"

    Let token5 be proc next_token from Lexer with lexer
    Let type5 be proc memory_get_int64 from Layout with token5, 0
    proc test_assert_equal from type5, TOKEN_READONLY from Lexer, "Expected TOKEN_READONLY"

    Let token6 be proc next_token from Lexer with lexer
    Let type6 be proc memory_get_int64 from Layout with token6, 0
    proc test_assert_equal from type6, TOKEN_PRIVATE from Lexer, "Expected TOKEN_PRIVATE"

    Let token7 be proc next_token from Lexer with lexer
    Let type7 be proc memory_get_int64 from Layout with token7, 0
    proc test_assert_equal from type7, TOKEN_PUBLIC from Lexer, "Expected TOKEN_PUBLIC"

    Let token8 be proc next_token from Lexer with lexer
    Let type8 be proc memory_get_int64 from Layout with token8, 0
    proc test_assert_equal from type8, TOKEN_PROTECTED from Lexer, "Expected TOKEN_PROTECTED"

    proc destroy_lexer from Lexer with lexer

    proc print_string from StringCore with "PASS: Lexer TypeScript keywords test"
    proc print_newline from StringCore

    Return 1
End Process

Process called "test_lexer_operators" returns Integer:
    Note: Test TypeScript operator tokenization

    proc print_string from StringCore with "Testing TypeScript lexer operators..."
    proc print_newline from StringCore

    Let source be "=== !== ?? ?. => ..."
    Let lexer be proc create_lexer from Lexer with source

    Let token1 be proc next_token from Lexer with lexer
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc test_assert_equal from type1, TOKEN_EQUAL_EQUAL_EQUAL from Lexer, "Expected TOKEN_EQUAL_EQUAL_EQUAL (===)"

    Let token2 be proc next_token from Lexer with lexer
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc test_assert_equal from type2, TOKEN_BANG_EQUAL_EQUAL from Lexer, "Expected TOKEN_BANG_EQUAL_EQUAL (!==)"

    Let token3 be proc next_token from Lexer with lexer
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc test_assert_equal from type3, TOKEN_QUESTION_QUESTION from Lexer, "Expected TOKEN_QUESTION_QUESTION (??)"

    Let token4 be proc next_token from Lexer with lexer
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc test_assert_equal from type4, TOKEN_QUESTION_DOT from Lexer, "Expected TOKEN_QUESTION_DOT (?.)"

    Let token5 be proc next_token from Lexer with lexer
    Let type5 be proc memory_get_int64 from Layout with token5, 0
    proc test_assert_equal from type5, TOKEN_ARROW from Lexer, "Expected TOKEN_ARROW (=>)"

    Let token6 be proc next_token from Lexer with lexer
    Let type6 be proc memory_get_int64 from Layout with token6, 0
    proc test_assert_equal from type6, TOKEN_SPREAD from Lexer, "Expected TOKEN_SPREAD (...)"

    proc destroy_lexer from Lexer with lexer

    proc print_string from StringCore with "PASS: Lexer operators test"
    proc print_newline from StringCore

    Return 1
End Process

Process called "test_lexer_literals" returns Integer:
    Note: Test TypeScript literal tokenization

    proc print_string from StringCore with "Testing TypeScript lexer literals..."
    proc print_newline from StringCore

    Let source be "123 3.14 \"hello\" 'world' `template` true false null"
    Let lexer be proc create_lexer from Lexer with source

    Let token1 be proc next_token from Lexer with lexer
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc test_assert_equal from type1, TOKEN_INTEGER from Lexer, "Expected TOKEN_INTEGER"

    Let token2 be proc next_token from Lexer with lexer
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc test_assert_equal from type2, TOKEN_FLOAT from Lexer, "Expected TOKEN_FLOAT"

    Let token3 be proc next_token from Lexer with lexer
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc test_assert_equal from type3, TOKEN_STRING_LITERAL from Lexer, "Expected TOKEN_STRING_LITERAL"

    Let token4 be proc next_token from Lexer with lexer
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc test_assert_equal from type4, TOKEN_STRING_LITERAL from Lexer, "Expected TOKEN_STRING_LITERAL"

    Let token5 be proc next_token from Lexer with lexer
    Let type5 be proc memory_get_int64 from Layout with token5, 0
    proc test_assert_equal from type5, TOKEN_TEMPLATE_STRING from Lexer, "Expected TOKEN_TEMPLATE_STRING"

    Let token6 be proc next_token from Lexer with lexer
    Let type6 be proc memory_get_int64 from Layout with token6, 0
    proc test_assert_equal from type6, TOKEN_TRUE from Lexer, "Expected TOKEN_TRUE"

    Let token7 be proc next_token from Lexer with lexer
    Let type7 be proc memory_get_int64 from Layout with token7, 0
    proc test_assert_equal from type7, TOKEN_FALSE from Lexer, "Expected TOKEN_FALSE"

    Let token8 be proc next_token from Lexer with lexer
    Let type8 be proc memory_get_int64 from Layout with token8, 0
    proc test_assert_equal from type8, TOKEN_NULL from Lexer, "Expected TOKEN_NULL"

    proc destroy_lexer from Lexer with lexer

    proc print_string from StringCore with "PASS: Lexer literals test"
    proc print_newline from StringCore

    Return 1
End Process

