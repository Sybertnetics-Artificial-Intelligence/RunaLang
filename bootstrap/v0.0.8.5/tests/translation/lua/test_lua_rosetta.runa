Note:
Lua Translation - Comprehensive Test Suite

This file provides comprehensive testing for the Lua Translation implementation,
covering lexing, parsing, translation to HIR, and code generation back to Lua.

Test Coverage:
- Lexer: All Lua tokens, keywords, operators, literals
- Parser: Complete Lua grammar including tables, metatables, coroutines
- Lua→HIR: Translation of Lua semantics to universal IR
- HIR→Lua: Generation of idiomatic Lua from HIR
- Round-trip: Lua→HIR→Lua preservation
- Edge cases: Error handling, boundary conditions, complex constructs

Lua Features Tested:
- Tables (arrays, dictionaries, mixed)
- Metatables and metamethods
- Coroutines (create, resume, yield)
- Multiple return values
- Varargs (...)
- String patterns and string library
- Module system (require)
- Iterators (pairs, ipairs, custom)
- Closures and upvalues
- Tail calls
- Error handling (pcall, xpcall, error)
- Weak tables
- Environments and _ENV
- String metatable
- Global vs local scope

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/lua/lua_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/lua/lua_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/lua/lua_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/lua/hir_to_lua.runa
- compiler/middle/gungnir/hir/translation/backends/lua/lua_emitter.runa
- compiler/frontend/primitives/test_framework.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/lua/lua_lexer.runa" as LuaLexer
Import "compiler/middle/gungnir/hir/translation/frontends/lua/lua_parser.runa" as LuaParser
Import "compiler/middle/gungnir/hir/translation/frontends/lua/lua_to_hir.runa" as LuaToHIR
Import "compiler/middle/gungnir/hir/translation/backends/lua/hir_to_lua.runa" as HIRToLua
Import "compiler/middle/gungnir/hir/translation/backends/lua/lua_emitter.runa" as LuaEmitter
Import "compiler/frontend/primitives/test_framework.runa" as Test
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test State
Note: ============================================================================

Type called "LuaTestState":
    tests_run as Integer
    tests_passed as Integer
    tests_failed as Integer
    current_test as String
End Type

Let test_state be a value of type LuaTestState with
    tests_run as 0,
    tests_passed as 0,
    tests_failed as 0,
    current_test as ""

Note: ============================================================================
Note: Test Framework Helpers
Note: ============================================================================

Process called "start_test" takes name as String:
    Note: Begin a new test

    Set test_state.current_test to name
    Set test_state.tests_run to test_state.tests_run plus 1

    proc test_log from Test with "Running test: ", name
End Process

Process called "assert_true" takes condition as Integer, message as String:
    Note: Assert condition is true

    If condition is equal to 1:
        Set test_state.tests_passed to test_state.tests_passed plus 1
        proc test_log from Test with "  PASS: ", message
    Otherwise:
        Set test_state.tests_failed to test_state.tests_failed plus 1
        proc test_error from Test with "  FAIL: ", message
    End If
End Process

Process called "assert_equal" takes actual as String, expected as String, message as String:
    Note: Assert actual equals expected

    Let are_equal be proc string_equals from StringCore with actual, expected

    If are_equal is equal to 1:
        Set test_state.tests_passed to test_state.tests_passed plus 1
        proc test_log from Test with "  PASS: ", message
    Otherwise:
        Set test_state.tests_failed to test_state.tests_failed plus 1
        proc test_error from Test with "  FAIL: ", message
        proc test_error from Test with "    Expected: ", expected
        proc test_error from Test with "    Actual:   ", actual
    End If
End Process

Process called "assert_not_null" takes value as Integer, message as String:
    Note: Assert value is not null

    If value is not equal to 0:
        Set test_state.tests_passed to test_state.tests_passed plus 1
        proc test_log from Test with "  PASS: ", message
    Otherwise:
        Set test_state.tests_failed to test_state.tests_failed plus 1
        proc test_error from Test with "  FAIL: ", message
    End If
End Process

Process called "print_test_summary":
    Note: Print test results summary

    proc test_log from Test with "\n=========================================="
    proc test_log from Test with "Lua Translation Test Summary"
    proc test_log from Test with "=========================================="
    proc test_log from Test with "Tests Run:    ", test_state.tests_run
    proc test_log from Test with "Tests Passed: ", test_state.tests_passed
    proc test_log from Test with "Tests Failed: ", test_state.tests_failed

    If test_state.tests_failed is equal to 0:
        proc test_log from Test with "\nALL TESTS PASSED ✓"
    Otherwise:
        proc test_error from Test with "\nSOME TESTS FAILED ✗"
    End If

    proc test_log from Test with "==========================================\n"
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_lexer_keywords":
    Note: Test Lua keyword tokenization

    proc start_test from "Lexer - Keywords"

    Let source be "function end if then else elseif while do for in repeat until break return local"
    Let lexer be proc create_lexer from LuaLexer with source

    proc assert_not_null from lexer, "Lexer created"

    Let token be proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "FUNCTION", "function keyword"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "END", "end keyword"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "IF", "if keyword"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "THEN", "then keyword"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "ELSE", "else keyword"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "ELSEIF", "elseif keyword"
End Process

Process called "test_lexer_operators":
    Note: Test Lua operator tokenization

    proc start_test from "Lexer - Operators"

    Let source be "+ - * / % ^ # == ~= <= >= < > = ( ) { } [ ] ; : , . .. ..."
    Let lexer be proc create_lexer from LuaLexer with source

    proc assert_not_null from lexer, "Lexer created"

    Let token be proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "PLUS", "+ operator"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "MINUS", "- operator"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "STAR", "* operator"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "SLASH", "/ operator"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "PERCENT", "% operator"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "CARET", "^ operator"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "HASH", "# operator"
End Process

Process called "test_lexer_literals":
    Note: Test Lua literal tokenization

    proc start_test from "Lexer - Literals"

    Let source be "123 45.67 0x1A 'string' \"another\" [[multiline]] true false nil"
    Let lexer be proc create_lexer from LuaLexer with source

    proc assert_not_null from lexer, "Lexer created"

    Let token be proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "NUMBER", "integer literal"
    proc assert_equal from proc token_value from LuaLexer with token, "123", "integer value"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "NUMBER", "float literal"
    proc assert_equal from proc token_value from LuaLexer with token, "45.67", "float value"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "NUMBER", "hex literal"
    proc assert_equal from proc token_value from LuaLexer with token, "0x1A", "hex value"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "STRING", "single-quoted string"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "STRING", "double-quoted string"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "STRING", "multiline string"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "TRUE", "true literal"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "FALSE", "false literal"

    Set token to proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "NIL", "nil literal"
End Process

Process called "test_lexer_comments":
    Note: Test Lua comment tokenization

    proc start_test from "Lexer - Comments"

    Let source be "-- single line\n--[[ multi\nline ]] x"
    Let lexer be proc create_lexer from LuaLexer with source

    proc assert_not_null from lexer, "Lexer created"

    Note: Comments should be skipped, next token should be 'x'
    Let token be proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "IDENTIFIER", "identifier after comments"
    proc assert_equal from proc token_value from LuaLexer with token, "x", "identifier value"
End Process

