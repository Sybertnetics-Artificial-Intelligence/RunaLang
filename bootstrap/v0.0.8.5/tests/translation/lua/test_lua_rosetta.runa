    Let lua_code be proc generate from HIRToLua with generator, hir

    proc assert_not_null from lua_code, "Lua code generated from HIR"

    Let contains_brace be proc string_contains from StringCore with lua_code, "{"
    proc assert_true from contains_brace, "Generated code contains table constructor"
End Process

Note: ============================================================================
Note: Round-Trip Tests (Lua → HIR → Lua)
Note: ============================================================================

Process called "test_roundtrip_function":
    Note: Test Lua function round-trip preservation

    proc start_test from "Round-Trip - Function"

    Let source be "function add(a, b)\n  return a + b\nend"

    Note: Parse original Lua
    Let lexer1 be proc create_lexer from LuaLexer with source
    Let parser1 be proc create_parser from LuaParser with lexer1
    Let ast1 be proc parse from LuaParser with parser1

    Note: Translate to HIR
    Let translator be proc create_translator from LuaToHIR
    Let hir be proc translate from LuaToHIR with translator, ast1

    Note: Generate Lua back
    Let generator be proc create_generator from HIRToLua
    Let lua_code be proc generate from HIRToLua with generator, hir

    Note: Parse generated Lua
    Let lexer2 be proc create_lexer from LuaLexer with lua_code
    Let parser2 be proc create_parser from LuaParser with lexer2
    Let ast2 be proc parse from LuaParser with parser2

    proc assert_not_null from ast2, "Round-trip preserved function structure"
End Process

Process called "test_roundtrip_table":
    Note: Test Lua table round-trip preservation

    proc start_test from "Round-Trip - Table"

    Let source be "{x = 1, y = 2, z = 3}"

    Let lexer1 be proc create_lexer from LuaLexer with source
    Let parser1 be proc create_parser from LuaParser with lexer1
    Let ast1 be proc parse from LuaParser with parser1

    Let translator be proc create_translator from LuaToHIR
    Let hir be proc translate from LuaToHIR with translator, ast1

    Let generator be proc create_generator from HIRToLua
    Let lua_code be proc generate from HIRToLua with generator, hir

    Let lexer2 be proc create_lexer from LuaLexer with lua_code
    Let parser2 be proc create_parser from LuaParser with lexer2
    Let ast2 be proc parse from LuaParser with parser2

    proc assert_not_null from ast2, "Round-trip preserved table structure"
End Process

Process called "test_roundtrip_control_flow":
    Note: Test Lua control flow round-trip preservation

    proc start_test from "Round-Trip - Control Flow"

    Let source be "if x > 0 then\n  return x\nelse\n  return -x\nend"

    Let lexer1 be proc create_lexer from LuaLexer with source
    Let parser1 be proc create_parser from LuaParser with lexer1
    Let ast1 be proc parse from LuaParser with parser1

    Let translator be proc create_translator from LuaToHIR
    Let hir be proc translate from LuaToHIR with translator, ast1

    Let generator be proc create_generator from HIRToLua
    Let lua_code be proc generate from HIRToLua with generator, hir

    Let lexer2 be proc create_lexer from LuaLexer with lua_code
    Let parser2 be proc create_parser from LuaParser with lexer2
    Let ast2 be proc parse from LuaParser with parser2

    proc assert_not_null from ast2, "Round-trip preserved control flow"
End Process

Note: ============================================================================
Note: Emitter Tests
Note: ============================================================================

Process called "test_emitter_formatting":
    Note: Test Lua code formatting

    proc start_test from "Emitter - Formatting"

    Let unformatted be "function add(a,b)return a+b end"
    Let formatted be proc emit_lua_to_string from LuaEmitter with unformatted

    proc assert_not_null from formatted, "Code formatted"

    Note: Check that formatting added proper spacing and newlines
    Let has_newline be proc string_contains from StringCore with formatted, "\n"
    proc assert_true from has_newline, "Formatted code has newlines"
End Process

Process called "test_emitter_indentation":
    Note: Test Lua code indentation

    proc start_test from "Emitter - Indentation"

    Let code be "function test()\nif true then\nprint('hello')\nend\nend"
    Let formatted be proc emit_lua_to_string from LuaEmitter with code

    proc assert_not_null from formatted, "Code indented"

    Note: Check that indentation was normalized
    Let has_spaces be proc string_contains from StringCore with formatted, "  "
    proc assert_true from has_spaces, "Formatted code has indentation"
End Process

Process called "test_emitter_validation":
    Note: Test Lua code syntax validation

    proc start_test from "Emitter - Validation"

    Note: Valid code
    Let valid_code be "function test()\n  return 42\nend"
    Let config1 be proc create_emitter_config from LuaEmitter
    Let emitter1 be proc create_emitter from LuaEmitter with config1
    Let result1 be proc emit_lua_code from LuaEmitter with emitter1, valid_code

    proc assert_not_null from result1, "Valid code emitted"

    Note: Invalid code (unbalanced)
    Let invalid_code be "function test()\n  return 42"
    Let config2 be proc create_emitter_config from LuaEmitter
    Let emitter2 be proc create_emitter from LuaEmitter with config2
    Let result2 be proc emit_lua_code from LuaEmitter with emitter2, invalid_code

    Let had_error be proc had_emitter_errors from LuaEmitter with emitter2
    proc assert_true from had_error, "Invalid code caught by validation"
End Process

