    Let lua_code be proc generate from HIRToLua with generator, hir

    proc assert_not_null from lua_code, "Iterator translated"

    Let contains_pairs be proc string_contains from StringCore with lua_code, "pairs"
    proc assert_true from contains_pairs, "Generated code contains iterator"
End Process

