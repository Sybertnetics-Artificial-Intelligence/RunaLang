Process called "test_integration_fibonacci":
    Note: Test complete Fibonacci function translation

    proc start_test from "Integration - Fibonacci"

    Let source be "function fib(n)\n  if n <= 1 then\n    return n\n  else\n    return fib(n-1) + fib(n-2)\n  end\nend"

    Let lexer be proc create_lexer from LuaLexer with source
    Let parser be proc create_parser from LuaParser with lexer
    Let ast be proc parse from LuaParser with parser

    Let translator be proc create_translator from LuaToHIR
    Let hir be proc translate from LuaToHIR with translator, ast

    Let generator be proc create_generator from HIRToLua
    Let lua_code be proc generate from HIRToLua with generator, hir

    proc assert_not_null from lua_code, "Fibonacci function translated"

    Let contains_fib be proc string_contains from StringCore with lua_code, "fib"
    proc assert_true from contains_fib, "Generated code contains function name"
End Process

Process called "test_integration_table_operations":
    Note: Test complete table operations translation

    proc start_test from "Integration - Table Operations"

    Let source be "local t = {}\nt[1] = 'a'\nt.key = 'b'\nreturn t"

    Let lexer be proc create_lexer from LuaLexer with source
    Let parser be proc create_parser from LuaParser with lexer
    Let ast be proc parse from LuaParser with parser

    Let translator be proc create_translator from LuaToHIR
