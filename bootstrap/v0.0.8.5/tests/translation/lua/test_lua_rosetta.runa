Note: Code Generation Tests (HIR → Lua)
Note: ============================================================================

Process called "test_generate_function":
    Note: Test generating Lua function from HIR

    proc start_test from "Code Gen - Function from HIR"

    Let source be "function add(a, b)\n  return a + b\nend"
    Let lexer be proc create_lexer from LuaLexer with source
    Let parser be proc create_parser from LuaParser with lexer
    Let ast be proc parse from LuaParser with parser
    Let translator be proc create_translator from LuaToHIR
    Let hir be proc translate from LuaToHIR with translator, ast

    Let generator be proc create_generator from HIRToLua
    Let lua_code be proc generate from HIRToLua with generator, hir

    proc assert_not_null from lua_code, "Lua code generated from HIR"

    Let contains_function be proc string_contains from StringCore with lua_code, "function"
    proc assert_true from contains_function, "Generated code contains 'function' keyword"
End Process

