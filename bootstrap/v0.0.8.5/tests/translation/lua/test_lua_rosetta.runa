Process called "test_edge_case_long_strings":
    Note: Test long string literals

    proc start_test from "Edge Case - Long Strings"

    Let source be "[[This is a very long string that spans multiple lines and has lots of text]]"
    Let lexer be proc create_lexer from LuaLexer with source

    Let token be proc next_token from LuaLexer with lexer
    proc assert_equal from proc token_type from LuaLexer with token, "STRING", "Long string tokenized"
End Process

Process called "test_edge_case_numeric_for_variations":
    Note: Test numeric for loop variations

    proc start_test from "Edge Case - Numeric For Variations"

    Note: With step
    Let source1 be "for i = 1, 10, 2 do end"
    Let lexer1 be proc create_lexer from LuaLexer with source1
    Let parser1 be proc create_parser from LuaParser with lexer1
    Let ast1 be proc parse from LuaParser with parser1
    proc assert_not_null from ast1, "For loop with step parsed"

    Note: Without step
    Let source2 be "for i = 1, 10 do end"
    Let lexer2 be proc create_lexer from LuaLexer with source2
    Let parser2 be proc create_parser from LuaParser with lexer2
    Let ast2 be proc parse from LuaParser with parser2
    proc assert_not_null from ast2, "For loop without step parsed"
End Process

