Note:
Protocol Buffers Translator Tests

Comprehensive test suite for Protocol Buffers frontend and backend translators.
Tests parsing, generation, round-trip translation, and edge cases.

Test Categories:
- Syntax declarations (proto2, proto3)
- Package declarations
- Import statements
- Message definitions (simple, nested)
- Field types (scalar, message, enum, repeated, map)
- Enum definitions
- Service definitions (gRPC)
- Options and custom options
- Comments
- Error handling (syntax errors, invalid types)
- Round-trip translation (Proto → HIR → Proto)
- Edge cases (reserved fields, oneof, extensions)

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/protobuf/protobuf_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/protobuf/protobuf_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/protobuf/protobuf_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/protobuf/protobuf_emitter.runa
- compiler/middle/gungnir/hir/translation/backends/protobuf/hir_to_protobuf.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/memory/layout.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/protobuf/protobuf_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/protobuf/protobuf_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/protobuf/protobuf_to_hir.runa" as Frontend
Import "compiler/middle/gungnir/hir/translation/backends/protobuf/hir_to_protobuf.runa" as Backend
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Test Infrastructure
Note: ============================================================================

Type called "ProtobufTestResult":
    test_name as Integer        Note: Test name
    passed as Integer           Note: Boolean: 1 if passed
    error_message as Integer    Note: Error message (if failed)
End Type

Process called "create_test_result" takes test_name as Integer, passed as Integer, error_message as Integer returns Integer:
    Note: Create test result

    Let result_size be 24  Note: ProtobufTestResult: 3 fields × 8 bytes
    Let result be proc allocate from Layout with result_size

    If result is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with result, 0, test_name
    proc memory_set_int64 from Layout with result, 8, passed
    proc memory_set_int64 from Layout with result, 16, error_message

    Return result
End Process

Process called "strings_equal" takes str1 as Integer, str2 as Integer returns Integer:
    Note: Compare two null-terminated strings for equality

    If str1 is equal to 0:
        If str2 is equal to 0:
            Return 1
        End If
        Return 0
    End If

    If str2 is equal to 0:
        Return 0
    End If

    Let len1 be proc string_length from StringCore with str1
    Let len2 be proc string_length from StringCore with str2

    If len1 is not equal to len2:
        Return 0
    End If

    Let index be 0
    While index is less than len1:
        Let c1 be proc memory_get_byte from Layout with str1, index
        Let c2 be proc memory_get_byte from Layout with str2, index

        If c1 is not equal to c2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Test 1: Syntax Declaration (Proto3)
Note: ============================================================================

Process called "test_syntax_proto3" returns Integer:
    Note: Test parsing proto3 syntax declaration

    Let proto_input be "syntax = \"proto3\";\n\nmessage Person {\n  string name = 1;\n  int32 age = 2;\n}"

    Note: Parse Protocol Buffers
    Let proto_ast be proc parse_protobuf from Parser with proto_input

    If proto_ast is equal to 0:
        Return proc create_test_result from "test_syntax_proto3", 0, "Failed to parse protobuf"
    End If

    Note: Translate to HIR
    Let translation_context be 0  Note: Null context for testing
    Let hir_root be proc translate_protobuf_to_hir from Frontend with proto_input, translation_context

    If hir_root is equal to 0:
        Return proc create_test_result from "test_syntax_proto3", 0, "Failed to translate to HIR"
    End If

    Return proc create_test_result from "test_syntax_proto3", 1, 0
End Process

