Note: Test 19: Round-Trip Simple Proto
Note: ============================================================================

Process called "test_roundtrip_simple" returns Integer:
    Note: Test Proto → HIR → Proto round-trip

    Let proto_input be "syntax = \"proto3\";\n\npackage test;\n\nmessage Person {\n  string name = 1;\n  int32 age = 2;\n}"

    Let translation_context be 0
    Let hir_root be proc translate_protobuf_to_hir from Frontend with proto_input, translation_context

    If hir_root is equal to 0:
        Return proc create_test_result from "test_roundtrip_simple", 0, "Failed to translate to HIR"
    End If

    Let proto_output be proc generate_protobuf_from_hir from Backend with hir_root, translation_context

    If proto_output is equal to 0:
        Return proc create_test_result from "test_roundtrip_simple", 0, "Failed to generate protobuf"
    End If

    Let hir_root2 be proc translate_protobuf_to_hir from Frontend with proto_output, translation_context

    If hir_root2 is equal to 0:
        Return proc create_test_result from "test_roundtrip_simple", 0, "Failed to re-parse generated protobuf"
    End If

    Return proc create_test_result from "test_roundtrip_simple", 1, 0
End Process

