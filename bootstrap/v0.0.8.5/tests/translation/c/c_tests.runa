Note:
C Translator Tests - Comprehensive test suite for C Translation implementation

This file contains comprehensive tests for the C language translator including:
- Lexer tokenization tests
- Parser AST construction tests
- Semantic analysis tests
- C→HIR translation tests
- HIR→C code generation tests
- Round-trip translation tests

Test Coverage:
- Simple function declarations
- Variable declarations with initializers
- Control flow (if, while, for, switch)
- Expressions (binary, unary, call, subscript, member access)
- Pointers and arrays
- Struct/union types
- Full programs

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/c/c_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/c/c_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/c/c_semantic.runa
- compiler/middle/gungnir/hir/translation/frontends/c/c_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/c/hir_to_c.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/c/c_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/c/c_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/c/c_semantic.runa" as Semantic
Import "compiler/middle/gungnir/hir/translation/frontends/c/c_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/c/hir_to_c.runa" as FromHIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test Utilities
Note: ============================================================================

Process called "print_test_result" takes test_name as Integer, passed as Integer returns Integer:
    Note: Print test result

    If passed is equal to 1:
        proc print from StringCore with "✓ "
        proc print from StringCore with test_name
        proc println from StringCore with " - PASSED"
    End If

    If passed is equal to 0:
        proc print from StringCore with "✗ "
        proc print from StringCore with test_name
        proc println from StringCore with " - FAILED"
    End If

    Return passed
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_lexer_keywords" returns Integer:
    Note: Test lexer keyword recognition

    Let source be "int main() { return 0; }"
    Let lexer be proc create_c_lexer from Lexer with source

    Let token1 be proc next_token from Lexer with lexer
    Let is_int be token1 is equal to TOKEN_INT from Lexer

    Let token2 be proc next_token from Lexer with lexer
    Let is_identifier be token2 is equal to TOKEN_IDENTIFIER from Lexer

    Let token3 be proc next_token from Lexer with lexer
    Let is_lparen be token3 is equal to TOKEN_LPAREN from Lexer

    Let token4 be proc next_token from Lexer with lexer
    Let is_rparen be token4 is equal to TOKEN_RPAREN from Lexer

    Let token5 be proc next_token from Lexer with lexer
    Let is_lbrace be token5 is equal to TOKEN_LBRACE from Lexer

    Let token6 be proc next_token from Lexer with lexer
    Let is_return be token6 is equal to TOKEN_RETURN from Lexer

    proc destroy_c_lexer from Lexer with lexer

    Let all_correct be is_int
    If all_correct is equal to 1:
        Set all_correct to is_identifier
    End If
    If all_correct is equal to 1:
        Set all_correct to is_lparen
    End If
    If all_correct is equal to 1:
        Set all_correct to is_rparen
    End If
    If all_correct is equal to 1:
        Set all_correct to is_lbrace
    End If
    If all_correct is equal to 1:
        Set all_correct to is_return
    End If

    Return proc print_test_result from "Lexer: Keyword recognition", all_correct
End Process

Process called "test_lexer_operators" returns Integer:
    Note: Test lexer operator recognition

    Let source be "x = y + z * 2;"
    Let lexer be proc create_c_lexer from Lexer with source

    Let token1 be proc next_token from Lexer with lexer  Note: x
    Let token2 be proc next_token from Lexer with lexer  Note: =
    Let is_equals be token2 is equal to TOKEN_EQUALS from Lexer

    Let token3 be proc next_token from Lexer with lexer  Note: y
    Let token4 be proc next_token from Lexer with lexer  Note: +
    Let is_plus be token4 is equal to TOKEN_PLUS from Lexer

    Let token5 be proc next_token from Lexer with lexer  Note: z
    Let token6 be proc next_token from Lexer with lexer  Note: *
    Let is_star be token6 is equal to TOKEN_STAR from Lexer

    proc destroy_c_lexer from Lexer with lexer

    Let all_correct be is_equals
    If all_correct is equal to 1:
        Set all_correct to is_plus
    End If
    If all_correct is equal to 1:
        Set all_correct to is_star
    End If

    Return proc print_test_result from "Lexer: Operator recognition", all_correct
End Process

Process called "test_lexer_literals" returns Integer:
    Note: Test lexer literal recognition

    Let source be "42 3.14 'a' \"hello\""
    Let lexer be proc create_c_lexer from Lexer with source

    Let token1 be proc next_token from Lexer with lexer
    Let is_integer be token1 is equal to TOKEN_INTEGER from Lexer

    Let token2 be proc next_token from Lexer with lexer
    Let is_float be token2 is equal to TOKEN_FLOAT_LITERAL from Lexer

    Let token3 be proc next_token from Lexer with lexer
    Let is_char be token3 is equal to TOKEN_CHAR_LITERAL from Lexer

    Let token4 be proc next_token from Lexer with lexer
    Let is_string be token4 is equal to TOKEN_STRING_LITERAL from Lexer

    proc destroy_c_lexer from Lexer with lexer

    Let all_correct be is_integer
    If all_correct is equal to 1:
        Set all_correct to is_float
    End If
    If all_correct is equal to 1:
        Set all_correct to is_char
    End If
    If all_correct is equal to 1:
        Set all_correct to is_string
    End If

    Return proc print_test_result from "Lexer: Literal recognition", all_correct
End Process

Note: ============================================================================
Note: Parser Tests
Note: ============================================================================

Process called "test_parser_simple_function" returns Integer:
    Note: Test parser with simple function

    Let source be "int main() { return 0; }"
    Let parser be proc create_c_parser from Parser with source

    Let ast be proc parse_program from Parser with parser

    Let is_valid be ast is not equal to 0
    Let has_error be proc has_parse_error from Parser with parser
    Let no_error be has_error is equal to 0

    proc destroy_c_parser from Parser with parser

    Let passed be is_valid
    If passed is equal to 1:
        Set passed to no_error
    End If

    Return proc print_test_result from "Parser: Simple function", passed
End Process

