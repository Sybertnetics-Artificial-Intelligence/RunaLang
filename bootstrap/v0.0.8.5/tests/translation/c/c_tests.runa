Note: ============================================================================
Note: HIR→C Generation Tests
Note: ============================================================================

Process called "test_hir_to_c_simple_function" returns Integer:
    Note: Test HIR→C generation with simple function

    Let source be "int test() { return 42; }"
    Let parser be proc create_c_parser from Parser with source
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast
    Let generated be proc generate_c_from_hir from FromHIR with hir

    Let is_valid be generated is not equal to 0

    If generated is not equal to 0:
        proc deallocate from Layout with generated
    End If

    proc destroy_c_parser from Parser with parser

    Return proc print_test_result from "HIR→C: Simple function", is_valid
End Process

Process called "test_hir_to_c_variable_declaration" returns Integer:
    Note: Test HIR→C generation with variable declaration

    Let source be "int x = 10;"
    Let parser be proc create_c_parser from Parser with source
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast
    Let generated be proc generate_c_from_hir from FromHIR with hir

    Let is_valid be generated is not equal to 0

    If generated is not equal to 0:
        proc deallocate from Layout with generated
    End If

    proc destroy_c_parser from Parser with parser

    Return proc print_test_result from "HIR→C: Variable declaration", is_valid
End Process

Note: ============================================================================
Note: Round-Trip Translation Tests
Note: ============================================================================

Process called "test_roundtrip_simple_function" returns Integer:
    Note: Test round-trip translation (C → HIR → C)

    Let source be "int main() { return 0; }"
    Let parser be proc create_c_parser from Parser with source
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast
    Let generated be proc generate_c_from_hir from FromHIR with hir

    Let is_valid be generated is not equal to 0

    If generated is not equal to 0:
        Note: Verify generated code contains key elements
        Let contains_int be proc string_contains from StringCore with generated, "int"
        Let contains_main be proc string_contains from StringCore with generated, "main"
        Let contains_return be proc string_contains from StringCore with generated, "return"

        Set is_valid to contains_int
        If is_valid is equal to 1:
            Set is_valid to contains_main
        End If
        If is_valid is equal to 1:
            Set is_valid to contains_return
        End If

        proc deallocate from Layout with generated
    End If

    proc destroy_c_parser from Parser with parser

    Return proc print_test_result from "Round-trip: Simple function", is_valid
End Process

Process called "test_roundtrip_arithmetic" returns Integer:
    Note: Test round-trip with arithmetic expressions

    Let source be "int calc() { return 2 + 3 * 4; }"
    Let parser be proc create_c_parser from Parser with source
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast
    Let generated be proc generate_c_from_hir from FromHIR with hir

    Let is_valid be generated is not equal to 0

    If generated is not equal to 0:
        Let contains_plus be proc string_contains from StringCore with generated, "+"
        Let contains_star be proc string_contains from StringCore with generated, "*"

        Set is_valid to contains_plus
        If is_valid is equal to 1:
            Set is_valid to contains_star
        End If

        proc deallocate from Layout with generated
    End If

    proc destroy_c_parser from Parser with parser

    Return proc print_test_result from "Round-trip: Arithmetic", is_valid
End Process

Process called "test_roundtrip_control_flow" returns Integer:
    Note: Test round-trip with if statement

    Let source be "void test(int x) { if (x > 0) x = 1; }"
    Let parser be proc create_c_parser from Parser with source
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast
    Let generated be proc generate_c_from_hir from FromHIR with hir

    Let is_valid be generated is not equal to 0

    If generated is not equal to 0:
        Let contains_if be proc string_contains from StringCore with generated, "if"

        Set is_valid to contains_if

        proc deallocate from Layout with generated
    End If

    proc destroy_c_parser from Parser with parser

    Return proc print_test_result from "Round-trip: Control flow", is_valid
End Process

Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Note: Run all C translator tests

    proc println from StringCore with "========================================"
    proc println from StringCore with "C Translator Test Suite"
    proc println from StringCore with "========================================"
    proc println from StringCore with ""

    Let total_tests be 0
    Let passed_tests be 0

    Note: Lexer tests
    proc println from StringCore with "Lexer Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_lexer_keywords
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_lexer_operators
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_lexer_literals
    proc println from StringCore with ""

    Note: Parser tests
    proc println from StringCore with "Parser Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_parser_simple_function
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_parser_variable_declaration
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_parser_if_statement
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_parser_while_loop
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_parser_for_loop
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_parser_function_call
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_parser_pointer_declaration
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_parser_array_declaration
    proc println from StringCore with ""

    Note: Semantic tests
    proc println from StringCore with "Semantic Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_semantic_type_checking
    proc println from StringCore with ""

    Note: C→HIR translation tests
    proc println from StringCore with "C→HIR Translation Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_c_to_hir_simple_function
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_c_to_hir_variable_declaration
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_c_to_hir_control_flow
    proc println from StringCore with ""

    Note: HIR→C generation tests
    proc println from StringCore with "HIR→C Generation Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_hir_to_c_simple_function
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_hir_to_c_variable_declaration
    proc println from StringCore with ""

    Note: Round-trip tests
    proc println from StringCore with "Round-Trip Translation Tests:"
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_roundtrip_simple_function
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_roundtrip_arithmetic
    Set total_tests to total_tests plus 1
    Set passed_tests to passed_tests plus proc test_roundtrip_control_flow
    proc println from StringCore with ""

    Note: Print summary
    proc println from StringCore with "========================================"
    proc print from StringCore with "Tests Passed: "
    proc print_int from StringCore with passed_tests
    proc print from StringCore with " / "
    proc println_int from StringCore with total_tests
    proc println from StringCore with "========================================"

    Return passed_tests
End Process

Note: ============================================================================
Note: Main Entry Point
Note: ============================================================================

Process called "main" returns Integer:
    Note: Main entry point for C translator tests

    Let passed be proc run_all_tests

    Return 0
End Process
