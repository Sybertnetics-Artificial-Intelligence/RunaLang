Note: ============================================================================
Note: Semantic Analysis Tests
Note: ============================================================================

Process called "test_semantic_type_checking" returns Integer:
    Note: Test semantic analyzer with type checking

    Let source be "int x = 42; float y = 3.14;"
    Let parser be proc create_c_parser from Parser with source
    Let ast be proc parse_program from Parser with parser

    Let analyzer be proc create_semantic_analyzer from Semantic
    Let result be proc validate_program from Semantic with analyzer, ast

    Let is_valid be result is equal to 1
    Let has_error be proc has_semantic_error from Semantic with analyzer
    Let no_error be has_error is equal to 0

    proc destroy_semantic_analyzer from Semantic with analyzer
    proc destroy_c_parser from Parser with parser

    Let passed be is_valid
    If passed is equal to 1:
        Set passed to no_error
    End If

    Return proc print_test_result from "Semantic: Type checking", passed
End Process

Note: ============================================================================
Note: C→HIR Translation Tests
Note: ============================================================================

Process called "test_c_to_hir_simple_function" returns Integer:
    Note: Test C→HIR translation with simple function

    Let source be "int add(int a, int b) { return a + b; }"
    Let parser be proc create_c_parser from Parser with source
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast

    Let is_valid be hir is not equal to 0

    proc destroy_c_parser from Parser with parser

    Return proc print_test_result from "C→HIR: Simple function", is_valid
End Process

Process called "test_c_to_hir_variable_declaration" returns Integer:
    Note: Test C→HIR translation with variable declaration

    Let source be "int count = 0;"
    Let parser be proc create_c_parser from Parser with source
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast

    Let is_valid be hir is not equal to 0

    proc destroy_c_parser from Parser with parser

    Return proc print_test_result from "C→HIR: Variable declaration", is_valid
End Process

Process called "test_c_to_hir_control_flow" returns Integer:
    Note: Test C→HIR translation with control flow

    Let source be "void test() { if (x > 0) y = 1; else y = 0; }"
    Let parser be proc create_c_parser from Parser with source
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast

    Let is_valid be hir is not equal to 0

