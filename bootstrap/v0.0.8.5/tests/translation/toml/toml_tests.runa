Note: Test 19: Round-Trip Simple Document
Note: ============================================================================

Process called "test_roundtrip_simple" returns Integer:
    Note: Test TOML → HIR → TOML round-trip for simple document

    Let toml_input be "title = \"TOML Example\"\n\n[owner]\nname = \"Tom\"\nage = 30"

    Let translation_context be 0
    Let hir_root be proc translate_toml_to_hir from Frontend with toml_input, translation_context

    If hir_root is equal to 0:
        Return proc create_test_result from "test_roundtrip_simple", 0, "Failed to translate to HIR"
    End If

    Let toml_output be proc generate_toml_from_hir from Backend with hir_root, translation_context

    If toml_output is equal to 0:
        Return proc create_test_result from "test_roundtrip_simple", 0, "Failed to generate TOML"
    End If

    Let hir_root2 be proc translate_toml_to_hir from Frontend with toml_output, translation_context

    If hir_root2 is equal to 0:
        Return proc create_test_result from "test_roundtrip_simple", 0, "Failed to re-parse generated TOML"
    End If

    Return proc create_test_result from "test_roundtrip_simple", 1, 0
End Process

