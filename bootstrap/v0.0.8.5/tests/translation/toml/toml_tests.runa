        Set passed_tests to passed_tests plus 1
    End If

    Note: Round-Trip Tests (19-20)
    Set result to proc test_roundtrip_simple
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_roundtrip_complex
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Report results
    If passed_tests is equal to total_tests:
        Return 1
    End If

    Return 0
End Process

Note: End of TOML Tests
