Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_all_toml_tests" returns Integer:
    Note: Run all TOML tests and report results

    @Reasoning:
    Executes all test cases and counts passed/failed tests.
    Returns 1 if all tests pass, 0 if any fail.
    @End Reasoning

    Let total_tests be 20
    Let passed_tests be 0

    Note: Parsing Tests (1-15)
    Let result be proc test_simple_key_value
    Let result_passed be proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_string_values
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_integer_values
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_float_values
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_boolean_values
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_array_values
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_inline_tables
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_standard_tables
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_nested_tables
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_array_of_tables
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_comments
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_date_time
    Set result_passed to proc memory_get_int64 from Layout with result, 8
    If result_passed is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set result to proc test_escaped_characters
