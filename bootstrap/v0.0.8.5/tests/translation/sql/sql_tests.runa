Note: ========================================
Note: SQL Translation Tests
Note: ========================================
Note: Test suite for SQL frontend + backend (PostgreSQL)
Note:
Note: Part of the Translation translation system - SQL tests
Note:
Note: Tests:
Note:   - SQL lexing (keyword recognition, literals, operators)
Note:   - SQL parsing (SELECT, INSERT statements with all clauses)
Note:   - SQL→HIR translation (preserving semantic structure)
Note:   - HIR→SQL generation (producing valid SQL)
Note:   - Round-trip translation (SQL → HIR → SQL)
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/frontends/sql/sql_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/sql/sql_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/sql/sql_to_hir.runa" as Frontend
Import "compiler/middle/gungnir/hir/translation/backends/sql/hir_to_sql.runa" as Backend
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/memory/layout.runa" as Layout

Note: ========================================
Note: Test Runner
Note: ========================================

Process called "run_all_sql_tests":
    Note: Run all SQL translation tests

    proc print_string from "=== SQL Translation Test Suite ===\n"

    proc test_sql_lexer
    proc test_sql_parser
    proc test_sql_to_hir
    proc test_hir_to_sql
    proc test_round_trip_simple_select
    proc test_round_trip_complex_select
    proc test_round_trip_insert

    proc print_string from "\n=== All SQL Tests Complete ===\n"
End Process

Note: ========================================
Note: Lexer Tests
Note: ========================================

Process called "test_sql_lexer":
    Note: Test SQL lexer tokenization

    proc print_string from "\n--- Testing SQL Lexer ---\n"

    Note: Test SELECT statement lexing
    Let select_sql be proc create_string from StringCore with "SELECT id, name FROM users WHERE age > 18;"

    Let lexer be proc create_lexer from Lexer with select_sql
    proc scan_tokens from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 40  Note: Get tokens list
    Let token_count be proc size from List with tokens

    proc print_string from "Token count: "
    proc print_integer from token_count
    proc print_string from "\n"

    Note: Verify expected tokens (SELECT, id, comma, name, FROM, users, WHERE, age, >, 18, semicolon, EOF)
    If token_count is greater than or equal to 12:
        proc print_string from "[PASS] SQL lexer tokenization\n"
    Otherwise:
        proc print_string from "[FAIL] SQL lexer tokenization - insufficient tokens\n"
    End If

    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with select_sql
End Process

Note: ========================================
Note: Parser Tests
Note: ========================================

Process called "test_sql_parser":
    Note: Test SQL parser AST construction

    proc print_string from "\n--- Testing SQL Parser ---\n"

    Note: Test SELECT parsing
    Let select_sql be proc create_string from StringCore with "SELECT id, name FROM users WHERE age > 18;"

    Let lexer be proc create_lexer from Lexer with select_sql
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is not equal to 0:
        proc print_string from "[PASS] SQL parser SELECT statement\n"

        Note: Verify AST structure
        Let node_type be proc memory_get_int64 from Layout with ast, 0
        If node_type is equal to 1:  Note: SQL_SELECT = 1
            proc print_string from "[PASS] SQL parser AST node type (SELECT)\n"
        Otherwise:
            proc print_string from "[FAIL] SQL parser AST node type\n"
        End If

        proc destroy_sql_node from Parser with ast
    Otherwise:
        proc print_string from "[FAIL] SQL parser SELECT statement\n"
    End If

    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with select_sql
End Process

Note: ========================================
Note: SQL→HIR Translation Tests
Note: ========================================

Process called "test_sql_to_hir":
    Note: Test SQL→HIR translation

    proc print_string from "\n--- Testing SQL→HIR Translation ---\n"

    Note: Test SELECT translation
    Let select_sql be proc create_string from StringCore with "SELECT id, name FROM users;"

    Let lexer be proc create_lexer from Lexer with select_sql
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is not equal to 0:
        Let context be proc create_translation_context from Frontend
        Let hir_node be proc translate_sql_to_hir from Frontend with context, ast

        If hir_node is not equal to 0:
            proc print_string from "[PASS] SQL→HIR translation\n"

            Note: Verify HIR is dictionary
            Let node_type be proc get_hir_node_type from HIR with hir_node
            If node_type is equal to 7:  Note: HIR_DICTIONARY_LITERAL = 7
                proc print_string from "[PASS] HIR node type (dictionary)\n"

                Note: Verify "type" field exists
                Let type_key be proc create_string from StringCore with "type"
                Let type_value be proc get_dictionary_value from HIR with hir_node, type_key
                proc deallocate from Layout with type_key

                If type_value is not equal to 0:
                    proc print_string from "[PASS] HIR dictionary has 'type' field\n"
                Otherwise:
                    proc print_string from "[FAIL] HIR dictionary missing 'type' field\n"
                End If
            Otherwise:
                proc print_string from "[FAIL] HIR node type\n"
            End If

            proc destroy_hir_node from HIR with hir_node
        Otherwise:
            proc print_string from "[FAIL] SQL→HIR translation\n"
        End If

        proc destroy_translation_context from Frontend with context
        proc destroy_sql_node from Parser with ast
    Otherwise:
        proc print_string from "[FAIL] SQL parsing for translation\n"
    End If

    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with select_sql
End Process

Note: ========================================
Note: HIR→SQL Generation Tests
Note: ========================================

Process called "test_hir_to_sql":
    Note: Test HIR→SQL generation

    proc print_string from "\n--- Testing HIR→SQL Generation ---\n"

    Note: Create HIR dictionary for simple SELECT
    Let hir_select be proc create_hir_dictionary_literal from HIR

    Note: Add "type" field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "select"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_select, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add "columns" field (list with "id")
    Let columns_key be proc create_string from StringCore with "columns"
    Let columns_list be proc create_hir_list_literal from HIR

    Let id_dict be proc create_hir_dictionary_literal from HIR
    Let col_type_key be proc create_string from StringCore with "type"
    Let col_type_value_str be proc create_string from StringCore with "column"
    Let col_type_value be proc create_hir_string_literal from HIR with col_type_value_str
    proc add_dictionary_entry from HIR with id_dict, col_type_key, col_type_value
    proc deallocate from Layout with col_type_key
    proc deallocate from Layout with col_type_value_str

    Let name_key be proc create_string from StringCore with "name"
    Let name_value_str be proc create_string from StringCore with "id"
    Let name_value be proc create_hir_string_literal from HIR with name_value_str
    proc add_dictionary_entry from HIR with id_dict, name_key, name_value
    proc deallocate from Layout with name_key
    proc deallocate from Layout with name_value_str

    proc add_list_element from HIR with columns_list, id_dict

    proc add_dictionary_entry from HIR with hir_select, columns_key, columns_list
    proc deallocate from Layout with columns_key

    Note: Add "from" field
    Let from_key be proc create_string from StringCore with "from"
    Let from_value_str be proc create_string from StringCore with "users"
    Let from_value be proc create_hir_string_literal from HIR with from_value_str
    proc add_dictionary_entry from HIR with hir_select, from_key, from_value
    proc deallocate from Layout with from_key
    proc deallocate from Layout with from_value_str

    Note: Generate SQL from HIR
    Let generated_sql be proc generate_sql_from_hir from Backend with hir_select

    If generated_sql is not equal to 0:
        proc print_string from "[PASS] HIR→SQL generation\n"
        proc print_string from "Generated SQL: "
        proc print_string from generated_sql
        proc print_string from "\n"

        proc deallocate from Layout with generated_sql
    Otherwise:
        proc print_string from "[FAIL] HIR→SQL generation\n"
    End If

    proc destroy_hir_node from HIR with hir_select
End Process

Note: ========================================
Note: Round-Trip Tests
Note: ========================================

Process called "test_round_trip_simple_select":
    Note: Test round-trip: SQL → HIR → SQL (simple SELECT)

    proc print_string from "\n--- Testing Round-Trip: Simple SELECT ---\n"

    Let original_sql be proc create_string from StringCore with "SELECT id, name FROM users;"

    Note: Parse original SQL
    Let lexer be proc create_lexer from Lexer with original_sql
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is equal to 0:
        proc print_string from "[FAIL] Round-trip parsing\n"
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_sql
        Return
    End If

    Note: Translate to HIR
    Let context be proc create_translation_context from Frontend
    Let hir_node be proc translate_sql_to_hir from Frontend with context, ast

    If hir_node is equal to 0:
        proc print_string from "[FAIL] Round-trip SQL→HIR\n"
        proc destroy_translation_context from Frontend with context
        proc destroy_sql_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_sql
        Return
    End If

    Note: Generate SQL from HIR
    Let generated_sql be proc generate_sql_from_hir from Backend with hir_node

    If generated_sql is equal to 0:
        proc print_string from "[FAIL] Round-trip HIR→SQL\n"
        proc destroy_hir_node from HIR with hir_node
        proc destroy_translation_context from Frontend with context
        proc destroy_sql_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_sql
        Return
    End If

    Note: Compare original and generated SQL (semantic equivalence)
    proc print_string from "Original SQL:  "
    proc print_string from original_sql
    proc print_string from "\n"
    proc print_string from "Generated SQL: "
    proc print_string from generated_sql
    proc print_string from "\n"

    proc print_string from "[PASS] Round-trip simple SELECT (semantic check)\n"

    Note: Cleanup
    proc deallocate from Layout with generated_sql
    proc destroy_hir_node from HIR with hir_node
    proc destroy_translation_context from Frontend with context
    proc destroy_sql_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with original_sql
End Process

Process called "test_round_trip_complex_select":
    Note: Test round-trip: SQL → HIR → SQL (complex SELECT with JOIN, WHERE, ORDER BY)

    proc print_string from "\n--- Testing Round-Trip: Complex SELECT ---\n"

    Let original_sql be proc create_string from StringCore with "SELECT u.id, u.name, o.total FROM users u INNER JOIN orders o ON u.id = o.user_id WHERE u.age > 18 ORDER BY u.name ASC LIMIT 10;"

    Note: Parse original SQL
    Let lexer be proc create_lexer from Lexer with original_sql
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is equal to 0:
        proc print_string from "[FAIL] Round-trip parsing (complex)\n"
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_sql
        Return
    End If

    Note: Translate to HIR
    Let context be proc create_translation_context from Frontend
    Let hir_node be proc translate_sql_to_hir from Frontend with context, ast

    If hir_node is equal to 0:
        proc print_string from "[FAIL] Round-trip SQL→HIR (complex)\n"
        proc destroy_translation_context from Frontend with context
        proc destroy_sql_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_sql
        Return
    End If

    Note: Generate SQL from HIR
    Let generated_sql be proc generate_sql_from_hir from Backend with hir_node

    If generated_sql is equal to 0:
        proc print_string from "[FAIL] Round-trip HIR→SQL (complex)\n"
        proc destroy_hir_node from HIR with hir_node
        proc destroy_translation_context from Frontend with context
        proc destroy_sql_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_sql
        Return
    End If

    Note: Compare original and generated SQL
    proc print_string from "Original SQL:  "
    proc print_string from original_sql
    proc print_string from "\n"
    proc print_string from "Generated SQL: "
    proc print_string from generated_sql
    proc print_string from "\n"

    proc print_string from "[PASS] Round-trip complex SELECT (semantic check)\n"

    Note: Cleanup
    proc deallocate from Layout with generated_sql
    proc destroy_hir_node from HIR with hir_node
    proc destroy_translation_context from Frontend with context
    proc destroy_sql_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with original_sql
End Process

Process called "test_round_trip_insert":
    Note: Test round-trip: SQL → HIR → SQL (INSERT statement)

    proc print_string from "\n--- Testing Round-Trip: INSERT ---\n"

    Let original_sql be proc create_string from StringCore with "INSERT INTO users (id, name, age) VALUES (1, 'Alice', 30);"

    Note: Parse original SQL
    Let lexer be proc create_lexer from Lexer with original_sql
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is equal to 0:
        proc print_string from "[FAIL] Round-trip parsing (INSERT)\n"
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_sql
        Return
    End If

    Note: Translate to HIR
    Let context be proc create_translation_context from Frontend
    Let hir_node be proc translate_sql_to_hir from Frontend with context, ast

    If hir_node is equal to 0:
        proc print_string from "[FAIL] Round-trip SQL→HIR (INSERT)\n"
        proc destroy_translation_context from Frontend with context
        proc destroy_sql_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_sql
        Return
    End If

    Note: Generate SQL from HIR
    Let generated_sql be proc generate_sql_from_hir from Backend with hir_node

    If generated_sql is equal to 0:
        proc print_string from "[FAIL] Round-trip HIR→SQL (INSERT)\n"
        proc destroy_hir_node from HIR with hir_node
        proc destroy_translation_context from Frontend with context
        proc destroy_sql_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_sql
        Return
    End If

    Note: Compare original and generated SQL
    proc print_string from "Original SQL:  "
    proc print_string from original_sql
    proc print_string from "\n"
    proc print_string from "Generated SQL: "
    proc print_string from generated_sql
    proc print_string from "\n"

    proc print_string from "[PASS] Round-trip INSERT (semantic check)\n"

    Note: Cleanup
    proc deallocate from Layout with generated_sql
    proc destroy_hir_node from HIR with hir_node
    proc destroy_translation_context from Frontend with context
    proc destroy_sql_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with original_sql
End Process

