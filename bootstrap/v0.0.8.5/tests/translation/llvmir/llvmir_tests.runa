Note:
LLVM IR Translation Tests - Comprehensive test suite for LLVM IR translator

This file tests the complete LLVM IR translation pipeline:
- Lexing and parsing LLVM IR code
- LLVM IR AST to HIR translation
- HIR to LLVM IR code generation
- Round-trip translation (LLVM IR → HIR → LLVM IR)

Test Coverage:
- Function definitions and declarations
- Basic blocks and labels
- Instructions (arithmetic, memory, control flow)
- Types (primitives, pointers)
- SSA registers
- Constants and literals
- Control flow (ret, br, call)
- Memory operations (alloca, load, store)

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/llvmir/llvmir_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/llvmir/llvmir_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/llvmir/llvmir_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/llvmir/hir_to_llvmir.runa
- compiler/middle/gungnir/hir/translation/backends/llvmir/llvmir_emitter.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/llvmir/llvmir_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/llvmir/llvmir_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/llvmir/llvmir_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/llvmir/hir_to_llvmir.runa" as FromHIR
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Test Infrastructure
Note: ============================================================================

Constant TEST_PASSED as Integer is 1
Constant TEST_FAILED as Integer is 0

Process called "assert_not_null" takes value as Integer, test_name as Integer returns Integer:
    Note: Assert that value is not null

    If value is equal to 0:
        proc println from StringCore with "[FAIL] "
        proc println from StringCore with test_name
        proc println from StringCore with ": Got null value"
        Return TEST_FAILED
    End If

    Return TEST_PASSED
End Process

Process called "assert_contains" takes haystack as Integer, needle as Integer, test_name as Integer returns Integer:
    Note: Assert that haystack contains needle substring

    If haystack is equal to 0:
        proc println from StringCore with "[FAIL] "
        proc println from StringCore with test_name
        proc println from StringCore with ": Haystack is null"
        Return TEST_FAILED
    End If

    If needle is equal to 0:
        proc println from StringCore with "[FAIL] "
        proc println from StringCore with test_name
        proc println from StringCore with ": Needle is null"
        Return TEST_FAILED
    End If

    Let haystack_len be proc string_length from StringCore with haystack
    Let needle_len be proc string_length from StringCore with needle

    If needle_len is greater than haystack_len:
        proc println from StringCore with "[FAIL] "
        proc println from StringCore with test_name
        proc println from StringCore with ": Needle longer than haystack"
        Return TEST_FAILED
    End If

    Note: Search for needle in haystack
    Let h_index be 0
    While h_index is less than or equal to haystack_len minus needle_len:
        Let matches be 1
        Let n_index be 0

        While n_index is less than needle_len:
            Let h_char be proc memory_get_byte from Layout with haystack, h_index plus n_index
            Let n_char be proc memory_get_byte from Layout with needle, n_index

            If h_char is not equal to n_char:
                Set matches to 0
                Break
            End If

            Set n_index to n_index plus 1
        End While

        If matches is equal to 1:
            Return TEST_PASSED
        End If

        Set h_index to h_index plus 1
    End While

    proc println from StringCore with "[FAIL] "
    proc println from StringCore with test_name
    proc println from StringCore with ": Substring not found"
    Return TEST_FAILED
End Process

Process called "pass_test" takes test_name as Integer returns Integer:
    Note: Mark test as passed

    proc println from StringCore with "[PASS] "
    proc println from StringCore with test_name
    Return TEST_PASSED
End Process

Note: ============================================================================
Note: LLVM IR Parsing Tests
Note: ============================================================================

Process called "test_simple_function" returns Integer:
    Note: Test parsing simple function definition

    Let source be "define i32 @main() {
entry:
  ret i32 0
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let result be proc assert_not_null from lexer, "test_simple_function - lexer"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Let parser be proc create_llvm_parser from Parser with lexer
    Set result to proc assert_not_null from parser, "test_simple_function - parser"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Let ast be proc parse_module from Parser with parser
    Set result to proc assert_not_null from ast, "test_simple_function - AST"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_simple_function"
End Process

Process called "test_function_with_add" returns Integer:
    Note: Test parsing function with add instruction

    Let source be "define i32 @add_numbers() {
entry:
  %result = add i32 5, 10
  ret i32 %result
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser

    Let result be proc assert_not_null from ast, "test_function_with_add"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_function_with_add"
End Process

Process called "test_function_with_branch" returns Integer:
    Note: Test parsing function with branch instruction

    Let source be "define void @test_br() {
entry:
  br label %block1
block1:
  ret void
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser

    Let result be proc assert_not_null from ast, "test_function_with_branch"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_function_with_branch"
End Process

Process called "test_alloca_instruction" returns Integer:
    Note: Test parsing alloca instruction

    Let source be "define i32 @test_alloca() {
entry:
  %ptr = alloca i32
  ret i32 0
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser

    Let result be proc assert_not_null from ast, "test_alloca_instruction"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_alloca_instruction"
End Process

Process called "test_load_store_instructions" returns Integer:
    Note: Test parsing load and store instructions

    Let source be "define i32 @test_mem() {
entry:
  %ptr = alloca i32
  store i32 42, ptr %ptr
  %val = load i32, ptr %ptr
  ret i32 %val
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser

    Let result be proc assert_not_null from ast, "test_load_store_instructions"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_load_store_instructions"
End Process

Note: ============================================================================
Note: LLVM IR to HIR Translation Tests
Note: ============================================================================

Process called "test_to_hir_simple_function" returns Integer:
    Note: Test translating simple function to HIR

    Let source be "define i32 @main() {
entry:
  ret i32 0
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser

    Let hir be proc translate_llvmir_to_hir from ToHIR with ast

    Let result be proc assert_not_null from hir, "test_to_hir_simple_function"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_to_hir_simple_function"
End Process

Process called "test_to_hir_with_instructions" returns Integer:
    Note: Test translating function with instructions to HIR

    Let source be "define i32 @add_func() {
entry:
  %result = add i32 5, 10
  ret i32 %result
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser

    Let hir be proc translate_llvmir_to_hir from ToHIR with ast

    Let result be proc assert_not_null from hir, "test_to_hir_with_instructions"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_to_hir_with_instructions"
End Process

Note: ============================================================================
Note: HIR to LLVM IR Generation Tests
Note: ============================================================================

Process called "test_from_hir_simple_function" returns Integer:
    Note: Test generating LLVM IR code from HIR

    Let source be "define i32 @main() {
entry:
  ret i32 0
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser
    Let hir be proc translate_llvmir_to_hir from ToHIR with ast

    Let generated be proc generate_llvmir from FromHIR with hir

    Let result be proc assert_not_null from generated, "test_from_hir_simple_function - generated"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Note: Check that generated code contains expected elements
    Set result to proc assert_contains from generated, "define", "test_from_hir_simple_function - define"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Set result to proc assert_contains from generated, "i32", "test_from_hir_simple_function - i32"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Set result to proc assert_contains from generated, "@main", "test_from_hir_simple_function - @main"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Set result to proc assert_contains from generated, "ret", "test_from_hir_simple_function - ret"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_from_hir_simple_function"
End Process

Process called "test_from_hir_with_add" returns Integer:
    Note: Test generating function with add instruction

    Let source be "define i32 @add_numbers() {
entry:
  %result = add i32 5, 10
  ret i32 %result
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser
    Let hir be proc translate_llvmir_to_hir from ToHIR with ast

    Let generated be proc generate_llvmir from FromHIR with hir

    Let result be proc assert_contains from generated, "add", "test_from_hir_with_add - add"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Set result to proc assert_contains from generated, "%result", "test_from_hir_with_add - %result"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_from_hir_with_add"
End Process

Note: ============================================================================
Note: Round-Trip Translation Tests
Note: ============================================================================

Process called "test_roundtrip_simple_function" returns Integer:
    Note: Test round-trip translation of simple function

    Let source be "define i32 @main() {
entry:
  ret i32 0
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser
    Let hir be proc translate_llvmir_to_hir from ToHIR with ast
    Let generated be proc generate_llvmir from FromHIR with hir

    Note: Parse generated code again
    Let lexer2 be proc create_llvmir_lexer from Lexer with generated
    Let parser2 be proc create_llvm_parser from Parser with lexer2
    Let ast2 be proc parse_module from Parser with parser2

    Let result be proc assert_not_null from ast2, "test_roundtrip_simple_function"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_roundtrip_simple_function"
End Process

Process called "test_roundtrip_with_instructions" returns Integer:
    Note: Test round-trip translation with instructions

    Let source be "define i32 @test() {
entry:
  %a = add i32 1, 2
  ret i32 %a
}"

    Let lexer be proc create_llvmir_lexer from Lexer with source
    Let parser be proc create_llvm_parser from Parser with lexer
    Let ast be proc parse_module from Parser with parser
    Let hir be proc translate_llvmir_to_hir from ToHIR with ast
    Let generated be proc generate_llvmir from FromHIR with hir

    Note: Parse generated code again
    Let lexer2 be proc create_llvmir_lexer from Lexer with generated
    Let parser2 be proc create_llvm_parser from Parser with lexer2
    Let ast2 be proc parse_module from Parser with parser2

    Let result be proc assert_not_null from ast2, "test_roundtrip_with_instructions"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_roundtrip_with_instructions"
End Process

Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_llvmir_tests" returns Integer:
    Note: Run all LLVM IR translator tests

    proc println from StringCore with "==========================================="
    proc println from StringCore with "LLVM IR Translation Translation Tests"
    proc println from StringCore with "==========================================="
    proc println from StringCore with ""

    Let total_tests be 0
    Let passed_tests be 0

    Note: Parsing tests
    proc println from StringCore with "--- Parsing Tests ---"

    Set total_tests to total_tests plus 1
    Let result be proc test_simple_function
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_function_with_add
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_function_with_branch
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_alloca_instruction
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_load_store_instructions
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    proc println from StringCore with ""

    Note: To HIR tests
    proc println from StringCore with "--- LLVM IR to HIR Translation Tests ---"

    Set total_tests to total_tests plus 1
    Set result to proc test_to_hir_simple_function
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_to_hir_with_instructions
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    proc println from StringCore with ""

    Note: From HIR tests
    proc println from StringCore with "--- HIR to LLVM IR Generation Tests ---"

    Set total_tests to total_tests plus 1
    Set result to proc test_from_hir_simple_function
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_from_hir_with_add
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    proc println from StringCore with ""

    Note: Round-trip tests
    proc println from StringCore with "--- Round-Trip Translation Tests ---"

    Set total_tests to total_tests plus 1
    Set result to proc test_roundtrip_simple_function
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_roundtrip_with_instructions
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    proc println from StringCore with ""
    proc println from StringCore with "==========================================="
    proc println from StringCore with "Test Results:"
    proc print from StringCore with "  Passed: "
    proc print_int from StringCore with passed_tests
    proc print from StringCore with " / "
    proc println_int from StringCore with total_tests

    Let failed_tests be total_tests minus passed_tests
    If failed_tests is greater than 0:
        proc print from StringCore with "  Failed: "
        proc println_int from StringCore with failed_tests
    End If

    proc println from StringCore with "==========================================="

    If passed_tests is equal to total_tests:
        Return 1  Note: All tests passed
    End If

    Return 0  Note: Some tests failed
End Process
