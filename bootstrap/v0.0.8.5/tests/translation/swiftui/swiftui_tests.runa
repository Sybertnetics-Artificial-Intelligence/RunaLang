Note: HIR to SwiftUI Generation Tests
Note: ============================================================================

Process called "test_from_hir_simple_text" returns Integer:
    Note: Test generating SwiftUI code from HIR

    Let source be "struct ContentView: View {
    var body: some View {
        Text(\"Hello, World!\")
    }
}"

    Let lexer be proc create_swiftui_lexer from Lexer with source
    Let parser be proc create_swiftui_parser from Parser with lexer
    Let ast be proc parse_swiftui from Parser with parser
    Let hir be proc translate_swiftui_to_hir from ToHIR with ast

    Let generated be proc generate_swiftui from FromHIR with hir

    Let result be proc assert_not_null from generated, "test_from_hir_simple_text - generated"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Note: Check that generated code contains expected elements
    Set result to proc assert_contains from generated, "struct ContentView", "test_from_hir_simple_text - struct"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Set result to proc assert_contains from generated, "View", "test_from_hir_simple_text - View protocol"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Set result to proc assert_contains from generated, "Text", "test_from_hir_simple_text - Text view"

    If result is equal to TEST_FAILED:
        Return TEST_FAILED
    End If

    Return proc pass_test from "test_from_hir_simple_text"
End Process

