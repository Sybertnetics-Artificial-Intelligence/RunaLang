    Let lexer2 be proc create_swiftui_lexer from Lexer with generated
    Let parser2 be proc create_swiftui_parser from Parser with lexer2
    Let ast2 be proc parse_swiftui from Parser with parser2

    Let result be proc assert_not_null from ast2, "test_roundtrip_simple_view"

