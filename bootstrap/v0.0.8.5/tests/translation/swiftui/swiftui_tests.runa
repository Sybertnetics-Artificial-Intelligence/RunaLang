Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_swiftui_tests" returns Integer:
    Note: Run all SwiftUI translator tests

    proc println from StringCore with "==========================================="
    proc println from StringCore with "SwiftUI Translation Translation Tests"
    proc println from StringCore with "==========================================="
    proc println from StringCore with ""

    Let total_tests be 0
    Let passed_tests be 0

    Note: Parsing tests
    proc println from StringCore with "--- Parsing Tests ---"

    Set total_tests to total_tests plus 1
    Let result be proc test_simple_text_view
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_vstack_with_children
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_property_wrappers
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_button_with_action
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_view_modifiers
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_hstack_with_params
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_nested_views
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    proc println from StringCore with ""

    Note: To HIR tests
    proc println from StringCore with "--- SwiftUI to HIR Translation Tests ---"

    Set total_tests to total_tests plus 1
    Set result to proc test_to_hir_simple_text
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_to_hir_vstack
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_to_hir_property_wrapper
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    proc println from StringCore with ""

    Note: From HIR tests
    proc println from StringCore with "--- HIR to SwiftUI Generation Tests ---"

    Set total_tests to total_tests plus 1
    Set result to proc test_from_hir_simple_text
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_from_hir_vstack
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_from_hir_modifiers
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_from_hir_property_wrapper
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    proc println from StringCore with ""

    Note: Round-trip tests
    proc println from StringCore with "--- Round-Trip Translation Tests ---"

    Set total_tests to total_tests plus 1
    Set result to proc test_roundtrip_simple_view
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_roundtrip_vstack
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    Set result to proc test_roundtrip_modifiers
    If result is equal to TEST_PASSED:
        Set passed_tests to passed_tests plus 1
    End If

    proc println from StringCore with ""
    proc println from StringCore with "==========================================="
    proc println from StringCore with "Test Results:"
    proc print from StringCore with "  Passed: "
    proc print_int from StringCore with passed_tests
    proc print from StringCore with " / "
    proc println_int from StringCore with total_tests

    Let failed_tests be total_tests minus passed_tests
    If failed_tests is greater than 0:
        proc print from StringCore with "  Failed: "
        proc println_int from StringCore with failed_tests
    End If

    proc println from StringCore with "==========================================="

    If passed_tests is equal to total_tests:
        Return 1  Note: All tests passed
    End If

    Return 0  Note: Some tests failed
End Process
