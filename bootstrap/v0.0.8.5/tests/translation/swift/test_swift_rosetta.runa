Note:
Swift Translation Test Suite

Tests complete Swift translation pipeline:
- Lexer: Swift source → Tokens
- Parser: Tokens → Swift AST
- Translation: Swift AST → HIR
- Generation: HIR → Swift source
- Round-trip: Swift → HIR → Swift

Test Coverage:
- Swift lexer (keywords, operators, literals, comments)
- Swift parser (declarations, statements, expressions)
- Swift→HIR translation (preserving Swift semantics)
- HIR→Swift generation (idiomatic Swift output)
- Round-trip translation (semantic preservation)

Swift-Specific Features Tested:
- Optionals (?, !, ??)
- Guard statements and early exit
- Protocol-oriented programming
- Value types (struct) vs reference types (class)
- Error handling (throws, try, catch)
- Closures and trailing closure syntax
- Property observers (willSet, didSet)
- Access control (public, private, fileprivate, internal, open)
- Memory management (weak, unowned)
- Generic constraints and where clauses

Success Criteria:
- All tokens correctly identified
- AST correctly represents source structure
- HIR preserves Swift semantics
- Generated Swift is idiomatic and correct
- Round-trip preserves semantics
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/swift/swift_lexer.runa" as SwiftLexer
Import "compiler/middle/gungnir/hir/translation/frontends/swift/swift_parser.runa" as SwiftParser
Import "compiler/middle/gungnir/hir/translation/frontends/swift/swift_to_hir.runa" as SwiftToHIR
Import "compiler/middle/gungnir/hir/translation/backends/swift/hir_to_swift.runa" as HIRToSwift
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test Utilities
Note: ============================================================================

Process called "assert_equal" takes actual as Integer, expected as Integer, test_name as Integer returns Integer:
    Note: Assert that actual equals expected

    @Reasoning:
    Simple equality assertion for test results.
    Prints test name and result.
    @End Reasoning

    Let are_equal be proc strings_equal from StringCore with actual, expected

    If are_equal is equal to 1:
        proc print from test_name, ": PASS"
        Return 1
    Otherwise:
        proc print from test_name, ": FAIL"
        proc print from "  Expected:", expected
        proc print from "  Actual:", actual
        Return 0
    End If
End Process

Process called "assert_not_null" takes value as Integer, test_name as Integer returns Integer:
    Note: Assert that value is not null (0)

    If value is not equal to 0:
        proc print from test_name, ": PASS"
        Return 1
    Otherwise:
        proc print from test_name, ": FAIL - got null"
        Return 0
    End If
End Process

Process called "assert_token_type" takes token as Integer, expected_type as Integer, test_name as Integer returns Integer:
    Note: Assert that token has expected type

    If token is equal to 0:
        proc print from test_name, ": FAIL - null token"
        Return 0
    End If

    Let token_type be proc memory_get_int64 from Layout with token, 0

    If token_type is equal to expected_type:
        proc print from test_name, ": PASS"
        Return 1
    Otherwise:
        proc print from test_name, ": FAIL - wrong token type"
        proc print from "  Expected:", expected_type
        proc print from "  Actual:", token_type
        Return 0
    End If
End Process

Note: ============================================================================
Note: Lexer Tests - Swift Tokenization
Note: ============================================================================

Process called "test_lexer_keywords" returns Integer:
    Note: Test that Swift keywords are correctly tokenized

    @Reasoning:
    Swift has ~70 keywords. Test a representative sample across
    declaration, control flow, and type keywords.
    @End Reasoning

    Let source be "func let var class struct enum protocol extension"
    Let lexer be proc create_lexer from SwiftLexer with source

    If lexer is equal to 0:
        Return proc assert_not_null from 0, "test_lexer_keywords"
    End If

    Note: func
    Let token be proc next_token from SwiftLexer with lexer
    Let result be proc assert_token_type from token, TOKEN_FUNC from SwiftLexer, "keyword: func"

    If result is equal to 0:
        Return 0
    End If

    Note: let
    Set token to proc next_token from SwiftLexer with lexer
    Set result to proc assert_token_type from token, TOKEN_LET from SwiftLexer, "keyword: let"

    If result is equal to 0:
        Return 0
    End If

    Note: var
    Set token to proc next_token from SwiftLexer with lexer
    Set result to proc assert_token_type from token, TOKEN_VAR from SwiftLexer, "keyword: var"

    If result is equal to 0:
        Return 0
    End If

    proc destroy_lexer from SwiftLexer with lexer

    Return 1
End Process

Process called "test_lexer_optionals" returns Integer:
    Note: Test Swift optional operators (?, !, ??)

    Let source be "value? value! value1 ?? value2"
    Let lexer be proc create_lexer from SwiftLexer with source

    If lexer is equal to 0:
        Return proc assert_not_null from 0, "test_lexer_optionals"
    End If

    Note: value
    Let token be proc next_token from SwiftLexer with lexer
    Let result be proc assert_token_type from token, TOKEN_IDENTIFIER from SwiftLexer, "identifier: value"

    If result is equal to 0:
        Return 0
    End If

    Note: ?
    Set token to proc next_token from SwiftLexer with lexer
    Set result to proc assert_token_type from token, TOKEN_QUESTION from SwiftLexer, "operator: ?"

    If result is equal to 0:
        Return 0
    End If

    proc destroy_lexer from SwiftLexer with lexer

    Return 1
End Process

Process called "test_lexer_numbers" returns Integer:
    Note: Test Swift number literal formats

    @Reasoning:
    Swift supports decimal, hexadecimal (0x), binary (0b), and octal (0o).
    @End Reasoning

    Let source be "42 0xFF 0b1010 0o77 3.14"
    Let lexer be proc create_lexer from SwiftLexer with source

    If lexer is equal to 0:
        Return proc assert_not_null from 0, "test_lexer_numbers"
    End If

    Note: Decimal
    Let token be proc next_token from SwiftLexer with lexer
    Let result be proc assert_token_type from token, TOKEN_INTEGER from SwiftLexer, "number: decimal"

    If result is equal to 0:
        Return 0
    End If

    Note: Hexadecimal
    Set token to proc next_token from SwiftLexer with lexer
    Set result to proc assert_token_type from token, TOKEN_INTEGER from SwiftLexer, "number: hexadecimal"

    If result is equal to 0:
        Return 0
    End If

    proc destroy_lexer from SwiftLexer with lexer

    Return 1
End Process

Process called "test_lexer_strings" returns Integer:
    Note: Test Swift string literals (single-line and multi-line)

    Let source be "\"hello\" \"\"\"multi\nline\"\"\""
    Let lexer be proc create_lexer from SwiftLexer with source

    If lexer is equal to 0:
        Return proc assert_not_null from 0, "test_lexer_strings"
    End If

    Note: Single-line string
    Let token be proc next_token from SwiftLexer with lexer
    Let result be proc assert_token_type from token, TOKEN_STRING from SwiftLexer, "string: single-line"

    If result is equal to 0:
        Return 0
    End If

    Note: Multi-line string
    Set token to proc next_token from SwiftLexer with lexer
    Set result to proc assert_token_type from token, TOKEN_STRING from SwiftLexer, "string: multi-line"

    If result is equal to 0:
        Return 0
    End If

    proc destroy_lexer from SwiftLexer with lexer

    Return 1
End Process

Process called "test_lexer_comments" returns Integer:
    Note: Test Swift comments (single-line and nested block)

    Let source be "// single\n/* outer /* nested */ outer */"
    Let lexer be proc create_lexer from SwiftLexer with source

    If lexer is equal to 0:
        Return proc assert_not_null from 0, "test_lexer_comments"
    End If

    Note: Comments are typically skipped, so we just verify lexer doesn't crash
    Let token be proc next_token from SwiftLexer with lexer

    proc destroy_lexer from SwiftLexer with lexer

    proc print from "test_lexer_comments: PASS"

    Return 1
End Process

Note: ============================================================================
Note: Parser Tests - Swift AST Generation
Note: ============================================================================

Process called "test_parser_function_decl" returns Integer:
    Note: Test parsing Swift function declaration

    @Reasoning:
    Test basic function with parameters, return type, and body.
    Example: func greet(name: String) -> String { return "Hello" }
    @End Reasoning

    Let source be "func greet(name: String) -> String { return \"Hello\" }"
    Let lexer be proc create_lexer from SwiftLexer with source

    If lexer is equal to 0:
        Return proc assert_not_null from 0, "test_parser_function_decl"
    End If

    Let parser be proc create_parser from SwiftParser with lexer

    If parser is equal to 0:
        Return proc assert_not_null from 0, "test_parser_function_decl"
    End If

    Let ast be proc parse from SwiftParser with parser

    If ast is equal to 0:
        proc destroy_parser from SwiftParser with parser
        Return proc assert_not_null from 0, "test_parser_function_decl"
    End If

    proc destroy_parser from SwiftParser with parser

    proc print from "test_parser_function_decl: PASS"

    Return 1
End Process

