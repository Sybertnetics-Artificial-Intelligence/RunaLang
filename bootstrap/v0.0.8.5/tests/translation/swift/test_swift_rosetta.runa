Note: ============================================================================
Note: Generation Tests - HIR to Swift
Note: ============================================================================

Process called "test_generation_simple" returns Integer:
    Note: Test HIR → Swift code generation for simple constructs

    @Reasoning:
    Create minimal HIR structure representing a simple Swift declaration,
    then verify it generates valid Swift code.
    @End Reasoning

    Note: Create HIR for: let x = 42
    Let hir be proc create_dict from HIR
    proc set_dict_string from HIR with hir, "_type", "swift_let"
    proc set_dict_string from HIR with hir, "name", "x"

    Let init_hir be proc create_dict from HIR
    proc set_dict_string from HIR with init_hir, "_type", "swift_literal"
    proc set_dict_string from HIR with init_hir, "value", "42"

    proc set_dict_value from HIR with hir, "initializer", init_hir

    Let swift_code be proc generate_swift_from_hir from HIRToSwift with hir

    If swift_code is equal to 0:
        Return proc assert_not_null from 0, "test_generation_simple"
    End If

    proc print from "test_generation_simple: PASS"
    proc print from "  Generated:", swift_code

    Return 1
End Process

Note: ============================================================================
Note: Round-Trip Tests - Swift → HIR → Swift
Note: ============================================================================

Process called "round_trip_swift" takes swift_input as Integer returns Integer:
    Note: Perform Swift→HIR→Swift round-trip translation

    @Reasoning:
    Parse Swift to AST, translate to HIR, regenerate Swift.
    Returns generated Swift or 0 on failure.
    @End Reasoning

    Note: Parse Swift to AST
    Let lexer be proc create_lexer from SwiftLexer with swift_input

    If lexer is equal to 0:
        proc print from "Failed to create lexer"
        Return 0
    End If

    Let parser be proc create_parser from SwiftParser with lexer

    If parser is equal to 0:
        proc print from "Failed to create parser"
        Return 0
    End If

    Let swift_ast be proc parse from SwiftParser with parser

    If swift_ast is equal to 0:
        proc print from "Failed to parse Swift"
        proc destroy_parser from SwiftParser with parser
        Return 0
    End If

    Note: Translate Swift AST to HIR
    Let hir be proc translate_swift_ast_to_hir from SwiftToHIR with swift_ast

    If hir is equal to 0:
        proc print from "Failed to translate Swift to HIR"
        proc destroy_parser from SwiftParser with parser
        Return 0
    End If

    proc destroy_parser from SwiftParser with parser

    Note: Generate Swift from HIR
    Let swift_output be proc generate_swift_from_hir from HIRToSwift with hir

    If swift_output is equal to 0:
        proc print from "Failed to generate Swift from HIR"
        Return 0
    End If

    Return swift_output
End Process

Process called "test_round_trip_function" returns Integer:
    Note: Test function round-trip preservation

    Let input be "func greet(name: String) -> String { return \"Hello\" }"
    Let output be proc round_trip_swift from input

    If output is equal to 0:
        Return proc assert_not_null from 0, "test_round_trip_function"
    End If

    proc print from "test_round_trip_function: PASS"
    proc print from "  Input:", input
    proc print from "  Output:", output

    Return 1
End Process

