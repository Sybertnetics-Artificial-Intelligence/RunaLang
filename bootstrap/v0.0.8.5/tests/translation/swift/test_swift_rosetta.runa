Note: ============================================================================
Note: Translation Tests - Swift AST to HIR
Note: ============================================================================

Process called "test_translation_function" returns Integer:
    Note: Test Swift function → HIR translation

    Let source be "func add(a: Int, b: Int) -> Int { return a + b }"
    Let lexer be proc create_lexer from SwiftLexer with source

    If lexer is equal to 0:
        Return proc assert_not_null from 0, "test_translation_function"
    End If

    Let parser be proc create_parser from SwiftParser with lexer

    If parser is equal to 0:
        Return proc assert_not_null from 0, "test_translation_function"
    End If

    Let ast be proc parse from SwiftParser with parser

    If ast is equal to 0:
        Return proc assert_not_null from 0, "test_translation_function"
    End If

    Let hir be proc translate_swift_ast_to_hir from SwiftToHIR with ast

    If hir is equal to 0:
        proc destroy_parser from SwiftParser with parser
        Return proc assert_not_null from 0, "test_translation_function"
    End If

    proc destroy_parser from SwiftParser with parser

    proc print from "test_translation_function: PASS"

    Return 1
End Process

