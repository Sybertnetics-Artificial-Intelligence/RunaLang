Note:
XML Translator Tests

Comprehensive test suite for XML frontend and backend translators.
Tests parsing, generation, round-trip translation, error handling,
and edge cases.

Test Categories:
- Basic parsing (elements, attributes, text)
- XML special features (CDATA, comments, PIs)
- Entity escaping (text and attributes)
- Nested elements and mixed content
- Self-closing tags
- Error handling (malformed XML, tag mismatches)
- Round-trip translation (XML → HIR → XML)
- Edge cases (whitespace, namespaces, deep nesting)

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/xml/xml_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/xml/xml_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/xml/xml_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/xml/xml_emitter.runa
- compiler/middle/gungnir/hir/translation/backends/xml/hir_to_xml.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/memory/layout.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/xml/xml_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/xml/xml_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/xml/xml_to_hir.runa" as Frontend
Import "compiler/middle/gungnir/hir/translation/backends/xml/hir_to_xml.runa" as Backend
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Test Infrastructure
Note: ============================================================================

Type called "XMLTestResult":
    test_name as Integer        Note: Test name
    passed as Integer           Note: Boolean: 1 if passed
    error_message as Integer    Note: Error message (if failed)
End Type

Process called "create_test_result" takes test_name as Integer, passed as Integer, error_message as Integer returns Integer:
    Note: Create test result

    Let result_size be 24  Note: XMLTestResult: 3 fields × 8 bytes
    Let result be proc allocate from Layout with result_size

    If result is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with result, 0, test_name
    proc memory_set_int64 from Layout with result, 8, passed
    proc memory_set_int64 from Layout with result, 16, error_message

    Return result
End Process

Process called "strings_equal" takes str1 as Integer, str2 as Integer returns Integer:
    Note: Compare two null-terminated strings for equality

    If str1 is equal to 0:
        If str2 is equal to 0:
            Return 1
        End If
        Return 0
    End If

    If str2 is equal to 0:
        Return 0
    End If

    Let len1 be proc string_length from StringCore with str1
    Let len2 be proc string_length from StringCore with str2

    If len1 is not equal to len2:
        Return 0
    End If

    Let index be 0
    While index is less than len1:
        Let c1 be proc memory_get_byte from Layout with str1, index
        Let c2 be proc memory_get_byte from Layout with str2, index

        If c1 is not equal to c2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Test 1: Simple Element Parsing
Note: ============================================================================

Process called "test_simple_element" returns Integer:
    Note: Test parsing a simple XML element

    Let xml_input be "<root>Hello World</root>"

    Note: Parse XML
    Let xml_ast be proc parse_xml from Parser with xml_input

    If xml_ast is equal to 0:
        Return proc create_test_result from "test_simple_element", 0, "Failed to parse XML"
    End If

    Note: Translate to HIR
    Let translation_context be 0  Note: Null context for testing
    Let hir_root be proc translate_xml_to_hir from Frontend with xml_input, translation_context

    If hir_root is equal to 0:
        Return proc create_test_result from "test_simple_element", 0, "Failed to translate to HIR"
    End If

    Note: Test passed
    Return proc create_test_result from "test_simple_element", 1, 0
End Process

Note: ============================================================================
Note: Test 2: Element with Attributes
Note: ============================================================================

Process called "test_element_with_attributes" returns Integer:
    Note: Test parsing element with multiple attributes

    Let xml_input be "<person name=\"Alice\" age=\"30\" active=\"true\"></person>"

    Let xml_ast be proc parse_xml from Parser with xml_input

    If xml_ast is equal to 0:
        Return proc create_test_result from "test_element_with_attributes", 0, "Failed to parse XML"
    End If

    Let translation_context be 0
    Let hir_root be proc translate_xml_to_hir from Frontend with xml_input, translation_context

    If hir_root is equal to 0:
        Return proc create_test_result from "test_element_with_attributes", 0, "Failed to translate to HIR"
    End If

    Return proc create_test_result from "test_element_with_attributes", 1, 0
End Process

