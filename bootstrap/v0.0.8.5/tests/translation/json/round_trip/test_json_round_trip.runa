Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_json_round_trip_tests" returns Integer:
    Note: Run all JSON round-trip tests

    Let total_tests be 0
    Let passed_tests be 0

    Note: Basic type tests
    Set total_tests to total_tests plus 1
    If proc test_round_trip_string is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_string_with_escapes is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_integer is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_negative_integer is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_boolean_true is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_boolean_false is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_null is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Object tests
    Set total_tests to total_tests plus 1
    If proc test_round_trip_empty_object is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_simple_object is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_nested_object is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Array tests
    Set total_tests to total_tests plus 1
    If proc test_round_trip_empty_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_integer_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_string_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_mixed_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_nested_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Complex structure tests
    Set total_tests to total_tests plus 1
    If proc test_round_trip_array_of_objects is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_object_with_arrays is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_round_trip_deeply_nested is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Print results
    proc print from "JSON Round-Trip Tests:", passed_tests, "/", total_tests, "passed"

    Return passed_tests
End Process

Note: End of JSON Round-Trip Test Suite
