{
  "test_suite": "JSON Nested Objects",
  "description": "Test parsing of nested object structures",
  "tests": {
    "simple_nesting": {
      "outer": {
        "inner": {
          "value": "deeply nested"
        }
      }
    },
    "multiple_levels": {
      "level1": {
        "level2": {
          "level3": {
            "level4": {
              "level5": {
                "value": "5 levels deep"
              }
            }
          }
        }
      }
    },
    "mixed_types_nested": {
      "user": {
        "name": "Alice",
        "age": 30,
        "active": true,
        "address": {
          "street": "123 Main St",
          "city": "Metropolis",
          "zipcode": 12345,
          "coordinates": {
            "latitude": 40.7128,
            "longitude": -74.0060
          }
        },
        "preferences": {
          "notifications": true,
          "theme": "dark",
          "language": "en-US"
        }
      }
    },
    "empty_objects_nested": {
      "outer": {},
      "middle": {
        "inner": {}
      },
      "deep": {
        "deeper": {
          "deepest": {}
        }
      }
    },
    "complex_hierarchy": {
      "company": {
        "name": "Tech Corp",
        "founded": 2010,
        "departments": {
          "engineering": {
            "manager": "Bob Smith",
            "team_size": 50,
            "budget": 5000000,
            "projects": {
              "project_a": {
                "status": "active",
                "priority": 1
              },
              "project_b": {
                "status": "planning",
                "priority": 2
              }
            }
          },
          "sales": {
            "manager": "Jane Doe",
            "team_size": 25,
            "budget": 2000000,
            "regions": {
              "north_america": {
                "revenue": 10000000
              },
              "europe": {
                "revenue": 7500000
              }
            }
          }
        }
      }
    }
  }
}
