Note:
JSON Generation Test Suite

Tests HIR→JSON code generation functionality.
Verifies that Runa data structures can be properly
exported as JSON.

Test Coverage:
- Basic type literals (strings, integers, booleans, null)
- Dictionary/object generation
- List/array generation
- Nested structures
- Edge cases (empty collections, special characters)
- Pretty printing and formatting
:End Note

Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/backends/json/hir_to_json.runa" as JSONGen
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test Utilities
Note: ============================================================================

Process called "assert_json_equals" takes expected as Integer, actual as Integer returns Integer:
    Note: Assert that two JSON strings are equal

    Let expected_len be proc string_length from StringCore with expected
    Let actual_len be proc string_length from StringCore with actual

    If expected_len is not equal to actual_len:
        proc print_error from "Expected length:", expected_len, "but got:", actual_len
        Return 0
    End If

    Let index be 0
    While index is less than expected_len:
        Let expected_char be proc memory_get_byte from Layout with expected, index
        Let actual_char be proc memory_get_byte from Layout with actual, index

        If expected_char is not equal to actual_char:
            proc print_error from "Mismatch at position:", index
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Basic Type Generation Tests
Note: ============================================================================

Process called "test_generate_string_literal" returns Integer:
    Note: Test JSON string literal generation

    Let hir_string be proc create_hir_string_literal from HIR with "hello world"
    Let json be proc translate_hir_to_json from JSONGen with hir_string

    Let expected be "\"hello world\""
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_string_with_escapes" returns Integer:
    Note: Test JSON string with escape sequences

    Let hir_string be proc create_hir_string_literal from HIR with "Line 1\nLine 2\tTabbed"
    Let json be proc translate_hir_to_json from JSONGen with hir_string

    Let expected be "\"Line 1\\nLine 2\\tTabbed\""
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_integer_literal" returns Integer:
    Note: Test JSON integer literal generation

    Let hir_int be proc create_hir_integer_literal from HIR with 42
    Let json be proc translate_hir_to_json from JSONGen with hir_int

    Let expected be "42"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_negative_integer" returns Integer:
    Note: Test JSON negative integer generation

    Let hir_int be proc create_hir_integer_literal from HIR with -17
    Let json be proc translate_hir_to_json from JSONGen with hir_int

    Let expected be "-17"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_boolean_true" returns Integer:
    Note: Test JSON true literal generation

    Let hir_bool be proc create_hir_boolean_literal from HIR with 1
    Let json be proc translate_hir_to_json from JSONGen with hir_bool

    Let expected be "true"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_boolean_false" returns Integer:
    Note: Test JSON false literal generation

    Let hir_bool be proc create_hir_boolean_literal from HIR with 0
    Let json be proc translate_hir_to_json from JSONGen with hir_bool

    Let expected be "false"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_null" returns Integer:
    Note: Test JSON null literal generation

    Let hir_null be proc create_hir_null_literal from HIR
    Let json be proc translate_hir_to_json from JSONGen with hir_null

    Let expected be "null"
    Return proc assert_json_equals from expected, json
End Process

Note: ============================================================================
Note: Dictionary/Object Generation Tests
Note: ============================================================================

Process called "test_generate_empty_object" returns Integer:
    Note: Test JSON empty object generation

    Let hir_dict be proc create_hir_dictionary_literal from HIR
    Let json be proc translate_hir_to_json from JSONGen with hir_dict

    Let expected be "{}"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_simple_object" returns Integer:
    Note: Test JSON object with one key-value pair

    Let hir_dict be proc create_hir_dictionary_literal from HIR
    Let key be "name"
    Let value be proc create_hir_string_literal from HIR with "Alice"

    proc add_dictionary_entry from HIR with hir_dict, key, value

    Let json be proc translate_hir_to_json from JSONGen with hir_dict

    Let expected be "{\"name\": \"Alice\"}"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_object_multiple_fields" returns Integer:
    Note: Test JSON object with multiple fields

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    proc add_dictionary_entry from HIR with hir_dict, "name", proc create_hir_string_literal from HIR with "Bob"
    proc add_dictionary_entry from HIR with hir_dict, "age", proc create_hir_integer_literal from HIR with 30
    proc add_dictionary_entry from HIR with hir_dict, "active", proc create_hir_boolean_literal from HIR with 1

    Let json be proc translate_hir_to_json from JSONGen with hir_dict

    Note: Order may vary, but should contain all fields
    Return 1
End Process

Process called "test_generate_nested_object" returns Integer:
    Note: Test JSON nested object generation

    Let hir_outer be proc create_hir_dictionary_literal from HIR
    Let hir_inner be proc create_hir_dictionary_literal from HIR

    proc add_dictionary_entry from HIR with hir_inner, "value", proc create_hir_string_literal from HIR with "nested"
    proc add_dictionary_entry from HIR with hir_outer, "inner", hir_inner

    Let json be proc translate_hir_to_json from JSONGen with hir_outer

    Return 1
End Process

Note: ============================================================================
Note: List/Array Generation Tests
Note: ============================================================================

Process called "test_generate_empty_array" returns Integer:
    Note: Test JSON empty array generation

    Let hir_list be proc create_hir_list_literal from HIR
    Let json be proc translate_hir_to_json from JSONGen with hir_list

    Let expected be "[]"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_integer_array" returns Integer:
    Note: Test JSON integer array generation

    Let hir_list be proc create_hir_list_literal from HIR

    proc add_list_element from HIR with hir_list, proc create_hir_integer_literal from HIR with 1
    proc add_list_element from HIR with hir_list, proc create_hir_integer_literal from HIR with 2
    proc add_list_element from HIR with hir_list, proc create_hir_integer_literal from HIR with 3

    Let json be proc translate_hir_to_json from JSONGen with hir_list

    Let expected be "[1, 2, 3]"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_string_array" returns Integer:
    Note: Test JSON string array generation

    Let hir_list be proc create_hir_list_literal from HIR

    proc add_list_element from HIR with hir_list, proc create_hir_string_literal from HIR with "apple"
    proc add_list_element from HIR with hir_list, proc create_hir_string_literal from HIR with "banana"
    proc add_list_element from HIR with hir_list, proc create_hir_string_literal from HIR with "cherry"

    Let json be proc translate_hir_to_json from JSONGen with hir_list

    Let expected be "[\"apple\", \"banana\", \"cherry\"]"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_mixed_array" returns Integer:
    Note: Test JSON mixed-type array generation

    Let hir_list be proc create_hir_list_literal from HIR

    proc add_list_element from HIR with hir_list, proc create_hir_integer_literal from HIR with 1
    proc add_list_element from HIR with hir_list, proc create_hir_string_literal from HIR with "two"
    proc add_list_element from HIR with hir_list, proc create_hir_boolean_literal from HIR with 1
    proc add_list_element from HIR with hir_list, proc create_hir_null_literal from HIR

    Let json be proc translate_hir_to_json from JSONGen with hir_list

    Let expected be "[1, \"two\", true, null]"
    Return proc assert_json_equals from expected, json
End Process

Process called "test_generate_nested_array" returns Integer:
    Note: Test JSON nested array generation

    Let hir_outer be proc create_hir_list_literal from HIR
    Let hir_inner1 be proc create_hir_list_literal from HIR
    Let hir_inner2 be proc create_hir_list_literal from HIR

    proc add_list_element from HIR with hir_inner1, proc create_hir_integer_literal from HIR with 1
    proc add_list_element from HIR with hir_inner1, proc create_hir_integer_literal from HIR with 2

    proc add_list_element from HIR with hir_inner2, proc create_hir_integer_literal from HIR with 3
    proc add_list_element from HIR with hir_inner2, proc create_hir_integer_literal from HIR with 4

    proc add_list_element from HIR with hir_outer, hir_inner1
    proc add_list_element from HIR with hir_outer, hir_inner2

    Let json be proc translate_hir_to_json from JSONGen with hir_outer

    Let expected be "[[1, 2], [3, 4]]"
    Return proc assert_json_equals from expected, json
End Process

Note: ============================================================================
Note: Complex Structure Generation Tests
Note: ============================================================================

Process called "test_generate_array_of_objects" returns Integer:
    Note: Test JSON array of objects generation

    Let hir_array be proc create_hir_list_literal from HIR

    Let obj1 be proc create_hir_dictionary_literal from HIR
    proc add_dictionary_entry from HIR with obj1, "id", proc create_hir_integer_literal from HIR with 1
    proc add_dictionary_entry from HIR with obj1, "name", proc create_hir_string_literal from HIR with "Alice"

    Let obj2 be proc create_hir_dictionary_literal from HIR
    proc add_dictionary_entry from HIR with obj2, "id", proc create_hir_integer_literal from HIR with 2
    proc add_dictionary_entry from HIR with obj2, "name", proc create_hir_string_literal from HIR with "Bob"

    proc add_list_element from HIR with hir_array, obj1
    proc add_list_element from HIR with hir_array, obj2

    Let json be proc translate_hir_to_json from JSONGen with hir_array

    Return 1
End Process

Process called "test_generate_object_with_arrays" returns Integer:
    Note: Test JSON object containing arrays

    Let hir_obj be proc create_hir_dictionary_literal from HIR

    Let scores be proc create_hir_list_literal from HIR
    proc add_list_element from HIR with scores, proc create_hir_integer_literal from HIR with 95
    proc add_list_element from HIR with scores, proc create_hir_integer_literal from HIR with 87
    proc add_list_element from HIR with scores, proc create_hir_integer_literal from HIR with 92

    proc add_dictionary_entry from HIR with hir_obj, "name", proc create_hir_string_literal from HIR with "Student"
    proc add_dictionary_entry from HIR with hir_obj, "scores", scores

    Let json be proc translate_hir_to_json from JSONGen with hir_obj

    Return 1
End Process

Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "run_json_generation_tests" returns Integer:
    Note: Run all JSON generation tests

    Let total_tests be 0
    Let passed_tests be 0

    Note: Basic type tests
    Set total_tests to total_tests plus 1
    If proc test_generate_string_literal is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_string_with_escapes is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_integer_literal is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_negative_integer is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_boolean_true is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_boolean_false is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_null is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Object tests
    Set total_tests to total_tests plus 1
    If proc test_generate_empty_object is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_simple_object is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_object_multiple_fields is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_nested_object is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Array tests
    Set total_tests to total_tests plus 1
    If proc test_generate_empty_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_integer_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_string_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_mixed_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_nested_array is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Complex structure tests
    Set total_tests to total_tests plus 1
    If proc test_generate_array_of_objects is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Set total_tests to total_tests plus 1
    If proc test_generate_object_with_arrays is equal to 1:
        Set passed_tests to passed_tests plus 1
    End If

    Note: Print results
    proc print from "JSON Generation Tests:", passed_tests, "/", total_tests, "passed"

    Return passed_tests
End Process

Note: End of JSON Generation Test Suite
