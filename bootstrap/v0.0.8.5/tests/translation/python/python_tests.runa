Process called "test_parser_function_with_decorator" returns Integer:
    Note: Test parsing Python function with decorator

    proc print_string from StringCore with "Testing Python parser function with decorator..."
    proc print_newline from StringCore

    Let source be "@decorator\ndef func(x):\n    return x\n"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer

    Let ast be proc parse from Parser with parser

    proc test_assert from ast is not equal to 0, "AST should not be null"

    Let node_type be proc get_node_type from Parser with ast
    proc test_assert_equal from node_type, PYTHON_MODULE from Parser, "Expected PYTHON_MODULE"

    proc destroy_parser from Parser with parser

    proc print_string from StringCore with "PASS: Parser function with decorator test"
    proc print_newline from StringCore

    Return 1
End Process

