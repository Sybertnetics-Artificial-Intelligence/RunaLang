    Let source be "def greet(name):\n    print(\"Hello, \" + name)\n"
    Let lexer be proc create_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser
    Let hir be proc translate_to_hir from ToHIR with ast

    Let context be proc create_generation_context from FromHIR
    Let generated be proc generate_python from FromHIR with context, hir

    proc test_assert from generated is not equal to 0, "Generated code should not be null"

    proc destroy_generation_context from FromHIR with context
    proc destroy_parser from Parser with parser

    proc print_string from StringCore with "PASS: HIR→Python function generation test"
    proc print_newline from StringCore

    Return 1
End Process

