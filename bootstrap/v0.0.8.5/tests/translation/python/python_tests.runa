Note:
Python Language Translator Tests - Comprehensive test suite

This file provides comprehensive tests for the Python language translator,
covering lexing, parsing, Python→HIR translation, HIR→Python generation,
and round-trip translation preservation.

Test Coverage:
- Lexer: Keywords, operators, literals, indentation handling
- Parser: Functions, classes, decorators, control flow, Python-specific features
- Translation: Python→HIR→Python round-trip preservation
- Generation: HIR→Python code generation with idiomatic Python output
- Integration: Complete translation pipeline validation

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/python/python_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/python/python_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/python/python_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/python/python_emitter.runa
- compiler/middle/gungnir/hir/translation/backends/python/hir_to_python.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/python/python_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/python/python_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/python/python_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/python/python_emitter.runa" as Emitter
Import "compiler/middle/gungnir/hir/translation/backends/python/hir_to_python.runa" as FromHIR
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Test Utilities
Note: ============================================================================

Process called "test_assert" takes condition as Integer, message as Integer returns Integer:
    Note: Assert condition is true, print message if false

    If condition is equal to 0:
        proc print_string from StringCore with "FAIL: "
        proc print_string from StringCore with message
        proc print_newline from StringCore
        Return 0
    End If

    Return 1
End Process

Process called "test_assert_equal" takes actual as Integer, expected as Integer, message as Integer returns Integer:
    Note: Assert two values are equal

    If actual is not equal to expected:
        proc print_string from StringCore with "FAIL: "
        proc print_string from StringCore with message
        proc print_string from StringCore with " (expected "
        proc print_int from StringCore with expected
        proc print_string from StringCore with ", got "
        proc print_int from StringCore with actual
        proc print_string from StringCore with ")"
        proc print_newline from StringCore
        Return 0
    End If

    Return 1
End Process

Process called "test_assert_string_equal" takes actual as Integer, expected as Integer, message as Integer returns Integer:
    Note: Assert two strings are equal

    Let are_equal be proc strings_equal from StringCore with actual, expected

    If are_equal is equal to 0:
        proc print_string from StringCore with "FAIL: "
        proc print_string from StringCore with message
        proc print_newline from StringCore
        proc print_string from StringCore with "  Expected: "
        proc print_string from StringCore with expected
        proc print_newline from StringCore
        proc print_string from StringCore with "  Got: "
        proc print_string from StringCore with actual
        proc print_newline from StringCore
        Return 0
    End If

    Return 1
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_lexer_keywords" returns Integer:
    Note: Test Python keyword tokenization including async/await/match/case

    proc print_string from StringCore with "Testing Python lexer keywords..."
    proc print_newline from StringCore

    Let source be "def class async await match case lambda yield return"
    Let lexer be proc create_lexer from Lexer with source

    Let token1 be proc next_token from Lexer with lexer
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc test_assert_equal from type1, TOKEN_DEF from Lexer, "Expected TOKEN_DEF"

    Let token2 be proc next_token from Lexer with lexer
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc test_assert_equal from type2, TOKEN_CLASS from Lexer, "Expected TOKEN_CLASS"

    Let token3 be proc next_token from Lexer with lexer
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc test_assert_equal from type3, TOKEN_ASYNC from Lexer, "Expected TOKEN_ASYNC"

    Let token4 be proc next_token from Lexer with lexer
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc test_assert_equal from type4, TOKEN_AWAIT from Lexer, "Expected TOKEN_AWAIT"

    Let token5 be proc next_token from Lexer with lexer
    Let type5 be proc memory_get_int64 from Layout with token5, 0
    proc test_assert_equal from type5, TOKEN_MATCH from Lexer, "Expected TOKEN_MATCH"

    Let token6 be proc next_token from Lexer with lexer
    Let type6 be proc memory_get_int64 from Layout with token6, 0
    proc test_assert_equal from type6, TOKEN_CASE from Lexer, "Expected TOKEN_CASE"

    Let token7 be proc next_token from Lexer with lexer
    Let type7 be proc memory_get_int64 from Layout with token7, 0
    proc test_assert_equal from type7, TOKEN_LAMBDA from Lexer, "Expected TOKEN_LAMBDA"

    Let token8 be proc next_token from Lexer with lexer
    Let type8 be proc memory_get_int64 from Layout with token8, 0
    proc test_assert_equal from type8, TOKEN_YIELD from Lexer, "Expected TOKEN_YIELD"

    Let token9 be proc next_token from Lexer with lexer
    Let type9 be proc memory_get_int64 from Layout with token9, 0
    proc test_assert_equal from type9, TOKEN_RETURN from Lexer, "Expected TOKEN_RETURN"

    proc destroy_lexer from Lexer with lexer

    proc print_string from StringCore with "PASS: Lexer keywords test"
    proc print_newline from StringCore

    Return 1
End Process

Process called "test_lexer_operators" returns Integer:
    Note: Test Python operator tokenization including walrus, floor division

    proc print_string from StringCore with "Testing Python lexer operators..."
    proc print_newline from StringCore

    Let source be ":= // ** @ ->"
    Let lexer be proc create_lexer from Lexer with source

    Let token1 be proc next_token from Lexer with lexer
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc test_assert_equal from type1, TOKEN_WALRUS from Lexer, "Expected TOKEN_WALRUS (:=)"

    Let token2 be proc next_token from Lexer with lexer
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc test_assert_equal from type2, TOKEN_FLOOR_DIV from Lexer, "Expected TOKEN_FLOOR_DIV (//)"

    Let token3 be proc next_token from Lexer with lexer
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc test_assert_equal from type3, TOKEN_POWER from Lexer, "Expected TOKEN_POWER (**)"

    Let token4 be proc next_token from Lexer with lexer
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc test_assert_equal from type4, TOKEN_AT from Lexer, "Expected TOKEN_AT (@)"

    Let token5 be proc next_token from Lexer with lexer
    Let type5 be proc memory_get_int64 from Layout with token5, 0
    proc test_assert_equal from type5, TOKEN_ARROW from Lexer, "Expected TOKEN_ARROW (->)"

    proc destroy_lexer from Lexer with lexer

    proc print_string from StringCore with "PASS: Lexer operators test"
    proc print_newline from StringCore

    Return 1
End Process

Process called "test_lexer_literals" returns Integer:
    Note: Test Python literal tokenization including all string formats

    proc print_string from StringCore with "Testing Python lexer literals..."
    proc print_newline from StringCore

    Let source be "123 3.14 \"hello\" r\"raw\" f\"formatted\" b\"bytes\""
    Let lexer be proc create_lexer from Lexer with source

    Let token1 be proc next_token from Lexer with lexer
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc test_assert_equal from type1, TOKEN_INTEGER from Lexer, "Expected TOKEN_INTEGER"

    Let token2 be proc next_token from Lexer with lexer
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc test_assert_equal from type2, TOKEN_FLOAT from Lexer, "Expected TOKEN_FLOAT"

    Let token3 be proc next_token from Lexer with lexer
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc test_assert_equal from type3, TOKEN_STRING from Lexer, "Expected TOKEN_STRING"

    Let token4 be proc next_token from Lexer with lexer
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc test_assert_equal from type4, TOKEN_RAW_STRING from Lexer, "Expected TOKEN_RAW_STRING"

    Let token5 be proc next_token from Lexer with lexer
    Let type5 be proc memory_get_int64 from Layout with token5, 0
    proc test_assert_equal from type5, TOKEN_FSTRING from Lexer, "Expected TOKEN_FSTRING"

    Let token6 be proc next_token from Lexer with lexer
    Let type6 be proc memory_get_int64 from Layout with token6, 0
    proc test_assert_equal from type6, TOKEN_BYTES from Lexer, "Expected TOKEN_BYTES"

    proc destroy_lexer from Lexer with lexer

    proc print_string from StringCore with "PASS: Lexer literals test"
    proc print_newline from StringCore

    Return 1
End Process

