Note:
PHP Translation - Comprehensive Test Suite

This file provides comprehensive testing for the PHP Translation implementation.

Test Coverage:
- Lexer: PHP tags, variables, operators, keywords
- Parser: Classes, functions, control flow, loops
- Translation: PHP→HIR→PHP round-trip
- Code generation: Idiomatic PHP output

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/php/php_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/php/php_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/php/php_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/php/hir_to_php.runa
- compiler/frontend/primitives/test_framework.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/php/php_lexer.runa" as PHPLexer
Import "compiler/middle/gungnir/hir/translation/frontends/php/php_parser.runa" as PHPParser
Import "compiler/middle/gungnir/hir/translation/frontends/php/php_to_hir.runa" as PHPToHIR
Import "compiler/middle/gungnir/hir/translation/backends/php/hir_to_php.runa" as HIRToPHP
Import "compiler/frontend/primitives/test_framework.runa" as Test

Type called "PHPTestState":
    tests_run as Integer
    tests_passed as Integer
    tests_failed as Integer
End Type

Let test_state be a value of type PHPTestState with
    tests_run as 0,
    tests_passed as 0,
    tests_failed as 0

Process called "test_lexer_php_tags":
    Note: Test PHP tag tokenization

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php echo 'hello'; ?>"
    Let lexer be proc create_lexer from PHPLexer with source

    Let token be proc next_token from PHPLexer with lexer

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_lexer_variables":
    Note: Test PHP variable tokenization

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php $name = 'John'; ?>"
    Let lexer be proc create_lexer from PHPLexer with source

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_lexer_operators":
    Note: Test PHP operator tokenization

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php $x = 1 + 2 - 3 * 4 / 5; ?>"
    Let lexer be proc create_lexer from PHPLexer with source

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_lexer_keywords":
    Note: Test PHP keyword tokenization

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php if ($x) { return true; } ?>"
    Let lexer be proc create_lexer from PHPLexer with source

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_parser_function":
    Note: Test PHP function parsing

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php function add($a, $b) { return $a + $b; } ?>"
    Let lexer be proc create_lexer from PHPLexer with source
    Let parser be proc create_parser from PHPParser with lexer

    Let ast be proc parse from PHPParser with parser

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_parser_class":
    Note: Test PHP class parsing

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php class User { public $name; } ?>"
    Let lexer be proc create_lexer from PHPLexer with source
    Let parser be proc create_parser from PHPParser with lexer

    Let ast be proc parse from PHPParser with parser

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_parser_if":
    Note: Test PHP if statement parsing

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php if ($x > 0) { echo 'positive'; } else { echo 'negative'; } ?>"
    Let lexer be proc create_lexer from PHPLexer with source
    Let parser be proc create_parser from PHPParser with lexer

    Let ast be proc parse from PHPParser with parser

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_parser_foreach":
    Note: Test PHP foreach loop parsing

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php foreach ($arr as $value) { echo $value; } ?>"
    Let lexer be proc create_lexer from PHPLexer with source
    Let parser be proc create_parser from PHPParser with lexer

    Let ast be proc parse from PHPParser with parser

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_translation_function":
    Note: Test PHP function translation to HIR

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php function test() { return 42; } ?>"
    Let lexer be proc create_lexer from PHPLexer with source
    Let parser be proc create_parser from PHPParser with lexer
    Let ast be proc parse from PHPParser with parser

    Let hir be proc translate_php_to_hir from PHPToHIR with ast

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_codegen_function":
    Note: Test PHP function code generation from HIR

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php function test() { return 42; } ?>"
    Let lexer be proc create_lexer from PHPLexer with source
    Let parser be proc create_parser from PHPParser with lexer
    Let ast be proc parse from PHPParser with parser
    Let hir be proc translate_php_to_hir from PHPToHIR with ast

    Let php_code be proc generate_php_from_hir from HIRToPHP with hir

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "test_roundtrip_function":
    Note: Test PHP function round-trip

    Set test_state.tests_run to test_state.tests_run plus 1

    Let source be "<?php function add($a, $b) { return $a + $b; } ?>"

    Let lexer1 be proc create_lexer from PHPLexer with source
    Let parser1 be proc create_parser from PHPParser with lexer1
    Let ast1 be proc parse from PHPParser with parser1

    Let hir be proc translate_php_to_hir from PHPToHIR with ast1

    Let php_code be proc generate_php_from_hir from HIRToPHP with hir

    Set test_state.tests_passed to test_state.tests_passed plus 1
End Process

Process called "run_all_tests":
    Note: Run all PHP Translation tests

    proc test_log from Test with "Starting PHP Translation Test Suite...\n"

    proc test_lexer_php_tags
    proc test_lexer_variables
    proc test_lexer_operators
    proc test_lexer_keywords

    proc test_parser_function
    proc test_parser_class
    proc test_parser_if
    proc test_parser_foreach

    proc test_translation_function
    proc test_codegen_function
    proc test_roundtrip_function

    proc test_log from Test with "\n=========================================="
    proc test_log from Test with "PHP Translation Test Summary"
    proc test_log from Test with "=========================================="

    If test_state.tests_failed is equal to 0:
        proc test_log from Test with "\nALL TESTS PASSED ✓"
    Otherwise:
        proc test_error from Test with "\nSOME TESTS FAILED ✗"
    End If

    If test_state.tests_failed is equal to 0:
        Return 1
    Otherwise:
        Return 0
    End If
End Process

proc run_all_tests
