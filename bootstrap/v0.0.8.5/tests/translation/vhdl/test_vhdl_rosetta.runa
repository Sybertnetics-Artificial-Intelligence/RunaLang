End Process

Note: ==================== Translator Tests ====================

Process called "test_translator_entity_to_module" returns Integer:
    Note: Test translating VHDL entity to HIR module

    Let source be "entity test is\n  port (clk : in std_logic);\nend entity;"
    Let lexer be proc create_lexer from VhdlLexer with source
    Let tokens be proc tokenize from VhdlLexer with lexer
    Let token_count be proc list_length from tokens
    Let vhdl_ast be proc parse from VhdlParser with tokens, token_count

    Let hir be proc translate from VhdlToHir with vhdl_ast

    Note: Check HIR structure
    Note: Should have program node with modules
    Let modules be proc dict_get from hir, "modules"
    Let module_count be proc list_length from modules

    If module_count is less than 1:
        proc test_fail from TestFramework with "Translator: no modules generated"
        Return 0
    End If

    proc test_pass from TestFramework with "Translator: entity to module"
    Return 1
End Process

