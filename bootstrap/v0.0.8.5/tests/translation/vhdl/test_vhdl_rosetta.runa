Note: ==================== Round-Trip Tests ====================

Process called "test_round_trip_entity" returns Integer:
    Note: Test VHDL → HIR → VHDL for entity

    Let source be "library ieee;\nuse ieee.std_logic_1164.all;\n\nentity test is\n  port (\n    clk : in std_logic\n  );\nend entity test;"

    Note: Parse VHDL
    Let lexer be proc create_lexer from VhdlLexer with source
    Let tokens be proc tokenize from VhdlLexer with lexer
    Let token_count be proc list_length from tokens
    Let vhdl_ast be proc parse from VhdlParser with tokens, token_count

    Note: Translate to HIR
    Let hir be proc translate from VhdlToHir with vhdl_ast

    Note: Generate VHDL from HIR
    Let generated_vhdl be proc generate from HirToVhdl with hir

    Note: Check that generated VHDL contains key elements
    Let has_entity be proc string_contains from StringCore with generated_vhdl, "entity"
    If has_entity is equal to 0:
        proc test_fail from TestFramework with "Round-trip: missing entity keyword"
        Return 0
    End If

    let has_port be proc string_contains from StringCore with generated_vhdl, "port"
    If has_port is equal to 0:
        proc test_fail from TestFramework with "Round-trip: missing port keyword"
        Return 0
    End If

    proc test_pass from TestFramework with "Round-trip: entity"
    Return 1
End Process

Process called "test_round_trip_architecture" returns Integer:
    Note: Test VHDL → HIR → VHDL for architecture

    Let source be "library ieee;\nuse ieee.std_logic_1164.all;\n\narchitecture rtl of test is\nbegin\n  x <= y;\nend architecture rtl;"

    Note: Parse VHDL
    Let lexer be proc create_lexer from VhdlLexer with source
    Let tokens be proc tokenize from VhdlLexer with lexer
    Let token_count be proc list_length from tokens
    Let vhdl_ast be proc parse from VhdlParser with tokens, token_count

    Note: Translate to HIR
    Let hir be proc translate from VhdlToHir with vhdl_ast

    Note: Generate VHDL from HIR
    Let generated_vhdl be proc generate from HirToVhdl with hir

    Note: Check for architecture keyword
    Let has_arch be proc string_contains from StringCore with generated_vhdl, "architecture"
    If has_arch is equal to 0:
        proc test_fail from TestFramework with "Round-trip: missing architecture keyword"
        Return 0
    End If

    proc test_pass from TestFramework with "Round-trip: architecture"
    Return 1
End Process

Note: ==================== Integration Tests ====================

Process called "test_integration_flip_flop" returns Integer:
    Note: Test complete flip-flop translation

    Let source be "library ieee;\nuse ieee.std_logic_1164.all;\n\nentity dff is\n  port (\n    clk : in std_logic;\n    d : in std_logic;\n    q : out std_logic\n  );\nend entity dff;\n\narchitecture rtl of dff is\nbegin\n  process (clk)\n  begin\n    if rising_edge(clk) then\n      q <= d;\n    end if;\n  end process;\nend architecture rtl;"

    Note: Full pipeline test
    Let lexer be proc create_lexer from VhdlLexer with source
    Let tokens be proc tokenize from VhdlLexer with lexer
    Let token_count be proc list_length from tokens
    Let vhdl_ast be proc parse from VhdlParser with tokens, token_count
    Let hir be proc translate from VhdlToHir with vhdl_ast
    Let generated_vhdl be proc generate from HirToVhdl with hir

    Note: Verify key elements present
    Let has_process be proc string_contains from StringCore with generated_vhdl, "process"
    If has_process is equal to 0:
        proc test_fail from TestFramework with "Integration: flip-flop missing process"
        Return 0
    End If

    proc test_pass from TestFramework with "Integration: D flip-flop"
    Return 1
End Process

Process called "test_integration_counter" returns Integer:
    Note: Test complete counter translation

    Let source be "library ieee;\nuse ieee.std_logic_1164.all;\nuse ieee.numeric_std.all;\n\nentity counter is\n  port (\n    clk : in std_logic;\n    rst : in std_logic;\n    count : out std_logic_vector(7 downto 0)\n  );\nend entity counter;\n\narchitecture rtl of counter is\n  signal cnt : unsigned(7 downto 0);\nbegin\n  process (clk, rst)\n  begin\n    if rst = '1' then\n      cnt <= (others => '0');\n    elsif rising_edge(clk) then\n      cnt <= cnt + 1;\n    end if;\n  end process;\n  count <= std_logic_vector(cnt);\nend architecture rtl;"

    Note: Full pipeline test
    Let lexer be proc create_lexer from VhdlLexer with source
    Let tokens be proc tokenize from VhdlLexer with lexer
    Let token_count be proc list_length from tokens
    Let vhdl_ast be proc parse from VhdlParser with tokens, token_count
    Let hir be proc translate from VhdlToHir with vhdl_ast
    Let generated_vhdl be proc generate from HirToVhdl with hir

    proc test_pass from TestFramework with "Integration: counter"
    Return 1
End Process

Note: ==================== Test Suite Runner ====================

Process called "run_all_tests" returns Integer:
    Note: Run all VHDL Translation tests

    proc test_suite_begin from TestFramework with "VHDL Translation Test Suite"

    Note: Lexer tests
    proc test_group_begin from TestFramework with "Lexer Tests"
    proc test_lexer_keywords
    proc test_lexer_identifiers
    proc test_lexer_numbers
    proc test_lexer_operators
    proc test_lexer_strings
    proc test_lexer_comments
    proc test_lexer_case_insensitive
    proc test_group_end from TestFramework

    Note: Parser tests
    proc test_group_begin from TestFramework with "Parser Tests"
    proc test_parser_entity
    proc test_parser_architecture
    proc test_parser_signal_assignment
    proc test_parser_process
    proc test_parser_if_statement
    proc test_parser_for_loop
    proc test_parser_component_instantiation
    proc test_group_end from TestFramework

    Note: Translator tests
    proc test_group_begin from TestFramework with "Translator Tests"
    proc test_translator_entity_to_module
    proc test_translator_signal_to_variable
    proc test_translator_process_to_function
    proc test_translator_operators
    proc test_group_end from TestFramework

    Note: Backend tests
    proc test_group_begin from TestFramework with "Backend Tests"
    proc test_backend_module_to_entity
    proc test_backend_assignment
    proc test_group_end from TestFramework

    Note: Round-trip tests
    proc test_group_begin from TestFramework with "Round-Trip Tests"
    proc test_round_trip_entity
    proc test_round_trip_architecture
    proc test_group_end from TestFramework

    Note: Integration tests
    proc test_group_begin from TestFramework with "Integration Tests"
    proc test_integration_flip_flop
    proc test_integration_counter
    proc test_group_end from TestFramework

    proc test_suite_end from TestFramework

    Note: Return test results
    Return proc get_test_results from TestFramework
End Process

Note: ==================== Main Entry Point ====================

Process called "main" returns Integer:
    Note: Main entry point for VHDL Translation tests

    Let results be proc run_all_tests

    If results is equal to 0:
        Return 1
    End If

    Return 0
End Process
