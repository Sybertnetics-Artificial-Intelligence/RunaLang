Process called "test_translation_always_block" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test round-trip translation of always block.
    @End Reasoning

    Let source be "module test; reg q; always @(posedge clk) begin q <= d; end endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let regenerated be proc round_trip from VerilogEmitter with emitter_ptr, source

    Let has_errors be proc has_errors from VerilogEmitter with emitter_ptr

    proc assert_equals from suite_ptr, "Translation: always block no errors", "0", proc integer_to_string with has_errors
    proc assert_not_equal from suite_ptr, "Translation: always block output not empty", "", regenerated

    Return 1
End Process

