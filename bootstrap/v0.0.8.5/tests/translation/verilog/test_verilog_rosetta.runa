Note: ================================================================
Note: Main Test Runner
Note: ================================================================

Process called "run_all_tests" that takes nothing returns Integer:
    @Reasoning
    Run all test suites and report results.
    @End Reasoning

    Let total_failures be 0

    Note: Lexer tests
    Let lexer_suite be proc create_test_suite with "Verilog Lexer Tests"
    proc test_lexer_keywords from lexer_suite
    proc test_lexer_operators from lexer_suite
    proc test_lexer_numbers from lexer_suite
    proc test_lexer_identifiers from lexer_suite
    proc test_lexer_comments from lexer_suite
    Set total_failures to total_failures + proc print_test_results with lexer_suite

    Note: Parser tests
    Let parser_suite be proc create_test_suite with "Verilog Parser Tests"
    proc test_parser_module_declaration from parser_suite
    proc test_parser_port_declarations from parser_suite
    proc test_parser_wire_reg_declarations from parser_suite
    proc test_parser_always_block from parser_suite
    proc test_parser_assign_statement from parser_suite
    proc test_parser_if_statement from parser_suite
    proc test_parser_case_statement from parser_suite
    proc test_parser_for_loop from parser_suite
    proc test_parser_expressions from parser_suite
    Set total_failures to total_failures + proc print_test_results with parser_suite

    Note: Translation tests
    Let translation_suite be proc create_test_suite with "Verilog Translation Tests"
    proc test_translation_simple_module from translation_suite
    proc test_translation_wire_declarations from translation_suite
    proc test_translation_reg_declarations from translation_suite
    proc test_translation_always_block from translation_suite
    proc test_translation_combinational_logic from translation_suite
    proc test_translation_sequential_logic from translation_suite
    proc test_translation_if_statement from translation_suite
    proc test_translation_case_statement from translation_suite
    proc test_translation_bit_operations from translation_suite
    proc test_translation_concatenation from translation_suite
    Set total_failures to total_failures + proc print_test_results with translation_suite

    Note: Print overall summary
    proc print_string with "\n========================================"
    proc print_string with "\nOVERALL TEST SUMMARY\n"
    proc print_string with "========================================\n"
    If total_failures is equal to 0:
        proc print_string with "ALL TESTS PASSED!\n"
    Otherwise:
        proc print_string with "TOTAL FAILURES: "
        proc print_integer with total_failures
        proc print_string with "\n"
    End If
    proc print_string with "========================================\n"

    Return total_failures
End Process

Note: ================================================================
Note: Helper Functions
Note: ================================================================

Process called "integer_to_string" that takes value as Integer returns String:
    @Reasoning
    Convert integer to string for test assertions.
    @End Reasoning

    If value is equal to 0:
        Return "0"
    End If

    If value is equal to 1:
        Return "1"
    End If

    If value is equal to 2:
        Return "2"
    End If

    If value is equal to 3:
        Return "3"
    End If

    If value is equal to 4:
        Return "4"
    End If

    If value is equal to 5:
        Return "5"
    End If

    If value is equal to 6:
        Return "6"
    End If

    If value is equal to 7:
        Return "7"
    End If

    If value is equal to 8:
        Return "8"
    End If

    If value is equal to 9:
        Return "9"
    End If

    If value is equal to 10:
        Return "10"
    End If

    Note: For larger numbers, build string digit by digit
    Let result be ""
    Let remaining be value
    Let is_negative be 0

    If value is less than 0:
        Set is_negative to 1
        Set remaining to 0 - value
    End If

    If remaining is equal to 0:
        Return "0"
    End If

    Let digits be proc create_list from ListCore

    While remaining is greater than 0:
        Let digit be remaining - ((remaining / 10) * 10)
        proc add_to_list from ListCore with digits, digit
        Set remaining to remaining / 10
    End While

    If is_negative is equal to 1:
        Set result to "-"
    End If

    Let digit_count be proc get_list_size from ListCore with digits
    Let index be digit_count - 1

    While index is greater than or equal to 0:
        Let digit be proc get_from_list from ListCore with digits, index

        If digit is equal to 0:
            Set result to proc string_concat from StringCore with result, "0"
        Otherwise: If digit is equal to 1:
            Set result to proc string_concat from StringCore with result, "1"
        Otherwise: If digit is equal to 2:
            Set result to proc string_concat from StringCore with result, "2"
        Otherwise: If digit is equal to 3:
            Set result to proc string_concat from StringCore with result, "3"
        Otherwise: If digit is equal to 4:
            Set result to proc string_concat from StringCore with result, "4"
        Otherwise: If digit is equal to 5:
            Set result to proc string_concat from StringCore with result, "5"
        Otherwise: If digit is equal to 6:
            Set result to proc string_concat from StringCore with result, "6"
        Otherwise: If digit is equal to 7:
            Set result to proc string_concat from StringCore with result, "7"
        Otherwise: If digit is equal to 8:
            Set result to proc string_concat from StringCore with result, "8"
        Otherwise: If digit is equal to 9:
            Set result to proc string_concat from StringCore with result, "9"
        End If

        Set index to index - 1
    End While

    Return result
End Process

Process called "print_string" that takes text as String returns Integer:
    @Reasoning
    Print string to console (placeholder for actual I/O).
    @End Reasoning

    Note: This would use actual I/O in production
    Return 1
End Process

Process called "print_integer" that takes value as Integer returns Integer:
    @Reasoning
    Print integer to console (placeholder for actual I/O).
    @End Reasoning

    Let str be proc integer_to_string with value
    proc print_string with str
    Return 1
End Process
