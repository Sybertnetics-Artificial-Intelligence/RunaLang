    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: octal numbers count", "3", proc integer_to_string with token_count

    Note: Test real numbers
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "3.14 1.5e-10"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: real numbers count", "3", proc integer_to_string with token_count

    Return 1
End Process

Process called "test_lexer_identifiers" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test lexer recognition of identifiers and strings.
    @End Reasoning

    Let lexer_ptr be proc create_lexer from VerilogLexer

    Note: Test simple identifiers
    Let tokens be proc scan from VerilogLexer with lexer_ptr, "clk rst data_in"
    Let token_count be proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: simple identifiers count", "4", proc integer_to_string with token_count

    Note: Test identifiers with underscores
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "_start end_ mid_dle"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: underscore identifiers count", "4", proc integer_to_string with token_count

    Note: Test string literals
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "\"hello\" \"world\""
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: string literals count", "3", proc integer_to_string with token_count

    Note: Test system tasks
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "$display $monitor $finish"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: system tasks count", "4", proc integer_to_string with token_count

    Note: Test compiler directives
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "`define `include `ifdef"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: compiler directives count", "4", proc integer_to_string with token_count

    Return 1
End Process

Process called "test_lexer_comments" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test lexer handling of comments.
    @End Reasoning

    Let lexer_ptr be proc create_lexer from VerilogLexer

    Note: Test line comments
    Let source be "wire a; // This is a comment\nwire b;"
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source
    Let token_count be proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: line comments handled", "7", proc integer_to_string with token_count  Note: wire, a, ;, wire, b, ;, EOF

    Note: Test block comments
    Set source to "wire a; /* block comment */ wire b;"
    Set tokens to proc scan from VerilogLexer with lexer_ptr, source
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: block comments handled", "7", proc integer_to_string with token_count

    Return 1
End Process

Note: ================================================================
Note: Parser Tests
Note: ================================================================

Process called "test_parser_module_declaration" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test parser module declaration parsing.
    @End Reasoning

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let source be "module test_mod(clk, rst, data); endmodule"
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let parser_ptr be proc create_parser from VerilogParser with tokens
    Let ast be proc parse from VerilogParser with parser_ptr

    proc assert_true from suite_ptr, "Parser: module declaration AST created", ast

    Let parser_errors be proc get_errors from VerilogParser with parser_ptr
    Let error_count be proc get_list_size from ListCore with parser_errors
    proc assert_equals from suite_ptr, "Parser: module declaration no errors", "0", proc integer_to_string with error_count

    Return 1
End Process

