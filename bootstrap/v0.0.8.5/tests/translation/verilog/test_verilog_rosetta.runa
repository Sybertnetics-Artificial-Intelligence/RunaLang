Note: ================================================================
Note: Verilog Translation - Comprehensive Test Suite
Note: ================================================================
Note: Tests all components of the Verilog translation layer:
Note:   - Lexer: Tokenization of all Verilog constructs
Note:   - Parser: AST construction for all syntax
Note:   - Translation: Verilog→HIR→Verilog round-trip
Note:   - Error handling and edge cases
Note: ================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/verilog/verilog_lexer.runa" as VerilogLexer
Import "compiler/middle/gungnir/hir/translation/frontends/verilog/verilog_parser.runa" as VerilogParser
Import "compiler/middle/gungnir/hir/translation/frontends/verilog/verilog_to_hir.runa" as VerilogToHIR
Import "compiler/middle/gungnir/hir/translation/backends/verilog/hir_to_verilog.runa" as HIRToVerilog
Import "compiler/middle/gungnir/hir/translation/backends/verilog/verilog_emitter.runa" as VerilogEmitter
Import "core/memory.runa" as Memory
Import "core/string.runa" as StringCore
Import "core/list.runa" as ListCore

Note: ================================================================
Note: Test Framework Types
Note: ================================================================

Type called "TestResult":
    test_name as String
    passed as Integer
    error_message as String
    expected as String
    actual as String
End Type

Type called "TestSuite":
    suite_name as String
    tests_run as Integer
    tests_passed as Integer
    tests_failed as Integer
    results as Integer  Note: List of TestResult
End Type

Note: ================================================================
Note: Test Framework Functions
Note: ================================================================

Process called "create_test_suite" that takes suite_name as String returns Integer:
    @Reasoning
    Create a new test suite for organizing related tests.
    @End Reasoning

    Let suite_ptr be proc allocate from Memory with 40

    proc write_string from Memory at suite_ptr with 0, suite_name
    proc write_integer from Memory at suite_ptr with 8, 0  Note: tests_run
    proc write_integer from Memory at suite_ptr with 16, 0  Note: tests_passed
    proc write_integer from Memory at suite_ptr with 24, 0  Note: tests_failed

    Let results_list be proc create_list from ListCore
    proc write_integer from Memory at suite_ptr with 32, results_list

    Return suite_ptr
End Process

Process called "assert_equals" that takes suite_ptr as Integer, test_name as String, expected as String, actual as String returns Integer:
    @Reasoning
    Assert that expected value equals actual value.
    @End Reasoning

    Let tests_run be proc read_integer from Memory at suite_ptr with 8
    proc write_integer from Memory at suite_ptr with 8, tests_run + 1

    Let result_ptr be proc allocate from Memory with 40
    proc write_string from Memory at result_ptr with 0, test_name

    If proc string_equals from StringCore with expected, actual:
        proc write_integer from Memory at result_ptr with 8, 1  Note: passed
        proc write_string from Memory at result_ptr with 16, ""  Note: no error

        Let tests_passed be proc read_integer from Memory at suite_ptr with 16
        proc write_integer from Memory at suite_ptr with 16, tests_passed + 1
    Otherwise:
        proc write_integer from Memory at result_ptr with 8, 0  Note: failed
        proc write_string from Memory at result_ptr with 16, "Values do not match"

        Let tests_failed be proc read_integer from Memory at suite_ptr with 24
        proc write_integer from Memory at suite_ptr with 24, tests_failed + 1
    End If

    proc write_string from Memory at result_ptr with 24, expected
    proc write_string from Memory at result_ptr with 32, actual

    Let results_list be proc read_integer from Memory at suite_ptr with 32
    proc add_to_list from ListCore with results_list, result_ptr

    Return 1
End Process

Process called "assert_not_equal" that takes suite_ptr as Integer, test_name as String, not_expected as String, actual as String returns Integer:
    @Reasoning
    Assert that value does not equal the not-expected value.
    @End Reasoning

    Let tests_run be proc read_integer from Memory at suite_ptr with 8
    proc write_integer from Memory at suite_ptr with 8, tests_run + 1

    Let result_ptr be proc allocate from Memory with 40
    proc write_string from Memory at result_ptr with 0, test_name

    If proc string_equals from StringCore with not_expected, actual:
        proc write_integer from Memory at result_ptr with 8, 0  Note: failed
        proc write_string from Memory at result_ptr with 16, "Values should not match"

        Let tests_failed be proc read_integer from Memory at suite_ptr with 24
        proc write_integer from Memory at suite_ptr with 24, tests_failed + 1
    Otherwise:
        proc write_integer from Memory at result_ptr with 8, 1  Note: passed
        proc write_string from Memory at result_ptr with 16, ""  Note: no error

        Let tests_passed be proc read_integer from Memory at suite_ptr with 16
        proc write_integer from Memory at suite_ptr with 16, tests_passed + 1
    End If

    proc write_string from Memory at result_ptr with 24, not_expected
    proc write_string from Memory at result_ptr with 32, actual

    Let results_list be proc read_integer from Memory at suite_ptr with 32
    proc add_to_list from ListCore with results_list, result_ptr

    Return 1
End Process

Process called "assert_true" that takes suite_ptr as Integer, test_name as String, condition as Integer returns Integer:
    @Reasoning
    Assert that condition is true (non-zero).
    @End Reasoning

    Let tests_run be proc read_integer from Memory at suite_ptr with 8
    proc write_integer from Memory at suite_ptr with 8, tests_run + 1

    Let result_ptr be proc allocate from Memory with 40
    proc write_string from Memory at result_ptr with 0, test_name

    If condition is not equal to 0:
        proc write_integer from Memory at result_ptr with 8, 1  Note: passed
        proc write_string from Memory at result_ptr with 16, ""

        Let tests_passed be proc read_integer from Memory at suite_ptr with 16
        proc write_integer from Memory at suite_ptr with 16, tests_passed + 1
    Otherwise:
        proc write_integer from Memory at result_ptr with 8, 0  Note: failed
        proc write_string from Memory at result_ptr with 16, "Condition is false"

        Let tests_failed be proc read_integer from Memory at suite_ptr with 24
        proc write_integer from Memory at suite_ptr with 24, tests_failed + 1
    End If

    proc write_string from Memory at result_ptr with 24, "true"
    proc write_string from Memory at result_ptr with 32, "false"

    Let results_list be proc read_integer from Memory at suite_ptr with 32
    proc add_to_list from ListCore with results_list, result_ptr

    Return 1
End Process

Process called "print_test_results" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Print test suite results summary.
    @End Reasoning

    Let suite_name be proc read_string from Memory at suite_ptr with 0
    Let tests_run be proc read_integer from Memory at suite_ptr with 8
    Let tests_passed be proc read_integer from Memory at suite_ptr with 16
    Let tests_failed be proc read_integer from Memory at suite_ptr with 24

    proc print_string with "========================================\n"
    proc print_string with "Test Suite: "
    proc print_string with suite_name
    proc print_string with "\n"
    proc print_string with "========================================\n"
    proc print_string with "Tests Run: "
    proc print_integer with tests_run
    proc print_string with "\n"
    proc print_string with "Tests Passed: "
    proc print_integer with tests_passed
    proc print_string with "\n"
    proc print_string with "Tests Failed: "
    proc print_integer with tests_failed
    proc print_string with "\n"

    Note: Print failed test details
    If tests_failed is greater than 0:
        proc print_string with "\nFailed Tests:\n"
        proc print_string with "----------------------------------------\n"

        Let results_list be proc read_integer from Memory at suite_ptr with 32
        Let result_count be proc get_list_size from ListCore with results_list
        Let index be 0

        While index is less than result_count:
            Let result_ptr be proc get_from_list from ListCore with results_list, index
            Let passed be proc read_integer from Memory at result_ptr with 8

            If passed is equal to 0:
                Let test_name be proc read_string from Memory at result_ptr with 0
                Let error_msg be proc read_string from Memory at result_ptr with 16
                Let expected be proc read_string from Memory at result_ptr with 24
                Let actual be proc read_string from Memory at result_ptr with 32

                proc print_string with "  FAIL: "
                proc print_string with test_name
                proc print_string with "\n"
                proc print_string with "    Error: "
                proc print_string with error_msg
                proc print_string with "\n"
                proc print_string with "    Expected: "
                proc print_string with expected
                proc print_string with "\n"
                proc print_string with "    Actual: "
                proc print_string with actual
                proc print_string with "\n\n"
            End If

            Set index to index + 1
        End While
    End If

    proc print_string with "========================================\n\n"

    Return tests_failed
End Process

Note: ================================================================
Note: Lexer Tests
Note: ================================================================

Process called "test_lexer_keywords" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test lexer recognition of all Verilog keywords.
    @End Reasoning

    Let lexer_ptr be proc create_lexer from VerilogLexer

    Note: Test module keywords
    Let tokens be proc scan from VerilogLexer with lexer_ptr, "module endmodule"
    Let token_count be proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: module keywords count", "3", proc integer_to_string with token_count  Note: module, endmodule, EOF

    Note: Test data type keywords
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "wire reg integer real time"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: data type keywords count", "6", proc integer_to_string with token_count

    Note: Test behavioral keywords
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "always initial assign"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: behavioral keywords count", "4", proc integer_to_string with token_count

    Note: Test control flow keywords
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "if else case endcase begin end"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: control flow keywords count", "7", proc integer_to_string with token_count

    Note: Test edge detection keywords
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "posedge negedge"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: edge detection keywords count", "3", proc integer_to_string with token_count

    Return 1
End Process

Process called "test_lexer_operators" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test lexer recognition of all Verilog operators.
    @End Reasoning

    Let lexer_ptr be proc create_lexer from VerilogLexer

    Note: Test arithmetic operators
    Let tokens be proc scan from VerilogLexer with lexer_ptr, "+ - * / % **"
    Let token_count be proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: arithmetic operators count", "7", proc integer_to_string with token_count

    Note: Test bitwise operators
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "& | ^ ~ ~& ~| ~^ ^~"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: bitwise operators count", "9", proc integer_to_string with token_count

    Note: Test logical operators
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "&& || !"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: logical operators count", "4", proc integer_to_string with token_count

    Note: Test comparison operators
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "== != < > <= >= === !=="
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: comparison operators count", "9", proc integer_to_string with token_count

    Note: Test shift operators
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "<< >> <<< >>>"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: shift operators count", "5", proc integer_to_string with token_count

    Note: Test assignment operators
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "= <="
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: assignment operators count", "3", proc integer_to_string with token_count

    Return 1
End Process

Process called "test_lexer_numbers" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test lexer recognition of all Verilog number formats.
    @End Reasoning

    Let lexer_ptr be proc create_lexer from VerilogLexer

    Note: Test decimal numbers
    Let tokens be proc scan from VerilogLexer with lexer_ptr, "42 123 0"
    Let token_count be proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: decimal numbers count", "4", proc integer_to_string with token_count

    Note: Test binary numbers
    Set tokens to proc scan from VerilogLexer with lexer_ptr, "8'b10101010 4'b1111"
    Set token_count to proc get_list_size from ListCore with tokens
    proc assert_equals from suite_ptr, "Lexer: binary numbers count", "3", proc integer_to_string with token_count

    Note: Test hexadecimal numbers
