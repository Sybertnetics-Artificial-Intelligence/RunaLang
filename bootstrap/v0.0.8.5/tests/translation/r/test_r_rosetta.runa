    Let hir be proc translate_program from RToHIR with translator, r_ast

    Note: HIR → R
    Let generator be proc create_generator from HIRToR
    proc generate_module from HIRToR with generator, hir
    Let output be proc get_output from HIRToR with generator

    Note: Verify output contains assignment
    Let has_assignment be proc string_contains from StringCore with output, "<-"
    proc assert_true from result, has_assignment, "Round-trip: simple assignment"

    Return 1
End Process

