Note: Helper Functions
Note: ============================================================================

Process called "string_from_literal" takes literal as Integer returns Integer:
    Note: Create string from C string literal

    Return literal
End Process

Process called "string_contains" takes haystack as Integer, needle as Integer returns Integer:
    Note: Check if haystack contains needle

    @Reasoning:
    Simple substring search for verifying generated code contains
    expected elements (operators, keywords, etc.).
    @End Reasoning

    If haystack is equal to 0:
        Return 0
    End If

    If needle is equal to 0:
        Return 0
    End If

    Let haystack_len be proc string_length from StringCore with haystack
    Let needle_len be proc string_length from StringCore with needle

    If needle_len is greater than haystack_len:
        Return 0
    End If

    Let i be 0
    Let max_i be haystack_len minus needle_len

    While i is less than or equal to max_i:
        Let matches be 1
        Let j be 0

        While j is less than needle_len:
            Let h_char be proc memory_get_byte from Layout with haystack, i plus j
            Let n_char be proc memory_get_byte from Layout with needle, j

            If h_char is not equal to n_char:
                Set matches to 0
                Set j to needle_len  Note: Break inner loop
            End If

            Set j to j plus 1
        End While

        If matches is equal to 1:
            Return 1  Note: Found
        End If

        Set i to i plus 1
    End While

    Return 0  Note: Not found
End Process
