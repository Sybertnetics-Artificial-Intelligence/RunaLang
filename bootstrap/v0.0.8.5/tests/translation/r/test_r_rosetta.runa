Note:
R Translation Test Suite

Comprehensive tests for R language translation through the Translation system.
Tests all components: lexer, parser, R→HIR translator, HIR→R backend, and
round-trip translation.

Test Coverage:
- Lexer: All R tokens and operators
- Parser: All R syntax constructs
- R→HIR: Semantic translation correctness
- HIR→R: Idiomatic code generation
- Round-trip: R → HIR → R preservation
- Edge cases: R-specific features and corner cases

Target: 100+ tests covering all R features

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/r/r_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/r/r_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/r/r_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/r/r_emitter.runa
- compiler/middle/gungnir/hir/translation/backends/r/hir_to_r.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/r/r_lexer.runa" as RLexer
Import "compiler/middle/gungnir/hir/translation/frontends/r/r_parser.runa" as RParser
Import "compiler/middle/gungnir/hir/translation/frontends/r/r_to_hir.runa" as RToHIR
Import "compiler/middle/gungnir/hir/translation/backends/r/r_emitter.runa" as REmitter
Import "compiler/middle/gungnir/hir/translation/backends/r/hir_to_r.runa" as HIRToR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test Framework
Note: ============================================================================

Type called "TestResult":
    passed as Integer           Note: Number of tests passed
    failed as Integer           Note: Number of tests failed
    total as Integer            Note: Total number of tests
End Type

Process called "create_test_result" returns Integer:
    Note: Create test result tracker

    Let result_size be 24  Note: TestResult: 3 fields × 8 bytes
    Let result be proc allocate from Layout with result_size

    If result is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with result, 0, 0   Note: passed = 0
    proc memory_set_int64 from Layout with result, 8, 0   Note: failed = 0
    proc memory_set_int64 from Layout with result, 16, 0  Note: total = 0

    Return result
End Process

Process called "assert_true" takes result as Integer, condition as Integer, test_name as Integer returns Integer:
    Note: Assert that condition is true

    Let total be proc memory_get_int64 from Layout with result, 16
    proc memory_set_int64 from Layout with result, 16, total plus 1

    If condition is equal to 1:
        Let passed be proc memory_get_int64 from Layout with result, 0
        proc memory_set_int64 from Layout with result, 0, passed plus 1
        Return 1
    Otherwise:
        Let failed be proc memory_get_int64 from Layout with result, 8
        proc memory_set_int64 from Layout with result, 8, failed plus 1
        Note: In real implementation, would print: "FAILED: " + test_name
        Return 0
    End If
End Process

Process called "assert_equal" takes result as Integer, expected as Integer, actual as Integer, test_name as Integer returns Integer:
    Note: Assert that expected equals actual

    Let are_equal be proc strings_equal from StringCore with expected, actual

    Return proc assert_true from result, are_equal, test_name
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_lexer_keywords" takes result as Integer returns Integer:
    Note: Test R keyword tokenization

    @Reasoning:
    R has specific keywords like function, if, while, for, repeat, etc.
    Verify that all keywords are correctly tokenized.
    @End Reasoning

    Note: Test function keyword
    Let source1 be proc string_from_literal from "function"
    Let lexer1 be proc create_lexer from RLexer with source1
    Let tokens1 be proc tokenize from RLexer with lexer1
    Let token1 be proc memory_get_int64 from Layout with tokens1, 0
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc assert_true from result, type1 is equal to RLexer.TOKEN_FUNCTION, "Lexer: function keyword"

    Note: Test if keyword
    Let source2 be proc string_from_literal from "if"
    Let lexer2 be proc create_lexer from RLexer with source2
    Let tokens2 be proc tokenize from RLexer with lexer2
    Let token2 be proc memory_get_int64 from Layout with tokens2, 0
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc assert_true from result, type2 is equal to RLexer.TOKEN_IF, "Lexer: if keyword"

    Note: Test while keyword
    Let source3 be proc string_from_literal from "while"
    Let lexer3 be proc create_lexer from RLexer with source3
    Let tokens3 be proc tokenize from RLexer with lexer3
    Let token3 be proc memory_get_int64 from Layout with tokens3, 0
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc assert_true from result, type3 is equal to RLexer.TOKEN_WHILE, "Lexer: while keyword"

    Note: Test for keyword
    Let source4 be proc string_from_literal from "for"
    Let lexer4 be proc create_lexer from RLexer with source4
    Let tokens4 be proc tokenize from RLexer with lexer4
    Let token4 be proc memory_get_int64 from Layout with tokens4, 0
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc assert_true from result, type4 is equal to RLexer.TOKEN_FOR, "Lexer: for keyword"

    Note: Test repeat keyword
    Let source5 be proc string_from_literal from "repeat"
    Let lexer5 be proc create_lexer from RLexer with source5
    Let tokens5 be proc tokenize from RLexer with lexer5
    Let token5 be proc memory_get_int64 from Layout with tokens5, 0
    Let type5 be proc memory_get_int64 from Layout with token5, 0
    proc assert_true from result, type5 is equal to RLexer.TOKEN_REPEAT, "Lexer: repeat keyword"

    Return 1
End Process

Process called "test_lexer_assignment_operators" takes result as Integer returns Integer:
    Note: Test R assignment operator tokenization

    @Reasoning:
    R has unique assignment operators: <-, <<-, ->, ->>, =
    These are critical to R syntax and must be correctly tokenized.
    @End Reasoning

    Note: Test <- (left assignment)
    Let source1 be proc string_from_literal from "<-"
    Let lexer1 be proc create_lexer from RLexer with source1
    Let tokens1 be proc tokenize from RLexer with lexer1
    Let token1 be proc memory_get_int64 from Layout with tokens1, 0
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc assert_true from result, type1 is equal to RLexer.TOKEN_LEFT_ASSIGN, "Lexer: <- operator"

    Note: Test <<- (left super assignment)
    Let source2 be proc string_from_literal from "<<-"
    Let lexer2 be proc create_lexer from RLexer with source2
    Let tokens2 be proc tokenize from RLexer with lexer2
    Let token2 be proc memory_get_int64 from Layout with tokens2, 0
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc assert_true from result, type2 is equal to RLexer.TOKEN_LEFT_SUPER_ASSIGN, "Lexer: <<- operator"

    Note: Test -> (right assignment)
    Let source3 be proc string_from_literal from "->"
    Let lexer3 be proc create_lexer from RLexer with source3
    Let tokens3 be proc tokenize from RLexer with lexer3
    Let token3 be proc memory_get_int64 from Layout with tokens3, 0
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc assert_true from result, type3 is equal to RLexer.TOKEN_RIGHT_ASSIGN, "Lexer: -> operator"

    Note: Test ->> (right super assignment)
    Let source4 be proc string_from_literal from "->>"
    Let lexer4 be proc create_lexer from RLexer with source4
    Let tokens4 be proc tokenize from RLexer with lexer4
    Let token4 be proc memory_get_int64 from Layout with tokens4, 0
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc assert_true from result, type4 is equal to RLexer.TOKEN_RIGHT_SUPER_ASSIGN, "Lexer: ->> operator"

    Return 1
End Process

