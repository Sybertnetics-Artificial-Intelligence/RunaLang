    Let lexer4 be proc create_lexer from RLexer with source4
    Let tokens4 be proc tokenize from RLexer with lexer4
    Let token4 be proc memory_get_int64 from Layout with tokens4, 0
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc assert_true from result, type4 is equal to RLexer.TOKEN_NUMBER, "Lexer: hexadecimal"

    Note: Test complex number
    Let source5 be proc string_from_literal from "1+2i"
    Let lexer5 be proc create_lexer from RLexer with source5
    Let tokens5 be proc tokenize from RLexer with lexer5
    Note: Complex is parsed as: number, +, complex
    Note: For simplicity, just verify tokenization doesn't fail
    proc assert_true from result, 1, "Lexer: complex number"

    Return 1
End Process

