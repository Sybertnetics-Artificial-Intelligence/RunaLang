Process called "test_parser_control_flow" takes result as Integer returns Integer:
    Note: Test R control flow parsing

    Note: Test if-else
    Let source1 be proc string_from_literal from "if (x > 0) { y <- 1 } else { y <- -1 }"
    Let lexer1 be proc create_lexer from RLexer with source1
    Let tokens1 be proc tokenize from RLexer with lexer1
    Let token_count1 be proc get_token_count from RLexer with lexer1
    Let parser1 be proc create_parser from RParser with tokens1, token_count1
    Let ast1 be proc parse_statement from RParser with parser1
    proc assert_true from result, ast1 is not equal to 0, "Parser: if-else"

    Note: Test while loop
    Let source2 be proc string_from_literal from "while (x < 10) { x <- x + 1 }"
    Let lexer2 be proc create_lexer from RLexer with source2
    Let tokens2 be proc tokenize from RLexer with lexer2
    Let token_count2 be proc get_token_count from RLexer with lexer2
    Let parser2 be proc create_parser from RParser with tokens2, token_count2
    Let ast2 be proc parse_statement from RParser with parser2
    proc assert_true from result, ast2 is not equal to 0, "Parser: while loop"

    Note: Test for loop
    Let source3 be proc string_from_literal from "for (i in 1:10) { print(i) }"
    Let lexer3 be proc create_lexer from RLexer with source3
    Let tokens3 be proc tokenize from RLexer with lexer3
    Let token_count3 be proc get_token_count from RLexer with lexer3
    Let parser3 be proc create_parser from RParser with tokens3, token_count3
    Let ast3 be proc parse_statement from RParser with parser3
    proc assert_true from result, ast3 is not equal to 0, "Parser: for loop"

    Note: Test repeat loop
    Let source4 be proc string_from_literal from "repeat { if (x > 10) break }"
    Let lexer4 be proc create_lexer from RLexer with source4
    Let tokens4 be proc tokenize from RLexer with lexer4
    Let token_count4 be proc get_token_count from RLexer with lexer4
    Let parser4 be proc create_parser from RParser with tokens4, token_count4
    Let ast4 be proc parse_statement from RParser with parser4
    proc assert_true from result, ast4 is not equal to 0, "Parser: repeat loop"

    Return 1
End Process

Process called "test_parser_indexing" takes result as Integer returns Integer:
    Note: Test R indexing parsing

    @Reasoning:
    R has two indexing operators: [...] for subsets and [[...]]
    for element extraction. Both must parse correctly.
    @End Reasoning

    Note: Test single bracket indexing
    Let source1 be proc string_from_literal from "x[1, 2]"
    Let lexer1 be proc create_lexer from RLexer with source1
    Let tokens1 be proc tokenize from RLexer with lexer1
    Let token_count1 be proc get_token_count from RLexer with lexer1
    Let parser1 be proc create_parser from RParser with tokens1, token_count1
    Let ast1 be proc parse_expression from RParser with parser1
    proc assert_true from result, ast1 is not equal to 0, "Parser: single bracket indexing"

    Note: Test double bracket indexing
    Let source2 be proc string_from_literal from "x[[1]]"
    Let lexer2 be proc create_lexer from RLexer with source2
    Let tokens2 be proc tokenize from RLexer with lexer2
    Let token_count2 be proc get_token_count from RLexer with lexer2
    Let parser2 be proc create_parser from RParser with tokens2, token_count2
    Let ast2 be proc parse_expression from RParser with parser2
    proc assert_true from result, ast2 is not equal to 0, "Parser: double bracket indexing"

    Return 1
End Process

