    Let hir be proc translate_expression from RToHIR with translator, r_ast

    Let generator be proc create_generator from HIRToR
    proc generate_expression from HIRToR with generator, hir
    Let output be proc get_output from HIRToR with generator

    Note: Verify operators preserved
    Let has_plus be proc string_contains from StringCore with output, "+"
    Let has_times be proc string_contains from StringCore with output, "*"
    Let success be has_plus is equal to 1
    If has_times is equal to 1:
        Set success to success
    End If

    proc assert_true from result, success, "Round-trip: vectorized operations"

    Return 1
End Process

