Process called "test_roundtrip_simple_function" returns Integer:
    Note: Test Go → HIR → Go round-trip translation

    Let source be "package main\nfunc add(a int, b int) int { return a + b }"
    Let length be 56

    Note: Parse original Go code
    Let lexer be proc create_go_lexer from Lexer with source, length
    Let parser be proc create_go_parser from Parser with lexer
    Let ast be proc parse_program from Parser with parser

    If ast is equal to 0:
        Return proc test_failed from "test_roundtrip_simple_function", "Failed to parse"
    End If

    Note: Translate to HIR
    Let hir be proc translate_go_to_hir from GoToHir with ast

    If hir is equal to 0:
        Return proc test_failed from "test_roundtrip_simple_function", "Go→HIR failed"
    End If

    Note: Generate back to Go
    Let go_code be proc generate_hir_to_go from HirToGo with hir

    If go_code is equal to 0:
        Return proc test_failed from "test_roundtrip_simple_function", "HIR→Go failed"
    End If

    proc destroy_go_parser from Parser with parser
    proc destroy_go_lexer from Lexer with lexer

    Return proc test_passed from "test_roundtrip_simple_function"
End Process

Process called "test_roundtrip_struct_and_methods" returns Integer:
    Note: Test Go → HIR → Go round-trip with structs and methods

    Let source be "package main\ntype Point struct { x int }\nfunc (p Point) GetX() int { return p.x }"
    Let length be 88

    Let lexer be proc create_go_lexer from Lexer with source, length
    Let parser be proc create_go_parser from Parser with lexer
    Let ast be proc parse_program from Parser with parser

    If ast is equal to 0:
