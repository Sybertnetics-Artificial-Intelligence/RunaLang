Note:
Go Tests - Comprehensive test suite for Go language translation

This file provides comprehensive tests for the complete Go translation pipeline:
- Lexer tests (tokenization)
- Parser tests (AST generation)
- Go→HIR translation tests
- HIR→Go generation tests
- Round-trip translation tests (Go → HIR → Go)

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/go/go_lexer.runa
- compiler/middle/gungnir/hir/translation/frontends/go/go_parser.runa
- compiler/middle/gungnir/hir/translation/frontends/go/go_to_hir.runa
- compiler/middle/gungnir/hir/translation/backends/go/go_emitter.runa
- compiler/middle/gungnir/hir/translation/backends/go/hir_to_go.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/go/go_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/go/go_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/go/go_to_hir.runa" as GoToHir
Import "compiler/middle/gungnir/hir/translation/backends/go/go_emitter.runa" as Emitter
Import "compiler/middle/gungnir/hir/translation/backends/go/hir_to_go.runa" as HirToGo
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test Utilities
Note: ============================================================================

Process called "test_passed" takes test_name as Integer returns Integer:
    Note: Report test passed

    proc print_string from test_name
    proc print_string from ": PASSED"
    proc print_newline

    Return 1
End Process

Process called "test_failed" takes test_name as Integer, reason as Integer returns Integer:
    Note: Report test failed

    proc print_string from test_name
    proc print_string from ": FAILED - "
    proc print_string from reason
    proc print_newline

    Return 0
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_go_lexer_keywords" returns Integer:
    Note: Test Go keyword tokenization

    Let source be "package func var const type struct interface"
    Let length be 48

    Let lexer be proc create_go_lexer from Lexer with source, length

    If lexer is equal to 0:
        Return proc test_failed from "test_go_lexer_keywords", "Failed to create lexer"
    End If

    Note: Test package keyword
    Let token1 be proc next_token from Lexer with lexer
    If token1 is not equal to TOKEN_PACKAGE from Lexer:
        Return proc test_failed from "test_go_lexer_keywords", "Expected TOKEN_PACKAGE"
    End If

    Note: Test func keyword
    Let token2 be proc next_token from Lexer with lexer
    If token2 is not equal to TOKEN_FUNC from Lexer:
        Return proc test_failed from "test_go_lexer_keywords", "Expected TOKEN_FUNC"
    End If

    Note: Test var keyword
    Let token3 be proc next_token from Lexer with lexer
    If token3 is not equal to TOKEN_VAR from Lexer:
        Return proc test_failed from "test_go_lexer_keywords", "Expected TOKEN_VAR"
    End If

    Note: Test const keyword
    Let token4 be proc next_token from Lexer with lexer
    If token4 is not equal to TOKEN_CONST from Lexer:
        Return proc test_failed from "test_go_lexer_keywords", "Expected TOKEN_CONST"
    End If

    Note: Test type keyword
    Let token5 be proc next_token from Lexer with lexer
    If token5 is not equal to TOKEN_TYPE from Lexer:
        Return proc test_failed from "test_go_lexer_keywords", "Expected TOKEN_TYPE"
    End If

    Note: Test struct keyword
    Let token6 be proc next_token from Lexer with lexer
    If token6 is not equal to TOKEN_STRUCT from Lexer:
        Return proc test_failed from "test_go_lexer_keywords", "Expected TOKEN_STRUCT"
    End If

    Note: Test interface keyword
    Let token7 be proc next_token from Lexer with lexer
    If token7 is not equal to TOKEN_INTERFACE from Lexer:
        Return proc test_failed from "test_go_lexer_keywords", "Expected TOKEN_INTERFACE"
    End If

    proc destroy_go_lexer from Lexer with lexer

    Return proc test_passed from "test_go_lexer_keywords"
End Process

Process called "test_go_lexer_operators" returns Integer:
    Note: Test Go operator tokenization

    Let source be ":= <- ... &^ == != <= >= ++ --"
    Let length be 33

    Let lexer be proc create_go_lexer from Lexer with source, length

    If lexer is equal to 0:
        Return proc test_failed from "test_go_lexer_operators", "Failed to create lexer"
    End If

    Note: Test := operator
    Let token1 be proc next_token from Lexer with lexer
    If token1 is not equal to TOKEN_COLON_EQUAL from Lexer:
        Return proc test_failed from "test_go_lexer_operators", "Expected TOKEN_COLON_EQUAL"
    End If

    Note: Test <- operator
    Let token2 be proc next_token from Lexer with lexer
    If token2 is not equal to TOKEN_ARROW from Lexer:
        Return proc test_failed from "test_go_lexer_operators", "Expected TOKEN_ARROW"
    End If

    Note: Test ... operator
    Let token3 be proc next_token from Lexer with lexer
    If token3 is not equal to TOKEN_ELLIPSIS from Lexer:
        Return proc test_failed from "test_go_lexer_operators", "Expected TOKEN_ELLIPSIS"
    End If

    Note: Test &^ operator
    Let token4 be proc next_token from Lexer with lexer
    If token4 is not equal to TOKEN_AMP_CARET from Lexer:
        Return proc test_failed from "test_go_lexer_operators", "Expected TOKEN_AMP_CARET"
    End If

    Note: Test == operator
    Let token5 be proc next_token from Lexer with lexer
    If token5 is not equal to TOKEN_EQUAL_EQUAL from Lexer:
        Return proc test_failed from "test_go_lexer_operators", "Expected TOKEN_EQUAL_EQUAL"
    End If

    Note: Test != operator
    Let token6 be proc next_token from Lexer with lexer
    If token6 is not equal to TOKEN_BANG_EQUAL from Lexer:
        Return proc test_failed from "test_go_lexer_operators", "Expected TOKEN_BANG_EQUAL"
    End If

    proc destroy_go_lexer from Lexer with lexer

    Return proc test_passed from "test_go_lexer_operators"
End Process

Process called "test_go_lexer_literals" returns Integer:
    Note: Test Go literal tokenization

    Let source be "42 3.14 'a' \"hello\" `raw string`"
    Let length be 37

    Let lexer be proc create_go_lexer from Lexer with source, length

    If lexer is equal to 0:
        Return proc test_failed from "test_go_lexer_literals", "Failed to create lexer"
    End If

    Note: Test integer literal
    Let token1 be proc next_token from Lexer with lexer
    If token1 is not equal to TOKEN_INTEGER from Lexer:
        Return proc test_failed from "test_go_lexer_literals", "Expected TOKEN_INTEGER"
    End If

    Note: Test float literal
    Let token2 be proc next_token from Lexer with lexer
    If token2 is not equal to TOKEN_FLOAT from Lexer:
        Return proc test_failed from "test_go_lexer_literals", "Expected TOKEN_FLOAT"
    End If

    Note: Test rune literal
    Let token3 be proc next_token from Lexer with lexer
    If token3 is not equal to TOKEN_RUNE from Lexer:
        Return proc test_failed from "test_go_lexer_literals", "Expected TOKEN_RUNE"
    End If

    Note: Test string literal
    Let token4 be proc next_token from Lexer with lexer
    If token4 is not equal to TOKEN_STRING from Lexer:
        Return proc test_failed from "test_go_lexer_literals", "Expected TOKEN_STRING"
    End If

    Note: Test raw string literal
    Let token5 be proc next_token from Lexer with lexer
    If token5 is not equal to TOKEN_STRING from Lexer:
        Return proc test_failed from "test_go_lexer_literals", "Expected TOKEN_STRING (raw)"
    End If

    proc destroy_go_lexer from Lexer with lexer

    Return proc test_passed from "test_go_lexer_literals"
End Process

Note: ============================================================================
Note: Parser Tests
Note: ============================================================================

Process called "test_go_parser_function" returns Integer:
    Note: Test parsing Go function declaration

    Let source be "package main\nfunc add(a int, b int) int { return a + b }"
    Let length be 56

    Let lexer be proc create_go_lexer from Lexer with source, length

    If lexer is equal to 0:
        Return proc test_failed from "test_go_parser_function", "Failed to create lexer"
    End If

    Let parser be proc create_go_parser from Parser with lexer

    If parser is equal to 0:
        Return proc test_failed from "test_go_parser_function", "Failed to create parser"
    End If

    Let ast be proc parse_program from Parser with parser

    If ast is equal to 0:
        Return proc test_failed from "test_go_parser_function", "Failed to parse program"
    End If

    Note: Verify AST node type
    Let node_type be proc memory_get_int64 from Layout with ast, 0

    If node_type is not equal to GO_PROGRAM from Parser:
        Return proc test_failed from "test_go_parser_function", "Expected GO_PROGRAM node"
    End If

    proc destroy_go_parser from Parser with parser
    proc destroy_go_lexer from Lexer with lexer

    Return proc test_passed from "test_go_parser_function"
End Process

