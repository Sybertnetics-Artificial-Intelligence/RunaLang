Note:
TCP socket layer verification probe.

Exercises the real code paths of the TCP runtime subsystem without
requiring any external network: the IPv4 dotted-decimal parser, the
sockaddr_in builder, live socket creation, and a full loopback
connect/send/receive/close round-trip against a local listener the test
harness starts on 127.0.0.1.

Exit code encodes which stage failed (0 = all stages passed):
  10 = parse_ipv4_literal("127.0.0.1") did not yield the expected
       network-order word (0x0100007F).
  11 = parse_ipv4_literal rejected a valid literal (returned -1).
  12 = parse_ipv4_literal accepted a malformed literal (should be -1).
  13 = tcp_socket_create failed to produce a valid fd.
  14 = build_sockaddr_in returned a null pointer.
  20 = tcp_connect to the loopback listener failed.
  21 = tcp_send sent fewer bytes than the payload length.
  22 = tcp_receive_all returned no data.
:End Note

Import "runtime/io/network/tcp_sockets.runa" as TCP
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory

Process called "main" returns Integer:
    Note: --- Stage 1: IPv4 literal parser ---
    Let ip be "127.0.0.1"
    Let parsed be proc parse_ipv4_literal from TCP with ip
    If parsed is equal to -1:
        Return 11
    End If
    Note: 127.0.0.1 network-order word: byte0=127, byte3=1 -> 0x0100007F.
    Let expected be 1 multiplied by 16777216
    Set expected to expected plus 127
    If parsed is not equal to expected:
        Return 10
    End If

    Note: A malformed literal must be rejected.
    Let bad be "999.1.1.1"
    Let bad_parsed be proc parse_ipv4_literal from TCP with bad
    If bad_parsed is not equal to -1:
        Return 12
    End If

    Note: --- Stage 2: live socket + sockaddr construction ---
    Let fd be proc tcp_socket_create from TCP
    If fd is less than 0:
        Return 13
    End If
    Let sa be proc build_sockaddr_in from TCP with parsed, 9
    If sa is equal to 0:
        proc tcp_close from TCP with fd
        Return 14
    End If
    proc tcp_close from TCP with fd

    Note: --- Stage 3: loopback connect/send/receive round-trip ---
    Note: The harness runs a listener on 127.0.0.1:port_arg that echoes a
    Note: fixed banner. We connect, send a request, and read the reply.
    Let host be "127.0.0.1"
    Let port be 38555
    Let timeout be 5
    Let conn be proc tcp_connect from TCP with host, port, timeout
    If conn is less than 0:
        Return 20
    End If

    Let payload be "PING\n"
    Let payload_len be proc string_length from StringCore with payload
    Let sent be proc tcp_send from TCP with conn, payload
    If sent is less than payload_len:
        proc tcp_close from TCP with conn
        Return 21
    End If

    Let reply be proc tcp_receive_all from TCP with conn, timeout
    proc tcp_close from TCP with conn
    If reply is equal to 0:
        Return 22
    End If
    Let reply_len be proc string_length from StringCore with reply
    If reply_len is equal to 0:
        Return 22
    End If

    Return 0
End Process
