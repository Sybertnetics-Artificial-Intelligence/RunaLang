Note:
Test Utilities - Self-contained assertion library for Runa unit tests.
No imports - uses only built-in functions available in the bootstrap compiler.
:End Note

Note: TEST_RESULTS_SIZE = 48 (6 fields * 8 bytes)

Note: TestResults layout:
Note:   offset 0:  total (8 bytes)
Note:   offset 8:  passed (8 bytes)
Note:   offset 16: failed (8 bytes)
Note:   offset 24: skipped (8 bytes)
Note:   offset 32: current_suite name pointer (8 bytes)
Note:   offset 40: is_verbose (8 bytes)

Process called "create_test_results" returns Integer:
    Let results be allocate(48)
    If results is 0:
        Return 0
    End If
    __store(results, 0, 0)
    __store(results, 8, 0)
    __store(results, 16, 0)
    __store(results, 24, 0)
    __store(results, 32, 0)
    __store(results, 40, 0)
    Return results
End Process

Process called "begin_suite" that takes results as Integer, suite_name as String returns Integer:
    If results is 0:
        Return 0
    End If
    __store(results, 32, suite_name)
    Display ""
    Display "========================================"
    Display "  SUITE: "
    Display suite_name
    Display "========================================"
    Return 1
End Process

Process called "assert_equal" that takes results as Integer, test_name as String, actual as Integer, expected as Integer returns Integer:
    If results is 0:
        Return 0
    End If
    Let total be __load(results, 0)
    __store(results, 0, total plus 1)
    If actual is equal to expected:
        Let passed be __load(results, 8)
        __store(results, 8, passed plus 1)
        Display "  PASS: "
        Display test_name
        Return 1
    Otherwise:
        Let failed be __load(results, 16)
        __store(results, 16, failed plus 1)
        Display "  FAIL: "
        Display test_name
        Display "    Expected: "
        Display expected
        Display "    Actual:   "
        Display actual
        Return 0
    End If
End Process

Process called "assert_not_equal" that takes results as Integer, test_name as String, actual as Integer, not_expected as Integer returns Integer:
    If results is 0:
        Return 0
    End If
    Let total be __load(results, 0)
    __store(results, 0, total plus 1)
    If actual is not equal to not_expected:
        Let passed be __load(results, 8)
        __store(results, 8, passed plus 1)
        Display "  PASS: "
        Display test_name
        Return 1
    Otherwise:
        Let failed be __load(results, 16)
        __store(results, 16, failed plus 1)
        Display "  FAIL: "
        Display test_name
        Display "    Should not be: "
        Display not_expected
        Return 0
    End If
End Process

Process called "assert_not_null" that takes results as Integer, test_name as String, value as Integer returns Integer:
    If results is 0:
        Return 0
    End If
    Let total be __load(results, 0)
    __store(results, 0, total plus 1)
    If value is not 0:
        Let passed be __load(results, 8)
        __store(results, 8, passed plus 1)
        Display "  PASS: "
        Display test_name
        Return 1
    Otherwise:
        Let failed be __load(results, 16)
        __store(results, 16, failed plus 1)
        Display "  FAIL: "
        Display test_name
        Display "    Expected non-null, got 0"
        Return 0
    End If
End Process

Process called "assert_null" that takes results as Integer, test_name as String, value as Integer returns Integer:
    If results is 0:
        Return 0
    End If
    Let total be __load(results, 0)
    __store(results, 0, total plus 1)
    If value is 0:
        Let passed be __load(results, 8)
        __store(results, 8, passed plus 1)
        Display "  PASS: "
        Display test_name
        Return 1
    Otherwise:
        Let failed be __load(results, 16)
        __store(results, 16, failed plus 1)
        Display "  FAIL: "
        Display test_name
        Display "    Expected null, got non-zero"
        Return 0
    End If
End Process

Process called "assert_true" that takes results as Integer, test_name as String, condition as Integer returns Integer:
    Return proc assert_not_null with results, test_name, condition
End Process

Process called "assert_greater_than" that takes results as Integer, test_name as String, actual as Integer, threshold as Integer returns Integer:
    If results is 0:
        Return 0
    End If
    Let total be __load(results, 0)
    __store(results, 0, total plus 1)
    If actual is greater than threshold:
        Let passed be __load(results, 8)
        __store(results, 8, passed plus 1)
        Display "  PASS: "
        Display test_name
        Return 1
    Otherwise:
        Let failed be __load(results, 16)
        __store(results, 16, failed plus 1)
        Display "  FAIL: "
        Display test_name
        Display "    Expected greater than: "
        Display threshold
        Display "    Actual: "
        Display actual
        Return 0
    End If
End Process

Process called "assert_less_than" that takes results as Integer, test_name as String, actual as Integer, threshold as Integer returns Integer:
    If results is 0:
        Return 0
    End If
    Let total be __load(results, 0)
    __store(results, 0, total plus 1)
    If actual is less than threshold:
        Let passed be __load(results, 8)
        __store(results, 8, passed plus 1)
        Display "  PASS: "
        Display test_name
        Return 1
    Otherwise:
        Let failed be __load(results, 16)
        __store(results, 16, failed plus 1)
        Display "  FAIL: "
        Display test_name
        Display "    Expected less than: "
        Display threshold
        Display "    Actual: "
        Display actual
        Return 0
    End If
End Process

Process called "record_pass" that takes results as Integer, test_name as String returns Integer:
    If results is 0:
        Return 0
    End If
    Let total be __load(results, 0)
    Let passed be __load(results, 8)
    __store(results, 0, total plus 1)
    __store(results, 8, passed plus 1)
    Display "  PASS: "
    Display test_name
    Return 1
End Process

Process called "record_fail" that takes results as Integer, test_name as String, message as String returns Integer:
    If results is 0:
        Return 0
    End If
    Let total be __load(results, 0)
    Let failed be __load(results, 16)
    __store(results, 0, total plus 1)
    __store(results, 16, failed plus 1)
    Display "  FAIL: "
    Display test_name
    If message is not 0:
        Display "    Reason: "
        Display message
    End If
    Return 0
End Process

Process called "record_skip" that takes results as Integer, test_name as String, reason as String returns Integer:
    If results is 0:
        Return 0
    End If
    Let total be __load(results, 0)
    Let skipped be __load(results, 24)
    __store(results, 0, total plus 1)
    __store(results, 24, skipped plus 1)
    Display "  SKIP: "
    Display test_name
    Return 1
End Process

Process called "print_summary" that takes results as Integer returns Integer:
    If results is 0:
        Display "ERROR: No test results"
        Return 0
    End If
    Let total be __load(results, 0)
    Let passed be __load(results, 8)
    Let failed be __load(results, 16)
    Let skipped be __load(results, 24)
    Display ""
    Display "----------------------------------------"
    Display "  RESULTS:"
    Display "    Total:   "
    Display total
    Display "    Passed:  "
    Display passed
    Display "    Failed:  "
    Display failed
    Display "    Skipped: "
    Display skipped
    Display "----------------------------------------"
    If failed is 0:
        Display "  ALL TESTS PASSED"
    Otherwise:
        Display "  SOME TESTS FAILED"
    End If
    Display ""
    Return 1
End Process

Process called "all_passed" that takes results as Integer returns Integer:
    If results is 0:
        Return 0
    End If
    Let failed be __load(results, 16)
    If failed is 0:
        Return 1
    End If
    Return 0
End Process

Process called "get_failed" that takes results as Integer returns Integer:
    If results is 0:
        Return 0
    End If
    Return __load(results, 16)
End Process

Process called "destroy_test_results" that takes results as Integer returns Integer:
    If results is 0:
        Return 0
    End If
    deallocate(results)
    Return 1
End Process
