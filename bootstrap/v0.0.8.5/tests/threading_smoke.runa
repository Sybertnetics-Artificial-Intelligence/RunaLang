Note: Verify counter = 4000 by checking final_val mod 65536
Import "compiler/frontend/primitives/assembly/threading.runa" as Threading
Import "compiler/frontend/primitives/core/atomic_core.runa" as Atomic
Import "compiler/frontend/primitives/assembly/syscall.runa" as Syscall
Import "compiler/frontend/primitives/memory/layout.runa" as Memory

Let GLOBAL_COUNTER_PTR be 0

Process called "worker" takes arg as Integer returns Integer:
    Let i be 0
    While i is less than 1000:
        proc atomic_increment from Atomic with GLOBAL_COUNTER_PTR
        Set i to i plus 1
    End While
    proc platform_thread_exit from Threading with 0
    Return 0
End Process

Process called "main" returns Integer:
    Let counter_ptr be proc syscall_mmap from Syscall with 0, 4, 3, 34, -1, 0
    If counter_ptr is less than 0:
        Return 91
    End If
    proc memory_set_int32 from Memory with counter_ptr, 0, 0
    Set GLOBAL_COUNTER_PTR to counter_ptr

    Let t1 be proc platform_thread_create from Threading with $worker, 0
    Let t2 be proc platform_thread_create from Threading with $worker, 0
    Let t3 be proc platform_thread_create from Threading with $worker, 0
    Let t4 be proc platform_thread_create from Threading with $worker, 0

    proc platform_thread_sleep from Threading with 500000

    Let final_val be proc memory_get_int32 from Memory with counter_ptr, 0
    Note: Return divisor results to encode 4000: high byte = final/256, low byte = final%256
    Note: 4000 = 0x0FA0, high byte=15, low byte=160. We return 4000 directly truncated.
    Note: To CONFIRM it's exactly 4000, we subtract 4000 and return 200 if equal.
    If final_val is equal to 4000:
        Return 200
    End If
    If final_val is less than 4000:
        Return 100
    End If
    Note: greater than 4000 — atomic race in test framework
    Return 150
End Process
