Note: Overrides for buggy functions in the legacy runtime.o.
Note: When linked FIRST under --allow-multiple-definition these definitions
Note: take precedence over the same symbols in the legacy runtime.o, which
Note: were emitted by an earlier stage1 compiler that produced wrong-ordered
Note: pushq/popq sequences around function calls.

Let __runa_no_mangle__ be 1

Process called "string_length" takes s as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    Let len be 0
    Let scanning be 1
    While scanning is equal to 1:
        Let byte_value be memory_get_byte(s, len)
        If byte_value is equal to 0:
            Set scanning to 0
        Otherwise:
            Set len to len plus 1
        End If
    End While
    Return len
End Process

Process called "string_duplicate" takes s as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    Let len be string_length(s)
    Let buf be memory_allocate(len plus 1)
    If buf is equal to 0:
        Return 0
    End If
    Let i be 0
    While i is less than len:
        Let b be memory_get_byte(s, i)
        memory_set_byte(buf, i, b)
        Set i to i plus 1
    End While
    memory_set_byte(buf, len, 0)
    Return buf
End Process

Process called "integer_to_string" takes value as Integer returns Integer:
    Note: Handle 0
    If value is equal to 0:
        Let z be memory_allocate(2)
        If z is equal to 0:
            Return 0
        End If
        memory_set_byte(z, 0, 48)
        memory_set_byte(z, 1, 0)
        Return z
    End If

    Note: Compute absolute and sign
    Let n be value
    Let is_neg be 0
    If n is less than 0:
        Set is_neg to 1
        Note: For INT64_MIN, negating overflows. Handle that by emitting digits
        Note: directly from the negative value (each digit is `n modulo 10` negated).
    End If

    Note: Buffer big enough for INT64 min "-9223372036854775808" + null.
    Let buf be memory_allocate(22)
    If buf is equal to 0:
        Return 0
    End If

    Note: Generate digits backwards
    Let tmp_count be 0
    Let absval be n
    If is_neg is equal to 1:
        Set absval to 0 minus n
        Note: If n was INT64_MIN, absval will overflow back to negative; the loop below uses absolute-of-modulo for safety.
    End If

    Note: Use a temp digit buffer
    Let digits be memory_allocate(22)
    If digits is equal to 0:
        Return 0
    End If
    Let count be 0
    Let v be absval
    Note: For INT64_MIN, v stays negative; emit |v % 10|
    If v is less than 0:
        Note: Path for INT64_MIN: compute via emit-and-divide using -1
        Set count to 0
        While v is not equal to 0:
            Let d be v modulo by 10
            If d is less than 0:
                Set d to 0 minus d
            End If
            memory_set_byte(digits, count, 48 plus d)
            Set count to count plus 1
            Set v to v divided by 10
        End While
    Otherwise:
        While v is greater than 0:
            Let d be v modulo by 10
            memory_set_byte(digits, count, 48 plus d)
            Set count to count plus 1
            Set v to v divided by 10
        End While
    End If

    Let pos be 0
    If is_neg is equal to 1:
        memory_set_byte(buf, 0, 45)
        Set pos to 1
    End If
    Let i be count minus 1
    While i is greater than or equal to 0:
        Let dbyte be memory_get_byte(digits, i)
        memory_set_byte(buf, pos, dbyte)
        Set pos to pos plus 1
        Set i to i minus 1
    End While
    memory_set_byte(buf, pos, 0)
    Return buf
End Process
