{
  "name": "sybertnetics-monorepo",
  "version": "1.0.0",
  "projects": {
    "runa": {
      "path": "./runa",
      "type": "python",
      "description": "Universal programming language"
    },
    "hermod": {
      "path": "./hermod",
      "type": "typescript",
      "description": "AI-powered IDE"
    },
    "shared": {
      "path": "./shared",
      "type": "typescript",
      "description": "Shared utilities"
    },
    "tools": {
      "path": "./tools",
      "type": "typescript",
      "description": "Development tools"
    }
  },
  "build": {
    "order": ["shared", "tools", "runa", "hermod"],
    "parallel": true
  },
  "test": {
    "parallel": true,
    "coverage": true
  }
} 