Note:
aott/analysis/call_graph/builder.runa
Call Graph Construction Module for AOTT Runtime Analysis

This module provides comprehensive call graph construction for the Runa AOTT system including:
- Static call graph construction from bytecode
- Dynamic call graph updates from runtime profiling
- Virtual call resolution and tracking
- Indirect call target prediction
- Call frequency and edge weight tracking
- Context-sensitive call graph variants
- Interprocedural edge classification
- Call chain depth analysis
- Recursive call pattern detection
- Call graph pruning and simplification
- Cross-module call tracking
- Native function call integration
- Speculative call edge insertion
- Call graph serialization and caching
- Incremental call graph updates
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: CALL GRAPH DATA STRUCTURES
Note: =====================================================================

Type called "CallGraph":
    nodes as Dictionary[String, CallNode]
    edges as List[CallEdge]
    entry_points as List[String]
    call_sites as Dictionary[String, List[CallSite]]
    indirect_calls as List[IndirectCall]
    virtual_calls as List[VirtualCall]
    profile_data as Dictionary[String, ProfileInfo]
    is_context_sensitive as Boolean

Type called "CallNode":
    function_id as String
    function_name as String
    module_path as String
    is_native as Boolean
    is_virtual as Boolean
    is_recursive as Boolean
    callers as List[String]
    callees as List[String]
    execution_count as Integer
    tier_level as Integer

Type called "CallEdge":
    caller_id as String
    callee_id as String
    call_site_id as String
    edge_type as String
    frequency as Integer
    is_speculative as Boolean
    confidence as Float
    inline_candidate as Boolean

Type called "CallSite":
    site_id as String
    function_id as String
    bytecode_offset as Integer
    call_type as String
    target_function as String
    is_polymorphic as Boolean
    receiver_types as List[String]

Type called "IndirectCall":
    call_site as CallSite
    possible_targets as List[String]
    target_probabilities as Dictionary[String, Float]
    resolution_strategy as String

Type called "VirtualCall":
    call_site as CallSite
    receiver_type as String
    method_signature as String
    resolved_targets as Dictionary[String, String]
    is_devirtualized as Boolean

Type called "ProfileInfo":
    execution_count as Integer
    total_time_ns as Integer
    self_time_ns as Integer
    is_hot as Boolean
    tier_promotion_ready as Boolean

