Let value be 42

Match value:
    Case 0:
        Display "Zero"
    Case 42:
        Display "The answer"
    Case x:
        Display x with message "Unknown value:"

Let status be "active"

Match status:
    Case "active":
        Display "System is running"
    Case "inactive":
        Display "System is stopped"
    Case _:
        Display "Unknown status"