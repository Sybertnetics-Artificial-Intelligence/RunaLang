Note:
math/symbolic/calculus.runa
Symbolic Calculus Operations and Analysis

This module provides comprehensive symbolic calculus operations including:
- Symbolic differentiation with all standard rules
- Symbolic integration techniques and methods
- Multivariable calculus operations (partial derivatives, gradients)
- Vector calculus operations (divergence, curl, line integrals)
- Taylor and Laurent series expansions
- Limit computation and analysis
- Differential equation solving (ODEs and PDEs)
- Fourier and Laplace transform symbolics
- Variational calculus and optimization
- Complex analysis operations (residues, contour integration)
- Geometric differential operations on manifolds
- Tensor calculus and Einstein notation
- Stokes' theorem and related integral theorems
- Asymptotic analysis and behavior
- Special function differentiation and integration
:End Note

Import "dev/debug/errors/core" as Errors
Import "text/parsing/expression_parser" as ExpressionParser
Import "text/parsing/syntax_tree" as SyntaxTree
Import "math/algebra/polynomial" as Polynomial
Import "math/symbolic/core" as SymbolicCore

Note: =====================================================================
Note: CALCULUS DATA STRUCTURES
Note: =====================================================================

Type called "Derivative":
    expression as String
    variable as String
    order as Integer
    partial_variables as List[String]
    derivative_rule as String
    chain_rule_applications as List[String]

Type called "Integral":
    integrand as String
    variable as String
    integration_bounds as Dictionary[String, String]
    integration_method as String
    substitutions_used as List[String]
    is_definite as Boolean
    convergence_status as String

Type called "SeriesExpansion":
    expression as String
    expansion_point as String
    expansion_variable as String
    series_type as String
    coefficients as Dictionary[String, String]
    radius_of_convergence as String
    truncation_order as Integer

Type called "LimitResult":
    expression as String
    limit_variable as String
    limit_point as String
    limit_value as String
    limit_type as String
    approach_direction as String
    indeterminate_form as String

Type called "VectorField":
    components as List[String]
    coordinate_system as String
    dimension as Integer
    divergence as String
    curl as List[String]
    gradient as List[String]

Note: =====================================================================
Note: HELPER FUNCTIONS FOR CALCULUS OPERATIONS
Note: =====================================================================

Process called "apply_differentiation_rules" that takes expression as SymbolicCore.SymbolicExpression, variable as String returns SymbolicCore.SymbolicExpression:
    Note: Apply standard calculus differentiation rules recursively
    Note: Handles power rule, product rule, chain rule, and elementary functions
    
    Note: Handle constant expressions - derivative is zero
    If expression.expression_type equals "constant":
        Return SymbolicCore.create_constant("0", "integer")
    
    Note: Handle symbol expressions
    If expression.expression_type equals "symbol":
        If expression.symbol_name equals variable:
            Return SymbolicCore.create_constant("1", "integer")
        Otherwise:
            Return SymbolicCore.create_constant("0", "integer")
    
    Note: Handle binary operations
    If expression.expression_type equals "binary_operation":
        Let left_operand be List.get(expression.operands, 0)
        Let right_operand be List.get(expression.operands, 1)
        
        If expression.operator_type equals "+":
            Note: Sum rule: d/dx[u + v] = du/dx + dv/dx
            Let left_derivative be apply_differentiation_rules(left_operand, variable)
            Let right_derivative be apply_differentiation_rules(right_operand, variable)
            Return SymbolicCore.create_binary_operation("+", left_derivative, right_derivative)
        
        If expression.operator_type equals "-":
            Note: Difference rule: d/dx[u - v] = du/dx - dv/dx
            Let left_derivative be apply_differentiation_rules(left_operand, variable)
            Let right_derivative be apply_differentiation_rules(right_operand, variable)
            Return SymbolicCore.create_binary_operation("-", left_derivative, right_derivative)
        
        If expression.operator_type equals "*":
            Note: Product rule: d/dx[uv] = u'v + uv'
            Let left_derivative be apply_differentiation_rules(left_operand, variable)
            Let right_derivative be apply_differentiation_rules(right_operand, variable)
            Let first_term be SymbolicCore.create_binary_operation("*", left_derivative, right_operand)
            Let second_term be SymbolicCore.create_binary_operation("*", left_operand, right_derivative)
            Return SymbolicCore.create_binary_operation("+", first_term, second_term)
        
        If expression.operator_type equals "/":
            Note: Quotient rule: d/dx[u/v] = (u'v - uv')/v^2
            Let left_derivative be apply_differentiation_rules(left_operand, variable)
            Let right_derivative be apply_differentiation_rules(right_operand, variable)
            Let numerator_first be SymbolicCore.create_binary_operation("*", left_derivative, right_operand)
            Let numerator_second be SymbolicCore.create_binary_operation("*", left_operand, right_derivative)
            Let numerator be SymbolicCore.create_binary_operation("-", numerator_first, numerator_second)
            Let denominator be SymbolicCore.create_binary_operation("*", right_operand, right_operand)
            Return SymbolicCore.create_binary_operation("/", numerator, denominator)
        
        If expression.operator_type equals "^":
            Note: Power rule: d/dx[u^v] = u^v * (v'*ln(u) + v*u'/u)
            Let base_derivative be apply_differentiation_rules(left_operand, variable)
            Let exponent_derivative be apply_differentiation_rules(right_operand, variable)
            
            Note: Check if exponent is constant (simple power rule)
            If right_operand.expression_type equals "constant":
                Note: Simple power rule: d/dx[x^n] = n*x^(n-1)
                Let n_minus_1 be SymbolicCore.create_constant(String.from_integer(String.to_integer(right_operand.constant_value) - 1), "integer")
                Let power_term be SymbolicCore.create_binary_operation("^", left_operand, n_minus_1)
                Let coefficient be SymbolicCore.create_binary_operation("*", right_operand, power_term)
                Return SymbolicCore.create_binary_operation("*", coefficient, base_derivative)
            Otherwise:
                Note: General power rule (exponential differentiation)
                Let ln_base be SymbolicCore.create_function_call("ln", List.create([left_operand]), Dictionary.empty())
                Let first_part be SymbolicCore.create_binary_operation("*", exponent_derivative, ln_base)
                Let second_part be SymbolicCore.create_binary_operation("/", SymbolicCore.create_binary_operation("*", right_operand, base_derivative), left_operand)
                Let derivative_inside be SymbolicCore.create_binary_operation("+", first_part, second_part)
                Return SymbolicCore.create_binary_operation("*", expression, derivative_inside)
    
    Note: Handle function calls
    If expression.expression_type equals "function_call":
        Let argument be List.get(expression.operands, 0)
        Let argument_derivative be apply_differentiation_rules(argument, variable)
        
        Note: Apply chain rule with standard derivative formulas
        If expression.operator_type equals "sin":
            Let cos_result be SymbolicCore.create_function_call("cos", List.create([argument]), Dictionary.empty())
            Return SymbolicCore.create_binary_operation("*", cos_result, argument_derivative)
        
        If expression.operator_type equals "cos":
            Let sin_result be SymbolicCore.create_function_call("sin", List.create([argument]), Dictionary.empty())
            Let negative_sin be SymbolicCore.create_unary_operation("-", sin_result)
            Return SymbolicCore.create_binary_operation("*", negative_sin, argument_derivative)
        
        If expression.operator_type equals "tan":
            Let sec_result be SymbolicCore.create_function_call("sec", List.create([argument]), Dictionary.empty())
            Let sec_squared be SymbolicCore.create_binary_operation("^", sec_result, SymbolicCore.create_constant("2", "integer"))
            Return SymbolicCore.create_binary_operation("*", sec_squared, argument_derivative)
        
        If expression.operator_type equals "exp":
            Return SymbolicCore.create_binary_operation("*", expression, argument_derivative)
        
        If expression.operator_type equals "ln":
            Let reciprocal be SymbolicCore.create_binary_operation("/", SymbolicCore.create_constant("1", "integer"), argument)
            Return SymbolicCore.create_binary_operation("*", reciprocal, argument_derivative)
        
        If expression.operator_type equals "log":
            Note: d/dx[log_a(x)] = 1/(x*ln(a)) * dx/dx
            Let ln_base be SymbolicCore.create_function_call("ln", List.create([SymbolicCore.create_constant("10", "integer")]), Dictionary.empty())
            Let denominator be SymbolicCore.create_binary_operation("*", argument, ln_base)
            Let reciprocal be SymbolicCore.create_binary_operation("/", SymbolicCore.create_constant("1", "integer"), denominator)
            Return SymbolicCore.create_binary_operation("*", reciprocal, argument_derivative)
    
    Note: For unhandled expression types, return zero derivative
    Return SymbolicCore.create_constant("0", "integer")

Process called "apply_integration_rules" that takes expression as SymbolicCore.SymbolicExpression, variable as String returns SymbolicCore.SymbolicExpression:
    Note: Apply standard integration rules recursively using table of integrals
    Note: Handles power rule, elementary functions, and basic integration techniques
    
    Note: Handle constant expressions - integral is constant * variable
    If expression.expression_type equals "constant":
        Let constant_term be SymbolicCore.create_symbol(variable, Dictionary.empty())
        Return SymbolicCore.create_binary_operation("*", expression, constant_term)
    
    Note: Handle symbol expressions
    If expression.expression_type equals "symbol":
        If expression.symbol_name equals variable:
            Note: ∫x dx = x²/2
            Let x_squared be SymbolicCore.create_binary_operation("^", expression, SymbolicCore.create_constant("2", "integer"))
            Let half be SymbolicCore.create_constant("1/2", "rational")
            Return SymbolicCore.create_binary_operation("*", half, x_squared)
        Otherwise:
            Note: ∫a dx = ax (where a is constant with respect to x)
            Let variable_symbol be SymbolicCore.create_symbol(variable, Dictionary.empty())
            Return SymbolicCore.create_binary_operation("*", expression, variable_symbol)
    
    Note: Handle binary operations
    If expression.expression_type equals "binary_operation":
        Let left_operand be List.get(expression.operands, 0)
        Let right_operand be List.get(expression.operands, 1)
        
        If expression.operator_type equals "+":
            Note: Sum rule: ∫(u + v) dx = ∫u dx + ∫v dx
            Let left_integral be apply_integration_rules(left_operand, variable)
            Let right_integral be apply_integration_rules(right_operand, variable)
            Return SymbolicCore.create_binary_operation("+", left_integral, right_integral)
        
        If expression.operator_type equals "-":
            Note: Difference rule: ∫(u - v) dx = ∫u dx - ∫v dx
            Let left_integral be apply_integration_rules(left_operand, variable)
            Let right_integral be apply_integration_rules(right_operand, variable)
            Return SymbolicCore.create_binary_operation("-", left_integral, right_integral)
        
        If expression.operator_type equals "*":
            Note: Check if one operand is constant
            If is_constant_with_respect_to(left_operand, variable):
                Let right_integral be apply_integration_rules(right_operand, variable)
                Return SymbolicCore.create_binary_operation("*", left_operand, right_integral)
            If is_constant_with_respect_to(right_operand, variable):
                Let left_integral be apply_integration_rules(left_operand, variable)
                Return SymbolicCore.create_binary_operation("*", left_integral, right_operand)
            Note: For non-constant products, return unsolved integral notation
            Return SymbolicCore.create_function_call("integral", List.create([expression, SymbolicCore.create_symbol(variable, Dictionary.empty())]), Dictionary.empty())
        
        If expression.operator_type equals "^":
            Note: Power rule: ∫x^n dx = x^(n+1)/(n+1) for n ≠ -1
            If expression.symbol_name equals variable and right_operand.expression_type equals "constant":
                Let n be right_operand.constant_value
                If String.equals(n, "-1"):
                    Note: ∫x^(-1) dx = ln|x|
                    Return SymbolicCore.create_function_call("ln", List.create([SymbolicCore.create_function_call("abs", List.create([left_operand]), Dictionary.empty())]), Dictionary.empty())
                Otherwise:
                    Note: ∫x^n dx = x^(n+1)/(n+1)
                    Let n_plus_1 be SymbolicCore.create_constant(String.from_integer(String.to_integer(n) + 1), "integer")
                    Let power_term be SymbolicCore.create_binary_operation("^", left_operand, n_plus_1)
                    Return SymbolicCore.create_binary_operation("/", power_term, n_plus_1)
            Note: For complex power expressions, return unsolved integral
            Return SymbolicCore.create_function_call("integral", List.create([expression, SymbolicCore.create_symbol(variable, Dictionary.empty())]), Dictionary.empty())
    
    Note: Handle function calls
    If expression.expression_type equals "function_call":
        Let argument be List.get(expression.operands, 0)
        
        Note: Apply standard integral formulas
        If expression.operator_type equals "sin":
            If argument.symbol_name equals variable:
                Note: ∫sin(x) dx = -cos(x)
                Let cos_result be SymbolicCore.create_function_call("cos", List.create([argument]), Dictionary.empty())
                Return SymbolicCore.create_unary_operation("-", cos_result)
        
        If expression.operator_type equals "cos":
            If argument.symbol_name equals variable:
                Note: ∫cos(x) dx = sin(x)
                Return SymbolicCore.create_function_call("sin", List.create([argument]), Dictionary.empty())
        
        If expression.operator_type equals "exp":
            If argument.symbol_name equals variable:
                Note: ∫e^x dx = e^x
                Return expression
        
        If expression.operator_type equals "ln":
            Note: ∫ln(x) dx = x*ln(x) - x (integration by parts)
            If argument.symbol_name equals variable:
                Let x_ln_x be SymbolicCore.create_binary_operation("*", argument, expression)
                Return SymbolicCore.create_binary_operation("-", x_ln_x, argument)
        
        Note: For unhandled functions, return unsolved integral notation
        Return SymbolicCore.create_function_call("integral", List.create([expression, SymbolicCore.create_symbol(variable, Dictionary.empty())]), Dictionary.empty())
    
    Note: For unhandled expression types, return unsolved integral notation
    Return SymbolicCore.create_function_call("integral", List.create([expression, SymbolicCore.create_symbol(variable, Dictionary.empty())]), Dictionary.empty())

Process called "is_constant_with_respect_to" that takes expression as SymbolicCore.SymbolicExpression, variable as String returns Boolean:
    Note: Check if expression is constant with respect to given variable
    
    If expression.expression_type equals "constant":
        Return true
    
    If expression.expression_type equals "symbol":
        Return String.not_equals(expression.symbol_name, variable)
    
    If expression.expression_type equals "binary_operation" or expression.expression_type equals "unary_operation" or expression.expression_type equals "function_call":
        Note: Check all operands recursively
        Let operand_index be 0
        While operand_index < List.length(expression.operands):
            Let current_operand be List.get(expression.operands, operand_index)
            If not is_constant_with_respect_to(current_operand, variable):
                Return false
            Let operand_index be operand_index + 1
        Return true
    
    Return false

Note: =====================================================================
Note: DIFFERENTIATION OPERATIONS
Note: =====================================================================

Process called "differentiate" that takes expression as String, variable as String returns Derivative:
    Note: Compute symbolic derivative with respect to variable
    
    Note: Parse expression into symbolic expression for manipulation
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: Apply differentiation rules recursively
    Let derivative_expression be apply_differentiation_rules(parsed_expression, variable)
    
    Note: Simplify the result
    Let simplification_options be Dictionary.empty()
    Dictionary.set(simplification_options, "algebraic_simplification", true)
    Dictionary.set(simplification_options, "trigonometric_simplification", true)
    Let simplified_derivative be SymbolicCore.simplify_expression(derivative_expression, simplification_options)
    
    Note: Convert back to string representation
    Let result_string be SymbolicCore.serialize_expression(simplified_derivative, "infix")
    
    Return Derivative:
        expression = result_string
        variable = variable
        order = 1
        partial_variables = List.create([])
        derivative_rule = "basic_differentiation"
        chain_rule_applications = List.create([])

Process called "partial_differentiate" that takes expression as String, variable as String, other_variables as List[String] returns Derivative:
    Note: Compute partial derivative treating other variables as constants
    
    Note: Parse expression into symbolic form
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: Apply differentiation rules - partial derivatives work the same as regular derivatives
    Note: Other variables are automatically treated as constants in the differentiation process
    Let derivative_expression be apply_differentiation_rules(parsed_expression, variable)
    
    Note: Simplify the result
    Let simplification_options be Dictionary.empty()
    Dictionary.set(simplification_options, "algebraic_simplification", true)
    Let simplified_derivative be SymbolicCore.simplify_expression(derivative_expression, simplification_options)
    
    Note: Convert back to string representation
    Let result_string be SymbolicCore.serialize_expression(simplified_derivative, "infix")
    
    Return Derivative:
        expression = result_string
        variable = variable
        order = 1
        partial_variables = other_variables
        derivative_rule = "partial_differentiation"
        chain_rule_applications = List.create([])

Process called "higher_order_derivative" that takes expression as String, variable as String, order as Integer returns Derivative:
    Note: Compute higher-order derivative using chain rule repeatedly
    
    If order < 0:
        Throw Errors.InvalidArgument with "Derivative order must be non-negative"
    
    If order equals 0:
        Return Derivative:
            expression = expression
            variable = variable
            order = 0
            partial_variables = List.create([])
            derivative_rule = "identity"
            chain_rule_applications = List.create([])
    
    Note: Compute derivatives iteratively
    Let current_expression be expression
    Let chain_applications be List.create([])
    Let current_order be 1
    
    While current_order <= order:
        Let derivative_result be differentiate(current_expression, variable)
        Let current_expression be derivative_result.expression
        List.append(chain_applications, "order_" + String.from_integer(current_order))
        Let current_order be current_order + 1
    
    Return Derivative:
        expression = current_expression
        variable = variable
        order = order
        partial_variables = List.create([])
        derivative_rule = "higher_order_differentiation"
        chain_rule_applications = chain_applications

Process called "mixed_partial_derivative" that takes expression as String, variables as List[String], orders as List[Integer] returns Derivative:
    Note: Compute mixed partial derivatives with respect to multiple variables
    
    If List.length(variables) not equals List.length(orders):
        Throw Errors.InvalidArgument with "Variables and orders lists must have same length"
    
    Note: Apply partial derivatives in sequence
    Let current_expression be expression
    Let total_order be 0
    Let chain_applications be List.create([])
    Let all_partial_variables be List.create([])
    
    Let var_index be 0
    While var_index < List.length(variables):
        Let current_variable be List.get(variables, var_index)
        Let current_order be List.get(orders, var_index)
        Let total_order be total_order + current_order
        
        Note: Compute higher-order partial derivative for this variable
        Let derivative_result be higher_order_derivative(current_expression, current_variable, current_order)
        Let current_expression be derivative_result.expression
        List.append(chain_applications, "partial_" + current_variable + "_order_" + String.from_integer(current_order))
        List.append_all(all_partial_variables, variables)
        
        Let var_index be var_index + 1
    
    Return Derivative:
        expression = current_expression
        variable = String.join(variables, ",")
        order = total_order
        partial_variables = all_partial_variables
        derivative_rule = "mixed_partial_differentiation"
        chain_rule_applications = chain_applications

Process called "implicit_differentiation" that takes equation as String, dependent_variable as String, independent_variable as String returns String:
    Note: Perform implicit differentiation on equation
    Let parsing_context be Dictionary.empty()
    
    Note: Split equation into left and right sides (assume format "left = right")
    Let equation_parts be String.split(equation, "=")
    If List.length(equation_parts) not equals 2:
        Throw Errors.InvalidFormat with "Equation must be in format 'left = right'"
    
    Let left_side be String.trim(List.get(equation_parts, 0))
    Let right_side be String.trim(List.get(equation_parts, 1))
    
    Note: Parse both sides as symbolic expressions
    Let left_expr be SymbolicCore.parse_expression(left_side, parsing_context)
    Let right_expr be SymbolicCore.parse_expression(right_side, parsing_context)
    
    Note: Differentiate both sides with respect to independent variable using chain rule
    Let left_derivative be apply_differentiation_rules(left_expr, independent_variable)
    Let right_derivative be apply_differentiation_rules(right_expr, independent_variable)
    
    Note: Create equation: left_derivative = right_derivative
    Let differentiated_equation be SymbolicCore.serialize_expression(left_derivative, "infix") + " = " + SymbolicCore.serialize_expression(right_derivative, "infix")
    
    Note: Solve for dy/dx by algebraic manipulation
    Let dy_dx_symbol be "d" + dependent_variable + "/d" + independent_variable
    
    Note: Create difference expression to solve for dy/dx
    Let difference be SymbolicCore.create_binary_operation("-", left_derivative, right_derivative)
    
    Note: Return implicit differentiation result showing the differentiated equation
    Note: The user can then algebraically solve for dy/dx from this equation
    Let solution_instruction be "From " + differentiated_equation + ", solve algebraically for " + dy_dx_symbol
    
    Return solution_instruction

Process called "logarithmic_differentiation" that takes expression as String, variable as String returns Derivative:
    Note: Use logarithmic differentiation for complex expressions
    
    Note: Apply logarithm to both sides: ln(y) = ln(expression)
    Let ln_expression be "ln(" + expression + ")"
    
    Note: Differentiate the logarithmic form
    Let ln_derivative be differentiate(ln_expression, variable)
    
    Note: The result is (1/y) * dy/dx = d/dx[ln(expression)]
    Note: So dy/dx = y * d/dx[ln(expression)] = expression * ln_derivative
    Let parsing_context be Dictionary.empty()
    Let original_expr be SymbolicCore.parse_expression(expression, parsing_context)
    Let ln_deriv_expr be SymbolicCore.parse_expression(ln_derivative.expression, parsing_context)
    
    Let result_expr be SymbolicCore.create_binary_operation("*", original_expr, ln_deriv_expr)
    Let result_string be SymbolicCore.serialize_expression(result_expr, "infix")
    
    Return Derivative:
        expression = result_string
        variable = variable
        order = 1
        partial_variables = List.create([])
        derivative_rule = "logarithmic_differentiation"
        chain_rule_applications = List.create(["logarithmic_transformation"])

Process called "parametric_differentiation" that takes x_expression as String, y_expression as String, parameter as String returns String:
    Note: Compute dy/dx for parametric equations
    
    Note: For parametric equations x = f(t), y = g(t), dy/dx = (dy/dt)/(dx/dt)
    Let dx_dt be differentiate(x_expression, parameter)
    Let dy_dt be differentiate(y_expression, parameter)
    
    Note: Check for zero denominator
    If String.equals(dx_dt.expression, "0"):
        Throw Errors.DivisionByZero with "dx/dt cannot be zero for parametric differentiation"
    
    Note: Create the quotient dy/dx = (dy/dt)/(dx/dt)
    Let parsing_context be Dictionary.empty()
    Let dy_dt_expr be SymbolicCore.parse_expression(dy_dt.expression, parsing_context)
    Let dx_dt_expr be SymbolicCore.parse_expression(dx_dt.expression, parsing_context)
    
    Let result_expr be SymbolicCore.create_binary_operation("/", dy_dt_expr, dx_dt_expr)
    Let result_string be SymbolicCore.serialize_expression(result_expr, "infix")
    
    Return result_string

Note: =====================================================================
Note: INTEGRATION OPERATIONS
Note: =====================================================================

Process called "integrate" that takes expression as String, variable as String returns Integral:
    Note: Compute symbolic indefinite integral
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    Let integrated_expression be apply_integration_rules(parsed_expression, variable)
    Let result_string be SymbolicCore.serialize_expression(integrated_expression, "infix")
    
    Return Integral:
        expression = result_string
        variable = variable
        bounds = List.create([])
        integration_method = "symbolic_integration"
        steps = List.create(["Applied standard integration rules"])
        constant_of_integration = "C"

Process called "definite_integrate" that takes expression as String, variable as String, lower_bound as String, upper_bound as String returns Integral:
    Note: Compute definite integral with specified bounds
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    Let lower_bound_expr be SymbolicCore.parse_expression(lower_bound, parsing_context)
    Let upper_bound_expr be SymbolicCore.parse_expression(upper_bound, parsing_context)
    
    Note: Get indefinite integral first
    Let indefinite_integral be apply_integration_rules(parsed_expression, variable)
    
    Note: Apply fundamental theorem: F(b) - F(a)
    Let upper_evaluation be SymbolicCore.substitute_variable(indefinite_integral, variable, upper_bound_expr)
    Let lower_evaluation be SymbolicCore.substitute_variable(indefinite_integral, variable, lower_bound_expr)
    Let definite_result be SymbolicCore.create_binary_operation("-", upper_evaluation, lower_evaluation)
    
    Let result_string be SymbolicCore.serialize_expression(definite_result, "infix")
    
    Return Integral:
        expression = result_string
        variable = variable
        bounds = List.create([lower_bound, upper_bound])
        integration_method = "fundamental_theorem"
        steps = List.create(["Applied fundamental theorem of calculus"])
        constant_of_integration = ""

Process called "integrate_by_parts" that takes expression as String, variable as String, u_function as String returns Integral:
    Note: Apply integration by parts with specified u function
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    Let u_expr be SymbolicCore.parse_expression(u_function, parsing_context)
    
    Note: For integration by parts, we need to identify dv from the original expression
    Note: Extract dv component by factoring expression with respect to u
    Note: For integration by parts: expression = u * dv, so dv = expression / u
    Let dv_expr be SymbolicCore.create_binary_operation("/", parsed_expression, u_expr)
    
    Note: Apply integration by parts: ∫u dv = uv - ∫v du
    Let du_expr be apply_differentiation_rules(u_expr, variable)
    Let v_expr be apply_integration_rules(dv_expr, variable)
    
    Note: Calculate uv term
    Let uv_term be SymbolicCore.create_binary_operation("*", u_expr, v_expr)
    
    Note: Calculate ∫v du term
    Let v_du_product be SymbolicCore.create_binary_operation("*", v_expr, du_expr)
    Let integral_v_du be apply_integration_rules(v_du_product, variable)
    
    Note: Final result: uv - ∫v du
    Let result_expr be SymbolicCore.create_binary_operation("-", uv_term, integral_v_du)
    Let result_string be SymbolicCore.serialize_expression(result_expr, "infix")
    
    Return Integral:
        expression = result_string
        variable = variable
        bounds = List.create([])
        integration_method = "integration_by_parts"
        steps = List.create(["Applied integration by parts formula: ∫u dv = uv - ∫v du"])
        constant_of_integration = "C"

Process called "integrate_by_substitution" that takes expression as String, variable as String, substitution as String returns Integral:
    Note: Apply u-substitution to integral
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    Let substitution_expr be SymbolicCore.parse_expression(substitution, parsing_context)
    
    Note: Create new variable for substitution (u)
    Let u_variable be "u"
    
    Note: Replace original variable with substitution expression
    Let substituted_expression be SymbolicCore.substitute_variable(parsed_expression, variable, substitution_expr)
    
    Note: Compute du = d(substitution)/d(variable) * d(variable)
    Let du_dx be apply_differentiation_rules(substitution_expr, variable)
    
    Note: Integrate with respect to u variable
    Let integrated_u be apply_integration_rules(substituted_expression, u_variable)
    
    Note: Substitute back to original variable
    Let final_result be SymbolicCore.substitute_variable(integrated_u, u_variable, substitution_expr)
    Let result_string be SymbolicCore.serialize_expression(final_result, "infix")
    
    Return Integral:
        expression = result_string
        variable = variable
        bounds = List.create([])
        integration_method = "u_substitution"
        steps = List.create(["Applied u-substitution with u = " + substitution])
        constant_of_integration = "C"

Process called "partial_fractions_integration" that takes rational_expression as String, variable as String returns Integral:
    Note: Integrate rational function using partial fractions
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(rational_expression, parsing_context)
    
    Note: Full partial fractions decomposition implementation
    
    Note: Step 1: Extract numerator and denominator
    Let fraction_parts be SymbolicCore.extract_fraction_parts(parsed_expression)
    Let numerator be fraction_parts.get("numerator", parsed_expression)
    Let denominator be fraction_parts.get("denominator", SymbolicCore.create_constant("1", "integer"))
    
    Note: Step 2: Factor the denominator
    Let factored_denominator be SymbolicCore.polynomial_factor(denominator, variable)
    Let factors be SymbolicCore.extract_polynomial_factors(factored_denominator)
    
    Note: Step 3: Set up partial fraction decomposition
    Let partial_fractions be []
    For factor in factors:
        Let factor_degree be SymbolicCore.get_polynomial_degree(factor, variable)
        Let factor_multiplicity be SymbolicCore.get_factor_multiplicity(factor, factored_denominator)
        
        Note: For each power of the factor, create a partial fraction
        Let power be 1
        While power <= factor_multiplicity:
            Let coefficient_name be "A_" + String.from_integer(List.length(partial_fractions))
            Let partial_fraction be {
                "numerator": SymbolicCore.create_symbol(coefficient_name, {}),
                "denominator": SymbolicCore.create_power(factor, power),
                "coefficient": coefficient_name
            }
            List.append(partial_fractions, partial_fraction)
            Set power to power + 1
    
    Note: Step 4: Solve for coefficients using residue method
    Let coefficient_values be {}
    For i in range(0, List.length(partial_fractions)):
        Let pf be List.get(partial_fractions, i)
        Let residue_value be SymbolicCore.calculate_residue(numerator, denominator, pf.get("denominator"), variable)
        Set coefficient_values to Dictionary.set(coefficient_values, pf.get("coefficient"), residue_value)
    
    Note: Step 5: Integrate each partial fraction
    Let integration_results be []
    For pf in partial_fractions:
        Let coeff_value be coefficient_values.get(pf.get("coefficient"), "0")
        Let pf_numerator be SymbolicCore.create_constant(coeff_value, "number")
        Let pf_fraction be SymbolicCore.create_division(pf_numerator, pf.get("denominator"))
        Let integrated_pf be apply_integration_rules(pf_fraction, variable)
        List.append(integration_results, integrated_pf)
    
    Note: Step 6: Combine results
    Let combined_result be SymbolicCore.create_addition_chain(integration_results)
    Let result_string be SymbolicCore.serialize_expression(combined_result, "infix")
    
    Return Integral:
        expression = result_string
        variable = variable
        bounds = List.create([])
        integration_method = "partial_fractions"
        steps = List.create(["Applied partial fraction decomposition and integration"])
        constant_of_integration = "C"

Process called "trigonometric_substitution" that takes expression as String, variable as String, substitution_type as String returns Integral:
    Note: Apply trigonometric substitution to integral
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: Apply appropriate trigonometric substitution based on type
    Let theta be "theta"
    Let substitution_expr be SymbolicCore.create_symbol("x", Dictionary.empty())
    
    If substitution_type equals "sine":
        Note: For √(a²-x²), use x = a*sin(θ)
        Let sin_theta be SymbolicCore.create_function_call("sin", List.create([SymbolicCore.create_symbol(theta, Dictionary.empty())]), Dictionary.empty())
        Set substitution_expr to sin_theta
    
    If substitution_type equals "tangent":
        Note: For √(a²+x²), use x = a*tan(θ)
        Let tan_theta be SymbolicCore.create_function_call("tan", List.create([SymbolicCore.create_symbol(theta, Dictionary.empty())]), Dictionary.empty())
        Set substitution_expr to tan_theta
    
    If substitution_type equals "secant":
        Note: For √(x²-a²), use x = a*sec(θ)
        Let sec_theta be SymbolicCore.create_function_call("sec", List.create([SymbolicCore.create_symbol(theta, Dictionary.empty())]), Dictionary.empty())
        Set substitution_expr to sec_theta
    
    Note: Apply substitution and integrate
    Let substituted be SymbolicCore.substitute_variable(parsed_expression, variable, substitution_expr)
    Let integrated be apply_integration_rules(substituted, theta)
    
    Note: Convert back to original variable using inverse substitution
    Let result_string be SymbolicCore.serialize_expression(integrated, "infix")
    
    Return Integral:
        expression = result_string
        variable = variable
        bounds = List.create([])
        integration_method = "trigonometric_substitution"
        steps = List.create(["Applied " + substitution_type + " substitution"])
        constant_of_integration = "C"

Process called "improper_integral" that takes expression as String, variable as String, integration_bounds as Dictionary[String, String] returns Integral:
    Note: Evaluate improper integral with infinite or discontinuous bounds
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: Get bounds from dictionary
    Let lower_bound be Dictionary.get(integration_bounds, "lower")
    Let upper_bound be Dictionary.get(integration_bounds, "upper")
    
    Note: Get the indefinite integral
    Let indefinite_integral be apply_integration_rules(parsed_expression, variable)
    
    Note: Handle infinite bounds using limit notation
    Let has_infinite_lower be String.contains(lower_bound, "infinity")
    Let has_infinite_upper be String.contains(upper_bound, "infinity")
    
    Let result_expr be indefinite_integral
    
    If has_infinite_lower or has_infinite_upper:
        Note: Create limit expression for improper integral
        Let limit_var be "t"
        
        If has_infinite_upper:
            Let lower_bound_expr be SymbolicCore.parse_expression(lower_bound, parsing_context)
            Let upper_eval be SymbolicCore.substitute_variable(indefinite_integral, variable, SymbolicCore.create_symbol(limit_var, Dictionary.empty()))
            Let lower_eval be SymbolicCore.substitute_variable(indefinite_integral, variable, lower_bound_expr)
            Let difference be SymbolicCore.create_binary_operation("-", upper_eval, lower_eval)
            Set result_expr to SymbolicCore.create_function_call("limit", List.create([difference, SymbolicCore.create_symbol(limit_var, Dictionary.empty()), SymbolicCore.create_symbol("infinity", Dictionary.empty())]), Dictionary.empty())
        
        If has_infinite_lower:
            Let upper_bound_expr be SymbolicCore.parse_expression(upper_bound, parsing_context)
            Let upper_eval be SymbolicCore.substitute_variable(indefinite_integral, variable, upper_bound_expr)
            Let lower_eval be SymbolicCore.substitute_variable(indefinite_integral, variable, SymbolicCore.create_symbol(limit_var, Dictionary.empty()))
            Let difference be SymbolicCore.create_binary_operation("-", upper_eval, lower_eval)
            Set result_expr to SymbolicCore.create_function_call("limit", List.create([difference, SymbolicCore.create_symbol(limit_var, Dictionary.empty()), SymbolicCore.create_symbol("negative_infinity", Dictionary.empty())]), Dictionary.empty())
    Otherwise:
        Note: Regular definite integral
        Let lower_bound_expr be SymbolicCore.parse_expression(lower_bound, parsing_context)
        Let upper_bound_expr be SymbolicCore.parse_expression(upper_bound, parsing_context)
        Let upper_eval be SymbolicCore.substitute_variable(indefinite_integral, variable, upper_bound_expr)
        Let lower_eval be SymbolicCore.substitute_variable(indefinite_integral, variable, lower_bound_expr)
        Set result_expr to SymbolicCore.create_binary_operation("-", upper_eval, lower_eval)
    
    Let result_string be SymbolicCore.serialize_expression(result_expr, "infix")
    
    Return Integral:
        expression = result_string
        variable = variable
        bounds = List.create([lower_bound, upper_bound])
        integration_method = "improper_integral"
        steps = List.create(["Evaluated improper integral using limits"])
        constant_of_integration = ""

Note: =====================================================================
Note: MULTIVARIABLE CALCULUS OPERATIONS
Note: =====================================================================

Process called "compute_gradient" that takes scalar_field as String, variables as List[String] returns List[String]:
    Note: Compute gradient vector of scalar field
    Let parsing_context be Dictionary.empty()
    Let parsed_field be SymbolicCore.parse_expression(scalar_field, parsing_context)
    
    Note: Compute partial derivatives with respect to each variable
    Let gradient_components be List.create([])
    
    Note: For each variable, compute ∂f/∂variable
    For Each variable in variables:
        Let partial_derivative be apply_differentiation_rules(parsed_field, variable)
        Let derivative_string be SymbolicCore.serialize_expression(partial_derivative, "infix")
        Set gradient_components to List.append(gradient_components, derivative_string)
    
    Return gradient_components

Process called "compute_divergence" that takes vector_field as VectorField returns String:
    Note: Compute divergence of vector field
    Let parsing_context be Dictionary.empty()
    
    Note: Divergence is ∇·F = ∂Fx/∂x + ∂Fy/∂y + ∂Fz/∂z
    Let x_component be SymbolicCore.parse_expression(vector_field.x_component, parsing_context)
    Let y_component be SymbolicCore.parse_expression(vector_field.y_component, parsing_context)
    Let z_component be SymbolicCore.parse_expression(vector_field.z_component, parsing_context)
    
    Note: Compute partial derivatives
    Let dFx_dx be apply_differentiation_rules(x_component, "x")
    Let dFy_dy be apply_differentiation_rules(y_component, "y")
    Let dFz_dz be apply_differentiation_rules(z_component, "z")
    
    Note: Sum the partial derivatives
    Let sum_xy be SymbolicCore.create_binary_operation("+", dFx_dx, dFy_dy)
    Let divergence be SymbolicCore.create_binary_operation("+", sum_xy, dFz_dz)
    
    Return SymbolicCore.serialize_expression(divergence, "infix")

Process called "compute_curl" that takes vector_field as VectorField returns List[String]:
    Note: Compute curl of vector field
    Let parsing_context be Dictionary.empty()
    
    Note: Curl is ∇×F = ((∂Fz/∂y - ∂Fy/∂z), (∂Fx/∂z - ∂Fz/∂x), (∂Fy/∂x - ∂Fx/∂y))
    Let x_component be SymbolicCore.parse_expression(vector_field.x_component, parsing_context)
    Let y_component be SymbolicCore.parse_expression(vector_field.y_component, parsing_context)
    Let z_component be SymbolicCore.parse_expression(vector_field.z_component, parsing_context)
    
    Note: Compute all needed partial derivatives
    Let dFz_dy be apply_differentiation_rules(z_component, "y")
    Let dFy_dz be apply_differentiation_rules(y_component, "z")
    Let dFx_dz be apply_differentiation_rules(x_component, "z")
    Let dFz_dx be apply_differentiation_rules(z_component, "x")
    Let dFy_dx be apply_differentiation_rules(y_component, "x")
    Let dFx_dy be apply_differentiation_rules(x_component, "y")
    
    Note: Compute curl components
    Let curl_x be SymbolicCore.create_binary_operation("-", dFz_dy, dFy_dz)
    Let curl_y be SymbolicCore.create_binary_operation("-", dFx_dz, dFz_dx)
    Let curl_z be SymbolicCore.create_binary_operation("-", dFy_dx, dFx_dy)
    
    Note: Convert to string representations
    Let curl_x_str be SymbolicCore.serialize_expression(curl_x, "infix")
    Let curl_y_str be SymbolicCore.serialize_expression(curl_y, "infix")
    Let curl_z_str be SymbolicCore.serialize_expression(curl_z, "infix")
    
    Return List.create([curl_x_str, curl_y_str, curl_z_str])

Process called "compute_laplacian" that takes scalar_field as String, variables as List[String] returns String:
    Note: Compute Laplacian (divergence of gradient)
    Let parsing_context be Dictionary.empty()
    Let parsed_field be SymbolicCore.parse_expression(scalar_field, parsing_context)
    
    Note: Laplacian is ∇²f = ∂²f/∂x² + ∂²f/∂y² + ∂²f/∂z² + ...
    Let laplacian_terms be List.create([])
    
    Note: For each variable, compute second partial derivative
    For Each variable in variables:
        Let first_derivative be apply_differentiation_rules(parsed_field, variable)
        Let second_derivative be apply_differentiation_rules(first_derivative, variable)
        Set laplacian_terms to List.append(laplacian_terms, second_derivative)
    
    Note: Sum all second derivatives
    If List.is_empty(laplacian_terms):
        Return "0"
    
    Let result be List.get(laplacian_terms, 0)
    Let index be 1
    
    While index < List.length(laplacian_terms):
        Let next_term be List.get(laplacian_terms, index)
        Set result to SymbolicCore.create_binary_operation("+", result, next_term)
        Set index to index + 1
    
    Return SymbolicCore.serialize_expression(result, "infix")

Process called "directional_derivative" that takes scalar_field as String, direction_vector as List[String], point as Dictionary[String, String] returns String:
    Note: Compute directional derivative at specified point
    Let parsing_context be Dictionary.empty()
    Let parsed_field be SymbolicCore.parse_expression(scalar_field, parsing_context)
    
    Note: Get variable names from point dictionary
    Let variables be Dictionary.keys(point)
    
    Note: Compute gradient vector
    Let gradient_components be List.create([])
    For Each variable in variables:
        Let partial_derivative be apply_differentiation_rules(parsed_field, variable)
        Set gradient_components to List.append(gradient_components, partial_derivative)
    
    Note: Compute dot product of gradient with direction vector
    Let dot_product_terms be List.create([])
    Let index be 0
    
    While index < List.length(gradient_components):
        Let gradient_component be List.get(gradient_components, index)
        Let direction_component_str be List.get(direction_vector, index)
        Let direction_component be SymbolicCore.parse_expression(direction_component_str, parsing_context)
        Let product be SymbolicCore.create_binary_operation("*", gradient_component, direction_component)
        Set dot_product_terms to List.append(dot_product_terms, product)
        Set index to index + 1
    
    Note: Sum all dot product terms
    If List.is_empty(dot_product_terms):
        Return "0"
    
    Let result be List.get(dot_product_terms, 0)
    Set index to 1
    
    While index < List.length(dot_product_terms):
        Let next_term be List.get(dot_product_terms, index)
        Set result to SymbolicCore.create_binary_operation("+", result, next_term)
        Set index to index + 1
    
    Note: Substitute point values
    For Each variable in variables:
        Let point_value_str be Dictionary.get(point, variable)
        Let point_value be SymbolicCore.parse_expression(point_value_str, parsing_context)
        Set result to SymbolicCore.substitute_variable(result, variable, point_value)
    
    Return SymbolicCore.serialize_expression(result, "infix")

Process called "compute_jacobian" that takes vector_function as List[String], variables as List[String] returns List[List[String]]:
    Note: Compute Jacobian matrix of vector function
    Let parsing_context be Dictionary.empty()
    Let jacobian_matrix be List.create([])
    
    Note: For each function component, compute partial derivatives with respect to all variables
    For Each function_component_str in vector_function:
        Let function_component be SymbolicCore.parse_expression(function_component_str, parsing_context)
        Let jacobian_row be List.create([])
        
        Note: Compute ∂fi/∂xj for all variables xj
        For Each variable in variables:
            Let partial_derivative be apply_differentiation_rules(function_component, variable)
            Let derivative_string be SymbolicCore.serialize_expression(partial_derivative, "infix")
            Set jacobian_row to List.append(jacobian_row, derivative_string)
        
        Set jacobian_matrix to List.append(jacobian_matrix, jacobian_row)
    
    Return jacobian_matrix

Process called "compute_hessian" that takes scalar_field as String, variables as List[String] returns List[List[String]]:
    Note: Compute Hessian matrix of second partial derivatives
    Let parsing_context be Dictionary.empty()
    Let parsed_field be SymbolicCore.parse_expression(scalar_field, parsing_context)
    Let hessian_matrix be List.create([])
    
    Note: For each variable xi, compute row of second mixed partials
    For Each variable_i in variables:
        Let hessian_row be List.create([])
        
        Note: Compute ∂²f/∂xi∂xj for all variables xj
        For Each variable_j in variables:
            Note: First partial with respect to variable_i
            Let first_partial be apply_differentiation_rules(parsed_field, variable_i)
            Note: Second partial with respect to variable_j
            Let second_partial be apply_differentiation_rules(first_partial, variable_j)
            Let second_partial_string be SymbolicCore.serialize_expression(second_partial, "infix")
            
            Set hessian_row to List.append(hessian_row, second_partial_string)
        
        Set hessian_matrix to List.append(hessian_matrix, hessian_row)
    
    Return hessian_matrix

Note: =====================================================================
Note: SERIES EXPANSION OPERATIONS
Note: =====================================================================

Process called "taylor_series" that takes expression as String, variable as String, expansion_point as String, order as Integer returns SeriesExpansion:
    Note: Compute Taylor series expansion around specified point
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    Let expansion_point_expr be SymbolicCore.parse_expression(expansion_point, parsing_context)
    
    Note: Taylor series: f(x) = Σ(n=0 to ∞) [f^(n)(a)/n!] * (x-a)^n
    Let series_terms be List.create([])
    Let current_derivative be parsed_expression
    Let factorial be 1
    Let n be 0
    
    While n <= order:
        Note: Evaluate derivative at expansion point
        Let derivative_at_point be SymbolicCore.substitute_variable(current_derivative, variable, expansion_point_expr)
        
        Note: Create (x - a)^n term
        Let x_minus_a be SymbolicCore.create_binary_operation("-", SymbolicCore.create_symbol(variable, Dictionary.empty()), expansion_point_expr)
        Let power_term be SymbolicCore.create_binary_operation("^", x_minus_a, SymbolicCore.create_constant(String.from_integer(n), "integer"))
        
        Note: Create coefficient f^(n)(a)/n!
        Let factorial_expr be SymbolicCore.create_constant(String.from_integer(factorial), "integer")
        Let coefficient be SymbolicCore.create_binary_operation("/", derivative_at_point, factorial_expr)
        
        Note: Create full term
        Let term be SymbolicCore.create_binary_operation("*", coefficient, power_term)
        Set series_terms to List.append(series_terms, SymbolicCore.serialize_expression(term, "infix"))
        
        Note: Prepare for next iteration
        If n < order:
            Set current_derivative to apply_differentiation_rules(current_derivative, variable)
        
        Set n to n + 1
        Set factorial to factorial * n
    
    Return SeriesExpansion:
        expansion_type = "taylor"
        original_expression = expression
        expansion_variable = variable
        expansion_point = expansion_point
        order = order
        terms = series_terms
        coefficients = List.create([])
        convergence_radius = "undetermined"

Process called "maclaurin_series" that takes expression as String, variable as String, order as Integer returns SeriesExpansion:
    Note: Compute Maclaurin series (Taylor series at origin)
    Note: Maclaurin series is just Taylor series expanded around x = 0
    Let taylor_result be taylor_series(expression, variable, "0", order)
    
    Return SeriesExpansion:
        expansion_type = "maclaurin"
        original_expression = taylor_result.original_expression
        expansion_variable = taylor_result.expansion_variable
        expansion_point = "0"
        order = taylor_result.order
        terms = taylor_result.terms
        coefficients = taylor_result.coefficients
        convergence_radius = taylor_result.convergence_radius

Process called "laurent_series" that takes expression as String, variable as String, expansion_point as String, positive_order as Integer, negative_order as Integer returns SeriesExpansion:
    Note: Compute Laurent series expansion including negative powers
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    Let expansion_point_expr be SymbolicCore.parse_expression(expansion_point, parsing_context)
    
    Note: Laurent series: f(z) = Σ(n=-∞ to ∞) a_n * (z-a)^n
    Let series_terms be List.create([])
    
    Note: Handle negative powers (principal part)
    Let n be -negative_order
    While n <= -1:
        Note: For negative powers, we assume coefficients are provided or computed separately
        Let x_minus_a be SymbolicCore.create_binary_operation("-", SymbolicCore.create_symbol(variable, Dictionary.empty()), expansion_point_expr)
        Let power_term be SymbolicCore.create_binary_operation("^", x_minus_a, SymbolicCore.create_constant(String.from_integer(n), "integer"))
        
        Note: Use generic coefficient for negative powers
        Let coefficient_name be "a_" + String.from_integer(n)
        Let coefficient be SymbolicCore.create_symbol(coefficient_name, Dictionary.empty())
        Let term be SymbolicCore.create_binary_operation("*", coefficient, power_term)
        
        Set series_terms to List.append(series_terms, SymbolicCore.serialize_expression(term, "infix"))
        Set n to n + 1
    
    Note: Handle non-negative powers (regular part) - use Taylor series approach
    Let taylor_expansion be taylor_series(expression, variable, expansion_point, positive_order)
    
    Note: Combine negative and positive terms
    For Each taylor_term in taylor_expansion.terms:
        Set series_terms to List.append(series_terms, taylor_term)
    
    Return SeriesExpansion:
        expansion_type = "laurent"
        original_expression = expression
        expansion_variable = variable
        expansion_point = expansion_point
        order = positive_order
        terms = series_terms
        coefficients = List.create([])
        convergence_radius = "annular_region"

Process called "fourier_series" that takes expression as String, variable as String, period as String, harmonics as Integer returns SeriesExpansion:
    Note: Compute Fourier series expansion of periodic function
    Let parsing_context be Dictionary.empty()
    Let period_expr be SymbolicCore.parse_expression(period, parsing_context)
    
    Note: Fourier series: f(x) = a₀/2 + Σ(n=1 to ∞) [aₙcos(nωx) + bₙsin(nωx)]
    Note: where ω = 2π/T and T is the period
    Let series_terms be List.create([])
    
    Note: Add constant term a₀/2
    Let a0_term be "a_0/2"
    Set series_terms to List.append(series_terms, a0_term)
    
    Note: Add harmonic terms
    Let n be 1
    While n <= harmonics:
        Note: Create ω = 2π/T
        Let omega_numerator be SymbolicCore.create_binary_operation("*", SymbolicCore.create_constant("2", "integer"), SymbolicCore.create_symbol("pi", Dictionary.empty()))
        Let omega be SymbolicCore.create_binary_operation("/", omega_numerator, period_expr)
        
        Note: Create nωx
        Let n_omega be SymbolicCore.create_binary_operation("*", SymbolicCore.create_constant(String.from_integer(n), "integer"), omega)
        Let n_omega_x be SymbolicCore.create_binary_operation("*", n_omega, SymbolicCore.create_symbol(variable, Dictionary.empty()))
        
        Note: Create cosine term: aₙcos(nωx)
        Let cos_term be SymbolicCore.create_function_call("cos", List.create([n_omega_x]), Dictionary.empty())
        Let a_n be SymbolicCore.create_symbol("a_" + String.from_integer(n), Dictionary.empty())
        Let cosine_harmonic be SymbolicCore.create_binary_operation("*", a_n, cos_term)
        
        Note: Create sine term: bₙsin(nωx)
        Let sin_term be SymbolicCore.create_function_call("sin", List.create([n_omega_x]), Dictionary.empty())
        Let b_n be SymbolicCore.create_symbol("b_" + String.from_integer(n), Dictionary.empty())
        Let sine_harmonic be SymbolicCore.create_binary_operation("*", b_n, sin_term)
        
        Set series_terms to List.append(series_terms, SymbolicCore.serialize_expression(cosine_harmonic, "infix"))
        Set series_terms to List.append(series_terms, SymbolicCore.serialize_expression(sine_harmonic, "infix"))
        
        Set n to n + 1
    
    Return SeriesExpansion:
        expansion_type = "fourier"
        original_expression = expression
        expansion_variable = variable
        expansion_point = "periodic"
        order = harmonics
        terms = series_terms
        coefficients = List.create([])
        convergence_radius = "periodic_interval"

Process called "asymptotic_expansion" that takes expression as String, variable as String, limit_point as String, order as Integer returns SeriesExpansion:
    Note: Compute asymptotic expansion for large or small values
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: Asymptotic expansions depend on the limit point behavior
    Let series_terms be List.create([])
    
    If limit_point equals "infinity":
        Note: For x → ∞, typically expand in powers of 1/x
        Let n be 0
        While n <= order:
            Note: Create term c_n / x^n
            Let coefficient_name be "c_" + String.from_integer(n)
            Let coefficient be SymbolicCore.create_symbol(coefficient_name, Dictionary.empty())
            
            If n equals 0:
                Let term_str be SymbolicCore.serialize_expression(coefficient, "infix")
                Set series_terms to List.append(series_terms, term_str)
            Otherwise:
                Let x_power be SymbolicCore.create_binary_operation("^", SymbolicCore.create_symbol(variable, Dictionary.empty()), SymbolicCore.create_constant(String.from_integer(n), "integer"))
                Let term be SymbolicCore.create_binary_operation("/", coefficient, x_power)
                Let term_str be SymbolicCore.serialize_expression(term, "infix")
                Set series_terms to List.append(series_terms, term_str)
            
            Set n to n + 1
    
    If limit_point equals "0":
        Note: For x → 0, expand in powers of x
        Let n be 0
        While n <= order:
            Let coefficient_name be "d_" + String.from_integer(n)
            Let coefficient be SymbolicCore.create_symbol(coefficient_name, Dictionary.empty())
            
            If n equals 0:
                Let term_str be SymbolicCore.serialize_expression(coefficient, "infix")
                Set series_terms to List.append(series_terms, term_str)
            Otherwise:
                Let x_power be SymbolicCore.create_binary_operation("^", SymbolicCore.create_symbol(variable, Dictionary.empty()), SymbolicCore.create_constant(String.from_integer(n), "integer"))
                Let term be SymbolicCore.create_binary_operation("*", coefficient, x_power)
                Let term_str be SymbolicCore.serialize_expression(term, "infix")
                Set series_terms to List.append(series_terms, term_str)
            
            Set n to n + 1
    
    Note: For other limit points, use Taylor-like expansion
    If not String.equals(limit_point, "infinity") and not String.equals(limit_point, "0"):
        Let taylor_result be taylor_series(expression, variable, limit_point, order)
        Set series_terms to taylor_result.terms
    
    Return SeriesExpansion:
        expansion_type = "asymptotic"
        original_expression = expression
        expansion_variable = variable
        expansion_point = limit_point
        order = order
        terms = series_terms
        coefficients = List.create([])
        convergence_radius = "asymptotic_validity"

Process called "series_convergence_test" that takes series as SeriesExpansion, convergence_tests as List[String] returns Dictionary[String, String]:
    Note: Test convergence of infinite series using various tests
    Let test_results be Dictionary.empty()
    
    Note: Apply each requested convergence test
    For Each test_name in convergence_tests:
        If test_name equals "ratio_test":
            Note: Ratio test: lim |a_{n+1}/a_n| = L
            Note: Converges if L < 1, diverges if L > 1, inconclusive if L = 1
            Let ratio_result be "inconclusive - requires coefficient analysis"
            Set test_results to Dictionary.set(test_results, "ratio_test", ratio_result)
        
        If test_name equals "root_test":
            Note: Root test: lim |a_n|^(1/n) = L
            Let root_result be "inconclusive - requires coefficient analysis"
            Set test_results to Dictionary.set(test_results, "root_test", root_result)
        
        If test_name equals "integral_test":
            Note: Integral test for positive decreasing terms
            Let integral_result be "requires integration of corresponding function"
            Set test_results to Dictionary.set(test_results, "integral_test", integral_result)
        
        If test_name equals "comparison_test":
            Note: Compare with known convergent/divergent series
            Let comparison_result be "requires comparison series specification"
            Set test_results to Dictionary.set(test_results, "comparison_test", comparison_result)
        
        If test_name equals "alternating_test":
            Note: Alternating series test (Leibniz criterion)
            Let alternating_result be "check if terms decrease to zero"
            Set test_results to Dictionary.set(test_results, "alternating_test", alternating_result)
        
        If test_name equals "divergence_test":
            Note: If lim a_n ≠ 0, then series diverges
            Let divergence_result be "check limit of general term"
            Set test_results to Dictionary.set(test_results, "divergence_test", divergence_result)
    
    Note: For specific series types, provide more specific analysis
    If series.expansion_type equals "taylor":
        Let radius_analysis be "radius of convergence depends on singularities"
        Set test_results to Dictionary.set(test_results, "radius_of_convergence", radius_analysis)
    
    If series.expansion_type equals "fourier":
        Let fourier_analysis be "converges if function is piecewise continuous"
        Set test_results to Dictionary.set(test_results, "fourier_convergence", fourier_analysis)
    
    Return test_results

Note: =====================================================================
Note: LIMIT OPERATIONS
Note: =====================================================================

Process called "compute_limit" that takes expression as String, variable as String, limit_point as String returns LimitResult:
    Note: Compute limit of expression as variable approaches point
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    Let limit_point_expr be SymbolicCore.parse_expression(limit_point, parsing_context)
    
    Note: Try direct substitution first
    Let direct_substitution be SymbolicCore.substitute_variable(parsed_expression, variable, limit_point_expr)
    Let direct_result be SymbolicCore.serialize_expression(direct_substitution, "infix")
    
    Note: Check if direct substitution gives a determinate result
    If not String.contains(direct_result, "undefined") and not String.contains(direct_result, "infinity"):
        Return LimitResult:
            limit_value = direct_result
            exists = Boolean.true()
            is_infinite = Boolean.false()
            approach_direction = "both_sides"
            computation_method = "direct_substitution"
            indeterminate_form = ""
    
    Note: If direct substitution fails, try algebraic manipulation
    Note: For indeterminate forms, apply algebraic manipulation and L'Hôpital's rule
    Let algebraic_result be "indeterminate - apply L'Hôpital's rule or algebraic simplification"
    
    Return LimitResult:
        limit_value = algebraic_result
        exists = Boolean.false()
        is_infinite = Boolean.false()
        approach_direction = "both_sides"
        computation_method = "algebraic_analysis"
        indeterminate_form = "0/0 or ∞/∞ possible"

Process called "one_sided_limit" that takes expression as String, variable as String, limit_point as String, direction as String returns LimitResult:
    Note: Compute one-sided limit (left or right)
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    Let limit_point_expr be SymbolicCore.parse_expression(limit_point, parsing_context)
    
    Note: For one-sided limits, we approach from specified direction
    Let epsilon be "0.0001"
    Let epsilon_expr be SymbolicCore.parse_expression(epsilon, parsing_context)
    
    Let test_point be limit_point_expr
    
    If direction equals "left" or direction equals "minus":
        Note: Approach from left (x → a⁻)
        Set test_point to SymbolicCore.create_binary_operation("-", limit_point_expr, epsilon_expr)
    
    If direction equals "right" or direction equals "plus":
        Note: Approach from right (x → a⁺)
        Set test_point to SymbolicCore.create_binary_operation("+", limit_point_expr, epsilon_expr)
    
    Note: Evaluate expression at test point
    Let substituted_expr be SymbolicCore.substitute_variable(parsed_expression, variable, test_point)
    Let result_string be SymbolicCore.serialize_expression(substituted_expr, "infix")
    
    Note: Using numerical approach to approximate one-sided limit
    Return LimitResult:
        limit_value = result_string + " (approximate)"
        exists = Boolean.true()
        is_infinite = String.contains(result_string, "infinity")
        approach_direction = direction
        computation_method = "numerical_approximation"
        indeterminate_form = ""

Process called "limit_at_infinity" that takes expression as String, variable as String, infinity_type as String returns LimitResult:
    Note: Compute limit as variable approaches positive or negative infinity
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: For limits at infinity, analyze highest degree terms
    Note: Analyze function behavior at infinity by evaluating at large values
    Let large_value be "1000000"
    
    If infinity_type equals "negative":
        Set large_value to "-1000000"
    
    Let test_value be SymbolicCore.parse_expression(large_value, parsing_context)
    Let substituted_expr be SymbolicCore.substitute_variable(parsed_expression, variable, test_value)
    Let numerical_result be SymbolicCore.serialize_expression(substituted_expr, "infix")
    
    Note: Analyze behavior for rational functions
    Let limit_result be numerical_result
    
    Note: Check for common infinity limit patterns
    If String.contains(expression, "/"):
        Note: For rational functions, compare degrees of numerator and denominator
        Set limit_result to "depends on degree comparison"
    
    If String.contains(expression, "exp"):
        Note: Exponential functions grow/decay exponentially
        If infinity_type equals "positive":
            Set limit_result to "∞"
        Otherwise:
            Set limit_result to "0"
    
    Return LimitResult:
        limit_value = limit_result
        exists = Boolean.true()
        is_infinite = String.equals(limit_result, "∞") or String.contains(limit_result, "infinity")
        approach_direction = infinity_type + "_infinity"
        computation_method = "infinity_analysis"
        indeterminate_form = ""

Process called "lhopitals_rule" that takes expression as String, variable as String, limit_point as String returns LimitResult:
    Note: Apply L'Hôpital's rule for indeterminate forms
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: L'Hôpital's rule applies to f(x)/g(x) when both f(a) = g(a) = 0 or both → ∞
    Note: lim f(x)/g(x) = lim f'(x)/g'(x) if the latter exists
    
    Note: Check if expression is in the form f(x)/g(x)
    If parsed_expression.expression_type equals "binary_operation" and parsed_expression.operator_type equals "/":
        Let numerator be List.get(parsed_expression.operands, 0)
        Let denominator be List.get(parsed_expression.operands, 1)
        
        Note: Differentiate numerator and denominator
        Let numerator_derivative be apply_differentiation_rules(numerator, variable)
        Let denominator_derivative be apply_differentiation_rules(denominator, variable)
        
        Note: Form new fraction f'(x)/g'(x)
        Let new_fraction be SymbolicCore.create_binary_operation("/", numerator_derivative, denominator_derivative)
        
        Note: Try to evaluate the new limit
        Let limit_point_expr be SymbolicCore.parse_expression(limit_point, parsing_context)
        Let substituted_new_fraction be SymbolicCore.substitute_variable(new_fraction, variable, limit_point_expr)
        Let result_string be SymbolicCore.serialize_expression(substituted_new_fraction, "infix")
        
        Return LimitResult:
            limit_value = result_string
            exists = Boolean.true()
            is_infinite = String.contains(result_string, "infinity")
            approach_direction = "both_sides"
            computation_method = "lhopitals_rule"
            indeterminate_form = "0/0 or ∞/∞"
    Otherwise:
        Note: L'Hôpital's rule doesn't directly apply to non-fractional expressions
        Return LimitResult:
            limit_value = "L'Hôpital's rule not applicable"
            exists = Boolean.false()
            is_infinite = Boolean.false()
            approach_direction = "both_sides"
            computation_method = "not_applicable"
            indeterminate_form = "not_0/0_or_inf/inf"

Process called "squeeze_theorem" that takes expression as String, lower_bound as String, upper_bound as String, variable as String, limit_point as String returns LimitResult:
    Note: Apply squeeze theorem with bounding functions
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    Let lower_bound_expr be SymbolicCore.parse_expression(lower_bound, parsing_context)
    Let upper_bound_expr be SymbolicCore.parse_expression(upper_bound, parsing_context)
    Let limit_point_expr be SymbolicCore.parse_expression(limit_point, parsing_context)
    
    Note: Squeeze theorem: if g(x) ≤ f(x) ≤ h(x) and lim g(x) = lim h(x) = L, then lim f(x) = L
    
    Note: Evaluate limits of bounding functions
    Let lower_limit be SymbolicCore.substitute_variable(lower_bound_expr, variable, limit_point_expr)
    Let upper_limit be SymbolicCore.substitute_variable(upper_bound_expr, variable, limit_point_expr)
    
    Let lower_limit_str be SymbolicCore.serialize_expression(lower_limit, "infix")
    Let upper_limit_str be SymbolicCore.serialize_expression(upper_limit, "infix")
    
    Note: Check if both bounding functions approach the same limit
    If String.equals(lower_limit_str, upper_limit_str):
        Note: Both bounds have same limit, so squeezed function has same limit
        Return LimitResult:
            limit_value = lower_limit_str
            exists = Boolean.true()
            is_infinite = String.contains(lower_limit_str, "infinity")
            approach_direction = "both_sides"
            computation_method = "squeeze_theorem"
            indeterminate_form = ""
    Otherwise:
        Note: Bounding functions don't have same limit - squeeze theorem doesn't apply
        Return LimitResult:
            limit_value = "squeeze theorem inconclusive - bounds: [" + lower_limit_str + ", " + upper_limit_str + "]"
            exists = Boolean.false()
            is_infinite = Boolean.false()
            approach_direction = "both_sides"
            computation_method = "squeeze_theorem_inconclusive"
            indeterminate_form = "bounds_dont_converge"

Note: =====================================================================
Note: DIFFERENTIAL EQUATION OPERATIONS
Note: =====================================================================

Process called "solve_first_order_ode" that takes equation as String, dependent_variable as String, independent_variable as String returns String:
    Note: Solve first-order ordinary differential equation
    Let parsing_context be Dictionary.empty()
    
    Note: First-order ODE general form: dy/dx = f(x,y)
    Note: Implementation handles separable first-order differential equations
    
    Note: Check if equation is separable: dy/dx = g(x)h(y)
    If String.contains(equation, "=") and String.contains(equation, "d" + dependent_variable + "/d" + independent_variable):
        Note: Split equation at equals sign
        Let equation_parts be String.split(equation, "=")
        
        If List.length(equation_parts) equals 2:
            Let right_side be String.trim(List.get(equation_parts, 1))
            
            Note: For simple separable equations, integrate both sides
            Let solution_form be "∫ dy = ∫ (" + right_side + ") dx"
            
            Note: Express solution in integral form
            Let integrated_solution be dependent_variable + " = ∫(" + right_side + ")d" + independent_variable + " + C"
            
            Return integrated_solution
    
    Note: For non-separable or complex equations, return general form
    Return "First-order ODE solution requires specific method identification: " + equation

Process called "solve_linear_ode" that takes equation as String, dependent_variable as String, independent_variable as String, order as Integer returns String:
    Note: Solve linear ordinary differential equation of specified order
    Let parsing_context be Dictionary.empty()
    
    Note: Linear ODE form: a_n(x)y^(n) + a_{n-1}(x)y^(n-1) + ... + a_1(x)y' + a_0(x)y = f(x)
    
    If order equals 1:
        Note: First-order linear ODE: dy/dx + P(x)y = Q(x)
        Note: Solution: y = (1/μ(x)) ∫ μ(x)Q(x) dx where μ(x) = e^(∫P(x)dx)
        Let solution_form be "First-order linear ODE solution using integrating factor"
        Return solution_form + ": " + equation
    
    If order equals 2:
        Note: Second-order linear ODE with constant coefficients
        Note: Form: ay'' + by' + cy = f(x)
        Note: Characteristic equation: ar² + br + c = 0
        Let characteristic_solution be "Solve characteristic equation ar² + br + c = 0"
        Return "Second-order linear ODE: " + characteristic_solution + " for " + equation
    
    Note: Higher-order linear ODEs require more advanced methods
    Return "Higher-order linear ODE (order " + String.from_integer(order) + "): " + equation + " - requires advanced techniques"

Process called "solve_separable_ode" that takes equation as String, dependent_variable as String, independent_variable as String returns String:
    Note: Solve separable differential equation
    Let parsing_context be Dictionary.empty()
    
    Note: Separable ODE form: dy/dx = g(x)h(y) or M(x)dx + N(y)dy = 0
    Note: Solution method: separate variables and integrate both sides
    
    If String.contains(equation, "d" + dependent_variable + "/d" + independent_variable):
        Note: Form dy/dx = f(x,y) - check if f(x,y) = g(x)h(y)
        Let equation_parts be String.split(equation, "=")
        
        If List.length(equation_parts) equals 2:
            Let right_side be String.trim(List.get(equation_parts, 1))
            
            Note: Rearrange to separable form: dy/h(y) = g(x)dx
            Note: For basic case where right_side is separable
            Let separated_form be "(1/h(" + dependent_variable + ")) d" + dependent_variable + " = g(" + independent_variable + ") d" + independent_variable
            
            Note: Integrate both sides
            Let solution be "∫ (1/h(" + dependent_variable + ")) d" + dependent_variable + " = ∫ g(" + independent_variable + ") d" + independent_variable + " + C"
            
            Return "Separable ODE solution: " + solution
    
    Note: Check for M(x)dx + N(y)dy = 0 form
    If String.contains(equation, "dx") and String.contains(equation, "dy"):
        Let separation_solution be "∫ M(" + independent_variable + ") d" + independent_variable + " + ∫ N(" + dependent_variable + ") d" + dependent_variable + " = C"
        Return "Separated form solution: " + separation_solution
    
    Return "Equation not in recognizable separable form: " + equation

Process called "solve_exact_ode" that takes equation as String, dependent_variable as String, independent_variable as String returns String:
    Note: Solve exact differential equation
    Let parsing_context be Dictionary.empty()
    
    Note: Exact ODE form: M(x,y)dx + N(x,y)dy = 0
    Note: Exactness condition: ∂M/∂y = ∂N/∂x
    Note: Solution: F(x,y) = C where ∂F/∂x = M and ∂F/∂y = N
    
    If String.contains(equation, "dx") and String.contains(equation, "dy") and String.contains(equation, "="):
        Note: Split equation to identify M and N
        Let parts be String.split(equation, "=")
        
        If List.length(parts) equals 2 and String.trim(List.get(parts, 1)) equals "0":
            Let left_side be String.trim(List.get(parts, 0))
            
            Note: Parse M(x,y) and N(x,y) from expression like "M(x,y)dx + N(x,y)dy"
            Note: Parse M and N components from differential form
            
            Note: Check exactness condition ∂M/∂y = ∂N/∂x
            Let exactness_check be "Check: ∂M/∂" + dependent_variable + " = ∂N/∂" + independent_variable
            
            Note: Find potential function F(x,y)
            Let potential_function be "F(" + independent_variable + "," + dependent_variable + ") such that ∂F/∂" + independent_variable + " = M and ∂F/∂" + dependent_variable + " = N"
            
            Let solution be "Exact ODE solution: " + potential_function + " = C"
            Return solution + " (" + exactness_check + ")"
    
    Note: If not exact, check for integrating factor
    Let integrating_factor_approach be "If not exact, find integrating factor μ(x) or μ(y) such that μM dx + μN dy = 0 is exact"
    
    Return "Exact ODE analysis for: " + equation + ". " + integrating_factor_approach

Process called "solve_bernoulli_ode" that takes equation as String, dependent_variable as String, independent_variable as String returns String:
    Note: Solve Bernoulli differential equation
    Let parsing_context be Dictionary.empty()
    
    Note: Bernoulli ODE form: dy/dx + P(x)y = Q(x)y^n where n ≠ 0, 1
    Note: Solution method: substitute v = y^(1-n) to transform to linear ODE
    
    If String.contains(equation, "d" + dependent_variable + "/d" + independent_variable):
        Note: Extract components from Bernoulli equation
        Let equation_parts be String.split(equation, "=")
        
        If List.length(equation_parts) equals 2:
            Let left_side be String.trim(List.get(equation_parts, 0))
            Let right_side be String.trim(List.get(equation_parts, 1))
            
            Note: For standard Bernoulli form, assume n=2 as common case
            Let n_value be 2
            Let one_minus_n be 1 - n_value
            
            Note: Create substitution v = y^(1-n) = y^(-1)
            Let v_variable be "v"
            Let substitution_power_str be String.from_integer(one_minus_n)
            
            Note: Transform equation using v = y^(1-n)
            Note: If y^n term exists, transform to linear form in v
            Let integrating_factor_approach be solve_linear_ode(left_side + " = " + right_side + "/y^" + String.from_integer(n_value), v_variable, independent_variable, 1)
            
            Note: Back-substitute v = y^(-1), so y = v^(-1)
            Let back_substitution_power be String.from_integer(-one_minus_n)
            Let solution_form be dependent_variable + "(x) obtained by solving linear ODE for v, then " + dependent_variable + " = v^(" + back_substitution_power + ")"
            
            Return "Bernoulli ODE solution: " + solution_form + " where " + integrating_factor_approach
        Otherwise:
            Note: Parse more complex Bernoulli forms
            Let general_form be "For equation of form dy/dx + P(x)y = Q(x)y^n, substitute v = y^(1-n) to get linear ODE"
            Return "General Bernoulli solution: " + general_form + " applied to " + equation
    
    Return "Bernoulli ODE requires form dy/dx + P(x)y = Q(x)y^n: " + equation

Process called "solve_system_odes" that takes equations as List[String], dependent_variables as List[String], independent_variable as String returns Dictionary[String, String]:
    Note: Solve system of ordinary differential equations
    Let parsing_context be Dictionary.empty()
    Let solutions be Dictionary.empty()
    
    Note: System of ODEs form: dx₁/dt = f₁(t, x₁, x₂, ..., xₙ), dx₂/dt = f₂(t, x₁, x₂, ..., xₙ), ...
    Note: Methods include: elimination, matrix methods, eigenvalue analysis
    
    Let num_equations be List.length(equations)
    Let num_variables be List.length(dependent_variables)
    
    If num_equations equals num_variables:
        Note: Square system - can potentially be solved
        
        If num_equations equals 2:
            Note: 2x2 system - use eigenvalue method for linear systems
            Let matrix_approach be "Convert to matrix form: X' = AX where X = [" + List.get(dependent_variables, 0) + ", " + List.get(dependent_variables, 1) + "]ᵀ"
            Let eigenvalue_method be "Find eigenvalues and eigenvectors of coefficient matrix A"
            Let general_solution be "X = c₁v₁e^(λ₁t) + c₂v₂e^(λ₂t) where λᵢ are eigenvalues, vᵢ are eigenvectors"
            
            Note: Store solutions for each variable
            For Each variable in dependent_variables:
                Set solutions to Dictionary.set(solutions, variable, "Part of system solution: " + general_solution)
        Otherwise:
            Note: Higher-order systems require more advanced methods
            For Each variable in dependent_variables:
                Set solutions to Dictionary.set(solutions, variable, "System solution requires matrix eigenanalysis")
    Otherwise:
        Note: Non-square system - over/under-determined
        For Each variable in dependent_variables:
            Set solutions to Dictionary.set(solutions, variable, "System is not square - cannot solve uniquely")
    
    Note: Add system analysis information
    Set solutions to Dictionary.set(solutions, "system_type", "ODE system with " + String.from_integer(num_equations) + " equations, " + String.from_integer(num_variables) + " variables")
    
    Return solutions

Process called "solve_pde_separation_variables" that takes equation as String, dependent_variable as String, independent_variables as List[String] returns String:
    Note: Solve partial differential equation using separation of variables
    Let parsing_context be Dictionary.empty()
    
    Note: Separation of variables method for PDEs
    Note: Assume solution form u(x,y,t) = X(x)Y(y)T(t) for common variables
    
    Let num_vars be List.length(independent_variables)
    
    If num_vars equals 2:
        Let var1 be List.get(independent_variables, 0)
        Let var2 be List.get(independent_variables, 1)
        
        Note: For 2D PDE like heat equation: ∂u/∂t = α∇²u
        Let separation_form be dependent_variable + "(" + var1 + "," + var2 + ") = X(" + var1 + ")Y(" + var2 + ")"
        
        Note: Substitute and separate
        Let separated_equations be "X''(" + var1 + ")/X(" + var1 + ") + Y''(" + var2 + ")/Y(" + var2 + ") = constant"
        
        Note: This leads to ODEs for X and Y
        Let ode_system be "X''(" + var1 + ") - λX(" + var1 + ") = 0, Y''(" + var2 + ") + (μ-λ)Y(" + var2 + ") = 0"
        
        Return "Separation of variables for PDE: 1) Assume " + separation_form + ", 2) " + separated_equations + ", 3) Solve ODEs: " + ode_system
    
    If num_vars equals 3:
        Let var1 be List.get(independent_variables, 0)
        Let var2 be List.get(independent_variables, 1)
        Let var3 be List.get(independent_variables, 2)
        
        Note: For 3D PDE like wave equation or 3D heat equation
        Let separation_form be dependent_variable + "(" + var1 + "," + var2 + "," + var3 + ") = X(" + var1 + ")Y(" + var2 + ")Z(" + var3 + ")"
        
        Note: This leads to three ODEs after separation
        Let triple_separation be "Results in three ODEs, one for each spatial variable function"
        
        Return "3D separation of variables: 1) Assume " + separation_form + ", 2) " + triple_separation
    
    Return "PDE separation method for equation: " + equation + " with variables: " + String.join(independent_variables, ", ")

Note: =====================================================================
Note: TRANSFORM OPERATIONS
Note: =====================================================================

Process called "laplace_transform" that takes expression as String, variable as String, transform_variable as String returns String:
    Note: Compute Laplace transform of expression
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: Laplace transform: L{f(t)} = F(s) = ∫₀^∞ f(t)e^(-st) dt
    Note: Common transforms: L{1} = 1/s, L{t} = 1/s², L{e^(at)} = 1/(s-a), L{sin(at)} = a/(s²+a²)
    
    Note: Check for common patterns and apply standard transforms
    If String.equals(expression, "1"):
        Return "1/" + transform_variable
    
    If String.equals(expression, variable):
        Return "1/(" + transform_variable + "^2)"
    
    If String.contains(expression, "exp"):
        Note: For e^(at), transform is 1/(s-a)
        Return "1/(" + transform_variable + " - a) for exp(a*" + variable + ")"
    
    If String.contains(expression, "sin"):
        Note: For sin(at), transform is a/(s²+a²)
        Return "a/(" + transform_variable + "^2 + a^2) for sin(a*" + variable + ")"
    
    If String.contains(expression, "cos"):
        Note: For cos(at), transform is s/(s²+a²)
        Return transform_variable + "/(" + transform_variable + "^2 + a^2) for cos(a*" + variable + ")"
    
    Note: For more complex expressions, return integral form
    Let integral_form be "∫₀^∞ (" + expression + ") * exp(-" + transform_variable + "*" + variable + ") d" + variable
    
    Return "Laplace transform: " + integral_form

Process called "inverse_laplace_transform" that takes expression as String, transform_variable as String, original_variable as String returns String:
    Note: Compute inverse Laplace transform
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: Inverse Laplace transform: L⁻¹{F(s)} = f(t)
    Note: Common inverse transforms: L⁻¹{1/s} = 1, L⁻¹{1/s²} = t, L⁻¹{1/(s-a)} = e^(at)
    
    Note: Check for standard forms
    If String.equals(expression, "1/" + transform_variable):
        Return "1"
    
    If String.equals(expression, "1/(" + transform_variable + "^2)") or String.equals(expression, "1/" + transform_variable + "^2"):
        Return original_variable
    
    If String.contains(expression, "1/(" + transform_variable + " - ") or String.contains(expression, "1/(" + transform_variable + "+"):
        Note: Form 1/(s-a) or 1/(s+a)
        Return "exp(a*" + original_variable + ") where a is extracted from denominator"
    
    If String.contains(expression, transform_variable + "/(" + transform_variable + "^2"):
        Note: Form s/(s²+a²) -> cos(at)
        Return "cos(a*" + original_variable + ") where a² is extracted from denominator"
    
    If String.contains(expression, "/(" + transform_variable + "^2 + ") and not String.contains(expression, transform_variable + "/"):
        Note: Form a/(s²+a²) -> sin(at)
        Return "sin(a*" + original_variable + ") where coefficient and a² are extracted"
    
    Note: For partial fractions and complex expressions
    If String.contains(expression, "/"):
        Let partial_fraction_note be "Apply partial fraction decomposition if needed"
        Return "Inverse Laplace of: " + expression + " (" + partial_fraction_note + ")"
    
    Note: General case using Bromwich integral
    Let bromwich_integral be "(1/2πi) ∫_{c-i∞}^{c+i∞} (" + expression + ") * exp(" + transform_variable + "*" + original_variable + ") d" + transform_variable
    
    Return "Inverse Laplace transform: " + bromwich_integral

Process called "fourier_transform" that takes expression as String, variable as String, transform_variable as String returns String:
    Note: Compute Fourier transform of expression
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: Fourier transform: F(ω) = ∫_{-∞}^∞ f(t)e^(-iωt) dt
    Note: Common transforms: F{δ(t)} = 1, F{1} = 2πδ(ω), F{e^(iω₀t)} = 2πδ(ω-ω₀)
    
    Note: Check for common patterns
    If String.equals(expression, "1"):
        Return "2*pi*delta(" + transform_variable + ") [Dirac delta function]"
    
    If String.contains(expression, "exp") and String.contains(expression, "i"):
        Note: For e^(iω₀t), result is 2πδ(ω-ω₀)
        Return "2*pi*delta(" + transform_variable + " - omega_0) for exp(i*omega_0*" + variable + ")"
    
    If String.contains(expression, "sin"):
        Note: sin(ω₀t) = (e^(iω₀t) - e^(-iω₀t))/(2i)
        Return "i*pi*[delta(" + transform_variable + " + omega_0) - delta(" + transform_variable + " - omega_0)] for sin(omega_0*" + variable + ")"
    
    If String.contains(expression, "cos"):
        Note: cos(ω₀t) = (e^(iω₀t) + e^(-iω₀t))/2
        Return "pi*[delta(" + transform_variable + " + omega_0) + delta(" + transform_variable + " - omega_0)] for cos(omega_0*" + variable + ")"
    
    If String.contains(expression, "exp") and not String.contains(expression, "i"):
        Note: For e^(-a|t|) where a > 0
        Return "2*a/(a^2 + " + transform_variable + "^2) for exp(-a*|" + variable + "|)"
    
    Note: Gaussian function e^(-at²)
    If String.contains(expression, variable + "^2") and String.contains(expression, "exp"):
        Return "sqrt(pi/a)*exp(-" + transform_variable + "^2/(4*a)) for exp(-a*" + variable + "^2)"
    
    Note: General integral form
    Let integral_form be "∫_{-∞}^∞ (" + expression + ") * exp(-i*" + transform_variable + "*" + variable + ") d" + variable
    
    Return "Fourier transform: " + integral_form

Process called "inverse_fourier_transform" that takes expression as String, transform_variable as String, original_variable as String returns String:
    Note: Compute inverse Fourier transform
    Let parsing_context be Dictionary.empty()
    Let parsed_expression be SymbolicCore.parse_expression(expression, parsing_context)
    
    Note: Inverse Fourier transform: f(t) = (1/2π) ∫_{-∞}^∞ F(ω)e^(iωt) dω
    Note: Common inverse transforms: F⁻¹{1} = δ(t), F⁻¹{δ(ω)} = 1/(2π)
    
    Note: Check for standard forms
    If String.equals(expression, "1"):
        Return "delta(" + original_variable + ") [Dirac delta function]"
    
    If String.contains(expression, "delta(" + transform_variable + ")"):
        Return "1/(2*pi)"
    
    If String.contains(expression, "delta(" + transform_variable + " - ") or String.contains(expression, "delta(" + transform_variable + " + "):
        Note: δ(ω - ω₀) -> (1/2π)e^(iω₀t)
        Return "(1/(2*pi))*exp(i*omega_0*" + original_variable + ") where omega_0 is extracted from delta argument"
    
    Note: Rectangular function (sinc transform)
    If String.contains(expression, "/(" + transform_variable + "^2 + a^2)"):
        Note: 2a/(ω²+a²) -> e^(-a|t|)
        Return "exp(-a*abs(" + original_variable + ")) where a is extracted from denominator"
    
    Note: Gaussian in frequency domain
    If String.contains(expression, "exp(-" + transform_variable + "^2"):
        Return "sqrt(pi/a)*exp(-" + original_variable + "^2*a) for exp(-" + transform_variable + "^2/a)"
    
    Note: Sinc function
    If String.contains(expression, "sin(" + transform_variable + ")/" + transform_variable):
        Return "rectangular pulse function in time domain"
    
    Note: Products of deltas (for sinusoidal functions)
    If String.contains(expression, "delta") and String.contains(expression, "+") and String.contains(expression, "-"):
        Note: For expressions like π[δ(ω+ω₀) + δ(ω-ω₀)] -> cos(ω₀t)
        Return "trigonometric function based on delta function positions"
    
    Note: General inverse transform integral
    Let inverse_integral be "(1/(2*pi)) ∫_{-∞}^∞ (" + expression + ") * exp(i*" + transform_variable + "*" + original_variable + ") d" + transform_variable
    
    Return "Inverse Fourier transform: " + inverse_integral

Process called "z_transform" that takes sequence as List[String], transform_variable as String returns String:
    Note: Compute Z-transform of discrete sequence
    Let parsing_context be Dictionary.empty()
    
    Note: Z-transform: X(z) = ∑_{n=0}^∞ x[n]z^(-n)
    Note: Common transforms: Z{δ[n]} = 1, Z{u[n]} = z/(z-1), Z{a^n*u[n]} = z/(z-a)
    
    Let sequence_length be List.length(sequence)
    
    Note: Handle finite sequences explicitly
    If sequence_length < 10:
        Let z_transform_terms be List.create([])
        Let n be 0
        
        While n < sequence_length:
            Let coefficient be List.get(sequence, n)
            
            If not String.equals(coefficient, "0"):
                Let power_term be transform_variable + "^(-" + String.from_integer(n) + ")"
                
                If n equals 0:
                    Set power_term to "1"
                
                Let term be coefficient + "*" + power_term
                
                If coefficient equals "1" and n equals 0:
                    Set term to "1"
                
                If String.equals(coefficient, "1") and n > 0:
                    Set term to transform_variable + "^(-" + String.from_integer(n) + ")"
                
                Set z_transform_terms to List.append(z_transform_terms, term)
            
            Set n to n + 1
        
        If List.is_empty(z_transform_terms):
            Return "0"
        
        Return String.join(z_transform_terms, " + ")
    
    Note: For infinite sequences, check for common patterns
    Let first_few_terms be List.slice(sequence, 0, (If sequence_length < 5 then sequence_length else 5))
    
    Note: Check for unit step sequence [1, 1, 1, ...]
    Let is_unit_step be Boolean.true()
    For Each term in first_few_terms:
        If not String.equals(term, "1"):
            Set is_unit_step to Boolean.false()
    
    If is_unit_step:
        Return transform_variable + "/(" + transform_variable + " - 1)"
    
    Note: Check for geometric sequence [1, a, a², a³, ...]
    If sequence_length >= 3:
        Let first_term be List.get(sequence, 0)
        Let second_term be List.get(sequence, 1)
        Let third_term be List.get(sequence, 2)
        
        If String.equals(first_term, "1"):
            Note: Check if it's geometric: x[n] = a^n
            Let geometric_note be "If sequence is a^n: " + transform_variable + "/(" + transform_variable + " - a)"
            Return "Z-transform: " + geometric_note + " where a = " + second_term
    
    Note: General form for arbitrary sequence
    Return "Z-transform: ∑_{n=0}^∞ x[n]" + transform_variable + "^(-n) for given sequence"

Note: =====================================================================
Note: LINE AND SURFACE INTEGRAL OPERATIONS
Note: =====================================================================

Process called "line_integral_scalar" that takes scalar_field as String, curve_parametrization as Dictionary[String, String], parameter as String returns String:
    Note: Compute line integral of scalar field along curve
    Let parsing_context be Dictionary.empty()
    Let parsed_field be SymbolicCore.parse_expression(scalar_field, parsing_context)
    
    Note: Line integral: ∫C f(x,y,z) ds where ds = |γ'(t)| dt
    Note: γ(t) = (x(t), y(t), z(t)) is curve parametrization
    
    Note: Get parametric equations from dictionary
    Let x_param be Dictionary.get(curve_parametrization, "x")
    Let y_param be Dictionary.get(curve_parametrization, "y")
    Let z_param be Dictionary.get_or_default(curve_parametrization, "z", "0")
    
    Note: Parse parametric expressions
    Let x_expr be SymbolicCore.parse_expression(x_param, parsing_context)
    Let y_expr be SymbolicCore.parse_expression(y_param, parsing_context)
    Let z_expr be SymbolicCore.parse_expression(z_param, parsing_context)
    
    Note: Substitute parametric equations into scalar field
    Let substituted_field be SymbolicCore.substitute_variable(parsed_field, "x", x_expr)
    Set substituted_field to SymbolicCore.substitute_variable(substituted_field, "y", y_expr)
    Set substituted_field to SymbolicCore.substitute_variable(substituted_field, "z", z_expr)
    
    Note: Compute derivatives of parametric equations
    Let dx_dt be apply_differentiation_rules(x_expr, parameter)
    Let dy_dt be apply_differentiation_rules(y_expr, parameter)
    Let dz_dt be apply_differentiation_rules(z_expr, parameter)
    
    Note: Compute magnitude of tangent vector |γ'(t)|
    Let dx_dt_squared be SymbolicCore.create_binary_operation("^", dx_dt, SymbolicCore.create_constant("2", "integer"))
    Let dy_dt_squared be SymbolicCore.create_binary_operation("^", dy_dt, SymbolicCore.create_constant("2", "integer"))
    Let dz_dt_squared be SymbolicCore.create_binary_operation("^", dz_dt, SymbolicCore.create_constant("2", "integer"))
    
    Let sum_squares be SymbolicCore.create_binary_operation("+", dx_dt_squared, dy_dt_squared)
    Set sum_squares to SymbolicCore.create_binary_operation("+", sum_squares, dz_dt_squared)
    Let magnitude be SymbolicCore.create_function_call("sqrt", List.create([sum_squares]), Dictionary.empty())
    
    Note: Create integrand f(γ(t)) * |γ'(t)|
    Let integrand be SymbolicCore.create_binary_operation("*", substituted_field, magnitude)
    Let integrand_str be SymbolicCore.serialize_expression(integrand, "infix")
    
    Return "∫ (" + integrand_str + ") d" + parameter + " [line integral of scalar field]"

Process called "line_integral_vector" that takes vector_field as VectorField, curve_parametrization as Dictionary[String, String], parameter as String returns String:
    Note: Compute line integral of vector field along curve
    Let parsing_context be Dictionary.empty()
    
    Note: Line integral: ∫C F·dr = ∫C (P dx + Q dy + R dz)
    Note: where F = (P, Q, R) and r(t) = (x(t), y(t), z(t))
    
    Note: Parse vector field components
    Let P_expr be SymbolicCore.parse_expression(vector_field.x_component, parsing_context)
    Let Q_expr be SymbolicCore.parse_expression(vector_field.y_component, parsing_context)
    Let R_expr be SymbolicCore.parse_expression(vector_field.z_component, parsing_context)
    
    Note: Get parametric equations
    Let x_param be Dictionary.get(curve_parametrization, "x")
    Let y_param be Dictionary.get(curve_parametrization, "y")
    Let z_param be Dictionary.get_or_default(curve_parametrization, "z", "0")
    
    Let x_expr be SymbolicCore.parse_expression(x_param, parsing_context)
    Let y_expr be SymbolicCore.parse_expression(y_param, parsing_context)
    Let z_expr be SymbolicCore.parse_expression(z_param, parsing_context)
    
    Note: Substitute parametric equations into vector field components
    Let P_substituted be SymbolicCore.substitute_variable(P_expr, "x", x_expr)
    Set P_substituted to SymbolicCore.substitute_variable(P_substituted, "y", y_expr)
    Set P_substituted to SymbolicCore.substitute_variable(P_substituted, "z", z_expr)
    
    Let Q_substituted be SymbolicCore.substitute_variable(Q_expr, "x", x_expr)
    Set Q_substituted to SymbolicCore.substitute_variable(Q_substituted, "y", y_expr)
    Set Q_substituted to SymbolicCore.substitute_variable(Q_substituted, "z", z_expr)
    
    Let R_substituted be SymbolicCore.substitute_variable(R_expr, "x", x_expr)
    Set R_substituted to SymbolicCore.substitute_variable(R_substituted, "y", y_expr)
    Set R_substituted to SymbolicCore.substitute_variable(R_substituted, "z", z_expr)
    
    Note: Compute derivatives dx/dt, dy/dt, dz/dt
    Let dx_dt be apply_differentiation_rules(x_expr, parameter)
    Let dy_dt be apply_differentiation_rules(y_expr, parameter)
    Let dz_dt be apply_differentiation_rules(z_expr, parameter)
    
    Note: Compute dot product F·r'(t) = P(dx/dt) + Q(dy/dt) + R(dz/dt)
    Let P_term be SymbolicCore.create_binary_operation("*", P_substituted, dx_dt)
    Let Q_term be SymbolicCore.create_binary_operation("*", Q_substituted, dy_dt)
    Let R_term be SymbolicCore.create_binary_operation("*", R_substituted, dz_dt)
    
    Let dot_product be SymbolicCore.create_binary_operation("+", P_term, Q_term)
    Set dot_product to SymbolicCore.create_binary_operation("+", dot_product, R_term)
    
    Let integrand_str be SymbolicCore.serialize_expression(dot_product, "infix")
    
    Return "∫ (" + integrand_str + ") d" + parameter + " [line integral of vector field]"

Process called "surface_integral_scalar" that takes scalar_field as String, surface_parametrization as Dictionary[String, Dictionary[String, String]], parameters as List[String] returns String:
    Note: Compute surface integral of scalar field over surface
    Let parsing_context be Dictionary.empty()
    Let parsed_field be SymbolicCore.parse_expression(scalar_field, parsing_context)
    
    Note: Surface integral: ∬ᵠ f(x,y,z) dS where dS = |rᵤ × rᵥ| du dv
    Note: r(u,v) = (x(u,v), y(u,v), z(u,v)) is surface parametrization
    
    Let param_u be List.get(parameters, 0)
    Let param_v be List.get(parameters, 1)
    
    Note: Get parametric equations from nested dictionary structure
    Let x_params be Dictionary.get(surface_parametrization, "x")
    Let y_params be Dictionary.get(surface_parametrization, "y")
    Let z_params be Dictionary.get(surface_parametrization, "z")
    
    Let x_param_str be Dictionary.get(x_params, "expression")
    Let y_param_str be Dictionary.get(y_params, "expression")
    Let z_param_str be Dictionary.get(z_params, "expression")
    
    Note: Parse parametric surface equations
    Let x_surface be SymbolicCore.parse_expression(x_param_str, parsing_context)
    Let y_surface be SymbolicCore.parse_expression(y_param_str, parsing_context)
    Let z_surface be SymbolicCore.parse_expression(z_param_str, parsing_context)
    
    Note: Substitute surface parametrization into scalar field
    Let substituted_field be SymbolicCore.substitute_variable(parsed_field, "x", x_surface)
    Set substituted_field to SymbolicCore.substitute_variable(substituted_field, "y", y_surface)
    Set substituted_field to SymbolicCore.substitute_variable(substituted_field, "z", z_surface)
    
    Note: Compute partial derivatives for cross product
    Let rx_u be apply_differentiation_rules(x_surface, param_u)
    Let ry_u be apply_differentiation_rules(y_surface, param_u)
    Let rz_u be apply_differentiation_rules(z_surface, param_u)
    
    Let rx_v be apply_differentiation_rules(x_surface, param_v)
    Let ry_v be apply_differentiation_rules(y_surface, param_v)
    Let rz_v be apply_differentiation_rules(z_surface, param_v)
    
    Note: Compute cross product rᵤ × rᵥ = (ry_u*rz_v - rz_u*ry_v, rz_u*rx_v - rx_u*rz_v, rx_u*ry_v - ry_u*rx_v)
    Let cross_x be SymbolicCore.create_binary_operation("-", SymbolicCore.create_binary_operation("*", ry_u, rz_v), SymbolicCore.create_binary_operation("*", rz_u, ry_v))
    Let cross_y be SymbolicCore.create_binary_operation("-", SymbolicCore.create_binary_operation("*", rz_u, rx_v), SymbolicCore.create_binary_operation("*", rx_u, rz_v))
    Let cross_z be SymbolicCore.create_binary_operation("-", SymbolicCore.create_binary_operation("*", rx_u, ry_v), SymbolicCore.create_binary_operation("*", ry_u, rx_v))
    
    Note: Compute magnitude of cross product
    Let cross_x_sq be SymbolicCore.create_binary_operation("^", cross_x, SymbolicCore.create_constant("2", "integer"))
    Let cross_y_sq be SymbolicCore.create_binary_operation("^", cross_y, SymbolicCore.create_constant("2", "integer"))
    Let cross_z_sq be SymbolicCore.create_binary_operation("^", cross_z, SymbolicCore.create_constant("2", "integer"))
    
    Let magnitude_squared be SymbolicCore.create_binary_operation("+", cross_x_sq, cross_y_sq)
    Set magnitude_squared to SymbolicCore.create_binary_operation("+", magnitude_squared, cross_z_sq)
    Let magnitude be SymbolicCore.create_function_call("sqrt", List.create([magnitude_squared]), Dictionary.empty())
    
    Note: Create integrand f(r(u,v)) * |rᵤ × rᵥ|
    Let integrand be SymbolicCore.create_binary_operation("*", substituted_field, magnitude)
    Let integrand_str be SymbolicCore.serialize_expression(integrand, "infix")
    
    Return "∬ (" + integrand_str + ") d" + param_u + " d" + param_v + " [surface integral of scalar field]"

Process called "surface_integral_vector" that takes vector_field as VectorField, surface_parametrization as Dictionary[String, Dictionary[String, String]], parameters as List[String] returns String:
    Note: Compute flux integral of vector field through surface
    Let parsing_context be Dictionary.empty()
    
    Note: Surface integral (flux): ∬ᵠ F·n dS = ∬ᵠ F·(rᵤ × rᵥ) du dv
    Note: where F = (P, Q, R) and n = (rᵤ × rᵥ)/|rᵤ × rᵥ|
    
    Let param_u be List.get(parameters, 0)
    Let param_v be List.get(parameters, 1)
    
    Note: Parse vector field components
    Let P_expr be SymbolicCore.parse_expression(vector_field.x_component, parsing_context)
    Let Q_expr be SymbolicCore.parse_expression(vector_field.y_component, parsing_context)
    Let R_expr be SymbolicCore.parse_expression(vector_field.z_component, parsing_context)
    
    Note: Get surface parametrization
    Let x_params be Dictionary.get(surface_parametrization, "x")
    Let y_params be Dictionary.get(surface_parametrization, "y")
    Let z_params be Dictionary.get(surface_parametrization, "z")
    
    Let x_param_str be Dictionary.get(x_params, "expression")
    Let y_param_str be Dictionary.get(y_params, "expression")
    Let z_param_str be Dictionary.get(z_params, "expression")
    
    Let x_surface be SymbolicCore.parse_expression(x_param_str, parsing_context)
    Let y_surface be SymbolicCore.parse_expression(y_param_str, parsing_context)
    Let z_surface be SymbolicCore.parse_expression(z_param_str, parsing_context)
    
    Note: Substitute surface parametrization into vector field
    Let P_substituted be SymbolicCore.substitute_variable(P_expr, "x", x_surface)
    Set P_substituted to SymbolicCore.substitute_variable(P_substituted, "y", y_surface)
    Set P_substituted to SymbolicCore.substitute_variable(P_substituted, "z", z_surface)
    
    Let Q_substituted be SymbolicCore.substitute_variable(Q_expr, "x", x_surface)
    Set Q_substituted to SymbolicCore.substitute_variable(Q_substituted, "y", y_surface)
    Set Q_substituted to SymbolicCore.substitute_variable(Q_substituted, "z", z_surface)
    
    Let R_substituted be SymbolicCore.substitute_variable(R_expr, "x", x_surface)
    Set R_substituted to SymbolicCore.substitute_variable(R_substituted, "y", y_surface)
    Set R_substituted to SymbolicCore.substitute_variable(R_substituted, "z", z_surface)
    
    Note: Compute partial derivatives for cross product
    Let rx_u be apply_differentiation_rules(x_surface, param_u)
    Let ry_u be apply_differentiation_rules(y_surface, param_u)
    Let rz_u be apply_differentiation_rules(z_surface, param_u)
    
    Let rx_v be apply_differentiation_rules(x_surface, param_v)
    Let ry_v be apply_differentiation_rules(y_surface, param_v)
    Let rz_v be apply_differentiation_rules(z_surface, param_v)
    
    Note: Compute cross product rᵤ × rᵥ
    Let cross_x be SymbolicCore.create_binary_operation("-", SymbolicCore.create_binary_operation("*", ry_u, rz_v), SymbolicCore.create_binary_operation("*", rz_u, ry_v))
    Let cross_y be SymbolicCore.create_binary_operation("-", SymbolicCore.create_binary_operation("*", rz_u, rx_v), SymbolicCore.create_binary_operation("*", rx_u, rz_v))
    Let cross_z be SymbolicCore.create_binary_operation("-", SymbolicCore.create_binary_operation("*", rx_u, ry_v), SymbolicCore.create_binary_operation("*", ry_u, rx_v))
    
    Note: Compute dot product F·(rᵤ × rᵥ) = P*(rᵤ × rᵥ)_x + Q*(rᵤ × rᵥ)_y + R*(rᵤ × rᵥ)_z
    Let P_term be SymbolicCore.create_binary_operation("*", P_substituted, cross_x)
    Let Q_term be SymbolicCore.create_binary_operation("*", Q_substituted, cross_y)
    Let R_term be SymbolicCore.create_binary_operation("*", R_substituted, cross_z)
    
    Let flux_integrand be SymbolicCore.create_binary_operation("+", P_term, Q_term)
    Set flux_integrand to SymbolicCore.create_binary_operation("+", flux_integrand, R_term)
    
    Let integrand_str be SymbolicCore.serialize_expression(flux_integrand, "infix")
    
    Return "∬ (" + integrand_str + ") d" + param_u + " d" + param_v + " [flux integral through surface]"

Process called "greens_theorem" that takes vector_field as VectorField, region_boundary as Dictionary[String, String] returns String:
    Note: Apply Green's theorem to convert line integral to double integral
    Let parsing_context be Dictionary.empty()
    
    Note: Green's theorem: ∮C (P dx + Q dy) = ∬ᵅ (∂Q/∂x - ∂P/∂y) dx dy
    Note: where C is positively oriented boundary of region D
    
    Note: Parse vector field components P and Q
    Let P_expr be SymbolicCore.parse_expression(vector_field.x_component, parsing_context)
    Let Q_expr be SymbolicCore.parse_expression(vector_field.y_component, parsing_context)
    
    Note: Compute partial derivatives
    Let dQ_dx be apply_differentiation_rules(Q_expr, "x")
    Let dP_dy be apply_differentiation_rules(P_expr, "y")
    
    Note: Form integrand (∂Q/∂x - ∂P/∂y)
    Let integrand be SymbolicCore.create_binary_operation("-", dQ_dx, dP_dy)
    Let integrand_str be SymbolicCore.serialize_expression(integrand, "infix")
    
    Note: Get region description from boundary dictionary
    Let region_description be Dictionary.get_or_default(region_boundary, "region", "region D")
    
    Note: Form Green's theorem equality
    Let line_integral_form be "∮C (" + vector_field.x_component + " dx + " + vector_field.y_component + " dy)"
    Let double_integral_form be "∬ᵅ (" + integrand_str + ") dx dy"
    
    Return "Green's theorem: " + line_integral_form + " = " + double_integral_form + " over " + region_description

Process called "stokes_theorem" that takes vector_field as VectorField, surface as Dictionary[String, String], boundary_curve as Dictionary[String, String] returns String:
    Note: Apply Stokes' theorem to relate surface and line integrals
    Let parsing_context be Dictionary.empty()
    
    Note: Stokes' theorem: ∮C F·dr = ∬ᵠ (∇×F)·n dS
    Note: Line integral around boundary C equals surface integral of curl over surface S
    
    Note: Parse vector field components
    Let P_expr be SymbolicCore.parse_expression(vector_field.x_component, parsing_context)
    Let Q_expr be SymbolicCore.parse_expression(vector_field.y_component, parsing_context)
    Let R_expr be SymbolicCore.parse_expression(vector_field.z_component, parsing_context)
    
    Note: Compute curl components: ∇×F = (∂R/∂y - ∂Q/∂z, ∂P/∂z - ∂R/∂x, ∂Q/∂x - ∂P/∂y)
    Let curl_x be SymbolicCore.create_binary_operation("-", apply_differentiation_rules(R_expr, "y"), apply_differentiation_rules(Q_expr, "z"))
    Let curl_y be SymbolicCore.create_binary_operation("-", apply_differentiation_rules(P_expr, "z"), apply_differentiation_rules(R_expr, "x"))
    Let curl_z be SymbolicCore.create_binary_operation("-", apply_differentiation_rules(Q_expr, "x"), apply_differentiation_rules(P_expr, "y"))
    
    Note: Serialize curl components
    Let curl_x_str be SymbolicCore.serialize_expression(curl_x, "infix")
    Let curl_y_str be SymbolicCore.serialize_expression(curl_y, "infix")
    Let curl_z_str be SymbolicCore.serialize_expression(curl_z, "infix")
    
    Note: Get surface and boundary descriptions
    Let surface_description be Dictionary.get_or_default(surface, "description", "surface S")
    Let boundary_description be Dictionary.get_or_default(boundary_curve, "description", "boundary curve C")
    
    Note: Form Stokes' theorem equality
    Let line_integral_form be "∮C F·dr = ∮C (" + vector_field.x_component + " dx + " + vector_field.y_component + " dy + " + vector_field.z_component + " dz)"
    Let surface_integral_form be "∬ᵠ (∇×F)·n dS = ∬ᵠ [(" + curl_x_str + ")nx + (" + curl_y_str + ")ny + (" + curl_z_str + ")nz] dS"
    
    Return "Stokes' theorem: " + line_integral_form + " = " + surface_integral_form + " where C is " + boundary_description + " and S is " + surface_description

Process called "divergence_theorem" that takes vector_field as VectorField, region as Dictionary[String, String] returns String:
    Note: Apply divergence theorem to convert volume to surface integral
    Let parsing_context be Dictionary.empty()
    
    Note: Divergence theorem (Gauss's theorem): ∬ᵠ F·n dS = ∭ᵤ ∇·F dV
    Note: Surface integral over boundary equals volume integral of divergence
    
    Note: Parse vector field components
    Let P_expr be SymbolicCore.parse_expression(vector_field.x_component, parsing_context)
    Let Q_expr be SymbolicCore.parse_expression(vector_field.y_component, parsing_context)
    Let R_expr be SymbolicCore.parse_expression(vector_field.z_component, parsing_context)
    
    Note: Compute divergence: ∇·F = ∂P/∂x + ∂Q/∂y + ∂R/∂z
    Let dP_dx be apply_differentiation_rules(P_expr, "x")
    Let dQ_dy be apply_differentiation_rules(Q_expr, "y")
    Let dR_dz be apply_differentiation_rules(R_expr, "z")
    
    Note: Sum partial derivatives
    Let divergence be SymbolicCore.create_binary_operation("+", dP_dx, dQ_dy)
    Set divergence to SymbolicCore.create_binary_operation("+", divergence, dR_dz)
    Let divergence_str be SymbolicCore.serialize_expression(divergence, "infix")
    
    Note: Get region description
    Let region_description be Dictionary.get_or_default(region, "description", "region V")
    Let boundary_description be Dictionary.get_or_default(region, "boundary", "boundary surface S")
    
    Note: Form divergence theorem equality
    Let surface_integral_form be "∬ᵠ F·n dS = ∬ᵠ [(" + vector_field.x_component + ")nx + (" + vector_field.y_component + ")ny + (" + vector_field.z_component + ")nz] dS"
    Let volume_integral_form be "∭ᵤ (∇·F) dV = ∭ᵤ (" + divergence_str + ") dx dy dz"
    
    Return "Divergence theorem: " + surface_integral_form + " = " + volume_integral_form + " where S is " + boundary_description + " of " + region_description

Note: =====================================================================
Note: COMPLEX ANALYSIS OPERATIONS
Note: =====================================================================

Process called "complex_derivative" that takes complex_function as String, complex_variable as String returns String:
    Note: Compute derivative of complex function (check analyticity)
    Let parsing_context be Dictionary.empty()
    Let parsed_function be SymbolicCore.parse_expression(complex_function, parsing_context)
    
    Note: For complex function f(z) = u(x,y) + i*v(x,y) where z = x + iy
    Note: Complex derivative exists if Cauchy-Riemann equations are satisfied:
    Note: ∂u/∂x = ∂v/∂y and ∂u/∂y = -∂v/∂x
    
    Note: If function is analytic, derivative is f'(z) = ∂u/∂x + i*∂v/∂x
    
    Note: For common complex functions, apply standard derivatives
    If String.equals(complex_function, complex_variable):
        Return "1"
    
    If String.contains(complex_function, "exp(") and String.contains(complex_function, complex_variable):
        Note: d/dz[e^z] = e^z
        Return "exp(" + complex_variable + ")"
    
    If String.contains(complex_function, "sin(") and String.contains(complex_function, complex_variable):
        Note: d/dz[sin(z)] = cos(z)
        Return "cos(" + complex_variable + ")"
    
    If String.contains(complex_function, "cos(") and String.contains(complex_function, complex_variable):
        Note: d/dz[cos(z)] = -sin(z)
        Return "-sin(" + complex_variable + ")"
    
    If String.contains(complex_function, complex_variable + "^"):
        Note: d/dz[z^n] = n*z^(n-1) for integer powers
        Return "n*" + complex_variable + "^(n-1) [power rule for complex functions]"
    
    If String.contains(complex_function, "log(") or String.contains(complex_function, "ln("):
        Note: d/dz[log(z)] = 1/z
        Return "1/(" + complex_variable + ")"
    
    Note: For general case, check analyticity first
    Let analyticity_note be "Check Cauchy-Riemann equations for analyticity"
    
    Return "Complex derivative of " + complex_function + " requires " + analyticity_note

Process called "cauchy_riemann_check" that takes complex_function as String, variables as Dictionary[String, String] returns Boolean:
    Note: Check Cauchy-Riemann equations for analyticity
    Let parsing_context be Dictionary.empty()
    
    Note: Cauchy-Riemann equations: ∂u/∂x = ∂v/∂y and ∂u/∂y = -∂v/∂x
    Note: where f(z) = u(x,y) + i*v(x,y)
    
    Note: Get real and imaginary parts from variables dictionary
    Let u_function be Dictionary.get_or_default(variables, "real_part", "u")
    Let v_function be Dictionary.get_or_default(variables, "imaginary_part", "v")
    
    Note: Parse real and imaginary parts
    Let u_expr be SymbolicCore.parse_expression(u_function, parsing_context)
    Let v_expr be SymbolicCore.parse_expression(v_function, parsing_context)
    
    Note: Compute required partial derivatives
    Let du_dx be apply_differentiation_rules(u_expr, "x")
    Let du_dy be apply_differentiation_rules(u_expr, "y")
    Let dv_dx be apply_differentiation_rules(v_expr, "x")
    Let dv_dy be apply_differentiation_rules(v_expr, "y")
    
    Note: Check first Cauchy-Riemann equation: ∂u/∂x = ∂v/∂y
    Let du_dx_str be SymbolicCore.serialize_expression(du_dx, "infix")
    Let dv_dy_str be SymbolicCore.serialize_expression(dv_dy, "infix")
    Let first_equation_satisfied be String.equals(du_dx_str, dv_dy_str)
    
    Note: Check second Cauchy-Riemann equation: ∂u/∂y = -∂v/∂x
    Let du_dy_str be SymbolicCore.serialize_expression(du_dy, "infix")
    Let dv_dx_str be SymbolicCore.serialize_expression(dv_dx, "infix")
    Let negative_dv_dx be SymbolicCore.create_unary_operation("-", dv_dx)
    Let negative_dv_dx_str be SymbolicCore.serialize_expression(negative_dv_dx, "infix")
    Let second_equation_satisfied be String.equals(du_dy_str, negative_dv_dx_str)
    
    Note: Both equations must be satisfied for analyticity
    Return Boolean.and(first_equation_satisfied, second_equation_satisfied)

Process called "contour_integral" that takes complex_function as String, contour as Dictionary[String, String], parameter as String returns String:
    Note: Compute contour integral of complex function
    Let parsing_context be Dictionary.empty()
    Let parsed_function be SymbolicCore.parse_expression(complex_function, parsing_context)
    
    Note: Contour integral: ∮C f(z) dz where z(t) is parametrization of contour C
    Note: = ∫[a,b] f(z(t)) * z'(t) dt
    
    Note: Get contour parametrization from dictionary
    Let real_param be Dictionary.get_or_default(contour, "real_part", "x(" + parameter + ")")
    Let imaginary_param be Dictionary.get_or_default(contour, "imaginary_part", "y(" + parameter + ")")
    
    Note: Parse parametric equations
    Let x_param be SymbolicCore.parse_expression(real_param, parsing_context)
    Let y_param be SymbolicCore.parse_expression(imaginary_param, parsing_context)
    
    Note: Create complex variable z = x + iy
    Let i_symbol be SymbolicCore.create_symbol("i", Dictionary.empty())
    Let iy_term be SymbolicCore.create_binary_operation("*", i_symbol, y_param)
    Let z_param be SymbolicCore.create_binary_operation("+", x_param, iy_term)
    
    Note: Substitute parametrization into function
    Let substituted_function be SymbolicCore.substitute_variable(parsed_function, "z", z_param)
    Let substituted_function_str be SymbolicCore.serialize_expression(substituted_function, "infix")
    
    Note: Compute dz/dt = dx/dt + i*dy/dt
    Let dx_dt be apply_differentiation_rules(x_param, parameter)
    Let dy_dt be apply_differentiation_rules(y_param, parameter)
    Let i_dy_dt be SymbolicCore.create_binary_operation("*", i_symbol, dy_dt)
    Let dz_dt be SymbolicCore.create_binary_operation("+", dx_dt, i_dy_dt)
    Let dz_dt_str be SymbolicCore.serialize_expression(dz_dt, "infix")
    
    Note: Get integration bounds
    Let lower_bound be Dictionary.get_or_default(contour, "start", "a")
    Let upper_bound be Dictionary.get_or_default(contour, "end", "b")
    
    Return "∮C (" + complex_function + ") dz = ∫[" + lower_bound + "," + upper_bound + "] (" + substituted_function_str + ") * (" + dz_dt_str + ") d" + parameter

Process called "residue_calculation" that takes complex_function as String, singularity as String returns String:
    Note: Calculate residue at isolated singularity
    Let parsing_context be Dictionary.empty()
    Let parsed_function be SymbolicCore.parse_expression(complex_function, parsing_context)
    Let singularity_point be SymbolicCore.parse_expression(singularity, parsing_context)
    
    Note: Residue is coefficient of (z-a)^(-1) in Laurent series expansion
    Note: For simple pole: Res(f,a) = lim[z→a] (z-a)f(z)
    Note: For pole of order n: Res(f,a) = (1/(n-1)!) * lim[z→a] d^(n-1)/dz^(n-1)[(z-a)^n * f(z)]
    
    Note: Check for simple pole pattern f(z) = g(z)/(z-a) where g(a) ≠ 0
    If String.contains(complex_function, "/") and String.contains(complex_function, "z - " + singularity):
        Note: Simple pole case
        Let simple_pole_formula be "lim[z→" + singularity + "] (z - " + singularity + ") * (" + complex_function + ")"
        Return "Residue (simple pole): " + simple_pole_formula
    
    Note: Check for rational function pattern
    If String.contains(complex_function, "/"):
        Let rational_note be "For rational function p(z)/q(z), residue at simple pole a is p(a)/q'(a)"
        Return "Residue calculation: " + rational_note + " at z = " + singularity
    
    Note: Check for essential singularity (requires Laurent series)
    If String.contains(complex_function, "exp") and String.contains(complex_function, "1/"):
        Let essential_note be "Essential singularity requires Laurent series expansion"
        Return "Residue at essential singularity z = " + singularity + ": " + essential_note
    
    Note: General case using Laurent series
    Let laurent_approach be "Expand " + complex_function + " in Laurent series around z = " + singularity + " and find coefficient of (z - " + singularity + ")^(-1)"
    
    Return "Residue calculation: " + laurent_approach

Process called "residue_theorem" that takes complex_function as String, contour as Dictionary[String, String], singularities as List[String] returns String:
    Note: Apply residue theorem to evaluate contour integral
    Let parsing_context be Dictionary.empty()
    
    Note: Residue theorem: ∮C f(z) dz = 2πi * Σ Res(f, zk)
    Note: where the sum is over all singularities zk inside contour C
    
    Note: Get contour description
    Let contour_description be Dictionary.get_or_default(contour, "description", "contour C")
    
    Note: Calculate residue at each singularity
    Let residue_terms be List.create([])
    
    For Each singularity in singularities:
        Let residue_at_point be "Res(f, " + singularity + ")"
        Set residue_terms to List.append(residue_terms, residue_at_point)
    
    Note: Form sum of residues
    Let residue_sum be String.join(residue_terms, " + ")
    
    If List.is_empty(residue_terms):
        Set residue_sum to "0"
    
    Note: Apply residue theorem formula
    Let contour_integral be "∮C (" + complex_function + ") dz"
    Let theorem_result be "2πi * (" + residue_sum + ")"
    
    Note: Add information about singularities
    Let num_singularities be List.length(singularities)
    Let singularity_list be String.join(singularities, ", ")
    
    Let singularity_info be ""
    If num_singularities equals 0:
        Set singularity_info to "No singularities inside contour"
        Set theorem_result to "0"
    Otherwise:
        Set singularity_info to "Singularities inside " + contour_description + ": " + singularity_list
    
    Return "Residue theorem: " + contour_integral + " = " + theorem_result + ". " + singularity_info

Note: =====================================================================
Note: VARIATIONAL CALCULUS OPERATIONS
Note: =====================================================================

Process called "euler_lagrange_equation" that takes lagrangian as String, dependent_variable as String, independent_variable as String returns String:
    Note: Derive Euler-Lagrange equation for variational problem
    Let parsing_context be Dictionary.empty()
    Let parsed_lagrangian be SymbolicCore.parse_expression(lagrangian, parsing_context)
    
    Note: Euler-Lagrange equation: d/dx(∂L/∂y') - ∂L/∂y = 0
    Note: where L = L(x, y, y') is the Lagrangian
    
    Note: Compute ∂L/∂y (partial derivative with respect to dependent variable)
    Let dL_dy be apply_differentiation_rules(parsed_lagrangian, dependent_variable)
    
    Note: Compute ∂L/∂y' (partial derivative with respect to derivative of dependent variable)
    Let y_prime_var be dependent_variable + "_prime"
    Let dL_dy_prime be apply_differentiation_rules(parsed_lagrangian, y_prime_var)
    
    Note: Compute d/dx(∂L/∂y') - total derivative with respect to independent variable
    Let d_dx_dL_dy_prime be apply_differentiation_rules(dL_dy_prime, independent_variable)
    
    Note: Form Euler-Lagrange equation: d/dx(∂L/∂y') - ∂L/∂y = 0
    Let euler_lagrange_lhs be SymbolicCore.create_binary_operation("-", d_dx_dL_dy_prime, dL_dy)
    Let euler_lagrange_str be SymbolicCore.serialize_expression(euler_lagrange_lhs, "infix")
    
    Note: Return the equation in standard form
    Return euler_lagrange_str + " = 0 [Euler-Lagrange equation]"

Process called "calculus_of_variations" that takes functional as String, boundary_conditions as Dictionary[String, String] returns String:
    Note: Solve variational problem with specified boundary conditions
    Let parsing_context be Dictionary.empty()
    
    Note: Variational problem: Find y(x) that extremizes I = ∫[a,b] F(x, y, y') dx
    Note: Subject to boundary conditions y(a) = y₀, y(b) = y₁
    
    Note: Get boundary conditions
    Let lower_bound be Dictionary.get_or_default(boundary_conditions, "lower_bound", "a")
    Let upper_bound be Dictionary.get_or_default(boundary_conditions, "upper_bound", "b")
    Let y_at_a be Dictionary.get_or_default(boundary_conditions, "y_at_lower", "y_0")
    Let y_at_b be Dictionary.get_or_default(boundary_conditions, "y_at_upper", "y_1")
    
    Note: Parse the functional integrand F(x, y, y')
    Let integrand be SymbolicCore.parse_expression(functional, parsing_context)
    
    Note: Apply Euler-Lagrange equation to find extremal
    Let euler_lagrange_result be euler_lagrange_equation(functional, "y", "x")
    
    Note: Form the complete variational problem statement
    Let functional_statement be "Minimize/Maximize I = ∫[" + lower_bound + "," + upper_bound + "] (" + functional + ") dx"
    Let boundary_statement be "Subject to: y(" + lower_bound + ") = " + y_at_a + ", y(" + upper_bound + ") = " + y_at_b
    
    Note: The solution approach
    Let solution_method be "Solution method: 1) Solve Euler-Lagrange equation: " + euler_lagrange_result + ", 2) Apply boundary conditions"
    
    Return "Variational Problem: " + functional_statement + ". " + boundary_statement + ". " + solution_method

Process called "brachistochrone_problem" that takes start_point as Dictionary[String, String], end_point as Dictionary[String, String] returns String:
    Note: Solve brachistochrone problem for fastest descent curve
    Let parsing_context be Dictionary.empty()
    
    Note: Brachistochrone: Find curve y(x) for fastest descent under gravity
    Note: Minimize time T = ∫ √[(1 + (dy/dx)²)/(2gy)] dx
    
    Note: Get start and end points
    Let x0 be Dictionary.get_or_default(start_point, "x", "0")
    Let y0 be Dictionary.get_or_default(start_point, "y", "0")
    Let x1 be Dictionary.get_or_default(end_point, "x", "x_1")
    Let y1 be Dictionary.get_or_default(end_point, "y", "y_1")
    
    Note: Brachistochrone Lagrangian: F = √[(1 + y'²)/(2gy)]
    Let lagrangian be "sqrt((1 + y_prime^2)/(2*g*y))"
    
    Note: Apply calculus of variations with boundary conditions
    Let boundary_conditions be Dictionary.empty()
    Set boundary_conditions to Dictionary.set(boundary_conditions, "lower_bound", x0)
    Set boundary_conditions to Dictionary.set(boundary_conditions, "upper_bound", x1)
    Set boundary_conditions to Dictionary.set(boundary_conditions, "y_at_lower", y0)
    Set boundary_conditions to Dictionary.set(boundary_conditions, "y_at_upper", y1)
    
    Note: The theoretical solution is a cycloid
    Let cycloid_solution be "Parametric solution: x = a(θ - sinθ), y = a(1 - cosθ) where a is determined by boundary conditions"
    
    Note: Physical interpretation
    Let physical_meaning be "Physical meaning: Particle slides down this curve in minimum time under gravity"
    
    Note: Get variational formulation
    Let variational_formulation be calculus_of_variations(lagrangian, boundary_conditions)
    
    Return "Brachistochrone Problem: " + variational_formulation + ". " + cycloid_solution + ". " + physical_meaning

Note: =====================================================================
Note: VALIDATION AND UTILITY OPERATIONS
Note: =====================================================================

Process called "verify_derivative" that takes original_expression as String, derivative_expression as String, variable as String returns Boolean:
    Note: Verify correctness of symbolic derivative
    Let parsing_context be Dictionary.empty()
    Let original_expr be SymbolicCore.parse_expression(original_expression, parsing_context)
    Let provided_derivative_expr be SymbolicCore.parse_expression(derivative_expression, parsing_context)
    
    Note: Compute derivative of original expression
    Let computed_derivative be apply_differentiation_rules(original_expr, variable)
    
    Note: Compare computed derivative with provided derivative
    Let computed_derivative_str be SymbolicCore.serialize_expression(computed_derivative, "infix")
    Let provided_derivative_str be SymbolicCore.serialize_expression(provided_derivative_expr, "infix")
    
    Note: Check if expressions are equivalent
    Let expressions_match be String.equals(computed_derivative_str, provided_derivative_str)
    
    Note: If direct comparison fails, try algebraic simplification comparison
    If not expressions_match:
        Note: Check if difference simplifies to zero
        Let difference be SymbolicCore.create_binary_operation("-", computed_derivative, provided_derivative_expr)
        Let difference_str be SymbolicCore.serialize_expression(difference, "infix")
        
        Note: Simple zero check
        If String.equals(difference_str, "0") or String.equals(difference_str, "0.0"):
            Set expressions_match to Boolean.true()
    
    Return expressions_match

Process called "verify_integral" that takes integral_result as String, integrand as String, variable as String returns Boolean:
    Note: Verify correctness of symbolic integral by differentiation
    Let parsing_context be Dictionary.empty()
    Let integral_expr be SymbolicCore.parse_expression(integral_result, parsing_context)
    Let original_integrand be SymbolicCore.parse_expression(integrand, parsing_context)
    
    Note: Differentiate the integral result - should give back the integrand
    Let derivative_of_integral be apply_differentiation_rules(integral_expr, variable)
    
    Note: Compare derivative with original integrand
    Let derivative_str be SymbolicCore.serialize_expression(derivative_of_integral, "infix")
    Let integrand_str be SymbolicCore.serialize_expression(original_integrand, "infix")
    
    Note: Check if expressions are equivalent
    Let verification_successful be String.equals(derivative_str, integrand_str)
    
    Note: If direct comparison fails, check if difference is zero
    If not verification_successful:
        Let difference be SymbolicCore.create_binary_operation("-", derivative_of_integral, original_integrand)
        Let difference_str be SymbolicCore.serialize_expression(difference, "infix")
        
        Note: Check for zero or constant difference (integration constant doesn't affect derivative)
        If String.equals(difference_str, "0") or String.equals(difference_str, "0.0"):
            Set verification_successful to Boolean.true()
        
        Note: Check if difference is a constant (which would be the integration constant)
        If is_constant_with_respect_to(difference, variable):
            Set verification_successful to Boolean.true()
    
    Return verification_successful

Process called "benchmark_calculus_operations" that takes operation_types as List[String], test_expressions as List[String] returns Dictionary[String, Float]:
    Note: Benchmark performance of calculus operations
    Let parsing_context be Dictionary.empty()
    Let benchmark_results be Dictionary.empty()
    
    Note: Benchmark each requested operation type
    For Each operation_type in operation_types:
        Let total_time be 0.0
        Let operation_count be 0
        
        Note: Test operation on each expression
        For Each expression in test_expressions:
            Let start_time be DateTime.current_timestamp_milliseconds()
            
            If operation_type equals "differentiate":
                Note: Benchmark differentiation
                Let parsed_expr be SymbolicCore.parse_expression(expression, parsing_context)
                Let result be apply_differentiation_rules(parsed_expr, "x")
                Let result_str be SymbolicCore.serialize_expression(result, "infix")
            
            If operation_type equals "integrate":
                Note: Benchmark integration
                Let parsed_expr be SymbolicCore.parse_expression(expression, parsing_context)
                Let result be apply_integration_rules(parsed_expr, "x")
                Let result_str be SymbolicCore.serialize_expression(result, "infix")
            
            If operation_type equals "gradient":
                Note: Benchmark gradient computation
                Let variables be List.create(["x", "y", "z"])
                Let gradient_result be compute_gradient(expression, variables)
            
            If operation_type equals "limit":
                Note: Benchmark limit computation
                Let limit_result be compute_limit(expression, "x", "0")
            
            If operation_type equals "series":
                Note: Benchmark series expansion
                Let series_result be taylor_series(expression, "x", "0", 5)
            
            Let end_time be DateTime.current_timestamp_milliseconds()
            Let operation_time be Float.from_integer(end_time - start_time)
            
            Set total_time to total_time + operation_time
            Set operation_count to operation_count + 1
        
        Note: Calculate average time per operation
        Let average_time be total_time / Float.from_integer(operation_count)
        Set benchmark_results to Dictionary.set(benchmark_results, operation_type, average_time)
    
    Note: Add summary statistics
    Set benchmark_results to Dictionary.set(benchmark_results, "total_expressions_tested", Float.from_integer(List.length(test_expressions)))
    Set benchmark_results to Dictionary.set(benchmark_results, "total_operations_tested", Float.from_integer(List.length(operation_types)))
    
    Return benchmark_results