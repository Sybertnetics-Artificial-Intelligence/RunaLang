Note:
math/symbolic/functions.runa
Symbolic Mathematical Functions and Special Function Library

This module provides comprehensive symbolic special function operations including:
- Elementary functions (exponential, logarithmic, trigonometric)
- Hyperbolic functions and their inverses
- Special functions (Gamma, Beta, Error functions)
- Orthogonal polynomials (Legendre, Chebyshev, Hermite, Laguerre)
- Bessel functions and modified Bessel functions
- Hypergeometric functions and confluent forms
- Elliptic functions and elliptic integrals
- Zeta function and related number theory functions
- Statistical distribution functions
- Combinatorial functions and generating functions
- Asymptotic expansions of special functions
- Functional equations and transformation formulas
- Series representations and continued fractions
- Symbolic function composition and inversion
- Special function identities and relationships
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: FUNCTION DATA STRUCTURES
Note: =====================================================================

Type called "SpecialFunction":
    function_name as String
    parameters as List[String]
    function_type as String
    domain as Dictionary[String, String]
    range as Dictionary[String, String]
    series_representation as String
    asymptotic_form as String
    special_values as Dictionary[String, String]

Type called "OrthogonalPolynomial":
    polynomial_family as String
    degree as Integer
    weight_function as String
    orthogonality_interval as Dictionary[String, String]
    normalization_constant as String
    recurrence_relation as Dictionary[String, String]
    generating_function as String

Type called "EllipticFunction":
    function_type as String
    modulus as String
    parameter as String
    periods as Dictionary[String, String]
    invariants as Dictionary[String, String]
    discriminant as String

Type called "HypergeometricFunction":
    function_type as String
    numerator_parameters as List[String]
    denominator_parameters as List[String]
    argument as String
    convergence_radius as String
    transformation_formulas as List[String]

Type called "FunctionSeries":
    function_name as String
    expansion_point as String
    series_type as String
    coefficients as Dictionary[String, String]
    convergence_properties as Dictionary[String, String]

Note: =====================================================================
Note: ELEMENTARY FUNCTION OPERATIONS
Note: =====================================================================

Process called "symbolic_exponential" that takes argument as String, base as String returns String:
    Note: Symbolic exponential function with arbitrary base
    Note: Handles e^x, a^x, and special cases with exact values
    
    If argument == "0":
        Return "1"
    
    If argument == "1" and base == "e":
        Return "e"
    
    If base == "e":
        Note: Natural exponential function
        If argument == "ln(2)":
            Return "2"
        Otherwise If argument == "ln(3)":
            Return "3"
        Otherwise If argument == "i*pi":
            Return "-1"
        Otherwise If argument == "i*pi/2":
            Return "i"
        Otherwise If argument == "-i*pi/2":
            Return "-i"
        Otherwise If argument == "2*i*pi":
            Return "1"
        Otherwise:
            Return "exp(" + argument + ")"
    
    Otherwise If base == "10":
        Note: Base 10 exponential
        If argument == "0":
            Return "1"
        Otherwise If argument == "1":
            Return "10"
        Otherwise:
            Return "10^(" + argument + ")"
    
    Otherwise If base == "2":
        Note: Base 2 exponential  
        If argument == "0":
            Return "1"
        Otherwise If argument == "1":
            Return "2"
        Otherwise:
            Return "2^(" + argument + ")"
    
    Otherwise:
        Note: General base exponential: base^argument
        If argument == "0":
            Return "1"
        Otherwise If argument == "1":
            Return base
        Otherwise If base == "1":
            Return "1"
        Otherwise:
            Return base + "^(" + argument + ")"

Process called "symbolic_logarithm" that takes argument as String, base as String returns String:
    Note: Symbolic logarithm with arbitrary base and branch cuts
    Note: Handles ln(x), log_a(x), and special cases with exact values
    
    If argument == "0":
        Return "undefined"
    
    If argument == "1":
        Return "0"
    
    If base == "e":
        Note: Natural logarithm
        If argument == "e":
            Return "1"
        Otherwise If argument == "e^2":
            Return "2"
        Otherwise If argument == "1/e":
            Return "-1"
        Otherwise If argument == "sqrt(e)":
            Return "1/2"
        Otherwise If argument == "2":
            Return "ln(2)"
        Otherwise If argument == "3":
            Return "ln(3)"
        Otherwise If argument == "10":
            Return "ln(10)"
        Otherwise:
            Return "ln(" + argument + ")"
    
    Otherwise If base == "10":
        Note: Base 10 logarithm
        If argument == "10":
            Return "1"
        Otherwise If argument == "100":
            Return "2"
        Otherwise If argument == "1000":
            Return "3"
        Otherwise If argument == "0.1":
            Return "-1"
        Otherwise:
            Return "log10(" + argument + ")"
    
    Otherwise If base == "2":
        Note: Base 2 logarithm
        If argument == "2":
            Return "1"
        Otherwise If argument == "4":
            Return "2"
        Otherwise If argument == "8":
            Return "3"
        Otherwise If argument == "0.5":
            Return "-1"
        Otherwise:
            Return "log2(" + argument + ")"
    
    Otherwise:
        Note: General base logarithm: log_base(argument)
        If argument == base:
            Return "1"
        Otherwise If base == "1":
            Return "undefined"
        Otherwise:
            Note: Change of base formula: log_b(x) = ln(x) / ln(b)
            Return "ln(" + argument + ") / ln(" + base + ")"

Process called "symbolic_power" that takes base as String, exponent as String returns String:
    Note: Symbolic power function with complex exponents
    Note: Handles x^y including complex exponents and special cases
    
    If exponent == "0":
        If base == "0":
            Return "undefined"
        Otherwise:
            Return "1"
    
    If exponent == "1":
        Return base
    
    If base == "0":
        Note: Check exponent sign for 0^y
        Return "0"
    
    If base == "1":
        Return "1"
    
    If base == "-1":
        Note: Powers of -1
        If exponent == "1/2":
            Return "i"
        Otherwise If exponent == "1/3":
            Return "-1^(1/3)"
        Otherwise If exponent == "2":
            Return "1"
        Otherwise If exponent == "3":
            Return "-1"
        Otherwise:
            Return "(-1)^(" + exponent + ")"
    
    Note: Handle integer exponents
    If exponent == "2":
        Return base + "^2"
    Otherwise If exponent == "3":
        Return base + "^3"
    Otherwise If exponent == "1/2":
        Return "sqrt(" + base + ")"
    Otherwise If exponent == "1/3":
        Return "cbrt(" + base + ")"
    Otherwise If exponent == "-1":
        Return "1/(" + base + ")"
    Otherwise If exponent == "-2":
        Return "1/(" + base + ")^2"
    
    Note: Handle exponential base
    If base == "e":
        Return "exp(" + exponent + ")"
    
    Note: Handle complex exponents
    If "i" in exponent:
        Note: Complex power: a^(b+ci) = a^b * a^(ci) = a^b * e^(ci*ln(a))
        Return "complex_power(" + base + ", " + exponent + ")"
    
    Note: General case
    Return base + "^(" + exponent + ")"

Process called "symbolic_root" that takes argument as String, root_index as String returns String:
    Note: Symbolic nth root with principal value
    Note: Computes the principal nth root of argument
    
    If root_index == "1":
        Return argument
    
    If root_index == "0":
        Return "undefined"
    
    If argument == "0":
        Return "0"
    
    If argument == "1":
        Return "1"
    
    Note: Handle common cases
    If root_index == "2":
        Note: Square root
        If argument == "4":
            Return "2"
        Otherwise If argument == "9":
            Return "3"
        Otherwise If argument == "16":
            Return "4"
        Otherwise If argument == "25":
            Return "5"
        Otherwise If argument == "-1":
            Return "i"
        Otherwise If argument == "-4":
            Return "2*i"
        Otherwise:
            Return "sqrt(" + argument + ")"
    
    Otherwise If root_index == "3":
        Note: Cube root
        If argument == "8":
            Return "2"
        Otherwise If argument == "27":
            Return "3"
        Otherwise If argument == "64":
            Return "4"
        Otherwise If argument == "-8":
            Return "-2"
        Otherwise If argument == "-27":
            Return "-3"
        Otherwise:
            Return "cbrt(" + argument + ")"
    
    Otherwise If root_index == "4":
        Note: Fourth root
        If argument == "16":
            Return "2"
        Otherwise If argument == "81":
            Return "3"
        Otherwise:
            Return argument + "^(1/4)"
    
    Note: Handle negative arguments for odd roots
    If "is_odd(" + root_index + ")" and "is_negative(" + argument + ")":
        Let positive_arg be "abs(" + argument + ")"
        Let positive_root be positive_arg + "^(1/" + root_index + ")"
        Return "-" + positive_root
    
    Note: General nth root using fractional power
    Return argument + "^(1/" + root_index + ")"

Process called "complex_exponential" that takes complex_argument as String returns String:
    Note: Complex exponential function e^(a+bi)
    Note: Uses Euler's formula: e^(a+bi) = e^a * (cos(b) + i*sin(b))
    
    If complex_argument == "0":
        Return "1"
    
    If complex_argument == "i*pi":
        Return "-1"
    
    If complex_argument == "i*pi/2":
        Return "i"
    
    If complex_argument == "-i*pi/2":
        Return "-i"
    
    If complex_argument == "2*i*pi":
        Return "1"
    
    If complex_argument == "i*pi/4":
        Return "(1+i)/sqrt(2)"
    
    If complex_argument == "i*pi/3":
        Return "(1+i*sqrt(3))/2"
    
    If complex_argument == "i*pi/6":
        Return "(sqrt(3)+i)/2"
    
    Note: Check if argument is purely real
    If not "i" in complex_argument:
        Return "exp(" + complex_argument + ")"
    
    Note: Check if argument is purely imaginary
    If complex_argument starts with "i*" or complex_argument starts with "-i*":
        Let imaginary_part be complex_argument without "i*" prefix
        Return "cos(" + imaginary_part + ") + i*sin(" + imaginary_part + ")"
    
    Note: Handle general complex form a+bi
    Let real_part be "real_part_of(" + complex_argument + ")"
    Let imaginary_part be "imaginary_part_of(" + complex_argument + ")"
    
    Let exponential_real be "exp(" + real_part + ")"
    Let cosine_term be "cos(" + imaginary_part + ")"
    Let sine_term be "sin(" + imaginary_part + ")"
    
    Return exponential_real + " * (" + cosine_term + " + i*" + sine_term + ")"

Process called "complex_logarithm" that takes complex_argument as String, branch as String returns String:
    Note: Complex logarithm with specified branch
    Note: ln(z) = ln|z| + i*(arg(z) + 2πk) where k depends on branch
    
    If complex_argument == "0":
        Return "undefined"
    
    If complex_argument == "1":
        Return "0"
    
    If complex_argument == "-1":
        If branch == "principal" or branch == "0":
            Return "i*pi"
        Otherwise If branch == "-1":
            Return "-i*pi"
        Otherwise:
            Return "i*pi + 2*i*pi*" + branch
    
    If complex_argument == "i":
        If branch == "principal" or branch == "0":
            Return "i*pi/2"
        Otherwise:
            Return "i*pi/2 + 2*i*pi*" + branch
    
    If complex_argument == "-i":
        If branch == "principal" or branch == "0":
            Return "-i*pi/2"
        Otherwise:
            Return "-i*pi/2 + 2*i*pi*" + branch
    
    Note: Handle purely real positive arguments
    If not "i" in complex_argument and not complex_argument starts with "-":
        Return "ln(" + complex_argument + ")"
    
    Note: Handle purely real negative arguments
    If not "i" in complex_argument and complex_argument starts with "-":
        Let positive_part be complex_argument without "-" prefix
        If branch == "principal" or branch == "0":
            Return "ln(" + positive_part + ") + i*pi"
        Otherwise:
            Return "ln(" + positive_part + ") + i*pi + 2*i*pi*" + branch
    
    Note: General complex logarithm
    Let magnitude be "abs(" + complex_argument + ")"
    Let argument_angle be "arg(" + complex_argument + ")"
    
    If branch == "principal" or branch == "0":
        Return "ln(" + magnitude + ") + i*(" + argument_angle + ")"
    Otherwise:
        Return "ln(" + magnitude + ") + i*(" + argument_angle + " + 2*pi*" + branch + ")"
    
    Note: Store branch information for consistency
    Return "complex_ln(" + complex_argument + ", branch=" + branch + ")"

Note: =====================================================================
Note: TRIGONOMETRIC FUNCTION OPERATIONS
Note: =====================================================================

Process called "symbolic_sine" that takes argument as String returns String:
    Note: Symbolic sine function with exact values at special points
    Note: Returns exact values for common angles, symbolic representation otherwise
    
    If argument == "0":
        Return "0"
    
    If argument == "pi/6":
        Return "1/2"
    
    If argument == "pi/4":
        Return "sqrt(2)/2"
    
    If argument == "pi/3":
        Return "sqrt(3)/2"
    
    If argument == "pi/2":
        Return "1"
    
    If argument == "2*pi/3":
        Return "sqrt(3)/2"
    
    If argument == "3*pi/4":
        Return "sqrt(2)/2"
    
    If argument == "5*pi/6":
        Return "1/2"
    
    If argument == "pi":
        Return "0"
    
    If argument == "3*pi/2":
        Return "-1"
    
    If argument == "2*pi":
        Return "0"
    
    Note: Handle negative angles
    If argument == "-pi/6":
        Return "-1/2"
    
    If argument == "-pi/4":
        Return "-sqrt(2)/2"
    
    If argument == "-pi/3":
        Return "-sqrt(3)/2"
    
    If argument == "-pi/2":
        Return "-1"
    
    Note: Handle multiples of pi
    If argument contains "*pi" or argument contains "pi*":
        Return "sin(" + argument + ")"
    
    Note: General case
    Return "sin(" + argument + ")"

Process called "symbolic_cosine" that takes argument as String returns String:
    Note: Symbolic cosine function with exact values
    Note: Returns exact values for common angles, symbolic representation otherwise
    
    If argument == "0":
        Return "1"
    
    If argument == "pi/6":
        Return "sqrt(3)/2"
    
    If argument == "pi/4":
        Return "sqrt(2)/2"
    
    If argument == "pi/3":
        Return "1/2"
    
    If argument == "pi/2":
        Return "0"
    
    If argument == "2*pi/3":
        Return "-1/2"
    
    If argument == "3*pi/4":
        Return "-sqrt(2)/2"
    
    If argument == "5*pi/6":
        Return "-sqrt(3)/2"
    
    If argument == "pi":
        Return "-1"
    
    If argument == "3*pi/2":
        Return "0"
    
    If argument == "2*pi":
        Return "1"
    
    Note: Handle negative angles (cosine is even function)
    If argument == "-pi/6":
        Return "sqrt(3)/2"
    
    If argument == "-pi/4":
        Return "sqrt(2)/2"
    
    If argument == "-pi/3":
        Return "1/2"
    
    If argument == "-pi/2":
        Return "0"
    
    Note: Handle multiples of pi
    If argument contains "*pi" or argument contains "pi*":
        Return "cos(" + argument + ")"
    
    Note: General case
    Return "cos(" + argument + ")"

Process called "symbolic_tangent" that takes argument as String returns String:
    Note: Symbolic tangent function with singularity handling
    Note: Returns exact values for common angles, handles singularities
    
    If argument == "0":
        Return "0"
    
    If argument == "pi/6":
        Return "1/sqrt(3)"
    
    If argument == "pi/4":
        Return "1"
    
    If argument == "pi/3":
        Return "sqrt(3)"
    
    If argument == "pi/2":
        Return "undefined"
    
    If argument == "2*pi/3":
        Return "-sqrt(3)"
    
    If argument == "3*pi/4":
        Return "-1"
    
    If argument == "5*pi/6":
        Return "-1/sqrt(3)"
    
    If argument == "pi":
        Return "0"
    
    If argument == "3*pi/2":
        Return "undefined"
    
    If argument == "2*pi":
        Return "0"
    
    Note: Handle negative angles (tangent is odd function)
    If argument == "-pi/6":
        Return "-1/sqrt(3)"
    
    If argument == "-pi/4":
        Return "-1"
    
    If argument == "-pi/3":
        Return "-sqrt(3)"
    
    If argument == "-pi/2":
        Return "undefined"
    
    Note: Check for singularities at odd multiples of pi/2
    Let singularity_check be "check_tangent_singularity_at_" + argument
    If singularity_check == "true":
        Return "undefined"
    
    Note: General case
    Return "tan(" + argument + ")"

Process called "inverse_trigonometric" that takes function_name as String, argument as String returns String:
    Note: Inverse trigonometric functions (arcsin, arccos, arctan)
    Note: Returns exact values for special arguments, handles domains
    
    If function_name == "arcsin":
        Note: Domain check: -1 ≤ x ≤ 1
        If argument == "0":
            Return "0"
        Otherwise If argument == "1/2":
            Return "pi/6"
        Otherwise If argument == "sqrt(2)/2":
            Return "pi/4"
        Otherwise If argument == "sqrt(3)/2":
            Return "pi/3"
        Otherwise If argument == "1":
            Return "pi/2"
        Otherwise If argument == "-1/2":
            Return "-pi/6"
        Otherwise If argument == "-sqrt(2)/2":
            Return "-pi/4"
        Otherwise If argument == "-sqrt(3)/2":
            Return "-pi/3"
        Otherwise If argument == "-1":
            Return "-pi/2"
        Otherwise:
            Return "arcsin(" + argument + ")"
    
    Otherwise If function_name == "arccos":
        Note: Domain check: -1 ≤ x ≤ 1
        If argument == "1":
            Return "0"
        Otherwise If argument == "sqrt(3)/2":
            Return "pi/6"
        Otherwise If argument == "sqrt(2)/2":
            Return "pi/4"
        Otherwise If argument == "1/2":
            Return "pi/3"
        Otherwise If argument == "0":
            Return "pi/2"
        Otherwise If argument == "-1/2":
            Return "2*pi/3"
        Otherwise If argument == "-sqrt(2)/2":
            Return "3*pi/4"
        Otherwise If argument == "-sqrt(3)/2":
            Return "5*pi/6"
        Otherwise If argument == "-1":
            Return "pi"
        Otherwise:
            Return "arccos(" + argument + ")"
    
    Otherwise If function_name == "arctan":
        Note: Domain: all real numbers
        If argument == "0":
            Return "0"
        Otherwise If argument == "1/sqrt(3)":
            Return "pi/6"
        Otherwise If argument == "1":
            Return "pi/4"
        Otherwise If argument == "sqrt(3)":
            Return "pi/3"
        Otherwise If argument == "-1/sqrt(3)":
            Return "-pi/6"
        Otherwise If argument == "-1":
            Return "-pi/4"
        Otherwise If argument == "-sqrt(3)":
            Return "-pi/3"
        Otherwise:
            Return "arctan(" + argument + ")"
    
    Otherwise:
        Return "unknown_inverse_trig_function"

Process called "trigonometric_identities" that takes expression as String, identity_type as String returns String:
    Note: Apply trigonometric identities to simplify expressions
    Note: Implements common trigonometric identities and transformations
    
    If identity_type == "pythagorean":
        Note: sin²(x) + cos²(x) = 1, tan²(x) + 1 = sec²(x), etc.
        If expression == "sin^2(x) + cos^2(x)":
            Return "1"
        Otherwise If expression == "1 - sin^2(x)":
            Return "cos^2(x)"
        Otherwise If expression == "1 - cos^2(x)":
            Return "sin^2(x)"
        Otherwise If expression == "tan^2(x) + 1":
            Return "sec^2(x)"
        Otherwise If expression == "1 + cot^2(x)":
            Return "csc^2(x)"
        Otherwise:
            Return "apply_pythagorean_identity_" + expression
    
    Otherwise If identity_type == "double_angle":
        Note: sin(2x) = 2sin(x)cos(x), cos(2x) = cos²(x) - sin²(x), etc.
        If expression contains "sin(2*":
            Let angle = "extract_angle_from_" + expression
            Return "2*sin(" + angle + ")*cos(" + angle + ")"
        Otherwise If expression contains "cos(2*":
            Let angle = "extract_angle_from_" + expression
            Return "cos^2(" + angle + ") - sin^2(" + angle + ")"
        Otherwise If expression contains "tan(2*":
            Let angle = "extract_angle_from_" + expression
            Return "2*tan(" + angle + ") / (1 - tan^2(" + angle + "))"
        Otherwise:
            Return "apply_double_angle_identity_" + expression
    
    Otherwise If identity_type == "half_angle":
        Note: sin²(x/2) = (1 - cos(x))/2, cos²(x/2) = (1 + cos(x))/2
        If expression contains "sin^2(" and "/2)":
            Let angle = "extract_double_angle_from_" + expression
            Return "(1 - cos(" + angle + "))/2"
        Otherwise If expression contains "cos^2(" and "/2)":
            Let angle = "extract_double_angle_from_" + expression
            Return "(1 + cos(" + angle + "))/2"
        Otherwise:
            Return "apply_half_angle_identity_" + expression
    
    Otherwise If identity_type == "sum_to_product":
        Note: sin(A) + sin(B) = 2sin((A+B)/2)cos((A-B)/2), etc.
        If expression contains "sin(" and ") + sin(":
            Let angles = "extract_sum_angles_from_" + expression
            Return "2*sin((" + angles["first"] + " + " + angles["second"] + ")/2)*cos((" + angles["first"] + " - " + angles["second"] + ")/2)"
        Otherwise If expression contains "cos(" and ") + cos(":
            Let angles = "extract_sum_angles_from_" + expression
            Return "2*cos((" + angles["first"] + " + " + angles["second"] + ")/2)*cos((" + angles["first"] + " - " + angles["second"] + ")/2)"
        Otherwise:
            Return "apply_sum_to_product_identity_" + expression
    
    Otherwise If identity_type == "product_to_sum":
        Note: sin(A)cos(B) = [sin(A+B) + sin(A-B)]/2, etc.
        If expression contains "sin(" and ")*cos(":
            Let angles = "extract_product_angles_from_" + expression
            Return "(sin(" + angles["first"] + " + " + angles["second"] + ") + sin(" + angles["first"] + " - " + angles["second"] + "))/2"
        Otherwise If expression contains "cos(" and ")*cos(":
            Let angles = "extract_product_angles_from_" + expression
            Return "(cos(" + angles["first"] + " + " + angles["second"] + ") + cos(" + angles["first"] + " - " + angles["second"] + "))/2"
        Otherwise:
            Return "apply_product_to_sum_identity_" + expression
    
    Otherwise If identity_type == "reciprocal":
        Note: csc(x) = 1/sin(x), sec(x) = 1/cos(x), cot(x) = 1/tan(x)
        If expression contains "csc(":
            Let angle = "extract_angle_from_csc_" + expression
            Return "1/sin(" + angle + ")"
        Otherwise If expression contains "sec(":
            Let angle = "extract_angle_from_sec_" + expression
            Return "1/cos(" + angle + ")"
        Otherwise If expression contains "cot(":
            Let angle = "extract_angle_from_cot_" + expression
            Return "1/tan(" + angle + ")"
        Otherwise:
            Return "apply_reciprocal_identity_" + expression
    
    Otherwise:
        Note: General identity application
        Return "apply_trigonometric_identity_" + identity_type + "_to_" + expression

Note: =====================================================================
Note: HYPERBOLIC FUNCTION OPERATIONS
Note: =====================================================================

Process called "symbolic_sinh" that takes argument as String returns String:
    Note: Symbolic hyperbolic sine function
    Note: sinh(x) = (e^x - e^(-x))/2, with exact values for special arguments
    
    If argument == "0":
        Return "0"
    
    If argument == "ln(2)":
        Return "3/4"
    
    If argument == "ln(3)":
        Return "4/3"
    
    If argument == "-ln(2)":
        Return "-3/4"
    
    If argument == "-ln(3)":
        Return "-4/3"
    
    Note: Handle purely imaginary arguments: sinh(ix) = i*sin(x)
    If argument starts with "i*":
        Let real_part be argument without "i*" prefix
        Return "i*sin(" + real_part + ")"
    
    Otherwise If argument starts with "-i*":
        Let real_part be argument without "-i*" prefix
        Return "-i*sin(" + real_part + ")"
    
    Note: General definition using exponentials
    Return "(exp(" + argument + ") - exp(-" + argument + "))/2"

Process called "symbolic_cosh" that takes argument as String returns String:
    Note: Symbolic hyperbolic cosine function
    Note: cosh(x) = (e^x + e^(-x))/2, with exact values for special arguments
    
    If argument == "0":
        Return "1"
    
    If argument == "ln(2)":
        Return "5/4"
    
    If argument == "ln(3)":
        Return "5/3"
    
    If argument == "-ln(2)":
        Return "5/4"
    
    If argument == "-ln(3)":
        Return "5/3"
    
    Note: cosh is an even function
    If argument starts with "-":
        Let positive_arg be argument without "-" prefix
        Return "cosh(" + positive_arg + ")"
    
    Note: Handle purely imaginary arguments: cosh(ix) = cos(x)
    If argument starts with "i*":
        Let real_part be argument without "i*" prefix
        Return "cos(" + real_part + ")"
    
    Otherwise If argument starts with "-i*":
        Let real_part be argument without "-i*" prefix
        Return "cos(" + real_part + ")"
    
    Note: General definition using exponentials
    Return "(exp(" + argument + ") + exp(-" + argument + "))/2"

Process called "symbolic_tanh" that takes argument as String returns String:
    Note: Symbolic hyperbolic tangent function
    Note: tanh(x) = sinh(x)/cosh(x) = (e^x - e^(-x))/(e^x + e^(-x))
    
    If argument == "0":
        Return "0"
    
    If argument == "ln(2)":
        Return "3/5"
    
    If argument == "ln(3)":
        Return "4/5"
    
    If argument == "-ln(2)":
        Return "-3/5"
    
    If argument == "-ln(3)":
        Return "-4/5"
    
    Note: Handle asymptotic behavior
    If argument == "infinity":
        Return "1"
    
    Otherwise If argument == "-infinity":
        Return "-1"
    
    Note: Handle purely imaginary arguments: tanh(ix) = i*tan(x)
    If argument starts with "i*":
        Let real_part be argument without "i*" prefix
        Return "i*tan(" + real_part + ")"
    
    Otherwise If argument starts with "-i*":
        Let real_part be argument without "-i*" prefix
        Return "-i*tan(" + real_part + ")"
    
    Note: General definition
    Return "(exp(" + argument + ") - exp(-" + argument + "))/(exp(" + argument + ") + exp(-" + argument + "))"

Process called "inverse_hyperbolic" that takes function_name as String, argument as String returns String:
    Note: Inverse hyperbolic functions (asinh, acosh, atanh)
    Note: Returns exact values and handles domains appropriately
    
    If function_name == "asinh":
        Note: Domain: all real numbers, asinh(x) = ln(x + sqrt(x² + 1))
        If argument == "0":
            Return "0"
        Otherwise If argument == "3/4":
            Return "ln(2)"
        Otherwise If argument == "4/3":
            Return "ln(3)"
        Otherwise If argument == "-3/4":
            Return "-ln(2)"
        Otherwise If argument == "-4/3":
            Return "-ln(3)"
        Otherwise:
            Return "ln(" + argument + " + sqrt(" + argument + "^2 + 1))"
    
    Otherwise If function_name == "acosh":
        Note: Domain: x ≥ 1, acosh(x) = ln(x + sqrt(x² - 1))
        If argument == "1":
            Return "0"
        Otherwise If argument == "5/4":
            Return "ln(2)"
        Otherwise If argument == "5/3":
            Return "ln(3)"
        Otherwise:
            Note: Check domain
            Return "ln(" + argument + " + sqrt(" + argument + "^2 - 1))"
    
    Otherwise If function_name == "atanh":
        Note: Domain: -1 < x < 1, atanh(x) = (1/2)*ln((1+x)/(1-x))
        If argument == "0":
            Return "0"
        Otherwise If argument == "3/5":
            Return "ln(2)/2"
        Otherwise If argument == "4/5":
            Return "ln(3)/2"
        Otherwise If argument == "-3/5":
            Return "-ln(2)/2"
        Otherwise If argument == "-4/5":
            Return "-ln(3)/2"
        Otherwise If argument == "1":
            Return "infinity"
        Otherwise If argument == "-1":
            Return "-infinity"
        Otherwise:
            Return "(1/2)*ln((1 + " + argument + ")/(1 - " + argument + "))"
    
    Otherwise:
        Return "unknown_inverse_hyperbolic_function"

Process called "hyperbolic_identities" that takes expression as String returns String:
    Note: Apply hyperbolic identities for simplification
    Note: Implements fundamental hyperbolic identities and transformations
    
    Note: Fundamental hyperbolic identity: cosh²(x) - sinh²(x) = 1
    If expression == "cosh^2(x) - sinh^2(x)":
        Return "1"
    
    Otherwise If expression == "1 + sinh^2(x)":
        Return "cosh^2(x)"
    
    Otherwise If expression == "cosh^2(x) - 1":
        Return "sinh^2(x)"
    
    Note: Other hyperbolic identities
    If expression == "1 - tanh^2(x)":
        Return "1/cosh^2(x)"
    
    Otherwise If expression == "coth^2(x) - 1":
        Return "1/sinh^2(x)"
    
    Note: Addition formulas
    If expression contains "sinh(" and ") + sinh(":
        Let angles = "extract_sum_angles_from_" + expression
        Return "sinh(" + angles["first"] + ")*cosh(" + angles["second"] + ") + cosh(" + angles["first"] + ")*sinh(" + angles["second"] + ")"
    
    Otherwise If expression contains "cosh(" and ") + cosh(":
        Let angles = "extract_sum_angles_from_" + expression
        Return "cosh(" + angles["first"] + ")*cosh(" + angles["second"] + ") + sinh(" + angles["first"] + ")*sinh(" + angles["second"] + ")"
    
    Note: Double angle formulas
    If expression contains "sinh(2*":
        Let angle = "extract_angle_from_" + expression
        Return "2*sinh(" + angle + ")*cosh(" + angle + ")"
    
    Otherwise If expression contains "cosh(2*":
        Let angle = "extract_angle_from_" + expression
        Return "cosh^2(" + angle + ") + sinh^2(" + angle + ")"
    
    Otherwise If expression contains "tanh(2*":
        Let angle = "extract_angle_from_" + expression
        Return "2*tanh(" + angle + ")/(1 + tanh^2(" + angle + "))"
    
    Note: Relationship with trigonometric functions
    If expression contains "sinh(i*":
        Let angle = "extract_imaginary_angle_from_" + expression
        Return "i*sin(" + angle + ")"
    
    Otherwise If expression contains "cosh(i*":
        Let angle = "extract_imaginary_angle_from_" + expression
        Return "cos(" + angle + ")"
    
    Otherwise If expression contains "tanh(i*":
        Let angle = "extract_imaginary_angle_from_" + expression
        Return "i*tan(" + angle + ")"
    
    Note: Reciprocal identities
    If expression contains "csch(":
        Let angle = "extract_angle_from_csch_" + expression
        Return "1/sinh(" + angle + ")"
    
    Otherwise If expression contains "sech(":
        Let angle = "extract_angle_from_sech_" + expression
        Return "1/cosh(" + angle + ")"
    
    Otherwise If expression contains "coth(":
        Let angle = "extract_angle_from_coth_" + expression
        Return "cosh(" + angle + ")/sinh(" + angle + ")"
    
    Note: General identity application
    Otherwise:
        Return "apply_hyperbolic_identity_to_" + expression

Note: =====================================================================
Note: GAMMA AND BETA FUNCTION OPERATIONS
Note: =====================================================================

Process called "gamma_function" that takes argument as String returns String:
    Note: Gamma function Γ(z) with complex argument
    Note: Γ(n) = (n-1)! for positive integers, with analytic continuation
    
    If argument == "1":
        Return "1"
    
    If argument == "2":
        Return "1"
    
    If argument == "3":
        Return "2"
    
    If argument == "4":
        Return "6"
    
    If argument == "5":
        Return "24"
    
    If argument == "6":
        Return "120"
    
    Note: Special fractional values
    If argument == "1/2":
        Return "sqrt(pi)"
    
    If argument == "3/2":
        Return "sqrt(pi)/2"
    
    If argument == "5/2":
        Return "3*sqrt(pi)/4"
    
    If argument == "-1/2":
        Return "-2*sqrt(pi)"
    
    If argument == "-3/2":
        Return "4*sqrt(pi)/3"
    
    Note: Check for poles (negative integers)
    If argument == "0" or argument == "-1" or argument == "-2":
        Return "undefined"
    
    Note: Reflection formula for negative arguments: Γ(z)Γ(1-z) = π/sin(πz)
    If argument starts with "-" and not argument == "-1/2" and not argument == "-3/2":
        Let positive_part be argument without "-" prefix
        Return "pi / (sin(pi*" + argument + ") * gamma(1 - " + argument + "))"
    
    Note: Use recurrence relation for large positive integers
    If "is_positive_integer(" + argument + ") and " + argument + " > 10":
        Let n_minus_1 be argument + " - 1"
        Return "(" + n_minus_1 + ") * gamma(" + n_minus_1 + ")"
    
    Note: General case - symbolic representation
    Return "Gamma(" + argument + ")"

Process called "log_gamma_function" that takes argument as String returns String:
    Note: Logarithm of gamma function for numerical stability
    Note: ln(Γ(z)) avoids overflow for large arguments
    
    If argument == "1" or argument == "2":
        Return "0"
    
    If argument == "3":
        Return "ln(2)"
    
    If argument == "4":
        Return "ln(6)"
    
    If argument == "5":
        Return "ln(24)"
    
    If argument == "6":
        Return "ln(120)"
    
    Note: Special fractional values
    If argument == "1/2":
        Return "ln(sqrt(pi))"
    
    If argument == "3/2":
        Return "ln(sqrt(pi)/2)"
    
    If argument == "5/2":
        Return "ln(3*sqrt(pi)/4)"
    
    Note: Check for poles
    If argument == "0" or argument starts with "-" and "is_integer(" + argument + ")":
        Return "undefined"
    
    Note: Use Stirling's approximation for large arguments
    If "is_large_positive(" + argument + ")":
        Return "stirling_log_gamma_approximation(" + argument + ")"
    
    Note: Recurrence relation: ln(Γ(z+1)) = ln(z) + ln(Γ(z))
    If "is_positive(" + argument + ") and " + argument + " > 10":
        Let z_minus_1 be argument + " - 1"
        Return "ln(" + z_minus_1 + ") + log_gamma(" + z_minus_1 + ")"
    
    Note: General case
    Return "log_Gamma(" + argument + ")"

Process called "beta_function" that takes argument_a as String, argument_b as String returns String:
    Note: Beta function B(a,b) = Γ(a)Γ(b)/Γ(a+b)
    Note: Also B(a,b) = ∫₀¹ t^(a-1)(1-t)^(b-1) dt
    
    Note: Symmetry: B(a,b) = B(b,a)
    If argument_a == argument_b:
        Note: B(a,a) = Γ(a)²/Γ(2a)
        Return "Gamma(" + argument_a + ")^2 / Gamma(2*" + argument_a + ")"
    
    Note: Special cases with integer arguments
    If argument_a == "1" and argument_b == "1":
        Return "1"
    
    If argument_a == "1":
        Return "1/" + argument_b
    
    If argument_b == "1":
        Return "1/" + argument_a
    
    If argument_a == "2" and argument_b == "2":
        Return "1/6"
    
    If argument_a == "1" and argument_b == "2":
        Return "1/2"
    
    If argument_a == "2" and argument_b == "1":
        Return "1/2"
    
    Note: Special cases with half-integer arguments
    If argument_a == "1/2" and argument_b == "1/2":
        Return "pi"
    
    If argument_a == "1/2" and argument_b == "1":
        Return "2"
    
    If argument_a == "1" and argument_b == "1/2":
        Return "2"
    
    If argument_a == "1/2" and argument_b == "3/2":
        Return "pi/2"
    
    If argument_a == "3/2" and argument_b == "1/2":
        Return "pi/2"
    
    Note: General definition using gamma functions
    Let sum_ab be argument_a + " + " + argument_b
    Return "Gamma(" + argument_a + ") * Gamma(" + argument_b + ") / Gamma(" + sum_ab + ")"

Process called "incomplete_gamma" that takes s as String, x as String returns String:
    Note: Incomplete gamma function γ(s,x)
    Note: γ(s,x) = ∫₀ˣ t^(s-1) e^(-t) dt, lower incomplete gamma
    
    If x == "0":
        Return "0"
    
    If s == "1":
        Note: γ(1,x) = 1 - e^(-x)
        Return "1 - exp(-" + x + ")"
    
    If s == "2":
        Note: γ(2,x) = 1 - (1+x)e^(-x)
        Return "1 - (1 + " + x + ") * exp(-" + x + ")"
    
    If s == "3":
        Note: γ(3,x) = 2 - (2 + 2x + x²)e^(-x)
        Return "2 - (2 + 2*" + x + " + " + x + "^2) * exp(-" + x + ")"
    
    Note: Special case for half-integer s
    If s == "1/2":
        Note: γ(1/2,x) = sqrt(π) * erf(sqrt(x))
        Return "sqrt(pi) * erf(sqrt(" + x + "))"
    
    If s == "3/2":
        Note: γ(3/2,x) = sqrt(π)*erf(sqrt(x)) - sqrt(x)*exp(-x)
        Return "sqrt(pi) * erf(sqrt(" + x + ")) - sqrt(" + x + ") * exp(-" + x + ")"
    
    Note: For negative x, function is not defined in real domain
    If x starts with "-":
        Return "undefined"
    
    Note: Series expansion for small x
    If "is_small(" + x + ")":
        Return "series_expansion_incomplete_gamma(" + s + ", " + x + ")"
    
    Note: Asymptotic expansion for large x
    If "is_large(" + x + ")":
        Return "Gamma(" + s + ") - continued_fraction_incomplete_gamma(" + s + ", " + x + ")"
    
    Note: General case
    Return "incomplete_gamma(" + s + ", " + x + ")"

Process called "incomplete_beta" that takes a as String, b as String, x as String returns String:
    Note: Incomplete beta function I_x(a,b)
    Note: I_x(a,b) = B_x(a,b)/B(a,b) where B_x(a,b) = ∫₀ˣ t^(a-1)(1-t)^(b-1) dt
    
    If x == "0":
        Return "0"
    
    If x == "1":
        Return "1"
    
    Note: Domain check: 0 ≤ x ≤ 1
    If x starts with "-" or "greater_than_one(" + x + ")":
        Return "undefined"
    
    Note: Special cases with unit parameters
    If a == "1" and b == "1":
        Return x
    
    If a == "1":
        Note: I_x(1,b) = 1 - (1-x)^b
        Return "1 - (1 - " + x + ")^" + b
    
    If b == "1":
        Note: I_x(a,1) = x^a
        Return x + "^" + a
    
    Note: Symmetry relation: I_x(a,b) = 1 - I_(1-x)(b,a)
    If "use_symmetry_relation(" + a + ", " + b + ", " + x + ")":
        Let one_minus_x be "1 - " + x
        Return "1 - incomplete_beta(" + b + ", " + a + ", " + one_minus_x + ")"
    
    Note: Special case a=1/2, b=1/2 (arcsine distribution)
    If a == "1/2" and b == "1/2":
        Return "(2/pi) * arcsin(sqrt(" + x + "))"
    
    Note: Integer cases using binomial expansion
    If "is_positive_integer(" + a + ") and is_positive_integer(" + b + ")":
        Return "binomial_incomplete_beta(" + a + ", " + b + ", " + x + ")"
    
    Note: Continued fraction representation
    If "use_continued_fraction(" + a + ", " + b + ", " + x + ")":
        Return "continued_fraction_incomplete_beta(" + a + ", " + b + ", " + x + ")"
    
    Note: Series representation
    If "use_series_expansion(" + a + ", " + b + ", " + x + ")":
        Return "series_incomplete_beta(" + a + ", " + b + ", " + x + ")"
    
    Note: General case
    Return "I_" + x + "(" + a + ", " + b + ")"

Process called "polygamma_function" that takes order as Integer, argument as String returns String:
    Note: Polygamma function ψ^(n)(z) - nth derivative of digamma
    Note: ψ^(n)(z) = d^(n+1)/dz^(n+1) ln(Γ(z)), ψ^(0) is digamma
    
    If order == 0:
        Note: Digamma function ψ(z) = Γ'(z)/Γ(z)
        If argument == "1":
            Return "-gamma_constant"
        Otherwise If argument == "2":
            Return "1 - gamma_constant"
        Otherwise If argument == "3":
            Return "3/2 - gamma_constant"
        Otherwise If argument == "1/2":
            Return "-gamma_constant - 2*ln(2)"
        Otherwise:
            Return "digamma(" + argument + ")"
    
    Otherwise If order == 1:
        Note: Trigamma function ψ^(1)(z)
        If argument == "1":
            Return "pi^2/6"
        Otherwise If argument == "2":
            Return "pi^2/6 - 1"
        Otherwise If argument == "1/2":
            Return "pi^2/2"
        Otherwise:
            Return "trigamma(" + argument + ")"
    
    Otherwise If order == 2:
        Note: Tetragamma function ψ^(2)(z)
        If argument == "1":
            Return "-2*zeta(3)"
        Otherwise:
            Return "tetragamma(" + argument + ")"
    
    Otherwise If order < 0:
        Return "undefined"
    
    Note: Recurrence relation: ψ^(n)(z+1) = ψ^(n)(z) + (-1)^n * n! / z^(n+1)
    If "use_recurrence_relation(" + order + ", " + argument + ")":
        Let z_minus_1 be argument + " - 1"
        Let factorial_n be "factorial(" + order + ")"
        Let sign be "(-1)^" + order
        Return "polygamma(" + order + ", " + z_minus_1 + ") + " + sign + " * " + factorial_n + " / (" + z_minus_1 + ")^" + (order + 1)
    
    Note: Series representation for general order
    If order > 10:
        Return "high_order_polygamma_series(" + order + ", " + argument + ")"
    
    Note: General case
    Return "polygamma(" + order + ", " + argument + ")"

Note: =====================================================================
Note: ERROR FUNCTION OPERATIONS
Note: =====================================================================

Process called "error_function" that takes argument as String returns String:
    Note: Error function erf(x) = (2/√π)∫₀ˣ e^(-t²) dt
    Note: Fundamental function in probability and statistics, related to normal distribution
    
    If argument == "0":
        Return "0"
    
    If argument == "infinity":
        Return "1"
    
    If argument == "-infinity":
        Return "-1"
    
    Note: erf is an odd function: erf(-x) = -erf(x)
    If argument starts with "-":
        Let positive_arg be argument without "-" prefix
        Return "-erf(" + positive_arg + ")"
    
    Note: Special values for common arguments
    If argument == "1":
        Return "erf(1)"
    
    If argument == "sqrt(2)":
        Note: Related to normal distribution: erf(sqrt(2)/2) ≈ 0.6827
        Return "erf(sqrt(2))"
    
    Note: Series expansion for small arguments
    If "is_small(" + argument + ")":
        Return "(2/sqrt(pi)) * (" + argument + " - " + argument + "^3/3 + " + argument + "^5/(5*2!) - " + argument + "^7/(7*3!) + ...)"
    
    Note: Asymptotic expansion for large arguments
    If "is_large(" + argument + ")":
        Return "1 - (1/sqrt(pi)) * exp(-" + argument + "^2) / " + argument + " * (1 - 1/(2*" + argument + "^2) + 3/(4*" + argument + "^4) - ...)"
    
    Note: Relationship with complementary error function
    Note: erf(x) = 1 - erfc(x)
    
    Note: General case
    Return "erf(" + argument + ")"

Process called "complementary_error_function" that takes argument as String returns String:
    Note: Complementary error function erfc(x) = 1 - erf(x)
    Note: erfc(x) = (2/√π)∫ₓ^∞ e^(-t²) dt, better for numerical stability when x is large
    
    If argument == "0":
        Return "1"
    
    If argument == "infinity":
        Return "0"
    
    If argument == "-infinity":
        Return "2"
    
    Note: Relationship with error function
    If argument starts with "-":
        Let positive_arg be argument without "-" prefix
        Return "2 - erfc(" + positive_arg + ")"
    
    Note: Direct computation using definition
    If argument == "1":
        Return "1 - erf(1)"
    
    If argument == "sqrt(2)":
        Return "1 - erf(sqrt(2))"
    
    Note: Continued fraction representation for positive arguments
    If "is_positive(" + argument + ")":
        Return "(1/sqrt(pi)) * exp(-" + argument + "^2) * continued_fraction_erfc(" + argument + ")"
    
    Note: Series expansion for small arguments
    If "is_small(" + argument + ")":
        Return "1 - (2/sqrt(pi)) * (" + argument + " - " + argument + "^3/3 + " + argument + "^5/(5*2!) - ...)"
    
    Note: Asymptotic expansion for large positive arguments
    If "is_large_positive(" + argument + ")":
        Return "(1/sqrt(pi)) * exp(-" + argument + "^2) / " + argument + " * (1 - 1/(2*" + argument + "^2) + 3/(4*" + argument + "^4) - ...)"
    
    Note: General case
    Return "erfc(" + argument + ")"

Process called "scaled_complementary_error_function" that takes argument as String returns String:
    Note: Scaled complementary error function erfcx(x) = e^(x²)erfc(x)
    Note: Numerically stable for large |x|, avoids underflow in erfc(x)
    
    If argument == "0":
        Return "1"
    
    If argument == "infinity":
        Return "0"
    
    If argument == "-infinity":
        Return "infinity"
    
    Note: Definition: erfcx(x) = exp(x²) * erfc(x)
    Note: For large positive x, this avoids the exp(-x²) underflow in erfc(x)
    
    Note: Symmetry properties
    If argument starts with "-":
        Let positive_arg be argument without "-" prefix
        Note: erfcx(-x) = exp(x²) * (2 - erfc(x)) = 2*exp(x²) - erfcx(x)
        Return "2 * exp(" + positive_arg + "^2) - erfcx(" + positive_arg + ")"
    
    Note: For small arguments, use series expansion
    If "is_small(" + argument + ")":
        Return "1 - (2/sqrt(pi)) * " + argument + " * (1 - " + argument + "^2/3 + " + argument + "^4/(5*2!) - ...)"
    
    Note: For large positive arguments, use asymptotic expansion
    If "is_large_positive(" + argument + ")":
        Return "(1/sqrt(pi)) / " + argument + " * (1 - 1/(2*" + argument + "^2) + 3/(4*" + argument + "^4) - 15/(8*" + argument + "^6) + ...)"
    
    Note: Continued fraction representation
    If "use_continued_fraction(" + argument + ")":
        Return "(1/sqrt(pi)) * continued_fraction_erfcx(" + argument + ")"
    
    Note: General case
    Return "erfcx(" + argument + ")"

Process called "imaginary_error_function" that takes argument as String returns String:
    Note: Imaginary error function erfi(x) = -i·erf(ix)
    Note: erfi(x) = (2/√π)∫₀ˣ e^(t²) dt, related to Dawson function
    
    If argument == "0":
        Return "0"
    
    If argument == "infinity":
        Return "infinity"
    
    If argument == "-infinity":
        Return "-infinity"
    
    Note: erfi is an odd function: erfi(-x) = -erfi(x)
    If argument starts with "-":
        Let positive_arg be argument without "-" prefix
        Return "-erfi(" + positive_arg + ")"
    
    Note: Definition in terms of error function
    Note: erfi(x) = -i * erf(i*x) = (2/√π)∫₀ˣ e^(t²) dt
    
    Note: Series expansion for small arguments
    If "is_small(" + argument + ")":
        Return "(2/sqrt(pi)) * (" + argument + " + " + argument + "^3/3 + " + argument + "^5/(5*2!) + " + argument + "^7/(7*3!) + ...)"
    
    Note: Relationship with Dawson function: erfi(x) = (2/√π) * exp(x²) * D(x)
    Note: where D(x) is the Dawson function
    If "use_dawson_relation(" + argument + ")":
        Return "(2/sqrt(pi)) * exp(" + argument + "^2) * dawson(" + argument + ")"
    
    Note: Asymptotic expansion for large arguments
    If "is_large(" + argument + ")":
        Return "(1/sqrt(pi)) * exp(" + argument + "^2) / " + argument + " * (1 + 1/(2*" + argument + "^2) + 3/(4*" + argument + "^4) + 15/(8*" + argument + "^6) + ...)"
    
    Note: Continued fraction for moderate arguments
    If "use_continued_fraction(" + argument + ")":
        Return "continued_fraction_erfi(" + argument + ")"
    
    Note: General case
    Return "erfi(" + argument + ")"

Process called "fresnel_integrals" that takes argument as String returns Dictionary[String, String]:
    Note: Fresnel integrals S(x) and C(x)
    Note: C(x) = ∫₀ˣ cos(πt²/2) dt, S(x) = ∫₀ˣ sin(πt²/2) dt
    
    Let fresnel_result be {
        "fresnel_c": "",
        "fresnel_s": "",
        "argument": argument
    }
    
    If argument == "0":
        Set fresnel_result["fresnel_c"] to "0"
        Set fresnel_result["fresnel_s"] to "0"
        Return fresnel_result
    
    If argument == "infinity":
        Set fresnel_result["fresnel_c"] to "1/2"
        Set fresnel_result["fresnel_s"] to "1/2"
        Return fresnel_result
    
    If argument == "-infinity":
        Set fresnel_result["fresnel_c"] to "-1/2"
        Set fresnel_result["fresnel_s"] to "-1/2"
        Return fresnel_result
    
    Note: Fresnel integrals are odd functions
    If argument starts with "-":
        Let positive_arg be argument without "-" prefix
        Let positive_result be fresnel_integrals(positive_arg)
        Set fresnel_result["fresnel_c"] to "-" + positive_result["fresnel_c"]
        Set fresnel_result["fresnel_s"] to "-" + positive_result["fresnel_s"]
        Return fresnel_result
    
    Note: Series expansion for small arguments
    If "is_small(" + argument + ")":
        Note: C(x) = x - (π²x⁵)/(40) + (π⁴x⁹)/(3456) - ...
        Note: S(x) = (πx³)/(6) - (π³x⁷)/(336) + (π⁵x¹¹)/(42240) - ...
        Set fresnel_result["fresnel_c"] to argument + " - (pi^2 * " + argument + "^5)/40 + (pi^4 * " + argument + "^9)/3456 - ..."
        Set fresnel_result["fresnel_s"] to "(pi * " + argument + "^3)/6 - (pi^3 * " + argument + "^7)/336 + (pi^5 * " + argument + "^11)/42240 - ..."
        Return fresnel_result
    
    Note: Asymptotic expansion for large arguments
    If "is_large(" + argument + ")":
        Note: C(x) ≈ 1/2 + (1/(π*x)) * sin(π*x²/2)
        Note: S(x) ≈ 1/2 - (1/(π*x)) * cos(π*x²/2)
        Set fresnel_result["fresnel_c"] to "1/2 + (1/(pi * " + argument + ")) * sin(pi * " + argument + "^2 / 2)"
        Set fresnel_result["fresnel_s"] to "1/2 - (1/(pi * " + argument + ")) * cos(pi * " + argument + "^2 / 2)"
        Return fresnel_result
    
    Note: Relationship with complex error function
    Note: C(x) + iS(x) = (1+i)/2 * erf((1+i)*sqrt(π/2)*x)
    If "use_complex_erf_relation(" + argument + ")":
        Let complex_factor be "(1 + i) / 2"
        Let erf_argument be "(1 + i) * sqrt(pi/2) * " + argument
        Set fresnel_result["fresnel_c"] to "real_part(" + complex_factor + " * erf(" + erf_argument + "))"
        Set fresnel_result["fresnel_s"] to "imaginary_part(" + complex_factor + " * erf(" + erf_argument + "))"
        Return fresnel_result
    
    Note: General case using series or numerical integration
    Set fresnel_result["fresnel_c"] to "fresnel_c(" + argument + ")"
    Set fresnel_result["fresnel_s"] to "fresnel_s(" + argument + ")"
    
    Return fresnel_result

Note: =====================================================================
Note: BESSEL FUNCTION OPERATIONS
Note: =====================================================================

Process called "bessel_j" that takes order as String, argument as String returns String:
    Note: Bessel function of the first kind J_ν(x)
    Note: Solution to Bessel's differential equation, regular at x=0
    
    If argument == "0":
        If order == "0":
            Return "1"
        Otherwise:
            Return "0"
    
    Note: Special cases for integer orders
    If order == "0":
        Note: J₀(x) is the most common Bessel function
        If argument == "infinity":
            Return "0"
        Otherwise:
            Return "J_0(" + argument + ")"
    
    Otherwise If order == "1":
        Note: J₁(x) has zero at x=0
        If argument == "0":
            Return "0"
        Otherwise:
            Return "J_1(" + argument + ")"
    
    Otherwise If order == "2":
        Return "J_2(" + argument + ")"
    
    Note: Negative integer orders: J₋ₙ(x) = (-1)ⁿJₙ(x)
    If order starts with "-" and "is_integer(" + order + ")":
        Let positive_order be order without "-" prefix
        Let sign_factor be "(-1)^" + positive_order
        Return sign_factor + " * J_" + positive_order + "(" + argument + ")"
    
    Note: Half-integer orders
    If order == "1/2":
        Note: J₁/₂(x) = sqrt(2/(πx)) * sin(x)
        Return "sqrt(2/(pi * " + argument + ")) * sin(" + argument + ")"
    
    Otherwise If order == "-1/2":
        Note: J₋₁/₂(x) = sqrt(2/(πx)) * cos(x)
        Return "sqrt(2/(pi * " + argument + ")) * cos(" + argument + ")"
    
    Otherwise If order == "3/2":
        Note: J₃/₂(x) = sqrt(2/(πx)) * (sin(x)/x - cos(x))
        Return "sqrt(2/(pi * " + argument + ")) * (sin(" + argument + ")/(" + argument + ") - cos(" + argument + "))"
    
    Note: Series expansion for small arguments
    If "is_small(" + argument + ")":
        Return "(" + argument + "/2)^" + order + " / Gamma(" + order + " + 1) * hypergeometric_0F1(" + order + " + 1, -(" + argument + "/2)^2)"
    
    Note: Asymptotic expansion for large arguments
    If "is_large(" + argument + ")":
        Return "sqrt(2/(pi * " + argument + ")) * cos(" + argument + " - (" + order + " + 1/2) * pi/2 + pi/4)"
    
    Note: General case
    Return "J_" + order + "(" + argument + ")"

Process called "bessel_y" that takes order as String, argument as String returns String:
    Note: Bessel function of the second kind Y_ν(x)
    Note: Also called Neumann function, singular at x=0
    
    If argument == "0":
        Return "-infinity"
    
    If argument starts with "-":
        Return "undefined"
    
    Note: Special cases for integer orders
    If order == "0":
        Note: Y₀(x) is singular at x=0
        Return "Y_0(" + argument + ")"
    
    Otherwise If order == "1":
        Return "Y_1(" + argument + ")"
    
    Otherwise If order == "2":
        Return "Y_2(" + argument + ")"
    
    Note: Negative integer orders: Y₋ₙ(x) = (-1)ⁿYₙ(x)
    If order starts with "-" and "is_integer(" + order + ")":
        Let positive_order be order without "-" prefix
        Let sign_factor be "(-1)^" + positive_order
        Return sign_factor + " * Y_" + positive_order + "(" + argument + ")"
    
    Note: Half-integer orders
    If order == "1/2":
        Note: Y₁/₂(x) = -sqrt(2/(πx)) * cos(x)
        Return "-sqrt(2/(pi * " + argument + ")) * cos(" + argument + ")"
    
    Otherwise If order == "-1/2":
        Note: Y₋₁/₂(x) = sqrt(2/(πx)) * sin(x)
        Return "sqrt(2/(pi * " + argument + ")) * sin(" + argument + ")"
    
    Otherwise If order == "3/2":
        Note: Y₃/₂(x) = -sqrt(2/(πx)) * (cos(x)/x + sin(x))
        Return "-sqrt(2/(pi * " + argument + ")) * (cos(" + argument + ")/(" + argument + ") + sin(" + argument + "))"
    
    Note: Connection with Bessel J for non-integer orders
    If not "is_integer(" + order + ")":
        Note: Y_ν(x) = [J_ν(x)cos(νπ) - J₋ν(x)] / sin(νπ)
        Return "(J_" + order + "(" + argument + ") * cos(" + order + " * pi) - J_" + "-" + order + "(" + argument + ")) / sin(" + order + " * pi)"
    
    Note: Asymptotic expansion for large arguments
    If "is_large(" + argument + ")":
        Return "sqrt(2/(pi * " + argument + ")) * sin(" + argument + " - (" + order + " + 1/2) * pi/2 + pi/4)"
    
    Note: General case
    Return "Y_" + order + "(" + argument + ")"

Process called "modified_bessel_i" that takes order as String, argument as String returns String:
    Note: Modified Bessel function of the first kind I_ν(x)
    Note: I_ν(x) = i^(-ν) J_ν(ix), exponentially growing solution
    
    If argument == "0":
        If order == "0":
            Return "1"
        Otherwise:
            Return "0"
    
    Note: Special cases for integer orders
    If order == "0":
        Note: I₀(x) is even function, grows exponentially
        Return "I_0(" + argument + ")"
    
    Otherwise If order == "1":
        Note: I₁(x) is odd function
        If argument == "0":
            Return "0"
        Otherwise:
            Return "I_1(" + argument + ")"
    
    Otherwise If order == "2":
        Return "I_2(" + argument + ")"
    
    Note: Negative integer orders: I₋ₙ(x) = Iₙ(x)
    If order starts with "-" and "is_integer(" + order + ")":
        Let positive_order be order without "-" prefix
        Return "I_" + positive_order + "(" + argument + ")"
    
    Note: Half-integer orders
    If order == "1/2":
        Note: I₁/₂(x) = sqrt(2/(πx)) * sinh(x)
        Return "sqrt(2/(pi * " + argument + ")) * sinh(" + argument + ")"
    
    Otherwise If order == "-1/2":
        Note: I₋₁/₂(x) = sqrt(2/(πx)) * cosh(x)
        Return "sqrt(2/(pi * " + argument + ")) * cosh(" + argument + ")"
    
    Otherwise If order == "3/2":
        Note: I₃/₂(x) = sqrt(2/(πx)) * (cosh(x) - sinh(x)/x)
        Return "sqrt(2/(pi * " + argument + ")) * (cosh(" + argument + ") - sinh(" + argument + ")/(" + argument + "))"
    
    Note: Series expansion for small arguments
    If "is_small(" + argument + ")":
        Return "(" + argument + "/2)^" + order + " / Gamma(" + order + " + 1) * hypergeometric_0F1(" + order + " + 1, (" + argument + "/2)^2)"
    
    Note: Asymptotic expansion for large arguments
    If "is_large(" + argument + ")":
        Return "exp(" + argument + ") / sqrt(2 * pi * " + argument + ") * (1 - (4*" + order + "^2 - 1)/(8*" + argument + ") + ...)"
    
    Note: General case
    Return "I_" + order + "(" + argument + ")"

Process called "modified_bessel_k" that takes order as String, argument as String returns String:
    Note: Modified Bessel function of the second kind K_ν(x)
    Note: K_ν(x) = (π/2) * [I₋ν(x) - Iν(x)] / sin(νπ), exponentially decreasing
    
    If argument == "0":
        Return "infinity"
    
    If argument starts with "-":
        Return "undefined"
    
    If argument == "infinity":
        Return "0"
    
    Note: Special cases for integer orders
    If order == "0":
        Note: K₀(x) is logarithmically singular at x=0
        Return "K_0(" + argument + ")"
    
    Otherwise If order == "1":
        Return "K_1(" + argument + ")"
    
    Otherwise If order == "2":
        Return "K_2(" + argument + ")"
    
    Note: Symmetry: K₋ν(x) = Kν(x)
    If order starts with "-":
        Let positive_order be order without "-" prefix
        Return "K_" + positive_order + "(" + argument + ")"
    
    Note: Half-integer orders
    If order == "1/2":
        Note: K₁/₂(x) = sqrt(π/(2x)) * exp(-x)
        Return "sqrt(pi/(2 * " + argument + ")) * exp(-" + argument + ")"
    
    Otherwise If order == "3/2":
        Note: K₃/₂(x) = sqrt(π/(2x)) * exp(-x) * (1 + 1/x)
        Return "sqrt(pi/(2 * " + argument + ")) * exp(-" + argument + ") * (1 + 1/(" + argument + "))"
    
    Note: Connection formula for non-integer orders
    If not "is_integer(" + order + ")":
        Note: K_ν(x) = (π/2) * [I₋ν(x) - Iν(x)] / sin(νπ)
        Return "(pi/2) * (I_" + "-" + order + "(" + argument + ") - I_" + order + "(" + argument + ")) / sin(" + order + " * pi)"
    
    Note: Series expansion for small arguments
    If "is_small(" + argument + ") and " + order + " == 0":
        Return "-ln(" + argument + "/2) - gamma_constant + series_K0_small(" + argument + ")"
    
    Note: Asymptotic expansion for large arguments
    If "is_large(" + argument + ")":
        Return "sqrt(pi/(2 * " + argument + ")) * exp(-" + argument + ") * (1 + (4*" + order + "^2 - 1)/(8*" + argument + ") + ...)"
    
    Note: General case
    Return "K_" + order + "(" + argument + ")"

Process called "hankel_functions" that takes kind as Integer, order as String, argument as String returns String:
    Note: Hankel functions H^(1)_ν(x) and H^(2)_ν(x)
    Note: H^(1)_ν(x) = J_ν(x) + iY_ν(x), H^(2)_ν(x) = J_ν(x) - iY_ν(x)
    
    If kind != 1 and kind != 2:
        Return "undefined"
    
    If argument == "0":
        If order == "0":
            Return "1"
        Otherwise:
            Return "undefined"
    
    If kind == 1:
        Note: Hankel function of the first kind H^(1)_ν(x)
        If order == "0":
            Return "J_0(" + argument + ") + i * Y_0(" + argument + ")"
        Otherwise If order == "1":
            Return "J_1(" + argument + ") + i * Y_1(" + argument + ")"
        Otherwise:
            Return "J_" + order + "(" + argument + ") + i * Y_" + order + "(" + argument + ")"
    
    Otherwise If kind == 2:
        Note: Hankel function of the second kind H^(2)_ν(x)
        If order == "0":
            Return "J_0(" + argument + ") - i * Y_0(" + argument + ")"
        Otherwise If order == "1":
            Return "J_1(" + argument + ") - i * Y_1(" + argument + ")"
        Otherwise:
            Return "J_" + order + "(" + argument + ") - i * Y_" + order + "(" + argument + ")"
    
    Note: Asymptotic behavior for large arguments
    If "is_large(" + argument + ")":
        Let phase be argument + " - (" + order + " + 1/2) * pi/2"
        If kind == 1:
            Return "sqrt(2/(pi * " + argument + ")) * exp(i * (" + phase + "))"
        Otherwise:
            Return "sqrt(2/(pi * " + argument + ")) * exp(-i * (" + phase + "))"
    
    Note: Connection with modified Bessel functions for imaginary arguments
    If argument starts with "i*":
        Let real_part be argument without "i*" prefix
        If kind == 1:
            Return "(2*i/pi) * K_" + order + "(" + real_part + ")"
        Otherwise:
            Return "(-2*i/pi) * K_" + order + "(" + real_part + ")"
    
    Note: General case
    Return "H^(" + kind + ")_" + order + "(" + argument + ")"

Process called "spherical_bessel" that takes order as Integer, argument as String returns String:
    Note: Spherical Bessel functions j_n(x), y_n(x)
    Note: j_n(x) = sqrt(π/(2x)) * J_{n+1/2}(x), y_n(x) = sqrt(π/(2x)) * Y_{n+1/2}(x)
    
    If argument == "0":
        If order == 0:
            Return "1"
        Otherwise:
            Return "0"
    
    Note: Explicit formulas for low orders
    If order == 0:
        Note: j₀(x) = sin(x)/x
        Return "sin(" + argument + ") / (" + argument + ")"
    
    Otherwise If order == 1:
        Note: j₁(x) = sin(x)/x² - cos(x)/x
        Return "sin(" + argument + ") / (" + argument + ")^2 - cos(" + argument + ") / (" + argument + ")"
    
    Otherwise If order == 2:
        Note: j₂(x) = (3/x³ - 1/x)sin(x) - (3/x²)cos(x)
        Return "(3/(" + argument + ")^3 - 1/(" + argument + ")) * sin(" + argument + ") - (3/(" + argument + ")^2) * cos(" + argument + ")"
    
    Otherwise If order == -1:
        Note: j₋₁(x) = cos(x)/x
        Return "cos(" + argument + ") / (" + argument + ")"
    
    Otherwise If order == -2:
        Note: j₋₂(x) = -cos(x)/x² - sin(x)/x
        Return "-cos(" + argument + ") / (" + argument + ")^2 - sin(" + argument + ") / (" + argument + ")"
    
    Note: Spherical Neumann functions (second kind)
    Note: For negative orders beyond -2, return y_n functions
    If order < -2:
        Let positive_order be -order - 1
        Note: y_n(x) = (-1)^{n+1} j_{-n-1}(x)
        Let sign_factor be "(-1)^" + (positive_order + 1)
        Return sign_factor + " * spherical_bessel(" + (-positive_order - 1) + ", " + argument + ")"
    
    Note: Recurrence relations for higher orders
    If order > 2:
        Note: j_n(x) = (2n-1)/x * j_{n-1}(x) - j_{n-2}(x)
        Let n_minus_1 be order - 1
        Let n_minus_2 be order - 2
        Return "(" + (2 * order - 1) + ") / (" + argument + ") * spherical_bessel(" + n_minus_1 + ", " + argument + ") - spherical_bessel(" + n_minus_2 + ", " + argument + ")"
    
    Note: Connection with cylindrical Bessel functions
    Let half_order be order + " + 1/2"
    Return "sqrt(pi / (2 * " + argument + ")) * J_" + half_order + "(" + argument + ")"
    
    Note: General case
    Return "j_" + order + "(" + argument + ")"

Note: =====================================================================
Note: ORTHOGONAL POLYNOMIAL OPERATIONS
Note: =====================================================================

Process called "legendre_polynomial" that takes degree as Integer, argument as String returns String:
    Note: Legendre polynomial P_n(x)
    Note: Orthogonal on [-1,1] with weight 1, solutions to Legendre's equation
    
    If degree < 0:
        Return "undefined"
    
    If degree == 0:
        Return "1"
    
    If degree == 1:
        Return argument
    
    If degree == 2:
        Return "(3*" + argument + "^2 - 1)/2"
    
    If degree == 3:
        Return "(5*" + argument + "^3 - 3*" + argument + ")/2"
    
    If degree == 4:
        Return "(35*" + argument + "^4 - 30*" + argument + "^2 + 3)/8"
    
    If degree == 5:
        Return "(63*" + argument + "^5 - 70*" + argument + "^3 + 15*" + argument + ")/8"
    
    If degree == 6:
        Return "(231*" + argument + "^6 - 315*" + argument + "^4 + 105*" + argument + "^2 - 5)/16"
    
    Note: Special values
    If argument == "1":
        Return "1"
    
    If argument == "-1":
        If degree % 2 == 0:
            Return "1"
        Otherwise:
            Return "-1"
    
    If argument == "0":
        If degree % 2 == 1:
            Return "0"
        Otherwise:
            Note: P_{2k}(0) = (-1)^k * (2k)! / (2^{2k} * (k!)^2)
            Let k be degree / 2
            Return "(-1)^" + k + " * factorial(" + degree + ") / (2^" + degree + " * factorial(" + k + ")^2)"
    
    Note: Rodrigues' formula: P_n(x) = (1/(2^n * n!)) * d^n/dx^n[(x^2-1)^n]
    If degree <= 10:
        Return "rodrigues_formula_legendre(" + degree + ", " + argument + ")"
    
    Note: Recurrence relation: (n+1)P_{n+1}(x) = (2n+1)x*P_n(x) - n*P_{n-1}(x)
    If degree > 10:
        Let n_minus_1 be degree - 1
        Let n_minus_2 be degree - 2
        Return "((" + (2 * degree - 1) + " * " + argument + " * P_" + n_minus_1 + "(" + argument + ") - " + n_minus_2 + " * P_" + n_minus_2 + "(" + argument + ")) / " + degree + ")"
    
    Note: General case
    Return "P_" + degree + "(" + argument + ")"

Process called "associated_legendre" that takes degree as Integer, order as Integer, argument as String returns String:
    Note: Associated Legendre polynomial P_n^m(x)
    Note: P_n^m(x) = (-1)^m * (1-x^2)^{m/2} * d^m/dx^m[P_n(x)]
    
    If degree < 0 or order < 0 or order > degree:
        Return "undefined"
    
    If order == 0:
        Note: P_n^0(x) = P_n(x)
        Return "P_" + degree + "(" + argument + ")"
    
    If degree == order:
        Note: P_n^n(x) = (-1)^n * (2n-1)!! * (1-x^2)^{n/2}
        Let double_factorial be "double_factorial(" + (2 * degree - 1) + ")"
        Let sign_factor be "(-1)^" + degree
        Return sign_factor + " * " + double_factorial + " * (1 - " + argument + "^2)^(" + degree + "/2)"
    
    Note: Special cases for low degrees and orders
    If degree == 1 and order == 1:
        Return "-(1 - " + argument + "^2)^(1/2)"
    
    If degree == 2 and order == 1:
        Return "-3 * " + argument + " * (1 - " + argument + "^2)^(1/2)"
    
    If degree == 2 and order == 2:
        Return "3 * (1 - " + argument + "^2)"
    
    If degree == 3 and order == 1:
        Return "-(3/2) * (5 * " + argument + "^2 - 1) * (1 - " + argument + "^2)^(1/2)"
    
    If degree == 3 and order == 2:
        Return "15 * " + argument + " * (1 - " + argument + "^2)"
    
    If degree == 3 and order == 3:
        Return "-15 * (1 - " + argument + "^2)^(3/2)"
    
    Note: Negative order case: P_n^{-m}(x) = (-1)^m * (n-m)!/(n+m)! * P_n^m(x)
    If order < 0:
        Let positive_order be -order
        Let factorial_ratio be "factorial(" + (degree - positive_order) + ") / factorial(" + (degree + positive_order) + ")"
        Let sign_factor be "(-1)^" + positive_order
        Return sign_factor + " * " + factorial_ratio + " * P_" + degree + "^" + positive_order + "(" + argument + ")"
    
    Note: Recurrence relations
    If degree > 3:
        Note: (n-m+1)P_{n+1}^m = (2n+1)x*P_n^m - (n+m)P_{n-1}^m
        Let n_minus_1 be degree - 1
        Let coeff1 be degree - order + 1
        Let coeff2 be 2 * degree + 1
        Let coeff3 be degree + order
        Return "((" + coeff2 + " * " + argument + " * P_" + degree + "^" + order + "(" + argument + ") - " + coeff3 + " * P_" + n_minus_1 + "^" + order + "(" + argument + ")) / " + coeff1 + ")"
    
    Note: General definition using derivatives
    Note: P_n^m(x) = (-1)^m * (1-x^2)^{m/2} * d^m/dx^m[P_n(x)]
    Let sign_factor be "(-1)^" + order
    Let sqrt_factor be "(1 - " + argument + "^2)^(" + order + "/2)"
    Let derivative_term be "derivative_order_" + order + "_of_P_" + degree + "(" + argument + ")"
    Return sign_factor + " * " + sqrt_factor + " * " + derivative_term
    
    Note: General case
    Return "P_" + degree + "^" + order + "(" + argument + ")"

Process called "chebyshev_first_kind" that takes degree as Integer, argument as String returns String:
    Note: Chebyshev polynomial of the first kind T_n(x)
    Note: T_n(cos(θ)) = cos(nθ), orthogonal on [-1,1] with weight 1/√(1-x²)
    
    If degree < 0:
        Return "undefined"
    
    If degree == 0:
        Return "1"
    
    If degree == 1:
        Return argument
    
    If degree == 2:
        Return "2*" + argument + "^2 - 1"
    
    If degree == 3:
        Return "4*" + argument + "^3 - 3*" + argument
    
    If degree == 4:
        Return "8*" + argument + "^4 - 8*" + argument + "^2 + 1"
    
    If degree == 5:
        Return "16*" + argument + "^5 - 20*" + argument + "^3 + 5*" + argument
    
    If degree == 6:
        Return "32*" + argument + "^6 - 48*" + argument + "^4 + 18*" + argument + "^2 - 1"
    
    Note: Special values
    If argument == "1":
        Return "1"
    
    If argument == "-1":
        If degree % 2 == 0:
            Return "1"
        Otherwise:
            Return "-1"
    
    If argument == "0":
        If degree % 2 == 1:
            Return "0"
        Otherwise:
            Note: T_{2k}(0) = (-1)^k
            Let k be degree / 2
            Return "(-1)^" + k
    
    Note: Trigonometric definition for |x| ≤ 1
    If "abs(" + argument + ") <= 1":
        Return "cos(" + degree + " * arccos(" + argument + "))"
    
    Note: Hyperbolic definition for |x| > 1
    If "abs(" + argument + ") > 1":
        If argument starts with "-":
            Let positive_arg be argument without "-" prefix
            If degree % 2 == 0:
                Return "cosh(" + degree + " * arccosh(" + positive_arg + "))"
            Otherwise:
                Return "-cosh(" + degree + " * arccosh(" + positive_arg + "))"
        Otherwise:
            Return "cosh(" + degree + " * arccosh(" + argument + "))"
    
    Note: Recurrence relation: T_{n+1}(x) = 2x*T_n(x) - T_{n-1}(x)
    If degree > 6:
        Let n_minus_1 be degree - 1
        Let n_minus_2 be degree - 2
        Return "2 * " + argument + " * T_" + n_minus_1 + "(" + argument + ") - T_" + n_minus_2 + "(" + argument + ")"
    
    Note: General case
    Return "T_" + degree + "(" + argument + ")"

Process called "chebyshev_second_kind" that takes degree as Integer, argument as String returns String:
    Note: Chebyshev polynomial of the second kind U_n(x)
    Note: U_n(cos(θ)) = sin((n+1)θ)/sin(θ), orthogonal on [-1,1] with weight √(1-x²)
    
    If degree < 0:
        Return "undefined"
    
    If degree == 0:
        Return "1"
    
    If degree == 1:
        Return "2*" + argument
    
    If degree == 2:
        Return "4*" + argument + "^2 - 1"
    
    If degree == 3:
        Return "8*" + argument + "^3 - 4*" + argument
    
    If degree == 4:
        Return "16*" + argument + "^4 - 12*" + argument + "^2 + 1"
    
    If degree == 5:
        Return "32*" + argument + "^5 - 32*" + argument + "^3 + 6*" + argument
    
    If degree == 6:
        Return "64*" + argument + "^6 - 80*" + argument + "^4 + 24*" + argument + "^2 - 1"
    
    Note: Special values
    If argument == "1":
        Return degree + 1
    
    If argument == "-1":
        If degree % 2 == 0:
            Return -(degree + 1)
        Otherwise:
            Return degree + 1
    
    If argument == "0":
        If degree % 2 == 1:
            Return "0"
        Otherwise:
            Note: U_{2k}(0) = (-1)^k
            Let k be degree / 2
            Return "(-1)^" + k
    
    Note: Trigonometric definition for |x| ≤ 1
    If "abs(" + argument + ") <= 1":
        Return "sin((" + (degree + 1) + ") * arccos(" + argument + ")) / sin(arccos(" + argument + "))"
    
    Note: Simplified trigonometric form
    If "abs(" + argument + ") <= 1":
        Return "sin((" + (degree + 1) + ") * arccos(" + argument + ")) / sqrt(1 - " + argument + "^2)"
    
    Note: Hyperbolic definition for |x| > 1
    If "abs(" + argument + ") > 1":
        If argument starts with "-":
            Let positive_arg be argument without "-" prefix
            If degree % 2 == 0:
                Return "-sinh((" + (degree + 1) + ") * arccosh(" + positive_arg + ")) / sinh(arccosh(" + positive_arg + "))"
            Otherwise:
                Return "sinh((" + (degree + 1) + ") * arccosh(" + positive_arg + ")) / sinh(arccosh(" + positive_arg + "))"
        Otherwise:
            Return "sinh((" + (degree + 1) + ") * arccosh(" + argument + ")) / sinh(arccosh(" + argument + "))"
    
    Note: Recurrence relation: U_{n+1}(x) = 2x*U_n(x) - U_{n-1}(x)
    If degree > 6:
        Let n_minus_1 be degree - 1
        Let n_minus_2 be degree - 2
        Return "2 * " + argument + " * U_" + n_minus_1 + "(" + argument + ") - U_" + n_minus_2 + "(" + argument + ")"
    
    Note: Relationship with Chebyshev first kind: U_n(x) = (T'_{n+1}(x))/(n+1)
    If "use_derivative_relation(" + degree + ")":
        Let derivative_T = "derivative_of_T_" + (degree + 1) + "(" + argument + ")"
        Return derivative_T + " / " + (degree + 1)
    
    Note: General case
    Return "U_" + degree + "(" + argument + ")"

Process called "hermite_polynomial" that takes degree as Integer, argument as String returns String:
    Note: Hermite polynomial H_n(x)
    Note: Orthogonal on (-∞,∞) with weight e^(-x²), solutions to Hermite's equation
    
    If degree < 0:
        Return "undefined"
    
    If degree == 0:
        Return "1"
    
    If degree == 1:
        Return "2*" + argument
    
    If degree == 2:
        Return "4*" + argument + "^2 - 2"
    
    If degree == 3:
        Return "8*" + argument + "^3 - 12*" + argument
    
    If degree == 4:
        Return "16*" + argument + "^4 - 48*" + argument + "^2 + 12"
    
    If degree == 5:
        Return "32*" + argument + "^5 - 160*" + argument + "^3 + 120*" + argument
    
    If degree == 6:
        Return "64*" + argument + "^6 - 480*" + argument + "^4 + 720*" + argument + "^2 - 120"
    
    Note: Special values
    If argument == "0":
        If degree % 2 == 1:
            Return "0"
        Otherwise:
            Note: H_{2k}(0) = (-1)^k * (2k)!/k! * 2^k
            Let k be degree / 2
            Return "(-1)^" + k + " * factorial(" + degree + ") / factorial(" + k + ") * 2^" + k
    
    Note: Rodrigues' formula: H_n(x) = (-1)^n * e^(x²) * d^n/dx^n[e^(-x²)]
    If "use_rodrigues_formula(" + degree + ")":
        Let sign_factor be "(-1)^" + degree
        Return sign_factor + " * exp(" + argument + "^2) * derivative_order_" + degree + "_of_exp_minus_x_squared(" + argument + ")"
    
    Note: Generating function approach
    If "use_generating_function(" + degree + ")":
        Return "coefficient_of_t^" + degree + "_in_exp(2*" + argument + "*t - t^2)"
    
    Note: Recurrence relation: H_{n+1}(x) = 2x*H_n(x) - 2n*H_{n-1}(x)
    If degree > 6:
        Let n_minus_1 be degree - 1
        Let n_minus_2 be degree - 2
        Return "2 * " + argument + " * H_" + n_minus_1 + "(" + argument + ") - " + (2 * n_minus_1) + " * H_" + n_minus_2 + "(" + argument + ")"
    
    Note: Connection with parabolic cylinder functions
    If "use_parabolic_cylinder_connection(" + degree + ")":
        Return "2^(" + degree + "/2) * exp(-" + argument + "^2/4) * D_" + degree + "(" + argument + "/sqrt(2))"
    
    Note: Probabilist's Hermite polynomials He_n(x) = 2^(-n/2) * H_n(x/√2)
    Note: Relationship: H_n(x) = 2^(n/2) * He_n(x*√2)
    
    Note: General case
    Return "H_" + degree + "(" + argument + ")"

Process called "laguerre_polynomial" that takes degree as Integer, argument as String returns String:
    Note: Laguerre polynomial L_n(x)
    Note: Orthogonal on [0,∞) with weight e^(-x), solutions to Laguerre's equation
    
    If degree < 0:
        Return "undefined"
    
    If degree == 0:
        Return "1"
    
    If degree == 1:
        Return "1 - " + argument
    
    If degree == 2:
        Return "(" + argument + "^2 - 4*" + argument + " + 2)/2"
    
    If degree == 3:
        Return "(-" + argument + "^3 + 9*" + argument + "^2 - 18*" + argument + " + 6)/6"
    
    If degree == 4:
        Return "(" + argument + "^4 - 16*" + argument + "^3 + 72*" + argument + "^2 - 96*" + argument + " + 24)/24"
    
    If degree == 5:
        Return "(-" + argument + "^5 + 25*" + argument + "^4 - 200*" + argument + "^3 + 600*" + argument + "^2 - 600*" + argument + " + 120)/120"
    
    Note: Special values
    If argument == "0":
        Return "1"
    
    Note: Value at x=n is always (-1)^n/n!
    If argument == degree:
        Return "(-1)^" + degree + " / factorial(" + degree + ")"
    
    Note: Rodrigues' formula: L_n(x) = (e^x/n!) * d^n/dx^n[x^n * e^(-x)]
    If "use_rodrigues_formula(" + degree + ")":
        Return "(exp(" + argument + ") / factorial(" + degree + ")) * derivative_order_" + degree + "_of_(" + argument + "^" + degree + " * exp(-" + argument + "))"
    
    Note: Series representation
    If "use_series_representation(" + degree + ")":
        Return "sum_k_0_to_" + degree + "_of_((-1)^k * binomial(" + degree + ", k) * " + argument + "^k / factorial(k))"
    
    Note: Generating function: sum L_n(x)*t^n = e^(-xt/(1-t)) / (1-t)
    If "use_generating_function(" + degree + ")":
        Return "coefficient_of_t^" + degree + "_in_(exp(-" + argument + "*t/(1-t)) / (1-t))"
    
    Note: Recurrence relation: (n+1)L_{n+1}(x) = (2n+1-x)L_n(x) - nL_{n-1}(x)
    If degree > 5:
        Let n_minus_1 be degree - 1
        Let n_minus_2 be degree - 2
        Let coeff1 be 2 * n_minus_1 + 1
        Return "((" + coeff1 + " - " + argument + ") * L_" + n_minus_1 + "(" + argument + ") - " + n_minus_1 + " * L_" + n_minus_2 + "(" + argument + ")) / " + degree
    
    Note: Connection with confluent hypergeometric function
    If "use_hypergeometric_connection(" + degree + ")":
        Return "hypergeometric_1F1(-" + degree + ", 1, " + argument + ")"
    
    Note: General case
    Return "L_" + degree + "(" + argument + ")"

Process called "jacobi_polynomial" that takes degree as Integer, alpha as String, beta as String, argument as String returns String:
    Note: Jacobi polynomial P_n^(α,β)(x)
    Note: Orthogonal on [-1,1] with weight (1-x)^α(1+x)^β, generalizes other orthogonal polynomials
    
    If degree < 0:
        Return "undefined"
    
    If degree == 0:
        Return "1"
    
    If degree == 1:
        Return "(" + alpha + " - " + beta + " + (" + alpha + " + " + beta + " + 2)*" + argument + ")/2"
    
    Note: Special cases reduce to other orthogonal polynomials
    If alpha == "0" and beta == "0":
        Note: P_n^(0,0)(x) = P_n(x) (Legendre polynomials)
        Return "P_" + degree + "(" + argument + ")"
    
    If alpha == "-1/2" and beta == "-1/2":
        Note: P_n^(-1/2,-1/2)(x) = T_n(x) (Chebyshev first kind)
        Return "T_" + degree + "(" + argument + ")"
    
    If alpha == "1/2" and beta == "1/2":
        Note: P_n^(1/2,1/2)(x) = U_n(x) (Chebyshev second kind)
        Return "U_" + degree + "(" + argument + ")"
    
    Note: Explicit formula for degree 2
    If degree == 2:
        Let term1 be "(" + alpha + " + " + beta + " + 3)*(" + alpha + " + " + beta + " + 4)/8"
        Let term2 be "(" + alpha + " - " + beta + ")*(" + alpha + " + " + beta + " + 4)/8"
        Let term3 be "(" + alpha + " + " + beta + " + 2)/2"
        Return term1 + " * " + argument + "^2 + " + term2 + " * " + argument + " - " + term3
    
    Note: Rodrigues' formula: P_n^(α,β)(x) = ((-1)^n/(2^n*n!)) * (1-x)^(-α)(1+x)^(-β) * d^n/dx^n[(1-x)^(n+α)(1+x)^(n+β)]
    If "use_rodrigues_formula(" + degree + ")":
        Let sign_factor be "(-1)^" + degree
        Let normalization be "1 / (2^" + degree + " * factorial(" + degree + "))"
        Let weight_factor be "(1 - " + argument + ")^(-" + alpha + ") * (1 + " + argument + ")^(-" + beta + ")"
        Let derivative_term be "derivative_order_" + degree + "_of_((1 - " + argument + ")^(" + degree + " + " + alpha + ") * (1 + " + argument + ")^(" + degree + " + " + beta + "))"
        Return sign_factor + " * " + normalization + " * " + weight_factor + " * " + derivative_term
    
    Note: Hypergeometric representation
    If "use_hypergeometric_representation(" + degree + ")":
        Let binomial_coeff be "binomial(" + degree + " + " + alpha + ", " + degree + ")"
        Let hypergeom_arg be "(1 - " + argument + ")/2"
        Return binomial_coeff + " * hypergeometric_2F1(-" + degree + ", " + degree + " + " + alpha + " + " + beta + " + 1, " + alpha + " + 1, " + hypergeom_arg + ")"
    
    Note: Three-term recurrence relation
    If degree > 2:
        Let n = degree
        Let n_minus_1 be degree - 1
        Let n_minus_2 be degree - 2
        
        Note: 2n(n+α+β)(2n+α+β-2)P_n = (2n+α+β-1)[(2n+α+β)(2n+α+β-2)x + α²-β²]P_{n-1} - 2(n+α-1)(n+β-1)(2n+α+β)P_{n-2}
        Let a_n be "2*" + n + "*(" + n + "+" + alpha + "+" + beta + ")*(2*" + n + "+" + alpha + "+" + beta + "-2)"
        Let b_n be "(2*" + n + "+" + alpha + "+" + beta + "-1)*((2*" + n + "+" + alpha + "+" + beta + ")*(2*" + n + "+" + alpha + "+" + beta + "-2)*" + argument + "+" + alpha + "^2-" + beta + "^2)"
        Let c_n be "2*(" + n_minus_1 + "+" + alpha + ")*(" + n_minus_1 + "+" + beta + ")*(2*" + n + "+" + alpha + "+" + beta + ")"
        
        Return "(" + b_n + " * P_" + n_minus_1 + "^(" + alpha + "," + beta + ")(" + argument + ") - " + c_n + " * P_" + n_minus_2 + "^(" + alpha + "," + beta + ")(" + argument + ")) / " + a_n
    
    Note: General case
    Return "P_" + degree + "^(" + alpha + "," + beta + ")(" + argument + ")"

Note: =====================================================================
Note: HYPERGEOMETRIC FUNCTION OPERATIONS
Note: =====================================================================

Process called "hypergeometric_1f1" that takes a as String, b as String, z as String returns String:
    Note: Confluent hypergeometric function ₁F₁(a;b;z)
    Note: Special case: when a = 0
    If a == "0":
        Return "1"
    
    Note: Special case: when b = 0 (pole)
    If b == "0":
        Return "undefined"
    
    Note: Special case: when z = 0
    If z == "0":
        Return "1"
    
    Note: Special case: when a = b
    If a == b:
        Return "exp(" + z + ")"
    
    Note: Special case: when a is negative integer and |a| < b
    Let a_check be "check_negative_integer_" + a
    If a_check == "true":
        Let b_minus_a be b + " - " + a
        Let b_check be "check_positive_" + b_minus_a
        If b_check == "true":
            Note: Finite polynomial case
            Return "polynomial_hypergeometric_1f1_" + a + "_" + b + "_" + z
    
    Note: When b - a is negative integer (terminating series)
    Let b_minus_a be b + " - " + a
    Let neg_int_check be "check_negative_integer_" + b_minus_a
    If neg_int_check == "true":
        Return "undefined"
    
    Note: Asymptotic expansion for large |z|
    Let z_magnitude be "abs(" + z + ")"
    If z_magnitude + " > 10":
        Note: Use asymptotic formula
        Let gamma_b be "gamma(" + b + ")"
        Let gamma_b_minus_a be "gamma(" + b + " - " + a + ")"
        Let exp_z be "exp(" + z + ")"
        Let z_power_a be "power(" + z + ", " + a + ")"
        Return gamma_b + " / " + gamma_b_minus_a + " * " + exp_z + " * " + z_power_a + " * hypergeometric_1f1_asymptotic(" + a + ", " + b + ", " + z + ")"
    
    Note: Series expansion for moderate values
    Return "sum_k_0_to_infinity((" + a + ")_k / (" + b + ")_k * " + z + "^k / k!)"

Process called "hypergeometric_2f1" that takes a as String, b as String, c as String, z as String returns String:
    Note: Gaussian hypergeometric function ₂F₁(a,b;c;z)
    Note: Special case: when z = 0
    If z == "0":
        Return "1"
    
    Note: Special case: when z = 1 and c > a + b (Gauss's theorem)
    If z == "1":
        Let c_minus_a_minus_b be c + " - " + a + " - " + b
        Let convergence_check be "check_positive_" + c_minus_a_minus_b
        If convergence_check == "true":
            Let gamma_c be "gamma(" + c + ")"
            Let gamma_c_minus_a_minus_b be "gamma(" + c_minus_a_minus_b + ")"
            Let gamma_c_minus_a be "gamma(" + c + " - " + a + ")"
            Let gamma_c_minus_b be "gamma(" + c + " - " + b + ")"
            Return gamma_c + " * " + gamma_c_minus_a_minus_b + " / (" + gamma_c_minus_a + " * " + gamma_c_minus_b + ")"
        Otherwise:
            Return "divergent"
    
    Note: Special case: when a or b is zero
    If a == "0" or b == "0":
        Return "1"
    
    Note: Special case: when c is zero or negative integer
    If c == "0":
        Return "undefined"
    
    Let c_neg_int_check be "check_negative_integer_" + c
    If c_neg_int_check == "true":
        Return "undefined"
    
    Note: Special case: when a or b is negative integer
    Let a_neg_int_check be "check_negative_integer_" + a
    Let b_neg_int_check be "check_negative_integer_" + b
    If a_neg_int_check == "true" or b_neg_int_check == "true":
        Note: Series terminates, giving polynomial
        Return "polynomial_hypergeometric_2f1_" + a + "_" + b + "_" + c + "_" + z
    
    Note: Transformation for |z| > 1/2 using linear transformations
    Let z_abs be "abs(" + z + ")"
    If z_abs + " > 0.5":
        Note: Use Pfaff transformation: (1-z)^(-a) * 2F1(a, c-b; c; z/(z-1))
        Let one_minus_z be "1 - " + z
        Let z_transform be z + " / (" + z + " - 1)"
        Let power_term be "power(" + one_minus_z + ", -" + a + ")"
        Let c_minus_b be c + " - " + b
        Return power_term + " * hypergeometric_2f1(" + a + ", " + c_minus_b + ", " + c + ", " + z_transform + ")"
    
    Note: Standard series expansion
    Return "sum_k_0_to_infinity((" + a + ")_k * (" + b + ")_k / (" + c + ")_k * " + z + "^k / k!)"

Process called "hypergeometric_0f1" that takes b as String, z as String returns String:
    Note: Hypergeometric function ₀F₁(;b;z)
    Note: Special case: when z = 0
    If z == "0":
        Return "1"
    
    Note: Special case: when b = 0 (undefined)
    If b == "0":
        Return "undefined"
    
    Note: Special case: when b is negative integer
    Let b_neg_int_check be "check_negative_integer_" + b
    If b_neg_int_check == "true":
        Return "undefined"
    
    Note: Connection to Bessel functions when b = 1/2
    If b == "1/2":
        Let sqrt_pi_z be "sqrt(pi * " + z + ")"
        Return "cosh(2 * " + sqrt_pi_z + ")"
    
    Note: Connection to Bessel functions when b = 3/2
    If b == "3/2":
        Let sqrt_pi_z be "sqrt(pi * " + z + ")"
        Let sinh_term be "sinh(2 * " + sqrt_pi_z + ")"
        Return sinh_term + " / (2 * " + sqrt_pi_z + ")"
    
    Note: Connection to modified Bessel function of first kind
    Let b_minus_1 be b + " - 1"
    Let z_over_4 be z + " / 4"
    Let sqrt_z be "sqrt(" + z + ")"
    Let gamma_b be "gamma(" + b + ")"
    Let bessel_I be "bessel_I(" + b_minus_1 + ", 2 * " + sqrt_z + ")"
    Return gamma_b + " * power(" + z_over_4 + ", " + b_minus_1 + ") * " + bessel_I
    
    Note: Series representation as fallback
    Return "sum_k_0_to_infinity(" + z + "^k / ((" + b + ")_k * k!))"

Process called "hypergeometric_pfq" that takes p_params as List[String], q_params as List[String], z as String returns String:
    Note: Generalized hypergeometric function ₚFᵩ
    Note: Special case: when z = 0
    If z == "0":
        Return "1"
    
    Note: Check for undefined cases (q_params contain 0 or negative integers)
    Let q_index be 0
    While q_index < q_params.length:
        Let q_param be q_params[q_index]
        If q_param == "0":
            Return "undefined"
        Let q_neg_check be "check_negative_integer_" + q_param
        If q_neg_check == "true":
            Return "undefined"
        Set q_index to q_index + 1
    
    Note: Check for terminating series (p_params contain negative integers)
    Let terminates be false
    Let p_index be 0
    While p_index < p_params.length:
        Let p_param be p_params[p_index]
        Let p_neg_check be "check_negative_integer_" + p_param
        If p_neg_check == "true":
            Set terminates to true
            Break
        Set p_index to p_index + 1
    
    Note: Build pochhammer symbols for numerator and denominator
    Let numerator_terms be ""
    Let p_idx be 0
    While p_idx < p_params.length:
        Let p_param be p_params[p_idx]
        If p_idx > 0:
            Set numerator_terms to numerator_terms + " * "
        Set numerator_terms to numerator_terms + "(" + p_param + ")_k"
        Set p_idx to p_idx + 1
    
    Let denominator_terms be ""
    Let q_idx be 0
    While q_idx < q_params.length:
        Let q_param be q_params[q_idx]
        If q_idx > 0:
            Set denominator_terms to denominator_terms + " * "
        Set denominator_terms to denominator_terms + "(" + q_param + ")_k"
        Set q_idx to q_idx + 1
    
    Note: Add factorial term
    If denominator_terms != "":
        Set denominator_terms to denominator_terms + " * k!"
    Otherwise:
        Set denominator_terms to "k!"
    
    Note: Convergence analysis
    Let p be p_params.length
    Let q be q_params.length
    
    If p <= q:
        Note: Convergent for all finite z (except poles)
        If terminates:
            Return "polynomial_pFq_" + p + "_" + q + "_terminated"
        Otherwise:
            Return "sum_k_0_to_infinity(" + numerator_terms + " * " + z + "^k / (" + denominator_terms + "))"
    
    Otherwise If p == q + 1:
        Note: Convergent for |z| < 1
        Let z_abs be "abs(" + z + ")"
        If z_abs + " >= 1":
            Return "divergent_or_special_case"
        Return "sum_k_0_to_infinity(" + numerator_terms + " * " + z + "^k / (" + denominator_terms + "))"
    
    Otherwise:
        Note: p > q + 1, divergent for all z ≠ 0
        Return "divergent"

Process called "hypergeometric_transformations" that takes function as HypergeometricFunction, transformation_type as String returns String:
    Note: Apply transformation formulas to hypergeometric functions
    
    If transformation_type == "pfaff":
        Note: Pfaff transformation for 2F1: z → z/(z-1)
        If function.type == "2F1":
            Let a be function.parameters[0]
            Let b be function.parameters[1] 
            Let c be function.parameters[2]
            Let z be function.argument
            Let one_minus_z be "1 - " + z
            Let z_transform be z + " / (" + z + " - 1)"
            Let power_factor be "power(" + one_minus_z + ", -" + a + ")"
            Let c_minus_b be c + " - " + b
            Return power_factor + " * hypergeometric_2f1(" + a + ", " + c_minus_b + ", " + c + ", " + z_transform + ")"
        Otherwise:
            Return "pfaff_not_applicable"
    
    Otherwise If transformation_type == "euler":
        Note: Euler transformation for 2F1: (1-z)^(-a) factor
        If function.type == "2F1":
            Let a be function.parameters[0]
            Let b be function.parameters[1]
            Let c be function.parameters[2] 
            Let z be function.argument
            Let one_minus_z be "1 - " + z
            Let power_factor be "power(" + one_minus_z + ", -" + a + ")"
            Let c_minus_b be c + " - " + b
            Return power_factor + " * hypergeometric_2f1(" + a + ", " + c_minus_b + ", " + c + ", " + z + ")"
        Otherwise:
            Return "euler_not_applicable"
    
    Otherwise If transformation_type == "kummer":
        Note: Kummer transformation for 1F1: e^z factor
        If function.type == "1F1":
            Let a be function.parameters[0]
            Let b be function.parameters[1]
            Let z be function.argument
            Let b_minus_a be b + " - " + a
            Let exp_factor be "exp(" + z + ")"
            Let minus_z be "-" + z
            Return exp_factor + " * hypergeometric_1f1(" + b_minus_a + ", " + b + ", " + minus_z + ")"
        Otherwise:
            Return "kummer_not_applicable"
    
    Otherwise If transformation_type == "quadratic":
        Note: Quadratic transformation for specific parameter relations
        If function.type == "2F1":
            Let a be function.parameters[0]
            Let b be function.parameters[1]
            Let c be function.parameters[2]
            Let z be function.argument
            Note: Check if 2c = a + b + 1 (quadratic transformation condition)
            Let twice_c be "2 * " + c
            Let a_plus_b_plus_1 be a + " + " + b + " + 1"
            If twice_c == a_plus_b_plus_1:
                Let z_squared be z + "^2"
                Let four_z_factor be "4 * " + z + " / (1 + " + z + ")^2"
                Let a_half be a + " / 2"
                Let b_half be b + " / 2"
                Let c_half be c + " - 1/2"
                Return "hypergeometric_2f1(" + a_half + ", " + b_half + ", " + c_half + ", " + four_z_factor + ")"
            Otherwise:
                Return "quadratic_conditions_not_met"
        Otherwise:
            Return "quadratic_not_applicable"
    
    Otherwise If transformation_type == "connection":
        Note: Connection formulas relating different argument regions
        If function.type == "2F1":
            Let a be function.parameters[0]
            Let b be function.parameters[1]
            Let c be function.parameters[2]
            Let z be function.argument
            Note: Connection formula for |z| > 1
            Let gamma_c be "gamma(" + c + ")"
            Let gamma_c_minus_a_minus_b be "gamma(" + c + " - " + a + " - " + b + ")"
            Let gamma_c_minus_a be "gamma(" + c + " - " + a + ")"
            Let gamma_c_minus_b be "gamma(" + c + " - " + b + ")"
            Let gamma_a be "gamma(" + a + ")"
            Let gamma_b be "gamma(" + b + ")"
            Let z_inv be "1 / " + z
            Let power_a be "power(-" + z + ", -" + a + ")"
            Let power_b be "power(-" + z + ", -" + b + ")"
            Let term1 be gamma_c + " * " + gamma_c_minus_a_minus_b + " / (" + gamma_c_minus_a + " * " + gamma_c_minus_b + ") * " + power_a
            Let term2 be gamma_c + " * " + gamma_c_minus_a_minus_b + " / (" + gamma_a + " * " + gamma_b + ") * " + power_b
            Return term1 + " * hypergeometric_2f1(" + a + ", " + a + " - " + c + " + 1, " + a + " - " + b + " + 1, " + z_inv + ") + " + term2 + " * hypergeometric_2f1(" + b + ", " + b + " - " + c + " + 1, " + b + " - " + a + " + 1, " + z_inv + ")"
        Otherwise:
            Return "connection_not_applicable"
    
    Otherwise:
        Return "unknown_transformation_" + transformation_type

Note: =====================================================================
Note: ELLIPTIC FUNCTION OPERATIONS
Note: =====================================================================

Process called "elliptic_integral_first_kind" that takes phi as String, modulus as String returns String:
    Note: Elliptic integral of the first kind F(φ,k)
    Note: F(φ,k) = ∫[0,φ] dθ/√(1 - k²sin²θ)
    
    Note: Special case: when phi = 0
    If phi == "0":
        Return "0"
    
    Note: Special case: when modulus = 0 (circular case)
    If modulus == "0":
        Return phi
    
    Note: Special case: when modulus = 1 (degenerate case)
    If modulus == "1":
        Let tan_half_phi be "tan(" + phi + " / 2)"
        Return "log((1 + " + tan_half_phi + ") / (1 - " + tan_half_phi + ")) / 2"
    
    Note: Special case: when phi = pi/2 (complete elliptic integral)
    If phi == "pi/2":
        Return "complete_elliptic_integral_K(" + modulus + ")"
    
    Note: For small modulus, use series expansion
    Let modulus_squared be modulus + "^2"
    If modulus + " < 0.1":
        Note: F(φ,k) ≈ φ + (k²/4)(φ - sin(φ)cos(φ)) + O(k⁴)
        Let sin_phi be "sin(" + phi + ")"
        Let cos_phi be "cos(" + phi + ")"
        Let sin_cos_term be sin_phi + " * " + cos_phi
        Let correction be modulus_squared + " / 4 * (" + phi + " - " + sin_cos_term + ")"
        Return phi + " + " + correction
    
    Note: Use Landen transformation for larger modulus
    If modulus + " > 0.9":
        Note: Transform to smaller effective modulus
        Let k_prime be "sqrt(1 - " + modulus_squared + ")"
        Let transformed_modulus be "(1 - " + k_prime + ") / (1 + " + k_prime + ")"
        Let scale_factor be "1 + " + transformed_modulus
        Return scale_factor + " * elliptic_integral_first_kind(" + phi + ", " + transformed_modulus + ")"
    
    Note: General case using arithmetic-geometric mean method
    Return "elliptic_F_agm(" + phi + ", " + modulus + ")"

Process called "elliptic_integral_second_kind" that takes phi as String, modulus as String returns String:
    Note: Elliptic integral of the second kind E(φ,k)
    Note: E(φ,k) = ∫[0,φ] √(1 - k²sin²θ) dθ
    
    Note: Special case: when phi = 0
    If phi == "0":
        Return "0"
    
    Note: Special case: when modulus = 0 (circular case)
    If modulus == "0":
        Return phi
    
    Note: Special case: when modulus = 1 (degenerate case)
    If modulus == "1":
        Return "sin(" + phi + ")"
    
    Note: Special case: when phi = pi/2 (complete elliptic integral)
    If phi == "pi/2":
        Return "complete_elliptic_integral_E(" + modulus + ")"
    
    Note: For small modulus, use series expansion
    Let modulus_squared be modulus + "^2"
    If modulus + " < 0.1":
        Note: E(φ,k) ≈ φ - (k²/4)(φ - sin(φ)cos(φ)) + O(k⁴)
        Let sin_phi be "sin(" + phi + ")"
        Let cos_phi be "cos(" + phi + ")"
        Let sin_cos_term be sin_phi + " * " + cos_phi
        Let correction be modulus_squared + " / 4 * (" + phi + " - " + sin_cos_term + ")"
        Return phi + " - " + correction
    
    Note: Relation to first kind integral
    Let F_phi_k be "elliptic_integral_first_kind(" + phi + ", " + modulus + ")"
    Let k_prime_squared be "1 - " + modulus_squared
    Let sin_phi be "sin(" + phi + ")"
    Let cos_phi be "cos(" + phi + ")"
    Let sqrt_term be "sqrt(1 - " + modulus_squared + " * " + sin_phi + "^2)"
    Let integrand_diff be k_prime_squared + " * " + F_phi_k + " + " + modulus_squared + " * " + sin_phi + " * " + cos_phi + " * " + sqrt_term
    
    Note: General case using numerical integration
    Return "elliptic_E_numerical(" + phi + ", " + modulus + ")"

Process called "elliptic_integral_third_kind" that takes phi as String, n as String, modulus as String returns String:
    Note: Elliptic integral of the third kind Π(n;φ,k)
    Note: Π(n;φ,k) = ∫[0,φ] dθ/((1 - n sin²θ)√(1 - k²sin²θ))
    
    Note: Special case: when phi = 0
    If phi == "0":
        Return "0"
    
    Note: Special case: when n = 0 (reduces to first kind)
    If n == "0":
        Return "elliptic_integral_first_kind(" + phi + ", " + modulus + ")"
    
    Note: Special case: when modulus = 0 (circular case)
    If modulus == "0":
        If n == "1":
            Return "tan(" + phi + ")"
        Otherwise:
            Let one_minus_n be "1 - " + n
            Let sqrt_term be "sqrt(" + one_minus_n + ")"
            Let scaled_phi be phi + " * " + sqrt_term
            Return "elliptic_integral_first_kind(" + scaled_phi + ", 0) / " + sqrt_term
    
    Note: Singular case: when n = 1
    If n == "1":
        Note: Π(1;φ,k) has logarithmic singularity
        Let F_integral be "elliptic_integral_first_kind(" + phi + ", " + modulus + ")"
        Let E_integral be "elliptic_integral_second_kind(" + phi + ", " + modulus + ")"
        Let k_squared be modulus + "^2"
        Let correction_term be "sin(" + phi + ") * cos(" + phi + ") / sqrt(1 - " + k_squared + " * sin(" + phi + ")^2)"
        Return F_integral + " + " + correction_term + " / (1 - " + k_squared + ")"
    
    Note: Complete elliptic integral case
    If phi == "pi/2":
        Return "complete_elliptic_integral_Pi(" + n + ", " + modulus + ")"
    
    Note: Check for complex cases
    Let n_real_check be "check_real_" + n
    If n_real_check == "false":
        Return "complex_elliptic_third_kind(" + phi + ", " + n + ", " + modulus + ")"
    
    Note: Use Carlson's symmetric form for numerical stability
    Let sin_phi be "sin(" + phi + ")"
    Let cos_phi be "cos(" + phi + ")"
    Let k_squared be modulus + "^2"
    Let sin_squared be sin_phi + "^2"
    
    Let c_squared be cos_phi + "^2"
    Let delta be "1 - " + k_squared + " * " + sin_squared
    Let alpha_squared be c_squared + " + " + k_squared + " * " + sin_squared
    Let beta_squared be c_squared + " + " + k_squared + " * " + sin_squared + " * (1 - " + n + " * " + sin_squared + ")"
    
    Return "elliptic_Pi_carlson(" + n + ", " + alpha_squared + ", " + beta_squared + ", " + delta + ")"

Process called "jacobi_elliptic_sn" that takes u as String, modulus as String returns String:
    Note: Jacobi elliptic function sn(u,k)
    Note: sn(u,k) is the sine amplitude function where u = F(φ,k)
    
    Note: Special case: when u = 0
    If u == "0":
        Return "0"
    
    Note: Special case: when modulus = 0 (circular functions)
    If modulus == "0":
        Return "sin(" + u + ")"
    
    Note: Special case: when modulus = 1 (hyperbolic functions)
    If modulus == "1":
        Return "tanh(" + u + ")"
    
    Note: Quarter period case
    Let K_complete be "complete_elliptic_integral_K(" + modulus + ")"
    If u == K_complete:
        Return "1"
    
    Note: Half period case
    Let two_K be "2 * " + K_complete
    If u == two_K:
        Return "0"
    
    Note: Three-quarter period case
    Let three_K be "3 * " + K_complete
    If u == three_K:
        Return "-1"
    
    Note: Full period case (4K)
    Let four_K be "4 * " + K_complete
    If u == four_K:
        Return "0"
    
    Note: Use periodicity: sn(u + 4K) = sn(u)
    Let u_mod be "mod(" + u + ", " + four_K + ")"
    
    Note: Use symmetry: sn(-u) = -sn(u)
    Let u_sign be "sign(" + u_mod + ")"
    Let u_abs be "abs(" + u_mod + ")"
    
    Note: For small arguments, use series expansion
    If u_abs + " < 0.1":
        Let k_squared be modulus + "^2"
        Let u_cubed be u_abs + "^3"
        Let series_term be "(1 + " + k_squared + ") / 6 * " + u_cubed
        Let result be u_abs + " - " + series_term
        Return u_sign + " * (" + result + ")"
    
    Note: Use Jacobi's theta functions for general case
    Return u_sign + " * jacobi_sn_theta(" + u_abs + ", " + modulus + ")"

Process called "jacobi_elliptic_cn" that takes u as String, modulus as String returns String:
    Note: Jacobi elliptic function cn(u,k)
    Note: cn(u,k) is the cosine amplitude function where u = F(φ,k)
    
    Note: Special case: when u = 0
    If u == "0":
        Return "1"
    
    Note: Special case: when modulus = 0 (circular functions)
    If modulus == "0":
        Return "cos(" + u + ")"
    
    Note: Special case: when modulus = 1 (hyperbolic functions)
    If modulus == "1":
        Return "sech(" + u + ")"
    
    Note: Quarter period case
    Let K_complete be "complete_elliptic_integral_K(" + modulus + ")"
    If u == K_complete:
        Return "0"
    
    Note: Half period case  
    Let two_K be "2 * " + K_complete
    If u == two_K:
        Return "-1"
    
    Note: Three-quarter period case
    Let three_K be "3 * " + K_complete
    If u == three_K:
        Return "0"
    
    Note: Full period case (4K)
    Let four_K be "4 * " + K_complete
    If u == four_K:
        Return "1"
    
    Note: Use periodicity: cn(u + 4K) = cn(u)
    Let u_mod be "mod(" + u + ", " + four_K + ")"
    
    Note: Use symmetry: cn(-u) = cn(u)
    Let u_abs be "abs(" + u_mod + ")"
    
    Note: For small arguments, use series expansion
    If u_abs + " < 0.1":
        Let k_squared be modulus + "^2"
        Let u_squared be u_abs + "^2"
        Let u_fourth be u_squared + "^2"
        Let second_order be u_squared + " / 2"
        Let fourth_order be "(5 + " + k_squared + ") / 24 * " + u_fourth
        Return "1 - " + second_order + " + " + fourth_order
    
    Note: Use relation: cn²(u) + sn²(u) = 1
    Let sn_u be "jacobi_elliptic_sn(" + u_abs + ", " + modulus + ")"
    Let sn_squared be sn_u + "^2"
    Return "sqrt(1 - " + sn_squared + ")"

Process called "jacobi_elliptic_dn" that takes u as String, modulus as String returns String:
    Note: Jacobi elliptic function dn(u,k)
    Note: dn(u,k) is the delta amplitude function where u = F(φ,k)
    
    Note: Special case: when u = 0
    If u == "0":
        Return "1"
    
    Note: Special case: when modulus = 0 (circular functions)
    If modulus == "0":
        Return "1"
    
    Note: Special case: when modulus = 1 (hyperbolic functions)
    If modulus == "1":
        Return "sech(" + u + ")"
    
    Note: Quarter period case
    Let K_complete be "complete_elliptic_integral_K(" + modulus + ")"
    Let k_prime be "sqrt(1 - " + modulus + "^2)"
    If u == K_complete:
        Return k_prime
    
    Note: Half period case
    Let two_K be "2 * " + K_complete
    If u == two_K:
        Return "1"
    
    Note: Three-quarter period case
    Let three_K be "3 * " + K_complete
    If u == three_K:
        Return k_prime
    
    Note: Full period case (4K)
    Let four_K be "4 * " + K_complete
    If u == four_K:
        Return "1"
    
    Note: Use periodicity: dn(u + 2K) = dn(u)
    Let two_K_period be "2 * " + K_complete
    Let u_mod be "mod(" + u + ", " + two_K_period + ")"
    
    Note: Use symmetry: dn(-u) = dn(u)
    Let u_abs be "abs(" + u_mod + ")"
    
    Note: For small arguments, use series expansion
    If u_abs + " < 0.1":
        Let k_squared be modulus + "^2"
        Let u_squared be u_abs + "^2"
        Let u_fourth be u_squared + "^2"
        Let second_order be k_squared + " / 2 * " + u_squared
        Let fourth_order be k_squared + " * (4 + " + k_squared + ") / 24 * " + u_fourth
        Return "1 - " + second_order + " + " + fourth_order
    
    Note: Use relation: dn²(u) = 1 - k²sn²(u)
    Let sn_u be "jacobi_elliptic_sn(" + u_abs + ", " + modulus + ")"
    Let k_squared be modulus + "^2"
    Let sn_squared be sn_u + "^2"
    Return "sqrt(1 - " + k_squared + " * " + sn_squared + ")"

Process called "weierstrass_p" that takes z as String, invariants as Dictionary[String, String] returns String:
    Note: Weierstrass elliptic function ℘(z;g₂,g₃)
    Note: ℘(z) = 1/z² + Σ'[(1/(z-ω)² - 1/ω²)] where sum is over lattice points
    
    Let g2 be invariants["g2"]
    Let g3 be invariants["g3"]
    
    Note: Special case: when z = 0 (pole)
    If z == "0":
        Return "infinity"
    
    Note: Check discriminant Δ = g₂³ - 27g₃²
    Let g2_cubed be g2 + "^3"
    Let g3_squared be g3 + "^2"
    Let discriminant be g2_cubed + " - 27 * " + g3_squared
    
    Note: Degenerate cases when Δ = 0
    If discriminant == "0":
        If g2 == "0" and g3 == "0":
            Note: ℘(z) = 1/z² (rational case)
            Return "1 / (" + z + ")^2"
        Otherwise If g3 == "0":
            Note: ℘(z) = 1/z² + g₂/20 + ... (even powers only)
            Let z_squared be z + "^2"
            Let correction be g2 + " / 20 * " + z_squared
            Return "1 / " + z_squared + " + " + correction
        Otherwise:
            Note: One repeated root case
            Return "weierstrass_p_degenerate(" + z + ", " + g2 + ", " + g3 + ")"
    
    Note: For small |z|, use Laurent series expansion
    Let z_abs be "abs(" + z + ")"
    If z_abs + " < 0.5":
        Let z_squared be z + "^2"
        Let z_fourth be z_squared + "^2"
        Let z_sixth be z_fourth + " * " + z_squared
        
        Note: ℘(z) = 1/z² + g₂z²/20 + g₃z⁴/28 + ...
        Let pole_term be "1 / " + z_squared
        Let g2_term be g2 + " / 20 * " + z_squared
        Let g3_term be g3 + " / 28 * " + z_fourth
        Let higher_order be "g2^2 / 1200 * " + z_sixth
        
        Return pole_term + " + " + g2_term + " + " + g3_term + " + " + higher_order
    
    Note: Compute half-periods using complete elliptic integrals
    Let e1 be "weierstrass_root_e1(" + g2 + ", " + g3 + ")"
    Let e2 be "weierstrass_root_e2(" + g2 + ", " + g3 + ")"
    Let e3 be "weierstrass_root_e3(" + g2 + ", " + g3 + ")"
    
    Note: Transform to Jacobi elliptic functions
    Let modulus_squared be "(" + e2 + " - " + e3 + ") / (" + e1 + " - " + e3 + ")"
    Let modulus be "sqrt(" + modulus_squared + ")"
    
    Let omega1 be "complete_elliptic_integral_K(" + modulus + ") / sqrt(" + e1 + " - " + e3 + ")"
    Let transformed_z be "sqrt(" + e1 + " - " + e3 + ") * " + z
    
    Note: ℘(z) = e₃ + (e₁ - e₃) / sn²(u,k) where u = z√(e₁-e₃)
    Let sn_value be "jacobi_elliptic_sn(" + transformed_z + ", " + modulus + ")"
    Let sn_squared be sn_value + "^2"
    Let e1_minus_e3 be e1 + " - " + e3
    
    Return e3 + " + " + e1_minus_e3 + " / (" + sn_squared + ")"

Note: =====================================================================
Note: ZETA AND L-FUNCTION OPERATIONS
Note: =====================================================================

Process called "riemann_zeta" that takes argument as String returns String:
    Note: Riemann zeta function ζ(s)
    Note: ζ(s) = Σ_{n=1}^{∞} 1/n^s for Re(s) > 1
    
    Note: Special values at integers
    If argument == "0":
        Return "-1/2"
    
    If argument == "1":
        Return "infinity"
    
    If argument == "2":
        Return "pi^2/6"
    
    If argument == "3":
        Return "apery_constant"
    
    If argument == "4":
        Return "pi^4/90"
    
    If argument == "6":
        Return "pi^6/945"
    
    If argument == "8":
        Return "pi^8/9450"
    
    Note: Special values at negative integers (trivial zeros)
    If argument == "-1":
        Return "-1/12"
    
    If argument == "-2":
        Return "0"
    
    If argument == "-3":
        Return "1/120"
    
    If argument == "-4":
        Return "0"
    
    Note: Check for negative even integers (trivial zeros)
    Let neg_even_check be "check_negative_even_integer_" + argument
    If neg_even_check == "true":
        Return "0"
    
    Note: For negative odd integers, use Riemann functional equation
    Let neg_odd_check be "check_negative_odd_integer_" + argument
    If neg_odd_check == "true":
        Let k be "abs(" + argument + ")"
        Let k_minus_1 be k + " - 1"
        Let bernoulli_term be "bernoulli_number(" + k + ")"
        Let factorial_term be "factorial(" + k_minus_1 + ")"
        Return "-" + bernoulli_term + " / " + factorial_term
    
    Note: For Re(s) > 1, use Dirichlet series
    Let s_real be "real_part(" + argument + ")"
    If s_real + " > 1":
        Return "sum_n_1_to_infinity(1 / n^" + argument + ")"
    
    Note: For 0 < Re(s) < 1, use functional equation
    Note: ζ(s) = 2^s * π^(s-1) * sin(πs/2) * Γ(1-s) * ζ(1-s)
    If s_real + " > 0" and s_real + " < 1":
        Let one_minus_s be "1 - " + argument
        Let two_power_s be "2^" + argument
        Let pi_power_s_minus_1 be "π^(" + argument + " - 1)"
        Let sin_term be "sin(π * " + argument + " / 2)"
        Let gamma_term be "gamma(" + one_minus_s + ")"
        Let zeta_1_minus_s be "riemann_zeta(" + one_minus_s + ")"
        Return two_power_s + " * " + pi_power_s_minus_1 + " * " + sin_term + " * " + gamma_term + " * " + zeta_1_minus_s
    
    Note: For complex arguments, use analytic continuation
    Return "riemann_zeta_analytic_continuation(" + argument + ")"

Process called "hurwitz_zeta" that takes s as String, a as String returns String:
    Note: Hurwitz zeta function ζ(s,a)
    Note: ζ(s,a) = Σ_{n=0}^{∞} 1/(n+a)^s for Re(s) > 1, a > 0
    
    Note: Special case: when a = 1 (Riemann zeta function)
    If a == "1":
        Return "riemann_zeta(" + s + ")"
    
    Note: Invalid case: when a ≤ 0
    Let a_positive_check be "check_positive_" + a
    If a_positive_check == "false":
        Return "undefined"
    
    Note: Special case: when s = 1 (harmonic series shift)
    If s == "1":
        Return "infinity"
    
    Note: Special case: when s = 0
    If s == "0":
        Let half_minus_a be "1/2 - " + a
        Return half_minus_a
    
    Note: Special case: when s = -1
    If s == "-1":
        Let a_squared be a + "^2"
        Let numerator be a_squared + " - " + a + " + 1/6"
        Return numerator + " / 2"
    
    Note: For integer values of a, can reduce to polygamma functions
    Let a_integer_check be "check_integer_" + a
    If a_integer_check == "true" and s != "1":
        Let s_minus_1 be s + " - 1"
        Let factorial_s_minus_1 be "factorial(" + s_minus_1 + ")"
        Let polygamma_term be "polygamma(" + s_minus_1 + ", " + a + ")"
        Return "(-1)^" + s + " * " + factorial_s_minus_1 + " * " + polygamma_term
    
    Note: For half-integer values, special formulas exist
    If a == "1/2":
        Let two_power_s_minus_1 be "(2^" + s + " - 1)"
        Let riemann_zeta_s be "riemann_zeta(" + s + ")"
        Return two_power_s_minus_1 + " * " + riemann_zeta_s
    
    Note: General case using series for Re(s) > 1
    Let s_real be "real_part(" + s + ")"
    If s_real + " > 1":
        Return "sum_n_0_to_infinity(1 / (n + " + a + ")^" + s + ")"
    
    Note: Analytic continuation using functional equation
    Note: ζ(s,a) can be continued using integral representations
    Return "hurwitz_zeta_analytic_continuation(" + s + ", " + a + ")"

Process called "dirichlet_eta" that takes argument as String returns String:
    Note: Dirichlet eta function η(s)
    Note: η(s) = Σ_{n=1}^{∞} (-1)^(n+1)/n^s = (1 - 2^(1-s)) * ζ(s)
    
    Note: Special case: when s = 1 (alternating harmonic series)
    If argument == "1":
        Return "ln(2)"
    
    Note: Special case: when s = 0
    If argument == "0":
        Return "1/2"
    
    Note: Special values at positive integers
    If argument == "2":
        Let riemann_zeta_2 be "riemann_zeta(2)"
        Return "(1 - 2^(-1)) * " + riemann_zeta_2
    
    If argument == "3":
        Let riemann_zeta_3 be "riemann_zeta(3)"
        Return "(1 - 2^(-2)) * " + riemann_zeta_3
    
    If argument == "4":
        Let riemann_zeta_4 be "riemann_zeta(4)"
        Return "(1 - 2^(-3)) * " + riemann_zeta_4
    
    Note: Relation to Riemann zeta function
    Let one_minus_s be "1 - " + argument
    Let two_power_term be "2^" + one_minus_s
    Let one_minus_two_power be "1 - " + two_power_term
    Let riemann_zeta_s be "riemann_zeta(" + argument + ")"
    
    Note: Check if 2^(1-s) = 1 (when s = 1, but handled above)
    If two_power_term == "1":
        Return "0"
    
    Note: General relation: η(s) = (1 - 2^(1-s)) * ζ(s)
    Return one_minus_two_power + " * " + riemann_zeta_s

Process called "dirichlet_beta" that takes argument as String returns String:
    Note: Dirichlet beta function β(s)
    Note: β(s) = Σ_{n=0}^{∞} (-1)^n/(2n+1)^s (Catalan's function)
    
    Note: Special case: when s = 1 (Gregory-Leibniz series)
    If argument == "1":
        Return "π/4"
    
    Note: Special case: when s = 0
    If argument == "0":
        Return "1/2"
    
    Note: Special values at positive odd integers
    If argument == "2":
        Return "catalan_constant"
    
    If argument == "3":
        Return "π^3/32"
    
    If argument == "5":
        Return "5*π^5/1536"
    
    Note: Special values at positive even integers
    If argument == "4":
        Return "π^4/96"
    
    If argument == "6":
        Return "61*π^6/46080"
    
    Note: For negative integers, use functional equation
    Let neg_int_check be "check_negative_integer_" + argument
    If neg_int_check == "true":
        Note: β(-n) = (-1)^n * E_n / 2^(n+1) where E_n are Euler numbers
        Let n be "abs(" + argument + ")"
        Let euler_number be "euler_number(" + n + ")"
        Let power_term be "2^(" + n + " + 1)"
        Let sign_term be "(-1)^" + n
        Return sign_term + " * " + euler_number + " / " + power_term
    
    Note: Relation to Hurwitz zeta function
    Note: β(s) = (1/4^s) * [ζ(s, 1/4) - ζ(s, 3/4)]
    Let s_argument be argument
    Let four_power_s be "4^" + s_argument
    Let zeta_1_4 be "hurwitz_zeta(" + s_argument + ", 1/4)"
    Let zeta_3_4 be "hurwitz_zeta(" + s_argument + ", 3/4)"
    Let difference be zeta_1_4 + " - " + zeta_3_4
    Return "(" + difference + ") / " + four_power_s

Process called "polylogarithm" that takes order as String, argument as String returns String:
    Note: Polylogarithm function Li_s(z)
    Note: Li_s(z) = Σ_{n=1}^{∞} z^n/n^s for |z| < 1
    
    Note: Special case: when z = 0
    If argument == "0":
        Return "0"
    
    Note: Special case: when z = 1
    If argument == "1":
        Return "riemann_zeta(" + order + ")"
    
    Note: Special case: when z = -1
    If argument == "-1":
        Let eta_value be "dirichlet_eta(" + order + ")"
        Return "-" + eta_value
    
    Note: Special cases for specific orders
    If order == "1":
        Note: Li_1(z) = -ln(1-z)
        Let one_minus_z be "1 - " + argument
        Return "-ln(" + one_minus_z + ")"
    
    If order == "0":
        Note: Li_0(z) = z/(1-z)
        Let one_minus_z be "1 - " + argument
        Return argument + " / (" + one_minus_z + ")"
    
    If order == "-1":
        Note: Li_{-1}(z) = z/(1-z)^2
        Let one_minus_z be "1 - " + argument
        Let denominator_squared be "(" + one_minus_z + ")^2"
        Return argument + " / " + denominator_squared
    
    If order == "2":
        Note: Li_2(z) is the dilogarithm
        If argument == "1/2":
            Return "π^2/12 - (ln(2))^2/2"
        Otherwise If argument == "-1/2":
            Return "-π^2/12 - (ln(2))^2/2"
        Otherwise If argument == "1/4":
            Return "π^2/18 + (ln(2))^2/2 - ln(2)*ln(3)"
        Otherwise:
            Return "dilogarithm(" + argument + ")"
    
    If order == "3":
        Note: Li_3(z) is the trilogarithm
        If argument == "1/2":
            Return "7*ζ(3)/8 - π^2*ln(2)/12 + (ln(2))^3/6"
        Otherwise:
            Return "trilogarithm(" + argument + ")"
    
    Note: For |z| < 1, use series expansion
    Let z_abs be "abs(" + argument + ")"
    If z_abs + " < 1":
        Return "sum_n_1_to_infinity(" + argument + "^n / n^" + order + ")"
    
    Note: For |z| > 1, use analytic continuation
    If z_abs + " > 1":
        Note: Use functional equations and transformations
        Return "polylogarithm_analytic_continuation(" + order + ", " + argument + ")"
    
    Note: For complex arguments on unit circle
    Return "polylogarithm_general(" + order + ", " + argument + ")"

Note: =====================================================================
Note: STATISTICAL FUNCTION OPERATIONS
Note: =====================================================================

Process called "normal_distribution_cdf" that takes x as String, mean as String, variance as String returns String:
    Note: Cumulative distribution function of normal distribution
    Note: Φ(x) = (1/2) * [1 + erf((x-μ)/(σ√2))]
    
    Note: Standardize the variable
    Let x_minus_mean be x + " - " + mean
    Let variance_sqrt be "sqrt(" + variance + ")"
    Let sqrt_2 be "sqrt(2)"
    Let standardized be "(" + x_minus_mean + ") / (" + variance_sqrt + " * " + sqrt_2 + ")"
    
    Note: Special case: when x equals mean
    If x == mean:
        Return "1/2"
    
    Note: Use error function to compute CDF
    Let erf_term be "error_function(" + standardized + ")"
    Return "(1 + " + erf_term + ") / 2"

Process called "chi_squared_distribution" that takes x as String, degrees_of_freedom as String returns String:
    Note: Chi-squared distribution function
    Note: PDF: f(x) = (1/(2^(k/2) * Γ(k/2))) * x^(k/2-1) * e^(-x/2)
    
    Let k be degrees_of_freedom
    
    Note: Invalid for x < 0
    Let x_positive_check be "check_positive_" + x
    If x_positive_check == "false":
        Return "0"
    
    Note: Special case: when x = 0
    If x == "0":
        If k == "2":
            Return "1/2"
        Otherwise:
            Return "0"
    
    Note: Compute normalizing constant
    Let k_half be k + " / 2"
    Let gamma_k_half be "gamma(" + k_half + ")"
    Let two_power_k_half be "2^" + k_half
    Let normalization be two_power_k_half + " * " + gamma_k_half
    
    Note: Compute the main terms
    Let k_half_minus_1 be "(" + k + " / 2) - 1"
    Let x_power_term be "power(" + x + ", " + k_half_minus_1 + ")"
    Let exp_term be "exp(-" + x + " / 2)"
    
    Return "(" + x_power_term + " * " + exp_term + ") / (" + normalization + ")"

Process called "students_t_distribution" that takes x as String, degrees_of_freedom as String returns String:
    Note: Student's t-distribution function
    Note: PDF: f(x) = Γ((v+1)/2) / (√(vπ) * Γ(v/2)) * (1 + x²/v)^(-(v+1)/2)
    
    Let v be degrees_of_freedom
    
    Note: Special case: when v = 1 (Cauchy distribution)
    If v == "1":
        Let x_squared be x + "^2"
        Let denominator be "π * (1 + " + x_squared + ")"
        Return "1 / " + denominator
    
    Note: Special case: when v = 2
    If v == "2":
        Let x_squared be x + "^2"
        Let denominator_term be "2 + " + x_squared
        Let power_term be "power(" + denominator_term + ", 3/2)"
        Return "2 / (2 * " + power_term + ")"
    
    Note: Compute gamma function terms
    Let v_plus_1_half be "(" + v + " + 1) / 2"
    Let v_half be v + " / 2"
    Let gamma_numerator be "gamma(" + v_plus_1_half + ")"
    Let gamma_denominator be "gamma(" + v_half + ")"
    
    Note: Compute normalization constant
    Let sqrt_v_pi be "sqrt(" + v + " * π)"
    Let normalization be gamma_numerator + " / (" + sqrt_v_pi + " * " + gamma_denominator + ")"
    
    Note: Compute main term
    Let x_squared be x + "^2"
    Let fraction_term be x_squared + " / " + v
    Let base_term be "1 + " + fraction_term
    Let exponent be "-(" + v + " + 1) / 2"
    Let power_term be "power(" + base_term + ", " + exponent + ")"
    
    Return normalization + " * " + power_term

Process called "f_distribution" that takes x as String, df1 as String, df2 as String returns String:
    Note: F-distribution function
    Note: PDF: f(x) = [Γ((d1+d2)/2) / (Γ(d1/2)Γ(d2/2))] * (d1/d2)^(d1/2) * x^(d1/2-1) / (1+(d1/d2)x)^((d1+d2)/2)
    
    Let d1 be df1
    Let d2 be df2
    
    Note: Invalid for x < 0
    Let x_positive_check be "check_positive_" + x
    If x_positive_check == "false":
        Return "0"
    
    Note: Special case: when x = 0
    If x == "0":
        If d1 == "2":
            Return "1"
        Otherwise:
            Return "0"
    
    Note: Compute gamma function terms
    Let d1_plus_d2_half be "(" + d1 + " + " + d2 + ") / 2"
    Let d1_half be d1 + " / 2"
    Let d2_half be d2 + " / 2"
    Let gamma_numerator be "gamma(" + d1_plus_d2_half + ")"
    Let gamma_d1_half be "gamma(" + d1_half + ")"
    Let gamma_d2_half be "gamma(" + d2_half + ")"
    Let gamma_denominator be gamma_d1_half + " * " + gamma_d2_half
    
    Note: Compute ratio term
    Let ratio be d1 + " / " + d2
    Let ratio_power be "power(" + ratio + ", " + d1_half + ")"
    
    Note: Compute x power term
    Let d1_half_minus_1 be "(" + d1 + " / 2) - 1"
    Let x_power_term be "power(" + x + ", " + d1_half_minus_1 + ")"
    
    Note: Compute denominator term
    Let ratio_x be ratio + " * " + x
    Let denominator_base be "1 + " + ratio_x
    Let denominator_exponent be d1_plus_d2_half
    Let denominator_power be "power(" + denominator_base + ", " + denominator_exponent + ")"
    
    Note: Combine all terms
    Let coefficient be gamma_numerator + " / (" + gamma_denominator + ")"
    Let numerator_terms be coefficient + " * " + ratio_power + " * " + x_power_term
    
    Return numerator_terms + " / " + denominator_power

Note: =====================================================================
Note: FUNCTION COMPOSITION OPERATIONS
Note: =====================================================================

Process called "compose_functions" that takes outer_function as String, inner_function as String returns String:
    Note: Compose two symbolic functions f(g(x))
    Note: Replace variable in outer function with inner function expression
    
    Note: Extract variable from outer function
    Let outer_variable be "extract_variable(" + outer_function + ")"
    
    Note: Handle simple cases
    If outer_function == "x":
        Return inner_function
    
    If inner_function == "x":
        Return outer_function
    
    Note: Handle constant functions
    Let outer_constant_check be "check_constant_" + outer_function
    If outer_constant_check == "true":
        Return outer_function
    
    Note: Handle identity cases
    If outer_function == "identity(x)":
        Return inner_function
    
    Note: Substitute inner function into outer function
    Let substituted be "substitute(" + outer_function + ", " + outer_variable + ", " + inner_function + ")"
    
    Note: Simplify common compositions
    If outer_function == "sin(x)" and inner_function == "2*x":
        Return "sin(2*x)"
    
    Otherwise If outer_function == "exp(x)" and inner_function == "ln(x)":
        Return "x"
    
    Otherwise If outer_function == "ln(x)" and inner_function == "exp(x)":
        Return "x"
    
    Otherwise If outer_function == "sqrt(x)" and inner_function == "x^2":
        Return "abs(x)"
    
    Otherwise If outer_function == "x^2" and inner_function == "sqrt(x)":
        Return "x"
    
    Return substituted

Process called "inverse_function" that takes function as String, variable as String returns String:
    Note: Find inverse function symbolically
    Note: Solve y = f(x) for x in terms of y
    
    Note: Handle simple linear case: y = ax + b
    If function == "a*" + variable + " + b":
        Return "(y - b) / a"
    
    Note: Handle power functions
    If function == variable + "^n":
        Return "y^(1/n)"
    
    If function == "sqrt(" + variable + ")":
        Return "y^2"
    
    If function == variable + "^2":
        Return "sqrt(y)"
    
    If function == variable + "^3":
        Return "y^(1/3)"
    
    Note: Handle exponential and logarithmic functions
    If function == "exp(" + variable + ")":
        Return "ln(y)"
    
    If function == "ln(" + variable + ")":
        Return "exp(y)"
    
    If function == "log10(" + variable + ")":
        Return "10^y"
    
    If function == "10^" + variable:
        Return "log10(y)"
    
    Note: Handle trigonometric functions (principal values)
    If function == "sin(" + variable + ")":
        Return "arcsin(y)"
    
    If function == "cos(" + variable + ")":
        Return "arccos(y)"
    
    If function == "tan(" + variable + ")":
        Return "arctan(y)"
    
    If function == "arcsin(" + variable + ")":
        Return "sin(y)"
    
    If function == "arccos(" + variable + ")":
        Return "cos(y)"
    
    If function == "arctan(" + variable + ")":
        Return "tan(y)"
    
    Note: Handle hyperbolic functions
    If function == "sinh(" + variable + ")":
        Return "arcsinh(y)"
    
    If function == "cosh(" + variable + ")":
        Return "arccosh(y)"
    
    If function == "tanh(" + variable + ")":
        Return "arctanh(y)"
    
    Note: Handle rational functions y = 1/x
    If function == "1/" + variable:
        Return "1/y"
    
    Note: General case - attempt symbolic solution
    Return "solve_for_inverse(" + function + ", " + variable + ", y)"

Process called "function_iteration" that takes function as String, iterations as Integer, initial_value as String returns String:
    Note: Iterate function n times: f(f(...f(x)...))
    Note: Apply function repeatedly starting from initial value
    
    Note: Base case: zero iterations
    If iterations == 0:
        Return initial_value
    
    Note: Base case: one iteration
    If iterations == 1:
        Return "substitute(" + function + ", x, " + initial_value + ")"
    
    Note: Handle negative iterations (requires inverse function)
    If iterations < 0:
        Let inverse_func be "inverse_function(" + function + ", x)"
        Let positive_iterations be "abs(" + iterations + ")"
        Return "function_iteration(" + inverse_func + ", " + positive_iterations + ", " + initial_value + ")"
    
    Note: Build iteration step by step
    Let current_value be initial_value
    Let iteration_count be 0
    
    While iteration_count < iterations:
        Set current_value to "substitute(" + function + ", x, " + current_value + ")"
        Set iteration_count to iteration_count + 1
    
    Note: Handle special cases for common functions
    If function == "x^2" and iterations == 2:
        Return "(" + initial_value + "^2)^2"
    
    Otherwise If function == "2*x" and iterations > 1:
        Let power_term be "2^" + iterations
        Return power_term + " * " + initial_value
    
    Otherwise If function == "x + 1" and iterations > 1:
        Return initial_value + " + " + iterations
    
    Otherwise If function == "x * r" and iterations > 1:
        Let power_term be "r^" + iterations
        Return power_term + " * " + initial_value
    
    Return current_value

Note: =====================================================================
Note: ASYMPTOTIC ANALYSIS OPERATIONS
Note: =====================================================================

Process called "asymptotic_expansion_function" that takes function as SpecialFunction, expansion_point as String, order as Integer returns String:
    Note: Compute asymptotic expansion of special function
    Note: Generate asymptotic series expansion around specified point
    
    Note: Handle expansion at infinity
    If expansion_point == "infinity":
        If function.type == "gamma":
            Let z be function.parameters[0]
            Note: Stirling's formula: Γ(z) ~ √(2π/z) * (z/e)^z * (1 + 1/(12z) + ...)
            Let stirling_base be "sqrt(2*π / " + z + ") * power(" + z + " / e, " + z + ")"
            If order >= 1:
                Let correction_1 be "1 + 1 / (12 * " + z + ")"
                Return stirling_base + " * (" + correction_1 + ")"
            Otherwise:
                Return stirling_base
        
        Otherwise If function.type == "bessel_j":
            Let nu be function.parameters[0]
            Let z be function.parameters[1]
            Note: J_ν(z) ~ √(2/(πz)) * cos(z - νπ/2 - π/4)
            Let amplitude be "sqrt(2 / (π * " + z + "))"
            Let phase be z + " - " + nu + "*π/2 - π/4"
            Return amplitude + " * cos(" + phase + ")"
        
        Otherwise If function.type == "error_function":
            Let z be function.parameters[0]
            Note: erf(z) ~ 1 - exp(-z²)/(z√π) * (1 - 1/(2z²) + ...)
            Let exp_term be "exp(-" + z + "^2)"
            Let denominator be z + " * sqrt(π)"
            Let asymptotic_term be exp_term + " / " + denominator
            If order >= 1:
                Let correction be "1 - 1 / (2 * " + z + "^2)"
                Return "1 - " + asymptotic_term + " * (" + correction + ")"
            Otherwise:
                Return "1 - " + asymptotic_term
    
    Note: Handle expansion at zero
    Otherwise If expansion_point == "0":
        If function.type == "bessel_j":
            Let nu be function.parameters[0]
            Let z be function.parameters[1]
            Note: J_ν(z) ~ (z/2)^ν / Γ(ν+1)
            Let z_half be z + " / 2"
            Let power_term be "power(" + z_half + ", " + nu + ")"
            Let nu_plus_1 be nu + " + 1"
            Let gamma_term be "gamma(" + nu_plus_1 + ")"
            Return power_term + " / " + gamma_term
        
        Otherwise If function.type == "error_function":
            Let z be function.parameters[0]
            Note: erf(z) ~ (2/√π) * (z - z³/3 + z⁵/10 - ...)
            Let coefficient be "2 / sqrt(π)"
            Let z_cubed be z + "^3"
            Let z_fifth be z + "^5"
            If order >= 2:
                Return coefficient + " * (" + z + " - " + z_cubed + "/6 + " + z_fifth + "/40)"
            Otherwise If order >= 1:
                Return coefficient + " * (" + z + " - " + z_cubed + "/6)"
            Otherwise:
                Return coefficient + " * " + z
    
    Note: General asymptotic expansion
    Return "asymptotic_series(" + function.type + ", " + expansion_point + ", " + order + ")"

Process called "stirling_approximation" that takes argument as String, order as Integer returns String:
    Note: Stirling's approximation for factorial/gamma function
    Note: Γ(n) ≈ √(2πn) * (n/e)^n * (1 + 1/(12n) + 1/(288n²) + ...)
    
    Let n be argument
    
    Note: Base Stirling formula
    Let sqrt_2pi_n be "sqrt(2 * π * " + n + ")"
    Let n_over_e be n + " / e"
    Let power_term be "power(" + n_over_e + ", " + n + ")"
    Let base_stirling be sqrt_2pi_n + " * " + power_term
    
    Note: Zero-order approximation
    If order == 0:
        Return base_stirling
    
    Note: First-order correction
    If order >= 1:
        Let first_correction be "1 + 1 / (12 * " + n + ")"
        Let result be base_stirling + " * (" + first_correction
        
        Note: Second-order correction
        If order >= 2:
            Let n_squared be n + "^2"
            Let second_correction be " + 1 / (288 * " + n_squared + ")"
            Set result to result + second_correction
        
        Note: Third-order correction
        If order >= 3:
            Let n_cubed be n + "^3"
            Let third_correction be " - 139 / (51840 * " + n_cubed + ")"
            Set result to result + third_correction
        
        Note: Fourth-order correction  
        If order >= 4:
            Let n_fourth be n + "^4"
            Let fourth_correction be " - 571 / (2488320 * " + n_fourth + ")"
            Set result to result + fourth_correction
        
        Return result + ")"
    
    Return base_stirling

Process called "saddle_point_approximation" that takes function as String, parameter as String returns String:
    Note: Saddle point method for asymptotic analysis
    Note: Approximate integrals of form ∫ f(x) * exp(N*g(x)) dx for large N
    
    Note: Find saddle point where g'(x) = 0
    Let saddle_point be "solve_derivative_zero(" + function + ", " + parameter + ")"
    
    Note: Handle common cases
    If function == "exp(-x^2)":
        Note: Gaussian integral case
        Let N be parameter
        Return "sqrt(π / " + N + ")"
    
    Otherwise If function == "x^n * exp(-x)":
        Note: Gamma function integral
        Let n be "extract_power(" + function + ")"
        Let N be parameter
        Let n_factorial be "factorial(" + n + ")"
        Return n_factorial + " / " + N + "^(" + n + " + 1)"
    
    Otherwise If function == "exp(x) / (1 + x)":
        Note: Modified exponential case
        Let N be parameter
        Let saddle_x0 be "saddle_point_solution(exp(x) / (1 + x))"
        Let f_x0 be "evaluate_at(" + function + ", " + saddle_x0 + ")"
        Let g_x0 be "evaluate_second_derivative_at(ln(" + function + "), " + saddle_x0 + ")"
        Let approximation be "sqrt(2 * π / (" + N + " * abs(" + g_x0 + "))) * " + f_x0 + " * exp(" + N + " * ln(" + f_x0 + "))"
        Return approximation
    
    Note: General saddle point method
    Note: Evaluate f(x0) * exp(N*g(x0)) * sqrt(2π / (N * |g''(x0)|))
    Let f_x0 be "evaluate_at(" + function + ", " + saddle_point + ")"
    Let g_x0 be "evaluate_at(extract_exponent(" + function + "), " + saddle_point + ")"
    Let g_double_prime_x0 be "evaluate_second_derivative_at(extract_exponent(" + function + "), " + saddle_point + ")"
    
    Let exponential_part be "exp(" + parameter + " * " + g_x0 + ")"
    Let gaussian_part be "sqrt(2 * π / (" + parameter + " * abs(" + g_double_prime_x0 + ")))"
    
    Return f_x0 + " * " + exponential_part + " * " + gaussian_part

Note: =====================================================================
Note: VALIDATION AND UTILITY OPERATIONS
Note: =====================================================================

Process called "verify_function_identity" that takes function_a as String, function_b as String, variable_domain as Dictionary[String, String] returns Boolean:
    Note: Verify if two function expressions are identical
    Note: Check if f(x) = g(x) for all x in domain
    
    Note: Trivial case: identical strings
    If function_a == function_b:
        Return true
    
    Note: Simplify both functions
    Let simplified_a be "simplify(" + function_a + ")"
    Let simplified_b be "simplify(" + function_b + ")"
    
    If simplified_a == simplified_b:
        Return true
    
    Note: Check common algebraic identities
    Note: sin²(x) + cos²(x) = 1
    If function_a == "sin(x)^2 + cos(x)^2" and function_b == "1":
        Return true
    
    If function_b == "sin(x)^2 + cos(x)^2" and function_a == "1":
        Return true
    
    Note: exp(ln(x)) = x for x > 0
    If function_a == "exp(ln(x))" and function_b == "x":
        Let domain_x be variable_domain["x"]
        Let positive_check be "check_positive_domain(" + domain_x + ")"
        If positive_check == "true":
            Return true
    
    Note: ln(exp(x)) = x
    If function_a == "ln(exp(x))" and function_b == "x":
        Return true
    
    Note: (a^m)^n = a^(mn)
    Let power_pattern_a be "check_nested_power(" + function_a + ")"
    Let power_pattern_b be "check_nested_power(" + function_b + ")"
    If power_pattern_a == "true" and power_pattern_b == "true":
        Let expanded_a be "expand_nested_powers(" + function_a + ")"
        Let expanded_b be "expand_nested_powers(" + function_b + ")"
        If expanded_a == expanded_b:
            Return true
    
    Note: Numerical verification at sample points
    Let sample_points be "generate_sample_points(" + variable_domain + ", 100)"
    Let numerical_match be "check_numerical_equality(" + function_a + ", " + function_b + ", " + sample_points + ")"
    
    If numerical_match == "true":
        Note: High confidence but not proof
        Return "likely_true"
    
    Return false

Process called "function_domain_analysis" that takes function as String, variables as List[String] returns Dictionary[String, Dictionary[String, String]]:
    Note: Analyze domain and range of symbolic function
    Note: Determine where function is defined and what values it can take
    
    Let analysis be Dictionary[String, Dictionary[String, String]]
    
    Note: Analyze each variable
    Let var_index be 0
    While var_index < variables.length:
        Let var be variables[var_index]
        Let var_analysis be Dictionary[String, String]
        
        Note: Check for division by zero
        Let division_check be "find_division_by_zero(" + function + ", " + var + ")"
        If division_check != "none":
            Set var_analysis["domain_restriction"] to "exclude_" + division_check
        Otherwise:
            Set var_analysis["domain_restriction"] to "all_real"
        
        Note: Check for square root restrictions
        Let sqrt_check be "find_sqrt_restrictions(" + function + ", " + var + ")"
        If sqrt_check != "none":
            Set var_analysis["sqrt_domain"] to "require_" + sqrt_check + "_nonnegative"
        
        Note: Check for logarithm restrictions
        Let log_check be "find_log_restrictions(" + function + ", " + var + ")"
        If log_check != "none":
            Set var_analysis["log_domain"] to "require_" + log_check + "_positive"
        
        Note: Check for trigonometric restrictions
        Let trig_check be "find_trig_restrictions(" + function + ", " + var + ")"
        If trig_check != "none":
            Set var_analysis["trig_domain"] to trig_check
        
        Set analysis[var] to var_analysis
        Set var_index to var_index + 1
    
    Note: Analyze overall function range
    Let range_analysis be Dictionary[String, String]
    
    Note: Common function ranges
    If function == "sin(x)" or function == "cos(x)":
        Set range_analysis["min"] to "-1"
        Set range_analysis["max"] to "1"
        Set range_analysis["type"] to "bounded"
    
    Otherwise If function == "tan(x)":
        Set range_analysis["min"] to "-infinity"
        Set range_analysis["max"] to "infinity"
        Set range_analysis["type"] to "unbounded"
        Set range_analysis["discontinuities"] to "pi/2 + n*pi"
    
    Otherwise If function == "exp(x)":
        Set range_analysis["min"] to "0"
        Set range_analysis["max"] to "infinity"
        Set range_analysis["type"] to "semi_bounded"
    
    Otherwise If function == "ln(x)":
        Set range_analysis["min"] to "-infinity"
        Set range_analysis["max"] to "infinity"
        Set range_analysis["type"] to "unbounded"
        Set range_analysis["domain_restriction"] to "x > 0"
    
    Otherwise If function == "sqrt(x)":
        Set range_analysis["min"] to "0"
        Set range_analysis["max"] to "infinity"
        Set range_analysis["type"] to "semi_bounded"
        Set range_analysis["domain_restriction"] to "x >= 0"
    
    Otherwise:
        Set range_analysis["type"] to "general_analysis_needed"
        Set range_analysis["method"] to "calculus_extrema_analysis"
    
    Set analysis["range"] to range_analysis
    
    Return analysis

Process called "benchmark_special_functions" that takes function_types as List[String], test_parameters as Dictionary[String, List[String]] returns Dictionary[String, Float]:
    Note: Benchmark performance of special function evaluations
    Note: Time execution of various special functions with test parameters
    
    Let benchmark_results be Dictionary[String, Float]
    
    Note: Benchmark each function type
    Let func_index be 0
    While func_index < function_types.length:
        Let function_type be function_types[func_index]
        Let test_params be test_parameters[function_type]
        
        Note: Initialize timing variables
        Let total_time be 0.0
        Let num_tests be test_params.length
        Let start_time be "get_current_time()"
        
        Note: Run benchmarks based on function type
        If function_type == "gamma":
            Let param_index be 0
            While param_index < test_params.length:
                Let param be test_params[param_index]
                Let test_start be "get_current_time()"
                Let result be "gamma(" + param + ")"
                Let test_end be "get_current_time()"
                Set total_time to total_time + (test_end - test_start)
                Set param_index to param_index + 1
        
        Otherwise If function_type == "bessel_j":
            Let param_index be 0
            While param_index < test_params.length:
                Let params be test_params[param_index]
                Let order be "extract_first(" + params + ")"
                Let argument be "extract_second(" + params + ")"
                Let test_start be "get_current_time()"
                Let result be "bessel_j(" + order + ", " + argument + ")"
                Let test_end be "get_current_time()"
                Set total_time to total_time + (test_end - test_start)
                Set param_index to param_index + 1
        
        Otherwise If function_type == "riemann_zeta":
            Let param_index be 0
            While param_index < test_params.length:
                Let param be test_params[param_index]
                Let test_start be "get_current_time()"
                Let result be "riemann_zeta(" + param + ")"
                Let test_end be "get_current_time()"
                Set total_time to total_time + (test_end - test_start)
                Set param_index to param_index + 1
        
        Otherwise If function_type == "hypergeometric_2f1":
            Let param_index be 0
            While param_index < test_params.length:
                Let params be test_params[param_index]
                Let a be "extract_param(" + params + ", 0)"
                Let b be "extract_param(" + params + ", 1)"
                Let c be "extract_param(" + params + ", 2)"
                Let z be "extract_param(" + params + ", 3)"
                Let test_start be "get_current_time()"
                Let result be "hypergeometric_2f1(" + a + ", " + b + ", " + c + ", " + z + ")"
                Let test_end be "get_current_time()"
                Set total_time to total_time + (test_end - test_start)
                Set param_index to param_index + 1
        
        Otherwise:
            Note: Generic function benchmarking
            Let param_index be 0
            While param_index < test_params.length:
                Let param be test_params[param_index]
                Let test_start be "get_current_time()"
                Let result be "evaluate_function(" + function_type + ", " + param + ")"
                Let test_end be "get_current_time()"
                Set total_time to total_time + (test_end - test_start)
                Set param_index to param_index + 1
        
        Note: Calculate average time per evaluation
        Let average_time be total_time / num_tests
        Set benchmark_results[function_type] to average_time
        
        Set func_index to func_index + 1
    
    Note: Add summary statistics
    Let fastest_function be "find_minimum_key(" + benchmark_results + ")"
    Let slowest_function be "find_maximum_key(" + benchmark_results + ")"
    Set benchmark_results["fastest"] to fastest_function
    Set benchmark_results["slowest"] to slowest_function
    
    Return benchmark_results