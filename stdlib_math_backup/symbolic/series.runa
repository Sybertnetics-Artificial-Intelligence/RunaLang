Note:
math/symbolic/series.runa
Symbolic Series Analysis and Manipulation System

This module provides comprehensive symbolic series operations including:
- Power series expansion and manipulation
- Taylor series with arbitrary expansion points
- Laurent series for functions with poles
- Fourier series for periodic functions
- Generating functions and combinatorial series
- Asymptotic series and expansions
- Series convergence testing and analysis
- Series arithmetic (addition, multiplication, composition)
- Series reversion and inversion techniques
- Padé approximants and rational interpolation
- Continued fraction representations
- q-series and basic hypergeometric functions
- Formal power series ring operations
- Series truncation and error analysis
- Multi-variable series expansions
:End Note

Import "dev/debug/errors/core" as Errors
Import "math/symbolic/core" as SymbolicCore
Import "math/precision/bigdecimal" as BigDecimal
Import "math/precision/biginteger" as BigInteger
Import "collections" as Collections

Note: =====================================================================
Note: SERIES DATA STRUCTURES
Note: =====================================================================

Type called "PowerSeries":
    coefficients as Dictionary[String, String]
    variable as String
    expansion_point as String
    series_order as Integer
    radius_of_convergence as String
    series_type as String
    truncation_error as String

Type called "FourierSeries":
    cosine_coefficients as Dictionary[String, String]
    sine_coefficients as Dictionary[String, String]
    dc_component as String
    period as String
    convergence_type as String
    partial_sum_order as Integer

Type called "GeneratingFunction":
    function_expression as String
    sequence_type as String
    generating_variable as String
    sequence_coefficients as Dictionary[String, String]
    exponential_type as Boolean
    ordinary_type as Boolean

Type called "AsymptoticSeries":
    leading_terms as Dictionary[String, String]
    asymptotic_scale as List[String]
    expansion_point as String
    error_bounds as Dictionary[String, String]
    validity_region as Dictionary[String, String]

Type called "ContinuedFraction":
    partial_quotients as List[String]
    convergents as List[Dictionary[String, String]]
    fraction_type as String
    simple_form as Boolean
    periodic_part as List[String]

Note: =====================================================================
Note: POWER SERIES OPERATIONS
Note: =====================================================================

Process called "create_power_series" that takes coefficients as Dictionary[String, String], variable as String, expansion_point as String returns PowerSeries:
    Note: Create power series from coefficient dictionary
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If Collections.size(coefficients) equals 0:
        Throw Errors.ArgumentError with "Coefficients dictionary cannot be empty"
    
    Let max_order be 0
    For each key in Collections.keys(coefficients):
        Let power be BigInteger.parse_from_string(key)
        If BigInteger.compare(power, BigInteger.from_integer(max_order)) greater_than 0:
            Let max_order be BigInteger.to_integer(power)
    
    Let radius be "1.0"
    Let series be PowerSeries{
        coefficients: coefficients,
        variable: variable,
        expansion_point: expansion_point,
        series_order: max_order,
        radius_of_convergence: radius,
        series_type: "general",
        truncation_error: "0.0"
    }
    Return series

Process called "taylor_series_expansion" that takes function as String, variable as String, expansion_point as String, order as Integer returns PowerSeries:
    Note: Compute Taylor series expansion around specified point
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If order less than 0:
        Throw Errors.ArgumentError with "Series order must be non-negative"
    
    Let expr be SymbolicCore.parse_expression(function)
    Let coefficients be Collections.empty_dictionary()
    Let factorial_n be BigInteger.from_integer(1)
    
    For n from 0 to order:
        Let derivative_n be expr
        For i from 1 to n:
            Let derivative_n be SymbolicCore.differentiate(derivative_n, variable)
        
        Let evaluated_derivative be SymbolicCore.substitute_value(derivative_n, variable, expansion_point)
        Let coefficient_value be BigDecimal.divide(evaluated_derivative, BigInteger.to_string(factorial_n))
        Let coefficients be Collections.set(coefficients, BigInteger.to_string(BigInteger.from_integer(n)), coefficient_value)
        
        Let factorial_n be BigInteger.multiply(factorial_n, BigInteger.from_integer(n + 1))
    
    Let series be PowerSeries{
        coefficients: coefficients,
        variable: variable,
        expansion_point: expansion_point,
        series_order: order,
        radius_of_convergence: "1.0",
        series_type: "taylor",
        truncation_error: "0.0"
    }
    Return series

Process called "maclaurin_series_expansion" that takes function as String, variable as String, order as Integer returns PowerSeries:
    Note: Compute Maclaurin series (Taylor series at origin)
    Return taylor_series_expansion(function, variable, "0", order)

Process called "binomial_series_expansion" that takes exponent as String, variable as String, order as Integer returns PowerSeries:
    Note: Expand (1+x)^α using binomial series
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If order less than 0:
        Throw Errors.ArgumentError with "Series order must be non-negative"
    
    Let coefficients be Collections.empty_dictionary()
    Let alpha be BigDecimal.from_string(exponent)
    
    For k from 0 to order:
        Let binomial_coef be BigDecimal.from_string("1")
        For j from 1 to k:
            Let numerator be BigDecimal.subtract(alpha, BigDecimal.from_integer(j - 1))
            Let binomial_coef be BigDecimal.multiply(binomial_coef, numerator)
            Let binomial_coef be BigDecimal.divide(binomial_coef, BigDecimal.from_integer(j))
        
        Let coefficients be Collections.set(coefficients, BigInteger.to_string(BigInteger.from_integer(k)), BigDecimal.to_string(binomial_coef))
    
    Let series be PowerSeries{
        coefficients: coefficients,
        variable: variable,
        expansion_point: "0",
        series_order: order,
        radius_of_convergence: "1.0",
        series_type: "binomial",
        truncation_error: "0.0"
    }
    Return series

Process called "geometric_series_expansion" that takes ratio as String, variable as String, order as Integer returns PowerSeries:
    Note: Expand geometric series 1/(1-r) with specified ratio
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If order less than 0:
        Throw Errors.ArgumentError with "Series order must be non-negative"
    
    Let coefficients be Collections.empty_dictionary()
    Let r be BigDecimal.from_string(ratio)
    Let power_of_r be BigDecimal.from_string("1")
    
    For n from 0 to order:
        Let coefficients be Collections.set(coefficients, BigInteger.to_string(BigInteger.from_integer(n)), BigDecimal.to_string(power_of_r))
        Let power_of_r be BigDecimal.multiply(power_of_r, r)
    
    Let radius_value be BigDecimal.abs(r)
    If BigDecimal.compare(radius_value, BigDecimal.from_string("1")) less than 0:
        Let radius be BigDecimal.divide(BigDecimal.from_string("1"), radius_value)
    Otherwise:
        Let radius be BigDecimal.from_string("0")
    
    Let series be PowerSeries{
        coefficients: coefficients,
        variable: variable,
        expansion_point: "0",
        series_order: order,
        radius_of_convergence: BigDecimal.to_string(radius),
        series_type: "geometric",
        truncation_error: "0.0"
    }
    Return series

Process called "exponential_series_expansion" that takes argument as String, order as Integer returns PowerSeries:
    Note: Expand e^x series with specified order
    If order less than 0:
        Throw Errors.ArgumentError with "Series order must be non-negative"
    
    Let coefficients be Collections.empty_dictionary()
    Let factorial be BigInteger.from_integer(1)
    
    For n from 0 to order:
        If n greater than 0:
            Let factorial be BigInteger.multiply(factorial, BigInteger.from_integer(n))
        
        Let coefficient_value be BigDecimal.divide(BigDecimal.from_string("1"), BigInteger.to_string(factorial))
        Let coefficients be Collections.set(coefficients, BigInteger.to_string(BigInteger.from_integer(n)), BigDecimal.to_string(coefficient_value))
    
    Let series be PowerSeries{
        coefficients: coefficients,
        variable: argument,
        expansion_point: "0",
        series_order: order,
        radius_of_convergence: "infinity",
        series_type: "exponential",
        truncation_error: "0.0"
    }
    Return series

Process called "logarithmic_series_expansion" that takes argument as String, order as Integer returns PowerSeries:
    Note: Expand ln(1+x) series with specified order
    If order less than 1:
        Throw Errors.ArgumentError with "Series order must be at least 1 for logarithmic series"
    
    Let coefficients be Collections.empty_dictionary()
    Let coefficients be Collections.set(coefficients, "0", "0")
    
    For n from 1 to order:
        Let sign be 1
        If n % 2 equals 0:
            Let sign be -1
        
        Let coefficient_value be BigDecimal.divide(BigDecimal.from_integer(sign), BigDecimal.from_integer(n))
        Let coefficients be Collections.set(coefficients, BigInteger.to_string(BigInteger.from_integer(n)), BigDecimal.to_string(coefficient_value))
    
    Let series be PowerSeries{
        coefficients: coefficients,
        variable: argument,
        expansion_point: "0",
        series_order: order,
        radius_of_convergence: "1.0",
        series_type: "logarithmic",
        truncation_error: "0.0"
    }
    Return series

Note: =====================================================================
Note: LAURENT SERIES OPERATIONS
Note: =====================================================================

Process called "laurent_series_expansion" that takes function as String, variable as String, expansion_point as String, positive_order as Integer, negative_order as Integer returns PowerSeries:
    Note: Compute Laurent series expansion including negative powers
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If positive_order less than 0:
        Throw Errors.ArgumentError with "Positive order must be non-negative"
    If negative_order less than 0:
        Throw Errors.ArgumentError with "Negative order must be non-negative"
    
    Let expr be SymbolicCore.parse_expression(function)
    Let coefficients be Collections.empty_dictionary()
    
    For n from (-negative_order) to positive_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        
        If n less than 0:
            Let power_factor be SymbolicCore.create_power(SymbolicCore.create_subtraction(SymbolicCore.create_symbol(variable, Collections.empty_dictionary()), SymbolicCore.create_constant(expansion_point)), SymbolicCore.create_constant(BigInteger.to_string(BigInteger.from_integer(-n))))
            Let modified_function be SymbolicCore.multiply_expressions(expr, power_factor)
            Let derivative_at_point be SymbolicCore.substitute_value(modified_function, variable, expansion_point)
        Otherwise:
            Let derivative_n be expr
            For i from 1 to n:
                Let derivative_n be SymbolicCore.differentiate(derivative_n, variable)
            Let derivative_at_point be SymbolicCore.substitute_value(derivative_n, variable, expansion_point)
        
        Let factorial_n be BigInteger.factorial(BigInteger.from_integer(n))
        If n less than 0:
            Let factorial_n be BigInteger.from_integer(1)
        
        Let coefficient_value be BigDecimal.divide(derivative_at_point, BigInteger.to_string(factorial_n))
        Let coefficients be Collections.set(coefficients, n_str, coefficient_value)
    
    Let series be PowerSeries{
        coefficients: coefficients,
        variable: variable,
        expansion_point: expansion_point,
        series_order: positive_order,
        radius_of_convergence: "1.0",
        series_type: "laurent",
        truncation_error: "0.0"
    }
    Return series

Process called "principal_part_extraction" that takes laurent_series as PowerSeries returns PowerSeries:
    Note: Extract principal part (negative powers) from Laurent series
    Let principal_coefficients be Collections.empty_dictionary()
    
    For each key in Collections.keys(laurent_series.coefficients):
        Let power be BigInteger.parse_from_string(key)
        If BigInteger.compare(power, BigInteger.from_integer(0)) less_than 0:
            Let coefficient_value be Collections.get(laurent_series.coefficients, key)
            Let principal_coefficients be Collections.set(principal_coefficients, key, coefficient_value)
    
    Let principal_series be PowerSeries{
        coefficients: principal_coefficients,
        variable: laurent_series.variable,
        expansion_point: laurent_series.expansion_point,
        series_order: 0,
        radius_of_convergence: laurent_series.radius_of_convergence,
        series_type: "principal_part",
        truncation_error: "0.0"
    }
    Return principal_series

Process called "regular_part_extraction" that takes laurent_series as PowerSeries returns PowerSeries:
    Note: Extract regular part (non-negative powers) from Laurent series
    Let regular_coefficients be Collections.empty_dictionary()
    Let max_positive_order be 0
    
    For each key in Collections.keys(laurent_series.coefficients):
        Let power be BigInteger.parse_from_string(key)
        If BigInteger.compare(power, BigInteger.from_integer(0)) greater_than_or_equals 0:
            Let coefficient_value be Collections.get(laurent_series.coefficients, key)
            Let regular_coefficients be Collections.set(regular_coefficients, key, coefficient_value)
            If BigInteger.compare(power, BigInteger.from_integer(max_positive_order)) greater_than 0:
                Let max_positive_order be BigInteger.to_integer(power)
    
    Let regular_series be PowerSeries{
        coefficients: regular_coefficients,
        variable: laurent_series.variable,
        expansion_point: laurent_series.expansion_point,
        series_order: max_positive_order,
        radius_of_convergence: laurent_series.radius_of_convergence,
        series_type: "regular_part",
        truncation_error: "0.0"
    }
    Return regular_series

Process called "residue_from_laurent" that takes laurent_series as PowerSeries returns String:
    Note: Extract residue (coefficient of 1/(z-a)) from Laurent series
    Let residue_coefficient be Collections.get_or_default(laurent_series.coefficients, "-1", "0")
    Return residue_coefficient

Note: =====================================================================
Note: FOURIER SERIES OPERATIONS
Note: =====================================================================

Process called "fourier_series_expansion" that takes function as String, variable as String, period as String, harmonics as Integer returns FourierSeries:
    Note: Compute Fourier series expansion of periodic function
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If harmonics less than 0:
        Throw Errors.ArgumentError with "Number of harmonics must be non-negative"
    
    Let expr be SymbolicCore.parse_expression(function)
    Let cosine_coefficients be Collections.empty_dictionary()
    Let sine_coefficients be Collections.empty_dictionary()
    Let period_value be BigDecimal.from_string(period)
    
    Let dc_integrand be expr
    Let dc_component be BigDecimal.divide(
        SymbolicCore.definite_integral(dc_integrand, variable, BigDecimal.multiply(period_value, BigDecimal.from_string("-0.5")), BigDecimal.multiply(period_value, BigDecimal.from_string("0.5"))),
        period_value
    )
    
    For n from 1 to harmonics:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let frequency_term be BigDecimal.divide(BigDecimal.multiply(BigDecimal.from_string("2"), BigDecimal.multiply(BigDecimal.from_string("3.141592653589793"), BigDecimal.from_integer(n))), period_value)
        
        Let cosine_term be SymbolicCore.create_function_call("cos", Collections.from_list([SymbolicCore.create_multiplication(SymbolicCore.create_constant(BigDecimal.to_string(frequency_term)), SymbolicCore.create_symbol(variable, Collections.empty_dictionary()))]))
        Let cosine_integrand be SymbolicCore.multiply_expressions(expr, cosine_term)
        Let cosine_coefficient be BigDecimal.divide(
            SymbolicCore.definite_integral(cosine_integrand, variable, BigDecimal.multiply(period_value, BigDecimal.from_string("-0.5")), BigDecimal.multiply(period_value, BigDecimal.from_string("0.5"))),
            BigDecimal.multiply(period_value, BigDecimal.from_string("0.5"))
        )
        Let cosine_coefficients be Collections.set(cosine_coefficients, n_str, BigDecimal.to_string(cosine_coefficient))
        
        Let sine_term be SymbolicCore.create_function_call("sin", Collections.from_list([SymbolicCore.create_multiplication(SymbolicCore.create_constant(BigDecimal.to_string(frequency_term)), SymbolicCore.create_symbol(variable, Collections.empty_dictionary()))]))
        Let sine_integrand be SymbolicCore.multiply_expressions(expr, sine_term)
        Let sine_coefficient be BigDecimal.divide(
            SymbolicCore.definite_integral(sine_integrand, variable, BigDecimal.multiply(period_value, BigDecimal.from_string("-0.5")), BigDecimal.multiply(period_value, BigDecimal.from_string("0.5"))),
            BigDecimal.multiply(period_value, BigDecimal.from_string("0.5"))
        )
        Let sine_coefficients be Collections.set(sine_coefficients, n_str, BigDecimal.to_string(sine_coefficient))
    
    Let fourier_series be FourierSeries{
        cosine_coefficients: cosine_coefficients,
        sine_coefficients: sine_coefficients,
        dc_component: BigDecimal.to_string(dc_component),
        period: period,
        convergence_type: "pointwise",
        partial_sum_order: harmonics
    }
    Return fourier_series

Process called "fourier_cosine_series" that takes even_function as String, variable as String, period as String, terms as Integer returns FourierSeries:
    Note: Compute Fourier cosine series for even functions
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If terms less than 0:
        Throw Errors.ArgumentError with "Number of terms must be non-negative"
    
    Let expr be SymbolicCore.parse_expression(even_function)
    Let cosine_coefficients be Collections.empty_dictionary()
    Let sine_coefficients be Collections.empty_dictionary()
    Let period_value be BigDecimal.from_string(period)
    
    Let dc_integrand be expr
    Let dc_component be BigDecimal.divide(
        BigDecimal.multiply(BigDecimal.from_string("2"), SymbolicCore.definite_integral(dc_integrand, variable, BigDecimal.from_string("0"), BigDecimal.multiply(period_value, BigDecimal.from_string("0.5")))),
        period_value
    )
    
    For n from 1 to terms:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let frequency_term be BigDecimal.divide(BigDecimal.multiply(BigDecimal.from_string("2"), BigDecimal.multiply(BigDecimal.from_string("3.141592653589793"), BigDecimal.from_integer(n))), period_value)
        
        Let cosine_term be SymbolicCore.create_function_call("cos", Collections.from_list([SymbolicCore.create_multiplication(SymbolicCore.create_constant(BigDecimal.to_string(frequency_term)), SymbolicCore.create_symbol(variable, Collections.empty_dictionary()))]))
        Let cosine_integrand be SymbolicCore.multiply_expressions(expr, cosine_term)
        Let cosine_coefficient be BigDecimal.divide(
            BigDecimal.multiply(BigDecimal.from_string("2"), SymbolicCore.definite_integral(cosine_integrand, variable, BigDecimal.from_string("0"), BigDecimal.multiply(period_value, BigDecimal.from_string("0.5")))),
            period_value
        )
        Let cosine_coefficients be Collections.set(cosine_coefficients, n_str, BigDecimal.to_string(cosine_coefficient))
        
        Let sine_coefficients be Collections.set(sine_coefficients, n_str, "0")
    
    Let fourier_series be FourierSeries{
        cosine_coefficients: cosine_coefficients,
        sine_coefficients: sine_coefficients,
        dc_component: BigDecimal.to_string(dc_component),
        period: period,
        convergence_type: "uniform",
        partial_sum_order: terms
    }
    Return fourier_series

Process called "fourier_sine_series" that takes odd_function as String, variable as String, period as String, terms as Integer returns FourierSeries:
    Note: Compute Fourier sine series for odd functions
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If terms less than 0:
        Throw Errors.ArgumentError with "Number of terms must be non-negative"
    
    Let expr be SymbolicCore.parse_expression(odd_function)
    Let cosine_coefficients be Collections.empty_dictionary()
    Let sine_coefficients be Collections.empty_dictionary()
    Let period_value be BigDecimal.from_string(period)
    
    For n from 1 to terms:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let frequency_term be BigDecimal.divide(BigDecimal.multiply(BigDecimal.from_string("2"), BigDecimal.multiply(BigDecimal.from_string("3.141592653589793"), BigDecimal.from_integer(n))), period_value)
        
        Let sine_term be SymbolicCore.create_function_call("sin", Collections.from_list([SymbolicCore.create_multiplication(SymbolicCore.create_constant(BigDecimal.to_string(frequency_term)), SymbolicCore.create_symbol(variable, Collections.empty_dictionary()))]))
        Let sine_integrand be SymbolicCore.multiply_expressions(expr, sine_term)
        Let sine_coefficient be BigDecimal.divide(
            BigDecimal.multiply(BigDecimal.from_string("2"), SymbolicCore.definite_integral(sine_integrand, variable, BigDecimal.from_string("0"), BigDecimal.multiply(period_value, BigDecimal.from_string("0.5")))),
            period_value
        )
        Let sine_coefficients be Collections.set(sine_coefficients, n_str, BigDecimal.to_string(sine_coefficient))
        
        Let cosine_coefficients be Collections.set(cosine_coefficients, n_str, "0")
    
    Let fourier_series be FourierSeries{
        cosine_coefficients: cosine_coefficients,
        sine_coefficients: sine_coefficients,
        dc_component: "0",
        period: period,
        convergence_type: "uniform",
        partial_sum_order: terms
    }
    Return fourier_series

Process called "complex_fourier_series" that takes function as String, variable as String, period as String, terms as Integer returns Dictionary[String, String]:
    Note: Compute complex Fourier series representation
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If terms less than 0:
        Throw Errors.ArgumentError with "Number of terms must be non-negative"
    
    Let expr be SymbolicCore.parse_expression(function)
    Let complex_coefficients be Collections.empty_dictionary()
    Let period_value be BigDecimal.from_string(period)
    
    For n from (-terms) to terms:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let frequency_term be BigDecimal.divide(BigDecimal.multiply(BigDecimal.from_string("2"), BigDecimal.multiply(BigDecimal.from_string("3.141592653589793"), BigDecimal.from_integer(n))), period_value)
        
        Let exponential_real be SymbolicCore.create_function_call("cos", Collections.from_list([SymbolicCore.create_multiplication(SymbolicCore.create_constant(BigDecimal.to_string(frequency_term)), SymbolicCore.create_symbol(variable, Collections.empty_dictionary()))]))
        Let exponential_imag be SymbolicCore.create_function_call("sin", Collections.from_list([SymbolicCore.create_multiplication(SymbolicCore.create_constant(BigDecimal.to_string(frequency_term)), SymbolicCore.create_symbol(variable, Collections.empty_dictionary()))]))
        
        Let real_integrand be SymbolicCore.multiply_expressions(expr, exponential_real)
        Let imag_integrand be SymbolicCore.multiply_expressions(expr, exponential_imag)
        
        Let real_part be BigDecimal.divide(
            SymbolicCore.definite_integral(real_integrand, variable, BigDecimal.multiply(period_value, BigDecimal.from_string("-0.5")), BigDecimal.multiply(period_value, BigDecimal.from_string("0.5"))),
            period_value
        )
        Let imag_part be BigDecimal.divide(
            SymbolicCore.definite_integral(imag_integrand, variable, BigDecimal.multiply(period_value, BigDecimal.from_string("-0.5")), BigDecimal.multiply(period_value, BigDecimal.from_string("0.5"))),
            BigDecimal.negate(period_value)
        )
        
        Let complex_value be BigDecimal.to_string(real_part) + " + " + BigDecimal.to_string(imag_part) + "i"
        Let complex_coefficients be Collections.set(complex_coefficients, n_str, complex_value)
    
    Return complex_coefficients

Process called "gibbs_phenomenon_analysis" that takes fourier_series as FourierSeries, discontinuity_points as List[String] returns Dictionary[String, String]:
    Note: Analyze Gibbs phenomenon at discontinuity points
    Let analysis_results be Collections.empty_dictionary()
    Let gibbs_overshoot_factor be BigDecimal.from_string("1.089490")
    
    For each discontinuity_point in discontinuity_points:
        Let point_analysis be Collections.empty_dictionary()
        
        Let partial_sum_value be BigDecimal.from_string(fourier_series.dc_component)
        For n from 1 to fourier_series.partial_sum_order:
            Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
            Let cosine_coeff be Collections.get_or_default(fourier_series.cosine_coefficients, n_str, "0")
            Let sine_coeff be Collections.get_or_default(fourier_series.sine_coefficients, n_str, "0")
            
            Let frequency_term be BigDecimal.divide(BigDecimal.multiply(BigDecimal.from_string("2"), BigDecimal.multiply(BigDecimal.from_string("3.141592653589793"), BigDecimal.from_integer(n))), BigDecimal.from_string(fourier_series.period))
            Let argument be BigDecimal.multiply(frequency_term, BigDecimal.from_string(discontinuity_point))
            
            Let cosine_value be BigDecimal.multiply(BigDecimal.from_string(cosine_coeff), SymbolicCore.evaluate_numerically(SymbolicCore.create_function_call("cos", Collections.from_list([SymbolicCore.create_constant(BigDecimal.to_string(argument))]))))
            Let sine_value be BigDecimal.multiply(BigDecimal.from_string(sine_coeff), SymbolicCore.evaluate_numerically(SymbolicCore.create_function_call("sin", Collections.from_list([SymbolicCore.create_constant(BigDecimal.to_string(argument))]))))
            
            Let partial_sum_value be BigDecimal.add(partial_sum_value, BigDecimal.add(cosine_value, sine_value))
        
        Let expected_jump_magnitude be "1.0"
        Let predicted_overshoot be BigDecimal.multiply(BigDecimal.from_string(expected_jump_magnitude), gibbs_overshoot_factor)
        
        Let point_analysis be Collections.set(point_analysis, "partial_sum_value", BigDecimal.to_string(partial_sum_value))
        Let point_analysis be Collections.set(point_analysis, "predicted_overshoot", BigDecimal.to_string(predicted_overshoot))
        Let point_analysis be Collections.set(point_analysis, "overshoot_percentage", "8.95")
        Let point_analysis be Collections.set(point_analysis, "convergence_rate", "1/N")
        
        Let analysis_results be Collections.set(analysis_results, "point_" + discontinuity_point, SymbolicCore.export_to_string(SymbolicCore.create_constant(BigDecimal.to_string(partial_sum_value))))
    
    Return analysis_results

Note: =====================================================================
Note: GENERATING FUNCTION OPERATIONS
Note: =====================================================================

Process called "ordinary_generating_function" that takes sequence as List[String], variable as String returns GeneratingFunction:
    Note: Create ordinary generating function from sequence
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If Collections.size(sequence) equals 0:
        Throw Errors.ArgumentError with "Sequence cannot be empty"
    
    Let sequence_coefficients be Collections.empty_dictionary()
    Let function_terms be Collections.empty_list()
    
    For n from 0 to (Collections.size(sequence) - 1):
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let sequence_value be Collections.get_at(sequence, n)
        Let sequence_coefficients be Collections.set(sequence_coefficients, n_str, sequence_value)
        
        If BigDecimal.compare(BigDecimal.from_string(sequence_value), BigDecimal.from_string("0")) not equals 0:
            If n equals 0:
                Let function_terms be Collections.append(function_terms, sequence_value)
            Otherwise:
                Let power_term be sequence_value + "*" + variable + "^" + BigInteger.to_string(BigInteger.from_integer(n))
                Let function_terms be Collections.append(function_terms, power_term)
    
    Let function_expression be Collections.join(function_terms, " + ")
    
    Let generating_function be GeneratingFunction{
        function_expression: function_expression,
        sequence_type: "ordinary",
        generating_variable: variable,
        sequence_coefficients: sequence_coefficients,
        exponential_type: False,
        ordinary_type: True
    }
    Return generating_function

Process called "exponential_generating_function" that takes sequence as List[String], variable as String returns GeneratingFunction:
    Note: Create exponential generating function from sequence
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If Collections.size(sequence) equals 0:
        Throw Errors.ArgumentError with "Sequence cannot be empty"
    
    Let sequence_coefficients be Collections.empty_dictionary()
    Let function_terms be Collections.empty_list()
    
    For n from 0 to (Collections.size(sequence) - 1):
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let sequence_value be Collections.get_at(sequence, n)
        Let sequence_coefficients be Collections.set(sequence_coefficients, n_str, sequence_value)
        
        If BigDecimal.compare(BigDecimal.from_string(sequence_value), BigDecimal.from_string("0")) not equals 0:
            Let factorial_n be BigInteger.factorial(BigInteger.from_integer(n))
            Let coefficient be BigDecimal.divide(BigDecimal.from_string(sequence_value), BigInteger.to_string(factorial_n))
            
            If n equals 0:
                Let function_terms be Collections.append(function_terms, BigDecimal.to_string(coefficient))
            Otherwise:
                Let power_term be BigDecimal.to_string(coefficient) + "*" + variable + "^" + BigInteger.to_string(BigInteger.from_integer(n))
                Let function_terms be Collections.append(function_terms, power_term)
    
    Let function_expression be Collections.join(function_terms, " + ")
    
    Let generating_function be GeneratingFunction{
        function_expression: function_expression,
        sequence_type: "exponential",
        generating_variable: variable,
        sequence_coefficients: sequence_coefficients,
        exponential_type: True,
        ordinary_type: False
    }
    Return generating_function

Process called "poisson_generating_function" that takes sequence as List[String], variable as String returns GeneratingFunction:
    Note: Create Poisson generating function from sequence
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If Collections.size(sequence) equals 0:
        Throw Errors.ArgumentError with "Sequence cannot be empty"
    
    Let sequence_coefficients be Collections.empty_dictionary()
    Let function_terms be Collections.empty_list()
    Let e_to_negative_lambda be "exp(-" + variable + ")"
    
    For n from 0 to (Collections.size(sequence) - 1):
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let sequence_value be Collections.get_at(sequence, n)
        Let sequence_coefficients be Collections.set(sequence_coefficients, n_str, sequence_value)
        
        If BigDecimal.compare(BigDecimal.from_string(sequence_value), BigDecimal.from_string("0")) not equals 0:
            Let factorial_n be BigInteger.factorial(BigInteger.from_integer(n))
            Let coefficient be BigDecimal.divide(BigDecimal.from_string(sequence_value), BigInteger.to_string(factorial_n))
            Let power_term be BigDecimal.to_string(coefficient) + "*" + variable + "^" + BigInteger.to_string(BigInteger.from_integer(n))
            Let function_terms be Collections.append(function_terms, power_term)
    
    Let function_expression be e_to_negative_lambda + "*(" + Collections.join(function_terms, " + ") + ")"
    
    Let generating_function be GeneratingFunction{
        function_expression: function_expression,
        sequence_type: "poisson",
        generating_variable: variable,
        sequence_coefficients: sequence_coefficients,
        exponential_type: True,
        ordinary_type: False
    }
    Return generating_function

Process called "dirichlet_generating_function" that takes sequence as List[String], variable as String returns GeneratingFunction:
    Note: Create Dirichlet generating function from sequence
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If Collections.size(sequence) equals 0:
        Throw Errors.ArgumentError with "Sequence cannot be empty"
    
    Let sequence_coefficients be Collections.empty_dictionary()
    Let function_terms be Collections.empty_list()
    
    For n from 1 to Collections.size(sequence):
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let sequence_value be Collections.get_at(sequence, n - 1)
        Let sequence_coefficients be Collections.set(sequence_coefficients, n_str, sequence_value)
        
        If BigDecimal.compare(BigDecimal.from_string(sequence_value), BigDecimal.from_string("0")) not equals 0:
            Let term be sequence_value + "/" + BigInteger.to_string(BigInteger.from_integer(n)) + "^" + variable
            Let function_terms be Collections.append(function_terms, term)
    
    Let function_expression be Collections.join(function_terms, " + ")
    
    Let generating_function be GeneratingFunction{
        function_expression: function_expression,
        sequence_type: "dirichlet",
        generating_variable: variable,
        sequence_coefficients: sequence_coefficients,
        exponential_type: False,
        ordinary_type: False
    }
    Return generating_function

Process called "extract_coefficients" that takes generating_function as GeneratingFunction, coefficient_range as Dictionary[String, Integer] returns Dictionary[String, String]:
    Note: Extract sequence coefficients from generating function
    Let result_coefficients be Collections.empty_dictionary()
    Let start_index be Collections.get_or_default(coefficient_range, "start", 0)
    Let end_index be Collections.get_or_default(coefficient_range, "end", 10)
    
    For n from start_index to end_index:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let coefficient_value be Collections.get_or_default(generating_function.sequence_coefficients, n_str, "0")
        Let result_coefficients be Collections.set(result_coefficients, n_str, coefficient_value)
    
    Return result_coefficients

Note: =====================================================================
Note: SERIES ARITHMETIC OPERATIONS
Note: =====================================================================

Process called "add_power_series" that takes series_a as PowerSeries, series_b as PowerSeries returns PowerSeries:
    Note: Add two power series with compatible variables
    If series_a.variable not equals series_b.variable:
        Throw Errors.ArgumentError with "Series must have the same variable"
    If series_a.expansion_point not equals series_b.expansion_point:
        Throw Errors.ArgumentError with "Series must have the same expansion point"
    
    Let result_coefficients be Collections.empty_dictionary()
    Let max_order be series_a.series_order
    If series_b.series_order greater than max_order:
        Let max_order be series_b.series_order
    
    For n from 0 to max_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let coeff_a be Collections.get_or_default(series_a.coefficients, n_str, "0")
        Let coeff_b be Collections.get_or_default(series_b.coefficients, n_str, "0")
        Let sum_coeff be BigDecimal.add(BigDecimal.from_string(coeff_a), BigDecimal.from_string(coeff_b))
        Let result_coefficients be Collections.set(result_coefficients, n_str, BigDecimal.to_string(sum_coeff))
    
    Let result_series be PowerSeries{
        coefficients: result_coefficients,
        variable: series_a.variable,
        expansion_point: series_a.expansion_point,
        series_order: max_order,
        radius_of_convergence: series_a.radius_of_convergence,
        series_type: "sum",
        truncation_error: "0.0"
    }
    Return result_series

Process called "multiply_power_series" that takes series_a as PowerSeries, series_b as PowerSeries returns PowerSeries:
    Note: Multiply power series using Cauchy product
    If series_a.variable not equals series_b.variable:
        Throw Errors.ArgumentError with "Series must have the same variable"
    If series_a.expansion_point not equals series_b.expansion_point:
        Throw Errors.ArgumentError with "Series must have the same expansion point"
    
    Let result_coefficients be Collections.empty_dictionary()
    Let max_order be series_a.series_order + series_b.series_order
    
    For n from 0 to max_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let sum_for_n be BigDecimal.from_string("0")
        
        For k from 0 to n:
            Let k_str be BigInteger.to_string(BigInteger.from_integer(k))
            Let n_minus_k_str be BigInteger.to_string(BigInteger.from_integer(n - k))
            
            Let coeff_a be Collections.get_or_default(series_a.coefficients, k_str, "0")
            Let coeff_b be Collections.get_or_default(series_b.coefficients, n_minus_k_str, "0")
            
            Let product be BigDecimal.multiply(BigDecimal.from_string(coeff_a), BigDecimal.from_string(coeff_b))
            Let sum_for_n be BigDecimal.add(sum_for_n, product)
        
        Let result_coefficients be Collections.set(result_coefficients, n_str, BigDecimal.to_string(sum_for_n))
    
    Let result_series be PowerSeries{
        coefficients: result_coefficients,
        variable: series_a.variable,
        expansion_point: series_a.expansion_point,
        series_order: max_order,
        radius_of_convergence: series_a.radius_of_convergence,
        series_type: "product",
        truncation_error: "0.0"
    }
    Return result_series

Process called "divide_power_series" that takes dividend as PowerSeries, divisor as PowerSeries returns PowerSeries:
    Note: Divide power series (when divisor has non-zero constant term)
    If dividend.variable not equals divisor.variable:
        Throw Errors.ArgumentError with "Series must have the same variable"
    If dividend.expansion_point not equals divisor.expansion_point:
        Throw Errors.ArgumentError with "Series must have the same expansion point"
    
    Let divisor_constant_term be Collections.get_or_default(divisor.coefficients, "0", "0")
    If BigDecimal.compare(BigDecimal.from_string(divisor_constant_term), BigDecimal.from_string("0")) equals 0:
        Throw Errors.ArgumentError with "Divisor must have non-zero constant term"
    
    Let result_coefficients be Collections.empty_dictionary()
    Let max_order be dividend.series_order
    
    For n from 0 to max_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let dividend_coeff_n be Collections.get_or_default(dividend.coefficients, n_str, "0")
        Let sum_to_subtract be BigDecimal.from_string("0")
        
        For k from 1 to n:
            Let k_str be BigInteger.to_string(BigInteger.from_integer(k))
            Let n_minus_k_str be BigInteger.to_string(BigInteger.from_integer(n - k))
            
            Let result_coeff_k be Collections.get_or_default(result_coefficients, n_minus_k_str, "0")
            Let divisor_coeff_k be Collections.get_or_default(divisor.coefficients, k_str, "0")
            
            Let product be BigDecimal.multiply(BigDecimal.from_string(result_coeff_k), BigDecimal.from_string(divisor_coeff_k))
            Let sum_to_subtract be BigDecimal.add(sum_to_subtract, product)
        
        Let numerator be BigDecimal.subtract(BigDecimal.from_string(dividend_coeff_n), sum_to_subtract)
        Let result_coeff_n be BigDecimal.divide(numerator, BigDecimal.from_string(divisor_constant_term))
        Let result_coefficients be Collections.set(result_coefficients, n_str, BigDecimal.to_string(result_coeff_n))
    
    Let result_series be PowerSeries{
        coefficients: result_coefficients,
        variable: dividend.variable,
        expansion_point: dividend.expansion_point,
        series_order: max_order,
        radius_of_convergence: dividend.radius_of_convergence,
        series_type: "quotient",
        truncation_error: "0.0"
    }
    Return result_series

Process called "compose_power_series" that takes outer_series as PowerSeries, inner_series as PowerSeries returns PowerSeries:
    Note: Compose power series f(g(x))
    Let inner_constant_term be Collections.get_or_default(inner_series.coefficients, "0", "0")
    If BigDecimal.compare(BigDecimal.from_string(inner_constant_term), BigDecimal.from_string("0")) not equals 0:
        Throw Errors.ArgumentError with "Inner series must have zero constant term for composition"
    
    Let result_coefficients be Collections.empty_dictionary()
    Let max_order be outer_series.series_order
    
    Let constant_coeff be Collections.get_or_default(outer_series.coefficients, "0", "0")
    Let result_coefficients be Collections.set(result_coefficients, "0", constant_coeff)
    
    Let current_inner_power be inner_series
    
    For n from 1 to max_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let outer_coeff_n be Collections.get_or_default(outer_series.coefficients, n_str, "0")
        
        If BigDecimal.compare(BigDecimal.from_string(outer_coeff_n), BigDecimal.from_string("0")) not equals 0:
            For k from 1 to max_order:
                Let k_str be BigInteger.to_string(BigInteger.from_integer(k))
                Let inner_power_coeff_k be Collections.get_or_default(current_inner_power.coefficients, k_str, "0")
                Let contribution be BigDecimal.multiply(BigDecimal.from_string(outer_coeff_n), BigDecimal.from_string(inner_power_coeff_k))
                
                Let existing_coeff be Collections.get_or_default(result_coefficients, k_str, "0")
                Let new_coeff be BigDecimal.add(BigDecimal.from_string(existing_coeff), contribution)
                Let result_coefficients be Collections.set(result_coefficients, k_str, BigDecimal.to_string(new_coeff))
        
        If n less than max_order:
            Let current_inner_power be multiply_power_series(current_inner_power, inner_series)
    
    Let result_series be PowerSeries{
        coefficients: result_coefficients,
        variable: inner_series.variable,
        expansion_point: inner_series.expansion_point,
        series_order: max_order,
        radius_of_convergence: inner_series.radius_of_convergence,
        series_type: "composition",
        truncation_error: "0.0"
    }
    Return result_series

Process called "differentiate_power_series" that takes series as PowerSeries returns PowerSeries:
    Note: Differentiate power series term by term
    Let result_coefficients be Collections.empty_dictionary()
    
    For n from 1 to series.series_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let n_minus_1_str be BigInteger.to_string(BigInteger.from_integer(n - 1))
        
        Let original_coeff be Collections.get_or_default(series.coefficients, n_str, "0")
        Let derivative_coeff be BigDecimal.multiply(BigDecimal.from_integer(n), BigDecimal.from_string(original_coeff))
        Let result_coefficients be Collections.set(result_coefficients, n_minus_1_str, BigDecimal.to_string(derivative_coeff))
    
    Let result_series be PowerSeries{
        coefficients: result_coefficients,
        variable: series.variable,
        expansion_point: series.expansion_point,
        series_order: series.series_order - 1,
        radius_of_convergence: series.radius_of_convergence,
        series_type: "derivative",
        truncation_error: "0.0"
    }
    Return result_series

Process called "integrate_power_series" that takes series as PowerSeries, integration_constant as String returns PowerSeries:
    Note: Integrate power series term by term
    Let result_coefficients be Collections.empty_dictionary()
    Let result_coefficients be Collections.set(result_coefficients, "0", integration_constant)
    
    For n from 0 to series.series_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let n_plus_1_str be BigInteger.to_string(BigInteger.from_integer(n + 1))
        
        Let original_coeff be Collections.get_or_default(series.coefficients, n_str, "0")
        Let integral_coeff be BigDecimal.divide(BigDecimal.from_string(original_coeff), BigDecimal.from_integer(n + 1))
        Let result_coefficients be Collections.set(result_coefficients, n_plus_1_str, BigDecimal.to_string(integral_coeff))
    
    Let result_series be PowerSeries{
        coefficients: result_coefficients,
        variable: series.variable,
        expansion_point: series.expansion_point,
        series_order: series.series_order + 1,
        radius_of_convergence: series.radius_of_convergence,
        series_type: "integral",
        truncation_error: "0.0"
    }
    Return result_series

Note: =====================================================================
Note: SERIES REVERSION OPERATIONS
Note: =====================================================================

Process called "revert_power_series" that takes series as PowerSeries returns PowerSeries:
    Note: Find inverse series such that f(g(x)) = x
    Let constant_coeff be Collections.get_or_default(series.coefficients, "0", "0")
    If BigDecimal.compare(BigDecimal.from_string(constant_coeff), BigDecimal.from_string("0")) not equals 0:
        Throw Errors.ArgumentError with "Series must have zero constant term for reversion"
    
    Let linear_coeff be Collections.get_or_default(series.coefficients, "1", "0")
    If BigDecimal.compare(BigDecimal.from_string(linear_coeff), BigDecimal.from_string("0")) equals 0:
        Throw Errors.ArgumentError with "Series must have non-zero linear term for reversion"
    
    Let result_coefficients be Collections.empty_dictionary()
    Let result_coefficients be Collections.set(result_coefficients, "1", BigDecimal.to_string(BigDecimal.divide(BigDecimal.from_string("1"), BigDecimal.from_string(linear_coeff))))
    
    For n from 2 to series.series_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let coefficient_sum be BigDecimal.from_string("0")
        
        For k from 2 to n:
            Let k_str be BigInteger.to_string(BigInteger.from_integer(k))
            Let series_coeff_k be Collections.get_or_default(series.coefficients, k_str, "0")
            Let result_coeff_n_minus_k_plus_1 be Collections.get_or_default(result_coefficients, BigInteger.to_string(BigInteger.from_integer(n - k + 1)), "0")
            Let product be BigDecimal.multiply(BigDecimal.from_string(series_coeff_k), BigDecimal.from_string(result_coeff_n_minus_k_plus_1))
            Let coefficient_sum be BigDecimal.add(coefficient_sum, product)
        
        Let result_coeff_n be BigDecimal.divide(BigDecimal.negate(coefficient_sum), BigDecimal.from_string(linear_coeff))
        Let result_coefficients be Collections.set(result_coefficients, n_str, BigDecimal.to_string(result_coeff_n))
    
    Let result_series be PowerSeries{
        coefficients: result_coefficients,
        variable: series.variable,
        expansion_point: series.expansion_point,
        series_order: series.series_order,
        radius_of_convergence: series.radius_of_convergence,
        series_type: "inverse",
        truncation_error: "0.0"
    }
    Return result_series

Process called "lagrange_inversion_formula" that takes function as String, variable as String, order as Integer returns PowerSeries:
    Note: Apply Lagrange inversion formula for series reversion
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If order less than 1:
        Throw Errors.ArgumentError with "Order must be at least 1"
    
    Let expr be SymbolicCore.parse_expression(function)
    Let result_coefficients be Collections.empty_dictionary()
    
    For n from 1 to order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let power_expr be SymbolicCore.create_power(expr, SymbolicCore.create_constant(BigInteger.to_string(BigInteger.from_integer(-n))))
        
        Let derivative_n_minus_1 be power_expr
        For i from 1 to (n - 1):
            Let derivative_n_minus_1 be SymbolicCore.differentiate(derivative_n_minus_1, variable)
        
        Let evaluated_derivative be SymbolicCore.substitute_value(derivative_n_minus_1, variable, "0")
        Let factorial_n_minus_1 be BigInteger.factorial(BigInteger.from_integer(n - 1))
        Let coefficient_value be BigDecimal.divide(evaluated_derivative, BigDecimal.multiply(BigDecimal.from_integer(n), BigInteger.to_string(factorial_n_minus_1)))
        Let result_coefficients be Collections.set(result_coefficients, n_str, BigDecimal.to_string(coefficient_value))
    
    Let result_series be PowerSeries{
        coefficients: result_coefficients,
        variable: variable,
        expansion_point: "0",
        series_order: order,
        radius_of_convergence: "1.0",
        series_type: "lagrange_inverse",
        truncation_error: "0.0"
    }
    Return result_series

Process called "compositional_inverse" that takes generating_function as GeneratingFunction returns GeneratingFunction:
    Note: Find compositional inverse of generating function
    Let constant_coeff be Collections.get_or_default(generating_function.sequence_coefficients, "0", "0")
    If BigDecimal.compare(BigDecimal.from_string(constant_coeff), BigDecimal.from_string("0")) not equals 0:
        Throw Errors.ArgumentError with "Generating function must have zero constant term"
    
    Let linear_coeff be Collections.get_or_default(generating_function.sequence_coefficients, "1", "0")
    If BigDecimal.compare(BigDecimal.from_string(linear_coeff), BigDecimal.from_string("0")) equals 0:
        Throw Errors.ArgumentError with "Generating function must have non-zero linear term"
    
    Let inverse_coefficients be Collections.empty_dictionary()
    Let inverse_coefficients be Collections.set(inverse_coefficients, "1", BigDecimal.to_string(BigDecimal.divide(BigDecimal.from_string("1"), BigDecimal.from_string(linear_coeff))))
    
    For n from 2 to 10:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let coefficient_sum be BigDecimal.from_string("0")
        
        For k from 2 to n:
            Let k_str = BigInteger.to_string(BigInteger.from_integer(k))
            Let orig_coeff_k be Collections.get_or_default(generating_function.sequence_coefficients, k_str, "0")
            Let inv_coeff_n_k_1 be Collections.get_or_default(inverse_coefficients, BigInteger.to_string(BigInteger.from_integer(n - k + 1)), "0")
            Let product be BigDecimal.multiply(BigDecimal.from_string(orig_coeff_k), BigDecimal.from_string(inv_coeff_n_k_1))
            Let coefficient_sum be BigDecimal.add(coefficient_sum, product)
        
        Let inv_coeff_n be BigDecimal.divide(BigDecimal.negate(coefficient_sum), BigDecimal.from_string(linear_coeff))
        Let inverse_coefficients be Collections.set(inverse_coefficients, n_str, BigDecimal.to_string(inv_coeff_n))
    
    Let inverse_function be GeneratingFunction{
        function_expression: "compositional_inverse",
        sequence_type: "inverse_" + generating_function.sequence_type,
        generating_variable: generating_function.generating_variable,
        sequence_coefficients: inverse_coefficients,
        exponential_type: generating_function.exponential_type,
        ordinary_type: generating_function.ordinary_type
    }
    Return inverse_function

Note: =====================================================================
Note: ASYMPTOTIC SERIES OPERATIONS
Note: =====================================================================

Process called "asymptotic_expansion" that takes function as String, variable as String, limit_point as String, order as Integer returns AsymptoticSeries:
    Note: Compute asymptotic expansion as variable approaches limit
    If variable equals "":
        Throw Errors.ArgumentError with "Variable name cannot be empty"
    If order less than 1:
        Throw Errors.ArgumentError with "Order must be at least 1"
    
    Let expr be SymbolicCore.parse_expression(function)
    Let leading_terms be Collections.empty_dictionary()
    Let asymptotic_scale be Collections.empty_list()
    Let error_bounds be Collections.empty_dictionary()
    
    For n from 0 to order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let scale_function be "1/" + variable + "^" + BigInteger.to_string(BigInteger.from_integer(n))
        Let asymptotic_scale be Collections.append(asymptotic_scale, scale_function)
        
        Let coefficient_expr be SymbolicCore.multiply_expressions(expr, SymbolicCore.create_power(SymbolicCore.create_symbol(variable, Collections.empty_dictionary()), SymbolicCore.create_constant(BigInteger.to_string(BigInteger.from_integer(n)))))
        Let limit_result be SymbolicCore.evaluate_limit(coefficient_expr, variable, limit_point)
        Let leading_terms be Collections.set(leading_terms, n_str, limit_result)
        
        Let error_estimate be "O(1/" + variable + "^" + BigInteger.to_string(BigInteger.from_integer(n + 1)) + ")"
        Let error_bounds be Collections.set(error_bounds, n_str, error_estimate)
    
    Let asymptotic_series be AsymptoticSeries{
        leading_terms: leading_terms,
        asymptotic_scale: asymptotic_scale,
        expansion_point: limit_point,
        error_bounds: error_bounds,
        validity_region: Collections.from_dictionary(["domain", "real_line"])
    }
    Return asymptotic_series

Process called "watson_lemma" that takes laplace_integrand as String, parameter as String, order as Integer returns AsymptoticSeries:
    Note: Apply Watson's lemma for Laplace method asymptotics
    If parameter equals "":
        Throw Errors.ArgumentError with "Parameter name cannot be empty"
    If order less than 1:
        Throw Errors.ArgumentError with "Order must be at least 1"
    
    Let expr be SymbolicCore.parse_expression(laplace_integrand)
    Let leading_terms be Collections.empty_dictionary()
    Let asymptotic_scale be Collections.empty_list()
    
    For n from 0 to order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let factorial_n be BigInteger.factorial(BigInteger.from_integer(n))
        Let scale_function be BigInteger.to_string(factorial_n) + "/" + parameter + "^" + BigInteger.to_string(BigInteger.from_integer(n + 1))
        Let asymptotic_scale be Collections.append(asymptotic_scale, scale_function)
        
        Let derivative_n be expr
        For i from 1 to n:
            Let derivative_n be SymbolicCore.differentiate(derivative_n, "t")
        
        Let evaluated_derivative be SymbolicCore.substitute_value(derivative_n, "t", "0")
        Let coefficient = BigDecimal.divide(evaluated_derivative, BigInteger.to_string(factorial_n))
        Let leading_terms be Collections.set(leading_terms, n_str, BigDecimal.to_string(coefficient))
    
    Let watson_series be AsymptoticSeries{
        leading_terms: leading_terms,
        asymptotic_scale: asymptotic_scale,
        expansion_point: "infinity",
        error_bounds: Collections.from_dictionary(["0", "exponentially_small"]),
        validity_region: Collections.from_dictionary(["domain", "large_" + parameter])
    }
    Return watson_series

Process called "method_of_steepest_descent" that takes integral_function as String, contour_parameter as String returns AsymptoticSeries:
    Note: Apply method of steepest descent for asymptotic analysis
    If contour_parameter equals "":
        Throw Errors.ArgumentError with "Contour parameter cannot be empty"
    
    Let expr be SymbolicCore.parse_expression(integral_function)
    Let leading_terms be Collections.empty_dictionary()
    Let asymptotic_scale be Collections.empty_list()
    
    Let critical_point_analysis be "saddle_point_approximation"
    Let dominant_contribution be "exp(-" + contour_parameter + "*S(z0))*sqrt(2*pi/(-" + contour_parameter + "*S''(z0)))"
    
    Let leading_terms be Collections.set(leading_terms, "0", dominant_contribution)
    Let asymptotic_scale be Collections.append(asymptotic_scale, "exp(-" + contour_parameter + ")") 
    
    For n from 1 to 3:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let correction_term be "C" + BigInteger.to_string(BigInteger.from_integer(n)) + "/" + contour_parameter + "^" + BigInteger.to_string(BigInteger.from_integer(n))
        Let leading_terms be Collections.set(leading_terms, n_str, correction_term)
        Let asymptotic_scale be Collections.append(asymptotic_scale, "1/" + contour_parameter + "^" + BigInteger.to_string(BigInteger.from_integer(n)))
    
    Let steepest_descent_series be AsymptoticSeries{
        leading_terms: leading_terms,
        asymptotic_scale: asymptotic_scale,
        expansion_point: "infinity",
        error_bounds: Collections.from_dictionary(["0", "exponentially_small"]),
        validity_region: Collections.from_dictionary(["domain", "large_" + contour_parameter])
    }
    Return steepest_descent_series

Process called "stationary_phase_method" that takes oscillatory_integral as String, frequency_parameter as String returns AsymptoticSeries:
    Note: Apply stationary phase method for oscillatory integrals
    If frequency_parameter equals "":
        Throw Errors.ArgumentError with "Frequency parameter cannot be empty"
    
    Let expr be SymbolicCore.parse_expression(oscillatory_integral)
    Let leading_terms be Collections.empty_dictionary()
    Let asymptotic_scale be Collections.empty_list()
    
    Let stationary_point_contribution be "sqrt(2*pi/|" + frequency_parameter + "*g''(x0)|)*exp(i*" + frequency_parameter + "*g(x0))"
    Let leading_terms be Collections.set(leading_terms, "0", stationary_point_contribution)
    Let asymptotic_scale be Collections.append(asymptotic_scale, "1/sqrt(" + frequency_parameter + ")")
    
    For n from 1 to 3:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let correction_term be "A" + BigInteger.to_string(BigInteger.from_integer(n)) + "/" + frequency_parameter + "^" + BigDecimal.to_string(BigDecimal.add(BigDecimal.from_string("0.5"), BigDecimal.from_integer(n)))
        Let leading_terms be Collections.set(leading_terms, n_str, correction_term)
        Let scale_power be BigDecimal.to_string(BigDecimal.add(BigDecimal.from_string("0.5"), BigDecimal.from_integer(n)))
        Let asymptotic_scale be Collections.append(asymptotic_scale, "1/" + frequency_parameter + "^" + scale_power)
    
    Let stationary_phase_series be AsymptoticSeries{
        leading_terms: leading_terms,
        asymptotic_scale: asymptotic_scale,
        expansion_point: "infinity",
        error_bounds: Collections.from_dictionary(["0", "O(1/" + frequency_parameter + "^2)"]),
        validity_region: Collections.from_dictionary(["domain", "large_" + frequency_parameter])
    }
    Return stationary_phase_series

Note: =====================================================================
Note: CONVERGENCE ANALYSIS OPERATIONS
Note: =====================================================================

Process called "radius_of_convergence" that takes series as PowerSeries returns String:
    Note: Compute radius of convergence using ratio or root test
    Let max_order be series.series_order
    If max_order less than 2:
        Return "infinity"
    
    Let ratio_limit be BigDecimal.from_string("0")
    Let consecutive_ratios be 0
    
    For n from 1 to max_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let n_plus_1_str be BigInteger.to_string(BigInteger.from_integer(n + 1))
        
        Let coeff_n be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_str, "0"))
        Let coeff_n_plus_1 be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_plus_1_str, "0"))
        
        If BigDecimal.compare(coeff_n, BigDecimal.from_string("0")) not equals 0 and BigDecimal.compare(coeff_n_plus_1, BigDecimal.from_string("0")) not equals 0:
            Let ratio be BigDecimal.divide(BigDecimal.abs(coeff_n), BigDecimal.abs(coeff_n_plus_1))
            Let ratio_limit be ratio
            Let consecutive_ratios be consecutive_ratios + 1
    
    If consecutive_ratios greater than 0:
        Return BigDecimal.to_string(ratio_limit)
    Otherwise:
        Return "infinity"

Process called "ratio_test" that takes series as PowerSeries returns Dictionary[String, String]:
    Note: Apply ratio test for series convergence
    Let results be Collections.empty_dictionary()
    Let max_order be series.series_order
    
    If max_order less than 2:
        Let results be Collections.set(results, "status", "inconclusive")
        Let results be Collections.set(results, "reason", "insufficient_terms")
        Return results
    
    Let ratios be Collections.empty_list()
    
    For n from 1 to (max_order - 1):
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let n_plus_1_str be BigInteger.to_string(BigInteger.from_integer(n + 1))
        
        Let coeff_n be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_str, "0"))
        Let coeff_n_plus_1 be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_plus_1_str, "0"))
        
        If BigDecimal.compare(coeff_n, BigDecimal.from_string("0")) not equals 0:
            Let ratio be BigDecimal.divide(BigDecimal.abs(coeff_n_plus_1), BigDecimal.abs(coeff_n))
            Let ratios be Collections.append(ratios, BigDecimal.to_string(ratio))
    
    If Collections.size(ratios) equals 0:
        Let results be Collections.set(results, "status", "inconclusive")
        Return results
    
    Let last_ratio be BigDecimal.from_string(Collections.get_at(ratios, Collections.size(ratios) - 1))
    
    If BigDecimal.compare(last_ratio, BigDecimal.from_string("1")) less than 0:
        Let results be Collections.set(results, "status", "convergent")
    Otherwise:
        If BigDecimal.compare(last_ratio, BigDecimal.from_string("1")) greater than 0:
            Let results be Collections.set(results, "status", "divergent")
        Otherwise:
            Let results be Collections.set(results, "status", "inconclusive")
    
    Let results be Collections.set(results, "limit", BigDecimal.to_string(last_ratio))
    Return results

Process called "root_test" that takes series as PowerSeries returns Dictionary[String, String]:
    Note: Apply root test (Cauchy-Hadamard) for convergence
    Let results be Collections.empty_dictionary()
    Let max_order be series.series_order
    
    If max_order less than 1:
        Let results be Collections.set(results, "status", "inconclusive")
        Return results
    
    Let max_root be BigDecimal.from_string("0")
    Let valid_terms be 0
    
    For n from 1 to max_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let coeff_n be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_str, "0"))
        
        If BigDecimal.compare(BigDecimal.abs(coeff_n), BigDecimal.from_string("0")) greater than 0:
            Let nth_root be BigDecimal.power(BigDecimal.abs(coeff_n), BigDecimal.divide(BigDecimal.from_string("1"), BigDecimal.from_integer(n)))
            If BigDecimal.compare(nth_root, max_root) greater than 0:
                Let max_root be nth_root
            Let valid_terms be valid_terms + 1
    
    If valid_terms equals 0:
        Let results be Collections.set(results, "status", "inconclusive")
        Return results
    
    If BigDecimal.compare(max_root, BigDecimal.from_string("1")) less than 0:
        Let results be Collections.set(results, "status", "convergent")
    Otherwise:
        If BigDecimal.compare(max_root, BigDecimal.from_string("1")) greater than 0:
            Let results be Collections.set(results, "status", "divergent")
        Otherwise:
            Let results be Collections.set(results, "status", "inconclusive")
    
    Let results be Collections.set(results, "lim_sup_root", BigDecimal.to_string(max_root))
    Let results be Collections.set(results, "radius", BigDecimal.to_string(BigDecimal.divide(BigDecimal.from_string("1"), max_root)))
    Return results

Process called "integral_test" that takes series as PowerSeries returns Dictionary[String, String]:
    Note: Apply integral test for series convergence
    Let results be Collections.empty_dictionary()
    
    Let decreasing_check be True
    For n from 1 to (series.series_order - 1):
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let n_plus_1_str be BigInteger.to_string(BigInteger.from_integer(n + 1))
        
        Let coeff_n be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_str, "0"))
        Let coeff_n_plus_1 be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_plus_1_str, "0"))
        
        If BigDecimal.compare(BigDecimal.abs(coeff_n_plus_1), BigDecimal.abs(coeff_n)) greater than 0:
            Let decreasing_check be False
    
    If decreasing_check equals False:
        Let results be Collections.set(results, "status", "test_not_applicable")
        Let results be Collections.set(results, "reason", "sequence_not_decreasing")
        Return results
    
    Let integral_approximation be BigDecimal.from_string("0")
    For n from 1 to series.series_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let coeff_n be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_str, "0"))
        Let integral_approximation be BigDecimal.add(integral_approximation, BigDecimal.abs(coeff_n))
    
    Let results be Collections.set(results, "status", "convergent_by_approximation")
    Let results be Collections.set(results, "integral_approximation", BigDecimal.to_string(integral_approximation))
    Return results

Process called "comparison_test" that takes series_a as PowerSeries, series_b as PowerSeries returns Dictionary[String, String]:
    Note: Apply comparison test between two series
    Let results be Collections.empty_dictionary()
    Let comparison_valid be True
    
    Let min_order be series_a.series_order
    If series_b.series_order less than min_order:
        Let min_order be series_b.series_order
    
    For n from 1 to min_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let coeff_a = BigDecimal.abs(BigDecimal.from_string(Collections.get_or_default(series_a.coefficients, n_str, "0")))
        Let coeff_b = BigDecimal.abs(BigDecimal.from_string(Collections.get_or_default(series_b.coefficients, n_str, "0")))
        
        If BigDecimal.compare(coeff_a, coeff_b) greater than 0:
            Let comparison_valid be False
    
    If comparison_valid:
        Let results be Collections.set(results, "status", "series_a_converges_if_series_b_converges")
        Let results = Collections.set(results, "conclusion", "dominated_series_test_applicable")
    Otherwise:
        Let results be Collections.set(results, "status", "inconclusive")
        Let results = Collections.set(results, "reason", "domination_condition_not_met")
    
    Return results

Process called "alternating_series_test" that takes series as PowerSeries returns Dictionary[String, String]:
    Note: Apply alternating series test (Leibniz criterion)
    Let results be Collections.empty_dictionary()
    
    Let alternating_check be True
    Let decreasing_check be True
    
    For n from 1 to (series.series_order - 1):
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let n_plus_1_str be BigInteger.to_string(BigInteger.from_integer(n + 1))
        
        Let coeff_n be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_str, "0"))
        Let coeff_n_plus_1 be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_plus_1_str, "0"))
        
        If BigDecimal.multiply(coeff_n, coeff_n_plus_1) greater than or equals BigDecimal.from_string("0"):
            Let alternating_check be False
        
        If BigDecimal.compare(BigDecimal.abs(coeff_n_plus_1), BigDecimal.abs(coeff_n)) greater than 0:
            Let decreasing_check be False
    
    If alternating_check and decreasing_check:
        Let results be Collections.set(results, "status", "convergent")
        Let results be Collections.set(results, "type", "conditionally_convergent")
    Otherwise:
        Let results be Collections.set(results, "status", "test_not_applicable")
        If alternating_check equals False:
            Let results be Collections.set(results, "reason", "not_alternating")
        Otherwise:
            Let results be Collections.set(results, "reason", "not_decreasing")
    
    Return results

Note: =====================================================================
Note: PADE APPROXIMATION OPERATIONS
Note: =====================================================================

Process called "pade_approximant" that takes series as PowerSeries, numerator_degree as Integer, denominator_degree as Integer returns Dictionary[String, String]:
    Note: Compute Padé approximant [m/n] to power series
    If numerator_degree less than 0 or denominator_degree less than 0:
        Throw Errors.ArgumentError with "Degrees must be non-negative"
    If numerator_degree + denominator_degree greater than series.series_order:
        Throw Errors.ArgumentError with "Total degree exceeds series order"
    
    Let pade_result be Collections.empty_dictionary()
    Let numerator_coeffs be Collections.empty_dictionary()
    Let denominator_coeffs be Collections.empty_dictionary()
    
    Let denominator_coeffs be Collections.set(denominator_coeffs, "0", "1")
    
    For i from 0 to numerator_degree:
        Let i_str be BigInteger.to_string(BigInteger.from_integer(i))
        Let series_coeff_i be Collections.get_or_default(series.coefficients, i_str, "0")
        Let numerator_coeffs be Collections.set(numerator_coeffs, i_str, series_coeff_i)
    
    For j from 1 to denominator_degree:
        Let j_str be BigInteger.to_string(BigInteger.from_integer(j))
        Let computed_coeff be BigDecimal.from_string("0")
        
        For k from 0 to (j - 1):
            Let k_str be BigInteger.to_string(BigInteger.from_integer(k))
            Let series_coeff_j_minus_k be Collections.get_or_default(series.coefficients, BigInteger.to_string(BigInteger.from_integer(j - k)), "0")
            Let denom_coeff_k be Collections.get_or_default(denominator_coeffs, k_str, "0")
            Let product be BigDecimal.multiply(BigDecimal.from_string(series_coeff_j_minus_k), BigDecimal.from_string(denom_coeff_k))
            Let computed_coeff be BigDecimal.add(computed_coeff, product)
        
        Let series_coeff_j be Collections.get_or_default(series.coefficients, j_str, "0")
        Let denom_coeff_j be BigDecimal.subtract(BigDecimal.from_string(series_coeff_j), computed_coeff)
        Let denominator_coeffs be Collections.set(denominator_coeffs, j_str, BigDecimal.to_string(denom_coeff_j))
    
    Let pade_result be Collections.set(pade_result, "numerator", SymbolicCore.export_to_string(SymbolicCore.create_constant("polynomial")))
    Let pade_result be Collections.set(pade_result, "denominator", SymbolicCore.export_to_string(SymbolicCore.create_constant("polynomial")))
    Let pade_result be Collections.set(pade_result, "degrees", "[" + BigInteger.to_string(BigInteger.from_integer(numerator_degree)) + "/" + BigInteger.to_string(BigInteger.from_integer(denominator_degree)) + "]")
    
    Return pade_result

Process called "pade_table" that takes series as PowerSeries, max_degree as Integer returns Dictionary[String, Dictionary[String, String]]:
    Note: Generate Padé table with multiple approximants
    If max_degree less than 0:
        Throw Errors.ArgumentError with "Max degree must be non-negative"
    If max_degree greater than series.series_order:
        Throw Errors.ArgumentError with "Max degree cannot exceed series order"
    
    Let pade_table be Collections.empty_dictionary()
    
    For m from 0 to max_degree:
        For n from 0 to (max_degree - m):
            If m + n less than or equals series.series_order:
                Let pade_key be "[" + BigInteger.to_string(BigInteger.from_integer(m)) + "/" + BigInteger.to_string(BigInteger.from_integer(n)) + "]"
                Let pade_approx be pade_approximant(series, m, n)
                Let pade_table be Collections.set(pade_table, pade_key, pade_approx)
    
    Return pade_table

Process called "diagonal_pade_sequence" that takes series as PowerSeries, max_order as Integer returns List[Dictionary[String, String]]:
    Note: Generate diagonal Padé approximants [n/n]
    If max_order less than 0:
        Throw Errors.ArgumentError with "Max order must be non-negative"
    
    Let diagonal_sequence be Collections.empty_list()
    
    For n from 0 to max_order:
        If 2 * n less than or equals series.series_order:
            Let pade_approx be pade_approximant(series, n, n)
            Let diagonal_sequence be Collections.append(diagonal_sequence, pade_approx)
    
    Return diagonal_sequence

Note: =====================================================================
Note: CONTINUED FRACTION OPERATIONS
Note: =====================================================================

Process called "series_to_continued_fraction" that takes series as PowerSeries returns ContinuedFraction:
    Note: Convert power series to continued fraction representation
    Let partial_quotients be Collections.empty_list()
    Let convergents be Collections.empty_list()
    
    Let a0 be Collections.get_or_default(series.coefficients, "0", "0")
    Let partial_quotients be Collections.append(partial_quotients, a0)
    
    For n from 1 to series.series_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let coeff_n be Collections.get_or_default(series.coefficients, n_str, "0")
        If BigDecimal.compare(BigDecimal.from_string(coeff_n), BigDecimal.from_string("0")) not equals 0:
            Let reciprocal be BigDecimal.divide(BigDecimal.from_string("1"), BigDecimal.from_string(coeff_n))
            Let partial_quotients be Collections.append(partial_quotients, BigDecimal.to_string(reciprocal))
        Otherwise:
            Let partial_quotients be Collections.append(partial_quotients, "infinity")
    
    For i from 0 to (Collections.size(partial_quotients) - 1):
        Let convergent_info be Collections.from_dictionary(["index", BigInteger.to_string(BigInteger.from_integer(i)), "value", Collections.get_at(partial_quotients, i)])
        Let convergents be Collections.append(convergents, convergent_info)
    
    Let continued_fraction be ContinuedFraction{
        partial_quotients: partial_quotients,
        convergents: convergents,
        fraction_type: "from_series",
        simple_form: True,
        periodic_part: Collections.empty_list()
    }
    Return continued_fraction

Process called "euclidean_algorithm_fractions" that takes numerator as String, denominator as String returns ContinuedFraction:
    Note: Apply Euclidean algorithm to generate continued fraction
    If BigDecimal.compare(BigDecimal.from_string(denominator), BigDecimal.from_string("0")) equals 0:
        Throw Errors.ArgumentError with "Denominator cannot be zero"
    
    Let partial_quotients be Collections.empty_list()
    Let current_num be BigDecimal.from_string(numerator)
    Let current_den be BigDecimal.from_string(denominator)
    
    While BigDecimal.compare(current_den, BigDecimal.from_string("0")) not equals 0:
        Let quotient be BigDecimal.floor(BigDecimal.divide(current_num, current_den))
        Let partial_quotients be Collections.append(partial_quotients, BigDecimal.to_string(quotient))
        
        Let remainder be BigDecimal.subtract(current_num, BigDecimal.multiply(quotient, current_den))
        Let current_num be current_den
        Let current_den be remainder
    
    Let convergents be Collections.empty_list()
    For i from 0 to (Collections.size(partial_quotients) - 1):
        Let convergent_info be Collections.from_dictionary(["index", BigInteger.to_string(BigInteger.from_integer(i)), "quotient", Collections.get_at(partial_quotients, i)])
        Let convergents be Collections.append(convergents, convergent_info)
    
    Let continued_fraction be ContinuedFraction{
        partial_quotients: partial_quotients,
        convergents: convergents,
        fraction_type: "euclidean",
        simple_form: True,
        periodic_part: Collections.empty_list()
    }
    Return continued_fraction

Process called "convergents_continued_fraction" that takes continued_fraction as ContinuedFraction, max_convergents as Integer returns List[Dictionary[String, String]]:
    Note: Compute convergents of continued fraction
    If max_convergents less than 1:
        Throw Errors.ArgumentError with "Max convergents must be at least 1"
    
    Let convergents_list be Collections.empty_list()
    Let num_quotients be Collections.size(continued_fraction.partial_quotients)
    Let max_iterations be max_convergents
    If num_quotients less than max_iterations:
        Let max_iterations be num_quotients
    
    Let p_prev be BigDecimal.from_string("1")
    Let p_curr be BigDecimal.from_string(Collections.get_at(continued_fraction.partial_quotients, 0))
    Let q_prev be BigDecimal.from_string("0")
    Let q_curr be BigDecimal.from_string("1")
    
    For n from 0 to (max_iterations - 1):
        Let convergent_value be BigDecimal.divide(p_curr, q_curr)
        Let convergent_info be Collections.from_dictionary(["numerator", BigDecimal.to_string(p_curr), "denominator", BigDecimal.to_string(q_curr), "value", BigDecimal.to_string(convergent_value)])
        Let convergents_list be Collections.append(convergents_list, convergent_info)
        
        If n less than (max_iterations - 1) and (n + 1) less than num_quotients:
            Let a_next be BigDecimal.from_string(Collections.get_at(continued_fraction.partial_quotients, n + 1))
            Let p_next be BigDecimal.add(BigDecimal.multiply(a_next, p_curr), p_prev)
            Let q_next be BigDecimal.add(BigDecimal.multiply(a_next, q_curr), q_prev)
            
            Let p_prev be p_curr
            Let p_curr be p_next
            Let q_prev be q_curr
            Let q_curr be q_next
    
    Return convergents_list

Process called "periodic_continued_fraction" that takes quadratic_irrational as String returns ContinuedFraction:
    Note: Find periodic continued fraction for quadratic irrational
    Let expr be SymbolicCore.parse_expression(quadratic_irrational)
    Let partial_quotients be Collections.empty_list()
    Let convergents be Collections.empty_list()
    
    Let integer_part be BigDecimal.floor(SymbolicCore.evaluate_numerically(expr))
    Let partial_quotients be Collections.append(partial_quotients, BigDecimal.to_string(integer_part))
    
    Let fractional_part be BigDecimal.subtract(SymbolicCore.evaluate_numerically(expr), integer_part)
    Let current_value be fractional_part
    Let period_start be 1
    Let periodic_part be Collections.empty_list()
    
    For i from 1 to 10:
        If BigDecimal.compare(current_value, BigDecimal.from_string("0")) not equals 0:
            Let reciprocal_value be BigDecimal.divide(BigDecimal.from_string("1"), current_value)
            Let floor_reciprocal be BigDecimal.floor(reciprocal_value)
            Let partial_quotients be Collections.append(partial_quotients, BigDecimal.to_string(floor_reciprocal))
            Let periodic_part be Collections.append(periodic_part, BigDecimal.to_string(floor_reciprocal))
            
            Let current_value be BigDecimal.subtract(reciprocal_value, floor_reciprocal)
    
    For i from 0 to (Collections.size(partial_quotients) - 1):
        Let convergent_info be Collections.from_dictionary(["index", BigInteger.to_string(BigInteger.from_integer(i)), "quotient", Collections.get_at(partial_quotients, i)])
        Let convergents be Collections.append(convergents, convergent_info)
    
    Let continued_fraction be ContinuedFraction{
        partial_quotients: partial_quotients,
        convergents: convergents,
        fraction_type: "periodic",
        simple_form: False,
        periodic_part: periodic_part
    }
    Return continued_fraction

Note: =====================================================================
Note: MULTIVARIABLE SERIES OPERATIONS
Note: =====================================================================

Process called "multivariable_taylor_expansion" that takes function as String, variables as List[String], expansion_point as Dictionary[String, String], order as Integer returns Dictionary[String, String]:
    Note: Compute multivariable Taylor series expansion
    If Collections.size(variables) equals 0:
        Throw Errors.ArgumentError with "Variables list cannot be empty"
    If order less than 0:
        Throw Errors.ArgumentError with "Order must be non-negative"
    
    Let expr be SymbolicCore.parse_expression(function)
    Let taylor_terms be Collections.empty_dictionary()
    
    For total_degree from 0 to order:
        For each variable in variables:
            For partial_degree from 0 to total_degree:
                Let derivative_expr be expr
                For j from 1 to partial_degree:
                    Let derivative_expr be SymbolicCore.differentiate(derivative_expr, variable)
                
                Let evaluated_derivative be derivative_expr
                For each var in variables:
                    Let expansion_value be Collections.get_or_default(expansion_point, var, "0")
                    Let evaluated_derivative be SymbolicCore.substitute_value(evaluated_derivative, var, expansion_value)
                
                Let factorial_term be BigInteger.factorial(BigInteger.from_integer(partial_degree))
                Let coefficient_value be BigDecimal.divide(evaluated_derivative, BigInteger.to_string(factorial_term))
                
                Let term_key be variable + "^" + BigInteger.to_string(BigInteger.from_integer(partial_degree))
                Let taylor_terms be Collections.set(taylor_terms, term_key, BigDecimal.to_string(coefficient_value))
    
    Return taylor_terms

Process called "multinomial_expansion" that takes expression as String, variables as List[String], power as Integer returns Dictionary[String, String]:
    Note: Expand (x₁ + x₂ + ... + xₙ)^k using multinomial theorem
    If Collections.size(variables) equals 0:
        Throw Errors.ArgumentError with "Variables list cannot be empty"
    If power less than 0:
        Throw Errors.ArgumentError with "Power must be non-negative"
    
    Let expansion_terms be Collections.empty_dictionary()
    Let num_variables be Collections.size(variables)
    
    For total_degree from 0 to power:
        Let multinomial_coefficient be BigInteger.factorial(BigInteger.from_integer(power))
        
        For i from 0 to (num_variables - 1):
            Let variable = Collections.get_at(variables, i)
            Let degree_for_variable be 0
            If i equals 0:
                Let degree_for_variable be total_degree
            
            Let factorial_degree be BigInteger.factorial(BigInteger.from_integer(degree_for_variable))
            Let multinomial_coefficient be BigInteger.divide(multinomial_coefficient, factorial_degree)
            
            If degree_for_variable greater than 0:
                Let term_key be variable + "^" + BigInteger.to_string(BigInteger.from_integer(degree_for_variable))
                Let expansion_terms be Collections.set(expansion_terms, term_key, BigInteger.to_string(multinomial_coefficient))
    
    If Collections.size(expansion_terms) equals 0:
        Let expansion_terms be Collections.set(expansion_terms, "constant", "1")
    
    Return expansion_terms

Process called "generating_function_multivariable" that takes multidimensional_sequence as Dictionary[String, String], variables as List[String] returns String:
    Note: Create multivariable generating function
    If Collections.size(variables) equals 0:
        Throw Errors.ArgumentError with "Variables list cannot be empty"
    If Collections.size(multidimensional_sequence) equals 0:
        Throw Errors.ArgumentError with "Sequence cannot be empty"
    
    Let function_terms be Collections.empty_list()
    
    For each key in Collections.keys(multidimensional_sequence):
        Let coefficient_value be Collections.get(multidimensional_sequence, key)
        Let indices = Collections.split(key, ",")
        
        If Collections.size(indices) equals Collections.size(variables):
            Let monomial_term be coefficient_value
            For i from 0 to (Collections.size(variables) - 1):
                Let variable be Collections.get_at(variables, i)
                Let index_value be Collections.get_at(indices, i)
                Let power_term be variable + "^" + index_value
                Let monomial_term be monomial_term + "*" + power_term
            
            Let function_terms be Collections.append(function_terms, monomial_term)
    
    Let generating_function_expression be Collections.join(function_terms, " + ")
    Return generating_function_expression

Note: =====================================================================
Note: Q-SERIES OPERATIONS
Note: =====================================================================

Process called "q_pochhammer_symbol" that takes base as String, q_parameter as String, n as String returns String:
    Note: Compute q-Pochhammer symbol (a;q)_n
    Let a be BigDecimal.from_string(base)
    Let q be BigDecimal.from_string(q_parameter)
    Let n_val be BigInteger.parse_from_string(n)
    
    If BigInteger.compare(n_val, BigInteger.from_integer(0)) equals 0:
        Return "1"
    
    Let result be BigDecimal.from_string("1")
    For k from 0 to (BigInteger.to_integer(n_val) - 1):
        Let power_term be BigDecimal.power(q, BigDecimal.from_integer(k))
        Let factor be BigDecimal.subtract(BigDecimal.from_string("1"), BigDecimal.multiply(a, power_term))
        Let result be BigDecimal.multiply(result, factor)
    
    Return BigDecimal.to_string(result)

Process called "basic_hypergeometric_series" that takes r as Integer, s as Integer, parameters as Dictionary[String, List[String]], q as String, z as String returns String:
    Note: Compute basic hypergeometric series ₓφᵧ
    If r less than 0 or s less than 0:
        Throw Errors.ArgumentError with "Parameters r and s must be non-negative"
    
    Let numerator_params be Collections.get_or_default(parameters, "numerator", Collections.empty_list())
    Let denominator_params be Collections.get_or_default(parameters, "denominator", Collections.empty_list())
    
    Let series_sum be BigDecimal.from_string("0")
    Let q_val be BigDecimal.from_string(q)
    Let z_val be BigDecimal.from_string(z)
    
    For n from 0 to 10:
        Let numerator_product be BigDecimal.from_string("1")
        For each a_param in numerator_params:
            Let pochhammer_val be q_pochhammer_symbol(a_param, q, BigInteger.to_string(BigInteger.from_integer(n)))
            Let numerator_product be BigDecimal.multiply(numerator_product, BigDecimal.from_string(pochhammer_val))
        
        Let denominator_product be BigDecimal.from_string("1")
        For each b_param in denominator_params:
            Let pochhammer_val be q_pochhammer_symbol(b_param, q, BigInteger.to_string(BigInteger.from_integer(n)))
            Let denominator_product be BigDecimal.multiply(denominator_product, BigDecimal.from_string(pochhammer_val))
        
        Let q_factorial_n be q_pochhammer_symbol(q, q, BigInteger.to_string(BigInteger.from_integer(n)))
        Let z_power_n be BigDecimal.power(z_val, BigDecimal.from_integer(n))
        
        Let term_value be BigDecimal.divide(BigDecimal.multiply(numerator_product, z_power_n), BigDecimal.multiply(denominator_product, BigDecimal.from_string(q_factorial_n)))
        Let series_sum be BigDecimal.add(series_sum, term_value)
    
    Return BigDecimal.to_string(series_sum)

Process called "q_binomial_coefficient" that takes n as String, k as String, q as String returns String:
    Note: Compute q-binomial coefficient [n choose k]_q
    Let n_val be BigInteger.parse_from_string(n)
    Let k_val be BigInteger.parse_from_string(k)
    
    If BigInteger.compare(k_val, BigInteger.from_integer(0)) less_than 0 or BigInteger.compare(k_val, n_val) greater_than 0:
        Return "0"
    
    If BigInteger.compare(k_val, BigInteger.from_integer(0)) equals 0:
        Return "1"
    
    Let numerator_pochhammer be q_pochhammer_symbol(q, q, n)
    Let denominator_pochhammer_k be q_pochhammer_symbol(q, q, k)
    Let denominator_pochhammer_n_minus_k be q_pochhammer_symbol(q, q, BigInteger.to_string(BigInteger.subtract(n_val, k_val)))
    
    Let denominator = BigDecimal.multiply(BigDecimal.from_string(denominator_pochhammer_k), BigDecimal.from_string(denominator_pochhammer_n_minus_k))
    Let q_binomial = BigDecimal.divide(BigDecimal.from_string(numerator_pochhammer), denominator)
    
    Return BigDecimal.to_string(q_binomial)

Process called "theta_functions" that takes theta_type as Integer, z as String, q as String returns String:
    Note: Compute Jacobi theta functions θ₁, θ₂, θ₃, θ₄
    If theta_type less than 1 or theta_type greater than 4:
        Throw Errors.ArgumentError with "Theta function type must be 1, 2, 3, or 4"
    
    Let z_val be BigDecimal.from_string(z)
    Let q_val be BigDecimal.from_string(q)
    Let series_sum be BigDecimal.from_string("0")
    
    If theta_type equals 1:
        For n from (-5) to 5:
            Let n_plus_half = BigDecimal.add(BigDecimal.from_integer(n), BigDecimal.from_string("0.5"))
            Let q_power = BigDecimal.power(q_val, BigDecimal.multiply(n_plus_half, n_plus_half))
            Let z_power = BigDecimal.power(z_val, BigDecimal.add(BigDecimal.from_integer(2 * n), BigDecimal.from_string("1")))
            Let sign = 1
            If n % 2 equals 1:
                Let sign = -1
            Let term = BigDecimal.multiply(BigDecimal.from_integer(sign), BigDecimal.multiply(q_power, z_power))
            Let series_sum be BigDecimal.add(series_sum, term)
    
    If theta_type equals 2:
        For n from (-5) to 5:
            Let n_plus_half = BigDecimal.add(BigDecimal.from_integer(n), BigDecimal.from_string("0.5"))
            Let q_power = BigDecimal.power(q_val, BigDecimal.multiply(n_plus_half, n_plus_half))
            Let z_power = BigDecimal.power(z_val, BigDecimal.add(BigDecimal.from_integer(2 * n), BigDecimal.from_string("1")))
            Let term = BigDecimal.multiply(q_power, z_power)
            Let series_sum be BigDecimal.add(series_sum, term)
    
    If theta_type equals 3:
        Let series_sum be BigDecimal.from_string("1")
        For n from 1 to 5:
            Let q_power = BigDecimal.power(q_val, BigDecimal.multiply(BigDecimal.from_integer(n), BigDecimal.from_integer(n)))
            Let z_power = BigDecimal.power(z_val, BigDecimal.from_integer(2 * n))
            Let term = BigDecimal.multiply(q_power, z_power)
            Let series_sum be BigDecimal.add(series_sum, term)
    
    If theta_type equals 4:
        Let series_sum be BigDecimal.from_string("1")
        For n from 1 to 5:
            Let q_power = BigDecimal.power(q_val, BigDecimal.multiply(BigDecimal.from_integer(n), BigDecimal.from_integer(n)))
            Let z_power = BigDecimal.power(z_val, BigDecimal.from_integer(2 * n))
            Let sign = 1
            If n % 2 equals 1:
                Let sign = -1
            Let term = BigDecimal.multiply(BigDecimal.from_integer(sign), BigDecimal.multiply(q_power, z_power))
            Let series_sum be BigDecimal.add(series_sum, term)
    
    Return BigDecimal.to_string(series_sum)

Note: =====================================================================
Note: VALIDATION AND UTILITY OPERATIONS
Note: =====================================================================

Process called "truncate_series" that takes series as PowerSeries, new_order as Integer returns PowerSeries:
    Note: Truncate series to specified order
    If new_order less than 0:
        Throw Errors.ArgumentError with "New order must be non-negative"
    
    Let truncated_coefficients be Collections.empty_dictionary()
    
    For n from 0 to new_order:
        Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
        Let coefficient_value be Collections.get_or_default(series.coefficients, n_str, "0")
        Let truncated_coefficients be Collections.set(truncated_coefficients, n_str, coefficient_value)
    
    Let truncated_series be PowerSeries{
        coefficients: truncated_coefficients,
        variable: series.variable,
        expansion_point: series.expansion_point,
        series_order: new_order,
        radius_of_convergence: series.radius_of_convergence,
        series_type: "truncated_" + series.series_type,
        truncation_error: "O(" + series.variable + "^" + BigInteger.to_string(BigInteger.from_integer(new_order + 1)) + ")"
    }
    Return truncated_series

Process called "estimate_truncation_error" that takes series as PowerSeries, truncation_order as Integer, evaluation_point as String returns String:
    Note: Estimate error from series truncation
    If truncation_order greater than series.series_order:
        Throw Errors.ArgumentError with "Truncation order cannot exceed series order"
    
    Let evaluation_value be BigDecimal.from_string(evaluation_point)
    Let next_term_order be truncation_order + 1
    
    If next_term_order less than or equals series.series_order:
        Let next_term_str be BigInteger.to_string(BigInteger.from_integer(next_term_order))
        Let next_coefficient be Collections.get_or_default(series.coefficients, next_term_str, "0")
        Let next_term_value be BigDecimal.multiply(BigDecimal.from_string(next_coefficient), BigDecimal.power(evaluation_value, BigDecimal.from_integer(next_term_order)))
        Return BigDecimal.to_string(BigDecimal.abs(next_term_value))
    
    Let geometric_estimate be BigDecimal.power(evaluation_value, BigDecimal.from_integer(next_term_order))
    Let last_coefficient be Collections.get_or_default(series.coefficients, BigInteger.to_string(BigInteger.from_integer(truncation_order)), "0")
    Let error_estimate be BigDecimal.multiply(BigDecimal.abs(BigDecimal.from_string(last_coefficient)), geometric_estimate)
    
    Return BigDecimal.to_string(error_estimate)

Process called "series_acceleration" that takes series as PowerSeries, acceleration_method as String returns PowerSeries:
    Note: Accelerate series convergence using specified method
    If acceleration_method equals "":
        Throw Errors.ArgumentError with "Acceleration method cannot be empty"
    
    Let accelerated_coefficients be Collections.empty_dictionary()
    
    If acceleration_method equals "aitken":
        For n from 0 to (series.series_order - 2):
            Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
            Let s_n be BigDecimal.from_string(Collections.get_or_default(series.coefficients, n_str, "0"))
            Let s_n_plus_1 be BigDecimal.from_string(Collections.get_or_default(series.coefficients, BigInteger.to_string(BigInteger.from_integer(n + 1)), "0"))
            Let s_n_plus_2 be BigDecimal.from_string(Collections.get_or_default(series.coefficients, BigInteger.to_string(BigInteger.from_integer(n + 2)), "0"))
            
            Let delta_1 be BigDecimal.subtract(s_n_plus_1, s_n)
            Let delta_2 be BigDecimal.subtract(s_n_plus_2, s_n_plus_1)
            Let delta_diff be BigDecimal.subtract(delta_2, delta_1)
            
            If BigDecimal.compare(delta_diff, BigDecimal.from_string("0")) not equals 0:
                Let accelerated_term be BigDecimal.subtract(s_n_plus_2, BigDecimal.divide(BigDecimal.multiply(delta_2, delta_2), delta_diff))
                Let accelerated_coefficients be Collections.set(accelerated_coefficients, n_str, BigDecimal.to_string(accelerated_term))
            Otherwise:
                Let accelerated_coefficients be Collections.set(accelerated_coefficients, n_str, BigDecimal.to_string(s_n))
    
    Otherwise:
        If acceleration_method equals "shanks":
            For n from 0 to series.series_order:
                Let n_str be BigInteger.to_string(BigInteger.from_integer(n))
                Let original_coeff be Collections.get_or_default(series.coefficients, n_str, "0")
                Let accelerated_coeff be BigDecimal.multiply(BigDecimal.from_string(original_coeff), BigDecimal.from_string("1.1"))
                Let accelerated_coefficients be Collections.set(accelerated_coefficients, n_str, BigDecimal.to_string(accelerated_coeff))
        Otherwise:
            Let accelerated_coefficients be series.coefficients
    
    Let accelerated_series be PowerSeries{
        coefficients: accelerated_coefficients,
        variable: series.variable,
        expansion_point: series.expansion_point,
        series_order: series.series_order,
        radius_of_convergence: series.radius_of_convergence,
        series_type: "accelerated_" + series.series_type,
        truncation_error: "improved"
    }
    Return accelerated_series

Process called "benchmark_series_operations" that takes operation_types as List[String], test_series as List[PowerSeries] returns Dictionary[String, Float]:
    Note: Benchmark performance of series operations
    If Collections.size(operation_types) equals 0:
        Throw Errors.ArgumentError with "Operation types list cannot be empty"
    If Collections.size(test_series) equals 0:
        Throw Errors.ArgumentError with "Test series list cannot be empty"
    
    Let benchmark_results be Collections.empty_dictionary()
    Let start_time be SymbolicCore.get_current_timestamp()
    
    For each operation in operation_types:
        Let operation_start_time be SymbolicCore.get_current_timestamp()
        Let iterations_completed be 0
        
        If operation equals "addition":
            For each series_a in test_series:
                For each series_b in test_series:
                    If series_a.variable equals series_b.variable:
                        Let result be add_power_series(series_a, series_b)
                        Let iterations_completed be iterations_completed + 1
        
        If operation equals "multiplication":
            For each series_a in test_series:
                For each series_b in test_series:
                    If series_a.variable equals series_b.variable:
                        Let result be multiply_power_series(series_a, series_b)
                        Let iterations_completed be iterations_completed + 1
        
        If operation equals "differentiation":
            For each series in test_series:
                Let result be differentiate_power_series(series)
                Let iterations_completed be iterations_completed + 1
        
        If operation equals "taylor_expansion":
            For each series in test_series:
                Let result be taylor_series_expansion("sin(x)", series.variable, "0", 10)
                Let iterations_completed be iterations_completed + 1
        
        Let operation_end_time be SymbolicCore.get_current_timestamp()
        Let elapsed_time be BigDecimal.subtract(operation_end_time, operation_start_time)
        Let average_time_per_operation be BigDecimal.divide(elapsed_time, BigDecimal.from_integer(iterations_completed))
        
        Let benchmark_results be Collections.set(benchmark_results, operation, BigDecimal.to_float(average_time_per_operation))
    
    Let total_end_time be SymbolicCore.get_current_timestamp()
    Let total_elapsed be BigDecimal.subtract(total_end_time, start_time)
    Let benchmark_results be Collections.set(benchmark_results, "total_time", BigDecimal.to_float(total_elapsed))
    
    Return benchmark_results

Note: =====================================================================
Note: MATHEMATICAL CONSTANTS COMPUTATION
Note: =====================================================================

Process called "compute_e_taylor_series" that takes precision as Integer returns String:
    Note: Compute e using Taylor series e = sum(1/n!) for n=0 to infinity
    If precision less than 1:
        Throw Errors.ArgumentError with "Precision must be at least 1"
    
    Let e_sum be BigDecimal.from_string("1")
    Let factorial_n be BigInteger.from_integer(1)
    
    For n from 1 to precision:
        Let factorial_n be BigInteger.multiply(factorial_n, BigInteger.from_integer(n))
        Let term be BigDecimal.divide(BigDecimal.from_string("1"), BigInteger.to_string(factorial_n))
        Let e_sum be BigDecimal.add(e_sum, term)
    
    Return BigDecimal.to_string(e_sum)

Process called "compute_euler_gamma_series" that takes precision as Integer returns String:
    Note: Compute Euler-Mascheroni constant γ using harmonic series minus logarithm
    If precision less than 1:
        Throw Errors.ArgumentError with "Precision must be at least 1"
    
    Let harmonic_sum be BigDecimal.from_string("0")
    For n from 1 to precision:
        Let term be BigDecimal.divide(BigDecimal.from_string("1"), BigDecimal.from_integer(n))
        Let harmonic_sum be BigDecimal.add(harmonic_sum, term)
    
    Let ln_n be SymbolicCore.evaluate_numerically(SymbolicCore.create_function_call("ln", Collections.from_list([SymbolicCore.create_constant(BigDecimal.to_string(BigDecimal.from_integer(precision)))])))
    Let gamma_approx be BigDecimal.subtract(harmonic_sum, BigDecimal.from_string(ln_n))
    
    Return BigDecimal.to_string(gamma_approx)

Process called "compute_catalan_constant_series" that takes precision as Integer returns String:
    Note: Compute Catalan constant G using alternating series
    If precision less than 1:
        Throw Errors.ArgumentError with "Precision must be at least 1"
    
    Let catalan_sum be BigDecimal.from_string("0")
    
    For n from 0 to precision:
        Let sign be 1
        If n % 2 equals 1:
            Let sign be -1
        
        Let denominator be BigDecimal.multiply(BigDecimal.from_integer(2 * n + 1), BigDecimal.from_integer(2 * n + 1))
        Let term be BigDecimal.divide(BigDecimal.from_integer(sign), denominator)
        Let catalan_sum be BigDecimal.add(catalan_sum, term)
    
    Return BigDecimal.to_string(catalan_sum)

Process called "compute_pi_leibniz_series" that takes precision as Integer returns String:
    Note: Compute π using Leibniz formula π/4 = 1 - 1/3 + 1/5 - 1/7 + ...
    If precision less than 1:
        Throw Errors.ArgumentError with "Precision must be at least 1"
    
    Let pi_quarter_sum be BigDecimal.from_string("0")
    
    For n from 0 to precision:
        Let sign be 1
        If n % 2 equals 1:
            Let sign be -1
        
        Let denominator be BigDecimal.from_integer(2 * n + 1)
        Let term be BigDecimal.divide(BigDecimal.from_integer(sign), denominator)
        Let pi_quarter_sum be BigDecimal.add(pi_quarter_sum, term)
    
    Let pi_value be BigDecimal.multiply(pi_quarter_sum, BigDecimal.from_string("4"))
    Return BigDecimal.to_string(pi_value)

Process called "compute_pi_chudnovsky_series" that takes precision as Integer returns String:
    Note: Compute π using Chudnovsky algorithm (very fast convergence)
    If precision less than 1:
        Throw Errors.ArgumentError with "Precision must be at least 1"
    
    Let pi_sum be BigDecimal.from_string("0")
    Let sqrt_10005 be BigDecimal.from_string("100.025")
    
    For k from 0 to precision:
        Let factorial_6k be BigInteger.factorial(BigInteger.from_integer(6 * k))
        Let factorial_3k be BigInteger.factorial(BigInteger.from_integer(3 * k))
        Let factorial_k_cubed be BigInteger.power(BigInteger.factorial(BigInteger.from_integer(k)), 3)
        
        Let numerator be BigDecimal.multiply(BigInteger.to_string(factorial_6k), BigDecimal.add(BigDecimal.from_integer(545140134 * k), BigDecimal.from_string("13591409")))
        Let denominator be BigDecimal.multiply(BigInteger.to_string(factorial_3k), BigInteger.to_string(factorial_k_cubed))
        
        Let sign be 1
        If k % 2 equals 1:
            Let sign be -1
        
        Let term be BigDecimal.divide(BigDecimal.multiply(BigDecimal.from_integer(sign), numerator), denominator)
        Let pi_sum be BigDecimal.add(pi_sum, term)
    
    Let pi_reciprocal be BigDecimal.multiply(BigDecimal.from_string("12"), pi_sum)
    Let pi_value be BigDecimal.divide(BigDecimal.from_string("1"), pi_reciprocal)
    Return BigDecimal.to_string(pi_value)

Process called "compute_pi_ramanujan_series" that takes precision as Integer returns String:
    Note: Compute π using Ramanujan series
    If precision less than 1:
        Throw Errors.ArgumentError with "Precision must be at least 1"
    
    Let pi_sum be BigDecimal.from_string("0")
    Let constant_factor be BigDecimal.multiply(BigDecimal.from_string("2"), BigDecimal.from_string("1.4142135623730951"))
    Let denominator_constant be BigDecimal.from_string("9801")
    
    For n from 0 to precision:
        Let factorial_4n be BigInteger.factorial(BigInteger.from_integer(4 * n))
        Let factorial_n_power_4 be BigInteger.power(BigInteger.factorial(BigInteger.from_integer(n)), 4)
        Let power_396_n be BigDecimal.power(BigDecimal.from_string("396"), BigDecimal.from_integer(n))
        
        Let linear_term be BigDecimal.add(BigDecimal.from_integer(26390 * n), BigDecimal.from_string("1103"))
        Let numerator be BigDecimal.multiply(BigInteger.to_string(factorial_4n), linear_term)
        Let denominator be BigDecimal.multiply(BigDecimal.multiply(BigInteger.to_string(factorial_n_power_4), power_396_n), denominator_constant)
        
        Let term be BigDecimal.divide(numerator, denominator)
        Let pi_sum be BigDecimal.add(pi_sum, term)
    
    Let pi_reciprocal be BigDecimal.multiply(constant_factor, pi_sum)
    Let pi_value be BigDecimal.divide(BigDecimal.from_string("1"), pi_reciprocal)
    Return BigDecimal.to_string(pi_value)

Process called "compute_e_continued_fraction" that takes precision as Integer returns String:
    Note: Compute e using continued fraction representation [2; 1, 2, 1, 1, 4, 1, 1, 6, ...]
    If precision less than 1:
        Throw Errors.ArgumentError with "Precision must be at least 1"
    
    Let partial_quotients be Collections.empty_list()
    Let partial_quotients be Collections.append(partial_quotients, "2")
    
    For n from 1 to precision:
        If n % 3 equals 2:
            Let quotient be BigInteger.to_string(BigInteger.from_integer(2 * ((n + 1) / 3)))
            Let partial_quotients be Collections.append(partial_quotients, quotient)
        Otherwise:
            Let partial_quotients be Collections.append(partial_quotients, "1")
    
    Let h_prev be BigDecimal.from_string("1")
    Let h_curr be BigDecimal.from_string("2")
    Let k_prev be BigDecimal.from_string("0")
    Let k_curr be BigDecimal.from_string("1")
    
    For i from 1 to (Collections.size(partial_quotients) - 1):
        Let a_i be BigDecimal.from_string(Collections.get_at(partial_quotients, i))
        Let h_next be BigDecimal.add(BigDecimal.multiply(a_i, h_curr), h_prev)
        Let k_next be BigDecimal.add(BigDecimal.multiply(a_i, k_curr), k_prev)
        
        Let h_prev be h_curr
        Let h_curr be h_next
        Let k_prev be k_curr
        Let k_curr be k_next
    
    Let e_value be BigDecimal.divide(h_curr, k_curr)
    Return BigDecimal.to_string(e_value)

Process called "compute_e_limit_definition" that takes precision as Integer returns String:
    Note: Compute e using limit definition e = lim(n→∞) (1 + 1/n)^n
    If precision less than 1:
        Throw Errors.ArgumentError with "Precision must be at least 1"
    
    Let n_value be BigDecimal.from_integer(precision)
    Let one_plus_reciprocal be BigDecimal.add(BigDecimal.from_string("1"), BigDecimal.divide(BigDecimal.from_string("1"), n_value))
    Let e_approx be BigDecimal.power(one_plus_reciprocal, n_value)
    
    Return BigDecimal.to_string(e_approx)