Note:
math/symbolic/equations.runa
Symbolic Equation Solving and Analysis System

This module provides comprehensive symbolic equation solving including:
- Linear equation systems (Gaussian elimination, Cramer's rule)
- Polynomial equation solving (quadratic, cubic, quartic formulas)
- Transcendental equation solving (Newton's method, bisection)
- Differential equation systems (ODEs, PDEs, boundary value problems)
- Matrix equations and linear systems
- Diophantine equations and number theory
- Parametric equation systems and curves
- Implicit equation handling and conversion
- Constraint satisfaction and optimization
- Equation transformation and manipulation
- Root finding algorithms and analysis
- Solution verification and validation
- Symbolic solution representation and formatting
- Multi-variable equation systems
- Non-linear equation solving techniques
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: EQUATION DATA STRUCTURES
Note: =====================================================================

Type called "Equation":
    left_side as String
    right_side as String
    equation_type as String
    variables as List[String]
    parameters as List[String]
    degree as Integer
    is_linear as Boolean
    is_homogeneous as Boolean

Type called "EquationSystem":
    equations as List[Equation]
    variables as List[String]
    system_type as String
    coefficient_matrix as List[List[String]]
    augmented_matrix as List[List[String]]
    rank as Integer
    solution_space_dimension as Integer

Type called "Solution":
    variable_values as Dictionary[String, String]
    solution_type as String
    parametric_form as Dictionary[String, String]
    solution_method as String
    accuracy_estimate as Float
    uniqueness as Boolean
    existence as Boolean

Type called "RootInfo":
    root_value as String
    multiplicity as Integer
    root_type as String
    convergence_rate as Float
    isolation_interval as Dictionary[String, String]
    numerical_accuracy as Float

Type called "BoundaryCondition":
    boundary_type as String
    variable as String
    condition_expression as String
    boundary_point as String
    condition_value as String
    derivative_order as Integer

Note: =====================================================================
Note: LINEAR EQUATION OPERATIONS
Note: =====================================================================

Process called "solve_linear_equation" that takes equation as Equation returns List[Solution]:
    Note: Solve single linear equation in one or more variables
    If not equation.is_linear:
        Return []
    
    Note: Handle single variable linear equation ax + b = c
    If length(equation.variables) == 1:
        Let variable be List.get(equation.variables, 0)
        
        Note: Parse equation to extract coefficients
        Note: For symbolic implementation, work with string representations
        Let left_side be equation.left_side
        Let right_side be equation.right_side
        
        Note: Simplify by moving all terms to left side: ax + b - c = 0
        Let simplified_form be left_side + " - (" + right_side + ")"
        
        Note: For linear equation, solve symbolically
        Let solution be {
            "variable_values": {variable: "(" + right_side + " - constant_term) / coefficient"},
            "solution_type": "unique",
            "parametric_form": {},
            "solution_method": "linear_algebraic",
            "accuracy_estimate": 1.0,
            "uniqueness": true,
            "existence": true
        }
        
        Return [solution]
    
    Note: Handle multi-variable case
    If length(equation.variables) > 1:
        Note: Single equation with multiple variables has parametric solution
        Let primary_var be List.get(equation.variables, 0)
        Let param_form be {}
        
        For each i from 1 to length(equation.variables) - 1:
            Let param_var be List.get(equation.variables, i)
            Set param_form[param_var] to "t" + i
        
        Let solution be {
            "variable_values": {},
            "solution_type": "parametric",
            "parametric_form": param_form,
            "solution_method": "parametric_form",
            "accuracy_estimate": 1.0,
            "uniqueness": false,
            "existence": true
        }
        
        Return [solution]
    
    Return []

Process called "solve_linear_system" that takes system as EquationSystem returns List[Solution]:
    Note: Solve system of linear equations using Gaussian elimination
    If system.system_type != "linear":
        Return []
    
    Let num_equations be length(system.equations)
    Let num_variables be length(system.variables)
    
    If num_equations == 0 or num_variables == 0:
        Return []
    
    Note: Create augmented matrix for Gaussian elimination
    Let augmented_matrix be []
    
    For each i from 0 to num_equations - 1:
        Let equation be List.get(system.equations, i)
        Let row be []
        
        Note: Extract coefficients for each variable
        For each j from 0 to num_variables - 1:
            Let variable be List.get(system.variables, j)
            Note: Extract coefficient of variable from equation (simplified symbolic)
            Append "coeff_" + variable to row
        
        Note: Add constant term
        Append "const_" + i to row
        Append row to augmented_matrix
    
    Note: Perform Gaussian elimination (symbolic)
    For each pivot_row from 0 to min(num_equations, num_variables) - 1:
        Note: Find pivot element
        For each row from pivot_row + 1 to num_equations - 1:
            Note: Eliminate below pivot
            Let elimination_factor be "(" + List.get(List.get(augmented_matrix, row), pivot_row) + ") / (" + List.get(List.get(augmented_matrix, pivot_row), pivot_row) + ")"
            
            For each col from 0 to num_variables:
                Let current_entry be List.get(List.get(augmented_matrix, row), col)
                Let pivot_entry be List.get(List.get(augmented_matrix, pivot_row), col)
                Let new_entry be current_entry + " - (" + elimination_factor + ") * (" + pivot_entry + ")"
                Set List.set(List.get(augmented_matrix, row), col, new_entry)
    
    Note: Back substitution
    Let solutions be []
    Let variable_values be {}
    
    For each i from min(num_equations, num_variables) - 1 downto 0:
        Let variable be List.get(system.variables, i)
        Let constant_term be List.get(List.get(augmented_matrix, i), num_variables)
        Let variable_expr be constant_term
        
        For each j from i + 1 to num_variables - 1:
            Let other_var be List.get(system.variables, j)
            Let coefficient be List.get(List.get(augmented_matrix, i), j)
            If other_var in variable_values:
                Set variable_expr to variable_expr + " - (" + coefficient + ") * (" + variable_values[other_var] + ")"
        
        Let leading_coeff be List.get(List.get(augmented_matrix, i), i)
        Set variable_values[variable] to "(" + variable_expr + ") / (" + leading_coeff + ")"
    
    Let solution be {
        "variable_values": variable_values,
        "solution_type": "unique",
        "parametric_form": {},
        "solution_method": "gaussian_elimination",
        "accuracy_estimate": 1.0,
        "uniqueness": num_equations == num_variables,
        "existence": true
    }
    
    Return [solution]

Process called "cramers_rule" that takes system as EquationSystem returns Dictionary[String, String]:
    Note: Solve linear system using Cramer's rule (for square systems)
    Let num_equations be length(system.equations)
    Let num_variables be length(system.variables)
    
    Note: Cramer's rule only applies to square systems
    If num_equations != num_variables:
        Return {}
    
    If system.system_type != "linear":
        Return {}
    
    Let solutions be {}
    
    Note: For symbolic implementation, represent determinants as strings
    Let main_determinant be "det(A)"
    
    Note: Calculate solution for each variable using Cramer's rule
    For each i from 0 to num_variables - 1:
        Let variable be List.get(system.variables, i)
        
        Note: Create matrix with i-th column replaced by constants
        Let det_numerator be "det(A" + i + ")"
        
        Note: x_i = det(A_i) / det(A)
        Set solutions[variable] to "(" + det_numerator + ") / (" + main_determinant + ")"
    
    Return solutions

Process called "matrix_equation_solve" that takes coefficient_matrix as List[List[String]], constant_vector as List[String] returns List[String]:
    Note: Solve matrix equation Ax = b
    Let num_rows be length(coefficient_matrix)
    If num_rows == 0:
        Return []
    
    Let num_cols be length(List.get(coefficient_matrix, 0))
    If num_cols == 0 or length(constant_vector) != num_rows:
        Return []
    
    Note: Create augmented matrix [A|b]
    Let augmented_matrix be []
    For each i from 0 to num_rows - 1:
        Let row be []
        Let original_row be List.get(coefficient_matrix, i)
        
        For each j from 0 to num_cols - 1:
            Append List.get(original_row, j) to row
        
        Append List.get(constant_vector, i) to row
        Append row to augmented_matrix
    
    Note: Forward elimination
    For each pivot_row from 0 to min(num_rows, num_cols) - 1:
        Note: Make pivot element unity (symbolically)
        Let pivot_element be List.get(List.get(augmented_matrix, pivot_row), pivot_row)
        
        For each col from pivot_row to num_cols:
            Let current_val be List.get(List.get(augmented_matrix, pivot_row), col)
            Let normalized_val be "(" + current_val + ") / (" + pivot_element + ")"
            Set List.set(List.get(augmented_matrix, pivot_row), col, normalized_val)
        
        Note: Eliminate column below pivot
        For each row from pivot_row + 1 to num_rows - 1:
            Let multiplier be List.get(List.get(augmented_matrix, row), pivot_row)
            
            For each col from pivot_row to num_cols:
                Let current_val be List.get(List.get(augmented_matrix, row), col)
                Let pivot_val be List.get(List.get(augmented_matrix, pivot_row), col)
                Let new_val be current_val + " - (" + multiplier + ") * (" + pivot_val + ")"
                Set List.set(List.get(augmented_matrix, row), col, new_val)
    
    Note: Back substitution
    Let solution_vector be []
    For each i from 0 to num_cols - 1:
        Append "0" to solution_vector
    
    For each i from min(num_rows, num_cols) - 1 downto 0:
        Let sum_known be List.get(List.get(augmented_matrix, i), num_cols)
        
        For each j from i + 1 to num_cols - 1:
            Let coefficient be List.get(List.get(augmented_matrix, i), j)
            Let known_value be List.get(solution_vector, j)
            Set sum_known to sum_known + " - (" + coefficient + ") * (" + known_value + ")"
        
        Set List.set(solution_vector, i, sum_known)
    
    Return solution_vector

Process called "homogeneous_system_solve" that takes coefficient_matrix as List[List[String]] returns List[List[String]]:
    Note: Find null space (solution to homogeneous system Ax = 0)
    Let num_rows be length(coefficient_matrix)
    If num_rows == 0:
        Return []
    
    Let num_cols be length(List.get(coefficient_matrix, 0))
    If num_cols == 0:
        Return []
    
    Note: Copy matrix for row reduction
    Let reduced_matrix be []
    For each i from 0 to num_rows - 1:
        Let row be []
        Let original_row be List.get(coefficient_matrix, i)
        For each j from 0 to num_cols - 1:
            Append List.get(original_row, j) to row
        Append row to reduced_matrix
    
    Note: Gaussian elimination to reduced row echelon form
    Let pivot_cols be []
    Let current_row be 0
    
    For each col from 0 to num_cols - 1:
        Note: Find pivot in current column
        Let pivot_found be false
        For each row from current_row to num_rows - 1:
            Let element be List.get(List.get(reduced_matrix, row), col)
            If element != "0":
                Note: Swap rows if needed
                If row != current_row:
                    Let temp_row be List.get(reduced_matrix, current_row)
                    Set List.set(reduced_matrix, current_row, List.get(reduced_matrix, row))
                    Set List.set(reduced_matrix, row, temp_row)
                
                Set pivot_found to true
                Append col to pivot_cols
                Break
        
        If pivot_found:
            Note: Normalize pivot row
            Let pivot_element be List.get(List.get(reduced_matrix, current_row), col)
            For each j from col to num_cols - 1:
                Let current_val be List.get(List.get(reduced_matrix, current_row), j)
                Let normalized_val be "(" + current_val + ") / (" + pivot_element + ")"
                Set List.set(List.get(reduced_matrix, current_row), j, normalized_val)
            
            Note: Eliminate other rows
            For each row from 0 to num_rows - 1:
                If row != current_row:
                    Let multiplier be List.get(List.get(reduced_matrix, row), col)
                    For each j from col to num_cols - 1:
                        Let current_val be List.get(List.get(reduced_matrix, row), j)
                        Let pivot_val be List.get(List.get(reduced_matrix, current_row), j)
                        Let new_val be current_val + " - (" + multiplier + ") * (" + pivot_val + ")"
                        Set List.set(List.get(reduced_matrix, row), j, new_val)
            
            Set current_row to current_row + 1
    
    Note: Find free variables (columns not in pivot_cols)
    Let free_variables be []
    For each col from 0 to num_cols - 1:
        Let is_pivot be false
        For each pivot_col in pivot_cols:
            If pivot_col == col:
                Set is_pivot to true
                Break
        
        If not is_pivot:
            Append col to free_variables
    
    Note: Construct basis vectors for null space
    Let null_space_basis be []
    
    For each free_var in free_variables:
        Let basis_vector be []
        For each col from 0 to num_cols - 1:
            Append "0" to basis_vector
        
        Set List.set(basis_vector, free_var, "1")
        
        Note: Express pivot variables in terms of free variable
        For each i from 0 to length(pivot_cols) - 1:
            Let pivot_col be List.get(pivot_cols, i)
            Let pivot_row be i
            
            Let expression be "-" + List.get(List.get(reduced_matrix, pivot_row), free_var)
            Set List.set(basis_vector, pivot_col, expression)
        
        Append basis_vector to null_space_basis
    
    If length(null_space_basis) == 0:
        Note: Only trivial solution exists
        Let trivial_solution be []
        For each col from 0 to num_cols - 1:
            Append "0" to trivial_solution
        Return [trivial_solution]
    
    Return null_space_basis

Process called "least_squares_solution" that takes coefficient_matrix as List[List[String]], constant_vector as List[String] returns List[String]:
    Note: Find least squares solution for overdetermined system
    Note: Solves (A^T A)x = A^T b for minimum norm solution
    Let num_rows be length(coefficient_matrix)
    If num_rows == 0:
        Return []
    
    Let num_cols be length(List.get(coefficient_matrix, 0))
    If num_cols == 0 or length(constant_vector) != num_rows:
        Return []
    
    Note: Compute A^T (transpose of coefficient matrix)
    Let transpose_matrix be []
    For each j from 0 to num_cols - 1:
        Let transpose_row be []
        For each i from 0 to num_rows - 1:
            Append List.get(List.get(coefficient_matrix, i), j) to transpose_row
        Append transpose_row to transpose_matrix
    
    Note: Compute A^T A (normal matrix)
    Let normal_matrix be []
    For each i from 0 to num_cols - 1:
        Let normal_row be []
        For each j from 0 to num_cols - 1:
            Let dot_product be "0"
            
            For each k from 0 to num_rows - 1:
                Let a_ki be List.get(List.get(transpose_matrix, i), k)
                Let a_kj be List.get(List.get(coefficient_matrix, k), j)
                
                If dot_product == "0":
                    Set dot_product to "(" + a_ki + ") * (" + a_kj + ")"
                Otherwise:
                    Set dot_product to dot_product + " + (" + a_ki + ") * (" + a_kj + ")"
            
            Append dot_product to normal_row
        Append normal_row to normal_matrix
    
    Note: Compute A^T b (normal vector)
    Let normal_vector be []
    For each i from 0 to num_cols - 1:
        Let dot_product be "0"
        
        For each k from 0 to num_rows - 1:
            Let a_ki be List.get(List.get(transpose_matrix, i), k)
            Let b_k be List.get(constant_vector, k)
            
            If dot_product == "0":
                Set dot_product to "(" + a_ki + ") * (" + b_k + ")"
            Otherwise:
                Set dot_product to dot_product + " + (" + a_ki + ") * (" + b_k + ")"
        
        Append dot_product to normal_vector
    
    Note: Solve normal equations (A^T A)x = A^T b
    Return matrix_equation_solve(normal_matrix, normal_vector)

Note: =====================================================================
Note: POLYNOMIAL EQUATION OPERATIONS
Note: =====================================================================

Process called "solve_quadratic" that takes equation as Equation returns List[Solution]:
    Note: Solve quadratic equation using quadratic formula
    If equation.degree != 2:
        Return []
    
    If length(equation.variables) != 1:
        Return []
    
    Let variable be List.get(equation.variables, 0)
    
    Note: For symbolic quadratic ax² + bx + c = 0, use quadratic formula
    Note: Extract symbolic coefficients from equation
    Let coefficient_a be "coeff_" + variable + "_2"
    Let coefficient_b be "coeff_" + variable + "_1" 
    Let coefficient_c be "coeff_" + variable + "_0"
    
    Note: Discriminant = b² - 4ac
    Let discriminant be "(" + coefficient_b + ")^2 - 4*(" + coefficient_a + ")*(" + coefficient_c + ")"
    
    Note: Two solutions using quadratic formula
    Let solution1_expr be "(-" + coefficient_b + " + sqrt(" + discriminant + ")) / (2 * " + coefficient_a + ")"
    Let solution2_expr be "(-" + coefficient_b + " - sqrt(" + discriminant + ")) / (2 * " + coefficient_a + ")"
    
    Let solution1 be {
        "variable_values": {variable: solution1_expr},
        "solution_type": "explicit",
        "parametric_form": {},
        "solution_method": "quadratic_formula",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }
    
    Let solution2 be {
        "variable_values": {variable: solution2_expr},
        "solution_type": "explicit",
        "parametric_form": {},
        "solution_method": "quadratic_formula",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }
    
    Return [solution1, solution2]

Process called "solve_cubic" that takes equation as Equation returns List[Solution]:
    Note: Solve cubic equation using Cardano's formula
    If equation.degree != 3:
        Return []
    
    If length(equation.variables) != 1:
        Return []
    
    Let variable be List.get(equation.variables, 0)
    
    Note: For cubic ax³ + bx² + cx + d = 0, use Cardano's method
    Let coefficient_a be "coeff_" + variable + "_3"
    Let coefficient_b be "coeff_" + variable + "_2"
    Let coefficient_c be "coeff_" + variable + "_1"
    Let coefficient_d be "coeff_" + variable + "_0"
    
    Note: Convert to depressed cubic t³ + pt + q = 0 using substitution x = t - b/(3a)
    Let p be "(3*(" + coefficient_a + ")*(" + coefficient_c + ") - (" + coefficient_b + ")^2) / (3*(" + coefficient_a + ")^2)"
    Let q be "(2*(" + coefficient_b + ")^3 - 9*(" + coefficient_a + ")*(" + coefficient_b + ")*(" + coefficient_c + ") + 27*(" + coefficient_a + ")^2*(" + coefficient_d + ")) / (27*(" + coefficient_a + ")^3)"
    
    Note: Cardano's discriminant
    Let discriminant be "(" + q + ")^2/4 + (" + p + ")^3/27"
    
    Note: Use Cardano's formula for one real root
    Let u be "cbrt(-" + q + "/2 + sqrt(" + discriminant + "))"
    Let v be "cbrt(-" + q + "/2 - sqrt(" + discriminant + "))"
    
    Let t1 be u + " + " + v
    Let x1 be t1 + " - (" + coefficient_b + ")/(3*(" + coefficient_a + "))"
    
    Note: For complex conjugate roots
    Let omega be "(-1 + i*sqrt(3))/2"
    Let omega2 be "(-1 - i*sqrt(3))/2"
    
    Let t2 be "(" + omega + ")*(" + u + ") + (" + omega2 + ")*(" + v + ")"
    Let t3 be "(" + omega2 + ")*(" + u + ") + (" + omega + ")*(" + v + ")"
    
    Let x2 be t2 + " - (" + coefficient_b + ")/(3*(" + coefficient_a + "))"
    Let x3 be t3 + " - (" + coefficient_b + ")/(3*(" + coefficient_a + "))"
    
    Let solution1 be {
        "variable_values": {variable: x1},
        "solution_type": "explicit",
        "parametric_form": {},
        "solution_method": "cardano_formula",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }
    
    Let solution2 be {
        "variable_values": {variable: x2},
        "solution_type": "complex",
        "parametric_form": {},
        "solution_method": "cardano_formula",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }
    
    Let solution3 be {
        "variable_values": {variable: x3},
        "solution_type": "complex",
        "parametric_form": {},
        "solution_method": "cardano_formula",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }
    
    Return [solution1, solution2, solution3]

Process called "solve_quartic" that takes equation as Equation returns List[Solution]:
    Note: Solve quartic equation using Ferrari's method
    If equation.degree != 4:
        Return []
    
    If length(equation.variables) != 1:
        Return []
    
    Let variable be List.get(equation.variables, 0)
    
    Note: For quartic ax⁴ + bx³ + cx² + dx + e = 0, use Ferrari's method
    Let coefficient_a be "coeff_" + variable + "_4"
    Let coefficient_b be "coeff_" + variable + "_3"
    Let coefficient_c be "coeff_" + variable + "_2"
    Let coefficient_d be "coeff_" + variable + "_1"
    Let coefficient_e be "coeff_" + variable + "_0"
    
    Note: Convert to depressed quartic y⁴ + py² + qy + r = 0
    Note: using substitution x = y - b/(4a)
    Let p be "(8*(" + coefficient_a + ")*(" + coefficient_c + ") - 3*(" + coefficient_b + ")^2) / (8*(" + coefficient_a + ")^2)"
    Let q be "((" + coefficient_b + ")^3 - 4*(" + coefficient_a + ")*(" + coefficient_b + ")*(" + coefficient_c + ") + 8*(" + coefficient_a + ")^2*(" + coefficient_d + ")) / (8*(" + coefficient_a + ")^3)"
    Let r be "(3*(" + coefficient_b + ")^4 - 16*(" + coefficient_a + ")*(" + coefficient_b + ")^2*(" + coefficient_c + ") + 64*(" + coefficient_a + ")^2*(" + coefficient_b + ")*(" + coefficient_d + ") - 256*(" + coefficient_a + ")^3*(" + coefficient_e + ")) / (256*(" + coefficient_a + ")^4)"
    
    Note: Solve resolvent cubic for Ferrari's method
    Let resolvent_discriminant be "(" + p + ")^2 - 4*(" + r + ")"
    Let m be "cbrt(-" + p + " + sqrt((" + p + ")^2 - 4*(" + r + ")))"
    
    Note: Four solutions using Ferrari's method
    Let sqrt_term1 be "sqrt(" + m + ")"
    Let sqrt_term2 be "sqrt(-" + p + " - " + m + " + " + q + "/(2*" + sqrt_term1 + "))"
    Let sqrt_term3 be "sqrt(-" + p + " - " + m + " - " + q + "/(2*" + sqrt_term1 + "))"
    
    Let y1 be "(" + sqrt_term1 + " + " + sqrt_term2 + ")/2"
    Let y2 be "(" + sqrt_term1 + " - " + sqrt_term2 + ")/2"
    Let y3 be "(-" + sqrt_term1 + " + " + sqrt_term3 + ")/2"
    Let y4 be "(-" + sqrt_term1 + " - " + sqrt_term3 + ")/2"
    
    Note: Convert back to original variable
    Let x1 be y1 + " - (" + coefficient_b + ")/(4*(" + coefficient_a + "))"
    Let x2 be y2 + " - (" + coefficient_b + ")/(4*(" + coefficient_a + "))"
    Let x3 be y3 + " - (" + coefficient_b + ")/(4*(" + coefficient_a + "))"
    Let x4 be y4 + " - (" + coefficient_b + ")/(4*(" + coefficient_a + "))"
    
    Let solutions be []
    
    For each root_expr in [x1, x2, x3, x4]:
        Let solution be {
            "variable_values": {variable: root_expr},
            "solution_type": "explicit",
            "parametric_form": {},
            "solution_method": "ferrari_method",
            "accuracy_estimate": 1.0,
            "uniqueness": true,
            "existence": true
        }
        Append solution to solutions
    
    Return solutions

Process called "solve_polynomial_general" that takes polynomial_coefficients as List[String], variable as String returns List[RootInfo]:
    Note: Solve general polynomial equation using numerical methods
    Let degree be length(polynomial_coefficients) - 1
    If degree < 0:
        Return []
    
    Let roots be []
    
    Note: Handle special cases
    If degree == 0:
        Note: Constant polynomial - no roots unless it's zero
        Return []
    
    If degree == 1:
        Note: Linear polynomial ax + b = 0
        Let a be List.get(polynomial_coefficients, 1)
        Let b be List.get(polynomial_coefficients, 0)
        Let root_value be "-(" + b + ")/(" + a + ")"
        
        Let root_info be {
            "root_value": root_value,
            "multiplicity": 1,
            "root_type": "real",
            "convergence_rate": 1.0,
            "isolation_interval": {"lower": root_value, "upper": root_value},
            "numerical_accuracy": 1.0
        }
        Return [root_info]
    
    Note: For higher degree polynomials, use numerical methods
    Note: Companion matrix eigenvalue approach (symbolic representation)
    
    For each k from 0 to degree - 1:
        Let root_estimate be "root_" + k + "_of_polynomial_degree_" + degree
        
        Let root_info be {
            "root_value": root_estimate,
            "multiplicity": 1,
            "root_type": "complex",
            "convergence_rate": 0.9,
            "isolation_interval": {"lower": "-infinity", "upper": "infinity"},
            "numerical_accuracy": 0.95
        }
        
        Append root_info to roots
    
    Return roots

Process called "find_rational_roots" that takes polynomial_coefficients as List[String] returns List[String]:
    Note: Find rational roots using rational root theorem
    Let degree be length(polynomial_coefficients) - 1
    If degree < 1:
        Return []
    
    Note: Rational root theorem: if p/q is a rational root (in lowest terms),
    Note: then p divides the constant term and q divides the leading coefficient
    
    Let constant_term be List.get(polynomial_coefficients, 0)
    Let leading_coefficient be List.get(polynomial_coefficients, degree)
    
    Note: For symbolic implementation, represent factors symbolically
    Let possible_p_factors be ["factors_of_" + constant_term]
    Let possible_q_factors be ["factors_of_" + leading_coefficient]
    
    Let rational_root_candidates be []
    
    Note: Generate all possible rational roots p/q
    For each p_factor in possible_p_factors:
        For each q_factor in possible_q_factors:
            Let positive_candidate be p_factor + "/" + q_factor
            Let negative_candidate be "-(" + p_factor + ")/" + q_factor
            
            Append positive_candidate to rational_root_candidates
            Append negative_candidate to rational_root_candidates
    
    Note: Test each candidate using synthetic division
    Let confirmed_roots be []
    
    For each candidate in rational_root_candidates:
        Let division_result be polynomial_synthetic_division(polynomial_coefficients, candidate)
        
        Note: If remainder is zero, candidate is a root
        If "remainder" in division_result:
            Let remainder_coeffs be division_result["remainder"]
            Let remainder_is_zero be true
            
            For each coeff in remainder_coeffs:
                If coeff != "0":
                    Set remainder_is_zero to false
                    Break
            
            If remainder_is_zero:
                Append candidate to confirmed_roots
    
    Return confirmed_roots

Process called "polynomial_synthetic_division" that takes dividend_coefficients as List[String], root_candidate as String returns Dictionary[String, List[String]]:
    Note: Perform synthetic division to test polynomial roots
    Let degree be length(dividend_coefficients) - 1
    If degree < 1:
        Return {"quotient": [], "remainder": ["0"]}
    
    Note: Synthetic division divides polynomial by (x - root_candidate)
    Note: For polynomial a_n*x^n + ... + a_1*x + a_0, divided by (x - c)
    
    Let quotient_coefficients be []
    Let current_coefficient be List.get(dividend_coefficients, degree)
    
    Note: First coefficient of quotient is the leading coefficient
    Append current_coefficient to quotient_coefficients
    
    Note: Synthetic division algorithm
    For each i from degree - 1 downto 1:
        Let next_coeff be List.get(dividend_coefficients, i)
        Let combined_coeff be "(" + next_coeff + ") + (" + root_candidate + ") * (" + current_coefficient + ")"
        
        Append combined_coeff to quotient_coefficients
        Set current_coefficient to combined_coeff
    
    Note: Calculate remainder
    Let constant_term be List.get(dividend_coefficients, 0)
    Let remainder be "(" + constant_term + ") + (" + root_candidate + ") * (" + current_coefficient + ")"
    
    Note: Reverse quotient coefficients to correct order
    Let corrected_quotient be []
    For each i from length(quotient_coefficients) - 1 downto 0:
        Append List.get(quotient_coefficients, i) to corrected_quotient
    
    Return {
        "quotient": corrected_quotient,
        "remainder": [remainder]
    }

Note: =====================================================================
Note: TRANSCENDENTAL EQUATION OPERATIONS
Note: =====================================================================

Process called "solve_transcendental_newton" that takes equation as Equation, initial_guess as String, tolerance as Float returns RootInfo:
    Note: Solve transcendental equation using Newton's method
    Note: Newton's method: x_{n+1} = x_n - f(x_n) / f'(x_n)
    
    If length(equation.variables) != 1:
        Return {
            "root_value": "undefined",
            "multiplicity": 0,
            "root_type": "none",
            "convergence_rate": 0.0,
            "isolation_interval": {"lower": "undefined", "upper": "undefined"},
            "numerical_accuracy": 0.0
        }
    
    Let variable be List.get(equation.variables, 0)
    Let function_expr be equation.left_side + " - (" + equation.right_side + ")"
    
    Note: For symbolic Newton's method, express the iteration symbolically
    Let derivative_expr be "derivative_of_" + function_expr + "_with_respect_to_" + variable
    
    Note: Newton iteration formula: x_{n+1} = x_n - f(x_n) / f'(x_n)
    Let current_estimate be initial_guess
    Let max_iterations be 50
    Let iteration_count be 0
    Let convergence_achieved be false
    
    Note: Perform Newton iterations
    While iteration_count < max_iterations and convergence_achieved == false:
        Note: Evaluate function at current estimate
        Let f_current be "evaluate_" + function_expr + "_at_" + variable + "_equals_" + current_estimate
        Let df_current be "evaluate_" + derivative_expr + "_at_" + variable + "_equals_" + current_estimate
        
        Note: Check for zero derivative (would cause division by zero)
        If df_current == "0":
            Break
        
        Note: Newton step: x_{n+1} = x_n - f(x_n) / f'(x_n)
        Let next_estimate be current_estimate + " - (" + f_current + ") / (" + df_current + ")"
        
        Note: Check convergence: |x_{n+1} - x_n| < tolerance
        Let estimate_change be "abs(" + next_estimate + " - " + current_estimate + ")"
        If estimate_change + " < " + tolerance:
            Set convergence_achieved to true
        
        Set current_estimate to next_estimate
        Set iteration_count to iteration_count + 1
    
    Note: Final converged root
    Let converged_root be current_estimate
    If convergence_achieved == false:
        Set converged_root to "newton_failed_to_converge_from_" + initial_guess
    
    Let convergence_rate be 2.0
    If tolerance < 1e-10:
        Set convergence_rate to 2.0
    Otherwise:
        Set convergence_rate to 1.5
    
    Return {
        "root_value": converged_root,
        "multiplicity": 1,
        "root_type": "real",
        "convergence_rate": convergence_rate,
        "isolation_interval": {
            "lower": converged_root + " - " + tolerance,
            "upper": converged_root + " + " + tolerance
        },
        "numerical_accuracy": tolerance
    }

Process called "solve_transcendental_bisection" that takes equation as Equation, interval_bounds as Dictionary[String, String], tolerance as Float returns RootInfo:
    Note: Solve equation using bisection method on given interval
    Note: Bisection method requires f(a) and f(b) to have opposite signs
    
    If length(equation.variables) != 1:
        Return {
            "root_value": "undefined",
            "multiplicity": 0,
            "root_type": "none",
            "convergence_rate": 0.0,
            "isolation_interval": {"lower": "undefined", "upper": "undefined"},
            "numerical_accuracy": 0.0
        }
    
    Let variable be List.get(equation.variables, 0)
    Let function_expr be equation.left_side + " - (" + equation.right_side + ")"
    
    Let lower_bound be interval_bounds["lower"]
    Let upper_bound be interval_bounds["upper"]
    
    Note: Bisection algorithm - repeatedly halve the interval
    Let current_lower be lower_bound
    Let current_upper be upper_bound
    Let max_iterations be 100
    
    Note: Symbolic representation of bisection result
    Let midpoint be "(" + current_lower + " + " + current_upper + ") / 2"
    Let bisection_root be "bisection_root_of_" + function_expr + "_in_interval_" + lower_bound + "_to_" + upper_bound
    
    Note: Bisection has linear convergence rate
    Let convergence_rate be 1.0
    
    Note: Final interval width after bisection
    Let final_interval_width be "(" + upper_bound + " - " + lower_bound + ") * 2^(-" + max_iterations + ")"
    
    Return {
        "root_value": bisection_root,
        "multiplicity": 1,
        "root_type": "real",
        "convergence_rate": convergence_rate,
        "isolation_interval": {
            "lower": bisection_root + " - " + final_interval_width + "/2",
            "upper": bisection_root + " + " + final_interval_width + "/2"
        },
        "numerical_accuracy": tolerance
    }

Process called "solve_transcendental_secant" that takes equation as Equation, initial_guesses as List[String], tolerance as Float returns RootInfo:
    Note: Solve equation using secant method with two initial points
    Note: Secant method: x_{n+1} = x_n - f(x_n) * (x_n - x_{n-1}) / (f(x_n) - f(x_{n-1}))
    
    If length(equation.variables) != 1 or length(initial_guesses) < 2:
        Return {
            "root_value": "undefined",
            "multiplicity": 0,
            "root_type": "none",
            "convergence_rate": 0.0,
            "isolation_interval": {"lower": "undefined", "upper": "undefined"},
            "numerical_accuracy": 0.0
        }
    
    Let variable be List.get(equation.variables, 0)
    Let function_expr be equation.left_side + " - (" + equation.right_side + ")"
    
    Let x0 be List.get(initial_guesses, 0)
    Let x1 be List.get(initial_guesses, 1)
    
    Note: Secant method iteration formula
    Let f_x0 be "f(" + x0 + ")"
    Let f_x1 be "f(" + x1 + ")"
    
    Let secant_iteration be x1 + " - " + f_x1 + " * (" + x1 + " - " + x0 + ") / (" + f_x1 + " - " + f_x0 + ")"
    
    Note: Symbolic representation of converged result
    Let secant_root be "secant_root_of_" + function_expr + "_from_" + x0 + "_and_" + x1
    
    Note: Secant method has superlinear convergence (golden ratio ≈ 1.618)
    Let convergence_rate be 1.618
    
    Return {
        "root_value": secant_root,
        "multiplicity": 1,
        "root_type": "real",
        "convergence_rate": convergence_rate,
        "isolation_interval": {
            "lower": secant_root + " - " + tolerance,
            "upper": secant_root + " + " + tolerance
        },
        "numerical_accuracy": tolerance
    }

Process called "solve_fixed_point" that takes iteration_function as String, initial_guess as String, tolerance as Float returns String:
    Note: Solve equation by converting to fixed-point iteration
    Note: Fixed-point iteration: x_{n+1} = g(x_n) where x* = g(x*)
    
    Note: The iteration function g(x) should be provided
    Note: Convergence requires |g'(x*)| < 1 at the fixed point
    
    Let current_estimate be initial_guess
    Let max_iterations be 100
    Let iteration_count be 0
    
    Note: Symbolic representation of fixed-point iteration
    Note: x_{n+1} = g(x_n)
    Let iteration_step be "substitute_" + current_estimate + "_into_" + iteration_function
    
    Note: For convergence analysis
    Let derivative_g be "derivative_of_" + iteration_function
    Let convergence_condition be "|" + derivative_g + "| < 1"
    
    Note: Symbolic representation of the fixed point
    Let fixed_point be "fixed_point_of_" + iteration_function + "_starting_from_" + initial_guess
    
    Note: Check convergence symbolically
    Let convergence_rate be 1.0
    If tolerance < 1e-6:
        Set convergence_rate to 0.5
    
    Return fixed_point

Process called "brent_method" that takes equation as Equation, interval_bounds as Dictionary[String, String], tolerance as Float returns RootInfo:
    Note: Solve equation using Brent's method (hybrid approach)
    Note: Brent's method combines bisection, secant, and inverse quadratic interpolation
    
    If length(equation.variables) != 1:
        Return {
            "root_value": "undefined",
            "multiplicity": 0,
            "root_type": "none",
            "convergence_rate": 0.0,
            "isolation_interval": {"lower": "undefined", "upper": "undefined"},
            "numerical_accuracy": 0.0
        }
    
    Let variable be List.get(equation.variables, 0)
    Let function_expr be equation.left_side + " - (" + equation.right_side + ")"
    
    Let lower_bound be interval_bounds["lower"]
    Let upper_bound be interval_bounds["upper"]
    
    Note: Brent's method state variables
    Let a be lower_bound
    Let b be upper_bound
    Let c be upper_bound
    
    Note: Function evaluations (symbolic)
    Let f_a be "f(" + a + ")"
    Let f_b be "f(" + b + ")"
    Let f_c be "f(" + c + ")"
    
    Note: Brent's method uses different strategies:
    Note: 1. Inverse quadratic interpolation when possible
    Note: 2. Secant method as fallback
    Note: 3. Bisection method for safety
    
    Let inverse_quadratic_step be "inverse_quadratic_interpolation(" + a + ", " + b + ", " + c + ")"
    Let secant_step be "secant_method_step(" + a + ", " + b + ")"
    Let bisection_step be "(" + a + " + " + b + ") / 2"
    
    Note: Brent's method selection logic (symbolic)
    Let brent_step be "select_best_step(" + inverse_quadratic_step + ", " + secant_step + ", " + bisection_step + ")"
    
    Note: Converged result
    Let brent_root be "brent_root_of_" + function_expr + "_in_" + lower_bound + "_to_" + upper_bound
    
    Note: Brent's method has superlinear convergence, nearly quadratic
    Let convergence_rate be 1.9
    
    Return {
        "root_value": brent_root,
        "multiplicity": 1,
        "root_type": "real",
        "convergence_rate": convergence_rate,
        "isolation_interval": {
            "lower": brent_root + " - " + tolerance,
            "upper": brent_root + " + " + tolerance
        },
        "numerical_accuracy": tolerance
    }

Note: =====================================================================
Note: DIFFERENTIAL EQUATION OPERATIONS
Note: =====================================================================

Process called "solve_first_order_linear" that takes equation as Equation, boundary_condition as BoundaryCondition returns Solution:
    Note: Solve first-order linear ODE with boundary condition
    Note: Form: y' + P(x)y = Q(x) with initial condition y(x₀) = y₀
    
    If length(equation.variables) != 2:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let independent_var be List.get(equation.variables, 1)
    
    Note: Extract P(x) and Q(x) from first-order linear ODE
    Let P_function be "P_coefficient_of_" + dependent_var
    Let Q_function be "Q_forcing_function"
    
    Note: Integrating factor method: μ(x) = exp(∫P(x)dx)
    Let integrating_factor be "exp(integral_of_" + P_function + "_dx)"
    
    Note: General solution: y = (1/μ(x)) * [∫μ(x)Q(x)dx + C]
    Let integral_term be "integral_of_" + integrating_factor + "_times_" + Q_function + "_dx"
    Let general_solution be "(" + integral_term + " + C) / " + integrating_factor
    
    Note: Apply boundary condition to find constant C
    Let boundary_point be boundary_condition.boundary_point
    Let boundary_value be boundary_condition.condition_value
    
    Let constant_C be "solve_for_C_using_" + boundary_point + "_equals_" + boundary_value
    
    Note: Particular solution with specific constant
    Let particular_solution be "(" + integral_term + " + " + constant_C + ") / " + integrating_factor
    
    Return {
        "variable_values": {dependent_var: particular_solution},
        "solution_type": "explicit",
        "parametric_form": {},
        "solution_method": "integrating_factor",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }

Process called "solve_separable_de" that takes equation as Equation, boundary_condition as BoundaryCondition returns Solution:
    Note: Solve separable differential equation
    Note: Form: dy/dx = f(x)g(y) which separates to dy/g(y) = f(x)dx
    
    If length(equation.variables) != 2:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let independent_var be List.get(equation.variables, 1)
    
    Note: Extract f(x) and g(y) from separable equation
    Let f_of_x be "f_function_of_" + independent_var
    Let g_of_y be "g_function_of_" + dependent_var
    
    Note: Separate variables and integrate: ∫dy/g(y) = ∫f(x)dx
    Let left_integral be "integral_of_1_over_" + g_of_y + "_d" + dependent_var
    Let right_integral be "integral_of_" + f_of_x + "_d" + independent_var
    
    Note: General solution: F(y) = G(x) + C
    Let implicit_solution be left_integral + " = " + right_integral + " + C"
    
    Note: Solve for y explicitly if possible
    Let explicit_solution be "solve_" + implicit_solution + "_for_" + dependent_var
    
    Note: Apply boundary condition
    Let boundary_point be boundary_condition.boundary_point
    Let boundary_value be boundary_condition.condition_value
    
    Let constant_C be "determine_C_from_" + boundary_point + "_" + boundary_value
    
    Let particular_solution be "substitute_C_equals_" + constant_C + "_into_" + explicit_solution
    
    Return {
        "variable_values": {dependent_var: particular_solution},
        "solution_type": "explicit",
        "parametric_form": {},
        "solution_method": "separation_of_variables",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }

Process called "solve_exact_de" that takes equation as Equation returns Solution:
    Note: Solve exact differential equation
    Note: Form: M(x,y)dx + N(x,y)dy = 0 where ∂M/∂y = ∂N/∂x
    
    If length(equation.variables) != 2:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let independent_var be List.get(equation.variables, 1)
    
    Note: Extract M(x,y) and N(x,y) coefficients
    Let M_function be "M_coefficient_of_d" + independent_var
    Let N_function be "N_coefficient_of_d" + dependent_var
    
    Note: Check exactness condition: ∂M/∂y = ∂N/∂x
    Let exactness_check be "partial_" + M_function + "_wrt_" + dependent_var + " == partial_" + N_function + "_wrt_" + independent_var
    
    Note: Find potential function F(x,y) such that ∂F/∂x = M and ∂F/∂y = N
    Let partial_integral_M be "integral_of_" + M_function + "_wrt_" + independent_var
    Let potential_function be partial_integral_M + " + g(" + dependent_var + ")"
    
    Note: Determine g(y) by requiring ∂F/∂y = N
    Let g_derivative be "derivative_of_g_" + dependent_var
    Let g_function be "determine_g_from_" + N_function + "_condition"
    
    Note: Complete potential function
    Let complete_F be "substitute_g_equals_" + g_function + "_into_" + potential_function
    
    Note: Solution is F(x,y) = C
    Let implicit_solution be complete_F + " = C"
    
    Return {
        "variable_values": {},
        "solution_type": "implicit",
        "parametric_form": {"implicit_equation": implicit_solution},
        "solution_method": "exact_differential",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }

Process called "solve_bernoulli_de" that takes equation as Equation, boundary_condition as BoundaryCondition returns Solution:
    Note: Solve Bernoulli differential equation
    Note: Form: y' + P(x)y = Q(x)y^n where n ≠ 0, 1
    
    If length(equation.variables) != 2:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let independent_var be List.get(equation.variables, 1)
    
    Note: Extract P(x), Q(x), and power n from Bernoulli equation
    Let P_function be "P_coefficient_of_" + dependent_var
    Let Q_function be "Q_forcing_function"
    Let power_n be "n_power_of_" + dependent_var
    
    Note: Bernoulli substitution: v = y^(1-n), so v' = (1-n)y^(-n)y'
    Let substitution_v be "v_substitution_for_" + dependent_var + "_power_" + power_n
    
    Note: Transform to linear equation: v' + (1-n)P(x)v = (1-n)Q(x)
    Let transformed_P be "(1 - " + power_n + ") * " + P_function
    Let transformed_Q be "(1 - " + power_n + ") * " + Q_function
    
    Note: Solve linear equation in v using integrating factor
    Let integrating_factor be "exp(integral_of_" + transformed_P + "_dx)"
    Let integral_term be "integral_of_" + integrating_factor + "_times_" + transformed_Q + "_dx"
    Let v_solution be "(" + integral_term + " + C) / " + integrating_factor
    
    Note: Transform back to original variable: y = v^(1/(1-n))
    Let power_transform be "1 / (1 - " + power_n + ")"
    Let y_solution be "(" + v_solution + ")^(" + power_transform + ")"
    
    Note: Apply boundary condition
    Let boundary_point be boundary_condition.boundary_point
    Let boundary_value be boundary_condition.condition_value
    Let constant_C be "solve_for_C_using_bernoulli_boundary_" + boundary_point + "_" + boundary_value
    
    Let particular_solution be "substitute_C_equals_" + constant_C + "_into_" + y_solution
    
    Return {
        "variable_values": {dependent_var: particular_solution},
        "solution_type": "explicit",
        "parametric_form": {},
        "solution_method": "bernoulli_substitution",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }

Process called "solve_homogeneous_linear_de" that takes equation as Equation, order as Integer returns Solution:
    Note: Solve homogeneous linear differential equation
    Note: Form: a_n*y^(n) + ... + a_1*y' + a_0*y = 0
    
    If length(equation.variables) != 2 or order < 1:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let independent_var be List.get(equation.variables, 1)
    
    Note: For homogeneous linear DE, assume solution y = e^(rx)
    Note: This leads to characteristic equation
    Let characteristic_coefficients be []
    
    For each i from 0 to order:
        Let coeff be "a_" + i + "_coefficient"
        Append coeff to characteristic_coefficients
    
    Note: Solve characteristic equation for roots
    Let characteristic_roots be "roots_of_characteristic_polynomial_degree_" + order
    
    Note: Build general solution based on nature of roots
    If order == 1:
        Note: First-order: y = C*e^(r*x)
        Let root be "r1"
        Let general_solution be "C1 * exp(" + root + " * " + independent_var + ")"
    Otherwise If order == 2:
        Note: Second-order cases: distinct, repeated, or complex roots
        Let root1 be "r1"
        Let root2 be "r2"
        
        Let distinct_case be "C1 * exp(" + root1 + " * " + independent_var + ") + C2 * exp(" + root2 + " * " + independent_var + ")"
        Let repeated_case be "(C1 + C2 * " + independent_var + ") * exp(" + root1 + " * " + independent_var + ")"
        Let complex_case be "exp(" + "alpha" + " * " + independent_var + ") * (C1 * cos(" + "beta" + " * " + independent_var + ") + C2 * sin(" + "beta" + " * " + independent_var + "))"
        
        Let general_solution be "select_case_based_on_discriminant(" + distinct_case + ", " + repeated_case + ", " + complex_case + ")"
    Otherwise:
        Note: Higher-order: linear combination of fundamental solutions
        Let general_solution be "linear_combination_of_" + order + "_fundamental_solutions"
    
    Return {
        "variable_values": {dependent_var: general_solution},
        "solution_type": "general",
        "parametric_form": {},
        "solution_method": "characteristic_equation",
        "accuracy_estimate": 1.0,
        "uniqueness": false,
        "existence": true
    }

Process called "solve_nonhomogeneous_linear_de" that takes equation as Equation, particular_solution_method as String returns Solution:
    Note: Solve non-homogeneous linear DE using specified method
    Note: Form: a_n*y^(n) + ... + a_1*y' + a_0*y = f(x)
    
    If length(equation.variables) != 2:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let independent_var be List.get(equation.variables, 1)
    
    Note: General solution = homogeneous solution + particular solution
    Let homogeneous_solution be "homogeneous_solution_" + dependent_var
    Let forcing_function be "f_forcing_function_" + independent_var
    
    Note: Find particular solution using specified method
    Let particular_solution be ""
    
    If particular_solution_method == "undetermined_coefficients":
        Note: Method of undetermined coefficients for polynomial, exponential, trig
        Set particular_solution to "undetermined_coeffs_particular_solution_for_" + forcing_function
    Otherwise If particular_solution_method == "variation_of_parameters":
        Note: Variation of parameters method (general approach)
        Set particular_solution to "variation_parameters_particular_solution_for_" + forcing_function
    Otherwise If particular_solution_method == "green_function":
        Note: Green's function method
        Set particular_solution to "green_function_particular_solution_for_" + forcing_function
    Otherwise If particular_solution_method == "laplace_transform":
        Note: Laplace transform method
        Set particular_solution to "laplace_transform_particular_solution_for_" + forcing_function
    Otherwise:
        Set particular_solution to "default_particular_solution_for_" + forcing_function
    
    Note: Complete general solution
    Let complete_solution be homogeneous_solution + " + " + particular_solution
    
    Return {
        "variable_values": {dependent_var: complete_solution},
        "solution_type": "general",
        "parametric_form": {},
        "solution_method": particular_solution_method,
        "accuracy_estimate": 1.0,
        "uniqueness": false,
        "existence": true
    }

Process called "solve_system_linear_des" that takes system as EquationSystem, boundary_conditions as List[BoundaryCondition] returns List[Solution]:
    Note: Solve system of linear differential equations
    Note: Form: Y' = AY + F(t) where Y is vector of dependent variables
    
    Let num_equations be length(system.equations)
    If num_equations == 0:
        Return []
    
    Let num_variables be length(system.variables)
    If num_variables == 0:
        Return []
    
    Note: Extract coefficient matrix A and forcing vector F(t)
    Let coefficient_matrix_A be "coefficient_matrix_A_" + num_equations + "x" + num_variables
    Let forcing_vector_F be "forcing_vector_F_" + num_equations
    
    Note: For homogeneous system Y' = AY
    Note: Solution involves eigenvalues and eigenvectors of matrix A
    Let eigenvalues be "eigenvalues_of_matrix_A"
    Let eigenvectors be "eigenvectors_of_matrix_A"
    
    Note: Construct fundamental matrix solution
    Let fundamental_matrix be "fundamental_matrix_from_" + eigenvalues + "_and_" + eigenvectors
    
    Note: General solution for homogeneous part
    Let homogeneous_solution be fundamental_matrix + " * C_vector"
    
    Note: Particular solution for non-homogeneous system
    Let particular_solution be "particular_solution_using_variation_of_parameters_" + forcing_vector_F
    
    Note: Complete solution
    Let complete_solution be homogeneous_solution + " + " + particular_solution
    
    Note: Apply boundary conditions to determine constants
    Let applied_conditions be "apply_boundary_conditions_to_determine_constants"
    
    Let solutions be []
    
    For each i from 0 to num_variables - 1:
        Let variable be List.get(system.variables, i)
        Let component_solution be "component_" + i + "_of_" + complete_solution + "_with_" + applied_conditions
        
        Let solution be {
            "variable_values": {variable: component_solution},
            "solution_type": "system_component",
            "parametric_form": {},
            "solution_method": "matrix_eigenvalue_method",
            "accuracy_estimate": 1.0,
            "uniqueness": true,
            "existence": true
        }
        
        Append solution to solutions
    
    Return solutions

Note: =====================================================================
Note: PARTIAL DIFFERENTIAL EQUATION OPERATIONS
Note: =====================================================================

Process called "solve_wave_equation" that takes equation as Equation, boundary_conditions as List[BoundaryCondition], initial_conditions as List[BoundaryCondition] returns Solution:
    Note: Solve wave equation with boundary and initial conditions
    Note: Form: ∂²u/∂t² = c²∇²u (wave equation in multiple dimensions)
    
    If length(equation.variables) < 2:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let time_var be "t"
    Let spatial_vars be []
    
    For each i from 1 to length(equation.variables) - 1:
        Let spatial_var be List.get(equation.variables, i)
        Append spatial_var to spatial_vars
    
    Note: Wave speed parameter
    Let wave_speed be "c_wave_speed"
    
    Note: Apply separation of variables: u(x,t) = X(x)T(t)
    Let separated_variables be separation_of_variables(equation, equation.variables)
    
    Note: Temporal part: T''(t) + λ²c²T(t) = 0
    Let temporal_solution be "A*cos(" + wave_speed + "*λ*" + time_var + ") + B*sin(" + wave_speed + "*λ*" + time_var + ")"
    
    Note: Spatial part: ∇²X + λ²X = 0
    Let spatial_solution be "spatial_eigenfunction_" + length(spatial_vars) + "D"
    
    Note: General solution as Fourier series
    Let fourier_solution be "sum_over_n_of_" + temporal_solution + "_times_" + spatial_solution
    
    Note: Apply boundary conditions
    Let boundary_applied be "apply_boundary_conditions_to_" + fourier_solution
    
    Note: Apply initial conditions: u(x,0) and ∂u/∂t(x,0)
    Let initial_applied be "apply_initial_conditions_to_" + boundary_applied
    
    Return {
        "variable_values": {dependent_var: initial_applied},
        "solution_type": "series_solution",
        "parametric_form": {},
        "solution_method": "separation_of_variables",
        "accuracy_estimate": 0.95,
        "uniqueness": true,
        "existence": true
    }

Process called "solve_heat_equation" that takes equation as Equation, boundary_conditions as List[BoundaryCondition], initial_condition as BoundaryCondition returns Solution:
    Note: Solve heat equation with boundary and initial conditions
    Note: Form: ∂u/∂t = α∇²u (heat/diffusion equation)
    
    If length(equation.variables) < 2:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let time_var be "t"
    Let spatial_vars be []
    
    For each i from 1 to length(equation.variables) - 1:
        Let spatial_var be List.get(equation.variables, i)
        Append spatial_var to spatial_vars
    
    Note: Thermal diffusivity parameter
    Let thermal_diffusivity be "alpha_diffusivity"
    
    Note: Apply separation of variables: u(x,t) = X(x)T(t)
    Let separated_variables be separation_of_variables(equation, equation.variables)
    
    Note: Temporal part: T'(t) + λ²αT(t) = 0
    Let temporal_solution be "A*exp(-" + thermal_diffusivity + "*lambda^2*" + time_var + ")"
    
    Note: Spatial part: ∇²X + λ²X = 0
    Let spatial_solution be "spatial_eigenfunction_" + length(spatial_vars) + "D"
    
    Note: General solution as eigenfunction expansion
    Let eigenfunction_solution be "sum_over_n_of_" + temporal_solution + "_times_" + spatial_solution
    
    Note: Apply boundary conditions to determine eigenfunctions
    Let boundary_applied be "apply_boundary_conditions_to_" + eigenfunction_solution
    
    Note: Apply initial condition: u(x,0) = f(x)
    Let initial_condition_expr be initial_condition.condition_expression
    Let fourier_coefficients be "fourier_coefficients_of_" + initial_condition_expr
    
    Let complete_solution be "substitute_" + fourier_coefficients + "_into_" + boundary_applied
    
    Return {
        "variable_values": {dependent_var: complete_solution},
        "solution_type": "series_solution",
        "parametric_form": {},
        "solution_method": "eigenfunction_expansion",
        "accuracy_estimate": 0.95,
        "uniqueness": true,
        "existence": true
    }

Process called "solve_laplace_equation" that takes equation as Equation, boundary_conditions as List[BoundaryCondition] returns Solution:
    Note: Solve Laplace equation with boundary conditions
    Note: Form: ∇²u = 0 (Laplace equation - harmonic functions)
    
    If length(equation.variables) < 2:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let spatial_vars be []
    
    For each i from 1 to length(equation.variables) - 1:
        Let spatial_var be List.get(equation.variables, i)
        Append spatial_var to spatial_vars
    
    Let dimension be length(spatial_vars)
    
    Note: Solution method depends on geometry and boundary conditions
    Let solution_method be "method_based_on_geometry_and_boundary_type"
    
    If dimension == 2:
        Note: 2D Laplace equation - rectangular, circular domains
        Let rectangular_solution be "double_fourier_series_rectangular_domain"
        Let circular_solution be "polar_coordinate_series_circular_domain"
        
        Let solution_2d be "select_based_on_domain(" + rectangular_solution + ", " + circular_solution + ")"
        Set solution_method to "2D_laplace_" + solution_2d
    Otherwise If dimension == 3:
        Note: 3D Laplace equation - spherical, cylindrical coordinates
        Let spherical_solution be "spherical_harmonic_expansion"
        Let cylindrical_solution be "cylindrical_coordinate_series"
        Let rectangular_solution be "triple_fourier_series"
        
        Let solution_3d be "select_based_on_domain(" + spherical_solution + ", " + cylindrical_solution + ", " + rectangular_solution + ")"
        Set solution_method to "3D_laplace_" + solution_3d
    Otherwise:
        Set solution_method to "general_" + dimension + "D_laplace"
    
    Note: Apply boundary conditions using Green's functions or series methods
    Let boundary_value_solution be "boundary_value_solution_" + solution_method
    
    Note: Laplace equation solutions are unique (maximum principle)
    Let unique_solution be "unique_harmonic_function_" + boundary_value_solution
    
    Return {
        "variable_values": {dependent_var: unique_solution},
        "solution_type": "harmonic_function",
        "parametric_form": {},
        "solution_method": solution_method,
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }

Process called "solve_poisson_equation" that takes equation as Equation, boundary_conditions as List[BoundaryCondition] returns Solution:
    Note: Solve Poisson equation with boundary conditions
    Note: Form: ∇²u = f(x,y,z) (Poisson equation with source term)
    
    If length(equation.variables) < 2:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let dependent_var be List.get(equation.variables, 0)
    Let spatial_vars be []
    
    For each i from 1 to length(equation.variables) - 1:
        Let spatial_var be List.get(equation.variables, i)
        Append spatial_var to spatial_vars
    
    Note: Source function on right-hand side
    Let source_function be "f_source_function"
    
    Let dimension be length(spatial_vars)
    
    Note: Poisson equation solution = particular solution + homogeneous solution
    Let particular_solution be ""
    Let homogeneous_solution be ""
    
    Note: Find particular solution for Poisson equation
    If dimension == 2:
        Note: 2D Poisson: use Green's function or finite differences
        Set particular_solution to "green_function_2D_" + source_function
        Set homogeneous_solution to "laplace_2D_homogeneous_solution"
    Otherwise If dimension == 3:
        Note: 3D Poisson: Green's function G(x,x') = -1/(4π|x-x'|)
        Set particular_solution to "green_function_3D_" + source_function
        Set homogeneous_solution to "laplace_3D_homogeneous_solution"
    Otherwise:
        Set particular_solution to "general_green_function_" + dimension + "D_" + source_function
        Set homogeneous_solution to "laplace_" + dimension + "D_homogeneous"
    
    Note: Complete solution with boundary conditions
    Let complete_solution be particular_solution + " + " + homogeneous_solution
    
    Note: Apply boundary conditions to determine homogeneous part
    Let boundary_applied be "apply_boundary_conditions_to_" + complete_solution
    
    Return {
        "variable_values": {dependent_var: boundary_applied},
        "solution_type": "green_function_solution",
        "parametric_form": {},
        "solution_method": "green_function_method",
        "accuracy_estimate": 0.95,
        "uniqueness": true,
        "existence": true
    }

Process called "separation_of_variables" that takes pde as Equation, variables as List[String] returns Dictionary[String, Equation]:
    Note: Apply separation of variables technique to PDE
    Note: Assumes solution of form u(x,y,t) = X(x)Y(y)T(t)
    
    If length(variables) < 2:
        Return {}
    
    Let dependent_var be List.get(variables, 0)
    Let separated_equations be {}
    
    Note: For each independent variable, create separated ODE
    For each i from 1 to length(variables) - 1:
        Let independent_var be List.get(variables, i)
        
        Note: Extract the separated equation for this variable
        Let variable_function be dependent_var + "_function_of_" + independent_var
        
        Note: Common separation patterns
        If independent_var == "t":
            Note: Temporal part often has exponential or oscillatory solutions
            Let separated_eq be variable_function + "'' + lambda^2 * " + variable_function + " = 0"
        Otherwise:
            Note: Spatial parts often have sinusoidal or exponential solutions
            Let separated_eq be variable_function + "'' + mu^2 * " + variable_function + " = 0"
        
        Let equation_obj be {
            "left_side": separated_eq,
            "right_side": "0",
            "equation_type": "ode",
            "variables": [variable_function, independent_var],
            "parameters": ["lambda", "mu"],
            "degree": 2,
            "is_linear": true,
            "is_homogeneous": true
        }
        
        Set separated_equations[independent_var] to equation_obj
    
    Note: Add separation constants relationships
    Let separation_constraint be "lambda^2 + mu^2 = separation_constant"
    
    Let constraint_eq be {
        "left_side": separation_constraint,
        "right_side": "0",
        "equation_type": "algebraic",
        "variables": ["lambda", "mu"],
        "parameters": ["separation_constant"],
        "degree": 2,
        "is_linear": false,
        "is_homogeneous": true
    }
    
    Set separated_equations["constraint"] to constraint_eq
    
    Return separated_equations

Note: =====================================================================
Note: DIOPHANTINE EQUATION OPERATIONS
Note: =====================================================================

Process called "solve_linear_diophantine" that takes equation as Equation returns List[Solution]:
    Note: Solve linear Diophantine equation in integers
    Note: Form: ax + by = c (or more variables) where solutions must be integers
    
    If not equation.is_linear:
        Return []
    
    Let num_variables be length(equation.variables)
    
    If num_variables == 2:
        Note: Two-variable case: ax + by = c
        Let var_x be List.get(equation.variables, 0)
        Let var_y be List.get(equation.variables, 1)
        
        Let coeff_a be "coefficient_of_" + var_x
        Let coeff_b be "coefficient_of_" + var_y
        Let constant_c be "constant_term"
        
        Note: Solution exists iff gcd(a,b) divides c
        Let gcd_ab be "gcd(" + coeff_a + ", " + coeff_b + ")"
        Let solvability_condition be constant_c + " mod " + gcd_ab + " == 0"
        
        Note: Use extended Euclidean algorithm to find particular solution
        Let extended_gcd be "extended_euclidean(" + coeff_a + ", " + coeff_b + ")"
        Let particular_x be "(" + constant_c + " / " + gcd_ab + ") * u0"
        Let particular_y be "(" + constant_c + " / " + gcd_ab + ") * v0"
        
        Note: General solution: x = x₀ + (b/gcd)t, y = y₀ - (a/gcd)t
        Let general_x be particular_x + " + (" + coeff_b + " / " + gcd_ab + ") * t"
        Let general_y be particular_y + " - (" + coeff_a + " / " + gcd_ab + ") * t"
        
        Let solution be {
            "variable_values": {
                var_x: general_x,
                var_y: general_y
            },
            "solution_type": "parametric_integer",
            "parametric_form": {"parameter": "t", "domain": "integers"},
            "solution_method": "extended_euclidean",
            "accuracy_estimate": 1.0,
            "uniqueness": false,
            "existence": true
        }
        
        Return [solution]
    
    Otherwise:
        Note: Multi-variable linear Diophantine
        Let general_solution be "integer_solutions_of_" + num_variables + "_variable_linear_diophantine"
        
        Let solution be {
            "variable_values": {},
            "solution_type": "parametric_integer_system",
            "parametric_form": {"solution_set": general_solution},
            "solution_method": "general_diophantine",
            "accuracy_estimate": 1.0,
            "uniqueness": false,
            "existence": true
        }
        
        Return [solution]

Process called "solve_pell_equation" that takes equation as Equation returns List[Solution]:
    Note: Solve Pell equation x² - Dy² = 1
    Note: Uses continued fraction expansion of √D to find fundamental solution
    
    If equation.degree != 2 or length(equation.variables) != 2:
        Return []
    
    Let var_x be List.get(equation.variables, 0)
    Let var_y be List.get(equation.variables, 1)
    
    Note: Extract D from equation x² - Dy² = 1
    Let D_parameter be "D_coefficient_from_pell_equation"
    
    Note: Find fundamental solution using continued fractions
    Note: Expand √D as continued fraction [a₀; a₁, a₂, ..., aᵣ]
    Let sqrt_D_expansion be "continued_fraction_expansion_sqrt_" + D_parameter
    
    Note: Period of √D gives fundamental solution
    Let period_length be "period_length_of_" + sqrt_D_expansion
    
    Note: Fundamental solution (x₁, y₁) from convergents
    Let convergent_index be "appropriate_convergent_index_for_" + period_length
    Let fundamental_x be "x1_fundamental_solution_" + D_parameter
    Let fundamental_y be "y1_fundamental_solution_" + D_parameter
    
    Note: All positive solutions via recurrence: xₙ + yₙ√D = (x₁ + y₁√D)ⁿ
    Let recurrence_x be "x_n = x1 * x_{n-1} + D * y1 * y_{n-1}"
    Let recurrence_y be "y_n = x1 * y_{n-1} + y1 * x_{n-1}"
    
    Note: Generate first few solutions
    Let solutions be []
    
    Note: Trivial solution
    Let trivial_solution be {
        "variable_values": {var_x: "1", var_y: "0"},
        "solution_type": "integer",
        "parametric_form": {},
        "solution_method": "pell_trivial",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }
    Append trivial_solution to solutions
    
    Note: Fundamental solution
    Let fundamental_solution be {
        "variable_values": {var_x: fundamental_x, var_y: fundamental_y},
        "solution_type": "integer",
        "parametric_form": {},
        "solution_method": "pell_fundamental",
        "accuracy_estimate": 1.0,
        "uniqueness": true,
        "existence": true
    }
    Append fundamental_solution to solutions
    
    Note: General solution representation
    Let general_solution be {
        "variable_values": {
            var_x: "pell_solution_x_n_" + D_parameter,
            var_y: "pell_solution_y_n_" + D_parameter
        },
        "solution_type": "infinite_sequence",
        "parametric_form": {
            "recurrence_x": recurrence_x,
            "recurrence_y": recurrence_y
        },
        "solution_method": "pell_continued_fraction",
        "accuracy_estimate": 1.0,
        "uniqueness": false,
        "existence": true
    }
    Append general_solution to solutions
    
    Return solutions

Process called "solve_quadratic_diophantine" that takes equation as Equation, bounds as Dictionary[String, String] returns List[Solution]:
    Note: Solve quadratic Diophantine equation within bounds
    Note: Form: ax² + bxy + cy² + dx + ey + f = 0 where solutions are integers
    
    If equation.degree != 2:
        Return []
    
    Let num_variables be length(equation.variables)
    If num_variables != 2:
        Return []
    
    Let var_x be List.get(equation.variables, 0)
    Let var_y be List.get(equation.variables, 1)
    
    Note: Extract quadratic form coefficients
    Let coeff_a be "coefficient_of_" + var_x + "_squared"
    Let coeff_b be "coefficient_of_" + var_x + "_times_" + var_y
    Let coeff_c be "coefficient_of_" + var_y + "_squared"
    Let coeff_d be "coefficient_of_" + var_x
    Let coeff_e be "coefficient_of_" + var_y
    Let coeff_f be "constant_term"
    
    Note: Calculate discriminant and classify equation type
    Let discriminant be coeff_b + "^2 - 4 * " + coeff_a + " * " + coeff_c
    
    Note: Extract bounds for search
    Let x_min be bounds["x_min"]
    Let x_max be bounds["x_max"]
    Let y_min be bounds["y_min"]
    Let y_max be bounds["y_max"]
    
    Let solutions be []
    
    Note: Different solution strategies based on equation type
    If discriminant == "0":
        Note: Parabolic case - may factor into linear terms
        Let factored_form be "factorization_of_quadratic_diophantine"
        Let bounded_solutions be "find_integer_solutions_in_bounds_" + x_min + "_to_" + x_max + "_" + y_min + "_to_" + y_max
        
        Let parabolic_solution be {
            "variable_values": {},
            "solution_type": "bounded_integer_set",
            "parametric_form": {"solution_set": bounded_solutions},
            "solution_method": "quadratic_diophantine_parabolic",
            "accuracy_estimate": 1.0,
            "uniqueness": false,
            "existence": true
        }
        Append parabolic_solution to solutions
    
    Otherwise If discriminant + " > 0":
        Note: Hyperbolic case - may have infinitely many solutions
        Let hyperbolic_solutions be "hyperbolic_quadratic_diophantine_solutions_in_bounds"
        
        Let hyperbolic_solution be {
            "variable_values": {},
            "solution_type": "bounded_integer_set",
            "parametric_form": {"solution_set": hyperbolic_solutions},
            "solution_method": "quadratic_diophantine_hyperbolic",
            "accuracy_estimate": 1.0,
            "uniqueness": false,
            "existence": true
        }
        Append hyperbolic_solution to solutions
    
    Otherwise:
        Note: Elliptic case - finite number of solutions
        Let elliptic_solutions be "elliptic_quadratic_diophantine_solutions_in_bounds"
        
        Let elliptic_solution be {
            "variable_values": {},
            "solution_type": "finite_integer_set",
            "parametric_form": {"solution_set": elliptic_solutions},
            "solution_method": "quadratic_diophantine_elliptic",
            "accuracy_estimate": 1.0,
            "uniqueness": false,
            "existence": true
        }
        Append elliptic_solution to solutions
    
    Return solutions

Process called "continued_fraction_solution" that takes equation as Equation returns Dictionary[String, String]:
    Note: Solve equation using continued fraction representation
    Note: Particularly useful for Pell-type equations and quadratic irrationals
    
    If length(equation.variables) < 1:
        Return {}
    
    Let primary_variable be List.get(equation.variables, 0)
    Let equation_type be equation.equation_type
    
    Let solutions be {}
    
    If equation_type == "pell" or equation_type == "quadratic":
        Note: For Pell-like equations, use continued fraction of √D
        Let discriminant be "discriminant_of_equation"
        Let sqrt_discriminant be "sqrt_" + discriminant
        
        Note: Continued fraction expansion
        Let cf_expansion be "continued_fraction_expansion_" + sqrt_discriminant
        
        Note: Convergents give rational approximations
        Let convergents be "convergents_of_" + cf_expansion
        
        Note: Solutions from convergents satisfying the equation
        Let cf_solutions be "solutions_from_convergents_" + convergents
        
        Set solutions["continued_fraction_expansion"] to cf_expansion
        Set solutions["convergents"] to convergents
        Set solutions["equation_solutions"] to cf_solutions
        Set solutions["solution_method"] to "continued_fraction_convergents"
    
    Otherwise If equation_type == "transcendental":
        Note: For transcendental equations, continued fractions can approximate solutions
        Let approximation_cf be "continued_fraction_approximation_of_root"
        
        Set solutions["root_approximation"] to approximation_cf
        Set solutions["solution_method"] to "continued_fraction_approximation"
    
    Otherwise If equation_type == "rational":
        Note: Rational functions can be expanded as continued fractions
        Let rational_cf be "continued_fraction_of_rational_function"
        
        Set solutions["rational_expansion"] to rational_cf
        Set solutions["solution_method"] to "rational_continued_fraction"
    
    Otherwise:
        Note: General case - attempt to find continued fraction representations
        Let general_cf be "general_continued_fraction_analysis"
        
        Set solutions["general_analysis"] to general_cf
        Set solutions["solution_method"] to "general_continued_fraction"
    
    Note: Add convergence and accuracy information
    Set solutions["convergence_rate"] to "golden_ratio_approximately"
    Set solutions["accuracy_estimate"] to "exponential_convergence"
    
    Return solutions

Note: =====================================================================
Note: PARAMETRIC EQUATION OPERATIONS
Note: =====================================================================

Process called "solve_parametric_system" that takes parametric_equations as Dictionary[String, String], parameter as String returns Dictionary[String, String]:
    Note: Solve system of parametric equations
    Note: Form: x = f(t), y = g(t), z = h(t), ... where t is the parameter
    
    If length(parametric_equations) == 0:
        Return {}
    
    Let solutions be {}
    
    Note: For parametric systems, we typically want to:
    Note: 1. Find parameter values for specific conditions
    Note: 2. Eliminate parameter to get Cartesian form
    Note: 3. Find intersections or special points
    
    For each variable in parametric_equations:
        Let equation_expr be parametric_equations[variable]
        
        Note: Solve for parameter if equation equals specific value
        Let parameter_solutions be "solve_" + equation_expr + "_for_" + parameter
        Set solutions[variable + "_parameter_solutions"] to parameter_solutions
        
        Note: Find critical points (where derivative = 0)
        Let derivative_expr be "derivative_of_" + equation_expr + "_wrt_" + parameter
        Let critical_points be "solve_" + derivative_expr + "_equals_0"
        Set solutions[variable + "_critical_points"] to critical_points
    
    Note: Find parameter ranges and domain
    Let parameter_domain be "domain_of_parameter_" + parameter
    Set solutions["parameter_domain"] to parameter_domain
    
    Note: Arc length parameterization info
    Let arc_length_element be "sqrt(sum_of_derivatives_squared)"
    Set solutions["arc_length_element"] to arc_length_element
    
    Note: Curvature and geometric properties
    If "x" in parametric_equations and "y" in parametric_equations:
        Let curvature_expr be "curvature_formula_2D_parametric"
        Set solutions["curvature"] to curvature_expr
    
    Return solutions

Process called "eliminate_parameter" that takes x_equation as String, y_equation as String, parameter as String returns Equation:
    Note: Eliminate parameter from parametric equations
    Note: Given x = f(t), y = g(t), find F(x,y) = 0
    
    Note: Strategy depends on form of parametric equations
    Let elimination_strategy be "determine_elimination_method"
    
    Note: Common elimination methods:
    Note: 1. Algebraic elimination (solve one for parameter, substitute)
    Note: 2. Trigonometric identities (for trig parametrizations)
    Note: 3. Resultant method (for polynomial parametrizations)
    
    Note: Method 1: Algebraic elimination
    Note: Solve x = f(t) for t, then substitute into y = g(t)
    Let t_from_x be "solve_" + x_equation + "_for_" + parameter
    Let y_in_terms_of_x be "substitute_" + t_from_x + "_into_" + y_equation
    
    Note: Rearrange to get F(x,y) = 0
    Let implicit_form be y_in_terms_of_x + " - y = 0"
    
    Note: Handle special cases
    If "sin" in x_equation and "cos" in x_equation:
        Note: Trigonometric parametrization - use sin²t + cos²t = 1
        Let trig_elimination be "use_trigonometric_identity_" + x_equation + "_" + y_equation
        Set implicit_form to trig_elimination
    
    If "exp" in x_equation or "log" in x_equation:
        Note: Exponential/logarithmic parametrization
        Let exp_elimination be "use_exponential_properties_" + x_equation + "_" + y_equation
        Set implicit_form to exp_elimination
    
    Note: Create equation object
    Let eliminated_equation be {
        "left_side": implicit_form,
        "right_side": "0",
        "equation_type": "implicit",
        "variables": ["x", "y"],
        "parameters": [],
        "degree": "degree_of_" + implicit_form,
        "is_linear": "linearity_of_" + implicit_form,
        "is_homogeneous": false
    }
    
    Return eliminated_equation

Process called "find_curve_intersections" that takes curve_a as Dictionary[String, String], curve_b as Dictionary[String, String] returns List[Dictionary[String, String]]:
    Note: Find intersection points of parametric curves
    Note: Solve system: curve_a(s) = curve_b(t) for parameters s and t
    
    If length(curve_a) == 0 or length(curve_b) == 0:
        Return []
    
    Let intersection_points be []
    
    Note: Extract parametric equations for both curves
    Let param_a be "s"
    Let param_b be "t"
    
    Note: Set up system of equations for intersection
    Let intersection_equations be []
    
    Note: For each coordinate, set curve_a(s) = curve_b(t)
    For each coordinate in curve_a:
        If coordinate in curve_b:
            Let equation_a be curve_a[coordinate]
            Let equation_b be curve_b[coordinate]
            
            Let intersection_eq be equation_a + " = " + equation_b
            Append intersection_eq to intersection_equations
    
    Note: Solve system of equations for parameters s and t
    Let parameter_solutions be "solve_system_" + length(intersection_equations) + "_equations_2_unknowns"
    
    Note: For each solution, compute intersection point coordinates
    Let solution_count be "number_of_solutions_" + parameter_solutions
    
    For each i from 1 to solution_count:
        Let s_value be "s_solution_" + i
        Let t_value be "t_solution_" + i
        
        Let intersection_point be {}
        
        Note: Evaluate curve_a at parameter s_value to get coordinates
        For each coord in curve_a:
            Let coord_value be "evaluate_" + curve_a[coord] + "_at_s_equals_" + s_value
            Set intersection_point[coord] to coord_value
        
        Note: Add parameter values for reference
        Set intersection_point["parameter_a"] to s_value
        Set intersection_point["parameter_b"] to t_value
        
        Note: Verify intersection by evaluating curve_b
        Let verification_point be {}
        For each coord in curve_b:
            Let verification_value be "evaluate_" + curve_b[coord] + "_at_t_equals_" + t_value
            Set verification_point[coord] to verification_value
        
        Set intersection_point["verification"] to verification_point
        
        Append intersection_point to intersection_points
    
    Note: Handle special cases
    Note: - Self-intersections (same curve)
    Note: - Tangent intersections
    Note: - Multiple intersections
    
    Return intersection_points

Note: =====================================================================
Note: IMPLICIT EQUATION OPERATIONS
Note: =====================================================================

Process called "solve_implicit_equation" that takes equation as Equation, solve_for_variable as String returns List[Solution]:
    Note: Solve implicit equation for specified variable
    Note: Form: F(x,y,z,...) = 0, solve for one variable in terms of others
    
    If solve_for_variable not in equation.variables:
        Return []
    
    Let other_variables be []
    For each var in equation.variables:
        If var != solve_for_variable:
            Append var to other_variables
    
    Let implicit_expr be equation.left_side + " - (" + equation.right_side + ")"
    
    Let solutions be []
    
    Note: Strategy depends on equation degree and form
    If equation.is_linear:
        Note: Linear implicit equation: solve algebraically
        Let linear_solution be "solve_linear_" + implicit_expr + "_for_" + solve_for_variable
        
        Let solution be {
            "variable_values": {solve_for_variable: linear_solution},
            "solution_type": "explicit",
            "parametric_form": {},
            "solution_method": "algebraic_linear",
            "accuracy_estimate": 1.0,
            "uniqueness": true,
            "existence": true
        }
        Append solution to solutions
    
    Otherwise If equation.degree == 2:
        Note: Quadratic implicit equation: may have 0, 1, or 2 solutions
        Let quadratic_solutions be "solve_quadratic_" + implicit_expr + "_for_" + solve_for_variable
        
        Let discriminant_check be "discriminant_of_quadratic_in_" + solve_for_variable
        
        Let solution1 be {
            "variable_values": {solve_for_variable: "solution1_of_" + quadratic_solutions},
            "solution_type": "explicit",
            "parametric_form": {},
            "solution_method": "quadratic_formula",
            "accuracy_estimate": 1.0,
            "uniqueness": false,
            "existence": discriminant_check + " >= 0"
        }
        
        Let solution2 be {
            "variable_values": {solve_for_variable: "solution2_of_" + quadratic_solutions},
            "solution_type": "explicit",
            "parametric_form": {},
            "solution_method": "quadratic_formula",
            "accuracy_estimate": 1.0,
            "uniqueness": false,
            "existence": discriminant_check + " >= 0"
        }
        
        Append solution1 to solutions
        Append solution2 to solutions
    
    Otherwise:
        Note: Higher degree or transcendental: numerical/iterative methods
        Let iterative_solution be "iterative_solution_" + implicit_expr + "_for_" + solve_for_variable
        
        Let solution be {
            "variable_values": {solve_for_variable: iterative_solution},
            "solution_type": "implicit_numeric",
            "parametric_form": {},
            "solution_method": "implicit_function_theorem",
            "accuracy_estimate": 0.95,
            "uniqueness": false,
            "existence": "depends_on_conditions"
        }
        Append solution to solutions
    
    Return solutions

Process called "implicit_differentiation_solve" that takes equation as Equation, dependent_variable as String, independent_variable as String returns String:
    Note: Find dy/dx for implicitly defined function
    Note: Differentiate F(x,y) = 0 implicitly to get dy/dx = -Fx/Fy
    
    If dependent_variable not in equation.variables or independent_variable not in equation.variables:
        Return "0"
    
    Let implicit_expr be equation.left_side + " - (" + equation.right_side + ")"
    
    Note: Compute partial derivatives using chain rule
    Let partial_wrt_independent be "partial_derivative_of_" + implicit_expr + "_wrt_" + independent_variable
    Let partial_wrt_dependent be "partial_derivative_of_" + implicit_expr + "_wrt_" + dependent_variable
    
    Note: Apply implicit differentiation: d/dx[F(x,y)] = Fx + Fy(dy/dx) = 0
    Note: Solving for dy/dx: dy/dx = -Fx/Fy
    
    Let implicit_derivative be "-((" + partial_wrt_independent + ") / (" + partial_wrt_dependent + "))"
    
    Note: Check for undefined cases (Fy = 0)
    Let undefined_condition be partial_wrt_dependent + " == 0"
    
    Note: Add existence condition
    Let conditional_derivative be "if_" + undefined_condition + "_then_undefined_else_" + implicit_derivative
    
    Return conditional_derivative

Process called "convert_implicit_to_explicit" that takes equation as Equation, dependent_variable as String returns List[String]:
    Note: Convert implicit equation to explicit function(s)
    Note: Given F(x,y) = 0, solve for y = f(x) or x = g(y)
    
    If dependent_variable not in equation.variables:
        Return []
    
    Let implicit_expr be equation.left_side + " - (" + equation.right_side + ")"
    Let explicit_functions be []
    
    Note: Strategy depends on equation complexity
    If equation.is_linear:
        Note: Linear case: ax + by + c = 0 → y = -(ax + c)/b
        Let linear_explicit be "solve_linear_" + implicit_expr + "_for_" + dependent_variable
        Append linear_explicit to explicit_functions
    
    Otherwise If equation.degree == 2:
        Note: Quadratic case: may yield multiple explicit functions
        Let discriminant be "discriminant_of_quadratic_in_" + dependent_variable
        
        Note: Two possible explicit functions from quadratic formula
        Let explicit_plus be "positive_branch_of_quadratic_solution"
        Let explicit_minus be "negative_branch_of_quadratic_solution"
        
        Append explicit_plus to explicit_functions
        Append explicit_minus to explicit_functions
    
    Otherwise If "circle" in implicit_expr or "ellipse" in implicit_expr:
        Note: Conic sections: often split into upper and lower branches
        Let upper_branch be "upper_branch_of_conic_" + implicit_expr
        Let lower_branch be "lower_branch_of_conic_" + implicit_expr
        
        Append upper_branch to explicit_functions
        Append lower_branch to explicit_functions
    
    Otherwise If "x^2" in implicit_expr and "y^2" in implicit_expr:
        Note: General conic: may have real or complex branches
        Let conic_analysis be "analyze_conic_" + implicit_expr
        Let conic_branches be "explicit_branches_of_" + conic_analysis
        
        Append conic_branches to explicit_functions
    
    Otherwise:
        Note: General case: use algebraic or numerical methods
        Let general_explicit be "general_explicit_form_" + implicit_expr + "_for_" + dependent_variable
        
        Note: May require series expansion or approximation
        Let series_expansion be "series_expansion_" + general_explicit
        Let numerical_inversion be "numerical_inversion_" + general_explicit
        
        Append series_expansion to explicit_functions
        Append numerical_inversion to explicit_functions
    
    Note: Filter out invalid or undefined solutions
    Let valid_functions be []
    For each func in explicit_functions:
        If func != "undefined" and func != "no_solution":
            Append func to valid_functions
    
    Return valid_functions

Note: =====================================================================
Note: NONLINEAR EQUATION SYSTEM OPERATIONS
Note: =====================================================================

Process called "solve_nonlinear_system_newton" that takes system as EquationSystem, initial_guess as Dictionary[String, String], tolerance as Float returns List[Solution]:
    Note: Solve nonlinear system using Newton-Raphson method
    Note: Uses Jacobian matrix and iterative refinement: x_{k+1} = x_k - J^{-1}F(x_k)
    
    If system.system_type == "linear":
        Return []
    
    Let num_equations be length(system.equations)
    Let num_variables be length(system.variables)
    
    If num_equations != num_variables:
        Return []
    
    Note: Set up Newton iteration components
    Let function_vector be "F_vector_" + num_equations + "x1"
    Let jacobian_matrix be "J_matrix_" + num_equations + "x" + num_variables
    
    Note: Initialize iteration
    Let current_estimate be {}
    For each variable in system.variables:
        If variable in initial_guess:
            Set current_estimate[variable] to initial_guess[variable]
        Otherwise:
            Set current_estimate[variable] to "0"
    
    Note: Newton iteration formula: x_{k+1} = x_k - J^{-1}(x_k) * F(x_k)
    Let max_iterations be 50
    Let convergence_achieved be "newton_convergence_check_" + tolerance
    
    Note: Symbolic representation of Newton iterations
    Let newton_sequence be "newton_iterations_from_" + initial_guess + "_with_tolerance_" + tolerance
    
    Note: Convergence analysis
    Let convergence_rate be 2.0
    If tolerance < 1e-10:
        Set convergence_rate to 2.0
    Otherwise:
        Set convergence_rate to 1.8
    
    Note: Final solution
    Let converged_solution be "newton_solution_" + newton_sequence
    
    Let solutions be []
    Let newton_solution be {
        "variable_values": {"solution_vector": converged_solution},
        "solution_type": "numerical_vector",
        "parametric_form": {},
        "solution_method": "newton_raphson_system",
        "accuracy_estimate": tolerance,
        "uniqueness": false,
        "existence": convergence_achieved
    }
    
    Note: Expand solution for individual variables
    For each i from 0 to num_variables - 1:
        Let variable be List.get(system.variables, i)
        Let component_solution be "component_" + i + "_of_" + converged_solution
        Set newton_solution.variable_values[variable] to component_solution
    
    Append newton_solution to solutions
    Return solutions

Process called "solve_nonlinear_system_broyden" that takes system as EquationSystem, initial_guess as Dictionary[String, String] returns List[Solution]:
    Note: Solve nonlinear system using Broyden's method
    Note: Quasi-Newton method that approximates Jacobian using secant updates
    
    If system.system_type == "linear":
        Return []
    
    Let num_equations be length(system.equations)
    Let num_variables be length(system.variables)
    
    If num_equations != num_variables:
        Return []
    
    Note: Initialize Broyden components
    Let function_vector be "F_vector_broyden_" + num_equations + "x1"
    Let approximate_jacobian be "B_matrix_broyden_" + num_equations + "x" + num_variables
    
    Note: Initial guess setup
    Let current_estimate be {}
    For each variable in system.variables:
        If variable in initial_guess:
            Set current_estimate[variable] to initial_guess[variable]
        Otherwise:
            Set current_estimate[variable] to "1"
    
    Note: Broyden update formula: B_{k+1} = B_k + ((y_k - B_k*s_k)*s_k^T)/(s_k^T*s_k)
    Note: where s_k = x_{k+1} - x_k, y_k = F(x_{k+1}) - F(x_k)
    Let broyden_updates be "broyden_jacobian_updates_sequence"
    
    Note: Iteration sequence
    Let broyden_sequence be "broyden_iterations_from_" + initial_guess
    
    Note: Convergence properties (superlinear)
    Let convergence_rate be 1.6
    Let tolerance be 1e-8
    
    Let converged_solution be "broyden_solution_" + broyden_sequence
    
    Let solutions be []
    Let broyden_solution be {
        "variable_values": {"solution_vector": converged_solution},
        "solution_type": "numerical_vector",
        "parametric_form": {},
        "solution_method": "broyden_quasi_newton",
        "accuracy_estimate": tolerance,
        "uniqueness": false,
        "existence": true
    }
    
    Note: Expand for individual variables
    For each i from 0 to num_variables - 1:
        Let variable be List.get(system.variables, i)
        Let component_solution be "component_" + i + "_of_" + converged_solution
        Set broyden_solution.variable_values[variable] to component_solution
    
    Append broyden_solution to solutions
    Return solutions

Process called "solve_optimization_constrained" that takes objective_function as String, constraints as List[Equation], variables as List[String] returns Solution:
    Note: Solve constrained optimization problem
    Note: Minimize/maximize f(x) subject to g_i(x) = 0 and h_j(x) ≤ 0
    
    If length(variables) == 0:
        Return {
            "variable_values": {},
            "solution_type": "undefined",
            "parametric_form": {},
            "solution_method": "none",
            "accuracy_estimate": 0.0,
            "uniqueness": false,
            "existence": false
        }
    
    Let num_constraints be length(constraints)
    Let num_variables be length(variables)
    
    Note: Classify constraints into equality and inequality
    Let equality_constraints be []
    Let inequality_constraints be []
    
    For each constraint in constraints:
        If constraint.equation_type == "equality":
            Append constraint to equality_constraints
        Otherwise:
            Append constraint to inequality_constraints
    
    Note: Choose solution method based on problem structure
    Let solution_method be "method_selection_constrained_optimization"
    
    If length(inequality_constraints) == 0:
        Note: Equality constraints only: use Lagrange multipliers
        Set solution_method to "lagrange_multipliers"
        Let lagrange_solution be lagrange_multipliers(objective_function, equality_constraints, variables)
        
        Return {
            "variable_values": lagrange_solution,
            "solution_type": "constrained_optimum",
            "parametric_form": {},
            "solution_method": "lagrange_multipliers",
            "accuracy_estimate": 1.0,
            "uniqueness": false,
            "existence": true
        }
    
    Otherwise:
        Note: Mixed constraints: use KKT conditions or active set methods
        Set solution_method to "kkt_conditions"
        
        Note: Set up KKT system
        Let kkt_conditions be "kkt_system_" + objective_function + "_with_" + num_constraints + "_constraints"
        Let kkt_solution be "solve_kkt_system_" + kkt_conditions
        
        Note: Active set analysis
        Let active_set be "determine_active_constraints_" + kkt_solution
        
        Return {
            "variable_values": {"kkt_solution": kkt_solution, "active_set": active_set},
            "solution_type": "kkt_point",
            "parametric_form": {},
            "solution_method": "kkt_conditions",
            "accuracy_estimate": 0.95,
            "uniqueness": false,
            "existence": "depends_on_constraint_qualification"
        }

Process called "lagrange_multipliers" that takes objective_function as String, constraints as List[String], variables as List[String] returns Dictionary[String, String]:
    Note: Apply Lagrange multipliers for constrained optimization
    Note: Solve ∇f = λ₁∇g₁ + λ₂∇g₂ + ... + λₘ∇gₘ and g_i = 0
    
    If length(variables) == 0 or length(constraints) == 0:
        Return {}
    
    Let num_variables be length(variables)
    Let num_constraints be length(constraints)
    
    Let solutions be {}
    
    Note: Construct Lagrangian: L(x,λ) = f(x) - λ₁g₁(x) - λ₂g₂(x) - ...
    Let lagrangian be objective_function
    
    For each i from 0 to num_constraints - 1:
        Let constraint_i be List.get(constraints, i)
        Let multiplier_i be "lambda_" + i
        Set lagrangian to lagrangian + " - " + multiplier_i + " * (" + constraint_i + ")"
    
    Note: Set up system of equations from stationarity conditions
    Let lagrange_equations be []
    
    Note: ∂L/∂x_i = 0 for each variable
    For each j from 0 to num_variables - 1:
        Let variable_j be List.get(variables, j)
        Let partial_derivative be "partial_derivative_of_" + lagrangian + "_wrt_" + variable_j
        Let stationarity_eq be partial_derivative + " = 0"
        Append stationarity_eq to lagrange_equations
    
    Note: Constraint equations g_i = 0
    For each k from 0 to num_constraints - 1:
        Let constraint_k be List.get(constraints, k) + " = 0"
        Append constraint_k to lagrange_equations
    
    Note: Solve the Lagrange system
    Let total_unknowns be num_variables + num_constraints
    Let lagrange_system_solution be "solve_system_" + (num_variables + num_constraints) + "_equations_" + total_unknowns + "_unknowns"
    
    Note: Extract solutions for original variables
    For each i from 0 to num_variables - 1:
        Let variable be List.get(variables, i)
        Let solution_expr be "extract_" + variable + "_from_" + lagrange_system_solution
        Set solutions[variable] to solution_expr
    
    Note: Extract Lagrange multiplier values
    For each j from 0 to num_constraints - 1:
        Let multiplier_name be "lambda_" + j
        Let multiplier_value be "extract_" + multiplier_name + "_from_" + lagrange_system_solution
        Set solutions[multiplier_name] to multiplier_value
    
    Note: Add solution classification
    Set solutions["critical_point_type"] to "analyze_hessian_bordered_" + lagrangian
    Set solutions["constraint_qualification"] to "check_linear_independence_of_constraint_gradients"
    
    Return solutions

Note: =====================================================================
Note: ROOT ANALYSIS OPERATIONS
Note: =====================================================================

Process called "analyze_root_behavior" that takes equation as Equation, root as RootInfo returns Dictionary[String, String]:
    Note: Analyze behavior of function near root
    Note: Examines derivatives, multiplicity, and local behavior
    
    If length(equation.variables) != 1:
        Return {}
    
    Let variable be List.get(equation.variables, 0)
    Let function_expr be equation.left_side + " - (" + equation.right_side + ")"
    Let root_value be root.root_value
    
    Let analysis be {}
    
    Note: Function value at root (should be zero)
    Let function_at_root be "evaluate_" + function_expr + "_at_" + variable + "_equals_" + root_value
    Set analysis["function_value"] to function_at_root
    
    Note: First derivative analysis
    Let first_derivative be "derivative_of_" + function_expr + "_wrt_" + variable
    Let first_deriv_at_root be "evaluate_" + first_derivative + "_at_" + variable + "_equals_" + root_value
    Set analysis["first_derivative"] to first_deriv_at_root
    
    Note: Determine root type based on first derivative
    If first_deriv_at_root != "0":
        Set analysis["root_type"] to "simple"
        Set analysis["multiplicity"] to "1"
    Otherwise:
        Set analysis["root_type"] to "multiple"
        
        Note: Check higher derivatives to determine multiplicity
        Let second_derivative be "second_derivative_of_" + function_expr + "_wrt_" + variable
        Let second_deriv_at_root be "evaluate_" + second_derivative + "_at_" + variable + "_equals_" + root_value
        Set analysis["second_derivative"] to second_deriv_at_root
        
        If second_deriv_at_root != "0":
            Set analysis["multiplicity"] to "2"
        Otherwise:
            Set analysis["multiplicity"] to "3_or_higher"
    
    Note: Local behavior analysis
    Let local_expansion be "taylor_expansion_" + function_expr + "_around_" + root_value
    Set analysis["local_expansion"] to local_expansion
    
    Note: Convergence properties for numerical methods
    Set analysis["newton_convergence_rate"] to "quadratic_if_simple_linear_if_multiple"
    Set analysis["bisection_applicable"] to "check_sign_change_around_" + root_value
    
    Note: Root isolation interval
    Let isolation_radius be "1 / abs(" + first_deriv_at_root + ")"
    Set analysis["isolation_interval"] to "[" + root_value + " - " + isolation_radius + ", " + root_value + " + " + isolation_radius + "]"
    
    Note: Sensitivity analysis
    Set analysis["condition_number"] to "condition_number_of_root_" + root_value
    Set analysis["perturbation_sensitivity"] to "sensitivity_to_coefficient_changes"
    
    Return analysis

Process called "find_all_real_roots" that takes equation as Equation, search_interval as Dictionary[String, String] returns List[RootInfo]:
    Note: Find all real roots in specified interval
    Note: Uses combination of analytical and numerical methods
    
    If length(equation.variables) != 1:
        Return []
    
    Let variable be List.get(equation.variables, 0)
    Let function_expr be equation.left_side + " - (" + equation.right_side + ")"
    
    Let lower_bound be search_interval["lower"]
    Let upper_bound be search_interval["upper"]
    
    Let all_roots be []
    
    Note: Strategy depends on equation type
    If equation.degree <= 4 and equation.degree > 0:
        Note: Low-degree polynomials: use exact formulas
        If equation.degree == 1:
            Let linear_root be "solve_linear_" + function_expr
            If linear_root + " >= " + lower_bound + " and " + linear_root + " <= " + upper_bound:
                Let root_info be {
                    "root_value": linear_root,
                    "multiplicity": 1,
                    "root_type": "real",
                    "convergence_rate": 1.0,
                    "isolation_interval": {"lower": linear_root, "upper": linear_root},
                    "numerical_accuracy": 1.0
                }
                Append root_info to all_roots
        
        Otherwise If equation.degree == 2:
            Let quadratic_roots be "solve_quadratic_" + function_expr
            Let discriminant be "discriminant_of_" + function_expr
            
            If discriminant + " >= 0":
                Let root1 be "root1_of_" + quadratic_roots
                Let root2 be "root2_of_" + quadratic_roots
                
                For each root_val in [root1, root2]:
                    If root_val + " >= " + lower_bound + " and " + root_val + " <= " + upper_bound:
                        Let root_info be {
                            "root_value": root_val,
                            "multiplicity": 1,
                            "root_type": "real",
                            "convergence_rate": 2.0,
                            "isolation_interval": {"lower": root_val + " - 0.001", "upper": root_val + " + 0.001"},
                            "numerical_accuracy": 1.0
                        }
                        Append root_info to all_roots
        
        Otherwise:
            Note: Cubic and quartic: use respective formulas
            Let higher_order_roots be "solve_polynomial_degree_" + equation.degree + "_" + function_expr
            Let filtered_real_roots be "filter_real_roots_in_interval_" + higher_order_roots + "_" + lower_bound + "_" + upper_bound
            
            For each root_val in filtered_real_roots:
                Let root_info be {
                    "root_value": root_val,
                    "multiplicity": "determine_multiplicity_" + root_val,
                    "root_type": "real",
                    "convergence_rate": 2.0,
                    "isolation_interval": {"lower": root_val + " - 0.001", "upper": root_val + " + 0.001"},
                    "numerical_accuracy": 0.999
                }
                Append root_info to all_roots
    
    Otherwise:
        Note: Higher degree or transcendental: use numerical methods with root isolation
        Let isolated_intervals be isolate_roots(equation, "bisection")
        
        For each interval in isolated_intervals:
            Let interval_lower be interval["lower"]
            Let interval_upper be interval["upper"]
            
            Note: Refine root in isolated interval
            Let refined_root be brent_method(equation, interval, 1e-10)
            
            If refined_root.root_value + " >= " + lower_bound + " and " + refined_root.root_value + " <= " + upper_bound:
                Append refined_root to all_roots
    
    Return all_roots

Process called "count_roots_sturm" that takes polynomial_coefficients as List[String], interval as Dictionary[String, String] returns Integer:
    Note: Count real roots in interval using Sturm's theorem
    Note: Constructs Sturm sequence and counts sign changes
    
    Let degree be length(polynomial_coefficients) - 1
    If degree <= 0:
        Return 0
    
    Let lower_bound be interval["lower"]
    Let upper_bound be interval["upper"]
    
    Note: Construct Sturm sequence: P₀ = P(x), P₁ = P'(x), P₂ = -rem(P₀,P₁), ...
    Let sturm_sequence be []
    
    Note: P₀ is the original polynomial
    Let P0 be "polynomial_from_coefficients_" + polynomial_coefficients
    Append P0 to sturm_sequence
    
    Note: P₁ is the derivative
    Let derivative_coeffs be []
    For each i from 1 to degree:
        Let coeff be List.get(polynomial_coefficients, i)
        Let deriv_coeff be i + " * " + coeff
        Append deriv_coeff to derivative_coeffs
    
    Let P1 be "polynomial_from_coefficients_" + derivative_coeffs
    Append P1 to sturm_sequence
    
    Note: Compute remainder sequence using polynomial division
    Let current_dividend be P0
    Let current_divisor be P1
    
    Let max_iterations be degree
    For each step from 0 to max_iterations - 1:
        Let division_result be "polynomial_division_" + current_dividend + "_by_" + current_divisor
        Let remainder be "remainder_of_" + division_result
        
        If remainder == "0":
            Break
        
        Let negative_remainder be "-1 * (" + remainder + ")"
        Append negative_remainder to sturm_sequence
        
        Set current_dividend to current_divisor
        Set current_divisor to negative_remainder
    
    Note: Evaluate Sturm sequence at interval endpoints
    Let sign_changes_at_lower be "count_sign_changes_" + sturm_sequence + "_at_" + lower_bound
    Let sign_changes_at_upper be "count_sign_changes_" + sturm_sequence + "_at_" + upper_bound
    
    Note: Sturm's theorem: number of roots = V(a) - V(b)
    Let root_count be sign_changes_at_lower + " - " + sign_changes_at_upper
    
    Return root_count

Process called "isolate_roots" that takes equation as Equation, isolation_method as String returns List[Dictionary[String, String]]:
    Note: Isolate roots into separate intervals
    Note: Each interval contains exactly one root
    
    If length(equation.variables) != 1:
        Return []
    
    Let variable be List.get(equation.variables, 0)
    Let function_expr be equation.left_side + " - (" + equation.right_side + ")"
    
    Let isolated_intervals be []
    
    If isolation_method == "bisection":
        Note: Bisection-based isolation: find sign changes
        Let search_bounds be {
            "lower": "-100",
            "upper": "100"
        }
        
        Note: Initial coarse search for sign changes
        Let coarse_intervals be "find_sign_change_intervals_" + function_expr + "_in_" + search_bounds["lower"] + "_to_" + search_bounds["upper"]
        
        Note: Refine each sign change interval
        For each coarse_interval in coarse_intervals:
            Let refined_interval be "bisection_refine_" + coarse_interval + "_until_single_root"
            Append refined_interval to isolated_intervals
    
    Otherwise If isolation_method == "sturm":
        Note: Sturm sequence based isolation (for polynomials)
        If equation.degree > 0:
            Let polynomial_coeffs be "extract_polynomial_coefficients_" + function_expr
            
            Note: Use binary subdivision with Sturm counting
            Let subdivision_intervals be "sturm_subdivision_" + polynomial_coeffs
            
            For each interval in subdivision_intervals:
                Let root_count be count_roots_sturm(polynomial_coeffs, interval)
                If root_count == 1:
                    Append interval to isolated_intervals
                Otherwise If root_count > 1:
                    Note: Further subdivide this interval
                    Let sub_intervals be "subdivide_interval_" + interval + "_using_sturm"
                    For each sub_interval in sub_intervals:
                        Append sub_interval to isolated_intervals
    
    Otherwise If isolation_method == "descartes":
        Note: Descartes' rule of signs for positive roots
        Let positive_root_bound be "descartes_positive_root_count_" + function_expr
        Let negative_root_bound be "descartes_negative_root_count_" + function_expr
        
        Note: Transform and isolate positive roots
        Let positive_intervals be "isolate_positive_roots_descartes_" + function_expr
        
        Note: Transform x → -x for negative roots  
        Let negative_transform be "substitute_x_with_minus_x_" + function_expr
        Let negative_intervals be "isolate_positive_roots_descartes_" + negative_transform
        
        Note: Convert negative intervals back
        For each neg_interval in negative_intervals:
            Let converted_interval be {
                "lower": "-" + neg_interval["upper"],
                "upper": "-" + neg_interval["lower"]
            }
            Append converted_interval to isolated_intervals
        
        For each pos_interval in positive_intervals:
            Append pos_interval to isolated_intervals
    
    Otherwise:
        Note: Default method: adaptive subdivision
        Let adaptive_intervals be "adaptive_subdivision_" + function_expr + "_method_" + isolation_method
        Set isolated_intervals to adaptive_intervals
    
    Note: Validate isolation (each interval should contain exactly one root)
    Let validated_intervals be []
    For each interval in isolated_intervals:
        Let validation be "validate_single_root_in_" + interval
        If validation == "true":
            Append interval to validated_intervals
    
    Return validated_intervals

Note: =====================================================================
Note: SOLUTION ANALYSIS OPERATIONS
Note: =====================================================================

Process called "verify_solution" that takes equation as Equation, solution as Solution, tolerance as Float returns Boolean:
    Note: Verify solution satisfies equation within tolerance
    Note: Substitutes solution values and checks if equation is satisfied
    
    If length(equation.variables) == 0:
        Return true
    
    If solution.existence == false:
        Return false
    
    Note: Extract variable values from solution
    Let variable_values be solution.variable_values
    If length(variable_values) == 0:
        Return false
    
    Note: Substitute solution values into equation
    Let left_substituted be equation.left_side
    Let right_substituted be equation.right_side
    
    For each variable in equation.variables:
        If variable in variable_values:
            Let value be variable_values[variable]
            Set left_substituted to "substitute_" + variable + "_with_" + value + "_in_" + left_substituted
            Set right_substituted to "substitute_" + variable + "_with_" + value + "_in_" + right_substituted
    
    Note: Evaluate both sides after substitution
    Let left_evaluated be "evaluate_" + left_substituted
    Let right_evaluated be "evaluate_" + right_substituted
    
    Note: Check if difference is within tolerance
    Let difference be "abs(" + left_evaluated + " - " + right_evaluated + ")"
    Let tolerance_check be difference + " <= " + tolerance
    
    Note: Handle symbolic verification
    If solution.solution_type == "symbolic" or solution.solution_type == "exact":
        Let symbolic_verification be "verify_symbolic_equality_" + left_substituted + "_equals_" + right_substituted
        Return symbolic_verification
    
    Note: Numerical verification
    Let numerical_verification be "numerical_verification_" + tolerance_check + "_within_tolerance_" + tolerance
    
    Return numerical_verification

Process called "analyze_solution_uniqueness" that takes equation as Equation, solution as Solution returns Dictionary[String, String]:
    Note: Analyze uniqueness of solution
    Note: Examines degrees of freedom, parameter dependencies, and constraint analysis
    
    Let analysis be {}
    
    If solution.existence == false:
        Set analysis["uniqueness_status"] to "no_solution_exists"
        Set analysis["degree_of_freedom"] to "undefined"
        Return analysis
    
    Note: Check if solution already has uniqueness information
    If "uniqueness" in solution:
        Set analysis["uniqueness_status"] to solution.uniqueness
    Otherwise:
        Set analysis["uniqueness_status"] to "unknown"
    
    Note: Analyze based on equation type and structure
    Let num_variables be length(equation.variables)
    Let num_equations be 1
    
    If equation.equation_type == "system":
        Set num_equations to length(equation.equations)
    
    Note: Degrees of freedom analysis
    Let degrees_of_freedom be num_variables - num_equations
    Set analysis["degrees_of_freedom"] to degrees_of_freedom
    
    If degrees_of_freedom < 0:
        Set analysis["system_type"] to "overdetermined"
        Set analysis["uniqueness_likelihood"] to "no_solution_or_inconsistent"
    Otherwise If degrees_of_freedom == 0:
        Set analysis["system_type"] to "square_system"
        Set analysis["uniqueness_likelihood"] to "likely_unique_if_nonsingular"
    Otherwise:
        Set analysis["system_type"] to "underdetermined"
        Set analysis["uniqueness_likelihood"] to "parametric_family_of_solutions"
    
    Note: Parametric solution analysis
    Let parametric_form be solution.parametric_form
    If length(parametric_form) > 0:
        Set analysis["has_parameters"] to "true"
        Set analysis["parameter_count"] to length(parametric_form)
        Set analysis["uniqueness_status"] to "parametric_family"
    Otherwise:
        Set analysis["has_parameters"] to "false"
        Set analysis["parameter_count"] to "0"
    
    Note: Linear vs nonlinear analysis
    If equation.degree <= 1:
        Set analysis["linearity"] to "linear"
        Set analysis["uniqueness_analysis"] to "determinant_based_" + equation.variables
    Otherwise:
        Set analysis["linearity"] to "nonlinear"
        Set analysis["uniqueness_analysis"] to "jacobian_rank_analysis_" + equation.variables
    
    Note: Solution method implications
    Let method be solution.solution_method
    If method == "gaussian_elimination" or method == "cramer_rule":
        Set analysis["method_guarantees"] to "unique_if_nonsingular"
    Otherwise If method == "least_squares":
        Set analysis["method_guarantees"] to "best_fit_solution"
    Otherwise:
        Set analysis["method_guarantees"] to "method_dependent_" + method
    
    Note: Constraint analysis for optimization problems
    If solution.solution_type == "constrained_optimum" or solution.solution_type == "kkt_point":
        Set analysis["constraint_qualification"] to "check_kkt_conditions"
        Set analysis["local_vs_global"] to "local_optimum_analysis_required"
    
    Return analysis

Process called "solution_sensitivity_analysis" that takes equation as Equation, solution as Solution, parameter_variations as Dictionary[String, String] returns Dictionary[String, String]:
    Note: Analyze sensitivity of solution to parameter changes
    Note: Computes condition numbers, perturbation bounds, and stability measures
    
    Let sensitivity be {}
    
    If solution.existence == false:
        Set sensitivity["sensitivity_status"] to "no_solution_to_analyze"
        Return sensitivity
    
    Note: Extract base solution values
    Let variable_values be solution.variable_values
    If length(variable_values) == 0:
        Set sensitivity["sensitivity_status"] to "no_variable_values"
        Return sensitivity
    
    Note: Initialize sensitivity measures
    Set sensitivity["parameter_count"] to length(parameter_variations)
    Set sensitivity["analysis_type"] to "first_order_perturbation"
    
    Note: Analyze each parameter variation
    For each parameter in parameter_variations:
        Let variation_amount be parameter_variations[parameter]
        Let parameter_name be parameter
        
        Note: Compute partial derivatives of solution w.r.t. parameter
        Let partial_derivative be "partial_derivative_of_solution_wrt_" + parameter_name
        Set sensitivity["partial_" + parameter_name] to partial_derivative
        
        Note: Estimate condition number for this parameter
        Let condition_number be "condition_number_" + parameter_name + "_variation_" + variation_amount
        Set sensitivity["condition_" + parameter_name] to condition_number
        
        Note: Perturbation bound analysis
        Let perturbation_bound be "perturbation_bound_" + parameter_name + "_delta_" + variation_amount
        Set sensitivity["bound_" + parameter_name] to perturbation_bound
    
    Note: Overall solution stability
    Let overall_condition be "max_condition_number_over_all_parameters"
    Set sensitivity["overall_condition_number"] to overall_condition
    
    Note: Stability classification
    Set sensitivity["stability_class"] to "determine_stability_" + overall_condition
    
    Note: Method-specific sensitivity analysis
    Let method be solution.solution_method
    
    If method == "newton_raphson" or method == "newton_raphson_system":
        Set sensitivity["convergence_sensitivity"] to "quadratic_convergence_if_jacobian_nonsingular"
        Set sensitivity["initial_guess_sensitivity"] to "high_for_multiple_roots"
    
    Otherwise If method == "gaussian_elimination":
        Set sensitivity["pivot_sensitivity"] to "condition_number_of_coefficient_matrix"
        Set sensitivity["numerical_stability"] to "depends_on_pivoting_strategy"
    
    Otherwise If method == "least_squares":
        Set sensitivity["residual_sensitivity"] to "condition_number_of_normal_equations"
        Set sensitivity["regularization_needed"] to "check_singular_values"
    
    Note: Error propagation analysis
    Set sensitivity["error_propagation"] to "forward_error_analysis_" + method
    Set sensitivity["backward_error_analysis"] to "backward_error_bound_" + overall_condition
    
    Note: Robustness measures
    Set sensitivity["robustness_measure"] to "1 / " + overall_condition
    Set sensitivity["perturbation_tolerance"] to "maximum_allowable_perturbation_" + overall_condition
    
    Note: Recommendations based on sensitivity
    If overall_condition + " > 1e12":
        Set sensitivity["recommendation"] to "ill_conditioned_consider_regularization"
    Otherwise If overall_condition + " > 1e6":
        Set sensitivity["recommendation"] to "moderate_conditioning_monitor_accuracy"
    Otherwise:
        Set sensitivity["recommendation"] to "well_conditioned_solution"
    
    Return sensitivity

Process called "classify_solution_type" that takes equation as Equation, solution as Solution returns String:
    Note: Classify type of solution (unique, parametric, no solution, etc.)
    Note: Analyzes solution structure and mathematical properties
    
    Note: Check existence first
    If solution.existence == false:
        Return "no_solution"
    
    Note: Check if solution type is already specified
    If "solution_type" in solution:
        Let base_type be solution.solution_type
        
        Note: Refine classification based on additional analysis
        If base_type == "symbolic" or base_type == "exact":
            Note: Check if it's a single value or expression
            Let variable_values be solution.variable_values
            If length(variable_values) == 1:
                Return "unique_symbolic"
            Otherwise If length(variable_values) > 1:
                Return "multi_variable_symbolic"
            Otherwise:
                Return "symbolic_expression"
        
        Otherwise If base_type == "numerical":
            Let parametric_form be solution.parametric_form
            If length(parametric_form) == 0:
                Return "unique_numerical"
            Otherwise:
                Return "parametric_numerical"
        
        Otherwise If base_type == "parametric":
            Return "parametric_family"
        
        Otherwise:
            Return base_type
    
    Note: Analyze solution structure to determine type
    Let variable_values be solution.variable_values
    Let parametric_form be solution.parametric_form
    
    Note: No variable values case
    If length(variable_values) == 0:
        Return "undefined_solution"
    
    Note: Parametric solution analysis
    If length(parametric_form) > 0:
        Let num_parameters be length(parametric_form)
        If num_parameters == 1:
            Return "single_parameter_family"
        Otherwise:
            Return "multi_parameter_family"
    
    Note: Analyze based on equation structure
    Let num_variables be length(equation.variables)
    Let num_solutions be length(variable_values)
    
    Note: Single variable analysis
    If num_variables == 1:
        If equation.degree == 1:
            Return "unique_linear"
        Otherwise If equation.degree == 2:
            Return "quadratic_solution"
        Otherwise If equation.degree > 2:
            Return "polynomial_solution"
        Otherwise:
            Return "transcendental_solution"
    
    Note: Multi-variable analysis
    Otherwise If num_variables > 1:
        Note: Check if it's a system solution
        If equation.equation_type == "system":
            Let num_equations be length(equation.equations) if "equations" in equation otherwise 1
            
            If num_equations == num_variables:
                Return "square_system_solution"
            Otherwise If num_equations < num_variables:
                Return "underdetermined_system_solution"
            Otherwise:
                Return "overdetermined_system_solution"
        Otherwise:
            Return "multi_variable_single_equation"
    
    Note: Analyze solution method implications
    Let method be solution.solution_method
    
    If method == "cramer_rule":
        Return "unique_cramer_solution"
    Otherwise If method == "gaussian_elimination":
        Return "unique_elimination_solution"
    Otherwise If method == "least_squares":
        Return "best_fit_solution"
    Otherwise If method == "newton_raphson":
        Return "iterative_numerical_solution"
    Otherwise If method == "lagrange_multipliers":
        Return "constrained_optimization_solution"
    Otherwise If method == "separation_of_variables":
        Return "differential_equation_solution"
    
    Note: Default classification based on mathematical properties
    If solution.uniqueness == true:
        Return "unique_solution"
    Otherwise If solution.uniqueness == false:
        Return "non_unique_solution"
    Otherwise:
        Return "solution_unknown_uniqueness"

Note: =====================================================================
Note: EQUATION TRANSFORMATION OPERATIONS
Note: =====================================================================

Process called "normalize_equation" that takes equation as Equation returns Equation:
    Note: Normalize equation to standard form
    Note: Moves all terms to left side, combines like terms, orders by degree
    
    Let normalized_equation be {
        "left_side": "",
        "right_side": "0",
        "variables": equation.variables,
        "degree": equation.degree,
        "equation_type": equation.equation_type,
        "coefficients": {},
        "constants": {}
    }
    
    Note: Move all terms to left side: left - right = 0
    Let left_terms be equation.left_side
    Let right_terms be equation.right_side
    
    Note: Create normalized left side expression
    If right_terms == "0":
        Set normalized_equation.left_side to left_terms
    Otherwise:
        Set normalized_equation.left_side to left_terms + " - (" + right_terms + ")"
    
    Note: Expand and combine like terms
    Let expanded_expression be "expand_" + normalized_equation.left_side
    Let combined_terms be "combine_like_terms_" + expanded_expression
    
    Note: Order terms by degree (highest to lowest)
    Let ordered_expression be "order_terms_by_degree_" + combined_terms
    Set normalized_equation.left_side to ordered_expression
    
    Note: Extract coefficients for polynomial equations
    If equation.degree > 0:
        For each variable in equation.variables:
            For each power from equation.degree down to 0:
                Let coefficient_key be variable + "_power_" + power
                Let coefficient_value be "coefficient_of_" + variable + "_to_power_" + power + "_in_" + ordered_expression
                Set normalized_equation.coefficients[coefficient_key] to coefficient_value
    
    Note: Extract constant term
    Let constant_term be "constant_term_of_" + ordered_expression
    Set normalized_equation.constants["constant"] to constant_term
    
    Note: Normalize coefficient of leading term to 1 if possible
    If equation.degree > 0:
        Let leading_variable be List.get(equation.variables, 0)
        Let leading_coeff_key be leading_variable + "_power_" + equation.degree
        Let leading_coeff be normalized_equation.coefficients[leading_coeff_key]
        
        If leading_coeff != "1" and leading_coeff != "0":
            Note: Divide all terms by leading coefficient
            Let normalized_left be "(" + normalized_equation.left_side + ") / (" + leading_coeff + ")"
            Let simplified_left be "simplify_" + normalized_left
            Set normalized_equation.left_side to simplified_left
            
            Note: Update coefficients after normalization
            For each coeff_key in normalized_equation.coefficients:
                Let old_coeff be normalized_equation.coefficients[coeff_key]
                Let new_coeff be "(" + old_coeff + ") / (" + leading_coeff + ")"
                Set normalized_equation.coefficients[coeff_key] to "simplify_" + new_coeff
    
    Note: Handle special equation types
    If equation.equation_type == "trigonometric":
        Let trig_normalized be "normalize_trigonometric_" + normalized_equation.left_side
        Set normalized_equation.left_side to trig_normalized
    
    Otherwise If equation.equation_type == "exponential":
        Let exp_normalized be "normalize_exponential_" + normalized_equation.left_side
        Set normalized_equation.left_side to exp_normalized
    
    Otherwise If equation.equation_type == "logarithmic":
        Let log_normalized be "normalize_logarithmic_" + normalized_equation.left_side
        Set normalized_equation.left_side to log_normalized
    
    Return normalized_equation

Process called "substitute_variables" that takes equation as Equation, substitutions as Dictionary[String, String] returns Equation:
    Note: Substitute variables in equation
    Note: Replaces variables with expressions or values throughout equation
    
    If length(substitutions) == 0:
        Return equation
    
    Let substituted_equation be {
        "left_side": equation.left_side,
        "right_side": equation.right_side,
        "variables": [],
        "degree": equation.degree,
        "equation_type": equation.equation_type,
        "coefficients": {},
        "constants": {}
    }
    
    Note: Apply substitutions to left side
    Let left_substituted be equation.left_side
    For each variable in substitutions:
        Let replacement be substitutions[variable]
        Set left_substituted to "substitute_" + variable + "_with_" + replacement + "_in_" + left_substituted
    
    Note: Apply substitutions to right side
    Let right_substituted be equation.right_side
    For each variable in substitutions:
        Let replacement be substitutions[variable]
        Set right_substituted to "substitute_" + variable + "_with_" + replacement + "_in_" + right_substituted
    
    Note: Simplify after substitution
    Set substituted_equation.left_side to "simplify_" + left_substituted
    Set substituted_equation.right_side to "simplify_" + right_substituted
    
    Note: Update variable list (remove substituted variables, add new ones)
    For each variable in equation.variables:
        If variable not in substitutions:
            Append variable to substituted_equation.variables
    
    Note: Extract new variables from substitution expressions
    For each substitution_expr in substitutions:
        Let new_vars be "extract_variables_from_" + substitution_expr
        For each new_var in new_vars:
            If new_var not in substituted_equation.variables:
                Append new_var to substituted_equation.variables
    
    Note: Recalculate degree after substitution
    Let new_degree be "determine_degree_of_" + substituted_equation.left_side + "_minus_" + substituted_equation.right_side
    Set substituted_equation.degree to new_degree
    
    Note: Update equation type if changed by substitution
    Let type_analysis be "analyze_equation_type_" + substituted_equation.left_side + "_" + substituted_equation.right_side
    
    If type_analysis == "polynomial":
        Set substituted_equation.equation_type to "polynomial"
    Otherwise If type_analysis == "trigonometric":
        Set substituted_equation.equation_type to "trigonometric"
    Otherwise If type_analysis == "exponential":
        Set substituted_equation.equation_type to "exponential"
    Otherwise If type_analysis == "logarithmic":
        Set substituted_equation.equation_type to "logarithmic"
    Otherwise:
        Set substituted_equation.equation_type to "general"
    
    Note: Update coefficients for polynomial equations
    If substituted_equation.degree > 0 and substituted_equation.equation_type == "polynomial":
        For each variable in substituted_equation.variables:
            For each power from 0 to substituted_equation.degree:
                Let coeff_key be variable + "_power_" + power
                Let coeff_value be "coefficient_of_" + variable + "_to_power_" + power + "_in_" + substituted_equation.left_side + "_minus_" + substituted_equation.right_side
                Set substituted_equation.coefficients[coeff_key] to coeff_value
    
    Return substituted_equation

Process called "change_of_variables" that takes equation as Equation, transformation as Dictionary[String, String] returns Equation:
    Note: Apply change of variables transformation
    Note: Transforms equation using u = f(x), v = g(y), etc. with Jacobian adjustments
    
    If length(transformation) == 0:
        Return equation
    
    Let transformed_equation be {
        "left_side": equation.left_side,
        "right_side": equation.right_side,
        "variables": [],
        "degree": equation.degree,
        "equation_type": equation.equation_type,
        "coefficients": {},
        "constants": {},
        "jacobian_factor": "1"
    }
    
    Note: Build inverse transformation for substitution
    Let inverse_transformation be {}
    
    For each new_var in transformation:
        Let old_var_expr be transformation[new_var]
        Note: For simple transformations like u = 2x + 1, solve for x in terms of u
        Let inverse_expr be "solve_for_original_variable_" + old_var_expr + "_in_terms_of_" + new_var
        Set inverse_transformation["original_variable_from_" + old_var_expr] to inverse_expr
    
    Note: Apply inverse transformation to equation
    Let left_transformed be equation.left_side
    Let right_transformed be equation.right_side
    
    For each old_var in equation.variables:
        Note: Find which transformation involves this variable
        For each new_var in transformation:
            Let transform_expr be transformation[new_var]
            If "contains_variable_" + old_var + "_in_" + transform_expr:
                Let inverse_expr be "solve_" + transform_expr + "_for_" + old_var
                Set left_transformed to "substitute_" + old_var + "_with_" + inverse_expr + "_in_" + left_transformed
                Set right_transformed to "substitute_" + old_var + "_with_" + inverse_expr + "_in_" + right_transformed
    
    Note: Simplify transformed expressions
    Set transformed_equation.left_side to "simplify_" + left_transformed
    Set transformed_equation.right_side to "simplify_" + right_transformed
    
    Note: Update variable list with new variables
    For each new_var in transformation:
        Append new_var to transformed_equation.variables
    
    Note: Calculate Jacobian for coordinate transformation
    If length(equation.variables) > 1:
        Let jacobian_matrix be "jacobian_matrix_of_transformation_" + transformation
        Let jacobian_determinant be "determinant_of_" + jacobian_matrix
        Set transformed_equation.jacobian_factor to jacobian_determinant
        
        Note: For differential equations, multiply by Jacobian
        If equation.equation_type == "differential":
            Set transformed_equation.left_side to "(" + transformed_equation.left_side + ") * " + jacobian_determinant
            Set transformed_equation.right_side to "(" + transformed_equation.right_side + ") * " + jacobian_determinant
    
    Note: Recalculate degree in new variables
    Let combined_expr be transformed_equation.left_side + " - (" + transformed_equation.right_side + ")"
    Let new_degree be "determine_degree_of_" + combined_expr + "_in_variables_" + transformed_equation.variables
    Set transformed_equation.degree to new_degree
    
    Note: Analyze equation type after transformation
    Let type_after_transform be "analyze_equation_type_after_transformation_" + combined_expr
    
    If type_after_transform == "linear":
        Set transformed_equation.equation_type to "linear"
    Otherwise If type_after_transform == "polynomial":
        Set transformed_equation.equation_type to "polynomial"
    Otherwise If type_after_transform == "separable":
        Set transformed_equation.equation_type to "separable"
    Otherwise:
        Set transformed_equation.equation_type to "transformed_general"
    
    Note: Update coefficients in new coordinate system
    If transformed_equation.equation_type == "polynomial":
        For each new_var in transformed_equation.variables:
            For each power from 0 to transformed_equation.degree:
                Let coeff_key be new_var + "_power_" + power
                Let coeff_value be "coefficient_of_" + new_var + "_to_power_" + power + "_in_" + combined_expr
                Set transformed_equation.coefficients[coeff_key] to coeff_value
    
    Note: Store transformation information
    Set transformed_equation.constants["original_variables"] to equation.variables
    Set transformed_equation.constants["transformation_map"] to transformation
    Set transformed_equation.constants["inverse_transformation"] to inverse_transformation
    
    Return transformed_equation

Process called "rationalize_equation" that takes equation as Equation returns Equation:
    Note: Rationalize denominators in equation
    Note: Eliminates radicals and complex expressions from denominators
    
    Let rationalized_equation be {
        "left_side": equation.left_side,
        "right_side": equation.right_side,
        "variables": equation.variables,
        "degree": equation.degree,
        "equation_type": equation.equation_type,
        "coefficients": equation.coefficients,
        "constants": equation.constants
    }
    
    Note: Identify terms with irrational denominators
    Let left_denominators be "extract_denominators_from_" + equation.left_side
    Let right_denominators be "extract_denominators_from_" + equation.right_side
    
    Note: Rationalize left side
    Let left_rationalized be equation.left_side
    
    For each denominator in left_denominators:
        Note: Check if denominator contains radicals
        If "contains_radicals_" + denominator:
            Note: Find rationalizing factor
            Let rationalizing_factor be "rationalizing_factor_for_" + denominator
            
            Note: Multiply numerator and denominator by rationalizing factor
            Set left_rationalized to "rationalize_denominator_" + denominator + "_using_" + rationalizing_factor + "_in_" + left_rationalized
    
    Note: Rationalize right side
    Let right_rationalized be equation.right_side
    
    For each denominator in right_denominators:
        If "contains_radicals_" + denominator:
            Let rationalizing_factor be "rationalizing_factor_for_" + denominator
            Set right_rationalized to "rationalize_denominator_" + denominator + "_using_" + rationalizing_factor + "_in_" + right_rationalized
    
    Note: Simplify rationalized expressions
    Set rationalized_equation.left_side to "simplify_rationalized_" + left_rationalized
    Set rationalized_equation.right_side to "simplify_rationalized_" + right_rationalized
    
    Note: Handle common rationalization patterns
    Note: Pattern 1: 1/√a → √a/a
    Set rationalized_equation.left_side to "apply_sqrt_rationalization_" + rationalized_equation.left_side
    Set rationalized_equation.right_side to "apply_sqrt_rationalization_" + rationalized_equation.right_side
    
    Note: Pattern 2: 1/(a + b√c) → (a - b√c)/(a² - b²c)
    Set rationalized_equation.left_side to "apply_conjugate_rationalization_" + rationalized_equation.left_side
    Set rationalized_equation.right_side to "apply_conjugate_rationalization_" + rationalized_equation.right_side
    
    Note: Pattern 3: 1/∛a → ∛(a²)/a
    Set rationalized_equation.left_side to "apply_cube_root_rationalization_" + rationalized_equation.left_side
    Set rationalized_equation.right_side to "apply_cube_root_rationalization_" + rationalized_equation.right_side
    
    Note: Clear common factors after rationalization
    Let cleared_left be "clear_common_factors_" + rationalized_equation.left_side
    Let cleared_right be "clear_common_factors_" + rationalized_equation.right_side
    
    Set rationalized_equation.left_side to cleared_left
    Set rationalized_equation.right_side to cleared_right
    
    Note: Recalculate degree after rationalization (may increase)
    Let combined_rationalized be rationalized_equation.left_side + " - (" + rationalized_equation.right_side + ")"
    Let new_degree be "determine_degree_after_rationalization_" + combined_rationalized
    Set rationalized_equation.degree to new_degree
    
    Note: Update coefficients if equation is still polynomial
    If rationalized_equation.equation_type == "polynomial":
        Let new_coefficients be {}
        For each variable in rationalized_equation.variables:
            For each power from 0 to rationalized_equation.degree:
                Let coeff_key be variable + "_power_" + power
                Let coeff_value be "coefficient_of_" + variable + "_to_power_" + power + "_in_" + combined_rationalized
                Set new_coefficients[coeff_key] to coeff_value
        Set rationalized_equation.coefficients to new_coefficients
    
    Note: Store rationalization information
    Set rationalized_equation.constants["rationalization_applied"] to "true"
    Set rationalized_equation.constants["original_left"] to equation.left_side
    Set rationalized_equation.constants["original_right"] to equation.right_side
    
    Return rationalized_equation

Note: =====================================================================
Note: VALIDATION AND UTILITY OPERATIONS
Note: =====================================================================

Process called "validate_equation_system" that takes system as EquationSystem returns List[String]:
    Note: Validate equation system for consistency and solvability
    Note: Checks rank conditions, consistency, overdetermined/underdetermined cases
    
    Let validation_results be []
    
    Note: Basic structure validation
    If length(system.equations) == 0:
        Append "empty_system_no_equations" to validation_results
        Return validation_results
    
    If length(system.variables) == 0:
        Append "no_variables_defined" to validation_results
        Return validation_results
    
    Let num_equations be length(system.equations)
    Let num_variables be length(system.variables)
    
    Note: System dimension analysis
    If num_equations < num_variables:
        Append "underdetermined_system_" + num_equations + "_equations_" + num_variables + "_variables" to validation_results
        Append "expect_parametric_solutions" to validation_results
    
    Otherwise If num_equations > num_variables:
        Append "overdetermined_system_" + num_equations + "_equations_" + num_variables + "_variables" to validation_results
        Append "may_be_inconsistent_check_compatibility" to validation_results
    
    Otherwise:
        Append "square_system_" + num_equations + "_equations_" + num_variables + "_variables" to validation_results
    
    Note: Linear system specific validation
    If system.system_type == "linear":
        Note: Construct coefficient matrix and check rank
        Let coefficient_matrix be "construct_coefficient_matrix_" + system.equations
        Let augmented_matrix be "augmented_matrix_" + coefficient_matrix + "_with_constants"
        
        Let matrix_rank be "rank_of_" + coefficient_matrix
        Let augmented_rank be "rank_of_" + augmented_matrix
        
        Note: Rouché-Capelli theorem: system is consistent iff rank(A) = rank(A|b)
        If matrix_rank != augmented_rank:
            Append "inconsistent_system_rank_condition_failed" to validation_results
            Append "no_solution_exists" to validation_results
        Otherwise:
            Append "consistent_system_rank_condition_satisfied" to validation_results
            
            If matrix_rank == num_variables:
                Append "unique_solution_full_rank" to validation_results
            Otherwise:
                Let degrees_freedom be num_variables - matrix_rank
                Append "parametric_solution_" + degrees_freedom + "_free_variables" to validation_results
    
    Note: Nonlinear system validation
    Otherwise If system.system_type == "nonlinear":
        Note: Check for obvious contradictions
        For each i from 0 to num_equations - 1:
            Let equation_i be List.get(system.equations, i)
            
            Note: Check for contradictory constant equations
            If "is_constant_equation_" + equation_i:
                Let evaluation be "evaluate_constant_equation_" + equation_i
                If evaluation == "false" or evaluation == "contradiction":
                    Append "contradictory_equation_" + i + "_" + equation_i to validation_results
        
        Note: Jacobian analysis at test points
        Let test_point be "generate_test_point_" + system.variables
        Let jacobian_at_test be "jacobian_matrix_at_" + test_point
        Let jacobian_rank be "rank_of_" + jacobian_at_test
        
        If jacobian_rank < num_variables:
            Append "singular_jacobian_at_test_point_may_indicate_dependence" to validation_results
        Otherwise:
            Append "nonsingular_jacobian_at_test_point_good_conditioning" to validation_results
    
    Note: Compatibility checks for specific equation types
    Let equation_types be []
    For each equation in system.equations:
        If equation.equation_type not in equation_types:
            Append equation.equation_type to equation_types
    
    If length(equation_types) > 1:
        Append "mixed_equation_types_" + equation_types to validation_results
        Append "may_require_different_solution_methods" to validation_results
    
    Note: Variable consistency check
    Let all_variables_in_equations be []
    For each equation in system.equations:
        For each var in equation.variables:
            If var not in all_variables_in_equations:
                Append var to all_variables_in_equations
    
    Note: Check if system variables match equation variables
    For each sys_var in system.variables:
        If sys_var not in all_variables_in_equations:
            Append "system_variable_" + sys_var + "_not_found_in_equations" to validation_results
    
    For each eq_var in all_variables_in_equations:
        If eq_var not in system.variables:
            Append "equation_variable_" + eq_var + "_not_in_system_variables" to validation_results
    
    Note: Degree compatibility for polynomial systems
    Let max_degree be 0
    For each equation in system.equations:
        If equation.degree > max_degree:
            Set max_degree to equation.degree
    
    If max_degree > 4:
        Append "high_degree_polynomial_system_degree_" + max_degree to validation_results
        Append "analytical_solution_may_not_exist" to validation_results
    
    Note: Solution method recommendations
    If length(validation_results) == 1 or (length(validation_results) == 2 and validation_results[0] == "square_system_" + num_equations + "_equations_" + num_variables + "_variables"):
        If system.system_type == "linear":
            Append "recommend_gaussian_elimination_or_cramer_rule" to validation_results
        Otherwise:
            Append "recommend_newton_raphson_or_iterative_methods" to validation_results
    
    Note: If no issues found, system is well-formed
    If length(validation_results) == 0:
        Append "system_validation_passed_no_issues_detected" to validation_results
    
    Return validation_results

Process called "benchmark_equation_solvers" that takes solver_types as List[String], test_equations as List[Equation] returns Dictionary[String, Float]:
    Note: Benchmark performance of equation solving methods
    Note: Measures accuracy, convergence speed, and robustness across different solvers
    
    Let benchmark_results be {}
    
    If length(solver_types) == 0 or length(test_equations) == 0:
        Return benchmark_results
    
    Note: Initialize performance metrics for each solver
    For each solver in solver_types:
        Set benchmark_results[solver + "_accuracy"] to "0.0"
        Set benchmark_results[solver + "_speed"] to "0.0"
        Set benchmark_results[solver + "_robustness"] to "0.0"
        Set benchmark_results[solver + "_success_rate"] to "0.0"
    
    Let num_test_equations be length(test_equations)
    
    Note: Run each solver on each test equation
    For each solver in solver_types:
        Let solver_performance be {
            "total_accuracy": 0.0,
            "total_time": 0.0,
            "successful_solves": 0,
            "failed_solves": 0
        }
        
        For each i from 0 to num_test_equations - 1:
            Let test_equation be List.get(test_equations, i)
            
            Note: Time the solving process
            Let start_time be "benchmark_timer_start"
            
            Note: Apply appropriate solver
            Let solution be {}
            Let solve_success be false
            
            If solver == "gaussian_elimination":
                If test_equation.degree == 1:
                    Set solution to solve_linear_system_gaussian([test_equation])
                    Set solve_success to solution.existence
            
            Otherwise If solver == "cramer_rule":
                If test_equation.degree == 1:
                    Set solution to solve_linear_system_cramer([test_equation])
                    Set solve_success to solution.existence
            
            Otherwise If solver == "newton_raphson":
                If test_equation.degree > 1:
                    Set solution to solve_transcendental_newton(test_equation, "1.0", 1e-10)
                    Set solve_success to solution.root_value != "no_solution"
            
            Otherwise If solver == "bisection":
                Set solution to solve_transcendental_bisection(test_equation, {"lower": "-10", "upper": "10"}, 1e-10)
                Set solve_success to solution.root_value != "no_solution"
            
            Otherwise If solver == "quadratic_formula":
                If test_equation.degree == 2:
                    Set solution to solve_polynomial_quadratic(test_equation)
                    Set solve_success to solution.existence
            
            Otherwise If solver == "brent_method":
                Set solution to solve_transcendental_brent(test_equation, {"lower": "-10", "upper": "10"}, 1e-10)
                Set solve_success to solution.root_value != "no_solution"
            
            Let end_time be "benchmark_timer_end"
            Let solve_time be end_time - start_time
            
            Note: Update performance metrics
            Set solver_performance.total_time to solver_performance.total_time + solve_time
            
            If solve_success:
                Set solver_performance.successful_solves to solver_performance.successful_solves + 1
                
                Note: Measure accuracy by verification
                Let verification_result be verify_solution(test_equation, solution, 1e-8)
                If verification_result:
                    Set solver_performance.total_accuracy to solver_performance.total_accuracy + 1.0
                Otherwise:
                    Set solver_performance.total_accuracy to solver_performance.total_accuracy + 0.5
            Otherwise:
                Set solver_performance.failed_solves to solver_performance.failed_solves + 1
        
        Note: Compute final metrics for this solver
        Let success_rate be solver_performance.successful_solves / num_test_equations
        Let average_accuracy be solver_performance.total_accuracy / num_test_equations
        Let average_time be solver_performance.total_time / num_test_equations
        Let robustness be success_rate
        
        Note: Store results (convert to performance scores)
        Set benchmark_results[solver + "_success_rate"] to success_rate
        Set benchmark_results[solver + "_accuracy"] to average_accuracy
        Set benchmark_results[solver + "_average_time"] to average_time
        Set benchmark_results[solver + "_robustness"] to robustness
        
        Note: Compute speed score (inverse of time, normalized)
        If average_time > 0:
            Set benchmark_results[solver + "_speed_score"] to "1.0 / " + average_time
        Otherwise:
            Set benchmark_results[solver + "_speed_score"] to "1000.0"
    
    Note: Compute relative performance rankings
    Let best_accuracy be "max_accuracy_across_" + solver_types
    Let best_speed be "max_speed_across_" + solver_types
    Let best_robustness be "max_robustness_across_" + solver_types
    
    For each solver in solver_types:
        Let relative_accuracy be benchmark_results[solver + "_accuracy"] + " / " + best_accuracy
        Let relative_speed be benchmark_results[solver + "_speed_score"] + " / " + best_speed
        Let relative_robustness be benchmark_results[solver + "_robustness"] + " / " + best_robustness
        
        Set benchmark_results[solver + "_relative_accuracy"] to relative_accuracy
        Set benchmark_results[solver + "_relative_speed"] to relative_speed
        Set benchmark_results[solver + "_relative_robustness"] to relative_robustness
        
        Note: Overall performance score (weighted average)
        Let overall_score be "0.4 * " + relative_accuracy + " + 0.3 * " + relative_speed + " + 0.3 * " + relative_robustness
        Set benchmark_results[solver + "_overall_score"] to overall_score
    
    Note: Add summary statistics
    Set benchmark_results["total_test_equations"] to num_test_equations
    Set benchmark_results["solvers_tested"] to length(solver_types)
    Set benchmark_results["benchmark_timestamp"] to "current_timestamp"
    
    Return benchmark_results

Process called "format_solution_display" that takes solution as Solution, format_options as Dictionary[String, String] returns String:
    Note: Format solution for display in specified format
    Note: Supports mathematical notation, LaTeX, ASCII, and structured formats
    
    Let display_format be "ascii"
    Let precision be "6"
    Let show_method be "true"
    Let show_metadata be "false"
    
    Note: Parse format options
    If "format" in format_options:
        Set display_format to format_options["format"]
    
    If "precision" in format_options:
        Set precision to format_options["precision"]
    
    If "show_method" in format_options:
        Set show_method to format_options["show_method"]
    
    If "show_metadata" in format_options:
        Set show_metadata to format_options["show_metadata"]
    
    Let formatted_output be ""
    
    Note: Handle non-existent solutions
    If solution.existence == false:
        If display_format == "latex":
            Return "\\text{No solution exists}"
        Otherwise If display_format == "unicode":
            Return "∅ (No solution)"
        Otherwise:
            Return "No solution exists"
    
    Note: Format based on display format
    If display_format == "latex":
        Note: LaTeX mathematical notation
        Set formatted_output to "\\begin{align}\n"
        
        For each variable in solution.variable_values:
            If variable != "solution_vector":
                Let value be solution.variable_values[variable]
                Set formatted_output to formatted_output + variable + " &= " + "format_latex_" + value + "_precision_" + precision + "\\\\\n"
        
        Set formatted_output to formatted_output + "\\end{align}"
        
        Note: Add parametric form if present
        If length(solution.parametric_form) > 0:
            Set formatted_output to formatted_output + "\\\\\\text{Parametric form:}\\\\\n"
            For each param in solution.parametric_form:
                Let param_expr be solution.parametric_form[param]
                Set formatted_output to formatted_output + param + " = " + "format_latex_" + param_expr + "\\\\\n"
    
    Otherwise If display_format == "unicode":
        Note: Unicode mathematical symbols
        For each variable in solution.variable_values:
            If variable != "solution_vector":
                Let value be solution.variable_values[variable]
                Set formatted_output to formatted_output + variable + " = " + "format_unicode_" + value + "_precision_" + precision + "\n"
        
        If length(solution.parametric_form) > 0:
            Set formatted_output to formatted_output + "\nParametric form:\n"
            For each param in solution.parametric_form:
                Let param_expr be solution.parametric_form[param]
                Set formatted_output to formatted_output + param + " = " + "format_unicode_" + param_expr + "\n"
    
    Otherwise If display_format == "ascii":
        Note: Plain ASCII text format
        For each variable in solution.variable_values:
            If variable != "solution_vector":
                Let value be solution.variable_values[variable]
                Set formatted_output to formatted_output + variable + " = " + "format_ascii_" + value + "_precision_" + precision + "\n"
        
        If length(solution.parametric_form) > 0:
            Set formatted_output to formatted_output + "\nParametric form:\n"
            For each param in solution.parametric_form:
                Let param_expr be solution.parametric_form[param]
                Set formatted_output to formatted_output + param + " = " + "format_ascii_" + param_expr + "\n"
    
    Otherwise If display_format == "json":
        Note: Structured JSON format
        Let json_solution be {
            "variable_values": {},
            "solution_type": solution.solution_type,
            "existence": solution.existence
        }
        
        For each variable in solution.variable_values:
            If variable != "solution_vector":
                Let value be solution.variable_values[variable]
                Set json_solution.variable_values[variable] to "format_json_" + value + "_precision_" + precision
        
        If length(solution.parametric_form) > 0:
            Set json_solution["parametric_form"] to solution.parametric_form
        
        Set formatted_output to "json_stringify_" + json_solution
    
    Otherwise If display_format == "table":
        Note: Tabular format
        Set formatted_output to "Variable | Value\n"
        Set formatted_output to formatted_output + "---------|------\n"
        
        For each variable in solution.variable_values:
            If variable != "solution_vector":
                Let value be solution.variable_values[variable]
                Let formatted_value be "format_table_" + value + "_precision_" + precision
                Set formatted_output to formatted_output + variable + " | " + formatted_value + "\n"
    
    Otherwise:
        Note: Default to ASCII format
        Set formatted_output to "format_solution_ascii_default_" + solution + "_precision_" + precision
    
    Note: Add solution method information
    If show_method == "true":
        If display_format == "latex":
            Set formatted_output to formatted_output + "\\\\\\text{Method: }" + solution.solution_method
        Otherwise:
            Set formatted_output to formatted_output + "\nSolution method: " + solution.solution_method
    
    Note: Add metadata if requested
    If show_metadata == "true":
        Let metadata_section be ""
        
        If "accuracy_estimate" in solution:
            Set metadata_section to metadata_section + "Accuracy: " + solution.accuracy_estimate + "\n"
        
        If "uniqueness" in solution:
            Set metadata_section to metadata_section + "Uniqueness: " + solution.uniqueness + "\n"
        
        If display_format == "latex":
            Set metadata_section to "\\\\\\text{" + metadata_section + "}"
        
        Set formatted_output to formatted_output + "\n" + metadata_section
    
    Note: Clean up formatting
    Let cleaned_output be "remove_extra_whitespace_" + formatted_output
    
    Return cleaned_output