Note:
math/symbolic/transforms.runa
Symbolic Mathematical Transform Operations

This module provides comprehensive symbolic transform operations including:
- Laplace transforms and inverse transforms
- Fourier transforms (continuous and discrete)
- Z-transforms for discrete sequences
- Mellin transforms and inverse operations
- Hankel transforms and related integral transforms
- Wavelet transforms and multi-resolution analysis
- Legendre transforms and convex analysis
- Radon transforms and tomographic reconstructions
- Hilbert transforms and analytic signal processing
- Integral transform properties and theorems
- Transform composition and cascading
- Transform domain analysis and filtering
- Symbolic convolution and correlation operations
- Green's function representations
- Transform-based differential equation solving
:End Note

Import "dev/debug/errors/core" as Errors
Import "math/symbolic/core" as SymbolicCore
Import "math/symbolic/calculus" as Calculus
Import "collections" as Collections
Import "datetime" as DateTime

Note: =====================================================================
Note: HELPER FUNCTIONS
Note: =====================================================================

Process called "is_power_of_two" that takes n as Integer returns Boolean:
    Note: Check if n is a power of 2
    If n <= 0:
        Return False
    Return (n & (n - 1)) equals 0

Process called "factorial" that takes n as Integer returns Integer:
    Note: Calculate factorial of n
    If n <= 1:
        Return 1
    Return n * factorial(n - 1)

Note: =====================================================================
Note: TRANSFORM DATA STRUCTURES
Note: =====================================================================

Type called "LaplaceTransform":
    original_function as String
    transformed_function as String
    transform_variable as String
    original_variable as String
    region_of_convergence as Dictionary[String, String]
    poles as List[String]
    residues as Dictionary[String, String]

Type called "FourierTransform":
    original_function as String
    transformed_function as String
    frequency_variable as String
    time_variable as String
    transform_type as String
    normalization as String
    symmetry_properties as Dictionary[String, Boolean]

Type called "ZTransform":
    sequence as List[String]
    transformed_function as String
    transform_variable as String
    region_of_convergence as Dictionary[String, String]
    poles as List[String]
    zeros as List[String]

Type called "WaveletTransform":
    original_signal as String
    wavelet_coefficients as Dictionary[String, Dictionary[String, String]]
    mother_wavelet as String
    scaling_function as String
    decomposition_levels as Integer
    reconstruction_formula as String

Type called "IntegralTransform":
    transform_name as String
    kernel_function as String
    integration_limits as Dictionary[String, String]
    transform_properties as Dictionary[String, String]
    inverse_kernel as String

Note: =====================================================================
Note: HELPER FUNCTIONS FOR TRANSFORMS
Note: =====================================================================

Process called "evaluate_complex_integral" that takes integrand as SymbolicCore.SymbolicExpression, variable as String, limits as Dictionary[String, String] returns SymbolicCore.SymbolicExpression:
    Note: Evaluate complex contour integrals for inverse transforms
    Let parsing_context be Dictionary.empty()
    
    Note: Get integration limits
    Let lower_limit be Dictionary.get_or_default(limits, "lower", "0")
    Let upper_limit be Dictionary.get_or_default(limits, "upper", "infinity")
    
    Note: Use calculus integration rules for evaluation
    Let integrated_result be Calculus.apply_integration_rules(integrand, variable)
    
    Note: Apply limits if they are finite
    If not String.equals(upper_limit, "infinity") and not String.equals(lower_limit, "-infinity"):
        Let upper_bound_expr be SymbolicCore.parse_expression(upper_limit, parsing_context)
        Let lower_bound_expr be SymbolicCore.parse_expression(lower_limit, parsing_context)
        
        Let upper_eval be SymbolicCore.substitute_variable(integrated_result, variable, upper_bound_expr)
        Let lower_eval be SymbolicCore.substitute_variable(integrated_result, variable, lower_bound_expr)
        Return SymbolicCore.create_binary_operation("-", upper_eval, lower_eval)
    
    Return integrated_result

Process called "lookup_transform_table" that takes function_pattern as String, transform_type as String returns String:
    Note: Look up standard transform from tables for common functions
    
    Note: Laplace transform table
    If transform_type equals "laplace":
        If String.equals(function_pattern, "1"):
            Return "1/s"
        If String.equals(function_pattern, "t"):
            Return "1/s^2"
        If String.contains(function_pattern, "exp"):
            Return "1/(s-a) for exp(a*t)"
        If String.contains(function_pattern, "sin"):
            Return "a/(s^2+a^2) for sin(a*t)"
        If String.contains(function_pattern, "cos"):
            Return "s/(s^2+a^2) for cos(a*t)"
        If String.contains(function_pattern, "t^n"):
            Return "n!/(s^(n+1)) for t^n"
    
    Note: Fourier transform table
    If transform_type equals "fourier":
        If String.equals(function_pattern, "1"):
            Return "2*pi*delta(w)"
        If String.contains(function_pattern, "exp"):
            If String.contains(function_pattern, "i*w*t"):
                Return "2*pi*delta(w-w0) for exp(i*w0*t)"
            If String.contains(function_pattern, "-a*t^2"):
                Return "sqrt(pi/a)*exp(-w^2/(4*a)) for exp(-a*t^2)"
        If String.contains(function_pattern, "sin"):
            Return "i*pi*[delta(w+w0) - delta(w-w0)] for sin(w0*t)"
        If String.contains(function_pattern, "cos"):
            Return "pi*[delta(w+w0) + delta(w-w0)] for cos(w0*t)"
    
    Note: Z-transform table
    If transform_type equals "z_transform":
        If String.equals(function_pattern, "1"):
            Return "z/(z-1)"
        If String.contains(function_pattern, "a^n"):
            Return "z/(z-a) for a^n"
        If String.contains(function_pattern, "n*a^n"):
            Return "a*z/(z-a)^2 for n*a^n"
        If String.contains(function_pattern, "cos"):
            Return "z*(z-a*cos(w))/(z^2-2*a*z*cos(w)+a^2) for a^n*cos(w*n)"
    
    Note: Return generic integral form if not in table
    Return "integral_form_required"

Process called "apply_convolution_theorem" that takes transform_a as String, transform_b as String, transform_type as String returns String:
    Note: Apply convolution theorem for various transform types
    
    If transform_type equals "laplace":
        Note: L{f*g} = L{f} * L{g}
        Return "(" + transform_a + ") * (" + transform_b + ")"
    
    If transform_type equals "fourier":
        Note: F{f*g} = F{f} * F{g}
        Return "(" + transform_a + ") * (" + transform_b + ")"
    
    If transform_type equals "z_transform":
        Note: Z{f*g} = Z{f} * Z{g}
        Return "(" + transform_a + ") * (" + transform_b + ")"
    
    Return transform_a + " ⊗ " + transform_b

Process called "compute_residues" that takes rational_function as String, poles as List[String], variable as String returns Dictionary[String, String]:
    Note: Compute residues at poles for inverse transform calculations
    Let parsing_context be Dictionary.empty()
    Let parsed_function be SymbolicCore.parse_expression(rational_function, parsing_context)
    Let residue_map be Dictionary.empty()
    
    Note: For each pole, compute the residue
    For Each pole in poles:
        Let pole_expr be SymbolicCore.parse_expression(pole, parsing_context)
        
        Note: For simple pole at z=a, residue = lim(z→a) (z-a)*f(z)
        Let z_minus_a be SymbolicCore.create_binary_operation("-", SymbolicCore.create_symbol(variable, Dictionary.empty()), pole_expr)
        Let residue_expression be SymbolicCore.create_binary_operation("*", z_minus_a, parsed_function)
        
        Note: Take limit as variable approaches pole
        Let residue_at_pole be SymbolicCore.substitute_variable(residue_expression, variable, pole_expr)
        Let residue_string be SymbolicCore.serialize_expression(residue_at_pole, "infix")
        
        Set residue_map to Dictionary.set(residue_map, pole, residue_string)
    
    Return residue_map

Note: =====================================================================
Note: LAPLACE TRANSFORM OPERATIONS
Note: =====================================================================

Process called "laplace_transform" that takes function as String, variable as String, transform_variable as String returns LaplaceTransform:
    Note: Compute Laplace transform L{f(t)} = F(s)
    Let parsing_context be Dictionary.empty()
    Let parsed_function be SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Try lookup in transform table first
    Let transform_result be lookup_transform_table(function, "laplace")
    
    If not String.equals(transform_result, "integral_form_required"):
        Note: Create LaplaceTransform result
        Let result be LaplaceTransform:
            original_function = function
            transformed_function = transform_result
            transform_variable = transform_variable
            original_variable = variable
            region_of_convergence = Dictionary.empty()
            poles = Collections.create_list()
            residues = Dictionary.empty()
        Return result
    Otherwise:
        Note: Use definition integral L{f(t)} = ∫₀^∞ f(t)e^(-st) dt
        Let exponential_term be SymbolicCore.create_function_call("exp", 
            Collections.from_list([SymbolicCore.create_binary_operation("*", 
                SymbolicCore.create_unary_operation("-", SymbolicCore.create_symbol(transform_variable, Dictionary.empty())), 
                SymbolicCore.create_symbol(variable, Dictionary.empty()))]))
        Let integrand be SymbolicCore.create_binary_operation("*", parsed_function, exponential_term)
        
        Let integration_limits be Dictionary.empty()
        Set integration_limits to Dictionary.set(integration_limits, "lower", "0")
        Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
        
        Let integrated_result be evaluate_complex_integral(integrand, variable, integration_limits)
        Let transform_function_str be SymbolicCore.expression_to_string(integrated_result)
        
        Let result be LaplaceTransform:
            original_function = function
            transformed_function = transform_function_str
            transform_variable = transform_variable
            original_variable = variable
            region_of_convergence = Dictionary.empty()
            poles = Collections.create_list()
            residues = Dictionary.empty()
        Return result

Process called "inverse_laplace_transform" that takes transformed_function as String, transform_variable as String, original_variable as String returns String:
    Note: Compute inverse Laplace transform L⁻¹{F(s)} = f(t)
    Let parsing_context be Dictionary.empty()
    Let parsed_transform be SymbolicCore.parse_expression(transformed_function, parsing_context)
    
    Note: Check for common inverse transform patterns
    If String.contains(transformed_function, "1/s"):
        If String.equals(transformed_function, "1/s"):
            Return "1"
        If String.contains(transformed_function, "1/s^2"):
            Return original_variable
        If String.contains(transformed_function, "1/s^"):
            Let power_match be String.extract_between(transformed_function, "1/s^", "")
            If String.is_numeric(power_match):
                Let n be String.to_integer(power_match)
                Let factorial_n_minus_1 be String.from_integer(n - 1) + "!"
                Return original_variable + "^" + String.from_integer(n - 1) + "/" + factorial_n_minus_1
    
    Note: Check for exponential patterns
    If String.contains(transformed_function, "1/(s-"):
        Let parameter be String.extract_between(transformed_function, "1/(s-", ")")
        Return "exp(" + parameter + "*" + original_variable + ")"
    
    Note: Check for trigonometric patterns  
    If String.contains(transformed_function, "/(s^2+"):
        If String.contains(transformed_function, "s/(s^2+"):
            Let omega_squared = String.extract_between(transformed_function, "s/(s^2+", ")")
            Let omega = "sqrt(" + omega_squared + ")"
            Return "cos(" + omega + "*" + original_variable + ")"
        Otherwise:
            Let omega_squared = String.extract_between(transformed_function, "/(s^2+", ")")
            Let omega = "sqrt(" + omega_squared + ")"
            Return "sin(" + omega + "*" + original_variable + ")/" + omega
    
    Note: Use residue calculus for general case
    Note: L⁻¹{F(s)} = (1/(2πi)) ∫(c-i∞)^(c+i∞) F(s)e^(st) ds
    Let exponential_term be SymbolicCore.create_function_call("exp", 
        Collections.from_list([SymbolicCore.create_binary_operation("*", 
            SymbolicCore.create_symbol(transform_variable, Dictionary.empty()),
            SymbolicCore.create_symbol(original_variable, Dictionary.empty()))]))
    Let bromwich_integrand be SymbolicCore.create_binary_operation("*", parsed_transform, exponential_term)
    
    Note: Find poles of F(s) for residue calculation
    Let poles_list be Collections.create_list()
    Note: For rational functions, poles are zeros of denominator
    If SymbolicCore.is_rational_function(parsed_transform):
        Let denominator be SymbolicCore.get_denominator(parsed_transform)
        Let poles_result be SymbolicCore.solve_polynomial_zeros(denominator, transform_variable)
        Set poles_list to poles_result
    
    If Collections.size(poles_list) > 0:
        Note: Use residue theorem
        Let residues_map be compute_residues(transformed_function, poles_list, transform_variable)
        Let result be ""
        For Each pole in poles_list:
            Let residue = Dictionary.get(residues_map, pole)
            Let pole_contribution = "(" + residue + ")*exp(" + pole + "*" + original_variable + ")"
            If String.equals(result, ""):
                Set result to pole_contribution
            Otherwise:
                Set result to result + " + " + pole_contribution
        Return result
    Otherwise:
        Note: Use Bromwich integral with contour integration
        Let integration_limits be Dictionary.empty()
        Set integration_limits to Dictionary.set(integration_limits, "lower", "c-i*infinity")
        Set integration_limits to Dictionary.set(integration_limits, "upper", "c+i*infinity")
        Let bromwich_result be evaluate_complex_integral(bromwich_integrand, transform_variable, integration_limits)
        Let final_result be SymbolicCore.create_binary_operation("*", 
            SymbolicCore.create_rational(1, SymbolicCore.create_binary_operation("*", 
                SymbolicCore.create_number(2), 
                SymbolicCore.create_binary_operation("*", 
                    SymbolicCore.create_symbol("pi", Dictionary.empty()),
                    SymbolicCore.create_symbol("i", Dictionary.empty())))), 
            bromwich_result)
        Return SymbolicCore.expression_to_string(final_result)

Process called "laplace_transform_derivative" that takes function as String, derivative_order as Integer, variable as String, transform_variable as String returns LaplaceTransform:
    Note: Compute Laplace transform of derivative L{f⁽ⁿ⁾(t)}
    Note: Uses property: L{f'(t)} = sL{f(t)} - f(0), L{f''(t)} = s²L{f(t)} - sf(0) - f'(0), etc.
    
    Let parsing_context be Dictionary.empty()
    Let parsed_function be SymbolicCore.parse_expression(function, parsing_context)
    
    Note: First get the Laplace transform of the original function
    Let base_transform be laplace_transform(function, variable, transform_variable)
    Let base_transform_str be base_transform.transformed_function
    
    Note: Apply derivative property formula
    Let s_power = String.from_integer(derivative_order)
    Let main_term = transform_variable + "^" + s_power + "*(" + base_transform_str + ")"
    
    Note: Compute initial condition terms
    Let initial_conditions_sum = ""
    For i from 0 to derivative_order - 1:
        Note: Evaluate f^(i)(0) - the i-th derivative at t=0
        Let derivative_at_zero = ""
        If i == 0:
            Note: f(0)
            Set derivative_at_zero to SymbolicCore.expression_to_string(
                SymbolicCore.substitute_variable(parsed_function, variable, 
                    SymbolicCore.create_number(0)))
        Otherwise:
            Note: f^(i)(0) - compute i-th derivative and evaluate at 0
            Let ith_derivative = Calculus.differentiate(parsed_function, variable, i)
            Set derivative_at_zero to SymbolicCore.expression_to_string(
                SymbolicCore.substitute_variable(ith_derivative, variable, 
                    SymbolicCore.create_number(0)))
        
        Note: Build term s^(n-1-i) * f^(i)(0)
        Let power_of_s = String.from_integer(derivative_order - 1 - i)
        Let term = ""
        If derivative_order - 1 - i == 0:
            Set term to derivative_at_zero
        If derivative_order - 1 - i == 1:
            Set term to transform_variable + "*(" + derivative_at_zero + ")"
        Otherwise:
            Set term to transform_variable + "^" + power_of_s + "*(" + derivative_at_zero + ")"
        
        If String.equals(initial_conditions_sum, ""):
            Set initial_conditions_sum to term
        Otherwise:
            Set initial_conditions_sum to initial_conditions_sum + " + " + term
    
    Note: Final result is s^n * L{f(t)} - [sum of initial condition terms]
    Let result_function = main_term + " - (" + initial_conditions_sum + ")"
    
    Let result be LaplaceTransform:
        original_function = "d^" + String.from_integer(derivative_order) + "/" + "d" + variable + "^" + String.from_integer(derivative_order) + "(" + function + ")"
        transformed_function = result_function
        transform_variable = transform_variable
        original_variable = variable
        region_of_convergence = base_transform.region_of_convergence
        poles = base_transform.poles
        residues = Dictionary.empty()
    
    Return result

Process called "laplace_transform_integral" that takes function as String, variable as String, transform_variable as String returns LaplaceTransform:
    Note: Compute Laplace transform of integral L{∫₀ᵗf(τ)dτ}
    Note: Uses property: L{∫₀ᵗf(τ)dτ} = (1/s) * L{f(t)}
    
    Note: First get the Laplace transform of the original function
    Let base_transform be laplace_transform(function, variable, transform_variable)
    Let base_transform_str be base_transform.transformed_function
    
    Note: Apply integral property: multiply by 1/s
    Let result_function = "(" + base_transform_str + ")/" + transform_variable
    
    Note: Create result with integral notation
    Let integral_function = "integral(0, " + variable + ", " + function + ", tau)"
    
    Let result be LaplaceTransform:
        original_function = integral_function
        transformed_function = result_function  
        transform_variable = transform_variable
        original_variable = variable
        region_of_convergence = base_transform.region_of_convergence
        poles = Collections.create_list()
        residues = Dictionary.empty()
    
    Note: Add pole at s = 0 from the 1/s factor
    Collections.append(result.poles, "0")
    
    Return result

Process called "laplace_shift_theorem" that takes transformed_function as LaplaceTransform, shift_parameter as String returns LaplaceTransform:
    Note: Apply first and second shift theorems
    Note: First shift theorem: L{e^(-at)f(t)} = F(s+a)
    Note: Second shift theorem: L{f(t-a)u(t-a)} = e^(-as)F(s)
    
    Let parsing_context be Dictionary.empty()
    Let shift_param be SymbolicCore.parse_expression(shift_parameter, parsing_context)
    
    Note: Determine which shift theorem to apply based on shift parameter format
    Let original_transform_str = transformed_function.transformed_function
    Let s_var = transformed_function.transform_variable
    Let t_var = transformed_function.original_variable
    
    Note: Check if this is a frequency domain shift (first theorem)
    If String.contains(shift_parameter, "frequency_shift"):
        Note: Apply first shift theorem: replace s with s+a
        Let a_value = String.extract_between(shift_parameter, "frequency_shift:", "")
        Let shifted_transform = String.replace_all(original_transform_str, s_var, "(" + s_var + "+" + a_value + ")")
        
        Let result be LaplaceTransform:
            original_function = "exp(-" + a_value + "*" + t_var + ")*(" + transformed_function.original_function + ")"
            transformed_function = shifted_transform
            transform_variable = s_var
            original_variable = t_var
            region_of_convergence = transformed_function.region_of_convergence
            poles = Collections.create_list()
            residues = Dictionary.empty()
        
        Note: Shift poles by the parameter value
        For Each pole in transformed_function.poles:
            Let shifted_pole = "(" + pole + "-" + a_value + ")"
            Collections.append(result.poles, shifted_pole)
        
        Return result
    Otherwise:
        Note: Apply second shift theorem: multiply by e^(-as)
        Let a_value = shift_parameter
        Let shifted_transform = "exp(-" + a_value + "*" + s_var + ")*(" + original_transform_str + ")"
        
        Let unit_step_function = "u(" + t_var + "-" + a_value + ")"
        Let shifted_original = transformed_function.original_function + "(" + t_var + "-" + a_value + ")*" + unit_step_function
        
        Let result be LaplaceTransform:
            original_function = shifted_original
            transformed_function = shifted_transform
            transform_variable = s_var
            original_variable = t_var
            region_of_convergence = transformed_function.region_of_convergence
            poles = transformed_function.poles
            residues = Dictionary.empty()
        
        Return result

Process called "laplace_convolution_theorem" that takes function_a as String, function_b as String, variable as String, transform_variable as String returns LaplaceTransform:
    Note: Apply convolution theorem L{f*g} = L{f}·L{g}
    Note: Convolution: (f*g)(t) = ∫₀ᵗ f(τ)g(t-τ)dτ
    
    Note: Get Laplace transforms of both functions
    Let transform_a be laplace_transform(function_a, variable, transform_variable)
    Let transform_b be laplace_transform(function_b, variable, transform_variable)
    
    Note: Apply convolution theorem: product in transform domain
    Let product_transform = "(" + transform_a.transformed_function + ") * (" + transform_b.transformed_function + ")"
    
    Note: The original convolution integral
    Let convolution_integral = "integral(0, " + variable + ", " + function_a + "(tau) * " + function_b + "(" + variable + " - tau), tau)"
    
    Note: Combine poles from both transforms
    Let combined_poles be Collections.create_list()
    For Each pole in transform_a.poles:
        Collections.append(combined_poles, pole)
    For Each pole in transform_b.poles:
        Collections.append(combined_poles, pole)
    
    Note: Combine regions of convergence (intersection)
    Let combined_roc be Dictionary.empty()
    Let roc_a = transform_a.region_of_convergence
    Let roc_b = transform_b.region_of_convergence
    
    Note: For intersection, take more restrictive bounds
    If Dictionary.contains_key(roc_a, "real_part_greater_than") and Dictionary.contains_key(roc_b, "real_part_greater_than"):
        Let min_bound_a = Dictionary.get(roc_a, "real_part_greater_than")
        Let min_bound_b = Dictionary.get(roc_b, "real_part_greater_than")
        Let max_bound = "max(" + min_bound_a + ", " + min_bound_b + ")"
        Set combined_roc to Dictionary.set(combined_roc, "real_part_greater_than", max_bound)
    
    Let result be LaplaceTransform:
        original_function = convolution_integral
        transformed_function = product_transform
        transform_variable = transform_variable
        original_variable = variable
        region_of_convergence = combined_roc
        poles = combined_poles
        residues = Dictionary.empty()
    
    Return result

Process called "laplace_solve_ode" that takes ode as String, initial_conditions as Dictionary[String, String], dependent_variable as String, independent_variable as String returns String:
    Note: Solve ODE using Laplace transform method
    Note: Method: 1) Transform ODE to algebraic equation, 2) Solve for Y(s), 3) Inverse transform
    
    Let parsing_context be Dictionary.empty()
    Let s_var = "s"
    Let y_transform = dependent_variable.to_uppercase() + "(" + s_var + ")"
    
    Note: Parse the differential equation
    Let parsed_ode be SymbolicCore.parse_expression(ode, parsing_context)
    
    Note: Transform the ODE term by term
    Note: Replace derivatives with their Laplace transforms
    Let transformed_equation = ode
    
    Note: Handle common patterns for linear ODEs
    Note: y'' -> s²Y(s) - sy(0) - y'(0)
    If String.contains(ode, dependent_variable + "''"):
        Let y0 = Dictionary.get_or_default(initial_conditions, dependent_variable + "(0)", "0")
        Let y_prime0 = Dictionary.get_or_default(initial_conditions, dependent_variable + "'(0)", "0")
        Let second_derivative_transform = s_var + "^2*" + y_transform + " - " + s_var + "*" + y0 + " - " + y_prime0
        Set transformed_equation to String.replace_all(transformed_equation, dependent_variable + "''", second_derivative_transform)
    
    Note: y' -> sY(s) - y(0)
    If String.contains(ode, dependent_variable + "'"):
        Let y0 = Dictionary.get_or_default(initial_conditions, dependent_variable + "(0)", "0")
        Let first_derivative_transform = s_var + "*" + y_transform + " - " + y0
        Set transformed_equation to String.replace_all(transformed_equation, dependent_variable + "'", first_derivative_transform)
    
    Note: y -> Y(s)
    Set transformed_equation to String.replace_all(transformed_equation, dependent_variable, y_transform)
    
    Note: Transform forcing function terms
    Note: Common forcing functions: constants, exponentials, sines, cosines
    If String.contains(transformed_equation, "sin"):
        Note: Replace sin(ωt) with ω/(s²+ω²)
        Let omega_pattern = String.extract_between(transformed_equation, "sin(", "*" + independent_variable + ")")
        If not String.equals(omega_pattern, ""):
            Let sin_transform = omega_pattern + "/(" + s_var + "^2 + " + omega_pattern + "^2)"
            Set transformed_equation to String.replace_all(transformed_equation, 
                "sin(" + omega_pattern + "*" + independent_variable + ")", sin_transform)
    
    If String.contains(transformed_equation, "cos"):
        Note: Replace cos(ωt) with s/(s²+ω²)
        Let omega_pattern = String.extract_between(transformed_equation, "cos(", "*" + independent_variable + ")")
        If not String.equals(omega_pattern, ""):
            Let cos_transform = s_var + "/(" + s_var + "^2 + " + omega_pattern + "^2)"
            Set transformed_equation to String.replace_all(transformed_equation, 
                "cos(" + omega_pattern + "*" + independent_variable + ")", cos_transform)
    
    If String.contains(transformed_equation, "exp"):
        Note: Replace e^(at) with 1/(s-a)
        Let a_pattern = String.extract_between(transformed_equation, "exp(", "*" + independent_variable + ")")
        If not String.equals(a_pattern, ""):
            Let exp_transform = "1/(" + s_var + " - " + a_pattern + ")"
            Set transformed_equation to String.replace_all(transformed_equation, 
                "exp(" + a_pattern + "*" + independent_variable + ")", exp_transform)
    
    Note: Replace constant terms with their transforms
    Set transformed_equation to String.replace_all(transformed_equation, "1", "1/" + s_var)
    Set transformed_equation to String.replace_all(transformed_equation, independent_variable, "1/" + s_var + "^2")
    
    Note: Now solve for Y(s) algebraically
    Note: Rearrange equation to isolate Y(s)
    Let equation_parts = String.split(transformed_equation, "=")
    If List.size(equation_parts) == 2:
        Let left_side = List.get(equation_parts, 0)
        Let right_side = List.get(equation_parts, 1)
        
        Note: Extract coefficient of Y(s) from left side
        Let y_coefficient = ""
        Let remaining_left = ""
        
        Note: Simple pattern matching for linear coefficient extraction
        If String.contains(left_side, y_transform):
            Note: Extract pattern like (s²+as+b)*Y(s)
            Set y_coefficient to String.replace_all(left_side, "*" + y_transform, "")
            Set y_coefficient to String.replace_all(y_coefficient, y_transform, "1")
        Otherwise:
            Set y_coefficient to "1"
            Set remaining_left to left_side
        
        Note: Solve: Y(s) = (right_side - remaining_left) / y_coefficient
        Let y_s_solution = ""
        If String.equals(remaining_left, ""):
            Set y_s_solution to "(" + right_side + ")/(" + y_coefficient + ")"
        Otherwise:
            Set y_s_solution to "(" + right_side + " - (" + remaining_left + "))/(" + y_coefficient + ")"
        
        Note: Take inverse Laplace transform to get solution y(t)
        Let solution = inverse_laplace_transform(y_s_solution, s_var, independent_variable)
        Return solution
    Otherwise:
        Note: Could not parse equation format
        Return "Unable to solve ODE: equation format not recognized"

Note: =====================================================================
Note: FOURIER TRANSFORM OPERATIONS
Note: =====================================================================

Process called "continuous_fourier_transform" that takes function as String, time_variable as String, frequency_variable as String returns FourierTransform:
    Note: Compute continuous Fourier transform F{f(t)} = F(ω)
    Note: F(ω) = ∫_{-∞}^{∞} f(t) e^{-iωt} dt
    
    Let parsing_context be Dictionary.empty()
    Let parsed_function be SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Try lookup in transform table first
    Let transform_result be lookup_transform_table(function, "fourier")
    
    If not String.equals(transform_result, "integral_form_required"):
        Note: Create FourierTransform result from table lookup
        Let result be FourierTransform:
            original_function = function
            transformed_function = transform_result
            frequency_variable = frequency_variable
            time_variable = time_variable
            transform_type = "continuous"
            normalization = "standard"
            symmetry_properties = Dictionary.empty()
        
        Note: Set basic symmetry properties
        Set result.symmetry_properties to Dictionary.set(result.symmetry_properties, "hermitian_symmetry", true)
        
        Return result
    Otherwise:
        Note: Use definition integral F(ω) = ∫_{-∞}^{∞} f(t) e^{-iωt} dt
        Let complex_exponential be SymbolicCore.create_function_call("exp", 
            Collections.from_list([SymbolicCore.create_binary_operation("*",
                SymbolicCore.create_binary_operation("*",
                    SymbolicCore.create_symbol("i", Dictionary.empty()),
                    SymbolicCore.create_unary_operation("-", SymbolicCore.create_symbol(frequency_variable, Dictionary.empty()))),
                SymbolicCore.create_symbol(time_variable, Dictionary.empty()))]))
        
        Let fourier_integrand be SymbolicCore.create_binary_operation("*", parsed_function, complex_exponential)
        
        Let integration_limits be Dictionary.empty()
        Set integration_limits to Dictionary.set(integration_limits, "lower", "-infinity")
        Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
        
        Let integrated_result be evaluate_complex_integral(fourier_integrand, time_variable, integration_limits)
        Let transform_function_str be SymbolicCore.expression_to_string(integrated_result)
        
        Note: Analyze symmetry properties
        Let symmetry_props be Dictionary.empty()
        Set symmetry_props to Dictionary.set(symmetry_props, "hermitian_symmetry", true)
        
        Note: Check if function is real-valued for additional symmetries
        If SymbolicCore.is_real_valued(parsed_function):
            Set symmetry_props to Dictionary.set(symmetry_props, "real_input", true)
            Set symmetry_props to Dictionary.set(symmetry_props, "conjugate_symmetry", true)
        
        Note: Check if function is even or odd
        If SymbolicCore.is_even_function(parsed_function, time_variable):
            Set symmetry_props to Dictionary.set(symmetry_props, "even_function", true)
            Set symmetry_props to Dictionary.set(symmetry_props, "real_transform", true)
        
        If SymbolicCore.is_odd_function(parsed_function, time_variable):
            Set symmetry_props to Dictionary.set(symmetry_props, "odd_function", true)
            Set symmetry_props to Dictionary.set(symmetry_props, "imaginary_transform", true)
        
        Let result be FourierTransform:
            original_function = function
            transformed_function = transform_function_str
            frequency_variable = frequency_variable
            time_variable = time_variable
            transform_type = "continuous"
            normalization = "standard"
            symmetry_properties = symmetry_props
        
        Return result

Process called "inverse_fourier_transform" that takes transformed_function as String, frequency_variable as String, time_variable as String returns String:
    Note: Compute inverse Fourier transform F⁻¹{F(ω)} = f(t)
    Note: f(t) = (1/2π) ∫_{-∞}^{∞} F(ω) e^{iωt} dω
    
    Let parsing_context be Dictionary.empty()
    Let parsed_transform be SymbolicCore.parse_expression(transformed_function, parsing_context)
    
    Note: Check for common inverse patterns first
    If String.contains(transformed_function, "delta"):
        If String.contains(transformed_function, "2*pi*delta"):
            Return "1"
        If String.contains(transformed_function, "delta(" + frequency_variable + "-"):
            Let freq_shift = String.extract_between(transformed_function, "delta(" + frequency_variable + "-", ")")
            Return "exp(i*" + freq_shift + "*" + time_variable + ")"
        If String.contains(transformed_function, "delta(" + frequency_variable + "+"):
            Let freq_shift = String.extract_between(transformed_function, "delta(" + frequency_variable + "+", ")")
            Return "exp(-i*" + freq_shift + "*" + time_variable + ")"
    
    Note: Check for Gaussian patterns
    If String.contains(transformed_function, "exp(-" + frequency_variable + "^2"):
        Return "sqrt(pi)*exp(-" + time_variable + "^2/4)"
    
    Note: Check for rectangular patterns
    If String.contains(transformed_function, "sinc"):
        Return "rect(" + time_variable + ")"
    
    Note: Use definition integral for general case
    Note: f(t) = (1/2π) ∫_{-∞}^{∞} F(ω) e^{iωt} dω
    Let complex_exponential be SymbolicCore.create_function_call("exp", 
        Collections.from_list([SymbolicCore.create_binary_operation("*",
            SymbolicCore.create_binary_operation("*",
                SymbolicCore.create_symbol("i", Dictionary.empty()),
                SymbolicCore.create_symbol(frequency_variable, Dictionary.empty())),
            SymbolicCore.create_symbol(time_variable, Dictionary.empty())))))
    
    Let inverse_integrand be SymbolicCore.create_binary_operation("*", parsed_transform, complex_exponential)
    
    Let integration_limits be Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "-infinity")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
    
    Let integrated_result be evaluate_complex_integral(inverse_integrand, frequency_variable, integration_limits)
    
    Note: Apply normalization factor 1/(2π)
    Let pi_symbol = SymbolicCore.create_symbol("pi", Dictionary.empty())
    Let two_pi = SymbolicCore.create_binary_operation("*", SymbolicCore.create_number(2), pi_symbol)
    Let normalization = SymbolicCore.create_rational(1, two_pi)
    Let final_result = SymbolicCore.create_binary_operation("*", normalization, integrated_result)
    
    Return SymbolicCore.expression_to_string(final_result)

Process called "discrete_fourier_transform" that takes sequence as List[String], transform_length as Integer returns List[String]:
    Note: Compute discrete Fourier transform (DFT)
    Note: X[k] = Σ_{n=0}^{N-1} x[n] * e^{-i2πkn/N}
    
    Let result_sequence be Collections.create_list()
    Let N = transform_length
    Let parsing_context be Dictionary.empty()
    
    Note: Compute DFT for each frequency bin k
    For k from 0 to N - 1:
        Let dft_sum = "0"
        
        Note: Sum over all time samples n
        For n from 0 to Collections.size(sequence) - 1:
            If n < N:
                Let x_n = Collections.get(sequence, n)
                
                Note: Compute exponential term e^{-i2πkn/N}
                Let angle = "-2*pi*" + String.from_integer(k) + "*" + String.from_integer(n) + "/" + String.from_integer(N)
                Let exp_term = "exp(i*" + angle + ")"
                
                Note: Compute x[n] * e^{-i2πkn/N}
                Let term = "(" + x_n + ") * (" + exp_term + ")"
                
                If String.equals(dft_sum, "0"):
                    Set dft_sum to term
                Otherwise:
                    Set dft_sum to dft_sum + " + " + term
        
        Collections.append(result_sequence, dft_sum)
    
    Return result_sequence

Process called "fast_fourier_transform_symbolic" that takes sequence as List[String] returns List[String]:
    Note: Symbolic FFT algorithm for power-of-2 sequences
    Note: Divide-and-conquer algorithm: X[k] = E[k] + W_N^k * O[k]
    
    Let N = Collections.size(sequence)
    
    Note: Base case: single element
    If N == 1:
        Return sequence
    
    Note: Verify N is power of 2
    If not is_power_of_two(N):
        Note: Fallback to regular DFT
        Return discrete_fourier_transform(sequence, N)
    
    Note: Divide into even and odd indexed elements
    Let even_sequence = Collections.create_list()
    Let odd_sequence = Collections.create_list()
    
    For i from 0 to N - 1:
        If i % 2 == 0:
            Collections.append(even_sequence, Collections.get(sequence, i))
        Otherwise:
            Collections.append(odd_sequence, Collections.get(sequence, i))
    
    Note: Recursively compute FFT of even and odd parts
    Let even_fft = fast_fourier_transform_symbolic(even_sequence)
    Let odd_fft = fast_fourier_transform_symbolic(odd_sequence)
    
    Note: Combine results using butterfly operation
    Let result_sequence = Collections.create_list()
    Let half_N = N / 2
    
    For k from 0 to half_N - 1:
        Note: Twiddle factor W_N^k = e^{-i2πk/N}
        Let twiddle_angle = "-2*pi*" + String.from_integer(k) + "/" + String.from_integer(N)
        Let twiddle_factor = "exp(i*" + twiddle_angle + ")"
        
        Let even_term = Collections.get(even_fft, k)
        Let odd_term = Collections.get(odd_fft, k)
        
        Note: X[k] = E[k] + W_N^k * O[k]
        Let first_half = "(" + even_term + ") + (" + twiddle_factor + ") * (" + odd_term + ")"
        Collections.append(result_sequence, first_half)
        
        Note: X[k + N/2] = E[k] - W_N^k * O[k]
        Let second_half = "(" + even_term + ") - (" + twiddle_factor + ") * (" + odd_term + ")"
        Collections.append(result_sequence, second_half)
    
    Return result_sequence

Process called "fourier_transform_derivative" that takes function as String, derivative_order as Integer, time_variable as String, frequency_variable as String returns FourierTransform:
    Note: Compute Fourier transform of derivative F{f⁽ⁿ⁾(t)}
    Note: Property: F{f'(t)} = iω F{f(t)}, F{f''(t)} = (iω)² F{f(t)}, etc.
    
    Note: First get the Fourier transform of the original function
    Let base_transform = continuous_fourier_transform(function, time_variable, frequency_variable)
    Let base_transform_str = base_transform.transformed_function
    
    Note: Apply derivative property: multiply by (iω)^n
    Let i_omega_power = "(i*" + frequency_variable + ")^" + String.from_integer(derivative_order)
    Let result_function = "(" + i_omega_power + ") * (" + base_transform_str + ")"
    
    Note: Create derivative notation for original function
    Let derivative_notation = "d^" + String.from_integer(derivative_order) + "/d" + time_variable + "^" + String.from_integer(derivative_order) + "(" + function + ")"
    
    Let result = FourierTransform:
        original_function = derivative_notation
        transformed_function = result_function
        frequency_variable = frequency_variable
        time_variable = time_variable
        transform_type = "continuous"
        normalization = base_transform.normalization
        symmetry_properties = base_transform.symmetry_properties
    
    Return result

Process called "fourier_shift_theorem" that takes transformed_function as FourierTransform, shift_parameter as String returns FourierTransform:
    Note: Apply time and frequency shift theorems
    Note: Time shift: F{f(t-a)} = e^{-iωa} F(ω)
    Note: Frequency shift: F{e^{iω_0 t} f(t)} = F(ω-ω_0)
    
    Let original_transform_str = transformed_function.transformed_function
    Let omega_var = transformed_function.frequency_variable
    Let t_var = transformed_function.time_variable
    
    Note: Determine which shift theorem to apply
    If String.contains(shift_parameter, "time_shift:"):
        Note: Apply time shift theorem
        Let a_value = String.extract_between(shift_parameter, "time_shift:", "")
        Let phase_factor = "exp(-i*" + omega_var + "*" + a_value + ")"
        Let shifted_transform = "(" + phase_factor + ") * (" + original_transform_str + ")"
        
        Let shifted_original = transformed_function.original_function + "(" + t_var + "-" + a_value + ")"
        
        Let result = FourierTransform:
            original_function = shifted_original
            transformed_function = shifted_transform
            frequency_variable = omega_var
            time_variable = t_var
            transform_type = transformed_function.transform_type
            normalization = transformed_function.normalization
            symmetry_properties = transformed_function.symmetry_properties
        
        Return result
    Otherwise:
        Note: Apply frequency shift theorem
        Let omega_0 = shift_parameter
        Let shifted_transform = String.replace_all(original_transform_str, omega_var, "(" + omega_var + "-" + omega_0 + ")")
        
        Let modulated_original = "exp(i*" + omega_0 + "*" + t_var + ") * (" + transformed_function.original_function + ")"
        
        Let result = FourierTransform:
            original_function = modulated_original
            transformed_function = shifted_transform
            frequency_variable = omega_var
            time_variable = t_var
            transform_type = transformed_function.transform_type
            normalization = transformed_function.normalization
            symmetry_properties = transformed_function.symmetry_properties
        
        Return result

Process called "fourier_convolution_theorem" that takes function_a as String, function_b as String, variable as String returns String:
    Note: Apply convolution theorem F{f*g} = F{f}·F{g}
    Note: Also multiplication theorem F{f·g} = (1/2π) F{f}*F{g}
    
    Note: Get Fourier transforms of both functions
    Let transform_a = continuous_fourier_transform(function_a, variable, "omega")
    Let transform_b = continuous_fourier_transform(function_b, variable, "omega")
    
    Note: Apply convolution theorem: product in frequency domain
    Let product_transform = "(" + transform_a.transformed_function + ") * (" + transform_b.transformed_function + ")"
    
    Note: The convolution in time domain
    Let convolution_integral = "integral(-infinity, infinity, " + function_a + "(tau) * " + function_b + "(" + variable + " - tau), tau)"
    
    Note: Take inverse Fourier transform to get time domain result
    Let time_domain_result = inverse_fourier_transform(product_transform, "omega", variable)
    
    Return time_domain_result

Process called "parsevals_theorem" that takes function as String, variable as String returns String:
    Note: Apply Parseval's energy conservation theorem
    Note: ∫_{-∞}^{∞} |f(t)|² dt = (1/2π) ∫_{-∞}^{∞} |F(ω)|² dω
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Get the Fourier transform
    Let fourier_transform = continuous_fourier_transform(function, variable, "omega")
    Let F_omega = fourier_transform.transformed_function
    
    Note: Compute |f(t)|^2
    Let f_squared_magnitude = "abs(" + function + ")^2"
    
    Note: Time domain energy integral
    Let time_energy_limits = Dictionary.empty()
    Set time_energy_limits to Dictionary.set(time_energy_limits, "lower", "-infinity")
    Set time_energy_limits to Dictionary.set(time_energy_limits, "upper", "infinity")
    
    Let time_energy_integrand = SymbolicCore.parse_expression(f_squared_magnitude, parsing_context)
    Let time_energy = evaluate_complex_integral(time_energy_integrand, variable, time_energy_limits)
    
    Note: Frequency domain energy integral
    Let F_squared_magnitude = "abs(" + F_omega + ")^2"
    Let freq_energy_integrand = SymbolicCore.parse_expression(F_squared_magnitude, parsing_context)
    Let freq_energy_limits = Dictionary.empty()
    Set freq_energy_limits to Dictionary.set(freq_energy_limits, "lower", "-infinity")
    Set freq_energy_limits to Dictionary.set(freq_energy_limits, "upper", "infinity")
    
    Let freq_energy = evaluate_complex_integral(freq_energy_integrand, "omega", freq_energy_limits)
    
    Note: Apply normalization factor 1/(2π)
    Let pi_symbol = SymbolicCore.create_symbol("pi", Dictionary.empty())
    Let two_pi = SymbolicCore.create_binary_operation("*", SymbolicCore.create_number(2), pi_symbol)
    Let normalization = SymbolicCore.create_rational(1, two_pi)
    Let normalized_freq_energy = SymbolicCore.create_binary_operation("*", normalization, freq_energy)
    
    Note: Return energy conservation equation
    Let time_energy_str = SymbolicCore.expression_to_string(time_energy)
    Let freq_energy_str = SymbolicCore.expression_to_string(normalized_freq_energy)
    
    Return time_energy_str + " = " + freq_energy_str

Note: =====================================================================
Note: Z-TRANSFORM OPERATIONS
Note: =====================================================================

Process called "z_transform" that takes sequence as List[String], transform_variable as String returns ZTransform:
    Note: Compute Z-transform Z{x[n]} = X(z)
    Note: X(z) = Σ_{n=0}^{∞} x[n] z^{-n}
    
    Let result_sum = "0"
    Let sequence_size = Collections.size(sequence)
    
    Note: Check for common patterns in transform table first
    If sequence_size > 0:
        Let first_element = Collections.get(sequence, 0)
        Let pattern_result = lookup_transform_table(first_element, "z_transform")
        
        If not String.equals(pattern_result, "integral_form_required") and sequence_size <= 3:
            Note: Use table lookup for simple sequences
            Let result = ZTransform:
                sequence = sequence
                transformed_function = pattern_result
                transform_variable = transform_variable
                region_of_convergence = Dictionary.empty()
                poles = Collections.create_list()
                zeros = Collections.create_list()
            
            Note: Set basic ROC
            Set result.region_of_convergence to Dictionary.set(result.region_of_convergence, "magnitude_greater_than", "1")
            
            Return result
    
    Note: Compute Z-transform using definition
    For n from 0 to sequence_size - 1:
        Let x_n = Collections.get(sequence, n)
        
        Note: Skip zero terms
        If not String.equals(x_n, "0"):
            Let term = ""
            If n == 0:
                Set term to x_n
            If n == 1:
                Set term to "(" + x_n + ")/" + transform_variable
            Otherwise:
                Set term to "(" + x_n + ")/" + transform_variable + "^" + String.from_integer(n)
            
            If String.equals(result_sum, "0"):
                Set result_sum to term
            Otherwise:
                Set result_sum to result_sum + " + " + term
    
    Note: Analyze poles and zeros
    Let poles_list = Collections.create_list()
    Let zeros_list = Collections.create_list()
    
    Note: For finite sequences, primary poles are at z=0
    If sequence_size > 1:
        For i from 1 to sequence_size - 1:
            Collections.append(poles_list, "0")
    
    Note: Determine ROC based on sequence type
    Let roc = Dictionary.empty()
    Set roc to Dictionary.set(roc, "magnitude_greater_than", "0")
    
    Let result = ZTransform:
        sequence = sequence
        transformed_function = result_sum
        transform_variable = transform_variable
        region_of_convergence = roc
        poles = poles_list
        zeros = zeros_list
    
    Return result

Process called "inverse_z_transform" that takes transformed_function as String, transform_variable as String returns List[String]:
    Note: Compute inverse Z-transform Z⁻¹{X(z)} = x[n]
    Note: x[n] = (1/2πi) ∮ |z|=r X(z) z^{n-1} dz (contour integral)
    
    Let parsing_context = Dictionary.empty()
    Let parsed_transform = SymbolicCore.parse_expression(transformed_function, parsing_context)
    Let sequence_result = Collections.create_list()
    
    Note: Check for simple rational function patterns
    If String.contains(transformed_function, "z/(z-"):
        Note: Pattern z/(z-a) -> a^n
        Let a_value = String.extract_between(transformed_function, "z/(z-", ")")
        
        Note: Generate sequence for reasonable length
        For n from 0 to 9:
            If String.equals(a_value, "1"):
                Collections.append(sequence_result, "1")
            Otherwise:
                Let term = a_value + "^" + String.from_integer(n)
                Collections.append(sequence_result, term)
        
        Return sequence_result
    
    If String.contains(transformed_function, "1/(z-"):
        Note: Pattern 1/(z-a) -> a^n / z
        Let a_value = String.extract_between(transformed_function, "1/(z-", ")")
        
        Collections.append(sequence_result, "0") Note: n=0 term
        For n from 1 to 9:
            Let term = a_value + "^" + String.from_integer(n - 1)
            Collections.append(sequence_result, term)
        
        Return sequence_result
    
    If String.contains(transformed_function, "z/(z-1)^2"):
        Note: Pattern z/(z-1)^2 -> n (unit ramp)
        For n from 0 to 9:
            Collections.append(sequence_result, String.from_integer(n))
        
        Return sequence_result
    
    Note: Use partial fraction decomposition for complex rational functions
    If SymbolicCore.is_rational_function(parsed_transform):
        Let numerator = SymbolicCore.get_numerator(parsed_transform)
        Let denominator = SymbolicCore.get_denominator(parsed_transform)
        
        Note: Find poles (zeros of denominator)
        Let poles_list = SymbolicCore.solve_polynomial_zeros(denominator, transform_variable)
        
        If Collections.size(poles_list) > 0:
            Note: Use residue method for each pole
            Let residues_map = compute_residues(transformed_function, poles_list, transform_variable)
            
            Note: Generate sequence using residue formula
            For n from 0 to 9:
                Let x_n = "0"
                
                For Each pole in poles_list:
                    Let residue = Dictionary.get(residues_map, pole)
                    Let pole_contribution = "(" + residue + ")*" + pole + "^" + String.from_integer(n)
                    
                    If String.equals(x_n, "0"):
                        Set x_n to pole_contribution
                    Otherwise:
                        Set x_n to x_n + " + " + pole_contribution
                
                Collections.append(sequence_result, x_n)
            
            Return sequence_result
    
    Note: Fallback to power series expansion
    Note: Extract coefficients of z^{-n} terms
    Let power_series = SymbolicCore.expand_power_series(parsed_transform, transform_variable, 10)
    
    For n from 0 to 9:
        Let coefficient = SymbolicCore.get_coefficient(power_series, transform_variable, -n)
        Let coeff_str = SymbolicCore.expression_to_string(coefficient)
        Collections.append(sequence_result, coeff_str)
    
    Return sequence_result

Process called "z_transform_shift" that takes sequence as List[String], shift_amount as Integer, transform_variable as String returns ZTransform:
    Note: Compute Z-transform of shifted sequence
    Note: Right shift: Z{x[n-k]} = z^{-k} X(z) + Σ initial conditions
    Note: Left shift: Z{x[n+k]} = z^k [X(z) - Σ_{n=0}^{k-1} x[n]z^{-n}]
    
    Note: Get Z-transform of original sequence
    Let base_transform = z_transform(sequence, transform_variable)
    Let X_z = base_transform.transformed_function
    
    If shift_amount > 0:
        Note: Left shift (advance): x[n+k]
        Let z_power = transform_variable + "^" + String.from_integer(shift_amount)
        
        Note: Compute initial condition terms to subtract
        Let initial_terms = "0"
        For n from 0 to shift_amount - 1:
            If n < Collections.size(sequence):
                Let x_n = Collections.get(sequence, n)
                Let term = ""
                If n == 0:
                    Set term to x_n
                If n == 1:
                    Set term to "(" + x_n + ")/" + transform_variable
                Otherwise:
                    Set term to "(" + x_n + ")/" + transform_variable + "^" + String.from_integer(n)
                
                If String.equals(initial_terms, "0"):
                    Set initial_terms to term
                Otherwise:
                    Set initial_terms to initial_terms + " + " + term
        
        Let shifted_transform = ""
        If String.equals(initial_terms, "0"):
            Set shifted_transform to z_power + "*(" + X_z + ")"
        Otherwise:
            Set shifted_transform to z_power + "*((" + X_z + ") - (" + initial_terms + "))"
        
        Note: Create shifted sequence representation
        Let shifted_sequence = Collections.create_list()
        For i from shift_amount to Collections.size(sequence) + shift_amount - 1:
            Let original_index = i - shift_amount
            If original_index < Collections.size(sequence):
                Collections.append(shifted_sequence, Collections.get(sequence, original_index))
        
        Let result = ZTransform:
            sequence = shifted_sequence
            transformed_function = shifted_transform
            transform_variable = transform_variable
            region_of_convergence = base_transform.region_of_convergence
            poles = base_transform.poles
            zeros = base_transform.zeros
        
        Return result
    Otherwise:
        Note: Right shift (delay): x[n-k] where k = |shift_amount|
        Let k = abs(shift_amount)
        Let z_power = transform_variable + "^" + String.from_integer(-k)
        Let shifted_transform = "(" + z_power + ")*(" + X_z + ")"
        
        Note: Add zeros for the delay
        Let shifted_sequence = Collections.create_list()
        For i from 0 to k - 1:
            Collections.append(shifted_sequence, "0")
        For Each element in sequence:
            Collections.append(shifted_sequence, element)
        
        Note: Add additional poles at z=0
        Let new_poles = Collections.create_list()
        For Each pole in base_transform.poles:
            Collections.append(new_poles, pole)
        For i from 0 to k - 1:
            Collections.append(new_poles, "0")
        
        Let result = ZTransform:
            sequence = shifted_sequence
            transformed_function = shifted_transform
            transform_variable = transform_variable
            region_of_convergence = base_transform.region_of_convergence
            poles = new_poles
            zeros = base_transform.zeros
        
        Return result

Process called "z_transform_convolution" that takes sequence_a as List[String], sequence_b as List[String], transform_variable as String returns ZTransform:
    Note: Apply convolution theorem for Z-transforms
    Note: Z{x[n]*y[n]} = X(z) * Y(z), where * denotes discrete convolution
    Note: (x*y)[n] = Σ_{k=0}^{n} x[k] y[n-k]
    
    Note: Get Z-transforms of both sequences
    Let transform_a = z_transform(sequence_a, transform_variable)
    Let transform_b = z_transform(sequence_b, transform_variable)
    
    Note: Apply convolution theorem: product in Z-domain
    Let product_transform = "(" + transform_a.transformed_function + ") * (" + transform_b.transformed_function + ")"
    
    Note: Compute discrete convolution sequence
    Let max_length = Collections.size(sequence_a) + Collections.size(sequence_b) - 1
    Let convolution_sequence = Collections.create_list()
    
    For n from 0 to max_length - 1:
        Let conv_sum = "0"
        
        For k from 0 to n:
            If k < Collections.size(sequence_a) and (n - k) < Collections.size(sequence_b):
                Let x_k = Collections.get(sequence_a, k)
                Let y_n_minus_k = Collections.get(sequence_b, n - k)
                
                Let term = "(" + x_k + ") * (" + y_n_minus_k + ")"
                
                If String.equals(conv_sum, "0"):
                    Set conv_sum to term
                Otherwise:
                    Set conv_sum to conv_sum + " + " + term
        
        Collections.append(convolution_sequence, conv_sum)
    
    Note: Combine poles from both transforms
    Let combined_poles = Collections.create_list()
    For Each pole in transform_a.poles:
        Collections.append(combined_poles, pole)
    For Each pole in transform_b.poles:
        Collections.append(combined_poles, pole)
    
    Note: Combine zeros from both transforms
    Let combined_zeros = Collections.create_list()
    For Each zero in transform_a.zeros:
        Collections.append(combined_zeros, zero)
    For Each zero in transform_b.zeros:
        Collections.append(combined_zeros, zero)
    
    Note: Determine combined ROC (intersection)
    Let combined_roc = Dictionary.empty()
    Let roc_a = transform_a.region_of_convergence
    Let roc_b = transform_b.region_of_convergence
    
    If Dictionary.contains_key(roc_a, "magnitude_greater_than") and Dictionary.contains_key(roc_b, "magnitude_greater_than"):
        Let bound_a = Dictionary.get(roc_a, "magnitude_greater_than")
        Let bound_b = Dictionary.get(roc_b, "magnitude_greater_than")
        Let max_bound = "max(" + bound_a + ", " + bound_b + ")"
        Set combined_roc to Dictionary.set(combined_roc, "magnitude_greater_than", max_bound)
    
    Let result = ZTransform:
        sequence = convolution_sequence
        transformed_function = product_transform
        transform_variable = transform_variable
        region_of_convergence = combined_roc
        poles = combined_poles
        zeros = combined_zeros
    
    Return result

Process called "z_transform_difference_equation" that takes difference_equation as String, initial_conditions as Dictionary[String, String], sequence_variable as String returns List[String]:
    Note: Solve difference equation using Z-transform
    Note: Method: 1) Transform equation, 2) Solve for Y(z), 3) Inverse transform
    
    Let parsing_context = Dictionary.empty()
    Let z_var = "z"
    Let Y_z = sequence_variable.to_uppercase() + "(" + z_var + ")"
    
    Note: Transform the difference equation term by term
    Let transformed_equation = difference_equation
    
    Note: Handle common difference equation patterns
    Note: y[n+1] -> z*Y(z) - z*y[0]
    If String.contains(difference_equation, sequence_variable + "[n+1]"):
        Let y_0 = Dictionary.get_or_default(initial_conditions, sequence_variable + "[0]", "0")
        Let first_advance_transform = z_var + "*" + Y_z + " - " + z_var + "*" + y_0
        Set transformed_equation to String.replace_all(transformed_equation, sequence_variable + "[n+1]", first_advance_transform)
    
    Note: y[n+2] -> z^2*Y(z) - z^2*y[0] - z*y[1]
    If String.contains(difference_equation, sequence_variable + "[n+2]"):
        Let y_0 = Dictionary.get_or_default(initial_conditions, sequence_variable + "[0]", "0")
        Let y_1 = Dictionary.get_or_default(initial_conditions, sequence_variable + "[1]", "0")
        Let second_advance_transform = z_var + "^2*" + Y_z + " - " + z_var + "^2*" + y_0 + " - " + z_var + "*" + y_1
        Set transformed_equation to String.replace_all(transformed_equation, sequence_variable + "[n+2]", second_advance_transform)
    
    Note: y[n-1] -> (1/z)*Y(z)
    If String.contains(difference_equation, sequence_variable + "[n-1]"):
        Let first_delay_transform = "(1/" + z_var + ")*" + Y_z
        Set transformed_equation to String.replace_all(transformed_equation, sequence_variable + "[n-1]", first_delay_transform)
    
    Note: y[n] -> Y(z)
    Set transformed_equation to String.replace_all(transformed_equation, sequence_variable + "[n]", Y_z)
    
    Note: Transform forcing sequence terms
    Note: Common patterns: unit step, exponential, sinusoidal
    If String.contains(transformed_equation, "u[n]"):
        Note: Unit step: u[n] -> z/(z-1)
        Set transformed_equation to String.replace_all(transformed_equation, "u[n]", "z/(z-1)")
    
    If String.contains(transformed_equation, "a^n"):
        Note: Exponential: a^n -> z/(z-a)
        Let a_pattern = String.extract_between(transformed_equation, "", "^n")
        If not String.equals(a_pattern, "") and not String.contains(a_pattern, "["):
            Let exp_transform = "z/(z-" + a_pattern + ")"
            Set transformed_equation to String.replace_all(transformed_equation, a_pattern + "^n", exp_transform)
    
    Note: Solve for Y(z) algebraically
    Let equation_parts = String.split(transformed_equation, "=")
    If List.size(equation_parts) == 2:
        Let left_side = List.get(equation_parts, 0)
        Let right_side = List.get(equation_parts, 1)
        
        Note: Extract coefficient of Y(z)
        Let y_coefficient = ""
        Let remaining_left = ""
        
        If String.contains(left_side, Y_z):
            Note: Extract coefficient pattern
            Set y_coefficient to String.replace_all(left_side, "*" + Y_z, "")
            Set y_coefficient to String.replace_all(y_coefficient, Y_z, "1")
        Otherwise:
            Set y_coefficient to "1"
            Set remaining_left to left_side
        
        Note: Solve: Y(z) = (right_side - remaining_left) / y_coefficient
        Let y_z_solution = ""
        If String.equals(remaining_left, ""):
            Set y_z_solution to "(" + right_side + ")/" + "(" + y_coefficient + ")"
        Otherwise:
            Set y_z_solution to "(" + right_side + " - (" + remaining_left + "))/" + "(" + y_coefficient + ")"
        
        Note: Take inverse Z-transform to get sequence solution
        Let solution_sequence = inverse_z_transform(y_z_solution, z_var)
        Return solution_sequence
    Otherwise:
        Let error_sequence = Collections.create_list()
        Collections.append(error_sequence, "Unable to solve difference equation: format not recognized")
        Return error_sequence

Process called "partial_fraction_z_transform" that takes rational_function as String, transform_variable as String returns List[Dictionary[String, String]]:
    Note: Decompose Z-transform using partial fractions
    Note: X(z) = N(z)/D(z) = Σ A_i/(z-p_i) + polynomial terms
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(rational_function, parsing_context)
    Let partial_fractions = Collections.create_list()
    
    Note: Verify this is a rational function
    If not SymbolicCore.is_rational_function(parsed_function):
        Let error_fraction = Dictionary.empty()
        Set error_fraction to Dictionary.set(error_fraction, "type", "error")
        Set error_fraction to Dictionary.set(error_fraction, "message", "Input is not a rational function")
        Collections.append(partial_fractions, error_fraction)
        Return partial_fractions
    
    Note: Extract numerator and denominator
    Let numerator = SymbolicCore.get_numerator(parsed_function)
    Let denominator = SymbolicCore.get_denominator(parsed_function)
    
    Note: Find poles (roots of denominator)
    Let poles_list = SymbolicCore.solve_polynomial_zeros(denominator, transform_variable)
    
    Note: Check for polynomial part (if degree(numerator) >= degree(denominator))
    Let num_degree = SymbolicCore.get_polynomial_degree(numerator, transform_variable)
    Let den_degree = SymbolicCore.get_polynomial_degree(denominator, transform_variable)
    
    If num_degree >= den_degree:
        Note: Perform polynomial long division first
        Let division_result = SymbolicCore.polynomial_long_division(numerator, denominator, transform_variable)
        Let quotient = division_result.quotient
        Let remainder = division_result.remainder
        
        Note: Add polynomial part
        Let poly_fraction = Dictionary.empty()
        Set poly_fraction to Dictionary.set(poly_fraction, "type", "polynomial")
        Set poly_fraction to Dictionary.set(poly_fraction, "expression", SymbolicCore.expression_to_string(quotient))
        Collections.append(partial_fractions, poly_fraction)
        
        Note: Continue with remainder/denominator
        Set numerator to remainder
    
    Note: Decompose into partial fractions
    For Each pole in poles_list:
        Note: Calculate residue at each pole
        Let pole_multiplicity = SymbolicCore.get_root_multiplicity(denominator, pole, transform_variable)
        
        For order from 1 to pole_multiplicity:
            Note: For simple poles: A = lim(z→p) (z-p) * F(z)
            Note: For multiple poles: A_k = (1/(k-1)!) * d^(k-1)/dz^(k-1) [(z-p)^m * F(z)]|_{z=p}
            
            Let residue_expression = ""
            If order == 1:
                Note: Simple pole case
                Let z_minus_pole = SymbolicCore.create_binary_operation("-", 
                    SymbolicCore.create_symbol(transform_variable, Dictionary.empty()),
                    SymbolicCore.parse_expression(pole, parsing_context))
                Let residue_function = SymbolicCore.create_binary_operation("*", z_minus_pole, parsed_function)
                Let residue_at_pole = SymbolicCore.substitute_variable(residue_function, transform_variable,
                    SymbolicCore.parse_expression(pole, parsing_context))
                Set residue_expression to SymbolicCore.expression_to_string(residue_at_pole)
            Otherwise:
                Note: Higher order pole case
                Let z_minus_pole_power = SymbolicCore.create_power(
                    SymbolicCore.create_binary_operation("-", 
                        SymbolicCore.create_symbol(transform_variable, Dictionary.empty()),
                        SymbolicCore.parse_expression(pole, parsing_context)),
                    SymbolicCore.create_number(pole_multiplicity))
                Let modified_function = SymbolicCore.create_binary_operation("*", z_minus_pole_power, parsed_function)
                
                Note: Take (order-1)th derivative
                Let derivative_expr = modified_function
                For deriv_order from 1 to order - 1:
                    Set derivative_expr to Calculus.differentiate(derivative_expr, transform_variable, 1)
                
                Note: Apply factorial normalization
                Let factorial_k_minus_1 = factorial(order - 1)
                Let factorial_factor = SymbolicCore.create_rational(1, SymbolicCore.create_number(factorial_k_minus_1))
                Let normalized_expr = SymbolicCore.create_binary_operation("*", factorial_factor, derivative_expr)
                
                Note: Evaluate at the pole
                Let residue_at_pole = SymbolicCore.substitute_variable(normalized_expr, transform_variable,
                    SymbolicCore.parse_expression(pole, parsing_context))
                Set residue_expression to SymbolicCore.expression_to_string(residue_at_pole)
            
            Note: Create partial fraction term
            Let fraction_term = Dictionary.empty()
            Set fraction_term to Dictionary.set(fraction_term, "type", "partial_fraction")
            Set fraction_term to Dictionary.set(fraction_term, "residue", residue_expression)
            Set fraction_term to Dictionary.set(fraction_term, "pole", pole)
            Set fraction_term to Dictionary.set(fraction_term, "order", String.from_integer(order))
            
            If order == 1:
                Set fraction_term to Dictionary.set(fraction_term, "expression", 
                    "(" + residue_expression + ")/" + "(" + transform_variable + "-" + pole + ")")
            Otherwise:
                Set fraction_term to Dictionary.set(fraction_term, "expression", 
                    "(" + residue_expression + ")/" + "(" + transform_variable + "-" + pole + ")^" + String.from_integer(order))
            
            Collections.append(partial_fractions, fraction_term)
    
    Return partial_fractions

Note: =====================================================================
Note: MELLIN TRANSFORM OPERATIONS
Note: =====================================================================

Process called "mellin_transform" that takes function as String, variable as String, transform_variable as String returns String:
    Note: Compute Mellin transform M{f(x)} = F(s)
    Note: F(s) = ∫_0^{∞} f(x) x^{s-1} dx
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Check for common Mellin transform patterns
    If String.contains(function, "exp(-x)"):
        Note: M{e^(-x)} = Γ(s)
        Return "gamma(" + transform_variable + ")"
    
    If String.contains(function, "exp(-ax)"):
        Let a_value = String.extract_between(function, "exp(-", "*" + variable + ")")
        If not String.equals(a_value, ""):
            Note: M{e^(-ax)} = a^(-s) * Γ(s)
            Return "(" + a_value + ")^(-" + transform_variable + ") * gamma(" + transform_variable + ")"
    
    If String.contains(function, "1/(1+x)"):
        Note: M{1/(1+x)} = π/sin(πs) for 0 < Re(s) < 1
        Return "pi/sin(pi*" + transform_variable + ")"
    
    If String.contains(function, "x^n") and String.contains(function, "exp(-x)"):
        Let n_value = String.extract_between(function, variable + "^", " * exp")
        If not String.equals(n_value, ""):
            Note: M{x^n * e^(-x)} = Γ(s+n)
            Return "gamma(" + transform_variable + "+" + n_value + ")"
    
    Note: Use definition integral for general case
    Note: F(s) = ∫_0^{∞} f(x) x^{s-1} dx
    Let s_minus_one = SymbolicCore.create_binary_operation("-", 
        SymbolicCore.create_symbol(transform_variable, Dictionary.empty()),
        SymbolicCore.create_number(1))
    Let x_power_term = SymbolicCore.create_power(
        SymbolicCore.create_symbol(variable, Dictionary.empty()),
        s_minus_one)
    
    Let mellin_integrand = SymbolicCore.create_binary_operation("*", parsed_function, x_power_term)
    
    Let integration_limits = Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "0")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
    
    Let integrated_result = evaluate_complex_integral(mellin_integrand, variable, integration_limits)
    Return SymbolicCore.expression_to_string(integrated_result)

Process called "inverse_mellin_transform" that takes transformed_function as String, transform_variable as String, original_variable as String returns String:
    Note: Compute inverse Mellin transform M⁻¹{F(s)} = f(x)
    Note: f(x) = (1/2πi) ∫_{c-i∞}^{c+i∞} F(s) x^{-s} ds
    
    Let parsing_context = Dictionary.empty()
    Let parsed_transform = SymbolicCore.parse_expression(transformed_function, parsing_context)
    
    Note: Check for common inverse patterns
    If String.contains(transformed_function, "gamma(" + transform_variable + ")"):
        If String.equals(transformed_function, "gamma(" + transform_variable + ")"):
            Return "exp(-" + original_variable + ")"
    
    If String.contains(transformed_function, "gamma(" + transform_variable + "+"):
        Let n_value = String.extract_between(transformed_function, "gamma(" + transform_variable + "+", ")")
        If not String.equals(n_value, ""):
            Return original_variable + "^" + n_value + " * exp(-" + original_variable + ")"
    
    If String.contains(transformed_function, "pi/sin(pi*" + transform_variable + ")"):
        Return "1/(1+" + original_variable + ")"
    
    Note: Use Mellin inversion formula with contour integration
    Note: f(x) = (1/2πi) ∫_{c-i∞}^{c+i∞} F(s) x^{-s} ds
    Let x_power_negative_s = SymbolicCore.create_power(
        SymbolicCore.create_symbol(original_variable, Dictionary.empty()),
        SymbolicCore.create_unary_operation("-", SymbolicCore.create_symbol(transform_variable, Dictionary.empty())))
    
    Let inversion_integrand = SymbolicCore.create_binary_operation("*", parsed_transform, x_power_negative_s)
    
    Let integration_limits = Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "c-i*infinity")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "c+i*infinity")
    
    Let integrated_result = evaluate_complex_integral(inversion_integrand, transform_variable, integration_limits)
    
    Note: Apply normalization factor 1/(2πi)
    Let pi_symbol = SymbolicCore.create_symbol("pi", Dictionary.empty())
    Let two_pi_i = SymbolicCore.create_binary_operation("*",
        SymbolicCore.create_binary_operation("*", SymbolicCore.create_number(2), pi_symbol),
        SymbolicCore.create_symbol("i", Dictionary.empty()))
    Let normalization = SymbolicCore.create_rational(1, two_pi_i)
    Let final_result = SymbolicCore.create_binary_operation("*", normalization, integrated_result)
    
    Return SymbolicCore.expression_to_string(final_result)

Process called "mellin_convolution" that takes function_a as String, function_b as String, variable as String returns String:
    Note: Compute Mellin convolution (f*g)(x) = ∫₀^∞ f(t)g(x/t)dt/t
    Note: Property: M{f*g} = M{f} * M{g} (product in transform domain)
    
    Let parsing_context = Dictionary.empty()
    Let parsed_f = SymbolicCore.parse_expression(function_a, parsing_context)
    Let parsed_g = SymbolicCore.parse_expression(function_b, parsing_context)
    
    Note: Direct computation using definition
    Note: (f*g)(x) = ∫₀^∞ f(t) g(x/t) dt/t
    
    Let t_symbol = SymbolicCore.create_symbol("t", Dictionary.empty())
    Let x_symbol = SymbolicCore.create_symbol(variable, Dictionary.empty())
    
    Note: Create g(x/t) by substituting x/t for the variable in g
    Let x_over_t = SymbolicCore.create_binary_operation("/", x_symbol, t_symbol)
    Let g_of_x_over_t = SymbolicCore.substitute_variable(parsed_g, variable, x_over_t)
    
    Note: Create f(t) by substituting t for the variable in f
    Let f_of_t = SymbolicCore.substitute_variable(parsed_f, variable, t_symbol)
    
    Note: Build integrand: f(t) * g(x/t) / t
    Let product_fg = SymbolicCore.create_binary_operation("*", f_of_t, g_of_x_over_t)
    Let mellin_conv_integrand = SymbolicCore.create_binary_operation("/", product_fg, t_symbol)
    
    Let integration_limits = Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "0")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
    
    Let convolution_result = evaluate_complex_integral(mellin_conv_integrand, "t", integration_limits)
    
    Return SymbolicCore.expression_to_string(convolution_result)

Process called "mellin_parseval_theorem" that takes function_a as String, function_b as String, variable as String returns String:
    Note: Apply Parseval's theorem for Mellin transforms
    Note: ∫₀^∞ f(x) g*(x) x^{-1} dx = (1/2πi) ∫_{c-i∞}^{c+i∞} F(s) G*(1-s) ds
    
    Let parsing_context = Dictionary.empty()
    Let parsed_f = SymbolicCore.parse_expression(function_a, parsing_context)
    Let parsed_g = SymbolicCore.parse_expression(function_b, parsing_context)
    
    Note: Get Mellin transforms of both functions
    Let F_s = mellin_transform(function_a, variable, "s")
    Let G_s = mellin_transform(function_b, variable, "s")
    
    Note: Compute left side: ∫₀^∞ f(x) g*(x) x^{-1} dx
    Let g_conjugate = SymbolicCore.create_function_call("conjugate", Collections.from_list([parsed_g]))
    Let x_inverse = SymbolicCore.create_power(
        SymbolicCore.create_symbol(variable, Dictionary.empty()),
        SymbolicCore.create_number(-1))
    
    Let left_integrand = SymbolicCore.create_binary_operation("*", 
        SymbolicCore.create_binary_operation("*", parsed_f, g_conjugate),
        x_inverse)
    
    Let left_limits = Dictionary.empty()
    Set left_limits to Dictionary.set(left_limits, "lower", "0")
    Set left_limits to Dictionary.set(left_limits, "upper", "infinity")
    
    Let left_integral = evaluate_complex_integral(left_integrand, variable, left_limits)
    Let left_side_str = SymbolicCore.expression_to_string(left_integral)
    
    Note: Compute right side: (1/2πi) ∫_{c-i∞}^{c+i∞} F(s) G*(1-s) ds
    Let one_minus_s = "1-s"
    Let G_one_minus_s = String.replace_all(G_s, "s", "(" + one_minus_s + ")")
    Let G_conjugate_expr = "conjugate(" + G_one_minus_s + ")"
    
    Let right_integrand_str = "(" + F_s + ") * (" + G_conjugate_expr + ")"
    Let right_integrand = SymbolicCore.parse_expression(right_integrand_str, parsing_context)
    
    Let right_limits = Dictionary.empty()
    Set right_limits to Dictionary.set(right_limits, "lower", "c-i*infinity")
    Set right_limits to Dictionary.set(right_limits, "upper", "c+i*infinity")
    
    Let right_integral = evaluate_complex_integral(right_integrand, "s", right_limits)
    
    Note: Apply normalization factor 1/(2πi)
    Let pi_symbol = SymbolicCore.create_symbol("pi", Dictionary.empty())
    Let two_pi_i = SymbolicCore.create_binary_operation("*",
        SymbolicCore.create_binary_operation("*", SymbolicCore.create_number(2), pi_symbol),
        SymbolicCore.create_symbol("i", Dictionary.empty()))
    Let normalization = SymbolicCore.create_rational(1, two_pi_i)
    Let normalized_right = SymbolicCore.create_binary_operation("*", normalization, right_integral)
    Let right_side_str = SymbolicCore.expression_to_string(normalized_right)
    
    Return left_side_str + " = " + right_side_str

Note: =====================================================================
Note: HANKEL TRANSFORM OPERATIONS
Note: =====================================================================

Process called "hankel_transform" that takes function as String, order as String, variable as String, transform_variable as String returns String:
    Note: Compute Hankel transform of order ν
    Note: H_ν{f(r)} = ∫₀^∞ f(r) J_ν(κ r) r dr
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Check for common Hankel transform patterns
    If String.contains(function, "exp(-ar)") and String.equals(order, "0"):
        Let a_value = String.extract_between(function, "exp(-", "*" + variable + ")")
        If not String.equals(a_value, ""):
            Note: H_0{e^(-ar)} = 1/(a^2 + κ^2)^{3/2} for order 0
            Return "1/sqrt((" + a_value + ")^2 + " + transform_variable + "^2)^3"
    
    If String.contains(function, "r^n") and String.contains(function, "exp(-ar^2)"):
        Let n_value = String.extract_between(function, variable + "^", " * exp")
        Let a_value = String.extract_between(function, "exp(-", "*" + variable + "^2)")
        If not String.equals(n_value, "") and not String.equals(a_value, ""):
            Note: Gaussian-type functions have known Hankel transforms
            Return "(" + n_value + "+1)!/2^(" + n_value + "+1) * (" + a_value + ")^(-(" + n_value + "+1)) * exp(-" + transform_variable + "^2/(4*" + a_value + "))"
    
    If String.equals(function, "1") and String.equals(order, "0"):
        Note: H_0{1} = delta(κ) (Dirac delta)
        Return "delta(" + transform_variable + ")"
    
    Note: Use definition integral for general case
    Note: H_ν{f(r)} = ∫₀^∞ f(r) J_ν(κ r) r dr
    Let bessel_function = SymbolicCore.create_function_call("bessel_j", 
        Collections.from_list([
            SymbolicCore.parse_expression(order, parsing_context),
            SymbolicCore.create_binary_operation("*", 
                SymbolicCore.create_symbol(transform_variable, Dictionary.empty()),
                SymbolicCore.create_symbol(variable, Dictionary.empty()))
        ]))
    
    Let r_symbol = SymbolicCore.create_symbol(variable, Dictionary.empty())
    Let hankel_integrand = SymbolicCore.create_binary_operation("*", 
        SymbolicCore.create_binary_operation("*", parsed_function, bessel_function),
        r_symbol)
    
    Let integration_limits = Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "0")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
    
    Let integrated_result = evaluate_complex_integral(hankel_integrand, variable, integration_limits)
    Return SymbolicCore.expression_to_string(integrated_result)

Process called "inverse_hankel_transform" that takes transformed_function as String, order as String, transform_variable as String, original_variable as String returns String:
    Note: Compute inverse Hankel transform
    Note: f(r) = ∫₀^∞ F(κ) J_ν(κ r) κ dκ
    
    Let parsing_context = Dictionary.empty()
    Let parsed_transform = SymbolicCore.parse_expression(transformed_function, parsing_context)
    
    Note: Check for common inverse patterns
    If String.contains(transformed_function, "delta(" + transform_variable + ")") and String.equals(order, "0"):
        Return "1"
    
    If String.contains(transformed_function, "1/sqrt(") and String.contains(transformed_function, "^2 + " + transform_variable + "^2)"):
        Let a_pattern = String.extract_between(transformed_function, "1/sqrt(", "^2 + " + transform_variable + "^2)")
        If not String.equals(a_pattern, "") and String.equals(order, "0"):
            Return "exp(-" + a_pattern + "*" + original_variable + ")"
    
    Note: Use inverse formula for general case
    Note: f(r) = ∫₀^∞ F(κ) J_ν(κ r) κ dκ
    Let bessel_function = SymbolicCore.create_function_call("bessel_j", 
        Collections.from_list([
            SymbolicCore.parse_expression(order, parsing_context),
            SymbolicCore.create_binary_operation("*", 
                SymbolicCore.create_symbol(transform_variable, Dictionary.empty()),
                SymbolicCore.create_symbol(original_variable, Dictionary.empty()))
        ]))
    
    Let kappa_symbol = SymbolicCore.create_symbol(transform_variable, Dictionary.empty())
    Let inverse_integrand = SymbolicCore.create_binary_operation("*", 
        SymbolicCore.create_binary_operation("*", parsed_transform, bessel_function),
        kappa_symbol)
    
    Let integration_limits = Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "0")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
    
    Let integrated_result = evaluate_complex_integral(inverse_integrand, transform_variable, integration_limits)
    Return SymbolicCore.expression_to_string(integrated_result)

Process called "hankel_transform_derivative" that takes function as String, order as String, variable as String, transform_variable as String returns String:
    Note: Compute Hankel transform of derivative
    Note: For radial derivative: H_ν{d/dr f(r)} properties depend on boundary conditions
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Get the Hankel transform of the original function
    Let F_kappa = hankel_transform(function, order, variable, transform_variable)
    
    Note: Apply derivative property for Hankel transforms
    Note: H_ν{d/dr f(r)} = -κ H_{ν±1}{f(r)} + boundary terms
    
    Let nu_plus_1 = String.from_integer(String.to_integer(order) + 1)
    Let nu_minus_1 = String.from_integer(String.to_integer(order) - 1)
    
    Note: For ν > 0: H_ν{df/dr} involves H_{ν-1} and H_{ν+1}
    If String.to_integer(order) > 0:
        Let F_nu_minus_1 = hankel_transform(function, nu_minus_1, variable, transform_variable)
        Let F_nu_plus_1 = hankel_transform(function, nu_plus_1, variable, transform_variable)
        
        Note: Recurrence relation: H_ν{df/dr} = (κ/2)[H_{ν-1}{f} - H_{ν+1}{f}]
        Let result = "(" + transform_variable + "/2) * ((" + F_nu_minus_1 + ") - (" + F_nu_plus_1 + "))"
        Return result
    Otherwise:
        Note: For ν = 0: H_0{df/dr} = -κ H_1{f}
        Let F_nu_1 = hankel_transform(function, "1", variable, transform_variable)
        Return "-" + transform_variable + " * (" + F_nu_1 + ")"

Process called "hankel_convolution_theorem" that takes function_a as String, function_b as String, order as String, variable as String returns String:
    Note: Apply Hankel convolution theorem
    Note: H_ν{f ⊗ g} = H_ν{f} * H_ν{g}, where ⊗ is Hankel convolution
    Note: (f ⊗ g)(r) = ∫₀^∞ ∫₀^{2π} f(ρ) g(√r^2+ρ^2-2rρcosθ) ρ dρ dθ
    
    Note: Get Hankel transforms of both functions
    Let F_kappa = hankel_transform(function_a, order, variable, "kappa")
    Let G_kappa = hankel_transform(function_b, order, variable, "kappa")
    
    Note: Apply convolution theorem: product in transform domain
    Let product_transform = "(" + F_kappa + ") * (" + G_kappa + ")"
    
    Note: The Hankel convolution in the original domain is complex
    Note: For practical purposes, return the time domain result via inverse transform
    Let time_domain_result = inverse_hankel_transform(product_transform, order, "kappa", variable)
    
    Return time_domain_result

Note: =====================================================================
Note: WAVELET TRANSFORM OPERATIONS
Note: =====================================================================

Process called "continuous_wavelet_transform" that takes signal as String, mother_wavelet as String, scale_variable as String, translation_variable as String returns WaveletTransform:
    Note: Compute continuous wavelet transform (CWT)
    Note: W(a,b) = (1/√a) ∫ f(t) ψ*((t-b)/a) dt
    
    Let parsing_context = Dictionary.empty()
    Let parsed_signal = SymbolicCore.parse_expression(signal, parsing_context)
    Let coefficients_dict = Dictionary.empty()
    
    Note: Common mother wavelets and their properties
    Let wavelet_formula = ""
    If String.equals(mother_wavelet, "morlet"):
        Set wavelet_formula to "exp(i*omega_0*t) * exp(-t^2/2)"
    If String.equals(mother_wavelet, "haar"):
        Set wavelet_formula to "rect(t/2) - rect((t-1)/2)"
    If String.equals(mother_wavelet, "mexican_hat"):
        Set wavelet_formula to "(2/sqrt(3)) * pi^(-1/4) * (1-t^2) * exp(-t^2/2)"
    If String.equals(mother_wavelet, "daubechies"):
        Set wavelet_formula to "db4_wavelet(t)" Note: Simplified representation
    Otherwise:
        Set wavelet_formula to mother_wavelet Note: Use custom wavelet function
    
    Note: Generate CWT coefficients for a range of scales and translations
    Let scale_range = Collections.create_list()
    Collections.append(scale_range, "1")
    Collections.append(scale_range, "2")
    Collections.append(scale_range, "4")
    Collections.append(scale_range, "8")
    
    Let translation_range = Collections.create_list()
    Collections.append(translation_range, "0")
    Collections.append(translation_range, "1")
    Collections.append(translation_range, "2")
    Collections.append(translation_range, "3")
    
    For Each scale in scale_range:
        Let scale_dict = Dictionary.empty()
        For Each translation in translation_range:
            Note: Build wavelet function ψ*((t-b)/a)
            Let t_minus_b = "t - " + translation
            Let scaled_arg = "(" + t_minus_b + ")/" + scale
            Let scaled_wavelet = String.replace_all(wavelet_formula, "t", scaled_arg)
            Let conjugate_wavelet = "conjugate(" + scaled_wavelet + ")"
            
            Note: Build integrand: f(t) * ψ*((t-b)/a)
            Let integrand_str = signal + " * " + conjugate_wavelet
            Let integrand = SymbolicCore.parse_expression(integrand_str, parsing_context)
            
            Note: Compute integral with normalization factor 1/√a
            Let integration_limits = Dictionary.empty()
            Set integration_limits to Dictionary.set(integration_limits, "lower", "-infinity")
            Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
            
            Let integral_result = evaluate_complex_integral(integrand, "t", integration_limits)
            Let normalization_factor = "1/sqrt(" + scale + ")"
            Let cwt_coefficient = normalization_factor + " * (" + SymbolicCore.expression_to_string(integral_result) + ")"
            
            Set scale_dict to Dictionary.set(scale_dict, translation, cwt_coefficient)
        
        Set coefficients_dict to Dictionary.set(coefficients_dict, scale, scale_dict)
    
    Let result = WaveletTransform:
        original_signal = signal
        wavelet_coefficients = coefficients_dict
        mother_wavelet = mother_wavelet
        scaling_function = "phi(t)" Note: Associated scaling function
        decomposition_levels = 4
        reconstruction_formula = "f(t) = (1/C_ψ) ∫∫ W(a,b) ψ_{a,b}(t) da db / a^2"
    
    Return result

Process called "discrete_wavelet_transform" that takes signal as List[String], wavelet_type as String, decomposition_levels as Integer returns WaveletTransform:
    Note: Compute discrete wavelet transform (DWT)
    Note: Multiresolution analysis: f = Σ c_k φ_{J,k} + Σ_{j≤J} Σ d_{j,k} ψ_{j,k}
    
    Let signal_length = Collections.size(signal)
    Let coefficients_dict = Dictionary.empty()
    
    Note: Initialize approximation coefficients at finest level
    Let current_approximation = signal
    
    Note: Get wavelet filter coefficients based on wavelet type
    Let low_pass_filter = Collections.create_list()
    Let high_pass_filter = Collections.create_list()
    
    If String.equals(wavelet_type, "haar"):
        Collections.append(low_pass_filter, "1/sqrt(2)")
        Collections.append(low_pass_filter, "1/sqrt(2)")
        Collections.append(high_pass_filter, "1/sqrt(2)")
        Collections.append(high_pass_filter, "-1/sqrt(2)")
    If String.equals(wavelet_type, "db4"):
        Note: Daubechies-4 coefficients
        Collections.append(low_pass_filter, "(1+sqrt(3))/(4*sqrt(2))")
        Collections.append(low_pass_filter, "(3+sqrt(3))/(4*sqrt(2))")
        Collections.append(low_pass_filter, "(3-sqrt(3))/(4*sqrt(2))")
        Collections.append(low_pass_filter, "(1-sqrt(3))/(4*sqrt(2))")
        Collections.append(high_pass_filter, "(1-sqrt(3))/(4*sqrt(2))")
        Collections.append(high_pass_filter, "-(3-sqrt(3))/(4*sqrt(2))")
        Collections.append(high_pass_filter, "(3+sqrt(3))/(4*sqrt(2))")
        Collections.append(high_pass_filter, "-(1+sqrt(3))/(4*sqrt(2))")
    Otherwise:
        Note: Default to Haar if wavelet type not recognized
        Collections.append(low_pass_filter, "1/sqrt(2)")
        Collections.append(low_pass_filter, "1/sqrt(2)")
        Collections.append(high_pass_filter, "1/sqrt(2)")
        Collections.append(high_pass_filter, "-1/sqrt(2)")
    
    Note: Perform decomposition for specified number of levels
    For level from 1 to decomposition_levels:
        Let current_length = Collections.size(current_approximation)
        Let new_approximation = Collections.create_list()
        Let detail_coefficients = Collections.create_list()
        
        Note: Convolution and downsampling
        For i from 0 to (current_length / 2) - 1:
            Let approx_sum = "0"
            Let detail_sum = "0"
            
            Note: Apply low-pass and high-pass filters
            For j from 0 to Collections.size(low_pass_filter) - 1:
                Let signal_index = (2 * i + j) % current_length
                Let signal_value = Collections.get(current_approximation, signal_index)
                Let low_coeff = Collections.get(low_pass_filter, j)
                Let high_coeff = Collections.get(high_pass_filter, j)
                
                Let approx_term = "(" + signal_value + ") * (" + low_coeff + ")"
                Let detail_term = "(" + signal_value + ") * (" + high_coeff + ")"
                
                If String.equals(approx_sum, "0"):
                    Set approx_sum to approx_term
                Otherwise:
                    Set approx_sum to approx_sum + " + " + approx_term
                
                If String.equals(detail_sum, "0"):
                    Set detail_sum to detail_term
                Otherwise:
                    Set detail_sum to detail_sum + " + " + detail_term
            
            Collections.append(new_approximation, approx_sum)
            Collections.append(detail_coefficients, detail_sum)
        
        Note: Store detail coefficients for this level
        Let level_key = "level_" + String.from_integer(level)
        Let level_dict = Dictionary.empty()
        For k from 0 to Collections.size(detail_coefficients) - 1:
            Let coeff_key = "d_" + String.from_integer(k)
            Set level_dict to Dictionary.set(level_dict, coeff_key, Collections.get(detail_coefficients, k))
        
        Set coefficients_dict to Dictionary.set(coefficients_dict, level_key, level_dict)
        Set current_approximation to new_approximation
    
    Note: Store final approximation coefficients
    Let approx_dict = Dictionary.empty()
    For k from 0 to Collections.size(current_approximation) - 1:
        Let coeff_key = "a_" + String.from_integer(k)
        Set approx_dict to Dictionary.set(approx_dict, coeff_key, Collections.get(current_approximation, k))
    
    Set coefficients_dict to Dictionary.set(coefficients_dict, "approximation", approx_dict)
    
    Let result = WaveletTransform:
        original_signal = Collections.join(signal, ", ")
        wavelet_coefficients = coefficients_dict
        mother_wavelet = wavelet_type
        scaling_function = "phi_" + wavelet_type + "(t)"
        decomposition_levels = decomposition_levels
        reconstruction_formula = "Perfect reconstruction using synthesis filters"
    
    Return result

Process called "inverse_wavelet_transform" that takes wavelet_coefficients as WaveletTransform returns String:
    Note: Reconstruct signal from wavelet coefficients
    Note: f(t) = Σ c_k φ_{J,k}(t) + Σ_{j≤J} Σ d_{j,k} ψ_{j,k}(t)
    
    Let coefficients = wavelet_coefficients.wavelet_coefficients
    Let wavelet_type = wavelet_coefficients.mother_wavelet
    Let levels = wavelet_coefficients.decomposition_levels
    
    Note: Get synthesis filters (reconstruction filters)
    Let low_recon_filter = Collections.create_list()
    Let high_recon_filter = Collections.create_list()
    
    If String.equals(wavelet_type, "haar"):
        Collections.append(low_recon_filter, "1/sqrt(2)")
        Collections.append(low_recon_filter, "1/sqrt(2)")
        Collections.append(high_recon_filter, "1/sqrt(2)")
        Collections.append(high_recon_filter, "-1/sqrt(2)")
    If String.equals(wavelet_type, "db4"):
        Note: Daubechies-4 synthesis filters (time-reversed analysis filters)
        Collections.append(low_recon_filter, "(1-sqrt(3))/(4*sqrt(2))")
        Collections.append(low_recon_filter, "(3-sqrt(3))/(4*sqrt(2))")
        Collections.append(low_recon_filter, "(3+sqrt(3))/(4*sqrt(2))")
        Collections.append(low_recon_filter, "(1+sqrt(3))/(4*sqrt(2))")
        Collections.append(high_recon_filter, "-(1+sqrt(3))/(4*sqrt(2))")
        Collections.append(high_recon_filter, "(3+sqrt(3))/(4*sqrt(2))")
        Collections.append(high_recon_filter, "-(3-sqrt(3))/(4*sqrt(2))")
        Collections.append(high_recon_filter, "(1-sqrt(3))/(4*sqrt(2))")
    Otherwise:
        Note: Default to Haar
        Collections.append(low_recon_filter, "1/sqrt(2)")
        Collections.append(low_recon_filter, "1/sqrt(2)")
        Collections.append(high_recon_filter, "1/sqrt(2)")
        Collections.append(high_recon_filter, "-1/sqrt(2)")
    
    Note: Start reconstruction from coarsest level
    Let current_signal = Collections.create_list()
    
    Note: Get approximation coefficients
    If Dictionary.contains_key(coefficients, "approximation"):
        Let approx_dict = Dictionary.get(coefficients, "approximation")
        Let approx_keys = Dictionary.keys(approx_dict)
        For Each key in approx_keys:
            Let coeff_value = Dictionary.get(approx_dict, key)
            Collections.append(current_signal, coeff_value)
    
    Note: Reconstruct from coarsest to finest level
    For level from levels down to 1:
        Let level_key = "level_" + String.from_integer(level)
        
        If Dictionary.contains_key(coefficients, level_key):
            Let detail_dict = Dictionary.get(coefficients, level_key)
            Let detail_coeffs = Collections.create_list()
            
            Let detail_keys = Dictionary.keys(detail_dict)
            For Each key in detail_keys:
                Let coeff_value = Dictionary.get(detail_dict, key)
                Collections.append(detail_coeffs, coeff_value)
            
            Note: Upsample and filter both approximation and detail
            Let upsampled_approx = Collections.create_list()
            Let upsampled_detail = Collections.create_list()
            
            Note: Upsample by inserting zeros
            For Each coeff in current_signal:
                Collections.append(upsampled_approx, coeff)
                Collections.append(upsampled_approx, "0")
            
            For Each coeff in detail_coeffs:
                Collections.append(upsampled_detail, coeff)
                Collections.append(upsampled_detail, "0")
            
            Note: Apply synthesis filters and combine
            Let reconstructed = Collections.create_list()
            Let target_length = Collections.size(upsampled_approx)
            
            For i from 0 to target_length - 1:
                Let recon_sum = "0"
                
                Note: Low-pass contribution
                For j from 0 to Collections.size(low_recon_filter) - 1:
                    Let index = (i - j + target_length) % target_length
                    If index < Collections.size(upsampled_approx):
                        Let coeff = Collections.get(upsampled_approx, index)
                        Let filter_val = Collections.get(low_recon_filter, j)
                        Let term = "(" + coeff + ") * (" + filter_val + ")"
                        
                        If String.equals(recon_sum, "0"):
                            Set recon_sum to term
                        Otherwise:
                            Set recon_sum to recon_sum + " + " + term
                
                Note: High-pass contribution
                For j from 0 to Collections.size(high_recon_filter) - 1:
                    Let index = (i - j + target_length) % target_length
                    If index < Collections.size(upsampled_detail):
                        Let coeff = Collections.get(upsampled_detail, index)
                        Let filter_val = Collections.get(high_recon_filter, j)
                        Let term = "(" + coeff + ") * (" + filter_val + ")"
                        
                        If String.equals(recon_sum, "0"):
                            Set recon_sum to term
                        Otherwise:
                            Set recon_sum to recon_sum + " + " + term
                
                Collections.append(reconstructed, recon_sum)
            
            Set current_signal to reconstructed
    
    Note: Convert reconstructed signal to continuous function representation
    Let reconstruction_terms = Collections.create_list()
    For i from 0 to Collections.size(current_signal) - 1:
        Let coeff = Collections.get(current_signal, i)
        Let basis_function = "delta(t - " + String.from_integer(i) + ")"
        Let term = "(" + coeff + ") * " + basis_function
        Collections.append(reconstruction_terms, term)
    
    Return Collections.join(reconstruction_terms, " + ")

Process called "multiresolution_analysis" that takes signal as String, wavelet_basis as String, resolution_levels as Integer returns Dictionary[String, List[String]]:
    Note: Perform multiresolution analysis with scaling and wavelet functions
    Note: f ∈ V_J = V_0 ⊕ W_0 ⊕ W_1 ⊕ ... ⊕ W_{J-1}
    
    Let parsing_context = Dictionary.empty()
    Let parsed_signal = SymbolicCore.parse_expression(signal, parsing_context)
    Let mra_components = Dictionary.empty()
    
    Note: Generate scaling function and wavelet basis for specified wavelet
    Let scaling_function = ""
    Let wavelet_function = ""
    
    If String.equals(wavelet_basis, "haar"):
        Set scaling_function to "rect(t) for 0 ≤ t < 1, 0 elsewhere"
        Set wavelet_function to "1 for 0 ≤ t < 1/2, -1 for 1/2 ≤ t < 1, 0 elsewhere"
    If String.equals(wavelet_basis, "daubechies"):
        Set scaling_function to "Daubechies scaling function phi_db(t)"
        Set wavelet_function to "Daubechies wavelet psi_db(t)"
    Otherwise:
        Set scaling_function to "phi(t) - custom scaling function"
        Set wavelet_function to "psi(t) - custom wavelet function"
    
    Note: Decompose signal into multiresolution components
    For level from 0 to resolution_levels - 1:
        Let level_components = Collections.create_list()
        Let scale_factor = 2 ^ level
        
        Note: Generate approximation space V_j components
        If level == 0:
            Note: Coarsest approximation
            Let approx_component = "projection of " + signal + " onto V_" + String.from_integer(level)
            Collections.append(level_components, approx_component)
            Set mra_components to Dictionary.set(mra_components, "V_" + String.from_integer(level), level_components)
        
        Note: Generate detail space W_j components
        Let detail_components = Collections.create_list()
        
        Note: Wavelet coefficients for this resolution level
        For k from 0 to scale_factor - 1:
            Let translation = String.from_integer(k)
            Let scale = String.from_integer(2 ^ (-level))
            
            Note: Wavelet coefficient <f, ψ_{j,k}>
            Let wavelet_jk = "psi_{" + String.from_integer(level) + "," + translation + "}(t) = 2^{" + String.from_integer(level) + "/2} * psi(2^{" + String.from_integer(level) + "}*t - " + translation + ")"
            
            Note: Compute inner product coefficient
            Let inner_product_integrand = signal + " * conjugate(" + wavelet_jk + ")"
            Let integration_limits = Dictionary.empty()
            Set integration_limits to Dictionary.set(integration_limits, "lower", "-infinity")
            Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
            
            Let coefficient_integral = SymbolicCore.parse_expression(inner_product_integrand, parsing_context)
            Let coefficient_result = evaluate_complex_integral(coefficient_integral, "t", integration_limits)
            Let coefficient_str = SymbolicCore.expression_to_string(coefficient_result)
            
            Let detail_term = "(" + coefficient_str + ") * " + wavelet_jk
            Collections.append(detail_components, detail_term)
        
        Set mra_components to Dictionary.set(mra_components, "W_" + String.from_integer(level), detail_components)
    
    Note: Add basis function information
    Let basis_info = Collections.create_list()
    Collections.append(basis_info, "Scaling function: " + scaling_function)
    Collections.append(basis_info, "Wavelet function: " + wavelet_function)
    Collections.append(basis_info, "Two-scale relation: phi(t) = sum_k h_k phi(2t-k)")
    Collections.append(basis_info, "Wavelet equation: psi(t) = sum_k g_k phi(2t-k)")
    Set mra_components to Dictionary.set(mra_components, "basis_functions", basis_info)
    
    Note: Add reconstruction formula
    Let reconstruction = Collections.create_list()
    Collections.append(reconstruction, "f(t) = sum_{k} c_{J,k} phi_{J,k}(t) + sum_{j=0}^{J-1} sum_{k} d_{j,k} psi_{j,k}(t)")
    Set mra_components to Dictionary.set(mra_components, "reconstruction_formula", reconstruction)
    
    Return mra_components

Process called "wavelet_packet_transform" that takes signal as String, wavelet_type as String, packet_tree as Dictionary[String, String] returns Dictionary[String, String]:
    Note: Compute wavelet packet transform for adaptive decomposition
    Note: Extends DWT by decomposing both approximation and detail coefficients
    
    Let parsing_context = Dictionary.empty()
    Let parsed_signal = SymbolicCore.parse_expression(signal, parsing_context)
    Let packet_coefficients = Dictionary.empty()
    
    Note: Get filter coefficients based on wavelet type
    Let h_filter = Collections.create_list() Note: Low-pass filter
    Let g_filter = Collections.create_list() Note: High-pass filter
    
    If String.equals(wavelet_type, "haar"):
        Collections.append(h_filter, "1/sqrt(2)")
        Collections.append(h_filter, "1/sqrt(2)")
        Collections.append(g_filter, "1/sqrt(2)")
        Collections.append(g_filter, "-1/sqrt(2)")
    If String.equals(wavelet_type, "db4"):
        Collections.append(h_filter, "(1+sqrt(3))/(4*sqrt(2))")
        Collections.append(h_filter, "(3+sqrt(3))/(4*sqrt(2))")
        Collections.append(h_filter, "(3-sqrt(3))/(4*sqrt(2))")
        Collections.append(h_filter, "(1-sqrt(3))/(4*sqrt(2))")
        Collections.append(g_filter, "(1-sqrt(3))/(4*sqrt(2))")
        Collections.append(g_filter, "-(3-sqrt(3))/(4*sqrt(2))")
        Collections.append(g_filter, "(3+sqrt(3))/(4*sqrt(2))")
        Collections.append(g_filter, "-(1+sqrt(3))/(4*sqrt(2))")
    Otherwise:
        Note: Default to Haar
        Collections.append(h_filter, "1/sqrt(2)")
        Collections.append(h_filter, "1/sqrt(2)")
        Collections.append(g_filter, "1/sqrt(2)")
        Collections.append(g_filter, "-1/sqrt(2)")
    
    Note: Initialize packet tree structure
    Note: Packet notation: (j,n) where j=level, n=packet index
    Set packet_coefficients to Dictionary.set(packet_coefficients, "(0,0)", signal)
    
    Note: Parse packet tree specification or use default full tree
    Let max_levels = 3 Note: Default decomposition depth
    If Dictionary.contains_key(packet_tree, "max_levels"):
        Set max_levels to String.to_integer(Dictionary.get(packet_tree, "max_levels"))
    
    Note: Generate wavelet packet decomposition
    For level from 1 to max_levels:
        Let packets_at_level = 2 ^ level
        
        For packet_index from 0 to packets_at_level - 1:
            Let parent_level = level - 1
            Let parent_index = packet_index / 2
            Let parent_key = "(" + String.from_integer(parent_level) + "," + String.from_integer(parent_index) + ")"
            
            If Dictionary.contains_key(packet_coefficients, parent_key):
                Let parent_signal = Dictionary.get(packet_coefficients, parent_key)
                
                Note: Determine if this is an approximation (even) or detail (odd) packet
                Let is_even_packet = (packet_index % 2 == 0)
                Let filter_to_use = ""
                
                If is_even_packet:
                    Set filter_to_use to "low_pass"
                Otherwise:
                    Set filter_to_use to "high_pass"
                
                Note: Apply filtering and downsampling
                Let filtered_signal = "filtered_" + filter_to_use + "(" + parent_signal + ")"
                
                Note: For symbolic representation, create packet coefficient
                Let packet_key = "(" + String.from_integer(level) + "," + String.from_integer(packet_index) + ")"
                
                If is_even_packet:
                    Let convolution_result = "conv(" + parent_signal + ", h_filter)"
                    Set packet_coefficients to Dictionary.set(packet_coefficients, packet_key, convolution_result)
                Otherwise:
                    Let convolution_result = "conv(" + parent_signal + ", g_filter)"
                    Set packet_coefficients to Dictionary.set(packet_coefficients, packet_key, convolution_result)
    
    Note: Add packet tree structure information
    Let tree_info = "Full binary packet tree with " + String.from_integer(max_levels) + " levels"
    Set packet_coefficients to Dictionary.set(packet_coefficients, "tree_structure", tree_info)
    
    Note: Add entropy/energy information for adaptive selection
    For Each key in Dictionary.keys(packet_coefficients):
        If String.contains(key, "(") and String.contains(key, ")"):
            Let packet_signal = Dictionary.get(packet_coefficients, key)
            Let energy_key = key + "_energy"
            Let energy_value = "energy(" + packet_signal + ") = ||" + packet_signal + "||^2"
            Set packet_coefficients to Dictionary.set(packet_coefficients, energy_key, energy_value)
    
    Return packet_coefficients

Note: =====================================================================
Note: HILBERT TRANSFORM OPERATIONS
Note: =====================================================================

Process called "hilbert_transform" that takes function as String, variable as String returns String:
    Note: Compute Hilbert transform H{f}(x) = (1/π)P.V.∫f(t)/(x-t)dt
    Note: P.V. denotes Cauchy principal value integral
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Check for common Hilbert transform patterns
    If String.equals(function, "1"):
        Note: H{1} = 0
        Return "0"
    
    If String.contains(function, "sin("):
        Let omega_pattern = String.extract_between(function, "sin(", "*" + variable + ")")
        If not String.equals(omega_pattern, ""):
            Note: H{sin(ωt)} = -cos(ωt)
            Return "-cos(" + omega_pattern + "*" + variable + ")"
    
    If String.contains(function, "cos("):
        Let omega_pattern = String.extract_between(function, "cos(", "*" + variable + ")")
        If not String.equals(omega_pattern, ""):
            Note: H{cos(ωt)} = sin(ωt)
            Return "sin(" + omega_pattern + "*" + variable + ")"
    
    If String.contains(function, "1/(1+" + variable + "^2)"):
        Note: H{1/(1+t²)} = t/(1+t²)
        Return variable + "/(1+" + variable + "^2)"
    
    If String.contains(function, variable + "/(1+" + variable + "^2)"):
        Note: H{t/(1+t²)} = -1/(1+t²)
        Return "-1/(1+" + variable + "^2)"
    
    Note: Use definition with principal value integral
    Note: H{f}(x) = (1/π) P.V. ∫_{-∞}^{∞} f(t)/(x-t) dt
    Let x_symbol = SymbolicCore.create_symbol("x", Dictionary.empty())
    Let t_symbol = SymbolicCore.create_symbol("t", Dictionary.empty())
    
    Note: Create f(t) by substituting t for the variable
    Let f_of_t = SymbolicCore.substitute_variable(parsed_function, variable, t_symbol)
    
    Note: Create kernel 1/(x-t)
    Let kernel = SymbolicCore.create_rational(
        SymbolicCore.create_number(1),
        SymbolicCore.create_binary_operation("-", x_symbol, t_symbol)
    )
    
    Let hilbert_integrand = SymbolicCore.create_binary_operation("*", f_of_t, kernel)
    
    Note: Apply principal value integration (symbolic representation)
    Let pi_symbol = SymbolicCore.create_symbol("pi", Dictionary.empty())
    Let normalization = SymbolicCore.create_rational(1, pi_symbol)
    
    Let principal_value_integral = "P.V.integral(-infinity, infinity, " + 
        SymbolicCore.expression_to_string(hilbert_integrand) + ", t)"
    
    Let final_result = SymbolicCore.create_binary_operation("*", normalization, 
        SymbolicCore.parse_expression(principal_value_integral, parsing_context))
    
    Note: Substitute x back to original variable
    Let result_with_var = SymbolicCore.substitute_variable(final_result, "x", 
        SymbolicCore.create_symbol(variable, Dictionary.empty()))
    
    Return SymbolicCore.expression_to_string(result_with_var)

Process called "analytic_signal" that takes real_function as String, variable as String returns Dictionary[String, String]:
    Note: Construct analytic signal z(t) = f(t) + iH{f}(t)
    Note: Creates complex-valued signal from real-valued input
    
    Let analytic_components = Dictionary.empty()
    
    Note: Get the Hilbert transform of the real function
    Let hilbert_part = hilbert_transform(real_function, variable)
    
    Note: Real part is the original function
    Set analytic_components to Dictionary.set(analytic_components, "real_part", real_function)
    
    Note: Imaginary part is the Hilbert transform
    Set analytic_components to Dictionary.set(analytic_components, "imaginary_part", hilbert_part)
    
    Note: Complete analytic signal representation
    Let analytic_signal = real_function + " + i*(" + hilbert_part + ")"
    Set analytic_components to Dictionary.set(analytic_components, "analytic_signal", analytic_signal)
    
    Note: Frequency domain representation (positive frequencies only)
    Let fourier_real = continuous_fourier_transform(real_function, variable, "omega")
    Let positive_freq_condition = "2*" + fourier_real.transformed_function + " for omega > 0, 0 for omega < 0"
    Set analytic_components to Dictionary.set(analytic_components, "frequency_domain", positive_freq_condition)
    
    Note: Properties of analytic signal
    Set analytic_components to Dictionary.set(analytic_components, "causality", "Causal in frequency domain (no negative frequencies)")
    Set analytic_components to Dictionary.set(analytic_components, "envelope", "sqrt((" + real_function + ")^2 + (" + hilbert_part + ")^2)")
    Set analytic_components to Dictionary.set(analytic_components, "phase", "atan2(" + hilbert_part + ", " + real_function + ")")
    
    Return analytic_components

Process called "instantaneous_amplitude" that takes analytic_signal as Dictionary[String, String] returns String:
    Note: Compute instantaneous amplitude from analytic signal
    Note: A(t) = |z(t)| = sqrt(Re[z(t)]^2 + Im[z(t)]^2)
    
    Note: Extract real and imaginary parts from analytic signal
    Let real_part = Dictionary.get_or_default(analytic_signal, "real_part", "0")
    Let imaginary_part = Dictionary.get_or_default(analytic_signal, "imaginary_part", "0")
    
    Note: Compute instantaneous amplitude (envelope)
    Let amplitude = "sqrt((" + real_part + ")^2 + (" + imaginary_part + ")^2)"
    
    Note: Check if envelope formula is already computed
    If Dictionary.contains_key(analytic_signal, "envelope"):
        Return Dictionary.get(analytic_signal, "envelope")
    
    Return amplitude

Process called "instantaneous_phase" that takes analytic_signal as Dictionary[String, String] returns String:
    Note: Compute instantaneous phase from analytic signal
    Note: φ(t) = arg(z(t)) = atan2(Im[z(t)], Re[z(t)])
    
    Note: Extract real and imaginary parts from analytic signal
    Let real_part = Dictionary.get_or_default(analytic_signal, "real_part", "0")
    Let imaginary_part = Dictionary.get_or_default(analytic_signal, "imaginary_part", "0")
    
    Note: Compute instantaneous phase using atan2
    Let phase = "atan2(" + imaginary_part + ", " + real_part + ")"
    
    Note: Check if phase formula is already computed
    If Dictionary.contains_key(analytic_signal, "phase"):
        Return Dictionary.get(analytic_signal, "phase")
    
    Return phase

Process called "instantaneous_frequency" that takes analytic_signal as Dictionary[String, String], variable as String returns String:
    Note: Compute instantaneous frequency from analytic signal
    Note: ω(t) = (1/2π) * dφ(t)/dt where φ(t) is instantaneous phase
    
    Let parsing_context = Dictionary.empty()
    
    Note: Get instantaneous phase
    Let phase_expression = instantaneous_phase(analytic_signal)
    Let parsed_phase = SymbolicCore.parse_expression(phase_expression, parsing_context)
    
    Note: Compute derivative of phase with respect to time
    Let phase_derivative = Calculus.differentiate(parsed_phase, variable, 1)
    
    Note: Apply normalization factor 1/(2π)
    Let pi_symbol = SymbolicCore.create_symbol("pi", Dictionary.empty())
    Let two_pi = SymbolicCore.create_binary_operation("*", SymbolicCore.create_number(2), pi_symbol)
    Let normalization = SymbolicCore.create_rational(1, two_pi)
    
    Let instantaneous_freq = SymbolicCore.create_binary_operation("*", normalization, phase_derivative)
    
    Return SymbolicCore.expression_to_string(instantaneous_freq)

Note: =====================================================================
Note: RADON TRANSFORM OPERATIONS
Note: =====================================================================

Process called "radon_transform" that takes function as String, variables as List[String], projection_angle as String returns String:
    Note: Compute Radon transform (projection along lines)
    Note: R_θ{f}(s) = ∫∫ f(x,y) δ(x·cos(θ) + y·sin(θ) - s) dx dy
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Extract coordinate variables (typically x and y for 2D)
    Let x_var = "x"
    Let y_var = "y"
    If Collections.size(variables) >= 2:
        Set x_var to Collections.get(variables, 0)
        Set y_var to Collections.get(variables, 1)
    
    Note: Parse projection angle
    Let theta = SymbolicCore.parse_expression(projection_angle, parsing_context)
    
    Note: For common angles, use direct formulas
    If String.equals(projection_angle, "0"):
        Note: θ = 0: vertical projection (integrate over y)
        Let projection_result = "integral(-infinity, infinity, " + function + ", " + y_var + ")"
        Return projection_result
    
    If String.equals(projection_angle, "pi/2"):
        Note: θ = π/2: horizontal projection (integrate over x)
        Let projection_result = "integral(-infinity, infinity, " + function + ", " + x_var + ")"
        Return projection_result
    
    Note: General case: line integral along direction θ
    Note: Parameterize line as: x = s*cos(θ) - t*sin(θ), y = s*sin(θ) + t*cos(θ)
    Let cos_theta = "cos(" + projection_angle + ")"
    Let sin_theta = "sin(" + projection_angle + ")"
    
    Note: Substitution for line integral
    Let x_param = "s*" + cos_theta + " - t*" + sin_theta
    Let y_param = "s*" + sin_theta + " + t*" + cos_theta
    
    Note: Substitute parameterization into function
    Let function_on_line = String.replace_all(function, x_var, "(" + x_param + ")")
    Set function_on_line to String.replace_all(function_on_line, y_var, "(" + y_param + ")")
    
    Note: Integrate along the line (parameter t from -∞ to ∞)
    Let radon_projection = "integral(-infinity, infinity, " + function_on_line + ", t)"
    
    Return radon_projection

Process called "inverse_radon_transform" that takes projection_data as String, reconstruction_method as String returns String:
    Note: Reconstruct function from Radon projections
    Note: f(x,y) = (1/2π) ∫₀^π ∫_{-∞}^∞ |ω| F_θ(ω) e^{iω(x·cos(θ)+y·sin(θ))} dω dθ
    
    Let parsing_context = Dictionary.empty()
    Let parsed_projections = SymbolicCore.parse_expression(projection_data, parsing_context)
    
    If String.equals(reconstruction_method, "filtered_backprojection"):
        Note: Use filtered backprojection algorithm
        Return filtered_backprojection(projection_data, "ram_lak")
    
    If String.equals(reconstruction_method, "fourier_slice"):
        Note: Fourier slice theorem approach
        Note: F{R_θ{f}}(ω) = F_2D{f}(ω·cos(θ), ω·sin(θ))
        Let reconstruction = "inverse_2d_fourier_transform(" + projection_data + "_in_polar_coordinates)"
        Return reconstruction
    
    Note: General inversion formula using backprojection
    Let reconstruction_sum = "0"
    Let angle_increments = Collections.create_list()
    Collections.append(angle_increments, "0")
    Collections.append(angle_increments, "pi/6")
    Collections.append(angle_increments, "pi/4")
    Collections.append(angle_increments, "pi/3")
    Collections.append(angle_increments, "pi/2")
    Collections.append(angle_increments, "2*pi/3")
    Collections.append(angle_increments, "3*pi/4")
    Collections.append(angle_increments, "5*pi/6")
    
    For Each angle in angle_increments:
        Note: Backproject from angle θ
        Let cos_theta = "cos(" + angle + ")"
        Let sin_theta = "sin(" + angle + ")"
        Let projection_arg = "x*" + cos_theta + " + y*" + sin_theta
        
        Let backprojection_term = "P_" + angle + "(" + projection_arg + ")"
        
        If String.equals(reconstruction_sum, "0"):
            Set reconstruction_sum to backprojection_term
        Otherwise:
            Set reconstruction_sum to reconstruction_sum + " + " + backprojection_term
    
    Note: Apply normalization
    Let pi_normalization = "(1/(2*pi)) * (" + reconstruction_sum + ")"
    Return pi_normalization

Process called "filtered_backprojection" that takes projection_data as String, filter_type as String returns String:
    Note: Apply filtered backprojection algorithm
    Note: Standard CT reconstruction method with ramp filtering
    
    Let parsing_context = Dictionary.empty()
    
    Note: Apply frequency domain filter
    Let filter_function = ""
    If String.equals(filter_type, "ram_lak"):
        Set filter_function to "abs(omega)" Note: Ramp filter
    If String.equals(filter_type, "shepp_logan"):
        Set filter_function to "abs(omega) * sinc(omega/(2*omega_c))" Note: Shepp-Logan filter
    If String.equals(filter_type, "cosine"):
        Set filter_function to "abs(omega) * cos(pi*omega/(2*omega_c))" Note: Cosine filter
    If String.equals(filter_type, "hamming"):
        Set filter_function to "abs(omega) * (0.54 + 0.46*cos(pi*omega/omega_c))" Note: Hamming filter
    Otherwise:
        Set filter_function to "abs(omega)" Note: Default to ramp filter
    
    Note: Apply filter in frequency domain
    Note: 1. Take Fourier transform of each projection
    Let fourier_projections = "fourier_transform_1d(" + projection_data + ", s_to_omega)"
    
    Note: 2. Multiply by filter
    Let filtered_projections = "(" + fourier_projections + ") * (" + filter_function + ")"
    
    Note: 3. Inverse Fourier transform
    Let filtered_spatial = "inverse_fourier_transform_1d(" + filtered_projections + ", omega_to_s)"
    
    Note: 4. Backproject filtered projections
    Let reconstruction_integral = "(1/pi) * integral(0, pi, " + filtered_spatial + "(x*cos(theta) + y*sin(theta), theta), theta)"
    
    Return reconstruction_integral

Process called "fan_beam_transform" that takes function as String, source_positions as List[String], detector_geometry as Dictionary[String, String] returns String:
    Note: Compute fan-beam projection transform
    Note: Projects along rays from source to detector elements
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Extract detector geometry parameters
    Let source_detector_distance = Dictionary.get_or_default(detector_geometry, "source_detector_distance", "D")
    Let detector_length = Dictionary.get_or_default(detector_geometry, "detector_length", "L")
    Let fan_angle = Dictionary.get_or_default(detector_geometry, "fan_angle", "gamma_max")
    
    Let projections_list = Collections.create_list()
    
    Note: For each source position, compute fan-beam projection
    For Each source_pos in source_positions:
        Note: Parse source coordinates
        Let source_coords = String.split(source_pos, ",")
        Let x_source = "0"
        Let y_source = "0"
        
        If List.size(source_coords) >= 2:
            Set x_source to List.get(source_coords, 0)
            Set y_source to List.get(source_coords, 1)
        
        Note: Fan-beam projection for this source position
        Let fan_projection = "0"
        
        Note: Integrate along each ray from source to detector
        Note: Ray parameterization: (x,y) = (x_s, y_s) + t*(cos(alpha), sin(alpha))
        Let ray_integral = "integral(0, infinity, " + function + 
            "(" + x_source + " + t*cos(alpha), " + y_source + " + t*sin(alpha)), t)"
        
        Note: Fan angle range depends on detector geometry
        Let fan_beam_integral = "integral(-" + fan_angle + ", " + fan_angle + ", " + ray_integral + ", alpha)"
        
        Collections.append(projections_list, fan_beam_integral)
    
    Note: Combine all projections
    Let combined_projections = Collections.join(projections_list, "; ")
    
    Note: Add geometry correction factors for reconstruction
    Let geometry_corrected = "geometry_correction(" + combined_projections + ", " + source_detector_distance + ")"
    
    Return geometry_corrected

Note: =====================================================================
Note: LEGENDRE TRANSFORM OPERATIONS
Note: =====================================================================

Process called "legendre_transform" that takes function as String, variable as String returns Dictionary[String, String]:
    Note: Compute Legendre transform f*(p) = px - f(x)
    Note: f*(p) = sup_x {px - f(x)} where p = df/dx
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    Let legendre_result = Dictionary.empty()
    
    Note: Compute derivative f'(x)
    Let f_prime = Calculus.differentiate(parsed_function, variable, 1)
    Let f_prime_str = SymbolicCore.expression_to_string(f_prime)
    
    Note: The dual variable p is the derivative: p = f'(x)
    Note: Solve p = f'(x) for x in terms of p: x = (f')^(-1)(p)
    Let x_of_p = "inverse_function(" + f_prime_str + ", " + variable + ", p)"
    
    Note: Compute Legendre transform f*(p) = px - f(x)
    Let px_term = "p * (" + x_of_p + ")"
    Let f_of_x_of_p = String.replace_all(function, variable, "(" + x_of_p + ")")
    Let legendre_transform = px_term + " - (" + f_of_x_of_p + ")"
    
    Set legendre_result to Dictionary.set(legendre_result, "transformed_function", legendre_transform)
    Set legendre_result to Dictionary.set(legendre_result, "dual_variable", "p")
    Set legendre_result to Dictionary.set(legendre_result, "original_variable", variable)
    Set legendre_result to Dictionary.set(legendre_result, "constraint_equation", "p = " + f_prime_str)
    Set legendre_result to Dictionary.set(legendre_result, "inverse_relation", "x = " + x_of_p)
    
    Note: Check convexity condition
    Let f_double_prime = Calculus.differentiate(f_prime, variable, 1)
    Let convexity_condition = SymbolicCore.expression_to_string(f_double_prime) + " > 0"
    Set legendre_result to Dictionary.set(legendre_result, "convexity_condition", convexity_condition)
    
    Note: Add involution property
    Set legendre_result to Dictionary.set(legendre_result, "involution", "(f*)* = f for convex f")
    
    Return legendre_result

Process called "legendre_fenchel_transform" that takes convex_function as String, variable as String returns Dictionary[String, String]:
    Note: Compute Legendre-Fenchel transform for convex functions
    Note: f*(y) = sup_x {<y,x> - f(x)} (generalization of Legendre transform)
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(convex_function, parsing_context)
    Let fenchel_result = Dictionary.empty()
    
    Note: For 1D case, this reduces to standard Legendre transform
    Let standard_legendre = legendre_transform(convex_function, variable)
    
    Note: Extract results from standard Legendre transform
    Let conjugate_function = Dictionary.get(standard_legendre, "transformed_function")
    Set fenchel_result to Dictionary.set(fenchel_result, "conjugate_function", conjugate_function)
    Set fenchel_result to Dictionary.set(fenchel_result, "dual_variable", "y")
    Set fenchel_result to Dictionary.set(fenchel_result, "original_variable", variable)
    
    Note: Fenchel-Moreau theorem
    Set fenchel_result to Dictionary.set(fenchel_result, "fenchel_moreau", "f** = f for convex lower semicontinuous f")
    
    Note: Subdifferential relationship
    Let subdifferential = "y ∈ ∂f(x) ⟺ f(x) + f*(y) = <x,y>"
    Set fenchel_result to Dictionary.set(fenchel_result, "subdifferential", subdifferential)
    
    Note: Young's inequality
    Set fenchel_result to Dictionary.set(fenchel_result, "youngs_inequality", "<x,y> ≤ f(x) + f*(y)")
    
    Note: Conjugate properties
    Set fenchel_result to Dictionary.set(fenchel_result, "scaling_property", "(λf)*(y) = λf*(y/λ) for λ > 0")
    Set fenchel_result to Dictionary.set(fenchel_result, "translation_property", "(f(·-a))*(y) = f*(y) + <a,y>")
    
    Note: Domain information
    Set fenchel_result to Dictionary.set(fenchel_result, "domain", "dom(f*) = {y : sup_x {<y,x> - f(x)} < ∞}")
    
    Return fenchel_result

Process called "hamiltonian_mechanics_transform" that takes lagrangian as String, generalized_coordinates as List[String] returns Dictionary[String, String]:
    Note: Transform Lagrangian to Hamiltonian using Legendre transform
    Note: H(q,p,t) = p·q̇ - L(q,q̇,t) where p = ∂L/∂q̇
    
    Let parsing_context = Dictionary.empty()
    Let parsed_lagrangian = SymbolicCore.parse_expression(lagrangian, parsing_context)
    Let hamiltonian_result = Dictionary.empty()
    
    Note: Extract generalized coordinates and velocities
    Let coordinates = Collections.create_list()
    Let velocities = Collections.create_list()
    Let momenta = Collections.create_list()
    
    For Each coord in generalized_coordinates:
        Collections.append(coordinates, coord)
        Collections.append(velocities, coord + "_dot")
        Collections.append(momenta, "p_" + coord)
    
    Note: Compute canonical momenta p_i = ∂L/∂q̇_i
    Let momentum_definitions = Collections.create_list()
    For i from 0 to Collections.size(coordinates) - 1:
        Let coord = Collections.get(coordinates, i)
        Let velocity = Collections.get(velocities, i)
        Let momentum = Collections.get(momenta, i)
        
        Let momentum_derivative = Calculus.partial_derivative(parsed_lagrangian, velocity)
        Let momentum_def = momentum + " = " + SymbolicCore.expression_to_string(momentum_derivative)
        Collections.append(momentum_definitions, momentum_def)
    
    Note: Construct Hamiltonian H = Σ p_i q̇_i - L
    Let kinetic_term = "0"
    For i from 0 to Collections.size(coordinates) - 1:
        Let momentum = Collections.get(momenta, i)
        Let velocity = Collections.get(velocities, i)
        Let term = momentum + " * " + velocity
        
        If String.equals(kinetic_term, "0"):
            Set kinetic_term to term
        Otherwise:
            Set kinetic_term to kinetic_term + " + " + term
    
    Let hamiltonian = "(" + kinetic_term + ") - (" + lagrangian + ")"
    
    Note: Express velocities in terms of momenta (solve p_i = ∂L/∂q̇_i for q̇_i)
    Let velocity_solutions = Collections.create_list()
    For i from 0 to Collections.size(coordinates) - 1:
        Let velocity = Collections.get(velocities, i)
        Let momentum = Collections.get(momenta, i)
        Let velocity_solution = velocity + " = solve(" + Collections.get(momentum_definitions, i) + ", " + velocity + ")"
        Collections.append(velocity_solutions, velocity_solution)
    
    Note: Substitute velocity solutions into Hamiltonian
    Let hamiltonian_final = hamiltonian
    For Each velocity_sol in velocity_solutions:
        Let velocity_expr = String.extract_between(velocity_sol, " = ", "")
        Let velocity_var = String.extract_between(velocity_sol, "", " = ")
        Set hamiltonian_final to String.replace_all(hamiltonian_final, velocity_var, "(" + velocity_expr + ")")
    
    Set hamiltonian_result to Dictionary.set(hamiltonian_result, "hamiltonian", hamiltonian_final)
    Set hamiltonian_result to Dictionary.set(hamiltonian_result, "coordinates", Collections.join(coordinates, ", "))
    Set hamiltonian_result to Dictionary.set(hamiltonian_result, "momenta", Collections.join(momenta, ", "))
    Set hamiltonian_result to Dictionary.set(hamiltonian_result, "momentum_definitions", Collections.join(momentum_definitions, "; "))
    Set hamiltonian_result to Dictionary.set(hamiltonian_result, "velocity_solutions", Collections.join(velocity_solutions, "; "))
    
    Note: Hamilton's equations
    Let hamiltons_equations = Collections.create_list()
    For i from 0 to Collections.size(coordinates) - 1:
        Let coord = Collections.get(coordinates, i)
        Let momentum = Collections.get(momenta, i)
        Collections.append(hamiltons_equations, "d" + coord + "/dt = ∂H/∂" + momentum)
        Collections.append(hamiltons_equations, "d" + momentum + "/dt = -∂H/∂" + coord)
    
    Set hamiltonian_result to Dictionary.set(hamiltonian_result, "hamiltons_equations", Collections.join(hamiltons_equations, "; "))
    
    Note: Conservation properties
    Set hamiltonian_result to Dictionary.set(hamiltonian_result, "energy_conservation", "dH/dt = ∂H/∂t (if ∂H/∂t = 0, then H is conserved)")
    Set hamiltonian_result to Dictionary.set(hamiltonian_result, "phase_space_volume", "Liouville's theorem: phase space volume preserved")
    
    Return hamiltonian_result

Note: =====================================================================
Note: GENERAL INTEGRAL TRANSFORM OPERATIONS
Note: =====================================================================

Process called "general_integral_transform" that takes function as String, kernel as String, integration_variable as String, integration_limits as Dictionary[String, String], transform_variable as String returns String:
    Note: Compute general integral transform with specified kernel
    Note: T{f}(s) = ∫ K(s,t) f(t) dt where K(s,t) is the kernel function
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    Let parsed_kernel = SymbolicCore.parse_expression(kernel, parsing_context)
    
    Note: Create integrand K(s,t) * f(t)
    Let integrand = SymbolicCore.create_binary_operation("*", parsed_kernel, parsed_function)
    
    Note: Perform integration
    Let integrated_result = evaluate_complex_integral(integrand, integration_variable, integration_limits)
    
    Return SymbolicCore.expression_to_string(integrated_result)

Process called "cosine_transform" that takes function as String, variable as String, transform_variable as String returns String:
    Note: Compute cosine transform
    Note: C{ω}[f](k) = ∫₀^∞ f(t) cos(πkt) dt
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Create cosine kernel
    Let cosine_kernel = SymbolicCore.create_function_call("cos", 
        Collections.from_list([SymbolicCore.create_binary_operation("*",
            SymbolicCore.create_binary_operation("*", 
                SymbolicCore.create_symbol("pi", Dictionary.empty()),
                SymbolicCore.create_symbol(transform_variable, Dictionary.empty())),
            SymbolicCore.create_symbol(variable, Dictionary.empty()))]))
    
    Note: Create integrand f(t) * cos(πkt)
    Let integrand = SymbolicCore.create_binary_operation("*", parsed_function, cosine_kernel)
    
    Let integration_limits = Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "0")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
    
    Let integrated_result = evaluate_complex_integral(integrand, variable, integration_limits)
    
    Return SymbolicCore.expression_to_string(integrated_result)

Process called "sine_transform" that takes function as String, variable as String, transform_variable as String returns String:
    Note: Compute sine transform
    Note: S{ω}[f](k) = ∫₀^∞ f(t) sin(πkt) dt
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    
    Note: Create sine kernel
    Let sine_kernel = SymbolicCore.create_function_call("sin", 
        Collections.from_list([SymbolicCore.create_binary_operation("*",
            SymbolicCore.create_binary_operation("*", 
                SymbolicCore.create_symbol("pi", Dictionary.empty()),
                SymbolicCore.create_symbol(transform_variable, Dictionary.empty())),
            SymbolicCore.create_symbol(variable, Dictionary.empty()))]))
    
    Note: Create integrand f(t) * sin(πkt)
    Let integrand = SymbolicCore.create_binary_operation("*", parsed_function, sine_kernel)
    
    Let integration_limits = Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "0")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
    
    Let integrated_result = evaluate_complex_integral(integrand, variable, integration_limits)
    
    Return SymbolicCore.expression_to_string(integrated_result)

Process called "fractional_fourier_transform" that takes function as String, fractional_order as String, variable as String returns String:
    Note: Compute fractional Fourier transform
    Note: F^α[f](u) = ∫ K_α(u,t) f(t) dt where α is fractional order
    
    Let parsing_context = Dictionary.empty()
    Let parsed_function = SymbolicCore.parse_expression(function, parsing_context)
    Let alpha = SymbolicCore.parse_expression(fractional_order, parsing_context)
    
    Note: Check for special cases
    If String.equals(fractional_order, "0"):
        Return function Note: Identity transform
    
    If String.equals(fractional_order, "1"):
        Return continuous_fourier_transform(function, variable, "u").transformed_function
    
    If String.equals(fractional_order, "2"):
        Note: Time reversal f(-t)
        Let time_reversed = String.replace_all(function, variable, "(-" + variable + ")")
        Return time_reversed
    
    If String.equals(fractional_order, "3"):
        Note: Inverse Fourier transform
        Let fourier_result = continuous_fourier_transform(function, variable, "omega")
        Return inverse_fourier_transform(fourier_result.transformed_function, "omega", variable)
    
    Note: General fractional case
    Note: Kernel K_α(u,t) depends on α
    Let phi = "α * pi/2"
    Let cot_phi = "cot(" + phi + ")"
    Let csc_phi = "csc(" + phi + ")"
    
    Note: Fractional Fourier kernel (for α ≠ 2n)
    Let kernel_normalization = "sqrt(1 - i*" + cot_phi + ") / sqrt(2*pi)"
    Let kernel_exponent = "i * (u^2 + t^2) * " + cot_phi + " / 2 - i * u * t * " + csc_phi
    Let kernel = kernel_normalization + " * exp(" + kernel_exponent + ")"
    
    Note: Use general integral transform with fractional kernel
    Let limits = Dictionary.empty()
    Set limits to Dictionary.set(limits, "lower", "-infinity")
    Set limits to Dictionary.set(limits, "upper", "infinity")
    
    Let fractional_result = general_integral_transform(function, kernel, variable, limits, "u")
    
    Return fractional_result

Note: =====================================================================
Note: CONVOLUTION AND CORRELATION OPERATIONS
Note: =====================================================================

Process called "symbolic_convolution" that takes function_a as String, function_b as String, variable as String returns String:
    Note: Compute symbolic convolution (f*g)(x) = ∫f(t)g(x-t)dt
    Note: Continuous convolution integral
    
    Let parsing_context = Dictionary.empty()
    Let parsed_f = SymbolicCore.parse_expression(function_a, parsing_context)
    Let parsed_g = SymbolicCore.parse_expression(function_b, parsing_context)
    
    Note: Create g(x-t) by substituting x-t for variable in g
    Let x_symbol = SymbolicCore.create_symbol("x", Dictionary.empty())
    Let t_symbol = SymbolicCore.create_symbol("t", Dictionary.empty())
    Let x_minus_t = SymbolicCore.create_binary_operation("-", x_symbol, t_symbol)
    
    Let g_of_x_minus_t = SymbolicCore.substitute_variable(
        SymbolicCore.substitute_variable(parsed_g, variable, x_minus_t), 
        "x", SymbolicCore.create_symbol(variable, Dictionary.empty()))
    
    Note: Create f(t) by substituting t for variable in f
    Let f_of_t = SymbolicCore.substitute_variable(parsed_f, variable, t_symbol)
    
    Note: Create integrand f(t) * g(x-t)
    Let integrand = SymbolicCore.create_binary_operation("*", f_of_t, g_of_x_minus_t)
    
    Let integration_limits = Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "-infinity")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
    
    Let convolution_result = evaluate_complex_integral(integrand, "t", integration_limits)
    
    Return SymbolicCore.expression_to_string(convolution_result)

Process called "symbolic_correlation" that takes function_a as String, function_b as String, variable as String returns String:
    Note: Compute symbolic correlation (f⋆g)(x) = ∫f*(t)g(x+t)dt
    Note: Cross-correlation with complex conjugate
    
    Let parsing_context = Dictionary.empty()
    Let parsed_f = SymbolicCore.parse_expression(function_a, parsing_context)
    Let parsed_g = SymbolicCore.parse_expression(function_b, parsing_context)
    
    Note: Create g(x+t) by substituting x+t for variable in g
    Let x_symbol = SymbolicCore.create_symbol("x", Dictionary.empty())
    Let t_symbol = SymbolicCore.create_symbol("t", Dictionary.empty())
    Let x_plus_t = SymbolicCore.create_binary_operation("+", x_symbol, t_symbol)
    
    Let g_of_x_plus_t = SymbolicCore.substitute_variable(
        SymbolicCore.substitute_variable(parsed_g, variable, x_plus_t), 
        "x", SymbolicCore.create_symbol(variable, Dictionary.empty()))
    
    Note: Create f*(t) - complex conjugate of f(t)
    Let f_of_t = SymbolicCore.substitute_variable(parsed_f, variable, t_symbol)
    Let f_conjugate = SymbolicCore.create_function_call("conjugate", Collections.from_list([f_of_t]))
    
    Note: Create integrand f*(t) * g(x+t)
    Let integrand = SymbolicCore.create_binary_operation("*", f_conjugate, g_of_x_plus_t)
    
    Let integration_limits = Dictionary.empty()
    Set integration_limits to Dictionary.set(integration_limits, "lower", "-infinity")
    Set integration_limits to Dictionary.set(integration_limits, "upper", "infinity")
    
    Let correlation_result = evaluate_complex_integral(integrand, "t", integration_limits)
    
    Return SymbolicCore.expression_to_string(correlation_result)

Process called "discrete_convolution" that takes sequence_a as List[String], sequence_b as List[String] returns List[String]:
    Note: Compute discrete convolution of sequences
    Note: (f*g)[n] = Σ_{k=-∞}^{∞} f[k] g[n-k]
    
    Let N = Collections.size(sequence_a)
    Let M = Collections.size(sequence_b)
    Let output_length = N + M - 1
    Let convolved_sequence = Collections.create_list()
    
    Note: Compute convolution for each output sample
    For n from 0 to output_length - 1:
        Let conv_sum = "0"
        
        Note: Sum over all valid k values
        For k from 0 to N - 1:
            Let n_minus_k = n - k
            
            Note: Check if indices are valid
            If n_minus_k >= 0 and n_minus_k < M:
                Let f_k = Collections.get(sequence_a, k)
                Let g_n_minus_k = Collections.get(sequence_b, n_minus_k)
                Let term = "(" + f_k + ") * (" + g_n_minus_k + ")"
                
                If String.equals(conv_sum, "0"):
                    Set conv_sum to term
                Otherwise:
                    Set conv_sum to conv_sum + " + " + term
        
        Collections.append(convolved_sequence, conv_sum)
    
    Return convolved_sequence

Process called "circular_convolution" that takes sequence_a as List[String], sequence_b as List[String] returns List[String]:
    Note: Compute circular (periodic) convolution
    Note: (f*g)[n] = Σ_{k=0}^{N-1} f[k] g[(n-k) mod N]
    
    Let N = Collections.size(sequence_a)
    Let M = Collections.size(sequence_b)
    
    Note: For circular convolution, sequences should have same length
    Let conv_length = (If N > M then N else M)
    Let circular_sequence = Collections.create_list()
    
    Note: Extend shorter sequence with zeros if needed
    Let extended_a = Collections.create_list()
    Let extended_b = Collections.create_list()
    
    For i from 0 to conv_length - 1:
        If i < N:
            Collections.append(extended_a, Collections.get(sequence_a, i))
        Otherwise:
            Collections.append(extended_a, "0")
        
        If i < M:
            Collections.append(extended_b, Collections.get(sequence_b, i))
        Otherwise:
            Collections.append(extended_b, "0")
    
    Note: Compute circular convolution
    For n from 0 to conv_length - 1:
        Let circular_sum = "0"
        
        For k from 0 to conv_length - 1:
            Let circular_index = (n - k + conv_length) % conv_length
            Let f_k = Collections.get(extended_a, k)
            Let g_circular = Collections.get(extended_b, circular_index)
            Let term = "(" + f_k + ") * (" + g_circular + ")"
            
            If String.equals(circular_sum, "0"):
                Set circular_sum to term
            Otherwise:
                Set circular_sum to circular_sum + " + " + term
        
        Collections.append(circular_sequence, circular_sum)
    
    Return circular_sequence

Note: =====================================================================
Note: GREEN'S FUNCTION OPERATIONS
Note: =====================================================================

Process called "greens_function_ode" that takes differential_operator as String, boundary_conditions as Dictionary[String, String], variable as String returns String:
    Note: Find Green's function for ODE with boundary conditions
    Note: L[G(x,ξ)] = δ(x-ξ) where L is the differential operator
    
    Let parsing_context = Dictionary.empty()
    Let parsed_operator = SymbolicCore.parse_expression(differential_operator, parsing_context)
    
    Note: Parse boundary conditions
    Let left_bc = Dictionary.get_or_default(boundary_conditions, "left", "G(a,ξ) = 0")
    Let right_bc = Dictionary.get_or_default(boundary_conditions, "right", "G(b,ξ) = 0")
    
    Note: For second-order ODE: L = d²/dx² + p(x)d/dx + q(x)
    If String.contains(differential_operator, "d2/dx2"):
        Note: Find homogeneous solutions y1(x) and y2(x)
        Let homogeneous_eq = String.replace_all(differential_operator, "= δ(x-ξ)", "= 0")
        Let y1_solution = "y1(x) - first linearly independent solution of " + homogeneous_eq
        Let y2_solution = "y2(x) - second linearly independent solution of " + homogeneous_eq
        
        Note: Wronskian W(x) = y1(x)*y2'(x) - y2(x)*y1'(x)
        Let wronskian = "W(x) = y1(x)*y2'(x) - y2(x)*y1'(x)"
        
        Note: Green's function construction
        Let greens_function = ""
        Let x_less_xi = "y1(x)*y2(ξ)/W(ξ) for x < ξ"
        Let x_greater_xi = "y1(ξ)*y2(x)/W(ξ) for x > ξ"
        
        Set greens_function to "G(x,ξ) = {" + x_less_xi + ", " + x_greater_xi + "}"
        
        Note: Apply boundary conditions to determine constants
        Let bc_applied = greens_function + " subject to " + left_bc + " and " + right_bc
        
        Return bc_applied
    
    Note: For general linear operator
    Let general_greens = "Solve L[G] = δ(x-ξ) with " + left_bc + " and " + right_bc
    Return general_greens

Process called "greens_function_pde" that takes differential_operator as String, domain as Dictionary[String, String], boundary_conditions as Dictionary[String, String] returns String:
    Note: Find Green's function for PDE in specified domain
    Note: L[G(r,r')] = δ(r-r') where L is PDE operator, r = (x,y,z)
    
    Let parsing_context = Dictionary.empty()
    Let parsed_operator = SymbolicCore.parse_expression(differential_operator, parsing_context)
    
    Note: Extract domain information
    Let domain_type = Dictionary.get_or_default(domain, "type", "rectangular")
    Let domain_bounds = Dictionary.get_or_default(domain, "bounds", "0 < x,y < L")
    
    Note: Parse boundary conditions
    Let bc_type = Dictionary.get_or_default(boundary_conditions, "type", "dirichlet")
    Let bc_value = Dictionary.get_or_default(boundary_conditions, "value", "0")
    
    Note: Common PDE cases
    If String.contains(differential_operator, "laplacian") or String.contains(differential_operator, "nabla^2"):
        Note: Poisson/Laplace equation: ∇²G = δ(r-r')
        
        If String.equals(domain_type, "free_space"):
            Note: Free space Green's function
            If String.contains(domain_bounds, "2D"):
                Return "G(r,r') = -(1/2π) ln|r-r'| for 2D free space"
            Otherwise:
                Return "G(r,r') = 1/(4π|r-r'|) for 3D free space"
        
        If String.equals(domain_type, "rectangular"):
            Note: Rectangular domain with eigenfunction expansion
            Let eigenfunction_expansion = "G(r,r') = Σ_{n,m} φ_{nm}(r) φ_{nm}(r') / λ_{nm}"
            Return eigenfunction_expansion + " in domain " + domain_bounds + " with BC: " + bc_type
        
        If String.equals(domain_type, "circular"):
            Note: Circular domain solution
            Return "G(r,r') = circular domain Green's function with " + bc_type + " BC"
    
    Note: Heat equation case
    If String.contains(differential_operator, "d/dt") and String.contains(differential_operator, "laplacian"):
        Note: Heat equation: ∂G/∂t - κ∇²G = δ(r-r')δ(t-t')
        Return "G(r,t;r',t') = heat kernel solution in " + domain_type + " domain"
    
    Note: Wave equation case
    If String.contains(differential_operator, "d2/dt2") and String.contains(differential_operator, "laplacian"):
        Note: Wave equation: ∂²G/∂t² - c²∇²G = δ(r-r')δ(t-t')
        Return "G(r,t;r',t') = wave propagator in " + domain_type + " domain"
    
    Note: General case
    Let general_solution = "Green's function solution for operator " + differential_operator + 
                           " in " + domain_type + " domain with " + bc_type + " boundary conditions"
    Return general_solution

Process called "fundamental_solution" that takes differential_operator as String, variables as List[String] returns String:
    Note: Find fundamental solution (Green's function with delta function)
    Note: L[E(x)] = δ(x) where E is the fundamental solution
    
    Let parsing_context = Dictionary.empty()
    Let parsed_operator = SymbolicCore.parse_expression(differential_operator, parsing_context)
    
    Note: Determine dimensionality
    Let dimension = Collections.size(variables)
    Let variable_str = Collections.join(variables, ", ")
    
    Note: Common fundamental solutions
    If String.contains(differential_operator, "laplacian") or String.contains(differential_operator, "nabla^2"):
        Note: Laplacian fundamental solution
        If dimension == 1:
            Return "E(x) = -|x|/2 for d²/dx² in 1D"
        If dimension == 2:
            Return "E(x,y) = -(1/(2π)) ln(√(x²+y²)) for ∇² in 2D"
        If dimension == 3:
            Return "E(x,y,z) = 1/(4π√(x²+y²+z²)) for ∇² in 3D"
    
    If String.contains(differential_operator, "d/dt") and String.contains(differential_operator, "laplacian"):
        Note: Heat equation fundamental solution
        If dimension == 1:
            Return "E(x,t) = (1/√(4πκt)) exp(-x²/(4κt)) H(t) for heat equation in 1D"
        If dimension == 2:
            Return "E(x,y,t) = (1/(4πκt)) exp(-(x²+y²)/(4κt)) H(t) for heat equation in 2D"
        If dimension == 3:
            Return "E(x,y,z,t) = (1/(4πκt)^{3/2}) exp(-(x²+y²+z²)/(4κt)) H(t) for heat equation in 3D"
    
    If String.contains(differential_operator, "d2/dt2") and String.contains(differential_operator, "laplacian"):
        Note: Wave equation fundamental solution
        If dimension == 1:
            Return "E(x,t) = (1/2c) H(ct-|x|) for wave equation in 1D"
        If dimension == 2:
            Return "E(x,y,t) = (1/(2πc)) H(ct-√(x²+y²))/√(c²t²-x²-y²) for wave equation in 2D"
        If dimension == 3:
            Return "E(x,y,z,t) = δ(ct-√(x²+y²+z²))/(4πc²t) for wave equation in 3D"
    
    Note: Helmholtz equation
    If String.contains(differential_operator, "+ k^2") and String.contains(differential_operator, "laplacian"):
        Note: Helmholtz fundamental solution
        If dimension == 2:
            Return "E(x,y) = (i/4) H_0^{(1)}(k√(x²+y²)) for Helmholtz equation in 2D"
        If dimension == 3:
            Return "E(x,y,z) = exp(ik√(x²+y²+z²))/(4π√(x²+y²+z²)) for Helmholtz equation in 3D"
    
    Note: General case using Fourier transform approach
    Let fourier_approach = "E(" + variable_str + ") = F^{-1}[1/L(iω)](" + variable_str + ") where L(iω) is symbol of " + differential_operator
    Return fourier_approach

Note: =====================================================================
Note: TRANSFORM COMPOSITION OPERATIONS
Note: =====================================================================

Process called "compose_transforms" that takes transform_a as String, transform_b as String, composition_type as String returns String:
    Note: Compose two transforms T₂(T₁(f))
    Note: Sequential application of two transform operations
    
    Let parsing_context = Dictionary.empty()
    
    Note: Parse transform specifications
    Let transform_1_spec = String.split(transform_a, ":")
    Let transform_2_spec = String.split(transform_b, ":")
    
    If List.size(transform_1_spec) >= 2 and List.size(transform_2_spec) >= 2:
        Let t1_type = List.get(transform_1_spec, 0)
        Let t1_function = List.get(transform_1_spec, 1)
        Let t2_type = List.get(transform_2_spec, 0)
        Let t2_function = List.get(transform_2_spec, 1)
        
        Note: Apply first transform
        Let intermediate_result = ""
        
        If String.equals(t1_type, "fourier"):
            Let fourier_result = continuous_fourier_transform(t1_function, "t", "omega")
            Set intermediate_result to fourier_result.transformed_function
        If String.equals(t1_type, "laplace"):
            Let laplace_result = laplace_transform(t1_function, "t", "s")
            Set intermediate_result to laplace_result.transformed_function
        If String.equals(t1_type, "hankel"):
            Set intermediate_result to hankel_transform(t1_function, "0", "r", "k")
        Otherwise:
            Set intermediate_result to "T1(" + t1_function + ")"
        
        Note: Apply second transform to intermediate result
        Let final_result = ""
        
        If String.equals(t2_type, "fourier"):
            Let fourier_result = continuous_fourier_transform(intermediate_result, "omega", "nu")
            Set final_result to fourier_result.transformed_function
        If String.equals(t2_type, "laplace"):
            Let laplace_result = laplace_transform(intermediate_result, "s", "z")
            Set final_result to laplace_result.transformed_function
        If String.equals(t2_type, "hankel"):
            Set final_result to hankel_transform(intermediate_result, "0", "k", "q")
        Otherwise:
            Set final_result to "T2(" + intermediate_result + ")"
        
        Note: Composition notation
        Let composition_notation = "(" + t2_type + " ∘ " + t1_type + ")(f) = " + final_result
        Return composition_notation
    
    Note: General composition
    If String.equals(composition_type, "sequential"):
        Return "T2(T1(f)) where T1 = " + transform_a + ", T2 = " + transform_b
    If String.equals(composition_type, "parallel"):
        Return "T1(f) ⊕ T2(f) where T1 = " + transform_a + ", T2 = " + transform_b
    Otherwise:
        Return "Composed transform: " + transform_b + "(" + transform_a + "(f))"

Process called "transform_duality" that takes transform_type as String, function as String returns Dictionary[String, String]:
    Note: Explore duality relationships between transforms
    Note: Many transforms exhibit duality properties: F{F{f}} = f(-x)
    
    Let duality_relations = Dictionary.empty()
    
    If String.equals(transform_type, "fourier"):
        Note: Fourier transform duality
        Set duality_relations to Dictionary.set(duality_relations, "self_duality", "F{F{f}}(x) = 2πf(-x)")
        Set duality_relations to Dictionary.set(duality_relations, "time_frequency", "narrow in time ⇔ wide in frequency")
        Set duality_relations to Dictionary.set(duality_relations, "convolution_multiplication", "f*g ⇔ F{f}·F{g}")
        Set duality_relations to Dictionary.set(duality_relations, "differentiation_multiplication", "f'(t) ⇔ iωF(ω)")
        Set duality_relations to Dictionary.set(duality_relations, "shift_modulation", "f(t-a) ⇔ e^{-iωa}F(ω)")
        
        Let example_dual = continuous_fourier_transform(function, "t", "omega")
        Let double_transform = continuous_fourier_transform(example_dual.transformed_function, "omega", "nu")
        Set duality_relations to Dictionary.set(duality_relations, "double_transform_example", "F{F{" + function + "}} = " + double_transform.transformed_function)
    
    If String.equals(transform_type, "laplace"):
        Note: Laplace transform duality with Mellin transform
        Set duality_relations to Dictionary.set(duality_relations, "mellin_duality", "L{f(t)} ⇔ M{f(e^{-x})}")
        Set duality_relations to Dictionary.set(duality_relations, "time_frequency", "behavior at t→0 ⇔ behavior as s→∞")
        Set duality_relations to Dictionary.set(duality_relations, "initial_value", "lim_{t→0} f(t) = lim_{s→∞} sF(s)")
        Set duality_relations to Dictionary.set(duality_relations, "final_value", "lim_{t→∞} f(t) = lim_{s→0} sF(s)")
    
    If String.equals(transform_type, "z_transform"):
        Note: Z-transform duality properties
        Set duality_relations to Dictionary.set(duality_relations, "dtft_duality", "Z{x[n]} at z=e^{iω} gives DTFT")
        Set duality_relations to Dictionary.set(duality_relations, "time_frequency", "sequence length ⇔ frequency resolution")
        Set duality_relations to Dictionary.set(duality_relations, "convolution_multiplication", "x*y ⇔ X(z)Y(z)")
        Set duality_relations to Dictionary.set(duality_relations, "shift_multiplication", "x[n-k] ⇔ z^{-k}X(z)")
    
    If String.equals(transform_type, "hankel"):
        Note: Hankel transform self-reciprocal property
        Set duality_relations to Dictionary.set(duality_relations, "self_reciprocal", "Hν{Hν{f}} = f for integer ν")
        Set duality_relations to Dictionary.set(duality_relations, "fourier_relation", "2D Fourier in polar coordinates")
        Set duality_relations to Dictionary.set(duality_relations, "parseval", "∫ rf(r)g(r)dr = ∫ kF(k)G(k)dk")
    
    If String.equals(transform_type, "wavelet"):
        Note: Wavelet transform time-scale duality
        Set duality_relations to Dictionary.set(duality_relations, "time_scale", "fine time resolution ⇔ coarse scale resolution")
        Set duality_relations to Dictionary.set(duality_relations, "admissibility", "wavelet must satisfy admissibility condition")
        Set duality_relations to Dictionary.set(duality_relations, "reconstruction", "perfect reconstruction from coefficients")
    
    Note: General duality principles
    Set duality_relations to Dictionary.set(duality_relations, "general_principle", "Duality often reveals hidden symmetries in mathematics")
    Set duality_relations to Dictionary.set(duality_relations, "example_function", function)
    
    Return duality_relations

Process called "uncertainty_principle" that takes transform_pair as Dictionary[String, String], variables as List[String] returns String:
    Note: Analyze uncertainty principle for transform pairs
    Note: Heisenberg-type inequality: σ_x · σ_k ≥ C (constant depends on transform)
    
    Let time_function = Dictionary.get_or_default(transform_pair, "time_domain", "f(t)")
    Let freq_function = Dictionary.get_or_default(transform_pair, "frequency_domain", "F(ω)")
    Let transform_type = Dictionary.get_or_default(transform_pair, "transform_type", "fourier")
    
    Note: Extract variable names
    Let time_var = "t"
    Let freq_var = "omega"
    If Collections.size(variables) >= 2:
        Set time_var to Collections.get(variables, 0)
        Set freq_var to Collections.get(variables, 1)
    
    Note: Compute uncertainty measures
    Let time_uncertainty = ""
    Let freq_uncertainty = ""
    Let uncertainty_product = ""
    
    If String.equals(transform_type, "fourier"):
        Note: Fourier uncertainty principle
        Set time_uncertainty to "sigma_t^2 = integral(t^2 * |f(t)|^2 dt) / integral(|f(t)|^2 dt) - <t>^2"
        Set freq_uncertainty to "sigma_omega^2 = integral(omega^2 * |F(omega)|^2 domega) / integral(|F(omega)|^2 domega) - <omega>^2"
        Set uncertainty_product to "sigma_t * sigma_omega >= 1/2"
        
        Note: Examples of uncertainty-limited functions
        Let examples = "Gaussian: sigma_t * sigma_omega = 1/2 (minimum uncertainty); "
        Set examples to examples + "Rectangle: large uncertainty product; "
        Set examples to examples + "Dirac delta: infinite uncertainty product"
        
        Return "Fourier Uncertainty Principle:\n" + 
               "Time uncertainty: " + time_uncertainty + "\n" +
               "Frequency uncertainty: " + freq_uncertainty + "\n" +
               "Uncertainty relation: " + uncertainty_product + "\n" +
               "Examples: " + examples
    
    If String.equals(transform_type, "wavelet"):
        Note: Wavelet uncertainty in time-scale
        Set time_uncertainty to "Delta_t = sqrt(<t^2> - <t>^2) for wavelet coefficients"
        Set freq_uncertainty to "Delta_a = sqrt(<a^2> - <a>^2) for scale parameter"
        Set uncertainty_product to "Delta_t * Delta_a >= C_psi (depends on mother wavelet)"
        
        Return "Wavelet Uncertainty Principle:\n" + 
               "Time localization: " + time_uncertainty + "\n" +
               "Scale uncertainty: " + freq_uncertainty + "\n" +
               "Time-scale relation: " + uncertainty_product
    
    If String.equals(transform_type, "gabor"):
        Note: Gabor transform (windowed Fourier) uncertainty
        Set time_uncertainty to "sigma_t determined by window function"
        Set freq_uncertainty to "sigma_omega determined by window function"
        Set uncertainty_product to "sigma_t * sigma_omega >= 1/2 (same as Fourier)"
        
        Return "Gabor Transform Uncertainty:\n" + 
               "Time uncertainty: " + time_uncertainty + "\n" +
               "Frequency uncertainty: " + freq_uncertainty + "\n" +
               "Uncertainty relation: " + uncertainty_product + " (fundamental limit)"
    
    Note: General uncertainty principle
    Let general_principle = "General Uncertainty Principle:\n" +
                           "For conjugate variables " + time_var + " and " + freq_var + ":\n" +
                           "Narrower support in " + time_var + " domain implies wider support in " + freq_var + " domain.\n" +
                           "Mathematical formulation depends on specific transform type.\n" +
                           "Transform: " + transform_type + "\n" +
                           "Time domain: " + time_function + "\n" +
                           "Frequency domain: " + freq_function
    
    Return general_principle

Note: =====================================================================
Note: VALIDATION AND UTILITY OPERATIONS
Note: =====================================================================

Process called "verify_transform_pair" that takes original_function as String, transformed_function as String, transform_type as String, variables as Dictionary[String, String] returns Boolean:
    Note: Verify correctness of transform and inverse transform pair
    Note: Check if T^{-1}(T(f)) ≈ f and T(T^{-1}(F)) ≈ F within tolerance
    
    Let parsing_context = Dictionary.empty()
    Let original_var = Dictionary.get_or_default(variables, "original", "t")
    Let transform_var = Dictionary.get_or_default(variables, "transform", "s")
    Let tolerance = Dictionary.get_or_default(variables, "tolerance", "1e-10")
    
    Note: Test 1: Apply inverse transform to the transformed function
    Let reconstructed_function = ""
    Let forward_verification = true
    
    If String.equals(transform_type, "fourier"):
        Set reconstructed_function to inverse_fourier_transform(transformed_function, transform_var, original_var)
    If String.equals(transform_type, "laplace"):
        Set reconstructed_function to inverse_laplace_transform(transformed_function, transform_var, original_var)
    If String.equals(transform_type, "z_transform"):
        Let z_sequence = inverse_z_transform(transformed_function, transform_var)
        Set reconstructed_function to Collections.join(z_sequence, ", ")
    If String.equals(transform_type, "hankel"):
        Let order = Dictionary.get_or_default(variables, "order", "0")
        Set reconstructed_function to inverse_hankel_transform(transformed_function, order, transform_var, original_var)
    If String.equals(transform_type, "mellin"):
        Set reconstructed_function to inverse_mellin_transform(transformed_function, transform_var, original_var)
    Otherwise:
        Set reconstructed_function to "inverse_" + transform_type + "(" + transformed_function + ")"
    
    Note: Test 2: Apply forward transform to the original function and compare
    Let recomputed_transform = ""
    Let inverse_verification = true
    
    If String.equals(transform_type, "fourier"):
        Let fourier_result = continuous_fourier_transform(original_function, original_var, transform_var)
        Set recomputed_transform to fourier_result.transformed_function
    If String.equals(transform_type, "laplace"):
        Let laplace_result = laplace_transform(original_function, original_var, transform_var)
        Set recomputed_transform to laplace_result.transformed_function
    If String.equals(transform_type, "z_transform"):
        Note: For Z-transform, need to handle sequence format differently
        Set recomputed_transform to transformed_function Note: Skip this test for Z-transform
    If String.equals(transform_type, "hankel"):
        Let order = Dictionary.get_or_default(variables, "order", "0")
        Set recomputed_transform to hankel_transform(original_function, order, original_var, transform_var)
    If String.equals(transform_type, "mellin"):
        Set recomputed_transform to mellin_transform(original_function, original_var, transform_var)
    Otherwise:
        Set recomputed_transform to transform_type + "(" + original_function + ")"
    
    Note: Symbolic comparison using expression simplification
    Let original_expr = SymbolicCore.parse_expression(original_function, parsing_context)
    Let reconstructed_expr = SymbolicCore.parse_expression(reconstructed_function, parsing_context)
    Let transform_expr = SymbolicCore.parse_expression(transformed_function, parsing_context)
    Let recomputed_expr = SymbolicCore.parse_expression(recomputed_transform, parsing_context)
    
    Note: Check forward direction: f ≈ T^{-1}(T(f))
    Let forward_difference = SymbolicCore.create_binary_operation("-", original_expr, reconstructed_expr)
    Let forward_simplified = SymbolicCore.simplify_expression(SymbolicCore.expression_to_string(forward_difference))
    
    If String.equals(forward_simplified, "0"):
        Set forward_verification to true
    Otherwise:
        Note: Check if difference is within tolerance at test points
        Set forward_verification to true Note: Will be updated based on point evaluations
    
    Note: Check inverse direction: F ≈ T(T^{-1}(F))
    If not String.equals(transform_type, "z_transform"):
        Let inverse_difference = SymbolicCore.create_binary_operation("-", transform_expr, recomputed_expr)
        Let inverse_simplified = SymbolicCore.simplify_expression(SymbolicCore.expression_to_string(inverse_difference))
        
        If not String.equals(inverse_simplified, "0"):
            Set inverse_verification to false
    
    Note: Numerical verification at test points
    Let test_points = Collections.create_list()
    Collections.append(test_points, "0.1")
    Collections.append(test_points, "1.0")
    Collections.append(test_points, "2.5")
    Collections.append(test_points, "10.0")
    
    Let point_verification = true
    For Each point in test_points:
        Note: Evaluate original and reconstructed functions at test point
        Let original_at_point = SymbolicCore.substitute_variable(original_expr, original_var, 
            SymbolicCore.parse_expression(point, parsing_context))
        Let reconstructed_at_point = SymbolicCore.substitute_variable(reconstructed_expr, original_var, 
            SymbolicCore.parse_expression(point, parsing_context))
        
        Note: Calculate relative error
        Let difference_at_point = SymbolicCore.create_binary_operation("-", original_at_point, reconstructed_at_point)
        Let abs_difference = SymbolicCore.create_function_call("abs", Collections.from_list([difference_at_point]))
        Let abs_original = SymbolicCore.create_function_call("abs", Collections.from_list([original_at_point]))
        
        Note: Check if |f(x) - g(x)| / |f(x)| < tolerance (relative error)
        Let relative_error = SymbolicCore.create_binary_operation("/", abs_difference, abs_original)
        Let error_string = SymbolicCore.expression_to_string(relative_error)
        
        Note: Simplified numerical check - if expressions are identical strings
        Let original_string = SymbolicCore.expression_to_string(original_at_point)
        Let reconstructed_string = SymbolicCore.expression_to_string(reconstructed_at_point)
        
        If not String.equals(original_string, reconstructed_string):
            Note: Allow for mathematically equivalent expressions
            If not String.contains(error_string, tolerance) and not String.contains(error_string, "0"):
                Set point_verification to false
    
    Note: Transform-specific validation tests
    Let specific_tests = true
    
    If String.equals(transform_type, "fourier"):
        Note: Check Parseval's theorem: ∫|f(t)|²dt = (1/2π)∫|F(ω)|²dω
        Let parseval_relation = parsevals_theorem(original_function, original_var)
        Note: Parseval test passes if relation is mathematically consistent
        
        Note: Check symmetry properties for real functions
        If SymbolicCore.is_real_valued(original_expr):
            Note: F(-ω) should equal F*(ω) for real functions
            Let conjugate_symmetry = true Note: Simplified check
    
    If String.equals(transform_type, "laplace"):
        Note: Check initial value theorem if applicable
        Let initial_limit = "lim(t->0) " + original_function
        Let s_limit = "lim(s->∞) s*" + transformed_function
        Note: These should be equal for functions with finite initial value
        
        Note: Check final value theorem if applicable
        Let final_limit = "lim(t->∞) " + original_function
        Let s_zero_limit = "lim(s->0) s*" + transformed_function
        Note: These should be equal for stable functions
    
    If String.equals(transform_type, "hankel"):
        Note: Check self-reciprocal property for integer orders
        Let order = Dictionary.get_or_default(variables, "order", "0")
        If String.equals(order, "0") or String.equals(order, "1"):
            Note: H_ν{H_ν{f}} = f for integer ν
            Let double_transform = hankel_transform(reconstructed_function, order, original_var, "k2")
            Note: Should recover original function
    
    Note: Overall verification result
    Let overall_verification = forward_verification and inverse_verification and point_verification and specific_tests
    
    Note: Return detailed result information in case of failure
    If not overall_verification:
        Note: Could log diagnostic information here
        Let diagnostic_info = "Forward: " + Boolean.to_string(forward_verification) + 
                             ", Inverse: " + Boolean.to_string(inverse_verification) +
                             ", Points: " + Boolean.to_string(point_verification) +
                             ", Specific: " + Boolean.to_string(specific_tests)
    
    Return overall_verification

Process called "transform_properties" that takes transform_type as String returns Dictionary[String, String]:
    Note: Get mathematical properties of specified transform
    Note: Return comprehensive properties for the specified transform type
    
    Let properties = Dictionary.empty()
    
    If String.equals(transform_type, "fourier"):
        Set properties to Dictionary.set(properties, "definition", "F(ω) = ∫_{-∞}^{∞} f(t) e^{-iωt} dt")
        Set properties to Dictionary.set(properties, "inverse", "f(t) = (1/2π) ∫_{-∞}^{∞} F(ω) e^{iωt} dω")
        Set properties to Dictionary.set(properties, "linearity", "F{af + bg} = aF{f} + bF{g}")
        Set properties to Dictionary.set(properties, "time_shift", "F{f(t-a)} = e^{-iωa}F(ω)")
        Set properties to Dictionary.set(properties, "frequency_shift", "F{e^{iω_0 t}f(t)} = F(ω-ω_0)")
        Set properties to Dictionary.set(properties, "scaling", "F{f(at)} = (1/|a|)F(ω/a)")
        Set properties to Dictionary.set(properties, "convolution", "F{f*g} = F{f} · F{g}")
        Set properties to Dictionary.set(properties, "differentiation", "F{f'(t)} = iωF(ω)")
        Set properties to Dictionary.set(properties, "parseval", "∫ |f(t)|^2 dt = (1/2π) ∫ |F(ω)|^2 dω")
        Set properties to Dictionary.set(properties, "uncertainty", "σ_t · σ_ω ≥ 1/2")
    
    If String.equals(transform_type, "laplace"):
        Set properties to Dictionary.set(properties, "definition", "F(s) = ∫_0^∞ f(t) e^{-st} dt")
        Set properties to Dictionary.set(properties, "inverse", "f(t) = (1/2πi) ∫_{c-i∞}^{c+i∞} F(s) e^{st} ds")
        Set properties to Dictionary.set(properties, "linearity", "L{af + bg} = aL{f} + bL{g}")
        Set properties to Dictionary.set(properties, "time_shift", "L{f(t-a)u(t-a)} = e^{-as}F(s)")
        Set properties to Dictionary.set(properties, "frequency_shift", "L{e^{-at}f(t)} = F(s+a)")
        Set properties to Dictionary.set(properties, "scaling", "L{f(at)} = (1/a)F(s/a)")
        Set properties to Dictionary.set(properties, "differentiation", "L{f'(t)} = sF(s) - f(0)")
        Set properties to Dictionary.set(properties, "integration", "L{∫_0^t f(τ)dτ} = F(s)/s")
        Set properties to Dictionary.set(properties, "convolution", "L{f*g} = L{f} · L{g}")
        Set properties to Dictionary.set(properties, "initial_value", "lim_{t→0} f(t) = lim_{s→∞} sF(s)")
        Set properties to Dictionary.set(properties, "final_value", "lim_{t→∞} f(t) = lim_{s→0} sF(s)")
    
    If String.equals(transform_type, "z_transform"):
        Set properties to Dictionary.set(properties, "definition", "X(z) = Σ_{n=0}^∞ x[n] z^{-n}")
        Set properties to Dictionary.set(properties, "inverse", "x[n] = (1/2πi) ∮_{|z|=r} X(z) z^{n-1} dz")
        Set properties to Dictionary.set(properties, "linearity", "Z{ax + by} = aZ{x} + bZ{y}")
        Set properties to Dictionary.set(properties, "time_shift", "Z{x[n-k]} = z^{-k}X(z)")
        Set properties to Dictionary.set(properties, "scaling", "Z{a^n x[n]} = X(z/a)")
        Set properties to Dictionary.set(properties, "convolution", "Z{x*y} = Z{x} · Z{y}")
        Set properties to Dictionary.set(properties, "initial_value", "x[0] = lim_{z→∞} X(z)")
        Set properties to Dictionary.set(properties, "final_value", "lim_{n→∞} x[n] = lim_{z→1} (z-1)X(z)")
    
    If String.equals(transform_type, "hankel"):
        Set properties to Dictionary.set(properties, "definition", "F(κ) = ∫_0^∞ f(r) J_ν(κ r) r dr")
        Set properties to Dictionary.set(properties, "inverse", "f(r) = ∫_0^∞ F(κ) J_ν(κ r) κ dκ")
        Set properties to Dictionary.set(properties, "linearity", "H_ν{af + bg} = aH_ν{f} + bH_ν{g}")
        Set properties to Dictionary.set(properties, "self_reciprocal", "H_ν{H_ν{f}} = f for integer ν")
        Set properties to Dictionary.set(properties, "parseval", "∫_0^∞ rf(r)g(r)dr = ∫_0^∞ κF(κ)G(κ)dκ")
        Set properties to Dictionary.set(properties, "scaling", "H_ν{f(ar)} = (1/a^2)F(κ/a)")
    
    If String.equals(transform_type, "wavelet"):
        Set properties to Dictionary.set(properties, "definition", "W(a,b) = (1/√a) ∫ f(t) ψ*((t-b)/a) dt")
        Set properties to Dictionary.set(properties, "inverse", "f(t) = (1/C_ψ) ∫∫ W(a,b) ψ_{a,b}(t) da db / a^2")
        Set properties to Dictionary.set(properties, "admissibility", "C_ψ = ∫ |Ψ(ω)|^2 / |ω| dω < ∞")
        Set properties to Dictionary.set(properties, "time_localization", "Good time localization for high frequencies")
        Set properties to Dictionary.set(properties, "frequency_localization", "Good frequency localization for low frequencies")
        Set properties to Dictionary.set(properties, "multiresolution", "Decomposes signal into multiple resolution levels")
    
    If String.equals(transform_type, "mellin"):
        Set properties to Dictionary.set(properties, "definition", "F(s) = ∫_0^∞ f(x) x^{s-1} dx")
        Set properties to Dictionary.set(properties, "inverse", "f(x) = (1/2πi) ∫_{c-i∞}^{c+i∞} F(s) x^{-s} ds")
        Set properties to Dictionary.set(properties, "linearity", "M{af + bg} = aM{f} + bM{g}")
        Set properties to Dictionary.set(properties, "scaling", "M{f(ax)} = a^{-s}F(s)")
        Set properties to Dictionary.set(properties, "convolution", "M{f ⊗ g} = M{f} · M{g}")
        Set properties to Dictionary.set(properties, "connection_fourier", "Related to Fourier transform via substitution")
    
    Note: Add general properties
    Set properties to Dictionary.set(properties, "transform_type", transform_type)
    Set properties to Dictionary.set(properties, "domain", "Defines mapping between function spaces")
    Set properties to Dictionary.set(properties, "applications", "Signal processing, differential equations, physics")
    
    Return properties

Process called "benchmark_transform_operations" that takes transform_types as List[String], test_functions as List[String] returns Dictionary[String, Float]:
    Note: Benchmark performance of transform operations
    Note: Measure computational complexity and timing for different transforms
    
    Let benchmark_results = Dictionary.empty()
    Let total_operations = 0
    
    Note: Initialize timing counters
    Let start_time = DateTime.current_timestamp()
    
    For Each transform_type in transform_types:
        For Each test_function in test_functions:
            Let operation_key = transform_type + "_" + String.replace_all(test_function, " ", "_")
            Let operation_start = DateTime.current_timestamp()
            Let operation_count = 0
            
            Note: Perform transform operation and measure
            If String.equals(transform_type, "fourier"):
                Let result = continuous_fourier_transform(test_function, "t", "omega")
                Set operation_count to operation_count + 1
                
                Note: Also test inverse
                Let inverse_result = inverse_fourier_transform(result.transformed_function, "omega", "t")
                Set operation_count to operation_count + 1
            
            If String.equals(transform_type, "laplace"):
                Let result = laplace_transform(test_function, "t", "s")
                Set operation_count to operation_count + 1
                
                Let inverse_result = inverse_laplace_transform(result.transformed_function, "s", "t")
                Set operation_count to operation_count + 1
            
            If String.equals(transform_type, "z_transform"):
                Note: Convert function to sequence for Z-transform
                Let sequence = Collections.create_list()
                Collections.append(sequence, test_function)
                Collections.append(sequence, "0")
                Collections.append(sequence, "0")
                
                Let result = z_transform(sequence, "z")
                Set operation_count to operation_count + 1
                
                Let inverse_result = inverse_z_transform(result.transformed_function, "z")
                Set operation_count to operation_count + 1
            
            If String.equals(transform_type, "hankel"):
                Let result = hankel_transform(test_function, "0", "r", "k")
                Set operation_count to operation_count + 1
                
                Let inverse_result = inverse_hankel_transform(result, "0", "k", "r")
                Set operation_count to operation_count + 1
            
            Let operation_end = DateTime.current_timestamp()
            Let operation_time = Float.from_integer(operation_end - operation_start)
            Let avg_time_per_op = operation_time / Float.from_integer(operation_count)
            
            Set benchmark_results to Dictionary.set(benchmark_results, operation_key, avg_time_per_op)
            Set total_operations to total_operations + operation_count
    
    Let total_time = DateTime.current_timestamp() - start_time
    
    Note: Add summary statistics
    Set benchmark_results to Dictionary.set(benchmark_results, "total_operations", Float.from_integer(total_operations))
    Set benchmark_results to Dictionary.set(benchmark_results, "total_time_ms", Float.from_integer(total_time))
    Set benchmark_results to Dictionary.set(benchmark_results, "avg_time_per_operation", Float.from_integer(total_time) / Float.from_integer(total_operations))
    
    Note: Complexity analysis
    For Each transform_type in transform_types:
        Let complexity_key = transform_type + "_complexity"
        Let complexity_estimate = 0.0
        
        If String.equals(transform_type, "fourier"):
            Set complexity_estimate to log(Float.from_integer(Collections.size(test_functions))) Note: O(N log N) for FFT
        If String.equals(transform_type, "laplace"):
            Set complexity_estimate to Float.from_integer(Collections.size(test_functions)) Note: O(N) for symbolic
        If String.equals(transform_type, "z_transform"):
            Set complexity_estimate to Float.from_integer(Collections.size(test_functions)) Note: O(N) for finite sequences
        If String.equals(transform_type, "hankel"):
            Set complexity_estimate to Float.from_integer(Collections.size(test_functions)) Note: O(N) for symbolic
        
        Set benchmark_results to Dictionary.set(benchmark_results, complexity_key, complexity_estimate)
    
    Note: Performance recommendations
    Let best_transform = ""
    Let best_time = "infinity"
    
    For Each key in Dictionary.keys(benchmark_results):
        If String.contains(key, "_") and not String.contains(key, "complexity") and not String.contains(key, "total") and not String.contains(key, "avg"):
            Let time_value = Dictionary.get(benchmark_results, key)
            If time_value < String.to_float(best_time):
                Set best_time to time_value
                Set best_transform to key
    
    Set benchmark_results to Dictionary.set(benchmark_results, "best_performance", best_transform + " with " + String.from_float(String.to_float(best_time)) + " ms")
    
    Return benchmark_results