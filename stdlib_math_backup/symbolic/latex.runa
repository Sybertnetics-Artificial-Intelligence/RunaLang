Note:
math/symbolic/latex.runa
LaTeX Mathematical Notation Export and Formatting System

This module provides comprehensive LaTeX mathematical notation export including:
- Expression-to-LaTeX conversion with proper formatting
- Mathematical symbol mapping and Unicode handling
- Equation environment generation (align, gather, split)
- Matrix and array formatting with alignment options
- Fraction display with numerator/denominator styling
- Superscript and subscript positioning
- Integral and summation notation with proper limits
- Function notation and operator precedence handling
- Custom LaTeX command generation and macros
- Bibliography and citation integration for math
- Document structure generation for mathematical papers
- Presentation slide formatting for mathematical content
- Interactive LaTeX with TikZ diagram integration
- LaTeX parsing and reverse conversion to symbolic expressions
- Error detection and LaTeX syntax validation
:End Note

Import "dev/debug/errors/core" as Errors
Import "math/symbolic/core" as SymbolicCore
Import "math/symbols/greek_letters" as GreekLetters
Import "text/string/manipulation" as StringManip
Import "text/string/builder" as StringBuilder

Note: =====================================================================
Note: LATEX FORMATTING DATA STRUCTURES
Note: =====================================================================

Type called "LaTeXExpression":
    latex_code as String
    expression_type as String
    formatting_options as Dictionary[String, String]
    required_packages as List[String]
    custom_commands as Dictionary[String, String]
    display_mode as String

Type called "LaTeXDocument":
    document_class as String
    preamble as String
    document_body as String
    required_packages as List[String]
    custom_definitions as Dictionary[String, String]
    bibliography as String

Type called "LaTeXMatrix":
    matrix_type as String
    entries as List[List[String]]
    alignment as String
    delimiters as Dictionary[String, String]
    spacing_options as Dictionary[String, String]

Type called "LaTeXEquation":
    equation_content as String
    equation_environment as String
    label as String
    numbering as Boolean
    alignment_points as List[String]
    multiline as Boolean

Type called "LaTeXSymbol":
    symbol_name as String
    latex_command as String
    unicode_representation as String
    symbol_category as String
    required_package as String
    font_specification as String

Note: =====================================================================
Note: BASIC EXPRESSION CONVERSION OPERATIONS
Note: =====================================================================

Process called "expression_to_latex" that takes expression as String, formatting_options as Dictionary[String, String] returns LaTeXExpression:
    Note: Convert mathematical expression to LaTeX format
    Let parsed_expression be SymbolicCore.parse_expression(expression, {})
    Let latex_code be convert_expression_to_latex_code(parsed_expression, formatting_options)
    Let display_mode be formatting_options.get("display_mode", "inline")
    Let required_packages be determine_required_packages(latex_code)
    Return {
        "latex_code": latex_code,
        "expression_type": "mathematical",
        "formatting_options": formatting_options,
        "required_packages": required_packages,
        "custom_commands": {},
        "display_mode": display_mode
    }

Process called "latex_to_expression" that takes latex_code as String, parsing_options as Dictionary[String, String] returns String:
    Note: Parse LaTeX mathematical notation back to expression
    Let cleaned_latex be StringManip.replace_all_substrings(latex_code, "\\left", "")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\right", "")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\frac{", "(")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "}{", ")/(") 
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "^{", "^(")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "_{", "_(")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\cdot", "*")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\times", "*")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\sin", "sin")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\cos", "cos")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\tan", "tan")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\pi", "pi")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\alpha", "alpha")
    Let cleaned_latex be StringManip.replace_all_substrings(cleaned_latex, "\\beta", "beta")
    Return cleaned_latex

Process called "inline_math_format" that takes expression as String returns String:
    Note: Format expression for inline mathematical display ($...$)
    Let latex_expression be expression_to_latex(expression, {"display_mode": "inline"})
    Let escaped_code be escape_latex_special_characters(latex_expression.latex_code)
    Return "$" + escaped_code + "$"

Process called "display_math_format" that takes expression as String returns String:
    Note: Format expression for display mathematical mode ($$...$$)
    Let latex_expression be expression_to_latex(expression, {"display_mode": "display"})
    Let escaped_code be escape_latex_special_characters(latex_expression.latex_code)
    Return "$$" + escaped_code + "$$"

Process called "equation_environment_format" that takes expression as String, environment_type as String, label as String returns LaTeXEquation:
    Note: Format expression in specific equation environment
    Let latex_expression be expression_to_latex(expression, {"display_mode": "display"})
    Let escaped_code be escape_latex_special_characters(latex_expression.latex_code)
    Let has_label be String.not_equals(label, "")
    Let has_numbering be String.not_equals(environment_type, "equation*")
    Let equation_content be escaped_code
    If has_label:
        Let equation_content be equation_content + "\\label{" + label + "}"
    Return {
        "equation_content": equation_content,
        "equation_environment": environment_type,
        "label": label,
        "numbering": has_numbering,
        "alignment_points": [],
        "multiline": String.contains(equation_content, "\\\\")
    }

Note: =====================================================================
Note: SYMBOL AND NOTATION OPERATIONS
Note: =====================================================================

Process called "symbol_to_latex" that takes symbol_name as String, symbol_context as String returns LaTeXSymbol:
    Note: Convert mathematical symbol to appropriate LaTeX command
    Let latex_command be get_latex_symbol_command(symbol_name)
    Let unicode_rep be get_unicode_for_symbol(symbol_name)
    Let symbol_category be determine_symbol_category(symbol_name)
    Let required_package be determine_symbol_package(symbol_name)
    Return {
        "symbol_name": symbol_name,
        "latex_command": latex_command,
        "unicode_representation": unicode_rep,
        "symbol_category": symbol_category,
        "required_package": required_package,
        "font_specification": "default"
    }

Process called "greek_letters_latex" that takes letter_name as String, case_type as String returns String:
    Note: Generate LaTeX for Greek letters (α, β, Γ, Δ, etc.)
    Let base_command be get_latex_symbol_command(letter_name)
    If String.equals(case_type, "uppercase"):
        Let first_char be String.substring(base_command, 1, 2)
        Let rest_chars be String.substring(base_command, 2, String.length(base_command))
        Let capitalized be String.to_uppercase(first_char) + rest_chars
        Return capitalized
    Otherwise:
        Return base_command

Process called "mathematical_operators_latex" that takes operator_name as String, operator_context as String returns String:
    Note: Generate LaTeX for mathematical operators (∑, ∏, ∫, ∂, etc.)
    If String.equals(operator_name, "summation"):
        Return "\\sum"
    If String.equals(operator_name, "product"):
        Return "\\prod"
    If String.equals(operator_name, "integral"):
        Return "\\int"
    If String.equals(operator_name, "double_integral"):
        Return "\\iint"
    If String.equals(operator_name, "triple_integral"):
        Return "\\iiint"
    If String.equals(operator_name, "contour_integral"):
        Return "\\oint"
    If String.equals(operator_name, "partial"):
        Return "\\partial"
    If String.equals(operator_name, "nabla"):
        Return "\\nabla"
    If String.equals(operator_name, "gradient"):
        Return "\\nabla"
    If String.equals(operator_name, "divergence"):
        Return "\\nabla \\cdot"
    If String.equals(operator_name, "curl"):
        Return "\\nabla \\times"
    If String.equals(operator_name, "laplacian"):
        Return "\\nabla^2"
    If String.equals(operator_name, "union"):
        Return "\\cup"
    If String.equals(operator_name, "intersection"):
        Return "\\cap"
    If String.equals(operator_name, "times"):
        Return "\\times"
    If String.equals(operator_name, "cdot"):
        Return "\\cdot"
    If String.equals(operator_name, "pm"):
        Return "\\pm"
    If String.equals(operator_name, "mp"):
        Return "\\mp"
    Otherwise:
        Return get_latex_symbol_command(operator_name)

Process called "set_theory_symbols_latex" that takes symbol_type as String returns String:
    Note: Generate LaTeX for set theory symbols (∈, ⊂, ∪, ∩, etc.)
    If String.equals(symbol_type, "in"):
        Return "\\in"
    If String.equals(symbol_type, "not_in"):
        Return "\\notin"
    If String.equals(symbol_type, "subset"):
        Return "\\subset"
    If String.equals(symbol_type, "subset_eq"):
        Return "\\subseteq"
    If String.equals(symbol_type, "superset"):
        Return "\\supset"
    If String.equals(symbol_type, "superset_eq"):
        Return "\\supseteq"
    If String.equals(symbol_type, "union"):
        Return "\\cup"
    If String.equals(symbol_type, "intersection"):
        Return "\\cap"
    If String.equals(symbol_type, "empty_set"):
        Return "\\emptyset"
    If String.equals(symbol_type, "complement"):
        Return "\\complement"
    If String.equals(symbol_type, "setminus"):
        Return "\\setminus"
    If String.equals(symbol_type, "cartesian"):
        Return "\\times"
    If String.equals(symbol_type, "power_set"):
        Return "\\mathcal{P}"
    Otherwise:
        Return symbol_type

Process called "logic_symbols_latex" that takes symbol_type as String returns String:
    Note: Generate LaTeX for logic symbols (∧, ∨, ¬, →, ∀, ∃, etc.)
    If String.equals(symbol_type, "and"):
        Return "\\land"
    If String.equals(symbol_type, "or"):
        Return "\\lor"
    If String.equals(symbol_type, "not"):
        Return "\\lnot"
    If String.equals(symbol_type, "implies"):
        Return "\\rightarrow"
    If String.equals(symbol_type, "iff"):
        Return "\\leftrightarrow"
    If String.equals(symbol_type, "forall"):
        Return "\\forall"
    If String.equals(symbol_type, "exists"):
        Return "\\exists"
    If String.equals(symbol_type, "exists_unique"):
        Return "\\exists!"
    If String.equals(symbol_type, "therefore"):
        Return "\\therefore"
    If String.equals(symbol_type, "because"):
        Return "\\because"
    If String.equals(symbol_type, "entails"):
        Return "\\vdash"
    If String.equals(symbol_type, "models"):
        Return "\\models"
    If String.equals(symbol_type, "true"):
        Return "\\top"
    If String.equals(symbol_type, "false"):
        Return "\\bot"
    Otherwise:
        Return symbol_type

Process called "arrow_symbols_latex" that takes arrow_type as String, arrow_style as String returns String:
    Note: Generate LaTeX for arrows (→, ⇒, ↔, ⇔, ↦, etc.)
    Let base_arrow be get_base_arrow_command(arrow_type)
    If String.equals(arrow_style, "long"):
        Let base_arrow be StringManip.replace_all_substrings(base_arrow, "arrow", "longarrow")
    If String.equals(arrow_style, "double"):
        Let base_arrow be StringManip.replace_all_substrings(base_arrow, "arrow", "Arrow")
    Return base_arrow

Note: =====================================================================
Note: FRACTION AND DIVISION OPERATIONS
Note: =====================================================================

Process called "fraction_latex" that takes numerator as String, denominator as String, fraction_style as String returns String:
    Note: Generate LaTeX fraction with specified style (\frac, \dfrac, \tfrac)
    Let escaped_num be escape_latex_special_characters(numerator)
    Let escaped_den be escape_latex_special_characters(denominator)
    If String.equals(fraction_style, "display"):
        Return "\\dfrac{" + escaped_num + "}{" + escaped_den + "}"
    If String.equals(fraction_style, "text"):
        Return "\\tfrac{" + escaped_num + "}{" + escaped_den + "}"
    If String.equals(fraction_style, "inline"):
        Return escaped_num + "/" + escaped_den
    Otherwise:
        Return "\\frac{" + escaped_num + "}{" + escaped_den + "}"

Process called "continued_fraction_latex" that takes partial_quotients as List[String], display_levels as Integer returns String:
    Note: Generate LaTeX for continued fraction representation
    If List.length(partial_quotients) equals 0:
        Return "0"
    Let first_term be List.get(partial_quotients, 0)
    If List.length(partial_quotients) equals 1:
        Return first_term
    Let remaining_terms be List.slice(partial_quotients, 1, List.length(partial_quotients))
    Let levels_to_show be (If display_levels < List.length(partial_quotients) - 1 then display_levels else List.length(partial_quotients) - 1)
    Let result be first_term + " + \\cfrac{1}{"
    Let current_level be 0
    For term in remaining_terms:
        If current_level < levels_to_show:
            If current_level equals levels_to_show - 1:
                Let result be result + term
                If current_level + 1 < List.length(remaining_terms):
                    Let result be result + " + \\cdots"
            Otherwise:
                Let result be result + term + " + \\cfrac{1}{"
            Let current_level be current_level + 1
    Let close_braces be String.repeat("}", levels_to_show)
    Return result + close_braces

Process called "nested_fraction_latex" that takes fraction_structure as Dictionary[String, String], nesting_style as String returns String:
    Note: Generate LaTeX for complex nested fractions
    Let main_num be fraction_structure.get("main_numerator", "1")
    Let main_den be fraction_structure.get("main_denominator", "1")
    Let nested_num be fraction_structure.get("nested_numerator", "")
    Let nested_den be fraction_structure.get("nested_denominator", "")
    Let nested_position be fraction_structure.get("nested_position", "denominator")
    
    If String.not_equals(nested_num, "") and String.not_equals(nested_den, ""):
        Let nested_frac be "\\frac{" + nested_num + "}{" + nested_den + "}"
        If String.equals(nested_position, "numerator"):
            Let combined_num be main_num + " + " + nested_frac
            Return "\\frac{" + combined_num + "}{" + main_den + "}"
        Otherwise:
            Let combined_den be main_den + " + " + nested_frac
            Return "\\frac{" + main_num + "}{" + combined_den + "}"
    Otherwise:
        Return "\\frac{" + main_num + "}{" + main_den + "}"

Process called "mixed_number_latex" that takes whole_part as String, numerator as String, denominator as String returns String:
    Note: Generate LaTeX for mixed numbers (e.g., 2¾)
    If String.equals(whole_part, "0"):
        Return fraction_latex(numerator, denominator, "standard")
    If String.equals(numerator, "0"):
        Return whole_part
    Let escaped_whole be escape_latex_special_characters(whole_part)
    Let fraction_part be fraction_latex(numerator, denominator, "text")
    Return escaped_whole + "\\," + fraction_part

Note: =====================================================================
Note: SUPERSCRIPT AND SUBSCRIPT OPERATIONS
Note: =====================================================================

Process called "superscript_latex" that takes base as String, exponent as String, grouping_options as Dictionary[String, String] returns String:
    Note: Generate LaTeX for superscripts with proper grouping
    Let escaped_base be escape_latex_special_characters(base)
    Let escaped_exp be escape_latex_special_characters(exponent)
    Let needs_braces be determine_if_braces_needed(exponent, grouping_options)
    If needs_braces:
        Return escaped_base + "^{" + escaped_exp + "}"
    Otherwise:
        Return escaped_base + "^" + escaped_exp

Process called "subscript_latex" that takes base as String, subscript as String, grouping_options as Dictionary[String, String] returns String:
    Note: Generate LaTeX for subscripts with proper grouping
    Let escaped_base be escape_latex_special_characters(base)
    Let escaped_sub be escape_latex_special_characters(subscript)
    Let needs_braces be determine_if_braces_needed(subscript, grouping_options)
    If needs_braces:
        Return escaped_base + "_{" + escaped_sub + "}"
    Otherwise:
        Return escaped_base + "_" + escaped_sub

Process called "super_subscript_latex" that takes base as String, superscript as String, subscript as String, positioning as String returns String:
    Note: Generate LaTeX for combined super and subscripts
    Let escaped_base be escape_latex_special_characters(base)
    Let escaped_sup be escape_latex_special_characters(superscript)
    Let escaped_sub be escape_latex_special_characters(subscript)
    Let sup_needs_braces be determine_if_braces_needed(superscript, {})
    Let sub_needs_braces be determine_if_braces_needed(subscript, {})
    
    Let sup_part be "^"
    If sup_needs_braces:
        Let sup_part be sup_part + "{" + escaped_sup + "}"
    Otherwise:
        Let sup_part be sup_part + escaped_sup
    
    Let sub_part be "_"
    If sub_needs_braces:
        Let sub_part be sub_part + "{" + escaped_sub + "}"
    Otherwise:
        Let sub_part be sub_part + escaped_sub
    
    If String.equals(positioning, "subscript_first"):
        Return escaped_base + sub_part + sup_part
    Otherwise:
        Return escaped_base + sup_part + sub_part

Process called "multi_level_scripts_latex" that takes base as String, scripts as Dictionary[String, String] returns String:
    Note: Generate LaTeX for multiple levels of scripts
    Let escaped_base be escape_latex_special_characters(base)
    Let result be escaped_base
    
    Let superscript be scripts.get("superscript", "")
    Let subscript be scripts.get("subscript", "")
    Let super_superscript be scripts.get("super_superscript", "")
    Let super_subscript be scripts.get("super_subscript", "")
    
    If String.not_equals(subscript, ""):
        Let needs_braces be determine_if_braces_needed(subscript, {})
        If needs_braces:
            Let result be result + "_{" + subscript + "}"
        Otherwise:
            Let result be result + "_" + subscript
    
    If String.not_equals(superscript, ""):
        Let script_content be superscript
        If String.not_equals(super_subscript, ""):
            Let script_content be script_content + "_{" + super_subscript + "}"
        If String.not_equals(super_superscript, ""):
            Let script_content be script_content + "^{" + super_superscript + "}"
        Let result be result + "^{" + script_content + "}"
    
    Return result

Note: =====================================================================
Note: MATRIX AND ARRAY OPERATIONS
Note: =====================================================================

Process called "matrix_latex" that takes matrix_entries as List[List[String]], matrix_type as String, alignment as String returns LaTeXMatrix:
    Note: Generate LaTeX matrix with specified delimiters and alignment
    Let matrix_env be determine_matrix_environment(matrix_type)
    Let alignment_spec be determine_matrix_alignment(alignment, List.length(List.get(matrix_entries, 0)))
    Let matrix_content be build_matrix_content(matrix_entries, alignment_spec)
    Let delimiters be get_matrix_delimiters(matrix_type)
    Return {
        "matrix_type": matrix_type,
        "entries": matrix_entries,
        "alignment": alignment,
        "delimiters": delimiters,
        "spacing_options": {"row_sep": "\\\\[0.1em]", "col_sep": "&"}
    }

Process called "determinant_latex" that takes matrix_entries as List[List[String]] returns String:
    Note: Generate LaTeX for determinant notation |A|
    Let matrix_content be build_matrix_content(matrix_entries, "c")
    Return "\\begin{vmatrix}" + matrix_content + "\\end{vmatrix}"

Process called "augmented_matrix_latex" that takes coefficient_matrix as List[List[String]], constant_vector as List[String] returns String:
    Note: Generate LaTeX for augmented matrix [A|b]
    Let num_cols be List.length(List.get(coefficient_matrix, 0))
    Let augmented_entries be build_augmented_entries(coefficient_matrix, constant_vector)
    Let alignment_spec be String.repeat("c", num_cols) + "|c"
    Let matrix_content be build_matrix_content(augmented_entries, alignment_spec)
    Return "\\left[\\begin{array}{" + alignment_spec + "}" + matrix_content + "\\end{array}\\right]"

Process called "block_matrix_latex" that takes block_structure as Dictionary[String, List[List[String]]], block_layout as Dictionary[String, String] returns String:
    Note: Generate LaTeX for block matrices with proper spacing
    Let block_arrangement be block_layout.get("arrangement", "2x2")
    Let spacing_type be block_layout.get("spacing", "standard")
    
    If String.equals(block_arrangement, "2x2"):
        Let top_left be block_structure.get("top_left", [["0"]])
        Let top_right be block_structure.get("top_right", [["0"]])
        Let bottom_left be block_structure.get("bottom_left", [["0"]])
        Let bottom_right be block_structure.get("bottom_right", [["0"]])
        
        Let tl_content be build_matrix_content(top_left, "c")
        Let tr_content be build_matrix_content(top_right, "c")
        Let bl_content be build_matrix_content(bottom_left, "c")
        Let br_content be build_matrix_content(bottom_right, "c")
        
        Return "\\begin{pmatrix} " + tl_content + " & " + tr_content + " \\\\ " + bl_content + " & " + br_content + " \\end{pmatrix}"
    Otherwise:
        Let default_block be block_structure.get("default", [["0"]])
        Let default_content be build_matrix_content(default_block, "c")
        Return "\\begin{pmatrix}" + default_content + "\\end{pmatrix}"

Process called "vector_latex" that takes vector_components as List[String], vector_notation as String returns String:
    Note: Generate LaTeX for vectors (column, row, or arrow notation)
    If String.equals(vector_notation, "column"):
        Let matrix_entries be build_column_vector_entries(vector_components)
        Return "\\begin{pmatrix}" + build_matrix_content(matrix_entries, "c") + "\\end{pmatrix}"
    If String.equals(vector_notation, "row"):
        Let escaped_components be List.map(vector_components, escape_latex_special_characters)
        Let joined_components be String.join(escaped_components, " & ")
        Return "\\begin{pmatrix}" + joined_components + "\\end{pmatrix}"
    If String.equals(vector_notation, "arrow"):
        Let first_component be List.get(vector_components, 0)
        Return "\\vec{" + escape_latex_special_characters(first_component) + "}"
    If String.equals(vector_notation, "bold"):
        Let first_component be List.get(vector_components, 0)
        Return "\\mathbf{" + escape_latex_special_characters(first_component) + "}"
    Otherwise:
        Let matrix_entries be build_column_vector_entries(vector_components)
        Return "\\begin{pmatrix}" + build_matrix_content(matrix_entries, "c") + "\\end{pmatrix}"

Note: =====================================================================
Note: INTEGRAL AND SUMMATION OPERATIONS
Note: =====================================================================

Process called "integral_latex" that takes integrand as String, variable as String, limits as Dictionary[String, String], integral_type as String returns String:
    Note: Generate LaTeX for integrals with proper limits positioning
    Let integral_symbol be get_integral_symbol(integral_type)
    Let lower_limit be limits.get("lower", "")
    Let upper_limit be limits.get("upper", "")
    Let escaped_integrand be escape_latex_special_characters(integrand)
    Let escaped_variable be escape_latex_special_characters(variable)
    
    Let integral_part be integral_symbol
    If String.not_equals(lower_limit, "") and String.not_equals(upper_limit, ""):
        Let integral_part be integral_part + "_{" + lower_limit + "}^{" + upper_limit + "}"
    
    Return integral_part + " " + escaped_integrand + " \\, d" + escaped_variable

Process called "multiple_integral_latex" that takes integrand as String, variables as List[String], limits as Dictionary[String, Dictionary[String, String]] returns String:
    Note: Generate LaTeX for multiple integrals (double, triple, etc.)
    Let num_variables be List.length(variables)
    Let integral_symbols be get_multiple_integral_symbols(num_variables)
    Let escaped_integrand be escape_latex_special_characters(integrand)
    
    Let integral_part be integral_symbols
    Let variables_part be ""
    
    For variable in List.reverse(variables):
        Let var_limits be limits.get(variable, {})
        Let lower be var_limits.get("lower", "")
        Let upper be var_limits.get("upper", "")
        Let escaped_var be escape_latex_special_characters(variable)
        
        If String.not_equals(lower, "") and String.not_equals(upper, ""):
            Let variables_part be variables_part + " \\, d" + escaped_var
        Otherwise:
            Let variables_part be variables_part + " \\, d" + escaped_var
    
    Return integral_part + " " + escaped_integrand + variables_part

Process called "line_integral_latex" that takes integrand as String, curve as String, parameter as String returns String:
    Note: Generate LaTeX for line integrals with curve notation
    Let escaped_integrand be escape_latex_special_characters(integrand)
    Let escaped_curve be escape_latex_special_characters(curve)
    Let escaped_param be escape_latex_special_characters(parameter)
    Return "\\int_{" + escaped_curve + "} " + escaped_integrand + " \\, d" + escaped_param

Process called "summation_latex" that takes summand as String, index_variable as String, limits as Dictionary[String, String], summation_style as String returns String:
    Note: Generate LaTeX for summations with index limits
    Let escaped_summand be escape_latex_special_characters(summand)
    Let escaped_index be escape_latex_special_characters(index_variable)
    Let lower_limit be limits.get("lower", "")
    Let upper_limit be limits.get("upper", "")
    
    Let sum_symbol be "\\sum"
    If String.equals(summation_style, "display"):
        Let sum_symbol be "\\displaystyle\\sum"
    
    If String.not_equals(lower_limit, "") and String.not_equals(upper_limit, ""):
        Return sum_symbol + "_{" + escaped_index + "=" + lower_limit + "}^{" + upper_limit + "} " + escaped_summand
    If String.not_equals(lower_limit, ""):
        Return sum_symbol + "_{" + escaped_index + "=" + lower_limit + "} " + escaped_summand
    Otherwise:
        Return sum_symbol + " " + escaped_summand

Process called "product_latex" that takes multiplicand as String, index_variable as String, limits as Dictionary[String, String] returns String:
    Note: Generate LaTeX for products (∏) with index limits
    Let escaped_multiplicand be escape_latex_special_characters(multiplicand)
    Let escaped_index be escape_latex_special_characters(index_variable)
    Let lower_limit be limits.get("lower", "")
    Let upper_limit be limits.get("upper", "")
    
    If String.not_equals(lower_limit, "") and String.not_equals(upper_limit, ""):
        Return "\\prod_{" + escaped_index + "=" + lower_limit + "}^{" + upper_limit + "} " + escaped_multiplicand
    If String.not_equals(lower_limit, ""):
        Return "\\prod_{" + escaped_index + "=" + lower_limit + "} " + escaped_multiplicand
    Otherwise:
        Return "\\prod " + escaped_multiplicand

Process called "limit_latex" that takes expression as String, variable as String, limit_point as String, approach_direction as String returns String:
    Note: Generate LaTeX for limits with proper notation
    Let escaped_expression be escape_latex_special_characters(expression)
    Let escaped_variable be escape_latex_special_characters(variable)
    Let escaped_limit_point be escape_latex_special_characters(limit_point)
    
    Let approach_notation be ""
    If String.equals(approach_direction, "left"):
        Let approach_notation be "^-"
    If String.equals(approach_direction, "right"):
        Let approach_notation be "^+"
    If String.equals(approach_direction, "both"):
        Let approach_notation be ""
    
    Return "\\lim_{" + escaped_variable + " \\to " + escaped_limit_point + approach_notation + "} " + escaped_expression

Note: =====================================================================
Note: FUNCTION AND OPERATOR OPERATIONS
Note: =====================================================================

Process called "function_latex" that takes function_name as String, arguments as List[String], function_style as String returns String:
    Note: Generate LaTeX for function calls with proper argument formatting
    Let escaped_function_name be get_latex_function_name(function_name)
    Let escaped_arguments be List.map(arguments, escape_latex_special_characters)
    Let arg_string be String.join(escaped_arguments, ", ")
    
    If String.equals(function_style, "parentheses"):
        Return escaped_function_name + "(" + arg_string + ")"
    If String.equals(function_style, "subscript"):
        Let first_arg be List.get(escaped_arguments, 0)
        Let remaining_args be List.slice(escaped_arguments, 1, List.length(escaped_arguments))
        Let remaining_string be String.join(remaining_args, ", ")
        If List.length(remaining_args) > 0:
            Return escaped_function_name + "_{" + first_arg + "}(" + remaining_string + ")"
        Otherwise:
            Return escaped_function_name + "_{" + first_arg + "}"
    Otherwise:
        Return escaped_function_name + "(" + arg_string + ")"

Process called "piecewise_function_latex" that takes cases as List[Dictionary[String, String]], case_style as String returns String:
    Note: Generate LaTeX for piecewise functions with cases environment
    Let cases_content be ""
    Let num_cases be List.length(cases)
    Let case_index be 0
    
    For case_dict in cases:
        Let expression be case_dict.get("expression", "")
        Let condition be case_dict.get("condition", "")
        Let escaped_expr be escape_latex_special_characters(expression)
        Let escaped_cond be escape_latex_special_characters(condition)
        
        Let cases_content be cases_content + escaped_expr + " & \\text{if } " + escaped_cond
        If case_index < num_cases - 1:
            Let cases_content be cases_content + " \\\\ "
        Let case_index be case_index + 1
    
    If String.equals(case_style, "brace_left"):
        Return "\\begin{cases} " + cases_content + " \\end{cases}"
    Otherwise:
        Return "\\begin{cases} " + cases_content + " \\end{cases}"

Process called "derivative_latex" that takes function as String, variable as String, order as Integer, notation_style as String returns String:
    Note: Generate LaTeX for derivatives (Leibniz or prime notation)
    Let escaped_function be escape_latex_special_characters(function)
    Let escaped_variable be escape_latex_special_characters(variable)
    
    If String.equals(notation_style, "prime") and order <= 3:
        If order equals 1:
            Return escaped_function + "'"
        If order equals 2:
            Return escaped_function + "''"
        If order equals 3:
            Return escaped_function + "'''"
    
    If String.equals(notation_style, "leibniz") or order > 3:
        If order equals 1:
            Return "\\frac{d}{d" + escaped_variable + "} " + escaped_function
        Otherwise:
            Return "\\frac{d^{" + String.from_integer(order) + "}}{d" + escaped_variable + "^{" + String.from_integer(order) + "}} " + escaped_function
    
    Otherwise:
        Return "\\frac{d}{d" + escaped_variable + "} " + escaped_function

Process called "partial_derivative_latex" that takes function as String, variables as List[String], orders as List[Integer] returns String:
    Note: Generate LaTeX for partial derivatives with proper notation
    Let escaped_function be escape_latex_special_characters(function)
    Let total_order be List.sum(orders)
    
    Let numerator be "\\partial"
    If total_order > 1:
        Let numerator be "\\partial^{" + String.from_integer(total_order) + "}"
    
    Let denominator be ""
    Let var_index be 0
    For variable in variables:
        Let escaped_var be escape_latex_special_characters(variable)
        Let var_order be List.get(orders, var_index)
        If var_order > 1:
            Let denominator be denominator + "\\partial " + escaped_var + "^{" + String.from_integer(var_order) + "}"
        Otherwise:
            Let denominator be denominator + "\\partial " + escaped_var
        Let var_index be var_index + 1
    
    Return "\\frac{" + numerator + "}{" + denominator + "} " + escaped_function

Process called "operator_latex" that takes operator_name as String, operands as List[String], operator_style as String returns String:
    Note: Generate LaTeX for mathematical operators with operands
    Let latex_operator be mathematical_operators_latex(operator_name, operator_style)
    Let escaped_operands be List.map(operands, escape_latex_special_characters)
    
    If String.equals(operator_name, "summation") or String.equals(operator_name, "product"):
        Let operand be List.get(escaped_operands, 0)
        Return latex_operator + " " + operand
    
    If String.equals(operator_name, "integral"):
        Let integrand be List.get(escaped_operands, 0)
        Let variable be List.get(escaped_operands, 1)
        Return latex_operator + " " + integrand + " \\, d" + variable
    
    If String.equals(operator_name, "gradient") or String.equals(operator_name, "divergence") or String.equals(operator_name, "curl"):
        Let operand be List.get(escaped_operands, 0)
        Return latex_operator + " " + operand
    
    If String.equals(operator_name, "times") or String.equals(operator_name, "cdot"):
        Return String.join(escaped_operands, " " + latex_operator + " ")
    
    If String.equals(operator_name, "pm") or String.equals(operator_name, "mp"):
        Return String.join(escaped_operands, " " + latex_operator + " ")
    
    Otherwise:
        Return latex_operator + "(" + String.join(escaped_operands, ", ") + ")"

Note: =====================================================================
Note: EQUATION SYSTEM OPERATIONS
Note: =====================================================================

Process called "equation_system_latex" that takes equations as List[String], alignment_style as String, numbering as Boolean returns String:
    Note: Generate LaTeX for systems of equations with alignment
    Let escaped_equations be List.map(equations, escape_latex_special_characters)
    Let equation_content be String.join(escaped_equations, " \\\\ ")
    
    If numbering:
        Return "\\begin{align} " + equation_content + " \\end{align}"
    Otherwise:
        Return "\\begin{align*} " + equation_content + " \\end{align*}"

Process called "align_equations_latex" that takes equations as List[String], alignment_points as List[String] returns String:
    Note: Generate LaTeX using align environment with custom alignment
    Let aligned_equations be []
    Let eq_index be 0
    
    For equation in equations:
        Let escaped_eq be escape_latex_special_characters(equation)
        If eq_index < List.length(alignment_points):
            Let alignment_char be List.get(alignment_points, eq_index)
            Let aligned_eq be StringManip.replace_all_substrings(escaped_eq, alignment_char, "&" + alignment_char)
            Let aligned_equations be List.append(aligned_equations, aligned_eq)
        Otherwise:
            Let aligned_equations be List.append(aligned_equations, escaped_eq)
        Let eq_index be eq_index + 1
    
    Let equation_content be String.join(aligned_equations, " \\\\ ")
    Return "\\begin{align} " + equation_content + " \\end{align}"

Process called "multiline_equation_latex" that takes equation_parts as List[String], break_points as List[String] returns String:
    Note: Generate LaTeX for multiline equations with proper breaks
    Let escaped_parts be List.map(equation_parts, escape_latex_special_characters)
    Let equation_content be String.join(escaped_parts, " \\\\ & ")
    Return "\\begin{multline} " + equation_content + " \\end{multline}"

Process called "equation_numbering_latex" that takes equations as List[String], numbering_scheme as String, labels as List[String] returns String:
    Note: Generate LaTeX with equation numbering and labeling
    Let numbered_equations be []
    Let eq_index be 0
    
    For equation in equations:
        Let escaped_eq be escape_latex_special_characters(equation)
        Let labeled_eq be escaped_eq
        
        If eq_index < List.length(labels):
            Let label be List.get(labels, eq_index)
            If String.not_equals(label, ""):
                Let labeled_eq be labeled_eq + " \\label{" + label + "}"
        
        Let numbered_equations be List.append(numbered_equations, labeled_eq)
        Let eq_index be eq_index + 1
    
    Let equation_content be String.join(numbered_equations, " \\\\ ")
    
    If String.equals(numbering_scheme, "none"):
        Return "\\begin{align*} " + equation_content + " \\end{align*}"
    Otherwise:
        Return "\\begin{align} " + equation_content + " \\end{align}"

Note: =====================================================================
Note: SPECIAL NOTATION OPERATIONS
Note: =====================================================================

Process called "binomial_coefficient_latex" that takes n as String, k as String, notation_style as String returns String:
    Note: Generate LaTeX for binomial coefficients (n choose k)
    Let escaped_n be escape_latex_special_characters(n)
    Let escaped_k be escape_latex_special_characters(k)
    
    If String.equals(notation_style, "parentheses"):
        Return "\\binom{" + escaped_n + "}{" + escaped_k + "}"
    If String.equals(notation_style, "brackets"):
        Return "\\begin{bmatrix} " + escaped_n + " \\\\ " + escaped_k + " \\end{bmatrix}"
    Otherwise:
        Return "\\binom{" + escaped_n + "}{" + escaped_k + "}"

Process called "absolute_value_latex" that takes expression as String, delimiter_style as String returns String:
    Note: Generate LaTeX for absolute value with proper delimiters
    Let escaped_expr be escape_latex_special_characters(expression)
    
    If String.equals(delimiter_style, "auto"):
        Return "\\left|" + escaped_expr + "\\right|"
    If String.equals(delimiter_style, "fixed"):
        Return "|" + escaped_expr + "|"
    Otherwise:
        Return "\\left|" + escaped_expr + "\\right|"

Process called "norm_latex" that takes expression as String, norm_type as String returns String:
    Note: Generate LaTeX for norms (L₁, L₂, L∞, etc.)
    Let escaped_expr be escape_latex_special_characters(expression)
    
    If String.equals(norm_type, "l1"):
        Return "\\|" + escaped_expr + "\\|_1"
    If String.equals(norm_type, "l2"):
        Return "\\|" + escaped_expr + "\\|_2"
    If String.equals(norm_type, "infinity"):
        Return "\\|" + escaped_expr + "\\|_{\\infty}"
    If String.equals(norm_type, "frobenius"):
        Return "\\|" + escaped_expr + "\\|_F"
    Otherwise:
        Return "\\|" + escaped_expr + "\\|"

Process called "floor_ceiling_latex" that takes expression as String, function_type as String returns String:
    Note: Generate LaTeX for floor ⌊x⌋ and ceiling ⌈x⌉ functions
    Let escaped_expr be escape_latex_special_characters(expression)
    
    If String.equals(function_type, "floor"):
        Return "\\lfloor " + escaped_expr + " \\rfloor"
    If String.equals(function_type, "ceiling") or String.equals(function_type, "ceil"):
        Return "\\lceil " + escaped_expr + " \\rceil"
    Otherwise:
        Return "\\lfloor " + escaped_expr + " \\rfloor"

Process called "set_notation_latex" that takes set_elements as List[String], set_builder_condition as String, notation_style as String returns String:
    Note: Generate LaTeX for set notation {x | condition}
    Let escaped_elements be List.map(set_elements, escape_latex_special_characters)
    Let escaped_condition be escape_latex_special_characters(set_builder_condition)
    
    If String.equals(set_builder_condition, ""):
        Let element_list be String.join(escaped_elements, ", ")
        Return "\\{" + element_list + "\\}"
    Otherwise:
        Let element_var be List.get(escaped_elements, 0)
        Return "\\{" + element_var + " \\mid " + escaped_condition + "\\}"

Note: =====================================================================
Note: DOCUMENT GENERATION OPERATIONS
Note: =====================================================================

Process called "create_latex_document" that takes document_type as String, title as String, author as String, content as String returns LaTeXDocument:
    Note: Create complete LaTeX document with proper structure
    Let document_class be "\\documentclass{" + document_type + "}"
    Let title_section be "\\title{" + escape_latex_special_characters(title) + "}"
    Let author_section be "\\author{" + escape_latex_special_characters(author) + "}"
    Let preamble be document_class + "\n" + "\\usepackage{amsmath}\n" + "\\usepackage{amssymb}\n" + "\\usepackage{amsfonts}\n"
    Let document_body be "\\begin{document}\n" + title_section + "\n" + author_section + "\n" + "\\maketitle\n" + content + "\n" + "\\end{document}"
    Return {
        "document_class": document_type,
        "preamble": preamble,
        "document_body": document_body,
        "required_packages": ["amsmath", "amssymb", "amsfonts"],
        "custom_definitions": {},
        "bibliography": ""
    }

Process called "math_article_template" that takes title as String, author as String, abstract as String, sections as List[Dictionary[String, String]] returns LaTeXDocument:
    Note: Generate LaTeX template for mathematical articles
    Let article_content be "\\begin{abstract}\n" + escape_latex_special_characters(abstract) + "\n\\end{abstract}\n\n"
    
    For section in sections:
        Let section_title be section.get("title", "")
        Let section_content be section.get("content", "")
        Let article_content be article_content + "\\section{" + escape_latex_special_characters(section_title) + "}\n" + section_content + "\n\n"
    
    Return create_latex_document("article", title, author, article_content)

Process called "beamer_presentation_template" that takes title as String, author as String, slides as List[Dictionary[String, String]] returns LaTeXDocument:
    Note: Generate LaTeX Beamer presentation for mathematical content
    Let slide_content be ""
    
    For slide in slides:
        Let slide_title be slide.get("title", "")
        Let slide_body be slide.get("content", "")
        Let slide_content be slide_content + "\\begin{frame}{" + escape_latex_special_characters(slide_title) + "}\n" + slide_body + "\n\\end{frame}\n\n"
    
    Let beamer_document be create_latex_document("beamer", title, author, slide_content)
    Let enhanced_preamble be beamer_document.preamble + "\\usetheme{default}\n"
    Return {
        "document_class": "beamer",
        "preamble": enhanced_preamble,
        "document_body": beamer_document.document_body,
        "required_packages": List.append(beamer_document.required_packages, "beamer"),
        "custom_definitions": beamer_document.custom_definitions,
        "bibliography": beamer_document.bibliography
    }

Process called "homework_template" that takes course_info as Dictionary[String, String], problems as List[Dictionary[String, String]] returns LaTeXDocument:
    Note: Generate LaTeX template for mathematical homework
    Let course_title be course_info.get("course", "")
    Let assignment_title be course_info.get("assignment", "")
    Let due_date be course_info.get("due_date", "")
    Let student_name be course_info.get("student", "")
    
    Let hw_header be "Course: " + course_title + "\\\\\nAssignment: " + assignment_title + "\\\\\nDue Date: " + due_date + "\\\\\n\\vspace{1em}\n\n"
    Let problem_content be ""
    Let problem_num be 1
    
    For problem in problems:
        Let problem_text be problem.get("problem", "")
        Let solution be problem.get("solution", "")
        Let problem_content be problem_content + "\\textbf{Problem " + String.from_integer(problem_num) + ":} " + problem_text + "\\\\\n\n"
        If String.not_equals(solution, ""):
            Let problem_content be problem_content + "\\textbf{Solution:} " + solution + "\\\\\n\n"
        Let problem_num be problem_num + 1
    
    Let full_content be hw_header + problem_content
    Return create_latex_document("article", assignment_title, student_name, full_content)

Note: =====================================================================
Note: TIKZ AND DIAGRAM OPERATIONS
Note: =====================================================================

Process called "function_plot_tikz" that takes function as String, domain as Dictionary[String, String], plot_options as Dictionary[String, String] returns String:
    Note: Generate TikZ code for function plotting
    Let x_min be domain.get("x_min", "-5")
    Let x_max be domain.get("x_max", "5")
    Let y_min be domain.get("y_min", "-5")
    Let y_max be domain.get("y_max", "5")
    Let plot_color be plot_options.get("color", "blue")
    Let line_width be plot_options.get("line_width", "thick")
    
    Let tikz_code be "\\begin{tikzpicture}\n"
    Let tikz_code be tikz_code + "\\begin{axis}[axis lines=middle, xlabel=$x$, ylabel=$y$, xmin=" + x_min + ", xmax=" + x_max + ", ymin=" + y_min + ", ymax=" + y_max + "]\n"
    Let tikz_code be tikz_code + "\\addplot[" + plot_color + ", " + line_width + ", domain=" + x_min + ":" + x_max + "] {" + function + "};\n"
    Let tikz_code be tikz_code + "\\end{axis}\n"
    Let tikz_code be tikz_code + "\\end{tikzpicture}"
    Return tikz_code

Process called "geometric_diagram_tikz" that takes geometric_objects as List[Dictionary[String, String]], diagram_options as Dictionary[String, String] returns String:
    Note: Generate TikZ code for geometric diagrams
    Let tikz_code be "\\begin{tikzpicture}\n"
    
    For obj in geometric_objects:
        Let obj_type be obj.get("type", "")
        Let coordinates be obj.get("coordinates", "")
        Let style be obj.get("style", "")
        
        If String.equals(obj_type, "point"):
            Let tikz_code be tikz_code + "\\fill[" + style + "] (" + coordinates + ") circle (2pt);\n"
        If String.equals(obj_type, "line"):
            Let tikz_code be tikz_code + "\\draw[" + style + "] (" + coordinates + ");\n"
        If String.equals(obj_type, "circle"):
            Let tikz_code be tikz_code + "\\draw[" + style + "] (" + coordinates + ");\n"
    
    Let tikz_code be tikz_code + "\\end{tikzpicture}"
    Return tikz_code

Process called "coordinate_system_tikz" that takes axis_type as String, range as Dictionary[String, String], grid_options as Dictionary[String, String] returns String:
    Note: Generate TikZ coordinate system with axes and grid
    Let x_min be range.get("x_min", "-5")
    Let x_max be range.get("x_max", "5")
    Let y_min be range.get("y_min", "-5")
    Let y_max be range.get("y_max", "5")
    Let show_grid be grid_options.get("show_grid", "true")
    Let grid_style be grid_options.get("grid_style", "gray")
    
    Let tikz_code be "\\begin{tikzpicture}\n"
    
    If String.equals(show_grid, "true"):
        Let tikz_code be tikz_code + "\\draw[" + grid_style + ", thin] (" + x_min + "," + y_min + ") grid (" + x_max + "," + y_max + ");\n"
    
    Let tikz_code be tikz_code + "\\draw[->] (" + x_min + ",0) -- (" + x_max + ",0) node[right] {$x$};\n"
    Let tikz_code be tikz_code + "\\draw[->] (0," + y_min + ") -- (0," + y_max + ") node[above] {$y$};\n"
    Let tikz_code be tikz_code + "\\end{tikzpicture}"
    Return tikz_code

Process called "mathematical_tree_tikz" that takes tree_structure as Dictionary[String, String], node_labels as Dictionary[String, String] returns String:
    Note: Generate TikZ tree diagrams for mathematical structures
    Let root_label be node_labels.get("root", "")
    Let left_label be node_labels.get("left", "")
    Let right_label be node_labels.get("right", "")
    
    Let tikz_code be "\\begin{tikzpicture}[level distance=1.5cm, level 1/.style={sibling distance=3cm}, level 2/.style={sibling distance=1.5cm}]\n"
    Let tikz_code be tikz_code + "\\node {$" + escape_latex_special_characters(root_label) + "$}\n"
    
    If String.not_equals(left_label, "") and String.not_equals(right_label, ""):
        Let tikz_code be tikz_code + "child {node {$" + escape_latex_special_characters(left_label) + "$}}\n"
        Let tikz_code be tikz_code + "child {node {$" + escape_latex_special_characters(right_label) + "$}};\n"
    
    Let tikz_code be tikz_code + "\\end{tikzpicture}"
    Return tikz_code

Note: =====================================================================
Note: PACKAGE AND MACRO OPERATIONS
Note: =====================================================================

Process called "required_packages_analysis" that takes latex_content as String returns List[String]:
    Note: Analyze LaTeX content to determine required packages
    Return determine_required_packages(latex_content)

Process called "create_custom_command" that takes command_name as String, command_definition as String, parameters as Integer returns String:
    Note: Create custom LaTeX command definition
    If parameters equals 0:
        Return "\\newcommand{\\" + command_name + "}{" + command_definition + "}"
    Otherwise:
        Return "\\newcommand{\\" + command_name + "}[" + String.from_integer(parameters) + "]{" + command_definition + "}"

Process called "mathematical_macros" that takes macro_category as String returns Dictionary[String, String]:
    Note: Generate common mathematical macros and shortcuts
    If String.equals(macro_category, "sets"):
        Return {
            "reals": "\\mathbb{R}",
            "integers": "\\mathbb{Z}",
            "naturals": "\\mathbb{N}",
            "rationals": "\\mathbb{Q}",
            "complex": "\\mathbb{C}"
        }
    If String.equals(macro_category, "operators"):
        Return {
            "grad": "\\nabla",
            "div": "\\nabla \\cdot",
            "curl": "\\nabla \\times",
            "laplacian": "\\nabla^2"
        }
    Otherwise:
        Return {"default": "\\newcommand"}

Process called "symbol_package_mapping" that takes symbols as List[String] returns Dictionary[String, String]:
    Note: Map mathematical symbols to their required LaTeX packages
    Let mapping be {}
    For symbol in symbols:
        Let package be determine_symbol_package(symbol)
        Let mapping be Dictionary.set(mapping, symbol, package)
    Return mapping

Note: =====================================================================
Note: FORMATTING AND STYLING OPERATIONS
Note: =====================================================================

Process called "equation_spacing_optimize" that takes latex_equations as List[String], spacing_preferences as Dictionary[String, String] returns List[String]:
    Note: Optimize spacing in LaTeX equations for better readability
    Let optimized_equations be []
    Let quad_spacing be spacing_preferences.get("quad_spacing", "true")
    Let thin_spacing be spacing_preferences.get("thin_spacing", "true")
    
    For equation in latex_equations:
        Let optimized_eq be equation
        If String.equals(quad_spacing, "true"):
            Let optimized_eq be StringManip.replace_all_substrings(optimized_eq, "=", " \\quad = \\quad ")
        If String.equals(thin_spacing, "true"):
            Let optimized_eq be StringManip.replace_all_substrings(optimized_eq, "+", " \\, + \\, ")
            Let optimized_eq be StringManip.replace_all_substrings(optimized_eq, "-", " \\, - \\, ")
        Let optimized_equations be List.append(optimized_equations, optimized_eq)
    
    Return optimized_equations

Process called "font_style_mathematics" that takes expression as String, font_style as String returns String:
    Note: Apply mathematical font styles (mathbf, mathit, mathcal, etc.)
    Let escaped_expr be escape_latex_special_characters(expression)
    
    If String.equals(font_style, "bold"):
        Return "\\mathbf{" + escaped_expr + "}"
    If String.equals(font_style, "italic"):
        Return "\\mathit{" + escaped_expr + "}"
    If String.equals(font_style, "calligraphic"):
        Return "\\mathcal{" + escaped_expr + "}"
    If String.equals(font_style, "script"):
        Return "\\mathscr{" + escaped_expr + "}"
    If String.equals(font_style, "blackboard"):
        Return "\\mathbb{" + escaped_expr + "}"
    If String.equals(font_style, "fraktur"):
        Return "\\mathfrak{" + escaped_expr + "}"
    If String.equals(font_style, "sans_serif"):
        Return "\\mathsf{" + escaped_expr + "}"
    If String.equals(font_style, "typewriter"):
        Return "\\mathtt{" + escaped_expr + "}"
    Otherwise:
        Return escaped_expr

Process called "color_mathematical_expressions" that takes expression as String, color_scheme as Dictionary[String, String] returns String:
    Note: Apply color coding to mathematical expressions
    Let escaped_expr be escape_latex_special_characters(expression)
    Let default_color be color_scheme.get("default", "black")
    Let operator_color be color_scheme.get("operators", "blue")
    Let number_color be color_scheme.get("numbers", "red")
    
    Let colored_expr be escaped_expr
    Let colored_expr be StringManip.replace_all_substrings(colored_expr, "+", "\\textcolor{" + operator_color + "}{+}")
    Let colored_expr be StringManip.replace_all_substrings(colored_expr, "-", "\\textcolor{" + operator_color + "}{-}")
    Let colored_expr be StringManip.replace_all_substrings(colored_expr, "=", "\\textcolor{" + operator_color + "}{=}")
    
    Return "\\textcolor{" + default_color + "}{" + colored_expr + "}"

Process called "line_breaking_optimization" that takes long_expression as String, line_width as Integer returns String:
    Note: Optimize line breaking for long mathematical expressions
    Let escaped_expr be escape_latex_special_characters(long_expression)
    
    If String.length(escaped_expr) > line_width:
        Let break_points be ["=", "+", "-", "\\cdot", "\\times"]
        Let result be escaped_expr
        
        For break_point in break_points:
            Let result be StringManip.replace_all_substrings(result, break_point, break_point + " \\\\\n& ")
        
        Return "\\begin{align}\n" + result + "\n\\end{align}"
    Otherwise:
        Return escaped_expr

Note: =====================================================================
Note: VALIDATION AND UTILITY OPERATIONS
Note: =====================================================================

Process called "validate_latex_syntax" that takes latex_code as String returns List[String]:
    Note: Validate LaTeX mathematical syntax and report errors
    Let errors be []
    Let open_braces be String.count(latex_code, "{")
    Let close_braces be String.count(latex_code, "}")
    
    If open_braces not equals close_braces:
        Let errors be List.append(errors, "Mismatched braces: " + String.from_integer(open_braces) + " opening, " + String.from_integer(close_braces) + " closing")
    
    If String.contains(latex_code, "\\begin{") and String.not_contains(latex_code, "\\end{"):
        Let errors be List.append(errors, "Missing \\end{} for \\begin{} environment")
    
    If String.contains(latex_code, "$$") and (String.count(latex_code, "$$") modulo 2) not equals 0:
        Let errors be List.append(errors, "Unmatched $$ delimiters")
    
    Return errors

Process called "latex_compilation_check" that takes latex_document as LaTeXDocument, compiler as String returns Dictionary[String, String]:
    Note: Check LaTeX document for compilation errors
    Let validation_errors be validate_latex_syntax(latex_document.document_body)
    Let missing_packages be []
    
    For package in latex_document.required_packages:
        If String.not_contains(latex_document.preamble, package):
            Let missing_packages be List.append(missing_packages, package)
    
    Return {
        "syntax_errors": String.join(validation_errors, "; "),
        "missing_packages": String.join(missing_packages, ", "),
        "compiler": compiler,
        "status": If List.length(validation_errors) equals 0 and List.length(missing_packages) equals 0 then "valid" else "errors"
    }

Process called "optimize_latex_performance" that takes latex_document as LaTeXDocument returns LaTeXDocument:
    Note: Optimize LaTeX document for faster compilation
    Let optimized_body be latex_document.document_body
    Let optimized_body be StringManip.replace_all_substrings(optimized_body, "\\left(", "(")
    Let optimized_body be StringManip.replace_all_substrings(optimized_body, "\\right)", ")")
    Let optimized_body be StringManip.replace_all_substrings(optimized_body, "\\left[", "[")
    Let optimized_body be StringManip.replace_all_substrings(optimized_body, "\\right]", "]")
    
    Return {
        "document_class": latex_document.document_class,
        "preamble": latex_document.preamble,
        "document_body": optimized_body,
        "required_packages": latex_document.required_packages,
        "custom_definitions": latex_document.custom_definitions,
        "bibliography": latex_document.bibliography
    }

Process called "convert_unicode_to_latex" that takes unicode_math as String returns String:
    Note: Convert Unicode mathematical symbols to LaTeX commands
    Let result be unicode_math
    Let result be StringManip.replace_all_substrings(result, "α", "\\alpha")
    Let result be StringManip.replace_all_substrings(result, "β", "\\beta")
    Let result be StringManip.replace_all_substrings(result, "γ", "\\gamma")
    Let result be StringManip.replace_all_substrings(result, "δ", "\\delta")
    Let result be StringManip.replace_all_substrings(result, "ε", "\\epsilon")
    Let result be StringManip.replace_all_substrings(result, "π", "\\pi")
    Let result be StringManip.replace_all_substrings(result, "∑", "\\sum")
    Let result be StringManip.replace_all_substrings(result, "∏", "\\prod")
    Let result be StringManip.replace_all_substrings(result, "∫", "\\int")
    Let result be StringManip.replace_all_substrings(result, "∞", "\\infty")
    Let result be StringManip.replace_all_substrings(result, "≤", "\\leq")
    Let result be StringManip.replace_all_substrings(result, "≥", "\\geq")
    Let result be StringManip.replace_all_substrings(result, "≠", "\\neq")
    Let result be StringManip.replace_all_substrings(result, "±", "\\pm")
    Let result be StringManip.replace_all_substrings(result, "∈", "\\in")
    Let result be StringManip.replace_all_substrings(result, "∉", "\\notin")
    Let result be StringManip.replace_all_substrings(result, "⊂", "\\subset")
    Let result be StringManip.replace_all_substrings(result, "⊆", "\\subseteq")
    Let result = StringManip.replace_all_substrings(result, "∪", "\\cup")
    Let result be StringManip.replace_all_substrings(result, "∩", "\\cap")
    Return result

Process called "benchmark_latex_operations" that takes operation_types as List[String], test_expressions as List[String] returns Dictionary[String, Float]:
    Note: Benchmark performance of LaTeX generation operations
    Let results be {}
    Let start_time be DateTime.current_timestamp()
    
    For operation_type in operation_types:
        Let operation_start be DateTime.current_timestamp()
        
        For expression in test_expressions:
            If String.equals(operation_type, "expression_to_latex"):
                Let latex_expr be expression_to_latex(expression, {})
            If String.equals(operation_type, "inline_math_format"):
                Let formatted be inline_math_format(expression)
            If String.equals(operation_type, "display_math_format"):
                Let formatted be display_math_format(expression)
        
        Let operation_end be DateTime.current_timestamp()
        Let duration be DateTime.subtract(operation_end, operation_start)
        Let results be Dictionary.set(results, operation_type, DateTime.to_seconds(duration))
    
    Return results

Note: =====================================================================
Note: HELPER FUNCTIONS
Note: =====================================================================

Process called "escape_latex_special_characters" that takes input_string as String returns String:
    Note: Escape LaTeX special characters
    Let result be StringManip.replace_all_substrings(input_string, "\\", "\\\\")
    Let result be StringManip.replace_all_substrings(result, "$", "\\$")
    Let result be StringManip.replace_all_substrings(result, "&", "\\&")
    Let result be StringManip.replace_all_substrings(result, "%", "\\%")
    Let result be StringManip.replace_all_substrings(result, "#", "\\#")
    Let result be StringManip.replace_all_substrings(result, "_", "\\_")
    Let result be StringManip.replace_all_substrings(result, "{", "\\{")
    Let result be StringManip.replace_all_substrings(result, "}", "\\}")
    Let result be StringManip.replace_all_substrings(result, "~", "\\~")
    Let result be StringManip.replace_all_substrings(result, "^", "\\^")
    Return result

Process called "wrap_in_delimiters" that takes expression as String, delimiter_type as String returns String:
    Note: Wrap expression with proper LaTeX delimiters
    If String.equals(delimiter_type, "parentheses"):
        Return "\\left(" + expression + "\\right)"
    If String.equals(delimiter_type, "brackets"):
        Return "\\left[" + expression + "\\right]"
    If String.equals(delimiter_type, "braces"):
        Return "\\left\\{" + expression + "\\right\\}"
    If String.equals(delimiter_type, "abs"):
        Return "\\left|" + expression + "\\right|"
    If String.equals(delimiter_type, "norm"):
        Return "\\left\\|" + expression + "\\right\\|"
    If String.equals(delimiter_type, "angle"):
        Return "\\langle " + expression + " \\rangle"
    If String.equals(delimiter_type, "floor"):
        Return "\\lfloor " + expression + " \\rfloor"
    If String.equals(delimiter_type, "ceil"):
        Return "\\lceil " + expression + " \\rceil"
    Otherwise:
        Return expression

Process called "get_latex_symbol_command" that takes symbol_name as String returns String:
    Note: Map symbol names to LaTeX commands
    If String.equals(symbol_name, "alpha"):
        Return "\\alpha"
    If String.equals(symbol_name, "beta"):
        Return "\\beta"
    If String.equals(symbol_name, "gamma"):
        Return "\\gamma"
    If String.equals(symbol_name, "delta"):
        Return "\\delta"
    If String.equals(symbol_name, "epsilon"):
        Return "\\epsilon"
    If String.equals(symbol_name, "pi"):
        Return "\\pi"
    If String.equals(symbol_name, "theta"):
        Return "\\theta"
    If String.equals(symbol_name, "lambda"):
        Return "\\lambda"
    If String.equals(symbol_name, "mu"):
        Return "\\mu"
    If String.equals(symbol_name, "sigma"):
        Return "\\sigma"
    If String.equals(symbol_name, "phi"):
        Return "\\phi"
    If String.equals(symbol_name, "omega"):
        Return "\\omega"
    If String.equals(symbol_name, "sum"):
        Return "\\sum"
    If String.equals(symbol_name, "product"):
        Return "\\prod"
    If String.equals(symbol_name, "integral"):
        Return "\\int"
    If String.equals(symbol_name, "partial"):
        Return "\\partial"
    If String.equals(symbol_name, "infinity"):
        Return "\\infty"
    If String.equals(symbol_name, "sqrt"):
        Return "\\sqrt"
    If String.equals(symbol_name, "sin"):
        Return "\\sin"
    If String.equals(symbol_name, "cos"):
        Return "\\cos"
    If String.equals(symbol_name, "tan"):
        Return "\\tan"
    Otherwise:
        Return symbol_name

Process called "convert_expression_to_latex_code" that takes expression as SymbolicCore.SymbolicExpression, options as Dictionary[String, String] returns String:
    Note: Convert symbolic expression to LaTeX code
    Let expression_type be SymbolicCore.get_expression_type(expression)
    If String.equals(expression_type, "number"):
        Return SymbolicCore.get_expression_value(expression)
    If String.equals(expression_type, "variable"):
        Return get_latex_symbol_command(SymbolicCore.get_expression_value(expression))
    If String.equals(expression_type, "operation"):
        Let operator be SymbolicCore.get_expression_operator(expression)
        Let operands be SymbolicCore.get_expression_operands(expression)
        If String.equals(operator, "+"):
            Return convert_expression_to_latex_code(List.get(operands, 0), options) + " + " + convert_expression_to_latex_code(List.get(operands, 1), options)
        If String.equals(operator, "-"):
            Return convert_expression_to_latex_code(List.get(operands, 0), options) + " - " + convert_expression_to_latex_code(List.get(operands, 1), options)
        If String.equals(operator, "*"):
            Return convert_expression_to_latex_code(List.get(operands, 0), options) + " \\cdot " + convert_expression_to_latex_code(List.get(operands, 1), options)
        If String.equals(operator, "/"):
            Return "\\frac{" + convert_expression_to_latex_code(List.get(operands, 0), options) + "}{" + convert_expression_to_latex_code(List.get(operands, 1), options) + "}"
        If String.equals(operator, "^"):
            Return convert_expression_to_latex_code(List.get(operands, 0), options) + "^{" + convert_expression_to_latex_code(List.get(operands, 1), options) + "}"
        If String.equals(operator, "sqrt"):
            Return "\\sqrt{" + convert_expression_to_latex_code(List.get(operands, 0), options) + "}"
        Otherwise:
            Return operator + "(" + convert_expression_to_latex_code(List.get(operands, 0), options) + ")"
    Otherwise:
        Return SymbolicCore.serialize_expression(expression, "infix")

Process called "determine_required_packages" that takes latex_code as String returns List[String]:
    Note: Determine required LaTeX packages from code
    Let packages be []
    If String.contains(latex_code, "\\frac"):
        Let packages be List.append(packages, "amsmath")
    If String.contains(latex_code, "\\sqrt"):
        Let packages be List.append(packages, "amsmath")
    If String.contains(latex_code, "\\sum") or String.contains(latex_code, "\\prod") or String.contains(latex_code, "\\int"):
        Let packages be List.append(packages, "amsmath")
    If String.contains(latex_code, "\\alpha") or String.contains(latex_code, "\\beta") or String.contains(latex_code, "\\gamma"):
        Let packages be List.append(packages, "amssymb")
    If String.contains(latex_code, "\\left") or String.contains(latex_code, "\\right"):
        Let packages be List.append(packages, "amsmath")
    If String.contains(latex_code, "\\begin{align}") or String.contains(latex_code, "\\begin{equation}"):
        Let packages be List.append(packages, "amsmath")
    If String.contains(latex_code, "\\mathbb") or String.contains(latex_code, "\\mathcal"):
        Let packages be List.append(packages, "amsfonts")
    Return packages

Process called "get_unicode_for_symbol" that takes symbol_name as String returns String:
    Note: Get Unicode representation for mathematical symbols
    If String.equals(symbol_name, "alpha"):
        Return "α"
    If String.equals(symbol_name, "beta"):
        Return "β"
    If String.equals(symbol_name, "gamma"):
        Return "γ"
    If String.equals(symbol_name, "delta"):
        Return "δ"
    If String.equals(symbol_name, "epsilon"):
        Return "ε"
    If String.equals(symbol_name, "pi"):
        Return "π"
    If String.equals(symbol_name, "sum"):
        Return "∑"
    If String.equals(symbol_name, "product"):
        Return "∏"
    If String.equals(symbol_name, "integral"):
        Return "∫"
    If String.equals(symbol_name, "infinity"):
        Return "∞"
    Otherwise:
        Return symbol_name

Process called "determine_symbol_category" that takes symbol_name as String returns String:
    Note: Determine the category of mathematical symbol
    If String.equals(symbol_name, "alpha") or String.equals(symbol_name, "beta") or String.equals(symbol_name, "gamma"):
        Return "greek_letter"
    If String.equals(symbol_name, "sum") or String.equals(symbol_name, "product") or String.equals(symbol_name, "integral"):
        Return "operator"
    If String.equals(symbol_name, "infinity") or String.equals(symbol_name, "pi"):
        Return "constant"
    Otherwise:
        Return "symbol"

Process called "determine_symbol_package" that takes symbol_name as String returns String:
    Note: Determine required LaTeX package for symbol
    If String.equals(symbol_name, "alpha") or String.equals(symbol_name, "beta") or String.equals(symbol_name, "gamma"):
        Return "amssymb"
    If String.equals(symbol_name, "sum") or String.equals(symbol_name, "product") or String.equals(symbol_name, "integral"):
        Return "amsmath"
    Otherwise:
        Return "amsmath"

Process called "get_base_arrow_command" that takes arrow_type as String returns String:
    Note: Get base LaTeX command for arrow types
    If String.equals(arrow_type, "right"):
        Return "\\rightarrow"
    If String.equals(arrow_type, "left"):
        Return "\\leftarrow"
    If String.equals(arrow_type, "both"):
        Return "\\leftrightarrow"
    If String.equals(arrow_type, "up"):
        Return "\\uparrow"
    If String.equals(arrow_type, "down"):
        Return "\\downarrow"
    If String.equals(arrow_type, "northeast"):
        Return "\\nearrow"
    If String.equals(arrow_type, "northwest"):
        Return "\\nwarrow"
    If String.equals(arrow_type, "southeast"):
        Return "\\searrow"
    If String.equals(arrow_type, "southwest"):
        Return "\\swarrow"
    If String.equals(arrow_type, "maps_to"):
        Return "\\mapsto"
    Otherwise:
        Return "\\rightarrow"

Process called "determine_if_braces_needed" that takes content as String, options as Dictionary[String, String] returns Boolean:
    Note: Determine if braces are needed for scripts
    Let force_braces be options.get("force_braces", "false")
    If String.equals(force_braces, "true"):
        Return True
    If String.length(content) > 1:
        Return True
    If String.contains(content, "+") or String.contains(content, "-") or String.contains(content, "*"):
        Return True
    If String.contains(content, "/") or String.contains(content, "^") or String.contains(content, "_"):
        Return True
    Otherwise:
        Return False

Process called "determine_matrix_environment" that takes matrix_type as String returns String:
    Note: Determine LaTeX environment for matrix type
    If String.equals(matrix_type, "parentheses"):
        Return "pmatrix"
    If String.equals(matrix_type, "brackets"):
        Return "bmatrix"
    If String.equals(matrix_type, "braces"):
        Return "Bmatrix"
    If String.equals(matrix_type, "determinant"):
        Return "vmatrix"
    If String.equals(matrix_type, "norm"):
        Return "Vmatrix"
    Otherwise:
        Return "pmatrix"

Process called "determine_matrix_alignment" that takes alignment as String, num_cols as Integer returns String:
    Note: Determine alignment specification for matrix
    If String.equals(alignment, "left"):
        Return String.repeat("l", num_cols)
    If String.equals(alignment, "right"):
        Return String.repeat("r", num_cols)
    If String.equals(alignment, "center"):
        Return String.repeat("c", num_cols)
    Otherwise:
        Return String.repeat("c", num_cols)

Process called "build_matrix_content" that takes matrix_entries as List[List[String]], alignment_spec as String returns String:
    Note: Build LaTeX content for matrix entries
    Let result be ""
    Let num_rows be List.length(matrix_entries)
    Let row_index be 0
    For row in matrix_entries:
        Let escaped_row be List.map(row, escape_latex_special_characters)
        Let row_content be String.join(escaped_row, " & ")
        Let result be result + row_content
        If row_index < num_rows - 1:
            Let result be result + " \\\\ "
        Let row_index be row_index + 1
    Return result

Process called "get_matrix_delimiters" that takes matrix_type as String returns Dictionary[String, String]:
    Note: Get delimiter specifications for matrix type
    If String.equals(matrix_type, "parentheses"):
        Return {"left": "(", "right": ")"}
    If String.equals(matrix_type, "brackets"):
        Return {"left": "[", "right": "]"}
    If String.equals(matrix_type, "braces"):
        Return {"left": "{", "right": "}"}
    If String.equals(matrix_type, "determinant"):
        Return {"left": "|", "right": "|"}
    If String.equals(matrix_type, "norm"):
        Return {"left": "||", "right": "||"}
    Otherwise:
        Return {"left": "(", "right": ")"}

Process called "build_augmented_entries" that takes coefficient_matrix as List[List[String]], constant_vector as List[String] returns List[List[String]]:
    Note: Build augmented matrix entries by combining coefficient matrix and constants
    Let result be []
    Let num_rows be List.length(coefficient_matrix)
    Let row_index be 0
    For row in coefficient_matrix:
        Let constant_value be List.get(constant_vector, row_index)
        Let augmented_row be List.append(row, constant_value)
        Let result be List.append(result, augmented_row)
        Let row_index be row_index + 1
    Return result

Process called "build_column_vector_entries" that takes vector_components as List[String] returns List[List[String]]:
    Note: Build matrix entries for column vector representation
    Let result be []
    For component in vector_components:
        Let single_entry_row be [component]
        Let result be List.append(result, single_entry_row)
    Return result

Process called "get_integral_symbol" that takes integral_type as String returns String:
    Note: Get appropriate integral symbol for type
    If String.equals(integral_type, "definite"):
        Return "\\int"
    If String.equals(integral_type, "indefinite"):
        Return "\\int"
    If String.equals(integral_type, "contour"):
        Return "\\oint"
    If String.equals(integral_type, "surface"):
        Return "\\iint"
    If String.equals(integral_type, "volume"):
        Return "\\iiint"
    Otherwise:
        Return "\\int"

Process called "get_multiple_integral_symbols" that takes num_integrals as Integer returns String:
    Note: Get multiple integral symbols
    If num_integrals equals 1:
        Return "\\int"
    If num_integrals equals 2:
        Return "\\iint"
    If num_integrals equals 3:
        Return "\\iiint"
    If num_integrals > 3:
        Return "\\int" + String.repeat("\\int", num_integrals - 1)
    Otherwise:
        Return "\\int"

Process called "get_latex_function_name" that takes function_name as String returns String:
    Note: Get LaTeX representation of function name
    If String.equals(function_name, "sin"):
        Return "\\sin"
    If String.equals(function_name, "cos"):
        Return "\\cos"
    If String.equals(function_name, "tan"):
        Return "\\tan"
    If String.equals(function_name, "log"):
        Return "\\log"
    If String.equals(function_name, "ln"):
        Return "\\ln"
    If String.equals(function_name, "exp"):
        Return "\\exp"
    If String.equals(function_name, "arcsin"):
        Return "\\arcsin"
    If String.equals(function_name, "arccos"):
        Return "\\arccos"
    If String.equals(function_name, "arctan"):
        Return "\\arctan"
    If String.equals(function_name, "sinh"):
        Return "\\sinh"
    If String.equals(function_name, "cosh"):
        Return "\\cosh"
    If String.equals(function_name, "tanh"):
        Return "\\tanh"
    If String.equals(function_name, "max"):
        Return "\\max"
    If String.equals(function_name, "min"):
        Return "\\min"
    If String.equals(function_name, "sup"):
        Return "\\sup"
    If String.equals(function_name, "inf"):
        Return "\\inf"
    If String.equals(function_name, "lim"):
        Return "\\lim"
    If String.equals(function_name, "det"):
        Return "\\det"
    If String.equals(function_name, "dim"):
        Return "\\dim"
    If String.equals(function_name, "ker"):
        Return "\\ker"
    If String.equals(function_name, "gcd"):
        Return "\\gcd"
    Otherwise:
        Return function_name
