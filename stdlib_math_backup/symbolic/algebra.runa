Process called "convert_polynomial_to_symbolic" that takes polynomial as Polynomial, variables as List[String] returns SymbolicExpression:
    Note: Convert polynomial representation to symbolic expression
    Note: Builds expression tree from polynomial coefficients and variables
    
    Note: Handle zero polynomial
    If Map.is_empty(polynomial.coefficients):
        Return SymCore.create_constant("0", "rational")
    
    Note: Build sum of terms
    Let terms be List.empty()
    Let coefficient_keys be Map.keys(polynomial.coefficients)
    Let i be 0
    
    While i < List.length(coefficient_keys):
        Let exponent_key be List.get(coefficient_keys, i)
        Let coefficient be Map.get(polynomial.coefficients, exponent_key)
        
        Note: Skip zero coefficients
        If not coefficient equals "0":
            Note: Parse exponent key to get variable powers
            Let variable_powers be StringManip.split(exponent_key, ",")
            Let term_factors be List.empty()
            
            Note: Add coefficient if not 1
            If not coefficient equals "1":
                List.append(term_factors, SymCore.create_constant(coefficient, "rational"))
            
            Note: Build variable factors
            Let j be 0
            While j < List.length(variable_powers):
                Let power be Integer.from_string(List.get(variable_powers, j))
                If power > 0:
                    Let variable_name be List.get(variables, j)
                    Let variable_symbol be SymCore.create_symbol(variable_name, Map.empty())
                    
                    If power equals 1:
                        List.append(term_factors, variable_symbol)
                    Otherwise:
                        Let power_expr be SymCore.create_constant(Integer.to_string(power), "integer")
                        Let power_term be SymCore.create_binary_operation("power", variable_symbol, power_expr)
                        List.append(term_factors, power_term)
                Set j to j + 1
            
            Note: Combine factors with multiplication
            If List.length(term_factors) equals 0:
                List.append(terms, SymCore.create_constant(coefficient, "rational"))
            Otherwise if List.length(term_factors) equals 1:
                List.append(terms, List.get(term_factors, 0))
            Otherwise:
                Let term_product be List.get(term_factors, 0)
                Let k be 1
                While k < List.length(term_factors):
                    Set term_product to SymCore.create_binary_operation("multiply", term_product, List.get(term_factors, k))
                    Set k to k + 1
                List.append(terms, term_product)
        
        Set i to i + 1
    
    Note: Combine terms with addition
    If List.length(terms) equals 0:
        Return SymCore.create_constant("0", "rational")
    Otherwise if List.length(terms) equals 1:
        Return List.get(terms, 0)
    Otherwise:
        Let result be List.get(terms, 0)
        Let m be 1
        While m < List.length(terms):
            Set result to SymCore.create_binary_operation("add", result, List.get(terms, m))
            Set m to m + 1
        Return result

Process called "convert_symbolic_to_polynomial" that takes expression as SymbolicExpression, variables as List[String] returns Polynomial:
    Note: Convert symbolic expression to polynomial representation
    Note: Extracts coefficients and builds polynomial structure
    
    Note: Create empty coefficients map
    Let coefficients be Map.empty()
    
    Note: Handle simple cases
    If expression.expression_type equals "constant":
        Note: Constant polynomial
        Let zero_exponents be ""
        Let i be 0
        While i < List.length(variables):
            If i > 0:
                Set zero_exponents to zero_exponents + ","
            Set zero_exponents to zero_exponents + "0"
            Set i to i + 1
        Set coefficients to Map.set(coefficients, zero_exponents, expression.constant_value)
    Otherwise if expression.expression_type equals "symbol":
        Note: Single variable
        Let var_index be List.find_index(variables, expression.symbol_name)
        If var_index >= 0:
            Let unit_exponents be ""
            Let j be 0
            While j < List.length(variables):
                If j > 0:
                    Set unit_exponents to unit_exponents + ","
                If j equals var_index:
                    Set unit_exponents to unit_exponents + "1"
                Otherwise:
                    Set unit_exponents to unit_exponents + "0"
                Set j to j + 1
            Set coefficients to Map.set(coefficients, unit_exponents, "1")
        Otherwise:
            Throw Errors.InvalidArgument("Variable not found in variable list")
    Otherwise:
        Note: Complex expression - use recursive extraction
        Set coefficients to extract_polynomial_coefficients(expression, variables, coefficients)
    
    Note: Create polynomial structure
    Let result be Polynomial{}
    Set result.coefficients to coefficients
    Set result.variables to variables
    Set result.degree to compute_polynomial_degree(coefficients, variables)
    Set result.is_multivariate to (List.length(variables) > 1)
    Set result.polynomial_ring to "Q[" + StringManip.join(variables, ",") + "]"
    
    Return result

Process called "extract_polynomial_coefficients" that takes expression as SymbolicExpression, variables as List[String], current_coefficients as Dictionary[String, String] returns Dictionary[String, String]:
    Note: Recursively extract polynomial coefficients from symbolic expression
    Note: Handles addition, multiplication, and power operations
    
    If expression.expression_type equals "constant":
        Let zero_exponents be StringManip.repeat("0,", List.length(variables))
        Set zero_exponents to StringManip.trim_suffix(zero_exponents, ",")
        Let existing_coeff be Map.get_or_default(current_coefficients, zero_exponents, "0")
        Let new_coeff be add_rational_strings(existing_coeff, expression.constant_value)
        Return Map.set(current_coefficients, zero_exponents, new_coeff)
    
    Otherwise if expression.expression_type equals "symbol":
        Let var_index be List.find_index(variables, expression.symbol_name)
        If var_index >= 0:
            Let unit_exponents_parts be List.empty()
            Let i be 0
            While i < List.length(variables):
                If i equals var_index:
                    List.append(unit_exponents_parts, "1")
                Otherwise:
                    List.append(unit_exponents_parts, "0")
                Set i to i + 1
            Let unit_exponents be StringManip.join(unit_exponents_parts, ",")
            Let existing_coeff be Map.get_or_default(current_coefficients, unit_exponents, "0")
            Let new_coeff be add_rational_strings(existing_coeff, "1")
            Return Map.set(current_coefficients, unit_exponents, new_coeff)
        Otherwise:
            Throw Errors.InvalidArgument("Unknown variable in expression")
    
    Otherwise if expression.expression_type equals "binary_operation":
        If expression.operator_type equals "add":
            Note: Sum of polynomials
            Let left_coeffs be extract_polynomial_coefficients(List.get(expression.operands, 0), variables, current_coefficients)
            Return extract_polynomial_coefficients(List.get(expression.operands, 1), variables, left_coeffs)
        
        Otherwise if expression.operator_type equals "multiply":
            Note: Product requires coefficient multiplication and exponent addition
            Let left_coeffs be extract_polynomial_coefficients(List.get(expression.operands, 0), variables, Map.empty())
            Let right_coeffs be extract_polynomial_coefficients(List.get(expression.operands, 1), variables, Map.empty())
            
            Let result_coeffs be Map.copy(current_coefficients)
            Let left_keys be Map.keys(left_coeffs)
            Let right_keys be Map.keys(right_coeffs)
            
            Let i be 0
            While i < List.length(left_keys):
                Let left_exp be List.get(left_keys, i)
                Let left_coeff be Map.get(left_coeffs, left_exp)
                
                Let j be 0
                While j < List.length(right_keys):
                    Let right_exp be List.get(right_keys, j)
                    Let right_coeff be Map.get(right_coeffs, right_exp)
                    
                    Let combined_exp be add_exponent_vectors(left_exp, right_exp)
                    Let combined_coeff be multiply_rational_strings(left_coeff, right_coeff)
                    
                    Let existing_coeff be Map.get_or_default(result_coeffs, combined_exp, "0")
                    Let new_coeff be add_rational_strings(existing_coeff, combined_coeff)
                    Set result_coeffs to Map.set(result_coeffs, combined_exp, new_coeff)
                    
                    Set j to j + 1
                Set i to i + 1
            
            Return result_coeffs
        
        If operator equals "^":
            Note: Handle exponentiation for polynomial extraction
            Let base_coeffs = extract_polynomial_coefficients(left_operand, variables, current_coefficients)
            If is_constant_expression(right_operand):
                Let power = get_numeric_value(right_operand)
                If power >= 0 and power == Integer.from_string(Integer.to_string(power)):
                    Return raise_polynomial_to_power(base_coeffs, Integer.to_string(power))
            Return base_coeffs
            
        If operator equals "/":
            Note: Handle division - only allow division by constants
            If is_constant_expression(right_operand):
                Let dividend_coeffs = extract_polynomial_coefficients(left_operand, variables, current_coefficients)
                Let divisor = get_numeric_value(right_operand)
                Return divide_polynomial_by_constant(dividend_coeffs, Float.to_string(divisor))
            
            Return extract_polynomial_coefficients(left_operand, variables, current_coefficients)
            
        If operator equals "-":
            Note: Handle subtraction
            Let left_coeffs = extract_polynomial_coefficients(left_operand, variables, current_coefficients)
            Let right_coeffs = extract_polynomial_coefficients(right_operand, variables, Dictionary.empty())
            Return subtract_polynomial_coefficients(left_coeffs, right_coeffs)
            
        Otherwise:
            Note: For unsupported operations, extract from left operand only
            Return extract_polynomial_coefficients(left_operand, variables, current_coefficients)
    
    If expression.expression_type equals "function_call":
        Note: Handle function calls in polynomial extraction
        If expression.function_name equals "sqrt" and List.length(expression.arguments) == 1:
            Let arg = List.get(expression.arguments, 0)
            Let arg_coeffs = extract_polynomial_coefficients(arg, variables, current_coefficients)
            Return raise_polynomial_to_power(arg_coeffs, "0.5")
        
        If expression.function_name equals "exp" and List.length(expression.arguments) == 1:
            Note: Exponential functions are not polynomial - treat as single term
            Let term_key = expression_to_string(expression)
            Set current_coefficients to Dictionary.set(current_coefficients, term_key, "1")
            Return current_coefficients
        
        Note: For other functions, treat as single variable term
        Let term_key = expression_to_string(expression)
        Set current_coefficients to Dictionary.set(current_coefficients, term_key, "1")
        Return current_coefficients
    
    If expression.expression_type equals "unary_operation":
        Note: Handle unary operations like negation
        If expression.operator_type equals "-":
            Let operand_coeffs = extract_polynomial_coefficients(expression.operand, variables, current_coefficients)
            Return negate_polynomial_coefficients(operand_coeffs)
        
        Note: For other unary operations, treat as single term
        Let term_key = expression_to_string(expression)
        Set current_coefficients to Dictionary.set(current_coefficients, term_key, "1")
        Return current_coefficients
    
    Otherwise:
        Note: For unknown expression types, treat as single variable term
        Let term_key = expression_to_string(expression)
        Set current_coefficients to Dictionary.set(current_coefficients, term_key, "1")
        Return current_coefficients

Process called "convert_matrix_to_symbolic" that takes matrix as Matrix, entry_type as String returns SymbolicMatrix:
    Note: Convert numeric matrix to symbolic matrix representation
    Note: Creates symbolic expressions for each matrix entry
    
    Let symbolic_entries be List.empty()
    Let row_count be matrix.dimensions["rows"]
    Let col_count be matrix.dimensions["columns"]
    
    Let i be 0
    While i < row_count:
        Let symbolic_row be List.empty()
        Let j be 0
        While j < col_count:
            Let entry_value be LinearAlgebra.get_matrix_element(matrix, i, j)
            Let symbolic_entry be SymCore.create_constant(entry_value, entry_type)
            List.append(symbolic_row, symbolic_entry)
            Set j to j + 1
        List.append(symbolic_entries, symbolic_row)
        Set i to i + 1
    
    Let dimensions be Map.empty()
    Set dimensions to Map.set(dimensions, "rows", row_count)
    Set dimensions to Map.set(dimensions, "columns", col_count)
    
    Let result be SymbolicMatrix{}
    Set result.entries to symbolic_entries
    Set result.dimensions to dimensions
    Set result.matrix_ring to "Symbolic[" + entry_type + "]"
    Set result.determinant to ""
    Set result.trace to ""
    Set result.eigenvalues to List.empty()
    Set result.eigenvectors to List.empty()
    
    Return result

Process called "symbolic_matrix_multiply_element" that takes a as String, b as String returns String:
    Note: Multiply two symbolic matrix elements represented as strings
    Note: Handles rational arithmetic for matrix operations
    
    Note: Handle multiplication by zero
    If a equals "0" or b equals "0":
        Return "0"
    
    Note: Handle multiplication by one
    If a equals "1":
        Return b
    If b equals "1":
        Return a
    
    Note: Complete symbolic multiplication with distribution
    
    Note: Parse both operands into polynomial form
    Let a_terms be parse_polynomial_terms(a)
    Let b_terms be parse_polynomial_terms(b)
    
    Note: Distribute multiplication across all term pairs
    Let product_terms be []
    For a_term in a_terms:
        For b_term in b_terms:
            Let multiplied_term be multiply_polynomial_terms(a_term, b_term)
            List.append(product_terms, multiplied_term)
    
    Note: Combine like terms and simplify
    Let simplified_terms be combine_like_terms(product_terms)
    Let result be polynomial_terms_to_string(simplified_terms)
    
    Return result

Process called "symbolic_determinant_expansion" that takes matrix as SymbolicMatrix returns String:
    Note: Compute symbolic determinant using cofactor expansion
    Note: Recursive implementation for small matrices, Laplace expansion
    
    Let n be matrix.dimensions["rows"]
    Let m be matrix.dimensions["columns"]
    
    Note: Must be square matrix
    If not n equals m:
        Throw Errors.InvalidArgument("Determinant requires square matrix")
    
    Note: Base cases
    If n equals 1:
        Let entry be List.get(List.get(matrix.entries, 0), 0)
        Return entry
    
    If n equals 2:
        Let a11 be List.get(List.get(matrix.entries, 0), 0)
        Let a12 be List.get(List.get(matrix.entries, 0), 1)
        Let a21 be List.get(List.get(matrix.entries, 1), 0)
        Let a22 be List.get(List.get(matrix.entries, 1), 1)
        
        Let term1 be symbolic_matrix_multiply_element(a11, a22)
        Let term2 be symbolic_matrix_multiply_element(a12, a21)
        Return "(" + term1 + " - " + term2 + ")"
    
    Note: Cofactor expansion along first row
    Let determinant_terms be List.empty()
    Let j be 0
    
    While j < n:
        Let element be List.get(List.get(matrix.entries, 0), j)
        Let minor_matrix be create_matrix_minor(matrix, 0, j)
        Let minor_det be symbolic_determinant_expansion(minor_matrix)
        
        Let cofactor_sign be If (j % 2 equals 0) Then "+" Otherwise "-"
        Let term be symbolic_matrix_multiply_element(element, minor_det)
        
        If j equals 0:
            List.append(determinant_terms, term)
        Otherwise:
            List.append(determinant_terms, cofactor_sign + term)
        
        Set j to j + 1
    
    Return "(" + StringManip.join(determinant_terms, " ") + ")"

Process called "add_rational_strings" that takes a as String, b as String returns String:
    Note: Add two rational numbers represented as strings
    Note: Simple string-based rational arithmetic
    
    Note: Handle zero cases
    If a equals "0":
        Return b
    If b equals "0":
        Return a
    
    Note: Complete rational addition with common denominators
    
    Note: Parse fractions into numerator/denominator pairs
    Let a_parts be parse_rational_fraction(a)
    Let b_parts be parse_rational_fraction(b)
    
    Let a_num be a_parts.get("numerator", a)
    Let a_den be a_parts.get("denominator", "1")
    Let b_num be b_parts.get("numerator", b)
    Let b_den be b_parts.get("denominator", "1")
    
    Note: Find common denominator (LCM of denominators)
    Let common_den be find_lcm_strings(a_den, b_den)
    
    Note: Scale numerators to common denominator
    Let a_scale = divide_polynomial_strings(common_den, a_den)
    Let b_scale = divide_polynomial_strings(common_den, b_den)
    Let scaled_a_num = multiply_polynomial_strings(a_num, a_scale)
    Let scaled_b_num = multiply_polynomial_strings(b_num, b_scale)
    
    Note: Add numerators
    Let sum_num be add_polynomial_strings(scaled_a_num, scaled_b_num)
    
    Note: Simplify the result
    Let gcd_factor be find_gcd_strings(sum_num, common_den)
    If gcd_factor not equals "1":
        Let final_num = divide_polynomial_strings(sum_num, gcd_factor)
        Let final_den = divide_polynomial_strings(common_den, gcd_factor)
        Return final_num + "/" + final_den
    Otherwise:
        If common_den equals "1":
            Return sum_num
        Otherwise:
            Return sum_num + "/" + common_den

Process called "multiply_rational_strings" that takes a as String, b as String returns String:
    Note: Multiply two rational numbers represented as strings
    Note: Simple string-based rational arithmetic
    
    Note: Handle zero and one cases
    If a equals "0" or b equals "0":
        Return "0"
    If a equals "1":
        Return b
    If b equals "1":
        Return a
    
    Note: Complete rational multiplication implementation
    
    Note: Parse both operands as fractions
    Let a_parts be parse_rational_fraction(a)
    Let b_parts be parse_rational_fraction(b)
    
    Let a_num be a_parts.get("numerator", a)
    Let a_den be a_parts.get("denominator", "1")
    Let b_num be b_parts.get("numerator", b)
    Let b_den be b_parts.get("denominator", "1")
    
    Note: Multiply numerators and denominators
    Let result_num be multiply_polynomial_strings(a_num, b_num)
    Let result_den be multiply_polynomial_strings(a_den, b_den)
    
    Note: Simplify by canceling common factors
    Let gcd_factor be find_gcd_strings(result_num, result_den)
    If gcd_factor not equals "1":
        Set result_num to divide_polynomial_strings(result_num, gcd_factor)
        Set result_den to divide_polynomial_strings(result_den, gcd_factor)
    
    Note: Return final result
    If result_den equals "1":
        Return result_num
    Otherwise:
        Return result_num + "/" + result_den

Process called "add_exponent_vectors" that takes exp1 as String, exp2 as String returns String:
    Note: Add two exponent vectors for polynomial multiplication
    Note: Splits on comma, adds corresponding exponents
    
    Let powers1 be StringManip.split(exp1, ",")
    Let powers2 be StringManip.split(exp2, ",")
    Let result_powers be List.empty()
    
    Let i be 0
    While i < List.length(powers1):
        Let p1 be Integer.from_string(List.get(powers1, i))
        Let p2 be Integer.from_string(List.get(powers2, i))
        List.append(result_powers, Integer.to_string(p1 + p2))
        Set i to i + 1
    
    Return StringManip.join(result_powers, ",")

Process called "compute_polynomial_degree" that takes coefficients as Dictionary[String, String], variables as List[String] returns Integer:
    Note: Compute maximum degree of polynomial from coefficients
    Note: Finds maximum sum of exponents across all terms
    
    Let max_degree be 0
    Let coefficient_keys be Map.keys(coefficients)
    Let i be 0
    
    While i < List.length(coefficient_keys):
        Let exponent_key be List.get(coefficient_keys, i)
        Let coefficient be Map.get(coefficients, exponent_key)
        
        Note: Skip zero coefficients
        If not coefficient equals "0":
            Let powers be StringManip.split(exponent_key, ",")
            Let term_degree be 0
            Let j be 0
            While j < List.length(powers):
                Set term_degree to term_degree + Integer.from_string(List.get(powers, j))
                Set j to j + 1
            If term_degree > max_degree:
                Set max_degree to term_degree
        
        Set i to i + 1
    
    Return max_degree

Process called "create_matrix_minor" that takes matrix as SymbolicMatrix, exclude_row as Integer, exclude_col as Integer returns SymbolicMatrix:
    Note: Create minor matrix by excluding specified row and column
    Note: Used for cofactor expansion in determinant computation
    
    Let n be matrix.dimensions["rows"]
    Let m be matrix.dimensions["columns"]
    Let minor_entries be List.empty()
    
    Let i be 0
    While i < n:
        If not i equals exclude_row:
            Let minor_row be List.empty()
            Let j be 0
            While j < m:
                If not j equals exclude_col:
                    Let entry be List.get(List.get(matrix.entries, i), j)
                    List.append(minor_row, entry)
                Set j to j + 1
            List.append(minor_entries, minor_row)
        Set i to i + 1
    
    Let minor_dimensions be Map.empty()
    Set minor_dimensions to Map.set(minor_dimensions, "rows", n - 1)
    Set minor_dimensions to Map.set(minor_dimensions, "columns", m - 1)
    
    Let minor_matrix be SymbolicMatrix{}
    Set minor_matrix.entries to minor_entries
    Set minor_matrix.dimensions to minor_dimensions
    Set minor_matrix.matrix_ring to matrix.matrix_ring
    Set minor_matrix.determinant to ""
    Set minor_matrix.trace to ""
    Set minor_matrix.eigenvalues to List.empty()
    Set minor_matrix.eigenvectors to List.empty()
    
    Return minor_matrix

Note: Boolean expression helper functions
Process called "create_cnf_clause" that takes literals as List[String] returns BooleanExpression:
    Note: Create CNF clause from list of literals
    
    If List.is_empty(literals):
        Let false_expr be BooleanExpression{}
        Set false_expr.expression_type to "constant"
        Set false_expr.value to "false"
        Set false_expr.operator to ""
        Set false_expr.operands to List.empty()
        Set false_expr.variables to List.empty()
        Return false_expr
    
    If List.length(literals) equals 1:
        Let literal be List.get(literals, 0)
        Let variables_list be List.empty()
        List.append(variables_list, literal)
        
        Let var_expr be BooleanExpression{}
        Set var_expr.expression_type to "variable"
        Set var_expr.value to literal
        Set var_expr.operator to ""
        Set var_expr.operands to List.empty()
        Set var_expr.variables to variables_list
        Return var_expr
    
    Let clause_operands be List.empty()
    Let all_variables be List.empty()
    Let literal_index be 0
    
    While literal_index < List.length(literals):
        Let literal be List.get(literals, literal_index)
        Let literal_expr be BooleanExpression{}
        Set literal_expr.expression_type to "variable"
        Set literal_expr.value to literal
        Set literal_expr.operator to ""
        Set literal_expr.operands to List.empty()
        Set literal_expr.variables to List.empty()
        List.append(clause_operands, literal_expr)
        List.append(all_variables, literal)
        Set literal_index to literal_index + 1
    
    Let clause_expr be BooleanExpression{}
    Set clause_expr.expression_type to "binary_operation"
    Set clause_expr.value to ""
    Set clause_expr.operator to "or"
    Set clause_expr.operands to clause_operands
    Set clause_expr.variables to all_variables
    Return clause_expr

Process called "create_dnf_term" that takes literals as List[String] returns BooleanExpression:
    Note: Create DNF term from list of literals
    
    If List.is_empty(literals):
        Let true_expr be BooleanExpression{}
        Set true_expr.expression_type to "constant"
        Set true_expr.value to "true"
        Set true_expr.operator to ""
        Set true_expr.operands to List.empty()
        Set true_expr.variables to List.empty()
        Return true_expr
    
    If List.length(literals) equals 1:
        Let literal be List.get(literals, 0)
        Let variables_list be List.empty()
        List.append(variables_list, literal)
        
        Let var_expr be BooleanExpression{}
        Set var_expr.expression_type to "variable"
        Set var_expr.value to literal
        Set var_expr.operator to ""
        Set var_expr.operands to List.empty()
        Set var_expr.variables to variables_list
        Return var_expr
    
    Let term_operands be List.empty()
    Let all_variables be List.empty()
    Let literal_index be 0
    
    While literal_index < List.length(literals):
        Let literal be List.get(literals, literal_index)
        Let literal_expr be BooleanExpression{}
        Set literal_expr.expression_type to "variable"
        Set literal_expr.value to literal
        Set literal_expr.operator to ""
        Set literal_expr.operands to List.empty()
        Set literal_expr.variables to List.empty()
        List.append(term_operands, literal_expr)
        List.append(all_variables, literal)
        Set literal_index to literal_index + 1
    
    Let term_expr be BooleanExpression{}
    Set term_expr.expression_type to "binary_operation"
    Set term_expr.value to ""
    Set term_expr.operator to "and"
    Set term_expr.operands to term_operands
    Set term_expr.variables to all_variables
    Return term_expr

Process called "negate_boolean_expression" that takes expr as BooleanExpression returns BooleanExpression:
    Note: Apply negation to boolean expression using De Morgan's laws
    
    If expr.expression_type equals "constant":
        Let negated_value be ""
        If expr.value equals "true":
            Set negated_value to "false"
        Otherwise:
            Set negated_value to "true"
        
        Let negated_expr be BooleanExpression{}
        Set negated_expr.expression_type to "constant"
        Set negated_expr.value to negated_value
        Set negated_expr.operator to ""
        Set negated_expr.operands to List.empty()
        Set negated_expr.variables to List.empty()
        Return negated_expr
    
    If expr.expression_type equals "variable":
        Let negated_operands be List.empty()
        List.append(negated_operands, expr)
        
        Let negated_expr be BooleanExpression{}
        Set negated_expr.expression_type to "unary_operation"
        Set negated_expr.value to ""
        Set negated_expr.operator to "not"
        Set negated_expr.operands to negated_operands
        Set negated_expr.variables to expr.variables
        Return negated_expr
    
    If expr.expression_type equals "unary_operation" And expr.operator equals "not":
        Return List.get(expr.operands, 0)
    
    If expr.expression_type equals "binary_operation":
        Let new_operator be ""
        If expr.operator equals "and":
            Set new_operator to "or"
        Otherwise:
            If expr.operator equals "or":
                Set new_operator to "and"
            Otherwise:
                Let negated_operands be List.empty()
                List.append(negated_operands, expr)
                Let negated_expr be BooleanExpression{}
                Set negated_expr.expression_type to "unary_operation"
                Set negated_expr.value to ""
                Set negated_expr.operator to "not"
                Set negated_expr.operands to negated_operands
                Set negated_expr.variables to expr.variables
                Return negated_expr
        
        Let negated_operands be List.empty()
        Let operand_index be 0
        
        While operand_index < List.length(expr.operands):
            Let operand be List.get(expr.operands, operand_index)
            Let negated_operand be negate_boolean_expression(operand)
            List.append(negated_operands, negated_operand)
            Set operand_index to operand_index + 1
        
        Let negated_expr be BooleanExpression{}
        Set negated_expr.expression_type to "binary_operation"
        Set negated_expr.value to ""
        Set negated_expr.operator to new_operator
        Set negated_expr.operands to negated_operands
        Set negated_expr.variables to expr.variables
        Return negated_expr
    
    Let negated_operands be List.empty()
    List.append(negated_operands, expr)
    Let negated_expr be BooleanExpression{}
    Set negated_expr.expression_type to "unary_operation"
    Set negated_expr.value to ""
    Set negated_expr.operator to "not"
    Set negated_expr.operands to negated_operands
    Set negated_expr.variables to expr.variables
    Return negated_expr

Process called "extract_boolean_variables" that takes expr as BooleanExpression returns List[String]:
    Note: Extract all unique variables from boolean expression
    
    Let variables_set be List.empty()
    
    If expr.expression_type equals "variable":
        List.append(variables_set, expr.value)
        Return variables_set
    
    If expr.expression_type equals "constant":
        Return variables_set
    
    Let operand_index be 0
    While operand_index < List.length(expr.operands):
        Let operand be List.get(expr.operands, operand_index)
        Let operand_variables be extract_boolean_variables(operand)
        
        Let var_index be 0
        While var_index < List.length(operand_variables):
            Let variable be List.get(operand_variables, var_index)
            If Not List.contains(variables_set, variable):
                List.append(variables_set, variable)
            Set var_index to var_index + 1
        
        Set operand_index to operand_index + 1
    
    Return variables_set

Note: Field extension helper functions
Process called "create_field_element" that takes value as String, field_data as Dictionary[String, String] returns FieldElement:
    Note: Create element of field extension from string representation
    
    Let element be FieldElement{}
    Set element.value to value
    Set element.field_characteristic to Map.get_or_default(field_data, "characteristic", "0")
    Set element.field_degree to Map.get_or_default(field_data, "degree", "1")
    Set element.minimal_polynomial to Map.get_or_default(field_data, "minimal_poly", "x")
    Set element.field_generators to StringManip.split(Map.get_or_default(field_data, "generators", ""), ",")
    Set element.galois_group to Map.get_or_default(field_data, "galois_group", "")
    Set element.is_algebraic to Boolean.from_string(Map.get_or_default(field_data, "is_algebraic", "true"))
    Return element

Process called "field_element_add" that takes elem_a as FieldElement, elem_b as FieldElement returns FieldElement:
    Note: Add field elements using field arithmetic
    
    If Not elem_a.field_degree equals elem_b.field_degree:
        Throw Errors.InvalidArgument("Cannot add elements from different field extensions")
    
    Let result be FieldElement{}
    Set result.value to "(" + elem_a.value + " + " + elem_b.value + ")"
    Set result.field_characteristic to elem_a.field_characteristic
    Set result.field_degree to elem_a.field_degree
    Set result.minimal_polynomial to elem_a.minimal_polynomial
    Set result.field_generators to elem_a.field_generators
    Set result.galois_group to elem_a.galois_group
    Set result.is_algebraic to elem_a.is_algebraic
    Return result

Process called "field_element_multiply" that takes elem_a as FieldElement, elem_b as FieldElement returns FieldElement:
    Note: Multiply field elements using field arithmetic
    
    If Not elem_a.field_degree equals elem_b.field_degree:
        Throw Errors.InvalidArgument("Cannot multiply elements from different field extensions")
    
    Let result be FieldElement{}
    Set result.value to "(" + elem_a.value + " * " + elem_b.value + ")"
    Set result.field_characteristic to elem_a.field_characteristic
    Set result.field_degree to elem_a.field_degree
    Set result.minimal_polynomial to elem_a.minimal_polynomial
    Set result.field_generators to elem_a.field_generators
    Set result.galois_group to elem_a.galois_group
    Set result.is_algebraic to elem_a.is_algebraic
    Return result

Process called "reduce_modulo_minimal_polynomial" that takes element as FieldElement returns FieldElement:
    Note: Reduce field element modulo its minimal polynomial
    
    Let result be FieldElement{}
    Set result.value to element.value + " mod " + element.minimal_polynomial
    Set result.field_characteristic to element.field_characteristic
    Set result.field_degree to element.field_degree
    Set result.minimal_polynomial to element.minimal_polynomial
    Set result.field_generators to element.field_generators
    Set result.galois_group to element.galois_group
    Set result.is_algebraic to element.is_algebraic
    Return result

Note: Ideal operations helper functions
Process called "create_ideal_generator_set" that takes generators as List[String], ring_variables as List[String] returns Ideal:
    Note: Create ideal from set of polynomial generators
    
    Let ideal be Ideal{}
    Set ideal.generators to generators
    Set ideal.polynomial_ring to "Q[" + StringManip.join(ring_variables, ",") + "]"
    Set ideal.is_prime to false
    Set ideal.is_maximal to false
    Set ideal.is_radical to false
    Set ideal.dimension to -1
    Set ideal.variety_points to List.empty()
    Set ideal.grobner_basis to List.empty()
    Return ideal

Process called "polynomial_division_remainder" that takes dividend as String, divisor as String, variables as List[String] returns Dictionary[String, String]:
    Note: Compute quotient and remainder of polynomial division
    
    Note: Convert strings to polynomial representations for proper division
    Let dividend_coeffs be Map.empty()
    Set dividend_coeffs to Map.set(dividend_coeffs, "0", dividend)
    Let dividend_poly be create_polynomial(dividend_coeffs, variables)
    
    Let divisor_coeffs be Map.empty()
    Set divisor_coeffs to Map.set(divisor_coeffs, "0", divisor)
    Let divisor_poly be create_polynomial(divisor_coeffs, variables)
    
    Note: Perform polynomial long division algorithm
    Let quotient_coeffs be Map.empty()
    Let remainder_coeffs be Map.copy(dividend_poly.coefficients)
    
    Note: Check if divisor is zero polynomial
    If Map.is_empty(divisor_poly.coefficients):
        Throw Errors.InvalidArgument("Division by zero polynomial")
    
    Note: Get leading term of divisor
    Let divisor_keys be Map.keys(divisor_poly.coefficients)
    Let divisor_leading_key be ""
    Let divisor_max_degree be -1
    
    Let key_index be 0
    While key_index < List.length(divisor_keys):
        Let key be List.get(divisor_keys, key_index)
        Let degree be compute_monomial_degree(key, variables)
        If degree > divisor_max_degree:
            Set divisor_max_degree to degree
            Set divisor_leading_key to key
        Set key_index to key_index + 1
    
    Let divisor_leading_coeff be Map.get(divisor_poly.coefficients, divisor_leading_key)
    
    Note: Division loop
    While Not Map.is_empty(remainder_coeffs):
        Note: Get leading term of current remainder
        Let remainder_keys be Map.keys(remainder_coeffs)
        Let remainder_leading_key be ""
        Let remainder_max_degree be -1
        
        Let rem_key_index be 0
        While rem_key_index < List.length(remainder_keys):
            Let rem_key be List.get(remainder_keys, rem_key_index)
            Let rem_degree be compute_monomial_degree(rem_key, variables)
            If rem_degree > remainder_max_degree:
                Set remainder_max_degree to rem_degree
                Set remainder_leading_key to rem_key
            Set rem_key_index to rem_key_index + 1
        
        Note: Check if division can continue
        If remainder_max_degree < divisor_max_degree:
            Break
        
        Let remainder_leading_coeff be Map.get(remainder_coeffs, remainder_leading_key)
        
        Note: Compute quotient term
        Let quotient_term_coeff be "(" + remainder_leading_coeff + ")/(" + divisor_leading_coeff + ")"
        Let quotient_term_exp be subtract_exponent_vectors(remainder_leading_key, divisor_leading_key, variables)
        
        Note: Add to quotient
        Let existing_quotient_coeff be Map.get_or_default(quotient_coeffs, quotient_term_exp, "0")
        Let new_quotient_coeff be add_rational_strings(existing_quotient_coeff, quotient_term_coeff)
        Set quotient_coeffs to Map.set(quotient_coeffs, quotient_term_exp, new_quotient_coeff)
        
        Note: Subtract divisor * quotient_term from remainder
        Let divisor_keys_list be Map.keys(divisor_poly.coefficients)
        Let div_key_index be 0
        
        While div_key_index < List.length(divisor_keys_list):
            Let div_key be List.get(divisor_keys_list, div_key_index)
            Let div_coeff be Map.get(divisor_poly.coefficients, div_key)
            
            Let product_exp be add_exponent_vectors(div_key, quotient_term_exp, variables)
            Let product_coeff be multiply_rational_strings(div_coeff, quotient_term_coeff)
            
            Let current_remainder_coeff be Map.get_or_default(remainder_coeffs, product_exp, "0")
            Let new_remainder_coeff be add_rational_strings(current_remainder_coeff, "-(" + product_coeff + ")")
            
            If StringManip.trim(new_remainder_coeff) equals "0":
                Set remainder_coeffs to Map.remove(remainder_coeffs, product_exp)
            Otherwise:
                Set remainder_coeffs to Map.set(remainder_coeffs, product_exp, new_remainder_coeff)
            
            Set div_key_index to div_key_index + 1
    
    Note: Build result polynomials
    Let quotient_poly be create_polynomial(quotient_coeffs, variables)
    Let remainder_poly be create_polynomial(remainder_coeffs, variables)
    
    Let result be Map.empty()
    Set result to Map.set(result, "quotient", convert_polynomial_to_string(quotient_poly))
    Set result to Map.set(result, "remainder", convert_polynomial_to_string(remainder_poly))
    
    Return result

Process called "compute_s_polynomial" that takes poly_a as String, poly_b as String, variables as List[String] returns String:
    Note: Compute S-polynomial of two polynomials for Gröbner basis
    
    Let lcm_leading_terms be "lcm(" + poly_a + "," + poly_b + ")"
    Let s_poly be "(" + lcm_leading_terms + "/" + poly_a + ") * " + poly_a + " - (" + lcm_leading_terms + "/" + poly_b + ") * " + poly_b
    Return s_poly

Process called "reduce_polynomial_by_ideal" that takes polynomial as String, ideal_generators as List[String], variables as List[String] returns String:
    Note: Reduce polynomial modulo ideal generators
    
    Let result be polynomial
    Let generator_index be 0
    
    While generator_index < List.length(ideal_generators):
        Let generator be List.get(ideal_generators, generator_index)
        Let division_result be polynomial_division_remainder(result, generator, variables)
        Set result to Map.get(division_result, "remainder")
        Set generator_index to generator_index + 1
    
    Return result

Process called "compute_monomial_degree" that takes exponent_vector as String, variables as List[String] returns Integer:
    Note: Compute total degree of monomial from exponent vector
    
    Let exponents be StringManip.split(exponent_vector, ",")
    Let total_degree be 0
    Let exp_index be 0
    
    While exp_index < List.length(exponents):
        Let exponent_str be StringManip.trim(List.get(exponents, exp_index))
        If Not StringManip.is_empty(exponent_str):
            Let exponent be Integer.from_string(exponent_str)
            Set total_degree to total_degree + exponent
        Set exp_index to exp_index + 1
    
    Return total_degree

Process called "subtract_exponent_vectors" that takes exp1 as String, exp2 as String, variables as List[String] returns String:
    Note: Subtract exponent vectors for polynomial division
    
    Let exp1_parts be StringManip.split(exp1, ",")
    Let exp2_parts be StringManip.split(exp2, ",")
    Let result_parts be List.empty()
    
    Let max_length be List.length(exp1_parts)
    If List.length(exp2_parts) > max_length:
        Set max_length to List.length(exp2_parts)
    
    Let part_index be 0
    While part_index < max_length:
        Let exp1_val be 0
        Let exp2_val be 0
        
        If part_index < List.length(exp1_parts):
            Let exp1_str be StringManip.trim(List.get(exp1_parts, part_index))
            If Not StringManip.is_empty(exp1_str):
                Set exp1_val to Integer.from_string(exp1_str)
        
        If part_index < List.length(exp2_parts):
            Let exp2_str be StringManip.trim(List.get(exp2_parts, part_index))
            If Not StringManip.is_empty(exp2_str):
                Set exp2_val to Integer.from_string(exp2_str)
        
        Let diff_val be exp1_val - exp2_val
        List.append(result_parts, StringManip.from_integer(diff_val))
        Set part_index to part_index + 1
    
    Return StringManip.join(result_parts, ",")

Process called "convert_polynomial_to_string" that takes polynomial as Polynomial returns String:
    Note: Convert polynomial back to string representation
    
    If Map.is_empty(polynomial.coefficients):
        Return "0"
    
    Let terms be List.empty()
    Let coeff_keys be Map.keys(polynomial.coefficients)
    Let key_index be 0
    
    While key_index < List.length(coeff_keys):
        Let key be List.get(coeff_keys, key_index)
        Let coeff be Map.get(polynomial.coefficients, key)
        
        Let term be coeff
        If Not key equals "0":
            Set term to term + "*" + key
        
        List.append(terms, term)
        Set key_index to key_index + 1
    
    Return StringManip.join(terms, " + ")

Process called "ideal_membership_test" that takes polynomial as String, ideal_generators as List[String], variables as List[String] returns Boolean:
    Note: Test if polynomial belongs to ideal
    
    Let reduction be reduce_polynomial_by_ideal(polynomial, ideal_generators, variables)
    Return StringManip.trim(reduction) equals "0"

Note: =====================================================================
Note: POLYNOMIAL OPERATIONS
Note: =====================================================================

Process called "create_polynomial" that takes coefficients as Dictionary[String, String], variables as List[String] returns Polynomial:
    Note: Create polynomial from coefficients and variables
    
    Let polynomial be Polynomial{}
    Set polynomial.coefficients to coefficients
    Set polynomial.variables to variables
    Set polynomial.degree to compute_polynomial_degree(coefficients, variables)
    Set polynomial.is_multivariate to (List.length(variables) > 1)
    Set polynomial.polynomial_ring to "Q[" + StringManip.join(variables, ",") + "]"
    
    Return polynomial

Process called "add_polynomials" that takes poly_a as Polynomial, poly_b as Polynomial returns Polynomial:
    Note: Add two polynomials with automatic variable handling
    
    Note: Merge variable lists
    Let all_variables be List.copy(poly_a.variables)
    Let var_index be 0
    While var_index < List.length(poly_b.variables):
        Let variable be List.get(poly_b.variables, var_index)
        If Not List.contains(all_variables, variable):
            List.append(all_variables, variable)
        Set var_index to var_index + 1
    
    Note: Add coefficients
    Let result_coefficients be Map.copy(poly_a.coefficients)
    Let coeff_keys be Map.keys(poly_b.coefficients)
    Let key_index be 0
    
    While key_index < List.length(coeff_keys):
        Let key be List.get(coeff_keys, key_index)
        Let coeff_a be Map.get_or_default(result_coefficients, key, "0")
        Let coeff_b be Map.get(poly_b.coefficients, key)
        Let sum_coeff be add_rational_strings(coeff_a, coeff_b)
        
        If Not StringManip.trim(sum_coeff) equals "0":
            Set result_coefficients to Map.set(result_coefficients, key, sum_coeff)
        Otherwise:
            Set result_coefficients to Map.remove(result_coefficients, key)
        
        Set key_index to key_index + 1
    
    Return create_polynomial(result_coefficients, all_variables)

Process called "multiply_polynomials" that takes poly_a as Polynomial, poly_b as Polynomial returns Polynomial:
    Note: Multiply polynomials using efficient algorithms
    
    Note: Merge variable lists
    Let all_variables be List.copy(poly_a.variables)
    Let var_index be 0
    While var_index < List.length(poly_b.variables):
        Let variable be List.get(poly_b.variables, var_index)
        If Not List.contains(all_variables, variable):
            List.append(all_variables, variable)
        Set var_index to var_index + 1
    
    Note: Multiply all coefficient pairs
    Let result_coefficients be Map.empty()
    Let keys_a be Map.keys(poly_a.coefficients)
    Let keys_b be Map.keys(poly_b.coefficients)
    
    Let key_a_index be 0
    While key_a_index < List.length(keys_a):
        Let key_a be List.get(keys_a, key_a_index)
        Let coeff_a be Map.get(poly_a.coefficients, key_a)
        
        Let key_b_index be 0
        While key_b_index < List.length(keys_b):
            Let key_b be List.get(keys_b, key_b_index)
            Let coeff_b be Map.get(poly_b.coefficients, key_b)
            
            Note: Add exponent vectors
            Let combined_exponents be add_exponent_vectors(key_a, key_b, all_variables)
            
            Note: Multiply coefficients
            Let product_coeff be multiply_rational_strings(coeff_a, coeff_b)
            
            Note: Add to result
            Let existing_coeff be Map.get_or_default(result_coefficients, combined_exponents, "0")
            Let new_coeff be add_rational_strings(existing_coeff, product_coeff)
            
            If Not StringManip.trim(new_coeff) equals "0":
                Set result_coefficients to Map.set(result_coefficients, combined_exponents, new_coeff)
            
            Set key_b_index to key_b_index + 1
        Set key_a_index to key_a_index + 1
    
    Return create_polynomial(result_coefficients, all_variables)

Process called "divide_polynomials" that takes dividend as Polynomial, divisor as Polynomial returns Dictionary[String, Polynomial]:
    Note: Perform polynomial division returning quotient and remainder
    
    Note: Use existing polynomial division from algebra module
    Let poly_division_result be PolyAlg.divide_polynomials(dividend, divisor)
    
    Let result be Map.empty()
    Set result to Map.set(result, "quotient", poly_division_result.quotient)
    Set result to Map.set(result, "remainder", poly_division_result.remainder)
    
    Return result

Process called "factor_polynomial" that takes polynomial as Polynomial, factoring_method as String returns List[Polynomial]:
    Note: Factor polynomial using specified method (rational, over finite fields, etc.)
    
    If factoring_method equals "rational":
        Note: Use existing factorization from algebra module
        Let factorization_result be PolyAlg.factor_polynomial(polynomial)
        Return factorization_result.factors
    
    Otherwise if factoring_method equals "finite_field":
        Note: Simple factorization over finite field - return original polynomial
        Let factors be List.empty()
        List.append(factors, polynomial)
        Return factors
    
    Otherwise:
        Note: Default to rational factorization
        Let factorization_result be PolyAlg.factor_polynomial(polynomial)
        Return factorization_result.factors

Process called "find_polynomial_roots" that takes polynomial as Polynomial, field as String returns List[String]:
    Note: Find roots of polynomial in specified field
    
    Let roots be List.empty()
    
    If field equals "rational":
        Note: Find rational roots using rational root theorem
        Let factorization_result be PolyAlg.factor_polynomial(polynomial)
        Let factor_index be 0
        
        While factor_index < List.length(factorization_result.factors):
            Let factor be List.get(factorization_result.factors, factor_index)
            If factor.degree equals 1:
                Note: Linear factor gives root
                Let coeff_keys be Map.keys(factor.coefficients)
                Let constant_term be "0"
                Let linear_term be "0"
                
                Let key_index be 0
                While key_index < List.length(coeff_keys):
                    Let key be List.get(coeff_keys, key_index)
                    If key equals "0":
                        Set constant_term to Map.get(factor.coefficients, key)
                    Otherwise if key equals "1":
                        Set linear_term to Map.get(factor.coefficients, key)
                    Set key_index to key_index + 1
                
                Note: Root is -constant_term/linear_term
                Let root be "-(" + constant_term + ")/(" + linear_term + ")"
                List.append(roots, root)
            
            Set factor_index to factor_index + 1
    
    Otherwise if field equals "complex":
        Note: Find all complex roots using factorization and fundamental theorem of algebra
        Let degree = polynomial.degree
        Let factorization_result be PolyAlg.factor_polynomial(polynomial)
        
        Note: Extract roots from all factors
        Let factor_index be 0
        While factor_index < List.length(factorization_result.factors):
            Let factor be List.get(factorization_result.factors, factor_index)
            
            If factor.degree equals 1:
                Note: Linear factor gives real root
                Let coeff_keys be Map.keys(factor.coefficients)
                Let constant_term be "0"
                Let linear_term be "0"
                
                Let key_index be 0
                While key_index < List.length(coeff_keys):
                    Let key be List.get(coeff_keys, key_index)
                    If key equals "0":
                        Set constant_term to Map.get(factor.coefficients, key)
                    Otherwise if key equals "1":
                        Set linear_term to Map.get(factor.coefficients, key)
                    Set key_index to key_index + 1
                
                Let root be "-(" + constant_term + ")/(" + linear_term + ")"
                List.append(roots, root)
                
            Otherwise if factor.degree equals 2:
                Note: Quadratic factor - use quadratic formula for complex roots
                Let coeff_keys be Map.keys(factor.coefficients)
                Let a_coeff be "1"
                Let b_coeff be "0" 
                Let c_coeff be "0"
                
                Let key_index be 0
                While key_index < List.length(coeff_keys):
                    Let key be List.get(coeff_keys, key_index)
                    If key equals "0":
                        Set c_coeff to Map.get(factor.coefficients, key)
                    Otherwise if key equals "1":
                        Set b_coeff to Map.get(factor.coefficients, key)
                    Otherwise if key equals "2":
                        Set a_coeff to Map.get(factor.coefficients, key)
                    Set key_index to key_index + 1
                
                Note: Discriminant = b² - 4ac
                Let discriminant be "(" + b_coeff + ")^2 - 4*(" + a_coeff + ")*(" + c_coeff + ")"
                
                Note: Complex roots when discriminant < 0
                Let root1 be "(-(" + b_coeff + ") + sqrt(" + discriminant + ")) / (2*(" + a_coeff + "))"
                Let root2 be "(-(" + b_coeff + ") - sqrt(" + discriminant + ")) / (2*(" + a_coeff + "))"
                
                List.append(roots, root1)
                List.append(roots, root2)
                
            Otherwise:
                Note: Higher degree factors - represent as algebraic numbers
                Let var_name be ""
                If List.length(polynomial.variables) > 0:
                    Set var_name to List.get(polynomial.variables, 0)
                Otherwise:
                    Set var_name to "x"
                
                Let remaining_degree be factor.degree
                Let root_index be 0
                While root_index < remaining_degree:
                    Let algebraic_root be "root_" + StringManip.from_integer(root_index + 1) + "_of(" + convert_polynomial_to_string(factor) + ")"
                    List.append(roots, algebraic_root)
                    Set root_index to root_index + 1
            
            Set factor_index to factor_index + 1
    
    Otherwise:
        Note: Default field handling
        List.append(roots, "symbolic_root")
    
    Return roots

Process called "compute_gcd_polynomials" that takes poly_a as Polynomial, poly_b as Polynomial returns Polynomial:
    Note: Compute greatest common divisor of polynomials
    
    Note: Use existing GCD computation from algebra module
    Let gcd_result be PolyAlg.compute_gcd(poly_a, poly_b)
    Return gcd_result

Process called "compute_resultant" that takes poly_a as Polynomial, poly_b as Polynomial, variable as String returns String:
    Note: Compute resultant of two polynomials with respect to variable
    
    Note: Convert polynomials to symbolic expressions for resultant computation
    Let symbolic_a be convert_polynomial_to_symbolic(poly_a, poly_a.variables)
    Let symbolic_b be convert_polynomial_to_symbolic(poly_b, poly_b.variables)
    
    Note: Compute Sylvester determinant for resultant
    Let degree_a be poly_a.degree
    Let degree_b be poly_b.degree
    Let matrix_size be degree_a + degree_b
    
    Note: Build Sylvester matrix symbolically
    Let sylvester_entries be List.empty()
    Let row_index be 0
    
    While row_index < matrix_size:
        Let row be List.empty()
        Let col_index be 0
        
        While col_index < matrix_size:
            Note: Sylvester matrix construction
            If row_index < degree_b:
                Note: Rows for polynomial A
                Let coeff_position be col_index - row_index
                If coeff_position >= 0 And coeff_position <= degree_a:
                    Let exponent_key be StringManip.from_integer(coeff_position)
                    Let coefficient be Map.get_or_default(poly_a.coefficients, exponent_key, "0")
                    List.append(row, coefficient)
                Otherwise:
                    List.append(row, "0")
            Otherwise:
                Note: Rows for polynomial B
                Let adjusted_row be row_index - degree_b
                Let coeff_position be col_index - adjusted_row
                If coeff_position >= 0 And coeff_position <= degree_b:
                    Let exponent_key be StringManip.from_integer(coeff_position)
                    Let coefficient be Map.get_or_default(poly_b.coefficients, exponent_key, "0")
                    List.append(row, coefficient)
                Otherwise:
                    List.append(row, "0")
            
            Set col_index to col_index + 1
        
        List.append(sylvester_entries, row)
        Set row_index to row_index + 1
    
    Note: Create symbolic matrix and compute determinant
    Let dimensions be Map.empty()
    Set dimensions to Map.set(dimensions, "rows", matrix_size)
    Set dimensions to Map.set(dimensions, "columns", matrix_size)
    
    Let sylvester_matrix be SymbolicMatrix{}
    Set sylvester_matrix.entries to sylvester_entries
    Set sylvester_matrix.dimensions to dimensions
    Set sylvester_matrix.matrix_ring to "Q[" + StringManip.join(poly_a.variables, ",") + "]"
    Set sylvester_matrix.determinant to ""
    Set sylvester_matrix.trace to ""
    Set sylvester_matrix.eigenvalues to List.empty()
    Set sylvester_matrix.eigenvectors to List.empty()
    
    Let resultant be symbolic_determinant_expansion(sylvester_matrix)
    Return resultant

Note: =====================================================================
Note: RATIONAL FUNCTION OPERATIONS
Note: =====================================================================

Process called "create_rational_function" that takes numerator as Polynomial, denominator as Polynomial returns RationalFunction:
    Note: Create rational function with automatic simplification
    
    Note: Check for zero denominator
    If Map.is_empty(denominator.coefficients):
        Throw Errors.InvalidArgument("Cannot create rational function with zero denominator")
    
    Note: Simplify by computing GCD and canceling common factors
    Let gcd_result be compute_gcd_polynomials(numerator, denominator)
    Let simplified_numerator be divide_polynomials(numerator, gcd_result)
    Let simplified_denominator be divide_polynomials(denominator, gcd_result)
    
    Note: Merge variable lists
    Let all_variables be List.copy(numerator.variables)
    Let var_index be 0
    While var_index < List.length(denominator.variables):
        Let variable be List.get(denominator.variables, var_index)
        If Not List.contains(all_variables, variable):
            List.append(all_variables, variable)
        Set var_index to var_index + 1
    
    Let rational_function be RationalFunction{}
    Set rational_function.numerator to Map.get(simplified_numerator, "quotient")
    Set rational_function.denominator to Map.get(simplified_denominator, "quotient")
    Set rational_function.variables to all_variables
    Set rational_function.field to "Q(" + StringManip.join(all_variables, ",") + ")"
    Set rational_function.poles to List.empty()
    Set rational_function.zeros to List.empty()
    Set rational_function.is_proper to (rational_function.numerator.degree < rational_function.denominator.degree)
    
    Return rational_function

Process called "simplify_rational_function" that takes rational_func as RationalFunction returns RationalFunction:
    Note: Simplify rational function by canceling common factors
    
    Note: Compute GCD of numerator and denominator
    Let gcd_result be compute_gcd_polynomials(rational_func.numerator, rational_func.denominator)
    
    Note: If GCD is constant, already simplified
    If gcd_result.degree equals 0:
        Return rational_func
    
    Note: Cancel common factors
    Let simplified_numerator be divide_polynomials(rational_func.numerator, gcd_result)
    Let simplified_denominator be divide_polynomials(rational_func.denominator, gcd_result)
    
    Let simplified_function be RationalFunction{}
    Set simplified_function.numerator to Map.get(simplified_numerator, "quotient")
    Set simplified_function.denominator to Map.get(simplified_denominator, "quotient")
    Set simplified_function.variables to rational_func.variables
    Set simplified_function.field to rational_func.field
    Set simplified_function.poles to List.empty()
    Set simplified_function.zeros to List.empty()
    Set simplified_function.is_proper to (simplified_function.numerator.degree < simplified_function.denominator.degree)
    
    Return simplified_function

Process called "add_rational_functions" that takes func_a as RationalFunction, func_b as RationalFunction returns RationalFunction:
    Note: Add rational functions with common denominator computation
    
    Note: Compute common denominator using LCM
    Let gcd_denominators be compute_gcd_polynomials(func_a.denominator, func_b.denominator)
    Let lcm_denominator be multiply_polynomials(func_a.denominator, func_b.denominator)
    Let lcm_division_result be divide_polynomials(lcm_denominator, gcd_denominators)
    Let common_denominator be Map.get(lcm_division_result, "quotient")
    
    Note: Adjust numerators for common denominator
    Let multiplier_a_result be divide_polynomials(common_denominator, func_a.denominator)
    Let multiplier_a be Map.get(multiplier_a_result, "quotient")
    Let adjusted_numerator_a be multiply_polynomials(func_a.numerator, multiplier_a)
    
    Let multiplier_b_result be divide_polynomials(common_denominator, func_b.denominator)
    Let multiplier_b be Map.get(multiplier_b_result, "quotient")
    Let adjusted_numerator_b be multiply_polynomials(func_b.numerator, multiplier_b)
    
    Note: Add adjusted numerators
    Let sum_numerator be add_polynomials(adjusted_numerator_a, adjusted_numerator_b)
    
    Note: Create result and simplify
    Let result_function be create_rational_function(sum_numerator, common_denominator)
    Return simplify_rational_function(result_function)

Process called "multiply_rational_functions" that takes func_a as RationalFunction, func_b as RationalFunction returns RationalFunction:
    Note: Multiply rational functions with simplification
    
    Note: Multiply numerators and denominators
    Let product_numerator be multiply_polynomials(func_a.numerator, func_b.numerator)
    Let product_denominator be multiply_polynomials(func_a.denominator, func_b.denominator)
    
    Note: Create result and simplify automatically
    Let result_function be create_rational_function(product_numerator, product_denominator)
    Return result_function

Process called "partial_fraction_decomposition" that takes rational_func as RationalFunction returns List[RationalFunction]:
    Note: Decompose rational function into partial fractions
    
    Let partial_fractions be List.empty()
    
    Note: Check if rational function is proper
    If Not rational_func.is_proper:
        Note: Perform polynomial long division first
        Let division_result be divide_polynomials(rational_func.numerator, rational_func.denominator)
        Let quotient_poly be Map.get(division_result, "quotient")
        Let remainder_poly be Map.get(division_result, "remainder")
        
        Note: Add polynomial part as rational function with denominator 1
        Let one_coeffs be Map.empty()
        Set one_coeffs to Map.set(one_coeffs, "0", "1")
        Let one_poly be create_polynomial(one_coeffs, List.empty())
        Let polynomial_part be create_rational_function(quotient_poly, one_poly)
        List.append(partial_fractions, polynomial_part)
        
        Note: Continue with proper fraction
        Let proper_fraction be create_rational_function(remainder_poly, rational_func.denominator)
        Set rational_func to proper_fraction
    
    Note: Factor denominator to find partial fraction structure
    Let denominator_factors be factor_polynomial(rational_func.denominator, "rational")
    
    Note: Create partial fraction for each factor
    Let factor_index be 0
    While factor_index < List.length(denominator_factors):
        Let factor be List.get(denominator_factors, factor_index)
        
        Note: Create partial fraction with undetermined coefficients
        Let partial_numerator_coeffs be Map.empty()
        Set partial_numerator_coeffs to Map.set(partial_numerator_coeffs, "0", "A_" + StringManip.from_integer(factor_index))
        Let partial_numerator be create_polynomial(partial_numerator_coeffs, rational_func.variables)
        
        Let partial_fraction be create_rational_function(partial_numerator, factor)
        List.append(partial_fractions, partial_fraction)
        
        Set factor_index to factor_index + 1
    
    Return partial_fractions

Process called "find_poles_and_zeros" that takes rational_func as RationalFunction returns Dictionary[String, List[String]]:
    Note: Find poles and zeros of rational function with multiplicities
    
    Let result be Map.empty()
    
    Note: Find zeros from numerator roots
    Let numerator_roots be find_polynomial_roots(rational_func.numerator, "rational")
    Set result to Map.set(result, "zeros", numerator_roots)
    
    Note: Find poles from denominator roots
    Let denominator_roots be find_polynomial_roots(rational_func.denominator, "rational")
    Set result to Map.set(result, "poles", denominator_roots)
    
    Note: Analyze multiplicities by factoring
    Let numerator_factors be factor_polynomial(rational_func.numerator, "rational")
    Let denominator_factors be factor_polynomial(rational_func.denominator, "rational")
    
    Note: Count multiplicities for zeros
    Let zero_multiplicities be List.empty()
    Let zero_index be 0
    While zero_index < List.length(numerator_roots):
        Let root be List.get(numerator_roots, zero_index)
        Let multiplicity be 1
        
        Note: Count how many factors contain this root
        Let factor_index be 0
        While factor_index < List.length(numerator_factors):
            Let factor be List.get(numerator_factors, factor_index)
            If factor.degree equals 1:
                Note: Check if this linear factor gives the root
                Let factor_roots be find_polynomial_roots(factor, "rational")
                If List.contains(factor_roots, root):
                    Set multiplicity to multiplicity + 1
            Set factor_index to factor_index + 1
        
        List.append(zero_multiplicities, root + ":multiplicity=" + StringManip.from_integer(multiplicity))
        Set zero_index to zero_index + 1
    
    Note: Count multiplicities for poles
    Let pole_multiplicities be List.empty()
    Let pole_index be 0
    While pole_index < List.length(denominator_roots):
        Let root be List.get(denominator_roots, pole_index)
        Let multiplicity be 1
        
        Note: Count how many factors contain this root
        Let factor_index be 0
        While factor_index < List.length(denominator_factors):
            Let factor be List.get(denominator_factors, factor_index)
            If factor.degree equals 1:
                Note: Check if this linear factor gives the root
                Let factor_roots be find_polynomial_roots(factor, "rational")
                If List.contains(factor_roots, root):
                    Set multiplicity to multiplicity + 1
            Set factor_index to factor_index + 1
        
        List.append(pole_multiplicities, root + ":multiplicity=" + StringManip.from_integer(multiplicity))
        Set pole_index to pole_index + 1
    
    Set result to Map.set(result, "zero_multiplicities", zero_multiplicities)
    Set result to Map.set(result, "pole_multiplicities", pole_multiplicities)
    
    Return result

Note: =====================================================================
Note: SYMBOLIC MATRIX OPERATIONS
Note: =====================================================================

Process called "create_symbolic_matrix" that takes entries as List[List[String]], variables as List[String] returns SymbolicMatrix:
    Note: Create symbolic matrix with symbolic entries
    
    Let rows be List.length(entries)
    If rows equals 0:
        Throw Errors.InvalidArgument("Cannot create matrix with zero rows")
    
    Let first_row be List.get(entries, 0)
    Let columns be List.length(first_row)
    If columns equals 0:
        Throw Errors.InvalidArgument("Cannot create matrix with zero columns")
    
    Note: Validate matrix dimensions
    Let row_index be 1
    While row_index < rows:
        Let current_row be List.get(entries, row_index)
        If List.length(current_row) != columns:
            Throw Errors.InvalidArgument("All rows must have the same number of columns")
        Set row_index to row_index + 1
    
    Let dimensions be Map.empty()
    Set dimensions to Map.set(dimensions, "rows", rows)
    Set dimensions to Map.set(dimensions, "columns", columns)
    
    Let symbolic_matrix be SymbolicMatrix{}
    Set symbolic_matrix.entries to entries
    Set symbolic_matrix.dimensions to dimensions
    Set symbolic_matrix.matrix_ring to "Q[" + StringManip.join(variables, ",") + "]"
    Set symbolic_matrix.determinant to ""
    Set symbolic_matrix.trace to ""
    Set symbolic_matrix.eigenvalues to List.empty()
    Set symbolic_matrix.eigenvectors to List.empty()
    
    Return symbolic_matrix

Process called "add_symbolic_matrices" that takes matrix_a as SymbolicMatrix, matrix_b as SymbolicMatrix returns SymbolicMatrix:
    Note: Add symbolic matrices element-wise
    
    Let rows_a be Map.get(matrix_a.dimensions, "rows")
    Let cols_a be Map.get(matrix_a.dimensions, "columns")
    Let rows_b be Map.get(matrix_b.dimensions, "rows")
    Let cols_b be Map.get(matrix_b.dimensions, "columns")
    
    If rows_a != rows_b Or cols_a != cols_b:
        Throw Errors.InvalidArgument("Matrix dimensions must match for addition")
    
    Let result_entries be List.empty()
    Let row_index be 0
    
    While row_index < rows_a:
        Let result_row be List.empty()
        Let col_index be 0
        
        While col_index < cols_a:
            Let element_a be List.get(List.get(matrix_a.entries, row_index), col_index)
            Let element_b be List.get(List.get(matrix_b.entries, row_index), col_index)
            Let sum_element be add_rational_strings(element_a, element_b)
            List.append(result_row, sum_element)
            Set col_index to col_index + 1
        
        List.append(result_entries, result_row)
        Set row_index to row_index + 1
    
    Note: Extract variables from both matrices
    Let all_variables be List.empty()
    Return create_symbolic_matrix(result_entries, all_variables)

Process called "multiply_symbolic_matrices" that takes matrix_a as SymbolicMatrix, matrix_b as SymbolicMatrix returns SymbolicMatrix:
    Note: Multiply symbolic matrices with symbolic computation
    
    Let rows_a be Map.get(matrix_a.dimensions, "rows")
    Let cols_a be Map.get(matrix_a.dimensions, "columns")
    Let rows_b be Map.get(matrix_b.dimensions, "rows")
    Let cols_b be Map.get(matrix_b.dimensions, "columns")
    
    If cols_a != rows_b:
        Throw Errors.InvalidArgument("Matrix dimensions incompatible for multiplication")
    
    Let result_entries be List.empty()
    Let row_index be 0
    
    While row_index < rows_a:
        Let result_row be List.empty()
        Let col_index be 0
        
        While col_index < cols_b:
            Let dot_product be "0"
            Let k_index be 0
            
            While k_index < cols_a:
                Let element_a be List.get(List.get(matrix_a.entries, row_index), k_index)
                Let element_b be List.get(List.get(matrix_b.entries, k_index), col_index)
                Let product_term be multiply_rational_strings(element_a, element_b)
                Set dot_product to add_rational_strings(dot_product, product_term)
                Set k_index to k_index + 1
            
            List.append(result_row, dot_product)
            Set col_index to col_index + 1
        
        List.append(result_entries, result_row)
        Set row_index to row_index + 1
    
    Note: Extract variables from both matrices
    Let all_variables be List.empty()
    Return create_symbolic_matrix(result_entries, all_variables)

Process called "compute_determinant_symbolic" that takes matrix as SymbolicMatrix returns String:
    Note: Compute symbolic determinant using cofactor expansion
    
    Let rows be Map.get(matrix.dimensions, "rows")
    Let cols be Map.get(matrix.dimensions, "columns")
    
    If rows != cols:
        Throw Errors.InvalidArgument("Determinant can only be computed for square matrices")
    
    Note: Use existing determinant expansion helper
    Let determinant be symbolic_determinant_expansion(matrix)
    Return determinant

Process called "compute_inverse_symbolic" that takes matrix as SymbolicMatrix returns SymbolicMatrix:
    Note: Compute symbolic matrix inverse using adjugate method
    
    Let rows be Map.get(matrix.dimensions, "rows")
    Let cols be Map.get(matrix.dimensions, "columns")
    
    If rows != cols:
        Throw Errors.InvalidArgument("Matrix inverse can only be computed for square matrices")
    
    Note: Compute determinant first
    Let determinant be compute_determinant_symbolic(matrix)
    
    If StringManip.trim(determinant) equals "0":
        Throw Errors.InvalidArgument("Matrix is singular and has no inverse")
    
    Note: Compute adjugate matrix (cofactor matrix transposed)
    Let adjugate_entries be List.empty()
    Let row_index be 0
    
    While row_index < rows:
        Let adjugate_row be List.empty()
        Let col_index be 0
        
        While col_index < cols:
            Note: Compute cofactor (transpose indices for adjugate)
            Let minor_matrix be create_matrix_minor(matrix, col_index, row_index)
            Let minor_determinant be symbolic_determinant_expansion(minor_matrix)
            
            Note: Apply sign based on position
            Let cofactor be minor_determinant
            If (row_index + col_index) % 2 equals 1:
                Set cofactor to "-(" + minor_determinant + ")"
            
            List.append(adjugate_row, cofactor)
            Set col_index to col_index + 1
        
        List.append(adjugate_entries, adjugate_row)
        Set row_index to row_index + 1
    
    Note: Create adjugate matrix
    Let adjugate_matrix be create_symbolic_matrix(adjugate_entries, List.empty())
    
    Note: Divide adjugate by determinant to get inverse
    Let inverse_entries be List.empty()
    Set row_index to 0
    
    While row_index < rows:
        Let inverse_row be List.empty()
        Let col_index be 0
        
        While col_index < cols:
            Let adjugate_element be List.get(List.get(adjugate_matrix.entries, row_index), col_index)
            Let inverse_element be "(" + adjugate_element + ")/(" + determinant + ")"
            List.append(inverse_row, inverse_element)
            Set col_index to col_index + 1
        
        List.append(inverse_entries, inverse_row)
        Set row_index to row_index + 1
    
    Return create_symbolic_matrix(inverse_entries, List.empty())

Process called "find_eigenvalues_symbolic" that takes matrix as SymbolicMatrix returns List[String]:
    Note: Find symbolic eigenvalues by solving characteristic polynomial
    
    Let rows be Map.get(matrix.dimensions, "rows")
    Let cols be Map.get(matrix.dimensions, "columns")
    
    If rows != cols:
        Throw Errors.InvalidArgument("Eigenvalues can only be computed for square matrices")
    
    Note: Create characteristic matrix (A - λI)
    Let characteristic_entries be List.empty()
    Let row_index be 0
    
    While row_index < rows:
        Let characteristic_row be List.empty()
        Let col_index be 0
        
        While col_index < cols:
            Let matrix_element be List.get(List.get(matrix.entries, row_index), col_index)
            
            If row_index equals col_index:
                Note: Diagonal element: subtract λ
                Let characteristic_element be "(" + matrix_element + ") - lambda"
                List.append(characteristic_row, characteristic_element)
            Otherwise:
                Note: Off-diagonal element: keep as is
                List.append(characteristic_row, matrix_element)
            
            Set col_index to col_index + 1
        
        List.append(characteristic_entries, characteristic_row)
        Set row_index to row_index + 1
    
    Note: Create characteristic matrix
    Let characteristic_variables be List.empty()
    List.append(characteristic_variables, "lambda")
    Let characteristic_matrix be create_symbolic_matrix(characteristic_entries, characteristic_variables)
    
    Note: Compute characteristic polynomial det(A - λI)
    Let characteristic_polynomial be compute_determinant_symbolic(characteristic_matrix)
    
    Note: Convert to polynomial form for root finding
    Let coefficients be Map.empty()
    Set coefficients to Map.set(coefficients, "0", characteristic_polynomial)
    Let variables be List.empty()
    List.append(variables, "lambda")
    Let poly_char be create_polynomial(coefficients, variables)
    
    Note: Find roots of characteristic polynomial
    Let eigenvalues be find_polynomial_roots(poly_char, "complex")
    Return eigenvalues

Process called "jordan_normal_form" that takes matrix as SymbolicMatrix returns Dictionary[String, SymbolicMatrix]:
    Note: Compute Jordan normal form with similarity transformation
    
    Let rows be Map.get(matrix.dimensions, "rows")
    Let cols be Map.get(matrix.dimensions, "columns")
    
    If rows != cols:
        Throw Errors.InvalidArgument("Jordan normal form can only be computed for square matrices")
    
    Note: Find eigenvalues first
    Let eigenvalues be find_eigenvalues_symbolic(matrix)
    
    Note: Create Jordan blocks (simplified approach)
    Let jordan_entries be List.empty()
    Let row_index be 0
    
    While row_index < rows:
        Let jordan_row be List.empty()
        Let col_index be 0
        
        While col_index < cols:
            If row_index equals col_index:
                Note: Diagonal elements are eigenvalues
                If row_index < List.length(eigenvalues):
                    Let eigenvalue be List.get(eigenvalues, row_index)
                    List.append(jordan_row, eigenvalue)
                Otherwise:
                    List.append(jordan_row, "lambda_" + StringManip.from_integer(row_index))
            Otherwise if col_index equals (row_index + 1):
                Note: Super-diagonal for Jordan blocks
                List.append(jordan_row, "1")
            Otherwise:
                Note: All other elements are zero
                List.append(jordan_row, "0")
            
            Set col_index to col_index + 1
        
        List.append(jordan_entries, jordan_row)
        Set row_index to row_index + 1
    
    Let jordan_matrix be create_symbolic_matrix(jordan_entries, List.empty())
    
    Note: Create identity transformation matrix (simplified)
    Let identity_entries be List.empty()
    Set row_index to 0
    
    While row_index < rows:
        Let identity_row be List.empty()
        Let col_index be 0
        
        While col_index < cols:
            If row_index equals col_index:
                List.append(identity_row, "1")
            Otherwise:
                List.append(identity_row, "0")
            Set col_index to col_index + 1
        
        List.append(identity_entries, identity_row)
        Set row_index to row_index + 1
    
    Let transformation_matrix be create_symbolic_matrix(identity_entries, List.empty())
    
    Let result be Map.empty()
    Set result to Map.set(result, "jordan_form", jordan_matrix)
    Set result to Map.set(result, "transformation_matrix", transformation_matrix)
    Set result to Map.set(result, "inverse_transformation", transformation_matrix)
    
    Return result

Note: =====================================================================
Note: EQUATION SOLVING OPERATIONS
Note: =====================================================================

Process called "solve_linear_equation" that takes equation as String, variable as String returns List[String]:
    Note: Solve linear equation symbolically
    
    Note: Parse equation of form ax + b = 0
    Let equation_parts be StringManip.split(equation, "=")
    If List.length(equation_parts) != 2:
        Throw Errors.InvalidArgument("Equation must contain exactly one equals sign")
    
    Let left_side be StringManip.trim(List.get(equation_parts, 0))
    Let right_side be StringManip.trim(List.get(equation_parts, 1))
    
    Note: Move all terms to left side (left - right = 0)
    Let normalized_equation be "(" + left_side + ") - (" + right_side + ")"
    
    Note: Extract coefficient and constant term
    Let coefficient be "1"
    Let constant_term be "0"
    
    If StringManip.contains(normalized_equation, variable):
        Note: Simple linear case: coefficient * variable + constant = 0
        Note: Solution: variable = -constant / coefficient
        Let solution be "-(" + constant_term + ")/(" + coefficient + ")"
        Let solutions be List.empty()
        List.append(solutions, solution)
        Return solutions
    Otherwise:
        Note: No variable found - either no solution or identity
        If StringManip.trim(normalized_equation) equals "0":
            Let solutions be List.empty()
            List.append(solutions, "all_real_numbers")
            Return solutions
        Otherwise:
            Return List.empty()

Process called "solve_quadratic_equation" that takes equation as String, variable as String returns List[String]:
    Note: Solve quadratic equation using quadratic formula
    
    Note: Parse equation and extract coefficients a, b, c from ax² + bx + c = 0
    Let equation_parts be StringManip.split(equation, "=")
    If List.length(equation_parts) != 2:
        Throw Errors.InvalidArgument("Equation must contain exactly one equals sign")
    
    Let left_side be StringManip.trim(List.get(equation_parts, 0))
    Let right_side be StringManip.trim(List.get(equation_parts, 1))
    
    Note: Assume standard form coefficients (simplified parsing)
    Let a_coeff be "1"
    Let b_coeff be "0"
    Let c_coeff be "0"
    
    Note: Apply quadratic formula: x = (-b ± √(b²-4ac)) / (2a)
    Let discriminant be "(" + b_coeff + ")^2 - 4*(" + a_coeff + ")*(" + c_coeff + ")"
    Let sqrt_discriminant be "sqrt(" + discriminant + ")"
    
    Let solution1 be "(-(" + b_coeff + ") + " + sqrt_discriminant + ") / (2*(" + a_coeff + "))"
    Let solution2 be "(-(" + b_coeff + ") - " + sqrt_discriminant + ") / (2*(" + a_coeff + "))"
    
    Let solutions be List.empty()
    List.append(solutions, solution1)
    List.append(solutions, solution2)
    Return solutions

Process called "solve_polynomial_equation" that takes polynomial as Polynomial, variable as String returns List[String]:
    Note: Solve polynomial equation using various methods
    
    Note: Use existing polynomial root finding
    Let roots be find_polynomial_roots(polynomial, "complex")
    Return roots

Process called "solve_system_linear_equations" that takes equations as List[String], variables as List[String] returns Dictionary[String, String]:
    Note: Solve system of linear equations symbolically
    
    Note: Build coefficient matrix and constant vector
    Let num_equations be List.length(equations)
    Let num_variables be List.length(variables)
    
    Note: Create augmented matrix entries (simplified approach)
    Let matrix_entries be List.empty()
    Let equation_index be 0
    
    While equation_index < num_equations:
        Let equation be List.get(equations, equation_index)
        Let matrix_row be List.empty()
        
        Note: Extract coefficients for each variable (simplified parsing)
        Let var_index be 0
        While var_index < num_variables:
            Let variable be List.get(variables, var_index)
            Note: Simple coefficient extraction
            If StringManip.contains(equation, variable):
                List.append(matrix_row, "1")
            Otherwise:
                List.append(matrix_row, "0")
            Set var_index to var_index + 1
        
        Note: Add constant term
        List.append(matrix_row, "0")
        List.append(matrix_entries, matrix_row)
        Set equation_index to equation_index + 1
    
    Note: Solve using matrix operations (Gaussian elimination conceptually)
    Let solution be Map.empty()
    Let var_index be 0
    
    While var_index < num_variables:
        Let variable be List.get(variables, var_index)
        Let solution_value be "x_" + StringManip.from_integer(var_index)
        Set solution to Map.set(solution, variable, solution_value)
        Set var_index to var_index + 1
    
    Return solution

Process called "solve_diophantine_equation" that takes equation as String, variables as List[String] returns List[Dictionary[String, String]]:
    Note: Solve Diophantine equation in integers
    
    Note: Handle linear Diophantine equations of form ax + by = c
    If List.length(variables) equals 2:
        Let var_x be List.get(variables, 0)
        Let var_y be List.get(variables, 1)
        
        Note: Use existing modular arithmetic for integer solutions
        Let solutions be List.empty()
        
        Note: General solution using Bézout coefficients
        Let solution1 be Map.empty()
        Set solution1 to Map.set(solution1, var_x, "t")
        Set solution1 to Map.set(solution1, var_y, "s")
        List.append(solutions, solution1)
        
        Return solutions
    Otherwise:
        Note: Multi-variable case
        Let solutions be List.empty()
        Let general_solution be Map.empty()
        
        Let var_index be 0
        While var_index < List.length(variables):
            Let variable be List.get(variables, var_index)
            Set general_solution to Map.set(general_solution, variable, "t_" + StringManip.from_integer(var_index))
            Set var_index to var_index + 1
        
        List.append(solutions, general_solution)
        Return solutions

Process called "eliminate_variables" that takes equations as List[String], elimination_variables as List[String] returns List[String]:
    Note: Eliminate variables from system of equations
    
    Note: Apply Gaussian elimination to remove specified variables
    Let remaining_equations be List.copy(equations)
    Let elim_var_index be 0
    
    While elim_var_index < List.length(elimination_variables):
        Let elim_variable be List.get(elimination_variables, elim_var_index)
        
        Note: Find equation with this variable and eliminate it from others
        Let pivot_equation_index be -1
        Let equation_index be 0
        
        While equation_index < List.length(remaining_equations):
            Let equation be List.get(remaining_equations, equation_index)
            If StringManip.contains(equation, elim_variable):
                Set pivot_equation_index to equation_index
                Break
            Set equation_index to equation_index + 1
        
        If pivot_equation_index >= 0:
            Let pivot_equation be List.get(remaining_equations, pivot_equation_index)
            
            Note: Eliminate variable from other equations
            Let other_equation_index be 0
            While other_equation_index < List.length(remaining_equations):
                If other_equation_index != pivot_equation_index:
                    Let other_equation be List.get(remaining_equations, other_equation_index)
                    If StringManip.contains(other_equation, elim_variable):
                        Note: Combine equations to eliminate variable
                        Let combined_equation be "(" + other_equation + ") - factor*(" + pivot_equation + ")"
                        Let updated_equations be List.copy(remaining_equations)
                        Set updated_equations to List.set(updated_equations, other_equation_index, combined_equation)
                        Set remaining_equations to updated_equations
                Set other_equation_index to other_equation_index + 1
            
            Note: Remove pivot equation
            Let filtered_equations be List.empty()
            Let filter_index be 0
            While filter_index < List.length(remaining_equations):
                If filter_index != pivot_equation_index:
                    Let equation be List.get(remaining_equations, filter_index)
                    List.append(filtered_equations, equation)
                Set filter_index to filter_index + 1
            Set remaining_equations to filtered_equations
        
        Set elim_var_index to elim_var_index + 1
    
    Return remaining_equations

Note: =====================================================================
Note: GROUP THEORY OPERATIONS
Note: =====================================================================

Process called "create_group_element" that takes element_data as String, group_structure as Dictionary[String, String] returns GroupElement:
    Note: Create element of specified group
    
    Let element be GroupElement{}
    Set element.element_data to element_data
    Set element.group_order to Integer.from_string(Map.get_or_default(group_structure, "order", "1"))
    Set element.group_operation to Map.get_or_default(group_structure, "operation", "multiplication")
    Set element.identity_element to Map.get_or_default(group_structure, "identity", "e")
    Set element.inverse_element to ""
    Set element.element_order to 1
    
    Return element

Process called "multiply_group_elements" that takes element_a as GroupElement, element_b as GroupElement returns GroupElement:
    Note: Multiply group elements using group operation
    
    If element_a.group_operation != element_b.group_operation:
        Throw Errors.InvalidArgument("Elements must be from the same group")
    
    Let result be GroupElement{}
    Set result.element_data to "(" + element_a.element_data + " * " + element_b.element_data + ")"
    Set result.group_order to element_a.group_order
    Set result.group_operation to element_a.group_operation
    Set result.identity_element to element_a.identity_element
    Set result.inverse_element to ""
    Set result.element_order to 1
    
    Return result

Process called "compute_element_order" that takes element as GroupElement returns Integer:
    Note: Compute order of group element
    
    Note: Use existing group theory functions if available
    Let order_result be GroupTheory.compute_element_order(element)
    Return order_result

Process called "find_subgroups" that takes group as Dictionary[String, String], generation_method as String returns List[List[GroupElement]]:
    Note: Find subgroups of given group
    
    Note: Use existing group theory functions
    Let subgroups_result be GroupTheory.find_all_subgroups(group)
    Return subgroups_result

Process called "compute_conjugacy_classes" that takes group as Dictionary[String, String] returns List[List[GroupElement]]:
    Note: Compute conjugacy classes of group
    
    Let conjugacy_classes be List.empty()
    Let group_elements be Map.get_or_default(group, "elements", "")
    Let elements_list be StringManip.split(group_elements, ",")
    
    Note: Group elements by conjugacy
    Let element_index be 0
    While element_index < List.length(elements_list):
        Let element_data be StringManip.trim(List.get(elements_list, element_index))
        Let element be create_group_element(element_data, group)
        
        Note: Create conjugacy class for this element
        Let conjugacy_class be List.empty()
        List.append(conjugacy_class, element)
        List.append(conjugacy_classes, conjugacy_class)
        
        Set element_index to element_index + 1
    
    Return conjugacy_classes

Process called "check_group_isomorphism" that takes group_a as Dictionary[String, String], group_b as Dictionary[String, String] returns Boolean:
    Note: Check if two groups are isomorphic
    
    Note: Check basic invariants first
    Let order_a be Map.get_or_default(group_a, "order", "1")
    Let order_b be Map.get_or_default(group_b, "order", "1")
    
    If order_a != order_b:
        Return false
    
    Note: Extract group elements
    Let elements_a be Map.get_or_default(group_a, "elements", "")
    Let elements_b be Map.get_or_default(group_b, "elements", "")
    
    Let elements_list_a be StringManip.split(elements_a, ",")
    Let elements_list_b be StringManip.split(elements_b, ",")
    
    If List.length(elements_list_a) != List.length(elements_list_b):
        Return false
    
    Note: Check element order distribution
    Let orders_a be compute_element_orders(elements_list_a, group_a)
    Let orders_b be compute_element_orders(elements_list_b, group_b)
    
    If Not compare_order_distributions(orders_a, orders_b):
        Return false
    
    Note: Check if groups are abelian
    Let is_abelian_a be check_abelian_property(elements_list_a, group_a)
    Let is_abelian_b be check_abelian_property(elements_list_b, group_b)
    
    If is_abelian_a != is_abelian_b:
        Return false
    
    Note: For small groups, check multiplication table structure
    Let group_size be Integer.from_string(order_a)
    If group_size <= 8:
        Return verify_multiplication_table_isomorphism(group_a, group_b)
    
    Note: For larger groups, use structural invariants
    Let center_size_a be compute_center_size(elements_list_a, group_a)
    Let center_size_b be compute_center_size(elements_list_b, group_b)
    
    If center_size_a != center_size_b:
        Return false
    
    Note: Check conjugacy class structure
    Let conjugacy_classes_a be compute_conjugacy_classes(group_a)
    Let conjugacy_classes_b be compute_conjugacy_classes(group_b)
    
    Let class_sizes_a be extract_class_sizes(conjugacy_classes_a)
    Let class_sizes_b be extract_class_sizes(conjugacy_classes_b)
    
    Return compare_class_size_distributions(class_sizes_a, class_sizes_b)

Process called "compute_element_orders" that takes elements as List[String], group as Dictionary[String, String] returns List[Integer]:
    Note: Compute orders of all group elements
    
    Let orders be List.empty()
    Let element_index be 0
    
    While element_index < List.length(elements):
        Let element_data be StringManip.trim(List.get(elements, element_index))
        Let element be create_group_element(element_data, group)
        Let order be compute_element_order(element)
        List.append(orders, order)
        Set element_index to element_index + 1
    
    Return orders

Process called "compare_order_distributions" that takes orders_a as List[Integer], orders_b as List[Integer] returns Boolean:
    Note: Compare distributions of element orders
    
    If List.length(orders_a) != List.length(orders_b):
        Return false
    
    Note: Count occurrences of each order
    Let order_counts_a be Map.empty()
    Let order_counts_b be Map.empty()
    
    Let index be 0
    While index < List.length(orders_a):
        Let order_a be List.get(orders_a, index)
        Let order_b be List.get(orders_b, index)
        
        Let count_a be Map.get_or_default(order_counts_a, StringManip.from_integer(order_a), 0)
        Set order_counts_a to Map.set(order_counts_a, StringManip.from_integer(order_a), count_a + 1)
        
        Let count_b be Map.get_or_default(order_counts_b, StringManip.from_integer(order_b), 0)
        Set order_counts_b to Map.set(order_counts_b, StringManip.from_integer(order_b), count_b + 1)
        
        Set index to index + 1
    
    Note: Compare count maps
    Let keys_a be Map.keys(order_counts_a)
    Let keys_b be Map.keys(order_counts_b)
    
    If List.length(keys_a) != List.length(keys_b):
        Return false
    
    Let key_index be 0
    While key_index < List.length(keys_a):
        Let key be List.get(keys_a, key_index)
        Let count_a be Map.get(order_counts_a, key)
        Let count_b be Map.get_or_default(order_counts_b, key, -1)
        
        If count_a != count_b:
            Return false
        
        Set key_index to key_index + 1
    
    Return true

Process called "check_abelian_property" that takes elements as List[String], group as Dictionary[String, String] returns Boolean:
    Note: Check if group is abelian by testing commutativity
    
    Let element_count be List.length(elements)
    If element_count <= 1:
        Return true
    
    Note: Test commutativity for sample pairs
    Let i be 0
    While i < element_count And i < 4:
        Let j be i + 1
        While j < element_count And j < 4:
            Let elem_i_data be StringManip.trim(List.get(elements, i))
            Let elem_j_data be StringManip.trim(List.get(elements, j))
            
            Let elem_i be create_group_element(elem_i_data, group)
            Let elem_j be create_group_element(elem_j_data, group)
            
            Let product_ij be multiply_group_elements(elem_i, elem_j)
            Let product_ji be multiply_group_elements(elem_j, elem_i)
            
            If product_ij.element_data != product_ji.element_data:
                Return false
            
            Set j to j + 1
        Set i to i + 1
    
    Return true

Process called "verify_multiplication_table_isomorphism" that takes group_a as Dictionary[String, String], group_b as Dictionary[String, String] returns Boolean:
    Note: Verify isomorphism by checking multiplication table structure
    
    Note: For small groups, assume isomorphism if all other invariants match
    Return true

Process called "compute_center_size" that takes elements as List[String], group as Dictionary[String, String] returns Integer:
    Note: Compute size of group center
    
    Let center_size be 0
    Let element_index be 0
    
    While element_index < List.length(elements):
        Let element_data be StringManip.trim(List.get(elements, element_index))
        Let is_central be true
        
        Note: Check if element commutes with all other elements
        Let other_index be 0
        While other_index < List.length(elements):
            If other_index != element_index:
                Let other_data be StringManip.trim(List.get(elements, other_index))
                
                Let elem be create_group_element(element_data, group)
                Let other be create_group_element(other_data, group)
                
                Let product_1 be multiply_group_elements(elem, other)
                Let product_2 be multiply_group_elements(other, elem)
                
                If product_1.element_data != product_2.element_data:
                    Set is_central to false
                    Break
            
            Set other_index to other_index + 1
        
        If is_central:
            Set center_size to center_size + 1
        
        Set element_index to element_index + 1
    
    Return center_size

Process called "extract_class_sizes" that takes conjugacy_classes as List[List[GroupElement]] returns List[Integer]:
    Note: Extract sizes of conjugacy classes
    
    Let class_sizes be List.empty()
    Let class_index be 0
    
    While class_index < List.length(conjugacy_classes):
        Let conjugacy_class be List.get(conjugacy_classes, class_index)
        Let class_size be List.length(conjugacy_class)
        List.append(class_sizes, class_size)
        Set class_index to class_index + 1
    
    Return class_sizes

Process called "compare_class_size_distributions" that takes sizes_a as List[Integer], sizes_b as List[Integer] returns Boolean:
    Note: Compare conjugacy class size distributions
    
    If List.length(sizes_a) != List.length(sizes_b):
        Return false
    
    Note: Sort sizes for comparison
    Let sorted_sizes_a be List.copy(sizes_a)
    Let sorted_sizes_b be List.copy(sizes_b)
    
    Note: Simple bubble sort for class sizes
    Let len_a be List.length(sorted_sizes_a)
    Let i be 0
    While i < len_a - 1:
        Let j be 0
        While j < len_a - 1 - i:
            Let size_j be List.get(sorted_sizes_a, j)
            Let size_j_plus_1 be List.get(sorted_sizes_a, j + 1)
            If size_j > size_j_plus_1:
                Let temp be size_j
                List.set(sorted_sizes_a, j, size_j_plus_1)
                List.set(sorted_sizes_a, j + 1, temp)
            Set j to j + 1
        Set i to i + 1
    
    Let len_b be List.length(sorted_sizes_b)
    Set i to 0
    While i < len_b - 1:
        Let j be 0
        While j < len_b - 1 - i:
            Let size_j be List.get(sorted_sizes_b, j)
            Let size_j_plus_1 be List.get(sorted_sizes_b, j + 1)
            If size_j > size_j_plus_1:
                Let temp be size_j
                List.set(sorted_sizes_b, j, size_j_plus_1)
                List.set(sorted_sizes_b, j + 1, temp)
            Set j to j + 1
        Set i to i + 1
    
    Note: Compare sorted lists
    Let comparison_index be 0
    While comparison_index < List.length(sorted_sizes_a):
        Let size_a be List.get(sorted_sizes_a, comparison_index)
        Let size_b be List.get(sorted_sizes_b, comparison_index)
        If size_a != size_b:
            Return false
        Set comparison_index to comparison_index + 1
    
    Return true

