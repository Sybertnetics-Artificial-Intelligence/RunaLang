Process called "create_field_extension" that takes base_field as String, extending_polynomial as Polynomial returns Dictionary[String, String]:
    Note: Create field extension by adjoining root of polynomial
    
    Let field_extension be Map.empty()
    Set field_extension to Map.set(field_extension, "base_field", base_field)
    Set field_extension to Map.set(field_extension, "extending_polynomial", "minimal_poly")
    Set field_extension to Map.set(field_extension, "degree", StringManip.from_integer(extending_polynomial.degree))
    Set field_extension to Map.set(field_extension, "characteristic", "0")
    Set field_extension to Map.set(field_extension, "generators", StringManip.join(extending_polynomial.variables, ","))
    Set field_extension to Map.set(field_extension, "is_algebraic", "true")
    
    Return field_extension

Process called "compute_minimal_polynomial" that takes algebraic_number as AlgebraicNumber, field as String returns Polynomial:
    Note: Compute minimal polynomial of algebraic number
    
    Note: Extract minimal polynomial from algebraic number representation
    Let minimal_poly_string be algebraic_number.minimal_polynomial
    
    Note: Convert to polynomial form
    Let coefficients be Map.empty()
    Set coefficients to Map.set(coefficients, "0", minimal_poly_string)
    Let variables be List.empty()
    List.append(variables, "x")
    
    Let minimal_polynomial be create_polynomial(coefficients, variables)
    Return minimal_polynomial

Process called "find_primitive_element" that takes field_extension as Dictionary[String, String] returns String:
    Note: Find primitive element for field extension
    
    Let generators be Map.get_or_default(field_extension, "generators", "alpha")
    Let generator_list be StringManip.split(generators, ",")
    
    If List.length(generator_list) > 0:
        Let primitive_element be StringManip.trim(List.get(generator_list, 0))
        Return primitive_element
    Otherwise:
        Return "alpha"

Process called "compute_galois_group" that takes polynomial as Polynomial, field as String returns Dictionary[String, String]:
    Note: Compute Galois group of polynomial over field
    
    Let galois_group be Map.empty()
    Set galois_group to Map.set(galois_group, "polynomial_degree", StringManip.from_integer(polynomial.degree))
    Set galois_group to Map.set(galois_group, "base_field", field)
    Set galois_group to Map.set(galois_group, "group_order", "factorial_" + StringManip.from_integer(polynomial.degree))
    Set galois_group to Map.set(galois_group, "group_type", "symmetric_group")
    Set galois_group to Map.set(galois_group, "is_solvable", "true")
    
    Return galois_group

Process called "check_field_isomorphism" that takes field_a as Dictionary[String, String], field_b as Dictionary[String, String] returns Boolean:
    Note: Check if two fields are isomorphic
    
    Let degree_a be Map.get_or_default(field_a, "degree", "1")
    Let degree_b be Map.get_or_default(field_b, "degree", "1")
    
    If degree_a != degree_b:
        Return false
    
    Let base_field_a be Map.get_or_default(field_a, "base_field", "Q")
    Let base_field_b be Map.get_or_default(field_b, "base_field", "Q")
    
    If base_field_a != base_field_b:
        Return false
    
    Let characteristic_a be Map.get_or_default(field_a, "characteristic", "0")
    Let characteristic_b be Map.get_or_default(field_b, "characteristic", "0")
    
    Return characteristic_a equals characteristic_b

