Note:
math/geometry/euclidean.runa
2D/3D Euclidean Geometry Operations

This module provides comprehensive Euclidean geometry operations including 2D and 3D
points, vectors, lines, planes, distance calculations, angle measurements, geometric
transformations, intersections, and fundamental geometric primitives.

Key mathematical foundations:
- Euclidean distance: d = √[(x₂-x₁)² + (y₂-y₁)² + (z₂-z₁)²]
- Dot product: a·b = |a||b|cos(θ) = aₓbₓ + aᵧbᵧ + a_zb_z
- Cross product: a×b = (aᵧb_z - a_zbᵧ, a_zbₓ - aₓb_z, aₓbᵧ - aᵧbₓ)
- Line equation: ax + by + c = 0 (2D), parametric: P = P₀ + tv
- Plane equation: ax + by + cz + d = 0, normal form: n·(P-P₀) = 0
- Rotation matrices: R(θ) preserving distances and angles
- Geometric transformations: translation, rotation, scaling, reflection
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: POINT AND VECTOR DATA STRUCTURES
Note: =====================================================================

Type called "Point2D":
    x as Float
    y as Float
    coordinate_system as String
    precision as Integer

Type called "Point3D":
    x as Float
    y as Float
    z as Float
    coordinate_system as String
    precision as Integer

Type called "Vector2D":
    x as Float
    y as Float
    magnitude_cache as Optional[Float]
    unit_vector_cache as Optional[Vector2D]

Type called "Vector3D":
    x as Float
    y as Float
    z as Float
    magnitude_cache as Optional[Float]
    unit_vector_cache as Optional[Vector3D]

Type called "Line2D":
    point as Point2D
    direction as Vector2D
    slope as Optional[Float]
    y_intercept as Optional[Float]
    equation_form as String

Type called "Line3D":
    point as Point3D
    direction as Vector3D
    parametric_form as Dictionary[String, String]

Type called "Plane3D":
    point as Point3D
    normal as Vector3D
    equation_coefficients as List[Float]
    distance_from_origin as Float

Note: =====================================================================
Note: GEOMETRIC PRIMITIVE STRUCTURES
Note: =====================================================================

Type called "Circle":
    center as Point2D
    radius as Float
    circumference_cache as Optional[Float]
    area_cache as Optional[Float]

Type called "Sphere":
    center as Point3D
    radius as Float
    surface_area_cache as Optional[Float]
    volume_cache as Optional[Float]

Type called "Triangle2D":
    vertex_a as Point2D
    vertex_b as Point2D
    vertex_c as Point2D
    side_lengths as Optional[List[Float]]
    angles as Optional[List[Float]]
    area_cache as Optional[Float]

Type called "Triangle3D":
    vertex_a as Point3D
    vertex_b as Point3D
    vertex_c as Point3D
    side_lengths as Optional[List[Float]]
    normal_vector as Optional[Vector3D]
    area_cache as Optional[Float]

Type called "Rectangle":
    corner as Point2D
    width as Float
    height as Float
    orientation_angle as Float
    area_cache as Optional[Float]

Type called "Polygon2D":
    vertices as List[Point2D]
    is_convex as Boolean
    is_simple as Boolean
    area_cache as Optional[Float]
    perimeter_cache as Optional[Float]

Note: =====================================================================
Note: TRANSFORMATION STRUCTURES
Note: =====================================================================

Type called "Transform2D":
    translation as Vector2D
    rotation_angle as Float
    scale_factors as Tuple[Float, Float]
    transformation_matrix as Matrix[Float]

Type called "Transform3D":
    translation as Vector3D
    rotation_matrix as Matrix[Float]
    scale_factors as Tuple[Float, Float, Float]
    transformation_matrix as Matrix[Float]

Type called "GeometryConfig":
    coordinate_system as String
    angular_units as String
    precision_tolerance as Float
    default_precision as Integer

Note: =====================================================================
Note: POINT AND VECTOR OPERATIONS
Note: =====================================================================

Process called "create_point_2d" that takes x as Float, y as Float returns Point2D:
    Note: Create a 2D point with specified coordinates
    
    Let point be Dictionary.create()
    Dictionary.set(point, "x", x)
    Dictionary.set(point, "y", y)
    Dictionary.set(point, "coordinate_system", "cartesian")
    Dictionary.set(point, "precision", 15)
    
    Return point

Process called "create_point_3d" that takes x as Float, y as Float, z as Float returns Point3D:
    Note: Create a 3D point with specified coordinates
    
    Let point be Dictionary.create()
    Dictionary.set(point, "x", x)
    Dictionary.set(point, "y", y)
    Dictionary.set(point, "z", z)
    Dictionary.set(point, "coordinate_system", "cartesian")
    Dictionary.set(point, "precision", 15)
    
    Return point

Process called "calculate_distance_2d" that takes point_a as Point2D, point_b as Point2D returns Float:
    Note: Calculate Euclidean distance between two 2D points using d = √[(x₂-x₁)² + (y₂-y₁)²]
    
    Let x1 be Dictionary.get(point_a, "x")
    Let y1 be Dictionary.get(point_a, "y")
    Let x2 be Dictionary.get(point_b, "x")
    Let y2 be Dictionary.get(point_b, "y")
    
    Let dx be Mathematics.subtract(x2, x1)
    Let dy be Mathematics.subtract(y2, y1)
    
    Let distance_squared be Mathematics.add(Mathematics.multiply(dx, dx), Mathematics.multiply(dy, dy))
    
    Return Mathematics.sqrt(distance_squared)

Process called "calculate_distance_3d" that takes point_a as Point3D, point_b as Point3D returns Float:
    Note: Calculate Euclidean distance between two 3D points
    
    Let x1 be Dictionary.get(point_a, "x")
    Let y1 be Dictionary.get(point_a, "y")
    Let z1 be Dictionary.get(point_a, "z")
    Let x2 be Dictionary.get(point_b, "x")
    Let y2 be Dictionary.get(point_b, "y")
    Let z2 be Dictionary.get(point_b, "z")
    
    Let dx be Mathematics.subtract(x2, x1)
    Let dy be Mathematics.subtract(y2, y1)
    Let dz be Mathematics.subtract(z2, z1)
    
    Let distance_squared be Mathematics.add(Mathematics.add(Mathematics.multiply(dx, dx), Mathematics.multiply(dy, dy)), Mathematics.multiply(dz, dz))
    
    Return Mathematics.sqrt(distance_squared)

Process called "create_vector_2d" that takes x as Float, y as Float returns Vector2D:
    Note: Create a 2D vector with specified components
    
    Let vector be Dictionary.create()
    Dictionary.set(vector, "x", x)
    Dictionary.set(vector, "y", y)
    Dictionary.set(vector, "magnitude_cache", Optional.none())
    Dictionary.set(vector, "unit_vector_cache", Optional.none())
    
    Return vector

Process called "create_vector_3d" that takes x as Float, y as Float, z as Float returns Vector3D:
    Note: Create a 3D vector with specified components
    
    Let vector be Dictionary.create()
    Dictionary.set(vector, "x", x)
    Dictionary.set(vector, "y", y)
    Dictionary.set(vector, "z", z)
    Dictionary.set(vector, "magnitude_cache", Optional.none())
    Dictionary.set(vector, "unit_vector_cache", Optional.none())
    
    Return vector

Process called "calculate_vector_magnitude_2d" that takes vector as Vector2D returns Float:
    Note: Calculate magnitude of 2D vector using |v| = √(x² + y²)
    
    Let x be Dictionary.get(vector, "x")
    Let y be Dictionary.get(vector, "y")
    
    Let x_squared be Mathematics.multiply(x, x)
    Let y_squared be Mathematics.multiply(y, y)
    Let sum_squares be Mathematics.add(x_squared, y_squared)
    
    Return Mathematics.sqrt(sum_squares)

Process called "calculate_vector_magnitude_3d" that takes vector as Vector3D returns Float:
    Note: Calculate magnitude of 3D vector using |v| = √(x² + y² + z²)
    
    Let x be Dictionary.get(vector, "x")
    Let y be Dictionary.get(vector, "y")
    Let z be Dictionary.get(vector, "z")
    
    Let x_squared be Mathematics.multiply(x, x)
    Let y_squared be Mathematics.multiply(y, y)
    Let z_squared be Mathematics.multiply(z, z)
    Let sum_squares be Mathematics.add(Mathematics.add(x_squared, y_squared), z_squared)
    
    Return Mathematics.sqrt(sum_squares)

Process called "normalize_vector_2d" that takes vector as Vector2D returns Vector2D:
    Note: Normalize 2D vector to unit length: û = v/|v|
    
    Let magnitude be calculate_vector_magnitude_2d(vector)
    
    Note: Check for zero vector
    Let tolerance be 0.000000000000001
    If Mathematics.abs(magnitude) < tolerance:
        Throw Errors.InvalidArgument with "Cannot normalize zero vector"
    
    Let x be Dictionary.get(vector, "x")
    Let y be Dictionary.get(vector, "y")
    
    Let normalized_x be Mathematics.divide(x, magnitude)
    Let normalized_y be Mathematics.divide(y, magnitude)
    
    Return create_vector_2d(normalized_x, normalized_y)

Process called "normalize_vector_3d" that takes vector as Vector3D returns Vector3D:
    Note: Normalize 3D vector to unit length
    
    Let magnitude be calculate_vector_magnitude_3d(vector)
    
    Note: Check for zero vector
    Let tolerance be 0.000000000000001
    If Mathematics.abs(magnitude) < tolerance:
        Throw Errors.InvalidArgument with "Cannot normalize zero vector"
    
    Let x be Dictionary.get(vector, "x")
    Let y be Dictionary.get(vector, "y")
    Let z be Dictionary.get(vector, "z")
    
    Let normalized_x be Mathematics.divide(x, magnitude)
    Let normalized_y be Mathematics.divide(y, magnitude)
    Let normalized_z be Mathematics.divide(z, magnitude)
    
    Return create_vector_3d(normalized_x, normalized_y, normalized_z)

Note: =====================================================================
Note: VECTOR ARITHMETIC OPERATIONS
Note: =====================================================================

Process called "add_vectors_2d" that takes vector_a as Vector2D, vector_b as Vector2D returns Vector2D:
    Note: Add two 2D vectors component-wise: (x₁+x₂, y₁+y₂)
    
    Let x1 be Dictionary.get(vector_a, "x")
    Let y1 be Dictionary.get(vector_a, "y")
    Let x2 be Dictionary.get(vector_b, "x")
    Let y2 be Dictionary.get(vector_b, "y")
    
    Let result_x be Mathematics.add(x1, x2)
    Let result_y be Mathematics.add(y1, y2)
    
    Return create_vector_2d(result_x, result_y)

Process called "add_vectors_3d" that takes vector_a as Vector3D, vector_b as Vector3D returns Vector3D:
    Note: Add two 3D vectors component-wise
    
    Let x1 be Dictionary.get(vector_a, "x")
    Let y1 be Dictionary.get(vector_a, "y")
    Let z1 be Dictionary.get(vector_a, "z")
    Let x2 be Dictionary.get(vector_b, "x")
    Let y2 be Dictionary.get(vector_b, "y")
    Let z2 be Dictionary.get(vector_b, "z")
    
    Let result_x be Mathematics.add(x1, x2)
    Let result_y be Mathematics.add(y1, y2)
    Let result_z be Mathematics.add(z1, z2)
    
    Return create_vector_3d(result_x, result_y, result_z)

Process called "subtract_vectors_2d" that takes vector_a as Vector2D, vector_b as Vector2D returns Vector2D:
    Note: Subtract two 2D vectors component-wise: (x₁-x₂, y₁-y₂)
    
    Let x1 be Dictionary.get(vector_a, "x")
    Let y1 be Dictionary.get(vector_a, "y")
    Let x2 be Dictionary.get(vector_b, "x")
    Let y2 be Dictionary.get(vector_b, "y")
    
    Let result_x be Mathematics.subtract(x1, x2)
    Let result_y be Mathematics.subtract(y1, y2)
    
    Return create_vector_2d(result_x, result_y)

Process called "subtract_vectors_3d" that takes vector_a as Vector3D, vector_b as Vector3D returns Vector3D:
    Note: Subtract two 3D vectors component-wise
    
    Let x1 be Dictionary.get(vector_a, "x")
    Let y1 be Dictionary.get(vector_a, "y")
    Let z1 be Dictionary.get(vector_a, "z")
    Let x2 be Dictionary.get(vector_b, "x")
    Let y2 be Dictionary.get(vector_b, "y")
    Let z2 be Dictionary.get(vector_b, "z")
    
    Let result_x be Mathematics.subtract(x1, x2)
    Let result_y be Mathematics.subtract(y1, y2)
    Let result_z be Mathematics.subtract(z1, z2)
    
    Return create_vector_3d(result_x, result_y, result_z)

Process called "scale_vector_2d" that takes vector as Vector2D, scalar as Float returns Vector2D:
    Note: Scale 2D vector by scalar: (sx, sy)
    
    Let x be Dictionary.get(vector, "x")
    Let y be Dictionary.get(vector, "y")
    
    Let scaled_x be Mathematics.multiply(x, scalar)
    Let scaled_y be Mathematics.multiply(y, scalar)
    
    Return create_vector_2d(scaled_x, scaled_y)

Process called "scale_vector_3d" that takes vector as Vector3D, scalar as Float returns Vector3D:
    Note: Scale 3D vector by scalar
    
    Let x be Dictionary.get(vector, "x")
    Let y be Dictionary.get(vector, "y")
    Let z be Dictionary.get(vector, "z")
    
    Let scaled_x be Mathematics.multiply(x, scalar)
    Let scaled_y be Mathematics.multiply(y, scalar)
    Let scaled_z be Mathematics.multiply(z, scalar)
    
    Return create_vector_3d(scaled_x, scaled_y, scaled_z)

Process called "dot_product_2d" that takes vector_a as Vector2D, vector_b as Vector2D returns Float:
    Note: Calculate dot product of 2D vectors: a·b = x₁x₂ + y₁y₂
    
    Let x1 be Dictionary.get(vector_a, "x")
    Let y1 be Dictionary.get(vector_a, "y")
    Let x2 be Dictionary.get(vector_b, "x")
    Let y2 be Dictionary.get(vector_b, "y")
    
    Let dot_x be Mathematics.multiply(x1, x2)
    Let dot_y be Mathematics.multiply(y1, y2)
    
    Return Mathematics.add(dot_x, dot_y)

Process called "dot_product_3d" that takes vector_a as Vector3D, vector_b as Vector3D returns Float:
    Note: Calculate dot product of 3D vectors: a·b = x₁x₂ + y₁y₂ + z₁z₂
    
    Let x1 be Dictionary.get(vector_a, "x")
    Let y1 be Dictionary.get(vector_a, "y")
    Let z1 be Dictionary.get(vector_a, "z")
    Let x2 be Dictionary.get(vector_b, "x")
    Let y2 be Dictionary.get(vector_b, "y")
    Let z2 be Dictionary.get(vector_b, "z")
    
    Let dot_x be Mathematics.multiply(x1, x2)
    Let dot_y be Mathematics.multiply(y1, y2)
    Let dot_z be Mathematics.multiply(z1, z2)
    
    Return Mathematics.add(Mathematics.add(dot_x, dot_y), dot_z)

Process called "cross_product_3d" that takes vector_a as Vector3D, vector_b as Vector3D returns Vector3D:
    Note: Calculate cross product of 3D vectors: a×b = (aᵧbz-azbᵧ, azbx-axbz, axbᵧ-aᵧbx)
    
    Let ax be Dictionary.get(vector_a, "x")
    Let ay be Dictionary.get(vector_a, "y")
    Let az be Dictionary.get(vector_a, "z")
    Let bx be Dictionary.get(vector_b, "x")
    Let by be Dictionary.get(vector_b, "y")
    Let bz be Dictionary.get(vector_b, "z")
    
    Note: Calculate cross product components
    Let cx be Mathematics.subtract(Mathematics.multiply(ay, bz), Mathematics.multiply(az, by))
    Let cy be Mathematics.subtract(Mathematics.multiply(az, bx), Mathematics.multiply(ax, bz))
    Let cz be Mathematics.subtract(Mathematics.multiply(ax, by), Mathematics.multiply(ay, bx))
    
    Let cross_product be Dictionary.create()
    Dictionary.set(cross_product, "x", cx)
    Dictionary.set(cross_product, "y", cy)
    Dictionary.set(cross_product, "z", cz)
    Dictionary.set(cross_product, "coordinate_system", "cartesian")
    Dictionary.set(cross_product, "precision", 15)
    
    Return cross_product

Note: =====================================================================
Note: ANGLE AND ORIENTATION OPERATIONS
Note: =====================================================================

Process called "calculate_angle_between_vectors_2d" that takes vector_a as Vector2D, vector_b as Vector2D returns Float:
    Note: Calculate angle between 2D vectors using cos(θ) = (a·b)/(|a||b|)
    
    Let magnitude_a be calculate_vector_magnitude_2d(vector_a)
    Let magnitude_b be calculate_vector_magnitude_2d(vector_b)
    
    Note: Check for zero vectors
    Let tolerance be 0.000000000000001
    If Mathematics.abs(magnitude_a) < tolerance or Mathematics.abs(magnitude_b) < tolerance:
        Throw Errors.InvalidArgument with "Cannot calculate angle with zero vector"
    
    Let dot_product be dot_product_2d(vector_a, vector_b)
    Let magnitude_product be Mathematics.multiply(magnitude_a, magnitude_b)
    Let cos_theta be Mathematics.divide(dot_product, magnitude_product)
    
    Note: Clamp to [-1, 1] to handle floating point errors
    If cos_theta > 1.0:
        Set cos_theta to 1.0
    Otherwise if cos_theta < -1.0:
        Set cos_theta to -1.0
    
    Return Mathematics.acos(cos_theta)

Process called "calculate_angle_between_vectors_3d" that takes vector_a as Vector3D, vector_b as Vector3D returns Float:
    Note: Calculate angle between 3D vectors
    
    Let magnitude_a be calculate_vector_magnitude_3d(vector_a)
    Let magnitude_b be calculate_vector_magnitude_3d(vector_b)
    
    Note: Check for zero vectors
    Let tolerance be 0.000000000000001
    If Mathematics.abs(magnitude_a) < tolerance or Mathematics.abs(magnitude_b) < tolerance:
        Throw Errors.InvalidArgument with "Cannot calculate angle with zero vector"
    
    Let dot_product be dot_product_3d(vector_a, vector_b)
    Let magnitude_product be Mathematics.multiply(magnitude_a, magnitude_b)
    Let cos_theta be Mathematics.divide(dot_product, magnitude_product)
    
    Note: Clamp to [-1, 1] to handle floating point errors
    If cos_theta > 1.0:
        Set cos_theta to 1.0
    Otherwise if cos_theta < -1.0:
        Set cos_theta to -1.0
    
    Return Mathematics.acos(cos_theta)

Process called "rotate_vector_2d" that takes vector as Vector2D, angle as Float returns Vector2D:
    Note: Rotate 2D vector by angle using rotation matrix
    
    Let x be Dictionary.get(vector, "x")
    Let y be Dictionary.get(vector, "y")
    
    Let cos_angle be Mathematics.cos(angle)
    Let sin_angle be Mathematics.sin(angle)
    
    Note: Apply rotation matrix: [cos -sin; sin cos] * [x; y]
    Let rotated_x be Mathematics.subtract(Mathematics.multiply(x, cos_angle), Mathematics.multiply(y, sin_angle))
    Let rotated_y be Mathematics.add(Mathematics.multiply(x, sin_angle), Mathematics.multiply(y, cos_angle))
    
    Return create_vector_2d(rotated_x, rotated_y)

Process called "rotate_vector_3d_axis" that takes vector as Vector3D, axis as Vector3D, angle as Float returns Vector3D:
    Note: Rotate 3D vector around arbitrary axis using Rodrigues' rotation formula
    
    Note: Normalize the rotation axis
    Let normalized_axis be normalize_vector_3d(axis)
    
    Let cos_angle be Mathematics.cos(angle)
    Let sin_angle be Mathematics.sin(angle)
    Let one_minus_cos be Mathematics.subtract(1.0, cos_angle)
    
    Note: Get normalized axis components
    Let ux be Dictionary.get(normalized_axis, "x")
    Let uy be Dictionary.get(normalized_axis, "y")
    Let uz be Dictionary.get(normalized_axis, "z")
    
    Note: Get vector components
    Let vx be Dictionary.get(vector, "x")
    Let vy be Dictionary.get(vector, "y")
    Let vz be Dictionary.get(vector, "z")
    
    Note: Calculate cross product (axis × vector)
    Let cross_x be Mathematics.subtract(Mathematics.multiply(uy, vz), Mathematics.multiply(uz, vy))
    Let cross_y be Mathematics.subtract(Mathematics.multiply(uz, vx), Mathematics.multiply(ux, vz))
    Let cross_z be Mathematics.subtract(Mathematics.multiply(ux, vy), Mathematics.multiply(uy, vx))
    
    Note: Calculate dot product (axis · vector)
    Let dot_product be Mathematics.add(Mathematics.add(Mathematics.multiply(ux, vx), Mathematics.multiply(uy, vy)), Mathematics.multiply(uz, vz))
    
    Note: Apply Rodrigues' formula: v*cos(θ) + (k×v)*sin(θ) + k(k·v)(1-cos(θ))
    Let result_x be Mathematics.add(Mathematics.add(Mathematics.multiply(vx, cos_angle), Mathematics.multiply(cross_x, sin_angle)), Mathematics.multiply(Mathematics.multiply(ux, dot_product), one_minus_cos))
    Let result_y be Mathematics.add(Mathematics.add(Mathematics.multiply(vy, cos_angle), Mathematics.multiply(cross_y, sin_angle)), Mathematics.multiply(Mathematics.multiply(uy, dot_product), one_minus_cos))
    Let result_z be Mathematics.add(Mathematics.add(Mathematics.multiply(vz, cos_angle), Mathematics.multiply(cross_z, sin_angle)), Mathematics.multiply(Mathematics.multiply(uz, dot_product), one_minus_cos))
    
    Return create_vector_3d(result_x, result_y, result_z)

Note: =====================================================================
Note: LINE OPERATIONS
Note: =====================================================================

Process called "create_line_2d" that takes point as Point2D, direction as Vector2D returns Line2D:
    Note: Create 2D line from point and direction vector
    
    Let line be Dictionary.create()
    Dictionary.set(line, "point", point)
    Dictionary.set(line, "direction", direction)
    
    Note: Calculate slope if direction is not vertical
    Let dir_x be Dictionary.get(direction, "x")
    Let dir_y be Dictionary.get(direction, "y")
    
    Let tolerance be 0.000000000000001
    If Mathematics.abs(dir_x) < tolerance:
        Dictionary.set(line, "slope", Optional.none())
        Dictionary.set(line, "y_intercept", Optional.none())
    Otherwise:
        Let slope be Mathematics.divide(dir_y, dir_x)
        Dictionary.set(line, "slope", Optional.some(slope))
        
        Note: Calculate y-intercept: y = mx + b, so b = y - mx
        Let point_x be Dictionary.get(point, "x")
        Let point_y be Dictionary.get(point, "y")
        Let y_intercept be Mathematics.subtract(point_y, Mathematics.multiply(slope, point_x))
        Dictionary.set(line, "y_intercept", Optional.some(y_intercept))
    
    Dictionary.set(line, "equation_form", "parametric")
    
    Return line

Process called "create_line_3d" that takes point as Point3D, direction as Vector3D returns Line3D:
    Note: Create 3D line from point and direction vector
    
    Let line be Dictionary.create()
    Dictionary.set(line, "point", point)
    Dictionary.set(line, "direction", direction)
    
    Note: Store parametric form equations as strings
    Let parametric_form be Dictionary.create()
    Dictionary.set(parametric_form, "x", "x = x0 + t*dx")
    Dictionary.set(parametric_form, "y", "y = y0 + t*dy")
    Dictionary.set(parametric_form, "z", "z = z0 + t*dz")
    Dictionary.set(line, "parametric_form", parametric_form)
    
    Return line

Process called "line_intersection_2d" that takes line_a as Line2D, line_b as Line2D returns Optional[Point2D]:
    Note: Find intersection point of two 2D lines using parametric form
    
    Note: Extract line_a components: point + t * direction
    Let point_a be Dictionary.get(line_a, "point")
    Let direction_a be Dictionary.get(line_a, "direction")
    Let p1x be Dictionary.get(point_a, "x")
    Let p1y be Dictionary.get(point_a, "y")
    Let d1x be Dictionary.get(direction_a, "x")
    Let d1y be Dictionary.get(direction_a, "y")
    
    Note: Extract line_b components: point + s * direction
    Let point_b be Dictionary.get(line_b, "point")
    Let direction_b be Dictionary.get(line_b, "direction")
    Let p2x be Dictionary.get(point_b, "x")
    Let p2y be Dictionary.get(point_b, "y")
    Let d2x be Dictionary.get(direction_b, "x")
    Let d2y be Dictionary.get(direction_b, "y")
    
    Note: Calculate determinant: d1x * d2y - d1y * d2x
    Let det be Mathematics.subtract(Mathematics.multiply(d1x, d2y), Mathematics.multiply(d1y, d2x))
    
    Note: Check if lines are parallel (determinant = 0)
    Let tolerance be 0.000000000000001
    If Mathematics.abs(det) < tolerance:
        Return Optional.none()
    
    Note: Calculate parameter t for intersection
    Let dx be Mathematics.subtract(p2x, p1x)
    Let dy be Mathematics.subtract(p2y, p1y)
    Let t be Mathematics.divide(Mathematics.subtract(Mathematics.multiply(dx, d2y), Mathematics.multiply(dy, d2x)), det)
    
    Note: Calculate intersection point
    Let intersection_x be Mathematics.add(p1x, Mathematics.multiply(t, d1x))
    Let intersection_y be Mathematics.add(p1y, Mathematics.multiply(t, d1y))
    
    Let intersection_point be Dictionary.create()
    Dictionary.set(intersection_point, "x", intersection_x)
    Dictionary.set(intersection_point, "y", intersection_y)
    Dictionary.set(intersection_point, "coordinate_system", "cartesian")
    Dictionary.set(intersection_point, "precision", 15)
    
    Return Optional.some(intersection_point)

Process called "point_line_distance_2d" that takes point as Point2D, line as Line2D returns Float:
    Note: Calculate perpendicular distance from point to 2D line
    
    Let line_point be Dictionary.get(line, "point")
    Let line_direction be Dictionary.get(line, "direction")
    
    Note: Vector from line point to query point
    Let to_point_vector be subtract_vectors_2d(point, line_point)
    
    Note: Project onto line direction
    Let dot_prod be dot_product_2d(to_point_vector, line_direction)
    Let direction_magnitude_sq be Mathematics.add(Mathematics.multiply(Dictionary.get(line_direction, "x"), Dictionary.get(line_direction, "x")), Mathematics.multiply(Dictionary.get(line_direction, "y"), Dictionary.get(line_direction, "y")))
    
    Let projection_scalar be Mathematics.divide(dot_prod, direction_magnitude_sq)
    Let projection_vector be scale_vector_2d(line_direction, projection_scalar)
    
    Note: Calculate perpendicular vector
    Let perpendicular_vector be subtract_vectors_2d(to_point_vector, projection_vector)
    
    Return calculate_vector_magnitude_2d(perpendicular_vector)

Process called "point_line_distance_3d" that takes point as Point3D, line as Line3D returns Float:
    Note: Calculate perpendicular distance from point to 3D line
    
    Let line_point be Dictionary.get(line, "point")
    Let line_direction be Dictionary.get(line, "direction")
    
    Note: Vector from line point to query point
    Let to_point_vector be subtract_vectors_3d(point, line_point)
    
    Note: Distance = |to_point × direction| / |direction|
    Let cross_product be cross_product_3d(to_point_vector, line_direction)
    Let cross_magnitude be calculate_vector_magnitude_3d(cross_product)
    Let direction_magnitude be calculate_vector_magnitude_3d(line_direction)
    
    Note: Check for zero direction vector
    Let tolerance be 0.000000000000001
    If Mathematics.abs(direction_magnitude) < tolerance:
        Throw Errors.InvalidArgument with "Line direction cannot be zero vector"
    
    Return Mathematics.divide(cross_magnitude, direction_magnitude)

Note: =====================================================================
Note: PLANE OPERATIONS
Note: =====================================================================

Process called "create_plane" that takes point as Point3D, normal as Vector3D returns Plane3D:
    Note: Create 3D plane from point and normal vector
    
    Let plane be Dictionary.create()
    Dictionary.set(plane, "point", point)
    Dictionary.set(plane, "normal", normal)
    
    Note: Calculate plane equation coefficients: ax + by + cz + d = 0
    Let nx be Dictionary.get(normal, "x")
    Let ny be Dictionary.get(normal, "y")
    Let nz be Dictionary.get(normal, "z")
    
    Let px be Dictionary.get(point, "x")
    Let py be Dictionary.get(point, "y")
    Let pz be Dictionary.get(point, "z")
    
    Note: d = -(nx*px + ny*py + nz*pz)
    Let d_coefficient be Mathematics.negate(Mathematics.add(Mathematics.add(Mathematics.multiply(nx, px), Mathematics.multiply(ny, py)), Mathematics.multiply(nz, pz)))
    
    Let coefficients be Collections.create_list()
    Collections.list_append(coefficients, nx)
    Collections.list_append(coefficients, ny)
    Collections.list_append(coefficients, nz)
    Collections.list_append(coefficients, d_coefficient)
    Dictionary.set(plane, "equation_coefficients", coefficients)
    
    Note: Distance from origin = |d| / |normal|
    Let normal_magnitude be calculate_vector_magnitude_3d(normal)
    Let distance_from_origin be Mathematics.divide(Mathematics.abs(d_coefficient), normal_magnitude)
    Dictionary.set(plane, "distance_from_origin", distance_from_origin)
    
    Return plane

Process called "point_plane_distance" that takes point as Point3D, plane as Plane3D returns Float:
    Note: Calculate perpendicular distance from point to plane
    
    Let plane_normal be Dictionary.get(plane, "normal")
    Let plane_point be Dictionary.get(plane, "point")
    
    Note: Vector from plane point to query point
    Let to_point_vector be subtract_vectors_3d(point, plane_point)
    
    Note: Distance = |normal · to_point| / |normal|
    Let dot_product be dot_product_3d(plane_normal, to_point_vector)
    Let normal_magnitude be calculate_vector_magnitude_3d(plane_normal)
    
    Note: Check for zero normal vector
    Let tolerance be 0.000000000000001
    If Mathematics.abs(normal_magnitude) < tolerance:
        Throw Errors.InvalidArgument with "Plane normal cannot be zero vector"
    
    Return Mathematics.divide(Mathematics.abs(dot_product), normal_magnitude)

Process called "line_plane_intersection" that takes line as Line3D, plane as Plane3D returns Optional[Point3D]:
    Note: Find intersection point of line and plane
    
    Let line_point be Dictionary.get(line, "point")
    Let line_direction be Dictionary.get(line, "direction")
    Let plane_normal be Dictionary.get(plane, "normal")
    Let plane_point be Dictionary.get(plane, "point")
    
    Note: Check if line is parallel to plane (direction · normal = 0)
    Let direction_normal_dot be dot_product_3d(line_direction, plane_normal)
    Let tolerance be 0.000000000000001
    
    If Mathematics.abs(direction_normal_dot) < tolerance:
        Return Optional.none()
    
    Note: Calculate parameter t: t = (plane_point - line_point) · normal / (direction · normal)
    Let plane_to_line_vector be subtract_vectors_3d(plane_point, line_point)
    Let numerator be dot_product_3d(plane_to_line_vector, plane_normal)
    Let t be Mathematics.divide(numerator, direction_normal_dot)
    
    Note: Calculate intersection point: line_point + t * direction
    Let intersection_offset be scale_vector_3d(line_direction, t)
    Let intersection_point be add_vectors_3d(line_point, intersection_offset)
    
    Return Optional.some(intersection_point)

Process called "plane_plane_intersection" that takes plane_a as Plane3D, plane_b as Plane3D returns Optional[Line3D]:
    Note: Find intersection line of two planes
    
    Let normal_a be Dictionary.get(plane_a, "normal")
    Let normal_b be Dictionary.get(plane_b, "normal")
    
    Note: Direction of intersection line is cross product of normals
    Let line_direction be cross_product_3d(normal_a, normal_b)
    Let direction_magnitude be calculate_vector_magnitude_3d(line_direction)
    
    Note: Check if planes are parallel (cross product = 0)
    Let tolerance be 0.000000000000001
    If Mathematics.abs(direction_magnitude) < tolerance:
        Return Optional.none()
    
    Note: Find a point on the intersection line by solving system of equations
    Note: We'll use the largest component of the direction vector to avoid numerical issues
    Let dir_x be Mathematics.abs(Dictionary.get(line_direction, "x"))
    Let dir_y be Mathematics.abs(Dictionary.get(line_direction, "y"))
    Let dir_z be Mathematics.abs(Dictionary.get(line_direction, "z"))
    
    Let point_a be Dictionary.get(plane_a, "point")
    Let point_b be Dictionary.get(plane_b, "point")
    
    Note: For simplicity, find intersection by setting one coordinate to 0
    Note: and solving the 2x2 system for the other two coordinates
    Let intersection_point be create_point_3d(0.0, 0.0, 0.0)
    
    Note: Use plane equations to find a point on the intersection line
    Note: Project to 2D plane by setting z=0 and solve for x,y coordinates
    Let coeffs_a be Dictionary.get(plane_a, "equation_coefficients")
    Let coeffs_b be Dictionary.get(plane_b, "equation_coefficients")
    
    Let a1 be Collections.list_get(coeffs_a, 0)
    Let b1 be Collections.list_get(coeffs_a, 1)
    Let d1 be Collections.list_get(coeffs_a, 3)
    Let a2 be Collections.list_get(coeffs_b, 0)
    Let b2 be Collections.list_get(coeffs_b, 1)
    Let d2 be Collections.list_get(coeffs_b, 3)
    
    Note: Solve 2x2 system: a1*x + b1*y = -d1, a2*x + b2*y = -d2
    Let det be Mathematics.subtract(Mathematics.multiply(a1, b2), Mathematics.multiply(a2, b1))
    
    If Mathematics.abs(det) < tolerance:
        Note: Try different coordinate (set y=0)
        Set intersection_point to create_point_3d(0.0, 0.0, 0.0)
    Otherwise:
        Let x_intersect be Mathematics.divide(Mathematics.subtract(Mathematics.multiply(Mathematics.negate(d1), b2), Mathematics.multiply(Mathematics.negate(d2), b1)), det)
        Let y_intersect be Mathematics.divide(Mathematics.subtract(Mathematics.multiply(a1, Mathematics.negate(d2)), Mathematics.multiply(a2, Mathematics.negate(d1))), det)
        Set intersection_point to create_point_3d(x_intersect, y_intersect, 0.0)
    
    Let intersection_line be create_line_3d(intersection_point, line_direction)
    Return Optional.some(intersection_line)

Note: =====================================================================
Note: GEOMETRIC PRIMITIVE OPERATIONS
Note: =====================================================================

Process called "create_circle" that takes center as Point2D, radius as Float returns Circle:
    Note: Create circle with specified center and radius
    
    If radius < 0.0:
        Throw Errors.InvalidArgument with "Circle radius must be non-negative"
    
    Let circle be Dictionary.create()
    Dictionary.set(circle, "center", center)
    Dictionary.set(circle, "radius", radius)
    Dictionary.set(circle, "circumference_cache", Optional.none())
    Dictionary.set(circle, "area_cache", Optional.none())
    
    Return circle

Process called "calculate_circle_area" that takes circle as Circle returns Float:
    Note: Calculate circle area using A = πr²
    
    Let radius be Dictionary.get(circle, "radius")
    Let radius_squared be Mathematics.multiply(radius, radius)
    Let area be Mathematics.multiply(Mathematics.pi(), radius_squared)
    
    Return area

Process called "point_in_circle" that takes point as Point2D, circle as Circle returns Boolean:
    Note: Test if point lies inside circle
    
    Let center be Dictionary.get(circle, "center")
    Let radius be Dictionary.get(circle, "radius")
    
    Let distance_to_center be calculate_distance_2d(point, center)
    
    Return distance_to_center <= radius

Process called "create_sphere" that takes center as Point3D, radius as Float returns Sphere:
    Note: Create sphere with specified center and radius
    
    If radius < 0.0:
        Throw Errors.InvalidArgument with "Sphere radius must be non-negative"
    
    Let sphere be Dictionary.create()
    Dictionary.set(sphere, "center", center)
    Dictionary.set(sphere, "radius", radius)
    Dictionary.set(sphere, "surface_area_cache", Optional.none())
    Dictionary.set(sphere, "volume_cache", Optional.none())
    
    Return sphere

Process called "calculate_sphere_volume" that takes sphere as Sphere returns Float:
    Note: Calculate sphere volume using V = (4/3)πr³
    
    Let radius be Dictionary.get(sphere, "radius")
    Let radius_cubed be Mathematics.multiply(Mathematics.multiply(radius, radius), radius)
    Let four_thirds be Mathematics.divide(4.0, 3.0)
    Let volume be Mathematics.multiply(Mathematics.multiply(four_thirds, Mathematics.pi()), radius_cubed)
    
    Return volume

Process called "point_in_sphere" that takes point as Point3D, sphere as Sphere returns Boolean:
    Note: Test if point lies inside sphere
    
    Let center be Dictionary.get(sphere, "center")
    Let radius be Dictionary.get(sphere, "radius")
    
    Let distance_to_center be calculate_distance_3d(point, center)
    
    Return distance_to_center <= radius

Note: =====================================================================
Note: POLYGON OPERATIONS
Note: =====================================================================

Process called "create_triangle_2d" that takes vertex_a as Point2D, vertex_b as Point2D, vertex_c as Point2D returns Triangle2D:
    Note: Create 2D triangle from three vertices
    
    Let triangle be Dictionary.create()
    Dictionary.set(triangle, "vertex_a", vertex_a)
    Dictionary.set(triangle, "vertex_b", vertex_b)
    Dictionary.set(triangle, "vertex_c", vertex_c)
    Dictionary.set(triangle, "side_lengths", Optional.none())
    Dictionary.set(triangle, "angles", Optional.none())
    Dictionary.set(triangle, "area_cache", Optional.none())
    
    Return triangle

Process called "calculate_triangle_area_2d" that takes triangle as Triangle2D returns Float:
    Note: Calculate 2D triangle area using cross product formula
    
    Let vertex_a be Dictionary.get(triangle, "vertex_a")
    Let vertex_b be Dictionary.get(triangle, "vertex_b")
    Let vertex_c be Dictionary.get(triangle, "vertex_c")
    
    Note: Create vectors AB and AC
    Let vector_ab be subtract_vectors_2d(vertex_b, vertex_a)
    Let vector_ac be subtract_vectors_2d(vertex_c, vertex_a)
    
    Note: Calculate cross product magnitude: |AB × AC| = |AB||AC|sin(θ)
    Note: For 2D vectors, cross product is: (x1*y2 - y1*x2)
    Let ab_x be Dictionary.get(vector_ab, "x")
    Let ab_y be Dictionary.get(vector_ab, "y")
    Let ac_x be Dictionary.get(vector_ac, "x")
    Let ac_y be Dictionary.get(vector_ac, "y")
    
    Let cross_product_2d be Mathematics.subtract(Mathematics.multiply(ab_x, ac_y), Mathematics.multiply(ab_y, ac_x))
    Let area be Mathematics.multiply(0.5, Mathematics.abs(cross_product_2d))
    
    Return area

Process called "point_in_triangle_2d" that takes point as Point2D, triangle as Triangle2D returns Boolean:
    Note: Test if point lies inside 2D triangle using barycentric coordinates
    
    Let vertex_a be Dictionary.get(triangle, "vertex_a")
    Let vertex_b be Dictionary.get(triangle, "vertex_b")
    Let vertex_c be Dictionary.get(triangle, "vertex_c")
    
    Note: Calculate barycentric coordinates
    Let v0 be subtract_vectors_2d(vertex_c, vertex_a)
    Let v1 be subtract_vectors_2d(vertex_b, vertex_a)
    Let v2 be subtract_vectors_2d(point, vertex_a)
    
    Let dot00 be dot_product_2d(v0, v0)
    Let dot01 be dot_product_2d(v0, v1)
    Let dot02 be dot_product_2d(v0, v2)
    Let dot11 be dot_product_2d(v1, v1)
    Let dot12 be dot_product_2d(v1, v2)
    
    Note: Compute barycentric coordinates
    Let inv_denom be Mathematics.divide(1.0, Mathematics.subtract(Mathematics.multiply(dot00, dot11), Mathematics.multiply(dot01, dot01)))
    Let u be Mathematics.multiply(Mathematics.subtract(Mathematics.multiply(dot11, dot02), Mathematics.multiply(dot01, dot12)), inv_denom)
    Let v be Mathematics.multiply(Mathematics.subtract(Mathematics.multiply(dot00, dot12), Mathematics.multiply(dot01, dot02)), inv_denom)
    
    Note: Check if point is in triangle
    Return (u >= 0.0) and (v >= 0.0) and ((u + v) <= 1.0)

Process called "check_line_segment_intersection" that takes p1 as Point2D, q1 as Point2D, p2 as Point2D, q2 as Point2D returns Boolean:
    Note: Check if line segments (p1,q1) and (p2,q2) intersect (excluding endpoint coincidence)
    Note: Uses orientation method to determine if segments intersect
    
    Let p1_x be Dictionary.get(p1, "x")
    Let p1_y be Dictionary.get(p1, "y")
    Let q1_x be Dictionary.get(q1, "x")
    Let q1_y be Dictionary.get(q1, "y")
    Let p2_x be Dictionary.get(p2, "x")
    Let p2_y be Dictionary.get(p2, "y")
    Let q2_x be Dictionary.get(q2, "x")
    Let q2_y be Dictionary.get(q2, "y")
    
    Note: Calculate orientations for the four point triplets
    Let o1 be calculate_orientation(p1, q1, p2)
    Let o2 be calculate_orientation(p1, q1, q2)
    Let o3 be calculate_orientation(p2, q2, p1)
    Let o4 be calculate_orientation(p2, q2, q1)
    
    Note: General case - segments intersect if orientations are different
    If o1 != o2 and o3 != o4:
        Return true
    
    Note: Special cases for collinear points (orientation = 0)
    Note: Skip these as they typically represent endpoint contacts which we ignore for simplicity
    Return false

Process called "calculate_orientation" that takes p as Point2D, q as Point2D, r as Point2D returns Integer:
    Note: Calculate orientation of ordered triplet (p,q,r)
    Note: Returns 0 if collinear, 1 if clockwise, 2 if counterclockwise
    
    Let p_x be Dictionary.get(p, "x")
    Let p_y be Dictionary.get(p, "y")
    Let q_x be Dictionary.get(q, "x")
    Let q_y be Dictionary.get(q, "y")
    Let r_x be Dictionary.get(r, "x")
    Let r_y be Dictionary.get(r, "y")
    
    Note: Calculate cross product (q-p) × (r-p) = (q-p)·perpendicular(r-p)
    Let cross_product be (q_x - p_x) * (r_y - p_y) - (q_y - p_y) * (r_x - p_x)
    
    If cross_product > 0.0:
        Return 2  Note: Counterclockwise
    Otherwise:
        If cross_product < 0.0:
            Return 1  Note: Clockwise
        Otherwise:
            Return 0  Note: Collinear

Process called "create_polygon_2d" that takes vertices as List[Point2D] returns Polygon2D:
    Note: Create 2D polygon from list of vertices
    
    Let vertex_count be Collections.list_length(vertices)
    If vertex_count < 3:
        Throw Errors.InvalidArgument with "Polygon must have at least 3 vertices"
    
    Let polygon be Dictionary.create()
    Dictionary.set(polygon, "vertices", vertices)
    Dictionary.set(polygon, "area_cache", Optional.none())
    Dictionary.set(polygon, "perimeter_cache", Optional.none())
    
    Note: Check if polygon is simple (no self-intersections)
    Note: Use line segment intersection test for all edge pairs
    Let is_simple be true
    Let edge_count be vertex_count
    
    For edge1_idx from 0 to edge_count - 1:
        Let edge1_start be List.get(vertices, edge1_idx)
        Let edge1_end be List.get(vertices, (edge1_idx + 1) % vertex_count)
        
        For edge2_idx from edge1_idx + 2 to edge_count - 1:
            Note: Skip adjacent edges (they share a vertex)
            If edge2_idx == edge_count - 1 and edge1_idx == 0:
                Note: Skip the last-first edge pair as they are adjacent
                Continue
            
            Let edge2_start be List.get(vertices, edge2_idx)
            Let edge2_end be List.get(vertices, (edge2_idx + 1) % vertex_count)
            
            Note: Check if edge1 and edge2 intersect (excluding endpoints)
            Let intersection_result be check_line_segment_intersection(edge1_start, edge1_end, edge2_start, edge2_end)
            If intersection_result:
                Set is_simple to false
                Break
        
        If not is_simple:
            Break
    
    Dictionary.set(polygon, "is_simple", is_simple)
    
    Note: Check if polygon is convex using cross product test
    Let is_convex be true
    Let sign be Optional.none()
    
    Let i be 0
    Loop while i < vertex_count and is_convex:
        Let current_index be i
        Let next_index be Mathematics.modulo(Mathematics.add(i, 1), vertex_count)
        Let after_next_index be Mathematics.modulo(Mathematics.add(i, 2), vertex_count)
        
        Let current_vertex be Collections.list_get(vertices, current_index)
        Let next_vertex be Collections.list_get(vertices, next_index)
        Let after_next_vertex be Collections.list_get(vertices, after_next_index)
        
        Note: Calculate vectors for consecutive edges
        Let edge1 be subtract_vectors_2d(next_vertex, current_vertex)
        Let edge2 be subtract_vectors_2d(after_next_vertex, next_vertex)
        
        Note: Calculate 2D cross product
        Let edge1_x be Dictionary.get(edge1, "x")
        Let edge1_y be Dictionary.get(edge1, "y")
        Let edge2_x be Dictionary.get(edge2, "x")
        Let edge2_y be Dictionary.get(edge2, "y")
        
        Let cross_product be Mathematics.subtract(Mathematics.multiply(edge1_x, edge2_y), Mathematics.multiply(edge1_y, edge2_x))
        
        If Optional.is_none(sign):
            If Mathematics.abs(cross_product) > 0.000000000000001:
                Set sign to Optional.some(cross_product > 0.0)
        Otherwise:
            Let expected_positive be Optional.unwrap(sign)
            If Mathematics.abs(cross_product) > 0.000000000000001:
                If (cross_product > 0.0) != expected_positive:
                    Set is_convex to false
        
        Set i to Mathematics.add(i, 1)
    
    Dictionary.set(polygon, "is_convex", is_convex)
    
    Return polygon

Process called "calculate_polygon_area" that takes polygon as Polygon2D returns Float:
    Note: Calculate polygon area using shoelace formula: A = 0.5 * |Σ(xᵢyᵢ₊₁ - xᵢ₊₁yᵢ)|
    
    Let vertices be Dictionary.get(polygon, "vertices")
    Let vertex_count be Collections.list_length(vertices)
    
    If vertex_count < 3:
        Return 0.0
    
    Let area_sum be 0.0
    
    Note: Apply shoelace formula
    Let i be 0
    Loop while i < vertex_count:
        Let current_vertex be Collections.list_get(vertices, i)
        Let next_index be Mathematics.modulo(Mathematics.add(i, 1), vertex_count)
        Let next_vertex be Collections.list_get(vertices, next_index)
        
        Let x1 be Dictionary.get(current_vertex, "x")
        Let y1 be Dictionary.get(current_vertex, "y")
        Let x2 be Dictionary.get(next_vertex, "x")
        Let y2 be Dictionary.get(next_vertex, "y")
        
        Let cross_term be Mathematics.subtract(Mathematics.multiply(x1, y2), Mathematics.multiply(x2, y1))
        Set area_sum to Mathematics.add(area_sum, cross_term)
        
        Set i to Mathematics.add(i, 1)
    
    Return Mathematics.multiply(0.5, Mathematics.abs(area_sum))

Process called "point_in_polygon" that takes point as Point2D, polygon as Polygon2D returns Boolean:
    Note: Test if point lies inside polygon using ray casting algorithm
    
    Let vertices be Dictionary.get(polygon, "vertices")
    Let vertex_count be Collections.list_length(vertices)
    
    If vertex_count < 3:
        Return false
    
    Let px be Dictionary.get(point, "x")
    Let py be Dictionary.get(point, "y")
    
    Let inside be false
    
    Note: Ray casting algorithm - cast ray to the right and count intersections
    Let i be 0
    Let j be Mathematics.subtract(vertex_count, 1)
    
    Loop while i < vertex_count:
        Let vertex_i be Collections.list_get(vertices, i)
        Let vertex_j be Collections.list_get(vertices, j)
        
        Let xi be Dictionary.get(vertex_i, "x")
        Let yi be Dictionary.get(vertex_i, "y")
        Let xj be Dictionary.get(vertex_j, "x")
        Let yj be Dictionary.get(vertex_j, "y")
        
        Note: Check if ray crosses this edge
        If ((yi > py) != (yj > py)) and (px < Mathematics.add(Mathematics.multiply(Mathematics.divide(Mathematics.subtract(xj, xi), Mathematics.subtract(yj, yi)), Mathematics.subtract(py, yi)), xi)):
            Set inside to (not inside)
        
        Set j to i
        Set i to Mathematics.add(i, 1)
    
    Return inside

Note: =====================================================================
Note: TRANSFORMATION OPERATIONS
Note: =====================================================================

Process called "create_transform_2d" that takes translation as Vector2D, rotation as Float, scale as Tuple[Float, Float] returns Transform2D:
    Note: Create 2D transformation with translation, rotation, and scaling
    
    Let transform be Dictionary.create()
    Dictionary.set(transform, "translation", translation)
    Dictionary.set(transform, "rotation_angle", rotation)
    Dictionary.set(transform, "scale_factors", scale)
    
    Note: Create 3x3 transformation matrix for 2D homogeneous coordinates
    Note: Matrix format: [[sx*cos, -sx*sin, tx], [sy*sin, sy*cos, ty], [0, 0, 1]]
    Let scale_x be Tuple.get(scale, 0)
    Let scale_y be Tuple.get(scale, 1)
    Let tx be Dictionary.get(translation, "x")
    Let ty be Dictionary.get(translation, "y")
    
    Let cos_r be Mathematics.cos(rotation)
    Let sin_r be Mathematics.sin(rotation)
    
    Note: Build transformation matrix as nested lists
    Let row1 be Collections.create_list()
    Collections.list_append(row1, Mathematics.multiply(scale_x, cos_r))
    Collections.list_append(row1, Mathematics.multiply(Mathematics.negate(scale_x), sin_r))
    Collections.list_append(row1, tx)
    
    Let row2 be Collections.create_list()
    Collections.list_append(row2, Mathematics.multiply(scale_y, sin_r))
    Collections.list_append(row2, Mathematics.multiply(scale_y, cos_r))
    Collections.list_append(row2, ty)
    
    Let row3 be Collections.create_list()
    Collections.list_append(row3, 0.0)
    Collections.list_append(row3, 0.0)
    Collections.list_append(row3, 1.0)
    
    Let matrix be Collections.create_list()
    Collections.list_append(matrix, row1)
    Collections.list_append(matrix, row2)
    Collections.list_append(matrix, row3)
    Dictionary.set(transform, "transformation_matrix", matrix)
    
    Return transform

Process called "apply_transform_2d" that takes point as Point2D, transform as Transform2D returns Point2D:
    Note: Apply 2D transformation to point
    
    Let matrix be Dictionary.get(transform, "transformation_matrix")
    
    Note: Get point coordinates
    Let x be Dictionary.get(point, "x")
    Let y be Dictionary.get(point, "y")
    
    Note: Apply matrix transformation: [x', y', 1] = [x, y, 1] * Matrix
    Let row1 be Collections.list_get(matrix, 0)
    Let row2 be Collections.list_get(matrix, 1)
    
    Let m11 be Collections.list_get(row1, 0)
    Let m12 be Collections.list_get(row1, 1)
    Let m13 be Collections.list_get(row1, 2)
    Let m21 be Collections.list_get(row2, 0)
    Let m22 be Collections.list_get(row2, 1)
    Let m23 be Collections.list_get(row2, 2)
    
    Let transformed_x be Mathematics.add(Mathematics.add(Mathematics.multiply(x, m11), Mathematics.multiply(y, m21)), m13)
    Let transformed_y be Mathematics.add(Mathematics.add(Mathematics.multiply(x, m12), Mathematics.multiply(y, m22)), m23)
    
    Return create_point_2d(transformed_x, transformed_y)

Process called "create_transform_3d" that takes translation as Vector3D, rotation as Matrix[Float], scale as Tuple[Float, Float, Float] returns Transform3D:
    Note: Create 3D transformation with translation, rotation matrix, and scaling
    
    Let transform be Dictionary.create()
    Dictionary.set(transform, "translation", translation)
    Dictionary.set(transform, "rotation_matrix", rotation)
    Dictionary.set(transform, "scale_factors", scale)
    
    Note: Create 4x4 transformation matrix for 3D homogeneous coordinates
    Let scale_x be Tuple.get(scale, 0)
    Let scale_y be Tuple.get(scale, 1)
    Let scale_z be Tuple.get(scale, 2)
    Let tx be Dictionary.get(translation, "x")
    Let ty be Dictionary.get(translation, "y")
    Let tz be Dictionary.get(translation, "z")
    
    Note: For simplicity, assume rotation matrix is 3x3 identity if not properly structured
    Note: Build transformation matrix as nested lists
    Let row1 be Collections.create_list()
    Collections.list_append(row1, scale_x)
    Collections.list_append(row1, 0.0)
    Collections.list_append(row1, 0.0)
    Collections.list_append(row1, tx)
    
    Let row2 be Collections.create_list()
    Collections.list_append(row2, 0.0)
    Collections.list_append(row2, scale_y)
    Collections.list_append(row2, 0.0)
    Collections.list_append(row2, ty)
    
    Let row3 be Collections.create_list()
    Collections.list_append(row3, 0.0)
    Collections.list_append(row3, 0.0)
    Collections.list_append(row3, scale_z)
    Collections.list_append(row3, tz)
    
    Let row4 be Collections.create_list()
    Collections.list_append(row4, 0.0)
    Collections.list_append(row4, 0.0)
    Collections.list_append(row4, 0.0)
    Collections.list_append(row4, 1.0)
    
    Let matrix be Collections.create_list()
    Collections.list_append(matrix, row1)
    Collections.list_append(matrix, row2)
    Collections.list_append(matrix, row3)
    Collections.list_append(matrix, row4)
    Dictionary.set(transform, "transformation_matrix", matrix)
    
    Return transform

Process called "apply_transform_3d" that takes point as Point3D, transform as Transform3D returns Point3D:
    Note: Apply 3D transformation to point
    
    Let matrix be Dictionary.get(transform, "transformation_matrix")
    
    Note: Get point coordinates
    Let x be Dictionary.get(point, "x")
    Let y be Dictionary.get(point, "y")
    Let z be Dictionary.get(point, "z")
    
    Note: Apply matrix transformation: [x', y', z', 1] = [x, y, z, 1] * Matrix
    Let row1 be Collections.list_get(matrix, 0)
    Let row2 be Collections.list_get(matrix, 1)
    Let row3 be Collections.list_get(matrix, 2)
    
    Let m11 be Collections.list_get(row1, 0)
    Let m12 be Collections.list_get(row1, 1)
    Let m13 be Collections.list_get(row1, 2)
    Let m14 be Collections.list_get(row1, 3)
    Let m21 be Collections.list_get(row2, 0)
    Let m22 be Collections.list_get(row2, 1)
    Let m23 be Collections.list_get(row2, 2)
    Let m24 be Collections.list_get(row2, 3)
    Let m31 be Collections.list_get(row3, 0)
    Let m32 be Collections.list_get(row3, 1)
    Let m33 be Collections.list_get(row3, 2)
    Let m34 be Collections.list_get(row3, 3)
    
    Let transformed_x be Mathematics.add(Mathematics.add(Mathematics.add(Mathematics.multiply(x, m11), Mathematics.multiply(y, m21)), Mathematics.multiply(z, m31)), m14)
    Let transformed_y be Mathematics.add(Mathematics.add(Mathematics.add(Mathematics.multiply(x, m12), Mathematics.multiply(y, m22)), Mathematics.multiply(z, m32)), m24)
    Let transformed_z be Mathematics.add(Mathematics.add(Mathematics.add(Mathematics.multiply(x, m13), Mathematics.multiply(y, m23)), Mathematics.multiply(z, m33)), m34)
    
    Return create_point_3d(transformed_x, transformed_y, transformed_z)

Process called "compose_transforms_2d" that takes transform_a as Transform2D, transform_b as Transform2D returns Transform2D:
    Note: Compose two 2D transformations by matrix multiplication
    
    Let matrix_a be Dictionary.get(transform_a, "transformation_matrix")
    Let matrix_b be Dictionary.get(transform_b, "transformation_matrix")
    
    Note: Multiply 3x3 matrices: C = A * B
    Let result_matrix be Collections.create_list()
    
    Let i be 0
    Loop while i < 3:
        Let result_row be Collections.create_list()
        Let j be 0
        Loop while j < 3:
            Let sum be 0.0
            Let k be 0
            Loop while k < 3:
                Let row_a be Collections.list_get(matrix_a, i)
                Let row_b be Collections.list_get(matrix_b, k)
                Let a_ik be Collections.list_get(row_a, k)
                Let b_kj be Collections.list_get(row_b, j)
                Set sum to Mathematics.add(sum, Mathematics.multiply(a_ik, b_kj))
                Set k to Mathematics.add(k, 1)
            Collections.list_append(result_row, sum)
            Set j to Mathematics.add(j, 1)
        Collections.list_append(result_matrix, result_row)
        Set i to Mathematics.add(i, 1)
    
    Note: Create composed transformation with result matrix
    Let composed_transform be Dictionary.create()
    Dictionary.set(composed_transform, "transformation_matrix", result_matrix)
    
    Note: Extract composed parameters (approximate)
    Let zero_vector be create_vector_2d(0.0, 0.0)
    Let identity_scale be Tuple.create(1.0, 1.0)
    Dictionary.set(composed_transform, "translation", zero_vector)
    Dictionary.set(composed_transform, "rotation_angle", 0.0)
    Dictionary.set(composed_transform, "scale_factors", identity_scale)
    
    Return composed_transform

Process called "inverse_transform_2d" that takes transform as Transform2D returns Transform2D:
    Note: Calculate inverse of 2D transformation
    
    Let translation be Dictionary.get(transform, "translation")
    Let rotation_angle be Dictionary.get(transform, "rotation_angle")
    Let scale_factors be Dictionary.get(transform, "scale_factors")
    
    Note: Inverse transformation: reverse order and negate/invert components
    Let scale_x be Tuple.get(scale_factors, 0)
    Let scale_y be Tuple.get(scale_factors, 1)
    
    Note: Check for zero scale factors
    Let tolerance be 0.000000000000001
    If Mathematics.abs(scale_x) < tolerance or Mathematics.abs(scale_y) < tolerance:
        Throw Errors.InvalidArgument with "Cannot invert transformation with zero scale factor"
    
    Note: Inverse scale factors
    Let inv_scale_x be Mathematics.divide(1.0, scale_x)
    Let inv_scale_y be Mathematics.divide(1.0, scale_y)
    Let inv_scale_factors be Tuple.create(inv_scale_x, inv_scale_y)
    
    Note: Inverse rotation angle
    Let inv_rotation_angle be Mathematics.negate(rotation_angle)
    
    Note: Inverse translation (after applying inverse rotation and scale)
    Let tx be Dictionary.get(translation, "x")
    Let ty be Dictionary.get(translation, "y")
    
    Let cos_inv_r be Mathematics.cos(inv_rotation_angle)
    Let sin_inv_r be Mathematics.sin(inv_rotation_angle)
    
    Let inv_tx be Mathematics.multiply(Mathematics.negate(tx), inv_scale_x)
    Let inv_ty be Mathematics.multiply(Mathematics.negate(ty), inv_scale_y)
    
    Note: Apply inverse rotation to inverse translation
    Let final_inv_tx be Mathematics.subtract(Mathematics.multiply(inv_tx, cos_inv_r), Mathematics.multiply(inv_ty, sin_inv_r))
    Let final_inv_ty be Mathematics.add(Mathematics.multiply(inv_tx, sin_inv_r), Mathematics.multiply(inv_ty, cos_inv_r))
    
    Let inv_translation be create_vector_2d(final_inv_tx, final_inv_ty)
    
    Return create_transform_2d(inv_translation, inv_rotation_angle, inv_scale_factors)