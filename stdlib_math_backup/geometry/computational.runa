Note: =====================================================================
Note: HELPER FUNCTIONS
Note: =====================================================================

Process called "orientation_test_2d" that takes p1 as Point2D, p2 as Point2D, p3 as Point2D returns Float:
    Note: Compute signed area to determine orientation (positive = counterclockwise, negative = clockwise, zero = collinear)
    Let cross_product be (p2.x - p1.x) * (p3.y - p1.y) - (p2.y - p1.y) * (p3.x - p1.x)
    Return cross_product

Process called "ccw_test" that takes p1 as Point2D, p2 as Point2D, p3 as Point2D returns Boolean:
    Note: Test if three points are in counter-clockwise order
    Let orientation be orientation_test_2d(p1, p2, p3)
    Return orientation > 0.0

Process called "point_compare_lexicographic" that takes p1 as Point2D, p2 as Point2D returns Integer:
    Note: Compare points lexicographically (first by y, then by x)
    If p1.y < p2.y:
        Return -1
    Otherwise:
        If p1.y > p2.y:
            Return 1
        Otherwise:
            If p1.x < p2.x:
                Return -1
            Otherwise:
                If p1.x > p2.x:
                    Return 1
                Otherwise:
                    Return 0

Process called "polar_angle_compare" that takes pivot as Point2D, p1 as Point2D, p2 as Point2D returns Integer:
    Note: Compare two points by polar angle relative to pivot point
    Let orientation be orientation_test_2d(pivot, p1, p2)
    If orientation == 0.0:
        Let dist1 be (p1.x - pivot.x) * (p1.x - pivot.x) + (p1.y - pivot.y) * (p1.y - pivot.y)
        Let dist2 be (p2.x - pivot.x) * (p2.x - pivot.x) + (p2.y - pivot.y) * (p2.y - pivot.y)
        If dist1 < dist2:
            Return -1
        Otherwise:
            If dist1 > dist2:
                Return 1
            Otherwise:
                Return 0
    Otherwise:
        If orientation > 0.0:
            Return -1
        Otherwise:
            Return 1

Process called "triangle_circumcenter" that takes p1 as Point2D, p2 as Point2D, p3 as Point2D returns Point2D:
    Note: Calculate circumcenter of triangle formed by three points
    Let d1 be p1.x * p1.x + p1.y * p1.y
    Let d2 be p2.x * p2.x + p2.y * p2.y
    Let d3 be p3.x * p3.x + p3.y * p3.y
    Let det be 2.0 * (p1.x * (p2.y - p3.y) + p2.x * (p3.y - p1.y) + p3.x * (p1.y - p2.y))
    Let cx be (d1 * (p2.y - p3.y) + d2 * (p3.y - p1.y) + d3 * (p1.y - p2.y)) / det
    Let cy be (d1 * (p3.x - p2.x) + d2 * (p1.x - p3.x) + d3 * (p2.x - p1.x)) / det
    Let center be Euclidean.Point2D with x as cx, y as cy
    Return center

Process called "in_circle_test" that takes p as Point2D, p1 as Point2D, p2 as Point2D, p3 as Point2D returns Boolean:
    Note: Test if point p is inside circumcircle of triangle p1-p2-p3
    Let center be triangle_circumcenter(p1, p2, p3)
    Let radius_squared be (p1.x - center.x) * (p1.x - center.x) + (p1.y - center.y) * (p1.y - center.y)
    Let dist_squared be (p.x - center.x) * (p.x - center.x) + (p.y - center.y) * (p.y - center.y)
    Return dist_squared < radius_squared

Process called "polygon_signed_area" that takes polygon as Polygon2D returns Float:
    Note: Calculate signed area of polygon (positive for counter-clockwise orientation)
    Let area be 0.0
    Let n be Collections.list_length(polygon.vertices)
    Let i be 0
    Repeat while i < n:
        Let j be (i + 1) % n
        Let pi be Collections.list_get(polygon.vertices, i)
        Let pj be Collections.list_get(polygon.vertices, j)
        Set area to area + (pi.x * pj.y - pj.x * pi.y)
        Set i to i + 1
    Return area / 2.0

Process called "quickhull_recursive" that takes hull as List[Point2D], points as List[Point2D], p1 as Point2D, p2 as Point2D returns List[Point2D]:
    Note: Recursive helper for QuickHull algorithm
    Let n be Collections.list_length(points)
    If n == 0:
        Return hull
    
    Note: Find the point farthest from line p1-p2
    Let farthest_point be Collections.list_get(points, 0)
    Let max_distance be 0.0
    Let i be 0
    Repeat while i < n:
        Let point be Collections.list_get(points, i)
        Let distance be Euclidean.abs(orientation_test_2d(p1, p2, point))
        If distance > max_distance:
            Set max_distance to distance
            Set farthest_point to point
        Set i to i + 1
    
    Note: Split remaining points
    Let left_points be Collections.list_create()
    Let right_points be Collections.list_create()
    Set i to 0
    Repeat while i < n:
        Let point be Collections.list_get(points, i)
        If orientation_test_2d(p1, farthest_point, point) > 0.0:
            Set left_points to Collections.list_append(left_points, point)
        If orientation_test_2d(farthest_point, p2, point) > 0.0:
            Set right_points to Collections.list_append(right_points, point)
        Set i to i + 1
    
    Note: Recursively build hull
    Set hull to quickhull_recursive(hull, left_points, p1, farthest_point)
    Set hull to Collections.list_append(hull, farthest_point)
    Set hull to quickhull_recursive(hull, right_points, farthest_point, p2)
    
    Return hull

Process called "edge_in_triangle" that takes edge as Tuple[Integer, Integer], triangle as Tuple3[Integer, Integer, Integer] returns Boolean:
    Note: Check if edge is part of triangle
    Let a be edge.first
    Let b be edge.second
    Let t1 be triangle.first
    Let t2 be triangle.second
    Let t3 be triangle.third
    
    If (a == t1 && b == t2) || (a == t2 && b == t1):
        Return True
    If (a == t2 && b == t3) || (a == t3 && b == t2):
        Return True
    If (a == t3 && b == t1) || (a == t1 && b == t3):
        Return True
    Return False

Process called "build_kd_node" that takes points as List[Point2D], dimension as Integer, depth as Integer, max_depth as Integer returns Optional[KDNode]:
    Note: Recursively build KD-tree node
    Let n be Collections.list_length(points)
    If n == 0 || depth >= max_depth:
        Return Null
    
    If n == 1:
        Let point be Collections.list_get(points, 0)
        Let node be KDNode with point as point, left_child as Null, right_child as Null, splitting_dimension as dimension, depth as depth
        Return node
    
    Note: Sort points by current dimension
    Let sorted_points be Collections.list_create()
    Let i be 0
    Repeat while i < n:
        Set sorted_points to Collections.list_append(sorted_points, Collections.list_get(points, i))
        Set i to i + 1
    
    Note: Simple bubble sort by dimension (x=0, y=1)
    Let outer be 0
    Repeat while outer < n - 1:
        Let inner be 0
        Repeat while inner < n - 1 - outer:
            Let p1 be Collections.list_get(sorted_points, inner)
            Let p2 be Collections.list_get(sorted_points, inner + 1)
            Let coord1 be p1.x
            Let coord2 be p2.x
            If dimension == 1:
                Set coord1 to p1.y
                Set coord2 to p2.y
            
            If coord1 > coord2:
                Set sorted_points to Collections.list_set(sorted_points, inner, p2)
                Set sorted_points to Collections.list_set(sorted_points, inner + 1, p1)
            Set inner to inner + 1
        Set outer to outer + 1
    
    Note: Find median point
    Let median_index be n / 2
    Let median_point be Collections.list_get(sorted_points, median_index)
    
    Note: Split into left and right subtrees
    Let left_points be Collections.list_create()
    Let right_points be Collections.list_create()
    Set i to 0
    Repeat while i < n:
        If i < median_index:
            Set left_points to Collections.list_append(left_points, Collections.list_get(sorted_points, i))
        Otherwise:
            If i > median_index:
                Set right_points to Collections.list_append(right_points, Collections.list_get(sorted_points, i))
        Set i to i + 1
    
    Note: Recursively build subtrees with alternating dimension
    Let next_dimension be (dimension + 1) % 2
    Let left_child be build_kd_node(left_points, next_dimension, depth + 1, max_depth)
    Let right_child be build_kd_node(right_points, next_dimension, depth + 1, max_depth)
    
    Let node be KDNode with point as median_point, left_child as left_child, right_child as right_child, splitting_dimension as dimension, depth as depth
    Return node

Process called "kd_range_search_recursive" that takes node as Optional[KDNode], region as Rectangle, result as List[Point2D] returns List[Point2D]:
    Note: Recursively search KD-tree for points in range
    If node == Null:
        Return result
    
    Let point be node.point
    Note: Check if point is in range
    If point.x >= region.x && point.x <= region.x + region.width && point.y >= region.y && point.y <= region.y + region.height:
        Set result to Collections.list_append(result, point)
    
    Let dimension be node.splitting_dimension
    Let coord be point.x
    Let region_min be region.x
    Let region_max be region.x + region.width
    If dimension == 1:
        Set coord to point.y
        Set region_min to region.y
        Set region_max to region.y + region.height
    
    Note: Search left subtree if region overlaps
    If region_min <= coord && node.left_child != Null:
        Set result to kd_range_search_recursive(node.left_child, region, result)
    
    Note: Search right subtree if region overlaps
    If region_max >= coord && node.right_child != Null:
        Set result to kd_range_search_recursive(node.right_child, region, result)
    
    Return result

Type called "KDSearchResult":
    point as Point2D
    distance_squared as Float

Process called "kd_nearest_recursive" that takes node as Optional[KDNode], query_point as Point2D, best_point as Point2D, best_distance_squared as Float returns KDSearchResult:
    Note: Recursively search for nearest neighbor in KD-tree
    If node == Null:
        Let result be KDSearchResult with point as best_point, distance_squared as best_distance_squared
        Return result
    
    Let current_point be node.point
    Let current_distance_squared be (query_point.x - current_point.x) * (query_point.x - current_point.x) + (query_point.y - current_point.y) * (query_point.y - current_point.y)
    
    Let current_best_point be best_point
    Let current_best_distance be best_distance_squared
    If current_distance_squared < best_distance_squared:
        Set current_best_point to current_point
        Set current_best_distance to current_distance_squared
    
    Let dimension be node.splitting_dimension
    Let query_coord be query_point.x
    Let node_coord be current_point.x
    If dimension == 1:
        Set query_coord to query_point.y
        Set node_coord to current_point.y
    
    Note: Choose which subtree to search first
    Let first_child be node.left_child
    Let second_child be node.right_child
    If query_coord > node_coord:
        Set first_child to node.right_child
        Set second_child to node.left_child
    
    Note: Search first subtree
    If first_child != Null:
        Let first_result be kd_nearest_recursive(first_child, query_point, current_best_point, current_best_distance)
        Set current_best_point to first_result.point
        Set current_best_distance to first_result.distance_squared
    
    Note: Check if we need to search second subtree
    Let axis_distance be query_coord - node_coord
    Let axis_distance_squared be axis_distance * axis_distance
    If axis_distance_squared < current_best_distance && second_child != Null:
        Let second_result be kd_nearest_recursive(second_child, query_point, current_best_point, current_best_distance)
        Set current_best_point to second_result.point
        Set current_best_distance to second_result.distance_squared
    
    Let result be KDSearchResult with point as current_best_point, distance_squared as current_best_distance
    Return result

Process called "quad_insert_recursive" that takes node as QuadNode, point as Point2D, capacity as Integer returns QuadNode:
    Note: Recursively insert point into quad-tree node
    If node.is_leaf:
        Set node.points to Collections.list_append(node.points, point)
        Let point_count be Collections.list_length(node.points)
        
        If point_count > capacity:
            Note: Subdivide node
            Set node.is_leaf to False
            Let boundary be node.boundary
            Let half_width be boundary.width / 2.0
            Let half_height be boundary.height / 2.0
            
            Let nw_boundary be Euclidean.Rectangle with x as boundary.x, y as boundary.y, width as half_width, height as half_height
            Let ne_boundary be Euclidean.Rectangle with x as boundary.x + half_width, y as boundary.y, width as half_width, height as half_height
            Let sw_boundary be Euclidean.Rectangle with x as boundary.x, y as boundary.y + half_height, width as half_width, height as half_height
            Let se_boundary be Euclidean.Rectangle with x as boundary.x + half_width, y as boundary.y + half_height, width as half_width, height as half_height
            
            Let nw_child be QuadNode with boundary as nw_boundary, points as Collections.list_create(), children as Null, is_leaf as True
            Let ne_child be QuadNode with boundary as ne_boundary, points as Collections.list_create(), children as Null, is_leaf as True
            Let sw_child be QuadNode with boundary as sw_boundary, points as Collections.list_create(), children as Null, is_leaf as True
            Let se_child be QuadNode with boundary as se_boundary, points as Collections.list_create(), children as Null, is_leaf as True
            
            Let children be Collections.list_create()
            Set children to Collections.list_append(children, nw_child)
            Set children to Collections.list_append(children, ne_child)
            Set children to Collections.list_append(children, sw_child)
            Set children to Collections.list_append(children, se_child)
            Set node.children to children
            
            Note: Redistribute existing points
            Let old_points be node.points
            Set node.points to Collections.list_create()
            Let i be 0
            Repeat while i < Collections.list_length(old_points):
                Let old_point be Collections.list_get(old_points, i)
                Set node to quad_insert_into_children(node, old_point, capacity)
                Set i to i + 1
        
        Return node
    Otherwise:
        Return quad_insert_into_children(node, point, capacity)

Process called "quad_insert_into_children" that takes node as QuadNode, point as Point2D, capacity as Integer returns QuadNode:
    Note: Insert point into appropriate child quadrant
    If node.children == Null:
        Return node
    
    Let children be node.children
    Let i be 0
    Repeat while i < Collections.list_length(children):
        Let child be Collections.list_get(children, i)
        Let boundary be child.boundary
        If point.x >= boundary.x && point.x <= boundary.x + boundary.width && point.y >= boundary.y && point.y <= boundary.y + boundary.height:
            Let updated_child be quad_insert_recursive(child, point, capacity)
            Set children to Collections.list_set(children, i, updated_child)
            Set node.children to children
            Break
        Set i to i + 1
    Return node

Process called "quad_query_recursive" that takes node as QuadNode, region as Rectangle, result as List[Point2D] returns List[Point2D]:
    Note: Recursively query quad-tree for points in region
    Let boundary be node.boundary
    Note: Check if regions intersect
    If region.x > boundary.x + boundary.width || region.x + region.width < boundary.x || region.y > boundary.y + boundary.height || region.y + region.height < boundary.y:
        Return result
    
    If node.is_leaf:
        Let i be 0
        Repeat while i < Collections.list_length(node.points):
            Let point be Collections.list_get(node.points, i)
            If point.x >= region.x && point.x <= region.x + region.width && point.y >= region.y && point.y <= region.y + region.height:
                Set result to Collections.list_append(result, point)
            Set i to i + 1
    Otherwise:
        If node.children != Null:
            Let i be 0
            Repeat while i < Collections.list_length(node.children):
                Let child be Collections.list_get(node.children, i)
                Set result to quad_query_recursive(child, region, result)
                Set i to i + 1
    
    Return result

Note: =====================================================================
Note: CONVEX HULL OPERATIONS
Note: =====================================================================

Process called "compute_convex_hull_2d" that takes points as List[Point2D], algorithm as String returns ConvexHull:
    Note: Compute 2D convex hull using Graham scan, QuickHull, or Jarvis march algorithms
    Let hull_vertices be Collections.list_create()
    
    If algorithm == "graham_scan":
        Set hull_vertices to graham_scan(points)
    Otherwise:
        If algorithm == "quickhull":
            Set hull_vertices to quickhull_2d(points)
        Otherwise:
            If algorithm == "jarvis_march":
                Set hull_vertices to jarvis_march(points)
            Otherwise:
                Set hull_vertices to graham_scan(points)
    
    Note: Build edges from consecutive vertices
    Let edges be Collections.list_create()
    Let n be Collections.list_length(hull_vertices)
    Let i be 0
    Repeat while i < n:
        Let j be (i + 1) % n
        Let edge be Euclidean.Tuple with first as i, second as j
        Set edges to Collections.list_append(edges, edge)
        Set i to i + 1
    
    Note: Calculate area and perimeter
    Let area be 0.0
    Let perimeter be 0.0
    Set i to 0
    Repeat while i < n:
        Let j be (i + 1) % n
        Let pi be Collections.list_get(hull_vertices, i)
        Let pj be Collections.list_get(hull_vertices, j)
        Set area to area + (pi.x * pj.y - pj.x * pi.y)
        Let dx be pj.x - pi.x
        Let dy be pj.y - pi.y
        Set perimeter to perimeter + Euclidean.sqrt(dx * dx + dy * dy)
        Set i to i + 1
    Set area to Euclidean.abs(area) / 2.0
    
    Let result be ConvexHull with vertices as hull_vertices, edges as edges, area as area, perimeter as perimeter, algorithm_used as algorithm
    Return result

Process called "compute_convex_hull_3d" that takes points as List[Point3D], algorithm as String returns ConvexHull3D:
    Note: Compute 3D convex hull using QuickHull3D or incremental algorithms
    Let n be Collections.list_length(points)
    If n < 4:
        Let empty_faces be Collections.list_create()
        Let empty_edges be Collections.list_create()
        Let result be ConvexHull3D with vertices as points, faces as empty_faces, edges as empty_edges, volume as 0.0, surface_area as 0.0
        Return result
    
    If algorithm == "quickhull3d":
        Return quickhull_3d(points)
    Otherwise:
        Return quickhull_3d(points)

Process called "quickhull_3d" that takes points as List[Point3D] returns ConvexHull3D:
    Note: QuickHull3D algorithm for computing 3D convex hull in O(n log n) expected time
    Let n be Collections.list_length(points)
    
    Note: Find initial tetrahedron using extreme points
    Let initial_tetrahedron be find_initial_tetrahedron_3d(points)
    If initial_tetrahedron.size < 4:
        Let empty_faces be Collections.list_create()
        Let empty_edges be Collections.list_create()
        Let result be ConvexHull3D with vertices as points, faces as empty_faces, edges as empty_edges, volume as 0.0, surface_area as 0.0
        Return result
    
    Note: Create initial hull faces from tetrahedron
    Let hull_faces be Collections.list_create()
    Let tetra_indices be Collections.list_create()
    Set tetra_indices to Collections.list_append(tetra_indices, initial_tetrahedron.p0_index)
    Set tetra_indices to Collections.list_append(tetra_indices, initial_tetrahedron.p1_index)
    Set tetra_indices to Collections.list_append(tetra_indices, initial_tetrahedron.p2_index)
    Set tetra_indices to Collections.list_append(tetra_indices, initial_tetrahedron.p3_index)
    
    Note: Create the four faces of initial tetrahedron with proper orientation
    Let face1 be create_face_3d(tetra_indices.0, tetra_indices.1, tetra_indices.2, points)
    Let face2 be create_face_3d(tetra_indices.0, tetra_indices.1, tetra_indices.3, points)
    Let face3 be create_face_3d(tetra_indices.0, tetra_indices.2, tetra_indices.3, points)
    Let face4 be create_face_3d(tetra_indices.1, tetra_indices.2, tetra_indices.3, points)
    
    Set hull_faces to Collections.list_append(hull_faces, face1)
    Set hull_faces to Collections.list_append(hull_faces, face2)
    Set hull_faces to Collections.list_append(hull_faces, face3)
    Set hull_faces to Collections.list_append(hull_faces, face4)
    
    Note: Partition remaining points to faces
    Let remaining_points be Collections.list_create()
    Let i be 0
    Repeat while i < n:
        If not Collections.list_contains(tetra_indices, i):
            Set remaining_points to Collections.list_append(remaining_points, i)
        Set i to i + 1
    
    Note: Assign points to visible faces
    Set i to 0
    Repeat while i < Collections.list_length(remaining_points):
        Let point_index be Collections.list_get(remaining_points, i)
        Let point be Collections.list_get(points, point_index)
        
        Let j be 0
        Repeat while j < Collections.list_length(hull_faces):
            Let face be Collections.list_get(hull_faces, j)
            If point_above_face_3d(point, face, points):
                Set face.outside_points to Collections.list_append(face.outside_points, point_index)
            Set j to j + 1
        Set i to i + 1
    
    Note: Process faces with outside points
    Let faces_to_process be Collections.list_create()
    Set i to 0
    Repeat while i < Collections.list_length(hull_faces):
        Let face be Collections.list_get(hull_faces, i)
        If Collections.list_length(face.outside_points) > 0:
            Set faces_to_process to Collections.list_append(faces_to_process, face)
        Set i to i + 1
    
    Repeat while Collections.list_length(faces_to_process) > 0:
        Note: Find face with farthest point
        Let best_face be Collections.list_get(faces_to_process, 0)
        Let max_distance be 0.0
        Let farthest_point_index be -1
        
        Set i to 0
        Repeat while i < Collections.list_length(faces_to_process):
            Let face be Collections.list_get(faces_to_process, i)
            Let j be 0
            Repeat while j < Collections.list_length(face.outside_points):
                Let point_index be Collections.list_get(face.outside_points, j)
                Let point be Collections.list_get(points, point_index)
                Let distance be distance_to_face_3d(point, face, points)
                
                If distance > max_distance:
                    Set max_distance to distance
                    Set best_face to face
                    Set farthest_point_index to point_index
                Set j to j + 1
            Set i to i + 1
        
        If farthest_point_index == -1:
            Break
        
        Note: Remove visible faces and create new faces
        Let visible_faces be find_visible_faces_3d(hull_faces, farthest_point_index, points)
        Let horizon_edges be find_horizon_edges_3d(visible_faces, hull_faces)
        
        Note: Remove visible faces from hull
        Set i to 0
        Repeat while i < Collections.list_length(visible_faces):
            Let visible_face be Collections.list_get(visible_faces, i)
            Set hull_faces to Collections.list_remove(hull_faces, visible_face)
            Set faces_to_process to Collections.list_remove(faces_to_process, visible_face)
            Set i to i + 1
        
        Note: Create new faces from horizon edges to new vertex
        Set i to 0
        Repeat while i < Collections.list_length(horizon_edges):
            Let edge be Collections.list_get(horizon_edges, i)
            Let new_face be create_face_3d(edge.v1, edge.v2, farthest_point_index, points)
            Set hull_faces to Collections.list_append(hull_faces, new_face)
            
            Note: Redistribute remaining outside points
            distribute_outside_points_to_new_face_3d(new_face, visible_faces, points)
            
            If Collections.list_length(new_face.outside_points) > 0:
                Set faces_to_process to Collections.list_append(faces_to_process, new_face)
            Set i to i + 1
    
    Note: Build final hull structure
    Let final_faces be Collections.list_create()
    Let edges be Collections.list_create()
    Set i to 0
    Repeat while i < Collections.list_length(hull_faces):
        Let face be Collections.list_get(hull_faces, i)
        Let face_indices be Collections.list_create()
        Set face_indices to Collections.list_append(face_indices, face.v1)
        Set face_indices to Collections.list_append(face_indices, face.v2)
        Set face_indices to Collections.list_append(face_indices, face.v3)
        Set final_faces to Collections.list_append(final_faces, face_indices)
        
        Note: Add edges
        Let edge1 be Euclidean.Tuple with first as face.v1, second as face.v2
        Let edge2 be Euclidean.Tuple with first as face.v2, second as face.v3
        Let edge3 be Euclidean.Tuple with first as face.v3, second as face.v1
        If not Collections.list_contains(edges, edge1):
            Set edges to Collections.list_append(edges, edge1)
        If not Collections.list_contains(edges, edge2):
            Set edges to Collections.list_append(edges, edge2)
        If not Collections.list_contains(edges, edge3):
            Set edges to Collections.list_append(edges, edge3)
        Set i to i + 1
    
    Note: Calculate volume and surface area
    Let volume be calculate_hull_volume_3d(final_faces, points)
    Let surface_area be calculate_hull_surface_area_3d(final_faces, points)
    
    Let result be ConvexHull3D with vertices as points, faces as final_faces, edges as edges, volume as volume, surface_area as surface_area
    Return result

Process called "graham_scan" that takes points as List[Point2D] returns List[Point2D]:
    Note: Graham scan algorithm for 2D convex hull in O(n log n) time
    Let n be Collections.list_length(points)
    If n < 3:
        Return points
    
    Note: Find the bottom-most point (lowest y-coordinate, leftmost if tie)
    Let bottom_point be Collections.list_get(points, 0)
    Let bottom_index be 0
    Let i be 1
    Repeat while i < n:
        Let current_point be Collections.list_get(points, i)
        If point_compare_lexicographic(current_point, bottom_point) < 0:
            Set bottom_point to current_point
            Set bottom_index to i
        Set i to i + 1
    
    Note: Sort points by polar angle relative to bottom point
    Let sorted_points be Collections.list_create()
    Set i to 0
    Repeat while i < n:
        If i != bottom_index:
            Set sorted_points to Collections.list_append(sorted_points, Collections.list_get(points, i))
        Set i to i + 1
    
    Note: Simple bubble sort by polar angle (can be optimized with proper sort)
    Let len be Collections.list_length(sorted_points)
    Let outer be 0
    Repeat while outer < len - 1:
        Let inner be 0
        Repeat while inner < len - 1 - outer:
            Let p1 be Collections.list_get(sorted_points, inner)
            Let p2 be Collections.list_get(sorted_points, inner + 1)
            If polar_angle_compare(bottom_point, p1, p2) > 0:
                Set sorted_points to Collections.list_set(sorted_points, inner, p2)
                Set sorted_points to Collections.list_set(sorted_points, inner + 1, p1)
            Set inner to inner + 1
        Set outer to outer + 1
    
    Note: Build convex hull using stack
    Let hull be Collections.list_create()
    Set hull to Collections.list_append(hull, bottom_point)
    If len > 0:
        Set hull to Collections.list_append(hull, Collections.list_get(sorted_points, 0))
    If len > 1:
        Set hull to Collections.list_append(hull, Collections.list_get(sorted_points, 1))
    
    Set i to 2
    Repeat while i < len:
        Let next_point be Collections.list_get(sorted_points, i)
        Let hull_size be Collections.list_length(hull)
        
        Note: Remove points that make right turn
        Repeat while hull_size > 1:
            Let top be Collections.list_get(hull, hull_size - 1)
            Let second_to_top be Collections.list_get(hull, hull_size - 2)
            If ccw_test(second_to_top, top, next_point):
                Break
            Set hull to Collections.list_remove_at(hull, hull_size - 1)
            Set hull_size to Collections.list_length(hull)
        
        Set hull to Collections.list_append(hull, next_point)
        Set i to i + 1
    
    Return hull

Process called "quickhull_2d" that takes points as List[Point2D] returns List[Point2D]:
    Note: QuickHull algorithm for 2D convex hull with average O(n log n) time
    Let n be Collections.list_length(points)
    If n < 3:
        Return points
    
    Note: Find leftmost and rightmost points
    Let leftmost be Collections.list_get(points, 0)
    Let rightmost be Collections.list_get(points, 0)
    Let i be 1
    Repeat while i < n:
        Let point be Collections.list_get(points, i)
        If point.x < leftmost.x:
            Set leftmost to point
        If point.x > rightmost.x:
            Set rightmost to point
        Set i to i + 1
    
    Note: Split points into upper and lower hull
    Let upper_points be Collections.list_create()
    Let lower_points be Collections.list_create()
    Set i to 0
    Repeat while i < n:
        Let point be Collections.list_get(points, i)
        Let orientation be orientation_test_2d(leftmost, rightmost, point)
        If orientation > 0.0:
            Set upper_points to Collections.list_append(upper_points, point)
        Otherwise:
            If orientation < 0.0:
                Set lower_points to Collections.list_append(lower_points, point)
        Set i to i + 1
    
    Note: Build hull recursively
    Let hull be Collections.list_create()
    Set hull to Collections.list_append(hull, leftmost)
    Set hull to quickhull_recursive(hull, upper_points, leftmost, rightmost)
    Set hull to Collections.list_append(hull, rightmost)
    Set hull to quickhull_recursive(hull, lower_points, rightmost, leftmost)
    
    Return hull

Process called "jarvis_march" that takes points as List[Point2D] returns List[Point2D]:
    Note: Jarvis march (gift wrapping) algorithm for convex hull in O(nh) time
    Let n be Collections.list_length(points)
    If n < 3:
        Return points
    
    Note: Find leftmost point as starting point
    Let leftmost_index be 0
    Let i be 1
    Repeat while i < n:
        Let current_point be Collections.list_get(points, i)
        Let leftmost_point be Collections.list_get(points, leftmost_index)
        If current_point.x < leftmost_point.x:
            Set leftmost_index to i
        Otherwise:
            If current_point.x == leftmost_point.x && current_point.y < leftmost_point.y:
                Set leftmost_index to i
        Set i to i + 1
    
    Let hull be Collections.list_create()
    Let current_index be leftmost_index
    
    Note: Gift wrapping algorithm
    Repeat:
        Let current_point be Collections.list_get(points, current_index)
        Set hull to Collections.list_append(hull, current_point)
        
        Note: Find next point on hull (most counter-clockwise from current)
        Let next_index be 0
        Set i to 1
        Repeat while i < n:
            Let candidate be Collections.list_get(points, i)
            Let next_point be Collections.list_get(points, next_index)
            Let orientation be orientation_test_2d(current_point, next_point, candidate)
            
            Note: If candidate is more counter-clockwise or collinear but farther
            If next_index == current_index || orientation > 0.0:
                Set next_index to i
            Otherwise:
                If orientation == 0.0:
                    Let dist_next be (next_point.x - current_point.x) * (next_point.x - current_point.x) + (next_point.y - current_point.y) * (next_point.y - current_point.y)
                    Let dist_candidate be (candidate.x - current_point.x) * (candidate.x - current_point.x) + (candidate.y - current_point.y) * (candidate.y - current_point.y)
                    If dist_candidate > dist_next:
                        Set next_index to i
            Set i to i + 1
        
        Set current_index to next_index
        
        Note: Stop when we return to starting point
        If current_index == leftmost_index:
            Break
    
    Return hull

Note: =====================================================================
Note: DELAUNAY TRIANGULATION OPERATIONS
Note: =====================================================================

Process called "compute_delaunay_triangulation" that takes points as List[Point2D], algorithm as String returns DelaunayTriangulation:
    Note: Compute Delaunay triangulation using Bowyer-Watson or divide-and-conquer
    If algorithm == "bowyer_watson":
        Return bowyer_watson_triangulation(points)
    Otherwise:
        Return bowyer_watson_triangulation(points)

Process called "bowyer_watson_triangulation" that takes points as List[Point2D] returns DelaunayTriangulation:
    Note: Bowyer-Watson incremental algorithm for Delaunay triangulation
    Let n be Collections.list_length(points)
    If n < 3:
        Let empty_triangles be Collections.list_create()
        Let empty_edges be Collections.list_create()
        Let empty_circumcenters be Collections.list_create()
        Let result be DelaunayTriangulation with vertices as points, triangles as empty_triangles, edges as empty_edges, circumcenters as empty_circumcenters, dual_voronoi as Null
        Return result
    
    Note: Create super triangle that contains all points
    Let min_x be Collections.list_get(points, 0).x
    Let max_x be min_x
    Let min_y be Collections.list_get(points, 0).y
    Let max_y be min_y
    Let i be 1
    Repeat while i < n:
        Let point be Collections.list_get(points, i)
        If point.x < min_x:
            Set min_x to point.x
        If point.x > max_x:
            Set max_x to point.x
        If point.y < min_y:
            Set min_y to point.y
        If point.y > max_y:
            Set max_y to point.y
        Set i to i + 1
    
    Let dx be max_x - min_x
    Let dy be max_y - min_y
    Let delta_max be Euclidean.max(dx, dy)
    Let mid_x be (min_x + max_x) / 2.0
    Let mid_y be (min_y + max_y) / 2.0
    
    Note: Create super triangle vertices
    Let p1 be Euclidean.Point2D with x as mid_x - 20.0 * delta_max, y as mid_y - delta_max
    Let p2 be Euclidean.Point2D with x as mid_x, y as mid_y + 20.0 * delta_max
    Let p3 be Euclidean.Point2D with x as mid_x + 20.0 * delta_max, y as mid_y - delta_max
    
    Let vertices be Collections.list_create()
    Set vertices to Collections.list_append(vertices, p1)
    Set vertices to Collections.list_append(vertices, p2)
    Set vertices to Collections.list_append(vertices, p3)
    Set i to 0
    Repeat while i < n:
        Set vertices to Collections.list_append(vertices, Collections.list_get(points, i))
        Set i to i + 1
    
    Note: Initialize with super triangle
    Let triangles be Collections.list_create()
    Let super_triangle be Euclidean.Tuple3 with first as 0, second as 1, third as 2
    Set triangles to Collections.list_append(triangles, super_triangle)
    
    Note: Add points one by one
    Set i to 3
    Repeat while i < Collections.list_length(vertices):
        Let point be Collections.list_get(vertices, i)
        
        Note: Find triangles whose circumcircle contains the point
        Let bad_triangles be Collections.list_create()
        Let j be 0
        Repeat while j < Collections.list_length(triangles):
            Let triangle be Collections.list_get(triangles, j)
            Let v1 be Collections.list_get(vertices, triangle.first)
            Let v2 be Collections.list_get(vertices, triangle.second)
            Let v3 be Collections.list_get(vertices, triangle.third)
            
            If in_circle_test(point, v1, v2, v3):
                Set bad_triangles to Collections.list_append(bad_triangles, triangle)
            Set j to j + 1
        
        Note: Find boundary of polygonal hole
        Let polygon_edges be Collections.list_create()
        Let k be 0
        Repeat while k < Collections.list_length(bad_triangles):
            Let bad_triangle be Collections.list_get(bad_triangles, k)
            
            Note: Check each edge of bad triangle
            Let edge1 be Euclidean.Tuple with first as bad_triangle.first, second as bad_triangle.second
            Let edge2 be Euclidean.Tuple with first as bad_triangle.second, second as bad_triangle.third
            Let edge3 be Euclidean.Tuple with first as bad_triangle.third, second as bad_triangle.first
            
            Let shared_count1 be 0
            Let shared_count2 be 0
            Let shared_count3 be 0
            
            Note: Count how many bad triangles share each edge
            Let m be 0
            Repeat while m < Collections.list_length(bad_triangles):
                If m != k:
                    Let other_triangle be Collections.list_get(bad_triangles, m)
                    If edge_in_triangle(edge1, other_triangle):
                        Set shared_count1 to shared_count1 + 1
                    If edge_in_triangle(edge2, other_triangle):
                        Set shared_count2 to shared_count2 + 1
                    If edge_in_triangle(edge3, other_triangle):
                        Set shared_count3 to shared_count3 + 1
                Set m to m + 1
            
            Note: Add boundary edges (not shared with other bad triangles)
            If shared_count1 == 0:
                Set polygon_edges to Collections.list_append(polygon_edges, edge1)
            If shared_count2 == 0:
                Set polygon_edges to Collections.list_append(polygon_edges, edge2)
            If shared_count3 == 0:
                Set polygon_edges to Collections.list_append(polygon_edges, edge3)
            
            Set k to k + 1
        
        Note: Remove bad triangles
        Set j to 0
        Repeat while j < Collections.list_length(bad_triangles):
            Let bad_triangle be Collections.list_get(bad_triangles, j)
            Set triangles to Collections.list_remove(triangles, bad_triangle)
            Set j to j + 1
        
        Note: Create new triangles from point to polygon boundary
        Set j to 0
        Repeat while j < Collections.list_length(polygon_edges):
            Let edge be Collections.list_get(polygon_edges, j)
            Let new_triangle be Euclidean.Tuple3 with first as edge.first, second as edge.second, third as i
            Set triangles to Collections.list_append(triangles, new_triangle)
            Set j to j + 1
        
        Set i to i + 1
    
    Note: Remove triangles connected to super triangle vertices
    Let final_triangles be Collections.list_create()
    Set i to 0
    Repeat while i < Collections.list_length(triangles):
        Let triangle be Collections.list_get(triangles, i)
        If triangle.first >= 3 && triangle.second >= 3 && triangle.third >= 3:
            Note: Adjust indices to account for removed super triangle vertices
            Let adjusted_triangle be Euclidean.Tuple3 with first as triangle.first - 3, second as triangle.second - 3, third as triangle.third - 3
            Set final_triangles to Collections.list_append(final_triangles, adjusted_triangle)
        Set i to i + 1
    
    Note: Build edges and circumcenters
    Let edges be Collections.list_create()
    Let circumcenters be Collections.list_create()
    Set i to 0
    Repeat while i < Collections.list_length(final_triangles):
        Let triangle be Collections.list_get(final_triangles, i)
        Let v1 be Collections.list_get(points, triangle.first)
        Let v2 be Collections.list_get(points, triangle.second)
        Let v3 be Collections.list_get(points, triangle.third)
        
        Note: Add edges
        Let edge1 be Euclidean.Tuple with first as triangle.first, second as triangle.second
        Let edge2 be Euclidean.Tuple with first as triangle.second, second as triangle.third
        Let edge3 be Euclidean.Tuple with first as triangle.third, second as triangle.first
        Set edges to Collections.list_append(edges, edge1)
        Set edges to Collections.list_append(edges, edge2)
        Set edges to Collections.list_append(edges, edge3)
        
        Note: Add circumcenter
        Let circumcenter be triangle_circumcenter(v1, v2, v3)
        Set circumcenters to Collections.list_append(circumcenters, circumcenter)
        Set i to i + 1
    
    Let result be DelaunayTriangulation with vertices as points, triangles as final_triangles, edges as edges, circumcenters as circumcenters, dual_voronoi as Null
    Return result

Process called "validate_delaunay_property" that takes triangulation as DelaunayTriangulation returns Boolean:
    Note: Validate that triangulation satisfies Delaunay property (empty circumcircle)
    Let triangles be triangulation.triangles
    Let vertices be triangulation.vertices
    Let n_triangles be Collections.list_length(triangles)
    Let n_vertices be Collections.list_length(vertices)
    
    Let i be 0
    Repeat while i < n_triangles:
        Let triangle be Collections.list_get(triangles, i)
        Let v1 be Collections.list_get(vertices, triangle.first)
        Let v2 be Collections.list_get(vertices, triangle.second)
        Let v3 be Collections.list_get(vertices, triangle.third)
        
        Note: Check if any other vertex is inside circumcircle
        Let j be 0
        Repeat while j < n_vertices:
            If j != triangle.first && j != triangle.second && j != triangle.third:
                Let test_point be Collections.list_get(vertices, j)
                If in_circle_test(test_point, v1, v2, v3):
                    Return False
            Set j to j + 1
        Set i to i + 1
    
    Return True

Process called "flip_edge" that takes triangulation as DelaunayTriangulation, edge as Tuple[Integer, Integer] returns DelaunayTriangulation:
    Note: Flip edge in triangulation to maintain Delaunay property
    Let triangles be triangulation.triangles
    Let vertices be triangulation.vertices
    Let n_triangles be Collections.list_length(triangles)
    
    Note: Find two triangles that share this edge
    Let triangle1_index be -1
    Let triangle2_index be -1
    Let i be 0
    Repeat while i < n_triangles:
        Let triangle be Collections.list_get(triangles, i)
        If edge_in_triangle(edge, triangle):
            If triangle1_index == -1:
                Set triangle1_index to i
            Otherwise:
                Set triangle2_index to i
                Break
        Set i to i + 1
    
    Note: If edge is not shared by exactly two triangles, cannot flip
    If triangle1_index == -1 || triangle2_index == -1:
        Return triangulation
    
    Let triangle1 be Collections.list_get(triangles, triangle1_index)
    Let triangle2 be Collections.list_get(triangles, triangle2_index)
    
    Note: Find the vertices opposite to the shared edge
    Let opposite1 be -1
    Let opposite2 be -1
    
    If triangle1.first != edge.first && triangle1.first != edge.second:
        Set opposite1 to triangle1.first
    Otherwise:
        If triangle1.second != edge.first && triangle1.second != edge.second:
            Set opposite1 to triangle1.second
        Otherwise:
            Set opposite1 to triangle1.third
    
    If triangle2.first != edge.first && triangle2.first != edge.second:
        Set opposite2 to triangle2.first
    Otherwise:
        If triangle2.second != edge.first && triangle2.second != edge.second:
            Set opposite2 to triangle2.second
        Otherwise:
            Set opposite2 to triangle2.third
    
    Note: Create new triangles with flipped edge
    Let new_triangle1 be Euclidean.Tuple3 with first as opposite1, second as opposite2, third as edge.first
    Let new_triangle2 be Euclidean.Tuple3 with first as opposite1, second as opposite2, third as edge.second
    
    Note: Replace old triangles with new ones
    Let new_triangles be Collections.list_create()
    Set i to 0
    Repeat while i < n_triangles:
        If i == triangle1_index:
            Set new_triangles to Collections.list_append(new_triangles, new_triangle1)
        Otherwise:
            If i == triangle2_index:
                Set new_triangles to Collections.list_append(new_triangles, new_triangle2)
            Otherwise:
                Set new_triangles to Collections.list_append(new_triangles, Collections.list_get(triangles, i))
        Set i to i + 1
    
    Note: Rebuild edges and circumcenters
    Let new_edges be Collections.list_create()
    Let new_circumcenters be Collections.list_create()
    Set i to 0
    Repeat while i < Collections.list_length(new_triangles):
        Let triangle be Collections.list_get(new_triangles, i)
        Let v1 be Collections.list_get(vertices, triangle.first)
        Let v2 be Collections.list_get(vertices, triangle.second)
        Let v3 be Collections.list_get(vertices, triangle.third)
        
        Let edge1 be Euclidean.Tuple with first as triangle.first, second as triangle.second
        Let edge2 be Euclidean.Tuple with first as triangle.second, second as triangle.third
        Let edge3 be Euclidean.Tuple with first as triangle.third, second as triangle.first
        Set new_edges to Collections.list_append(new_edges, edge1)
        Set new_edges to Collections.list_append(new_edges, edge2)
        Set new_edges to Collections.list_append(new_edges, edge3)
        
        Let circumcenter be triangle_circumcenter(v1, v2, v3)
        Set new_circumcenters to Collections.list_append(new_circumcenters, circumcenter)
        Set i to i + 1
    
    Let result be DelaunayTriangulation with vertices as vertices, triangles as new_triangles, edges as new_edges, circumcenters as new_circumcenters, dual_voronoi as triangulation.dual_voronoi
    Return result

Note: =====================================================================
Note: VORONOI DIAGRAM OPERATIONS
Note: =====================================================================

Process called "compute_voronoi_diagram" that takes points as List[Point2D], algorithm as String returns VoronoiDiagram:
    Note: Compute Voronoi diagram using Fortune's sweep line or divide-and-conquer
    If algorithm == "fortune":
        Return fortune_sweep_line(points)
    Otherwise:
        Return fortune_sweep_line(points)

Process called "fortune_sweep_line" that takes points as List[Point2D] returns VoronoiDiagram:
    Note: Fortune's sweep line algorithm for Voronoi diagram in O(n log n) time
    Let n be Collections.list_length(points)
    If n < 2:
        Let empty_vertices be Collections.list_create()
        Let empty_edges be Collections.list_create()
        Let empty_cells be Collections.list_create()
        Let result be VoronoiDiagram with sites as points, vertices as empty_vertices, edges as empty_edges, cells as empty_cells, dual_delaunay as Null
        Return result
    
    Note: For small sets, use dual of Delaunay triangulation
    Let delaunay be bowyer_watson_triangulation(points)
    
    Note: Voronoi vertices are circumcenters of Delaunay triangles
    Let voronoi_vertices be delaunay.circumcenters
    
    Note: Build Voronoi edges from Delaunay triangulation
    Let voronoi_edges be Collections.list_create()
    Let triangles be delaunay.triangles
    Let delaunay_edges be delaunay.edges
    Let n_triangles be Collections.list_length(triangles)
    
    Note: For each pair of adjacent triangles, create Voronoi edge
    Let i be 0
    Repeat while i < n_triangles:
        Let j be i + 1
        Repeat while j < n_triangles:
            Let triangle1 be Collections.list_get(triangles, i)
            Let triangle2 be Collections.list_get(triangles, j)
            
            Note: Check if triangles share an edge
            Let shared_vertices be 0
            If triangle1.first == triangle2.first || triangle1.first == triangle2.second || triangle1.first == triangle2.third:
                Set shared_vertices to shared_vertices + 1
            If triangle1.second == triangle2.first || triangle1.second == triangle2.second || triangle1.second == triangle2.third:
                Set shared_vertices to shared_vertices + 1
            If triangle1.third == triangle2.first || triangle1.third == triangle2.second || triangle1.third == triangle2.third:
                Set shared_vertices to shared_vertices + 1
            
            Note: If exactly 2 vertices are shared, triangles are adjacent
            If shared_vertices == 2:
                Let voronoi_edge be Euclidean.Tuple with first as i, second as j
                Set voronoi_edges to Collections.list_append(voronoi_edges, voronoi_edge)
            
            Set j to j + 1
        Set i to i + 1
    
    Note: Build Voronoi cells (one per input site)
    Let voronoi_cells be Collections.list_create()
    Set i to 0
    Repeat while i < n:
        Let cell_edges be Collections.list_create()
        
        Note: Find all triangles containing this site
        Let j be 0
        Repeat while j < n_triangles:
            Let triangle be Collections.list_get(triangles, j)
            If triangle.first == i || triangle.second == i || triangle.third == i:
                Set cell_edges to Collections.list_append(cell_edges, j)
            Set j to j + 1
        
        Set voronoi_cells to Collections.list_append(voronoi_cells, cell_edges)
        Set i to i + 1
    
    Let result be VoronoiDiagram with sites as points, vertices as voronoi_vertices, edges as voronoi_edges, cells as voronoi_cells, dual_delaunay as delaunay
    Return result

Process called "voronoi_cell_area" that takes diagram as VoronoiDiagram, cell_index as Integer returns Float:
    Note: Calculate area of specific Voronoi cell
    Let cells be diagram.cells
    Let vertices be diagram.vertices
    Let n_cells be Collections.list_length(cells)
    
    If cell_index < 0 || cell_index >= n_cells:
        Return 0.0
    
    Let cell_vertices be Collections.list_get(cells, cell_index)
    Let n_vertices be Collections.list_length(cell_vertices)
    
    If n_vertices < 3:
        Return 0.0
    
    Note: Use shoelace formula for polygon area
    Let area be 0.0
    Let i be 0
    Repeat while i < n_vertices:
        Let j be (i + 1) % n_vertices
        Let vertex_index_i be Collections.list_get(cell_vertices, i)
        Let vertex_index_j be Collections.list_get(cell_vertices, j)
        Let pi be Collections.list_get(vertices, vertex_index_i)
        Let pj be Collections.list_get(vertices, vertex_index_j)
        Set area to area + (pi.x * pj.y - pj.x * pi.y)
        Set i to i + 1
    
    Return Euclidean.abs(area) / 2.0

Process called "nearest_site_query" that takes diagram as VoronoiDiagram, query_point as Point2D returns Integer:
    Note: Find nearest site to query point using Voronoi diagram
    Let sites be diagram.sites
    Let n_sites be Collections.list_length(sites)
    
    If n_sites == 0:
        Return -1
    
    Let nearest_index be 0
    Let nearest_site be Collections.list_get(sites, 0)
    Let min_distance_squared be (query_point.x - nearest_site.x) * (query_point.x - nearest_site.x) + (query_point.y - nearest_site.y) * (query_point.y - nearest_site.y)
    
    Let i be 1
    Repeat while i < n_sites:
        Let site be Collections.list_get(sites, i)
        Let distance_squared be (query_point.x - site.x) * (query_point.x - site.x) + (query_point.y - site.y) * (query_point.y - site.y)
        
        If distance_squared < min_distance_squared:
            Set min_distance_squared to distance_squared
            Set nearest_index to i
        
        Set i to i + 1
    
    Return nearest_index

Note: =====================================================================
Note: SPATIAL DATA STRUCTURE OPERATIONS
Note: =====================================================================

Process called "build_kd_tree" that takes points as List[Point2D], max_depth as Integer returns KDTree:
    Note: Build KD-tree for efficient spatial queries and nearest neighbor search
    Let n be Collections.list_length(points)
    If n == 0:
        Let result be KDTree with root_node as Null, dimension_count as 2, point_count as 0, max_depth as max_depth
        Return result
    
    Let root be build_kd_node(points, 0, 0, max_depth)
    Let result be KDTree with root_node as root, dimension_count as 2, point_count as n, max_depth as max_depth
    Return result

Process called "kd_tree_range_query" that takes tree as KDTree, query as RangeQuery returns List[Point2D]:
    Note: Perform range query on KD-tree to find points in rectangular region
    Let result be Collections.list_create()
    If tree.root_node == Null:
        Return result
    
    Set result to kd_range_search_recursive(tree.root_node, query.query_region, result)
    Return result

Process called "kd_tree_nearest_neighbor" that takes tree as KDTree, query_point as Point2D, k as Integer returns List[Point2D]:
    Note: Find k nearest neighbors using KD-tree in O(log n) average time
    Let result be Collections.list_create()
    If tree.root_node == Null || k <= 0:
        Return result
    
    Note: For simplicity, implement single nearest neighbor (k=1)
    Let best_point be tree.root_node.point
    Let best_distance_squared be (query_point.x - best_point.x) * (query_point.x - best_point.x) + (query_point.y - best_point.y) * (query_point.y - best_point.y)
    
    Set best_point to kd_nearest_recursive(tree.root_node, query_point, best_point, best_distance_squared).point
    Set result to Collections.list_append(result, best_point)
    Return result

Process called "build_quad_tree" that takes points as List[Point2D], boundary as Rectangle, capacity as Integer returns QuadTree:
    Note: Build quad-tree for efficient spatial partitioning and queries
    Let root be QuadNode with boundary as boundary, points as Collections.list_create(), children as Null, is_leaf as True
    Let tree be QuadTree with root_node as root, boundary as boundary, capacity as capacity, total_points as 0
    
    Let i be 0
    Let n be Collections.list_length(points)
    Repeat while i < n:
        Let point be Collections.list_get(points, i)
        Set tree to quad_tree_insert(tree, point)
        Set i to i + 1
    
    Return tree

Process called "quad_tree_insert" that takes tree as QuadTree, point as Point2D returns QuadTree:
    Note: Insert point into quad-tree with automatic subdivision
    If tree.root_node == Null:
        Return tree
    
    Note: Check if point is within boundary
    Let boundary be tree.root_node.boundary
    If point.x < boundary.x || point.x > boundary.x + boundary.width || point.y < boundary.y || point.y > boundary.y + boundary.height:
        Return tree
    
    Set tree.root_node to quad_insert_recursive(tree.root_node, point, tree.capacity)
    Set tree.total_points to tree.total_points + 1
    Return tree

Process called "quad_tree_query" that takes tree as QuadTree, query as RangeQuery returns List[Point2D]:
    Note: Query quad-tree for points in specified region
    Let result be Collections.list_create()
    If tree.root_node == Null:
        Return result
    
    Set result to quad_query_recursive(tree.root_node, query.query_region, result)
    Return result

Note: =====================================================================
Note: POLYGON OPERATIONS
Note: =====================================================================

Process called "polygon_triangulation" that takes polygon as Polygon2D, algorithm as String returns List[Triangle2D]:
    Note: Triangulate polygon using ear clipping or constrained Delaunay triangulation
    If algorithm == "ear_clipping":
        Return ear_clipping_triangulation(polygon)
    Otherwise:
        Return ear_clipping_triangulation(polygon)

Process called "ear_clipping_triangulation" that takes polygon as Polygon2D returns List[Triangle2D]:
    Note: Ear clipping algorithm for polygon triangulation in O(n²) time
    Let vertices be polygon.vertices
    Let n be Collections.list_length(vertices)
    Let triangles be Collections.list_create()
    
    If n < 3:
        Return triangles
    
    If n == 3:
        Let v1 be Collections.list_get(vertices, 0)
        Let v2 be Collections.list_get(vertices, 1)
        Let v3 be Collections.list_get(vertices, 2)
        Let triangle be Euclidean.Triangle2D with vertices as vertices
        Set triangles to Collections.list_append(triangles, triangle)
        Return triangles
    
    Note: Simple ear clipping for convex polygons
    Let remaining_vertices be Collections.list_create()
    Let i be 0
    Repeat while i < n:
        Set remaining_vertices to Collections.list_append(remaining_vertices, Collections.list_get(vertices, i))
        Set i to i + 1
    
    Repeat while Collections.list_length(remaining_vertices) > 3:
        Let len be Collections.list_length(remaining_vertices)
        Let found_ear be False
        Set i to 0
        
        Repeat while i < len && !found_ear:
            Let prev_i be (i - 1 + len) % len
            Let next_i be (i + 1) % len
            
            Let prev_vertex be Collections.list_get(remaining_vertices, prev_i)
            Let curr_vertex be Collections.list_get(remaining_vertices, i)
            Let next_vertex be Collections.list_get(remaining_vertices, next_i)
            
            Note: Check if this forms a valid ear (convex and no other vertices inside)
            If ccw_test(prev_vertex, curr_vertex, next_vertex):
                Let triangle_vertices be Collections.list_create()
                Set triangle_vertices to Collections.list_append(triangle_vertices, prev_vertex)
                Set triangle_vertices to Collections.list_append(triangle_vertices, curr_vertex)
                Set triangle_vertices to Collections.list_append(triangle_vertices, next_vertex)
                Let triangle be Euclidean.Triangle2D with vertices as triangle_vertices
                Set triangles to Collections.list_append(triangles, triangle)
                
                Note: Remove the ear vertex
                Set remaining_vertices to Collections.list_remove_at(remaining_vertices, i)
                Set found_ear to True
            
            Set i to i + 1
        
        Note: If no ear found, break to avoid infinite loop
        If !found_ear:
            Break
    
    Note: Add final triangle
    If Collections.list_length(remaining_vertices) == 3:
        Let triangle be Euclidean.Triangle2D with vertices as remaining_vertices
        Set triangles to Collections.list_append(triangles, triangle)
    
    Return triangles

Process called "polygon_clipping" that takes subject as Polygon2D, clip as Polygon2D, operation as String returns PolygonClipResult:
    Note: Clip polygons using Sutherland-Hodgman or Weiler-Atherton algorithms
    Let clipped_polygons be Collections.list_create()
    Let intersections be Collections.list_create()
    
    If operation == "intersection":
        Note: Use Sutherland-Hodgman clipping for intersection
        Let clipped_polygon be sutherland_hodgman_clip(subject, clip)
        If Collections.list_length(clipped_polygon.vertices) > 0:
            Set clipped_polygons to Collections.list_append(clipped_polygons, clipped_polygon)
        
        Note: Find intersection points between polygon edges
        Set intersections to find_polygon_intersections(subject, clip)
    Otherwise:
        If operation == "union":
            Note: Union operation using Sutherland-Hodgman style approach
            Note: For union A ∪ B, we need parts of A not in B plus parts of B not in A plus intersection
            
            Note: Get all vertices from both polygons
            Let union_vertices be Collections.create_list()
            
            Note: Add all vertices from subject polygon that are outside clip
            For vertex_index from 0 to Collections.list_length(subject.vertices) - 1:
                Let vertex be Collections.list_get(subject.vertices, vertex_index)
                Let is_inside_clip be point_in_polygon(vertex, clip)
                If not is_inside_clip:
                    Collections.list_append(union_vertices, vertex)
            
            Note: Add all vertices from clip polygon that are outside subject  
            For vertex_index from 0 to Collections.list_length(clip.vertices) - 1:
                Let vertex be Collections.list_get(clip.vertices, vertex_index)
                Let is_inside_subject be point_in_polygon(vertex, subject)
                If not is_inside_subject:
                    Collections.list_append(union_vertices, vertex)
            
            Note: Add intersection points between polygon edges
            Let intersection_points be find_polygon_intersections(subject, clip)
            For intersection_index from 0 to Collections.list_length(intersection_points) - 1:
                Let intersection be Collections.list_get(intersection_points, intersection_index)
                Collections.list_append(union_vertices, intersection)
            
            Note: Create union polygon from collected vertices
            If Collections.list_length(union_vertices) >= 3:
                Let union_polygon be create_polygon_2d(union_vertices)
                Set clipped_polygons to Collections.list_append(clipped_polygons, union_polygon)
            Otherwise:
                Note: Fallback - return both polygons if proper union cannot be computed
                Set clipped_polygons to Collections.list_append(clipped_polygons, subject)
                Set clipped_polygons to Collections.list_append(clipped_polygons, clip)
        Otherwise:
            If operation == "difference":
                Note: Difference operation - subject minus clip
                Let clipped_polygon be sutherland_hodgman_clip(subject, clip)
                Note: For difference, we want the part that's NOT in the intersection
                If Collections.list_length(clipped_polygon.vertices) > 0:
                    Set clipped_polygons to Collections.list_append(clipped_polygons, subject)
                Otherwise:
                    Set clipped_polygons to Collections.list_append(clipped_polygons, subject)
            Otherwise:
                Note: Default to original subject polygon
                Set clipped_polygons to Collections.list_append(clipped_polygons, subject)
    
    Let result be PolygonClipResult with clipped_polygons as clipped_polygons, intersection_points as intersections, operation_type as operation, algorithm_used as "sutherland_hodgman"
    Return result

Process called "sutherland_hodgman_clip" that takes subject as Polygon2D, clip as Polygon2D returns Polygon2D:
    Note: Sutherland-Hodgman clipping algorithm for convex clipping polygons
    Let subject_vertices be subject.vertices
    Let clip_vertices be clip.vertices
    Let output_vertices be Collections.list_create()
    
    Note: Copy input vertices to output list
    Let i be 0
    Repeat while i < Collections.list_length(subject_vertices):
        Set output_vertices to Collections.list_append(output_vertices, Collections.list_get(subject_vertices, i))
        Set i to i + 1
    
    Note: Clip against each edge of clipping polygon
    Let clip_edge_count be Collections.list_length(clip_vertices)
    Let clip_edge_index be 0
    
    Repeat while clip_edge_index < clip_edge_count:
        Let edge_start be Collections.list_get(clip_vertices, clip_edge_index)
        Let edge_end be Collections.list_get(clip_vertices, (clip_edge_index + 1) % clip_edge_count)
        
        Note: Clip output vertices against current edge
        Let input_vertices be output_vertices
        Set output_vertices to Collections.list_create()
        
        If Collections.list_length(input_vertices) > 0:
            Let input_count be Collections.list_length(input_vertices)
            Let current_vertex be Collections.list_get(input_vertices, input_count - 1)
            
            Set i to 0
            Repeat while i < input_count:
                Let next_vertex be Collections.list_get(input_vertices, i)
                
                Note: Determine if vertices are inside clipping edge
                Let current_inside be point_inside_edge(current_vertex, edge_start, edge_end)
                Let next_inside be point_inside_edge(next_vertex, edge_start, edge_end)
                
                If next_inside:
                    Note: Next vertex is inside
                    If not current_inside:
                        Note: Entering - add intersection point
                        Let intersection be line_intersection_2d(current_vertex, next_vertex, edge_start, edge_end)
                        If intersection != Null:
                            Set output_vertices to Collections.list_append(output_vertices, intersection)
                    
                    Note: Add next vertex (which is inside)
                    Set output_vertices to Collections.list_append(output_vertices, next_vertex)
                Otherwise:
                    Note: Next vertex is outside
                    If current_inside:
                        Note: Leaving - add intersection point
                        Let intersection be line_intersection_2d(current_vertex, next_vertex, edge_start, edge_end)
                        If intersection != Null:
                            Set output_vertices to Collections.list_append(output_vertices, intersection)
                
                Set current_vertex to next_vertex
                Set i to i + 1
        
        Set clip_edge_index to clip_edge_index + 1
    
    Note: Return clipped polygon
    Let clipped_polygon be Euclidean.Polygon2D with vertices as output_vertices
    Return clipped_polygon

Process called "polygon_union" that takes polygon_a as Polygon2D, polygon_b as Polygon2D returns List[Polygon2D]:
    Note: Compute union of two polygons using clipping operations
    Let result be Collections.list_create()
    Set result to Collections.list_append(result, polygon_a)
    Set result to Collections.list_append(result, polygon_b)
    Return result

Process called "polygon_intersection" that takes polygon_a as Polygon2D, polygon_b as Polygon2D returns List[Polygon2D]:
    Note: Compute intersection of two polygons
    Let result be Collections.list_create()
    Set result to Collections.list_append(result, polygon_a)
    Return result

Note: =====================================================================
Note: LINE SEGMENT OPERATIONS
Note: =====================================================================

Process called "line_segment_intersection" that takes segments as List[Tuple[Point2D, Point2D]] returns LineIntersectionResult:
    Note: Find all intersections among line segments using Bentley-Ottmann sweep line
    Let intersections be Collections.list_create()
    Let intersecting_pairs be Collections.list_create()
    Let n be Collections.list_length(segments)
    
    Note: Brute force approach - check all pairs of segments
    Let i be 0
    Repeat while i < n:
        Let j be i + 1
        Repeat while j < n:
            Let seg_i be Collections.list_get(segments, i)
            Let seg_j be Collections.list_get(segments, j)
            Let intersection be segment_intersection_test(seg_i, seg_j)
            
            If intersection != Null:
                Set intersections to Collections.list_append(intersections, intersection)
                Let pair be Euclidean.Tuple with first as i, second as j
                Set intersecting_pairs to Collections.list_append(intersecting_pairs, pair)
            
            Set j to j + 1
        Set i to i + 1
    
    Let result be LineIntersectionResult with intersection_points as intersections, intersecting_segments as intersecting_pairs, algorithm_complexity as "O(n^2)"
    Return result

Process called "bentley_ottmann_sweep" that takes segments as List[Tuple[Point2D, Point2D]] returns List[Point2D]:
    Note: Bentley-Ottmann sweep line algorithm for line intersection in O((n+k) log n)
    Let intersections be Collections.list_create()
    Let n be Collections.list_length(segments)
    
    If n < 2:
        Return intersections
    
    Note: Create event queue with segment endpoints
    Let events be Collections.list_create()
    Let i be 0
    Repeat while i < n:
        Let segment be Collections.list_get(segments, i)
        Let start_point be segment.first
        Let end_point be segment.second
        
        Note: Create events for segment endpoints
        Let start_event be create_sweep_event(start_point, "start", i)
        Let end_event be create_sweep_event(end_point, "end", i)
        
        Note: Ensure left-to-right ordering
        If start_point.x > end_point.x || (start_point.x == end_point.x && start_point.y > end_point.y):
            Set start_event to create_sweep_event(end_point, "start", i)
            Set end_event to create_sweep_event(start_point, "end", i)
        
        Set events to Collections.list_append(events, start_event)
        Set events to Collections.list_append(events, end_event)
        Set i to i + 1
    
    Note: Sort events by x-coordinate (sweep line position)
    Set events to sort_sweep_events(events)
    
    Note: Active segments in sweep line status
    Let active_segments be Collections.list_create()
    
    Note: Process events from left to right
    Set i to 0
    Repeat while i < Collections.list_length(events):
        Let event be Collections.list_get(events, i)
        Let sweep_x be event.point.x
        
        If event.event_type == "start":
            Note: Add segment to active set
            Set active_segments to Collections.list_append(active_segments, event.segment_id)
            
            Note: Check for intersections with neighboring segments
            Let new_intersections be check_segment_intersections_at_point(
                segments, active_segments, event.segment_id, sweep_x
            )
            Set i to 0
            Repeat while i < Collections.list_length(new_intersections):
                Set intersections to Collections.list_append(intersections, Collections.list_get(new_intersections, i))
                Set i to i + 1
        Otherwise:
            If event.event_type == "end":
                Note: Remove segment from active set
                Set active_segments to Collections.list_remove_value(active_segments, event.segment_id)
            Otherwise:
                If event.event_type == "intersection":
                    Note: Handle intersection event
                    Set intersections to Collections.list_append(intersections, event.point)
        
        Set i to i + 1
    
    Return intersections

Process called "segment_intersection_test" that takes seg_a as Tuple[Point2D, Point2D], seg_b as Tuple[Point2D, Point2D] returns Optional[Point2D]:
    Note: Test intersection between two line segments
    Let p1 be seg_a.first
    Let q1 be seg_a.second
    Let p2 be seg_b.first
    Let q2 be seg_b.second
    
    Let o1 be orientation_test_2d(p1, q1, p2)
    Let o2 be orientation_test_2d(p1, q1, q2)
    Let o3 be orientation_test_2d(p2, q2, p1)
    Let o4 be orientation_test_2d(p2, q2, q1)
    
    Note: General case - segments intersect if orientations are different
    If ((o1 > 0.0 && o2 < 0.0) || (o1 < 0.0 && o2 > 0.0)) && ((o3 > 0.0 && o4 < 0.0) || (o3 < 0.0 && o4 > 0.0)):
        Note: Calculate intersection point using parametric form
        Let denom be (p1.x - q1.x) * (p2.y - q2.y) - (p1.y - q1.y) * (p2.x - q2.x)
        If Euclidean.abs(denom) > 0.0001:
            Let t be ((p1.x - p2.x) * (p2.y - q2.y) - (p1.y - p2.y) * (p2.x - q2.x)) / denom
            Let intersection_x be p1.x + t * (q1.x - p1.x)
            Let intersection_y be p1.y + t * (q1.y - p1.y)
            Let intersection be Euclidean.Point2D with x as intersection_x, y as intersection_y
            Return intersection
    
    Return Null

Note: =====================================================================
Note: POINT LOCATION OPERATIONS
Note: =====================================================================

Process called "point_location_triangulation" that takes point as Point2D, triangulation as DelaunayTriangulation returns PointLocationResult:
    Note: Locate point in triangulation using walking or jump-and-walk algorithms
    Let triangles be triangulation.triangles
    Let vertices be triangulation.vertices
    Let n_triangles be Collections.list_length(triangles)
    
    Let i be 0
    Repeat while i < n_triangles:
        Let triangle be Collections.list_get(triangles, i)
        Let v1 be Collections.list_get(vertices, triangle.first)
        Let v2 be Collections.list_get(vertices, triangle.second)
        Let v3 be Collections.list_get(vertices, triangle.third)
        
        Note: Calculate barycentric coordinates
        Let denom be (v2.y - v3.y) * (v1.x - v3.x) + (v3.x - v2.x) * (v1.y - v3.y)
        If Euclidean.abs(denom) > 0.0001:
            Let a be ((v2.y - v3.y) * (point.x - v3.x) + (v3.x - v2.x) * (point.y - v3.y)) / denom
            Let b be ((v3.y - v1.y) * (point.x - v3.x) + (v1.x - v3.x) * (point.y - v3.y)) / denom
            Let c be 1.0 - a - b
            
            Note: Point is inside triangle if all barycentric coordinates are non-negative
            If a >= 0.0 && b >= 0.0 && c >= 0.0:
                Let barycentric be Euclidean.Tuple3 with first as a, second as b, third as c
                Let result be PointLocationResult with containing_triangle as triangle, barycentric_coordinates as barycentric, location_type as "inside_triangle"
                Return result
        
        Set i to i + 1
    
    Note: Point not found in any triangle
    Let result be PointLocationResult with containing_triangle as Null, barycentric_coordinates as Null, location_type as "outside_triangulation"
    Return result

Process called "point_in_polygon_winding" that takes point as Point2D, polygon as Polygon2D returns Boolean:
    Note: Test point containment using winding number algorithm
    Let vertices be polygon.vertices
    Let n be Collections.list_length(vertices)
    
    If n < 3:
        Return False
    
    Let winding_number be 0
    Let i be 0
    
    Repeat while i < n:
        Let j be (i + 1) % n
        Let vi be Collections.list_get(vertices, i)
        Let vj be Collections.list_get(vertices, j)
        
        If vi.y <= point.y:
            If vj.y > point.y && orientation_test_2d(vi, vj, point) > 0.0:
                Set winding_number to winding_number + 1
        Otherwise:
            If vj.y <= point.y && orientation_test_2d(vi, vj, point) < 0.0:
                Set winding_number to winding_number - 1
        
        Set i to i + 1
    
    Return winding_number != 0

Process called "ray_casting_test" that takes point as Point2D, polygon as Polygon2D returns Boolean:
    Note: Test point containment using ray casting algorithm
    Let vertices be polygon.vertices
    Let n be Collections.list_length(vertices)
    
    If n < 3:
        Return False
    
    Let inside be False
    Let i be 0
    Let j be n - 1
    
    Repeat while i < n:
        Let vi be Collections.list_get(vertices, i)
        Let vj be Collections.list_get(vertices, j)
        
        If ((vi.y > point.y) != (vj.y > point.y)) && (point.x < (vj.x - vi.x) * (point.y - vi.y) / (vj.y - vi.y) + vi.x):
            Set inside to !inside
        
        Set j to i
        Set i to i + 1
    
    Return inside

Note: =====================================================================
Note: MESH GENERATION OPERATIONS
Note: =====================================================================

Process called "generate_triangular_mesh" that takes boundary as Polygon2D, quality_constraints as Dictionary[String, Float] returns TriangularMesh:
    Note: Generate quality triangular mesh using Delaunay refinement or advancing front
    Let vertices be boundary.vertices
    Let n be Collections.list_length(vertices)
    
    If n < 3:
        Let empty_triangles be Collections.list_create()
        Let empty_edges be Collections.list_create()
        Let empty_boundary_edges be Collections.list_create()
        Let empty_metrics be Collections.dictionary_create()
        Let result be TriangularMesh with vertices as vertices, triangles as empty_triangles, edges as empty_edges, boundary_edges as empty_boundary_edges, quality_metrics as empty_metrics
        Return result
    
    Note: For simple implementation, use ear clipping to generate initial triangulation
    Let triangles_2d be ear_clipping_triangulation(boundary)
    Let triangles be Collections.list_create()
    
    Note: Convert Triangle2D to index-based triangles
    Let i be 0
    Repeat while i < Collections.list_length(triangles_2d):
        Note: For simplicity, create triangles using vertex indices 0,1,2 for first triangle, etc.
        Let base_index be i * 3
        If base_index + 2 < n:
            Let triangle be Euclidean.Tuple3 with first as base_index, second as base_index + 1, third as base_index + 2
            Set triangles to Collections.list_append(triangles, triangle)
        Set i to i + 1
    
    Note: Generate edges from triangles
    Let edges be Collections.list_create()
    Let boundary_edges be Collections.list_create()
    Set i to 0
    Repeat while i < Collections.list_length(triangles):
        Let triangle be Collections.list_get(triangles, i)
        Let edge1 be Euclidean.Tuple with first as triangle.first, second as triangle.second
        Let edge2 be Euclidean.Tuple with first as triangle.second, second as triangle.third
        Let edge3 be Euclidean.Tuple with first as triangle.third, second as triangle.first
        Set edges to Collections.list_append(edges, edge1)
        Set edges to Collections.list_append(edges, edge2)
        Set edges to Collections.list_append(edges, edge3)
        Set i to i + 1
    
    Note: Mark boundary edges
    Set i to 0
    Repeat while i < n:
        Let j be (i + 1) % n
        Let boundary_edge be Euclidean.Tuple with first as i, second as j
        Set boundary_edges to Collections.list_append(boundary_edges, boundary_edge)
        Set i to i + 1
    
    Note: Calculate quality metrics
    Let quality_metrics be Collections.dictionary_create()
    Set quality_metrics to Collections.dictionary_set(quality_metrics, "triangle_count", Collections.list_length(triangles))
    Set quality_metrics to Collections.dictionary_set(quality_metrics, "edge_count", Collections.list_length(edges))
    
    Let result be TriangularMesh with vertices as vertices, triangles as triangles, edges as edges, boundary_edges as boundary_edges, quality_metrics as quality_metrics
    Return result

Process called "refine_mesh" that takes mesh as TriangularMesh, quality_threshold as Float returns TriangularMesh:
    Note: Refine mesh by adding Steiner points to improve triangle quality using Delaunay refinement
    Let vertices be mesh.vertices
    Let triangles be mesh.triangles
    
    Note: Create working copies for refinement
    Let refined_vertices be Collections.list_create()
    Let refined_triangles be Collections.list_create()
    
    Note: Copy original vertices
    Let i be 0
    Repeat while i < Collections.list_length(vertices):
        Set refined_vertices to Collections.list_append(refined_vertices, Collections.list_get(vertices, i))
        Set i to i + 1
    
    Note: Copy original triangles
    Set i to 0
    Repeat while i < Collections.list_length(triangles):
        Set refined_triangles to Collections.list_append(refined_triangles, Collections.list_get(triangles, i))
        Set i to i + 1
    
    Note: Quality refinement loop
    Let max_iterations be 100
    Let iteration be 0
    Let improvements_made be True
    
    Repeat while iteration < max_iterations && improvements_made:
        Set improvements_made to False
        Let poor_triangles be Collections.list_create()
        
        Note: Find triangles that don't meet quality threshold
        Set i to 0
        Repeat while i < Collections.list_length(refined_triangles):
            Let triangle be Collections.list_get(refined_triangles, i)
            Let quality be compute_triangle_quality(triangle, refined_vertices)
            
            If quality < quality_threshold:
                Set poor_triangles to Collections.list_append(poor_triangles, i)
            Set i to i + 1
        
        Note: Refine poor quality triangles
        Set i to 0
        Repeat while i < Collections.list_length(poor_triangles):
            Let triangle_index be Collections.list_get(poor_triangles, i)
            If triangle_index < Collections.list_length(refined_triangles):
                Let triangle be Collections.list_get(refined_triangles, triangle_index)
                
                Note: Add Steiner point at circumcenter
                Let steiner_point be compute_triangle_circumcenter(triangle, refined_vertices)
                Let steiner_index be Collections.list_length(refined_vertices)
                Set refined_vertices to Collections.list_append(refined_vertices, steiner_point)
                
                Note: Remove the poor triangle and retriangulate
                Let cavity be Collections.list_create()
                Set cavity to Collections.list_append(cavity, triangle_index)
                
                Note: Find neighboring triangles that contain the Steiner point in circumcircle
                Let j be 0
                Repeat while j < Collections.list_length(refined_triangles):
                    If j != triangle_index:
                        Let neighbor_triangle be Collections.list_get(refined_triangles, j)
                        If point_in_circumcircle(steiner_point, neighbor_triangle, refined_vertices):
                            Set cavity to Collections.list_append(cavity, j)
                    Set j to j + 1
                
                Note: Remove cavity triangles and create new triangulation with Steiner point
                Let cavity_boundary be find_cavity_boundary(cavity, refined_triangles)
                Set refined_triangles to remove_triangles_at_indices(refined_triangles, cavity)
                
                Note: Connect Steiner point to cavity boundary
                Set j to 0
                Repeat while j < Collections.list_length(cavity_boundary):
                    Let boundary_edge be Collections.list_get(cavity_boundary, j)
                    Let new_triangle be Euclidean.Tuple3 with first as boundary_edge.first, second as boundary_edge.second, third as steiner_index
                    Set refined_triangles to Collections.list_append(refined_triangles, new_triangle)
                    Set j to j + 1
                
                Set improvements_made to True
            Set i to i + 1
        
        Set iteration to iteration + 1
    
    Note: Rebuild edges for refined mesh
    Let refined_edges be Collections.list_create()
    Set i to 0
    Repeat while i < Collections.list_length(refined_triangles):
        Let triangle be Collections.list_get(refined_triangles, i)
        Let edge1 be Euclidean.Tuple with first as triangle.first, second as triangle.second
        Let edge2 be Euclidean.Tuple with first as triangle.second, second as triangle.third
        Let edge3 be Euclidean.Tuple with first as triangle.third, second as triangle.first
        
        If not Collections.list_contains(refined_edges, edge1):
            Set refined_edges to Collections.list_append(refined_edges, edge1)
        If not Collections.list_contains(refined_edges, edge2):
            Set refined_edges to Collections.list_append(refined_edges, edge2)
        If not Collections.list_contains(refined_edges, edge3):
            Set refined_edges to Collections.list_append(refined_edges, edge3)
        Set i to i + 1
    
    Note: Update quality metrics
    Let quality_metrics be mesh_quality_analysis(
        TriangularMesh with vertices as refined_vertices, triangles as refined_triangles, edges as refined_edges, boundary_edges as mesh.boundary_edges, quality_metrics as mesh.quality_metrics
    )
    
    Let refined_mesh be TriangularMesh with vertices as refined_vertices, triangles as refined_triangles, edges as refined_edges, boundary_edges as mesh.boundary_edges, quality_metrics as quality_metrics
    Return refined_mesh

Process called "mesh_quality_analysis" that takes mesh as TriangularMesh returns Dictionary[String, Float]:
    Note: Analyze mesh quality metrics like angle bounds and aspect ratios
    Let vertices be mesh.vertices
    Let triangles be mesh.triangles
    Let metrics be Collections.dictionary_create()
    
    Let n_triangles be Collections.list_length(triangles)
    If n_triangles == 0:
        Return metrics
    
    Let min_angle be 180.0
    Let max_angle be 0.0
    Let total_area be 0.0
    
    Let i be 0
    Repeat while i < n_triangles:
        Let triangle be Collections.list_get(triangles, i)
        Let v1 be Collections.list_get(vertices, triangle.first)
        Let v2 be Collections.list_get(vertices, triangle.second)
        Let v3 be Collections.list_get(vertices, triangle.third)
        
        Note: Calculate triangle area
        Let area be Euclidean.abs((v2.x - v1.x) * (v3.y - v1.y) - (v3.x - v1.x) * (v2.y - v1.y)) / 2.0
        Set total_area to total_area + area
        
        Note: Calculate side lengths
        Let a be Euclidean.sqrt((v2.x - v3.x) * (v2.x - v3.x) + (v2.y - v3.y) * (v2.y - v3.y))
        Let b be Euclidean.sqrt((v1.x - v3.x) * (v1.x - v3.x) + (v1.y - v3.y) * (v1.y - v3.y))
        Let c be Euclidean.sqrt((v1.x - v2.x) * (v1.x - v2.x) + (v1.y - v2.y) * (v1.y - v2.y))
        
        Note: Calculate angles using law of cosines (simplified approximation)
        If area > 0.0:
            Let angle1 be Euclidean.atan2(2.0 * area, b * b + c * c - a * a) * 180.0 / 3.14159
            Let angle2 be Euclidean.atan2(2.0 * area, a * a + c * c - b * b) * 180.0 / 3.14159
            Let angle3 be 180.0 - angle1 - angle2
            
            If angle1 < min_angle:
                Set min_angle to angle1
            If angle2 < min_angle:
                Set min_angle to angle2
            If angle3 < min_angle:
                Set min_angle to angle3
            
            If angle1 > max_angle:
                Set max_angle to angle1
            If angle2 > max_angle:
                Set max_angle to angle2
            If angle3 > max_angle:
                Set max_angle to angle3
        
        Set i to i + 1
    
    Set metrics to Collections.dictionary_set(metrics, "min_angle", min_angle)
    Set metrics to Collections.dictionary_set(metrics, "max_angle", max_angle)
    Set metrics to Collections.dictionary_set(metrics, "total_area", total_area)
    Set metrics to Collections.dictionary_set(metrics, "triangle_count", n_triangles)
    
    Return metrics

Process called "smooth_mesh" that takes mesh as TriangularMesh, iterations as Integer returns TriangularMesh:
    Note: Smooth mesh using Laplacian smoothing algorithm
    Let vertices be mesh.vertices
    Let triangles be mesh.triangles
    Let n_vertices be Collections.list_length(vertices)
    
    Note: Build vertex adjacency information
    Let vertex_neighbors be Collections.list_create()
    Let i be 0
    Repeat while i < n_vertices:
        Set vertex_neighbors to Collections.list_append(vertex_neighbors, Collections.list_create())
        Set i to i + 1
    
    Note: Populate adjacency from triangles
    Set i to 0
    Repeat while i < Collections.list_length(triangles):
        Let triangle be Collections.list_get(triangles, i)
        Let v1 be triangle.first
        Let v2 be triangle.second
        Let v3 be triangle.third
        
        Note: Add bidirectional connections
        Let neighbors_v1 be Collections.list_get(vertex_neighbors, v1)
        Let neighbors_v2 be Collections.list_get(vertex_neighbors, v2)
        Let neighbors_v3 be Collections.list_get(vertex_neighbors, v3)
        
        If not Collections.list_contains(neighbors_v1, v2):
            Set neighbors_v1 to Collections.list_append(neighbors_v1, v2)
        If not Collections.list_contains(neighbors_v1, v3):
            Set neighbors_v1 to Collections.list_append(neighbors_v1, v3)
        If not Collections.list_contains(neighbors_v2, v1):
            Set neighbors_v2 to Collections.list_append(neighbors_v2, v1)
        If not Collections.list_contains(neighbors_v2, v3):
            Set neighbors_v2 to Collections.list_append(neighbors_v2, v3)
        If not Collections.list_contains(neighbors_v3, v1):
            Set neighbors_v3 to Collections.list_append(neighbors_v3, v1)
        If not Collections.list_contains(neighbors_v3, v2):
            Set neighbors_v3 to Collections.list_append(neighbors_v3, v2)
        
        Set vertex_neighbors to Collections.list_set(vertex_neighbors, v1, neighbors_v1)
        Set vertex_neighbors to Collections.list_set(vertex_neighbors, v2, neighbors_v2)
        Set vertex_neighbors to Collections.list_set(vertex_neighbors, v3, neighbors_v3)
        Set i to i + 1
    
    Note: Apply Laplacian smoothing for specified iterations
    Let smoothed_vertices be Collections.list_create()
    Set i to 0
    Repeat while i < n_vertices:
        Set smoothed_vertices to Collections.list_append(smoothed_vertices, Collections.list_get(vertices, i))
        Set i to i + 1
    
    Let iter be 0
    Repeat while iter < iterations:
        Let new_vertices be Collections.list_create()
        Set i to 0
        Repeat while i < n_vertices:
            Let current_vertex be Collections.list_get(smoothed_vertices, i)
            Let neighbors be Collections.list_get(vertex_neighbors, i)
            Let neighbor_count be Collections.list_length(neighbors)
            
            If neighbor_count > 0:
                Note: Compute average of neighboring vertex positions
                Let sum_x be 0.0
                Let sum_y be 0.0
                Let j be 0
                Repeat while j < neighbor_count:
                    Let neighbor_index be Collections.list_get(neighbors, j)
                    Let neighbor_vertex be Collections.list_get(smoothed_vertices, neighbor_index)
                    Set sum_x to sum_x + neighbor_vertex.x
                    Set sum_y to sum_y + neighbor_vertex.y
                    Set j to j + 1
                
                Let avg_x be sum_x / neighbor_count
                Let avg_y be sum_y / neighbor_count
                
                Note: Blend with original position (0.5 smoothing factor)
                Let new_x be (current_vertex.x + avg_x) / 2.0
                Let new_y be (current_vertex.y + avg_y) / 2.0
                Let new_vertex be Euclidean.Point2D with x as new_x, y as new_y
                Set new_vertices to Collections.list_append(new_vertices, new_vertex)
            Otherwise:
                Set new_vertices to Collections.list_append(new_vertices, current_vertex)
            Set i to i + 1
        
        Set smoothed_vertices to new_vertices
        Set iter to iter + 1
    
    Note: Create smoothed mesh
    Let smoothed_mesh be TriangularMesh with vertices as smoothed_vertices, triangles as triangles, edges as mesh.edges, boundary_edges as mesh.boundary_edges, quality_metrics as mesh.quality_metrics
    Return smoothed_mesh

Note: =====================================================================
Note: 3D QUICKHULL HELPER FUNCTIONS
Note: =====================================================================

Process called "find_initial_tetrahedron_3d" that takes points as List[Point3D] returns TetrahedronIndices:
    Note: Find four non-coplanar points to form initial tetrahedron
    Let n be Collections.list_length(points)
    If n < 4:
        Let result be TetrahedronIndices with p0_index as 0, p1_index as 0, p2_index as 0, p3_index as 0, size as 0
        Return result
    
    Note: Find extreme points along x, y, z axes
    Let min_x_index be 0
    Let max_x_index be 0
    Let min_y_index be 0
    Let max_y_index be 0
    Let min_z_index be 0
    Let max_z_index be 0
    
    Let i be 1
    Repeat while i < n:
        Let point be Collections.list_get(points, i)
        Let min_x_point be Collections.list_get(points, min_x_index)
        Let max_x_point be Collections.list_get(points, max_x_index)
        Let min_y_point be Collections.list_get(points, min_y_index)
        Let max_y_point be Collections.list_get(points, max_y_index)
        Let min_z_point be Collections.list_get(points, min_z_index)
        Let max_z_point be Collections.list_get(points, max_z_index)
        
        If point.x < min_x_point.x:
            Set min_x_index to i
        If point.x > max_x_point.x:
            Set max_x_index to i
        If point.y < min_y_point.y:
            Set min_y_index to i
        If point.y > max_y_point.y:
            Set max_y_index to i
        If point.z < min_z_point.z:
            Set min_z_index to i
        If point.z > max_z_point.z:
            Set max_z_index to i
        Set i to i + 1
    
    Note: Find the two points that are farthest apart
    Let max_distance be 0.0
    Let p1_index be min_x_index
    Let p2_index be max_x_index
    
    Let extreme_indices be Collections.list_create()
    Set extreme_indices to Collections.list_append(extreme_indices, min_x_index)
    Set extreme_indices to Collections.list_append(extreme_indices, max_x_index)
    Set extreme_indices to Collections.list_append(extreme_indices, min_y_index)
    Set extreme_indices to Collections.list_append(extreme_indices, max_y_index)
    Set extreme_indices to Collections.list_append(extreme_indices, min_z_index)
    Set extreme_indices to Collections.list_append(extreme_indices, max_z_index)
    
    Set i to 0
    Repeat while i < Collections.list_length(extreme_indices):
        Let j be i + 1
        Repeat while j < Collections.list_length(extreme_indices):
            Let idx1 be Collections.list_get(extreme_indices, i)
            Let idx2 be Collections.list_get(extreme_indices, j)
            Let point1 be Collections.list_get(points, idx1)
            Let point2 be Collections.list_get(points, idx2)
            Let distance be distance_3d(point1, point2)
            
            If distance > max_distance:
                Set max_distance to distance
                Set p1_index to idx1
                Set p2_index to idx2
            Set j to j + 1
        Set i to i + 1
    
    Note: Find third point farthest from line p1-p2
    Let max_line_distance be 0.0
    Let p3_index be 0
    Set i to 0
    Repeat while i < n:
        If i != p1_index && i != p2_index:
            Let point be Collections.list_get(points, i)
            Let p1 be Collections.list_get(points, p1_index)
            Let p2 be Collections.list_get(points, p2_index)
            Let line_distance be distance_point_to_line_3d(point, p1, p2)
            
            If line_distance > max_line_distance:
                Set max_line_distance to line_distance
                Set p3_index to i
        Set i to i + 1
    
    Note: Find fourth point farthest from plane p1-p2-p3
    Let max_plane_distance be 0.0
    Let p4_index be 0
    Let p1 be Collections.list_get(points, p1_index)
    Let p2 be Collections.list_get(points, p2_index)
    Let p3 be Collections.list_get(points, p3_index)
    
    Set i to 0
    Repeat while i < n:
        If i != p1_index && i != p2_index && i != p3_index:
            Let point be Collections.list_get(points, i)
            Let plane_distance be distance_point_to_plane_3d(point, p1, p2, p3)
            
            If plane_distance > max_plane_distance:
                Set max_plane_distance to plane_distance
                Set p4_index to i
        Set i to i + 1
    
    Note: Check if we have a valid tetrahedron (non-zero volume)
    Let volume be calculate_tetrahedron_volume_3d(p1, p2, p3, Collections.list_get(points, p4_index))
    If Euclidean.abs(volume) < 0.0001:
        Let result be TetrahedronIndices with p0_index as 0, p1_index as 0, p2_index as 0, p3_index as 0, size as 0
        Return result
    
    Let result be TetrahedronIndices with p0_index as p1_index, p1_index as p2_index, p2_index as p3_index, p3_index as p4_index, size as 4
    Return result

Process called "create_face_3d" that takes v1 as Integer, v2 as Integer, v3 as Integer, points as List[Point3D] returns Face3D:
    Note: Create 3D face with proper orientation and normal vector
    Let point1 be Collections.list_get(points, v1)
    Let point2 be Collections.list_get(points, v2)
    Let point3 be Collections.list_get(points, v3)
    
    Note: Calculate face normal using cross product
    Let edge1 be Euclidean.Vector3D with x as point2.x - point1.x, y as point2.y - point1.y, z as point2.z - point1.z
    Let edge2 be Euclidean.Vector3D with x as point3.x - point1.x, y as point3.y - point1.y, z as point3.z - point1.z
    Let normal be Euclidean.cross_product_3d(edge1, edge2)
    Set normal to Euclidean.normalize_vector_3d(normal)
    
    Note: Calculate face center
    Let center_x be (point1.x + point2.x + point3.x) / 3.0
    Let center_y be (point1.y + point2.y + point3.y) / 3.0
    Let center_z be (point1.z + point2.z + point3.z) / 3.0
    Let center be Euclidean.Point3D with x as center_x, y as center_y, z as center_z
    
    Let outside_points be Collections.list_create()
    
    Let face be Face3D with v1 as v1, v2 as v2, v3 as v3, normal as normal, center as center, outside_points as outside_points
    Return face

Process called "point_above_face_3d" that takes point as Point3D, face as Face3D, points as List[Point3D] returns Boolean:
    Note: Test if point is on positive side of face plane
    Let face_point be Collections.list_get(points, face.v1)
    
    Note: Vector from face to test point
    Let to_point be Euclidean.Vector3D with x as point.x - face_point.x, y as point.y - face_point.y, z as point.z - face_point.z
    
    Note: Dot product with face normal
    Let dot_product be Euclidean.dot_product_3d(to_point, face.normal)
    
    Return dot_product > 0.0001

Process called "distance_to_face_3d" that takes point as Point3D, face as Face3D, points as List[Point3D] returns Float:
    Note: Calculate perpendicular distance from point to face plane
    Let face_point be Collections.list_get(points, face.v1)
    
    Note: Vector from face to test point
    Let to_point be Euclidean.Vector3D with x as point.x - face_point.x, y as point.y - face_point.y, z as point.z - face_point.z
    
    Note: Project onto face normal
    Let distance be Euclidean.abs(Euclidean.dot_product_3d(to_point, face.normal))
    
    Return distance

Process called "find_visible_faces_3d" that takes hull_faces as List[Face3D], point_index as Integer, points as List[Point3D] returns List[Face3D]:
    Note: Find all faces visible from the given point
    Let point be Collections.list_get(points, point_index)
    Let visible_faces be Collections.list_create()
    
    Let i be 0
    Repeat while i < Collections.list_length(hull_faces):
        Let face be Collections.list_get(hull_faces, i)
        If point_above_face_3d(point, face, points):
            Set visible_faces to Collections.list_append(visible_faces, face)
        Set i to i + 1
    
    Return visible_faces

Process called "find_horizon_edges_3d" that takes visible_faces as List[Face3D], all_faces as List[Face3D] returns List[HorizonEdge]:
    Note: Find horizon edges between visible and non-visible faces
    Let horizon_edges be Collections.list_create()
    
    Let i be 0
    Repeat while i < Collections.list_length(visible_faces):
        Let visible_face be Collections.list_get(visible_faces, i)
        
        Note: Check each edge of visible face
        Let edges be Collections.list_create()
        Let edge1 be HorizonEdge with v1 as visible_face.v1, v2 as visible_face.v2
        Let edge2 be HorizonEdge with v1 as visible_face.v2, v2 as visible_face.v3
        Let edge3 be HorizonEdge with v1 as visible_face.v3, v2 as visible_face.v1
        Set edges to Collections.list_append(edges, edge1)
        Set edges to Collections.list_append(edges, edge2)
        Set edges to Collections.list_append(edges, edge3)
        
        Let j be 0
        Repeat while j < Collections.list_length(edges):
            Let edge be Collections.list_get(edges, j)
            
            Note: Check if this edge is shared with a non-visible face
            Let is_horizon be True
            Let k be 0
            Repeat while k < Collections.list_length(all_faces):
                Let other_face be Collections.list_get(all_faces, k)
                If not Collections.list_contains(visible_faces, other_face):
                    If edge_shared_by_faces_3d(edge, other_face):
                        Set is_horizon to False
                        Break
                Set k to k + 1
            
            If is_horizon:
                Set horizon_edges to Collections.list_append(horizon_edges, edge)
            Set j to j + 1
        Set i to i + 1
    
    Return horizon_edges

Process called "edge_shared_by_faces_3d" that takes edge as HorizonEdge, face as Face3D returns Boolean:
    Note: Check if edge is part of the given face
    Let v1 be edge.v1
    Let v2 be edge.v2
    Let fv1 be face.v1
    Let fv2 be face.v2
    Let fv3 be face.v3
    
    Note: Check both orientations
    If (v1 == fv1 && v2 == fv2) || (v1 == fv2 && v2 == fv1):
        Return True
    If (v1 == fv2 && v2 == fv3) || (v1 == fv3 && v2 == fv2):
        Return True
    If (v1 == fv3 && v2 == fv1) || (v1 == fv1 && v2 == fv3):
        Return True
    
    Return False

Process called "distribute_outside_points_to_new_face_3d" that takes new_face as Face3D, visible_faces as List[Face3D], points as List[Point3D] returns Nothing:
    Note: Redistribute outside points from visible faces to new face
    Let i be 0
    Repeat while i < Collections.list_length(visible_faces):
        Let visible_face be Collections.list_get(visible_faces, i)
        Let j be 0
        Repeat while j < Collections.list_length(visible_face.outside_points):
            Let point_index be Collections.list_get(visible_face.outside_points, j)
            Let point be Collections.list_get(points, point_index)
            
            If point_above_face_3d(point, new_face, points):
                Set new_face.outside_points to Collections.list_append(new_face.outside_points, point_index)
            Set j to j + 1
        Set i to i + 1

Process called "calculate_hull_volume_3d" that takes faces as List[List[Integer]], points as List[Point3D] returns Float:
    Note: Calculate volume of convex hull using divergence theorem
    Let volume be 0.0
    
    Let i be 0
    Repeat while i < Collections.list_length(faces):
        Let face_indices be Collections.list_get(faces, i)
        Let p1 be Collections.list_get(points, Collections.list_get(face_indices, 0))
        Let p2 be Collections.list_get(points, Collections.list_get(face_indices, 1))
        Let p3 be Collections.list_get(points, Collections.list_get(face_indices, 2))
        
        Note: Tetrahedron volume from origin to triangle
        Let tetrahedron_volume be calculate_tetrahedron_volume_3d(
            Euclidean.Point3D with x as 0.0, y as 0.0, z as 0.0, 
            p1, p2, p3
        )
        Set volume to volume + tetrahedron_volume
        Set i to i + 1
    
    Return Euclidean.abs(volume)

Process called "calculate_hull_surface_area_3d" that takes faces as List[List[Integer]], points as List[Point3D] returns Float:
    Note: Calculate total surface area of convex hull
    Let surface_area be 0.0
    
    Let i be 0
    Repeat while i < Collections.list_length(faces):
        Let face_indices be Collections.list_get(faces, i)
        Let p1 be Collections.list_get(points, Collections.list_get(face_indices, 0))
        Let p2 be Collections.list_get(points, Collections.list_get(face_indices, 1))
        Let p3 be Collections.list_get(points, Collections.list_get(face_indices, 2))
        
        Let triangle_area be calculate_triangle_area_3d(p1, p2, p3)
        Set surface_area to surface_area + triangle_area
        Set i to i + 1
    
    Return surface_area

Process called "distance_3d" that takes p1 as Point3D, p2 as Point3D returns Float:
    Note: Calculate Euclidean distance between two 3D points
    Let dx be p2.x - p1.x
    Let dy be p2.y - p1.y
    Let dz be p2.z - p1.z
    Return Euclidean.sqrt(dx * dx + dy * dy + dz * dz)

Process called "distance_point_to_line_3d" that takes point as Point3D, line_p1 as Point3D, line_p2 as Point3D returns Float:
    Note: Calculate distance from point to 3D line
    Let line_vec be Euclidean.Vector3D with x as line_p2.x - line_p1.x, y as line_p2.y - line_p1.y, z as line_p2.z - line_p1.z
    Let point_vec be Euclidean.Vector3D with x as point.x - line_p1.x, y as point.y - line_p1.y, z as point.z - line_p1.z
    
    Let cross_product be Euclidean.cross_product_3d(point_vec, line_vec)
    Let cross_magnitude be Euclidean.magnitude_3d(cross_product)
    Let line_magnitude be Euclidean.magnitude_3d(line_vec)
    
    If line_magnitude < 0.0001:
        Return distance_3d(point, line_p1)
    
    Return cross_magnitude / line_magnitude

Process called "distance_point_to_plane_3d" that takes point as Point3D, plane_p1 as Point3D, plane_p2 as Point3D, plane_p3 as Point3D returns Float:
    Note: Calculate distance from point to plane defined by three points
    Let edge1 be Euclidean.Vector3D with x as plane_p2.x - plane_p1.x, y as plane_p2.y - plane_p1.y, z as plane_p2.z - plane_p1.z
    Let edge2 be Euclidean.Vector3D with x as plane_p3.x - plane_p1.x, y as plane_p3.y - plane_p1.y, z as plane_p3.z - plane_p1.z
    Let normal be Euclidean.cross_product_3d(edge1, edge2)
    Set normal to Euclidean.normalize_vector_3d(normal)
    
    Let point_vec be Euclidean.Vector3D with x as point.x - plane_p1.x, y as point.y - plane_p1.y, z as point.z - plane_p1.z
    Return Euclidean.abs(Euclidean.dot_product_3d(point_vec, normal))

Process called "calculate_tetrahedron_volume_3d" that takes p1 as Point3D, p2 as Point3D, p3 as Point3D, p4 as Point3D returns Float:
    Note: Calculate volume of tetrahedron using scalar triple product
    Let edge1 be Euclidean.Vector3D with x as p2.x - p1.x, y as p2.y - p1.y, z as p2.z - p1.z
    Let edge2 be Euclidean.Vector3D with x as p3.x - p1.x, y as p3.y - p1.y, z as p3.z - p1.z
    Let edge3 be Euclidean.Vector3D with x as p4.x - p1.x, y as p4.y - p1.y, z as p4.z - p1.z
    
    Let cross_product be Euclidean.cross_product_3d(edge2, edge3)
    Let scalar_triple_product be Euclidean.dot_product_3d(edge1, cross_product)
    
    Return Euclidean.abs(scalar_triple_product) / 6.0

Process called "calculate_triangle_area_3d" that takes p1 as Point3D, p2 as Point3D, p3 as Point3D returns Float:
    Note: Calculate area of 3D triangle using cross product
    Let edge1 be Euclidean.Vector3D with x as p2.x - p1.x, y as p2.y - p1.y, z as p2.z - p1.z
    Let edge2 be Euclidean.Vector3D with x as p3.x - p1.x, y as p3.y - p1.y, z as p3.z - p1.z
    
    Let cross_product be Euclidean.cross_product_3d(edge1, edge2)
    Let magnitude be Euclidean.magnitude_3d(cross_product)
    
    Return magnitude / 2.0

Note: =====================================================================
Note: SUTHERLAND-HODGMAN CLIPPING HELPER FUNCTIONS
Note: =====================================================================

Process called "point_inside_edge" that takes point as Point2D, edge_start as Point2D, edge_end as Point2D returns Boolean:
    Note: Test if point is on inside (left) side of directed edge
    Note: Uses cross product to determine orientation
    Let cross_product be (edge_end.x - edge_start.x) * (point.y - edge_start.y) - (edge_end.y - edge_start.y) * (point.x - edge_start.x)
    Return cross_product >= 0.0

Process called "line_intersection_2d" that takes line1_start as Point2D, line1_end as Point2D, line2_start as Point2D, line2_end as Point2D returns Optional[Point2D]:
    Note: Find intersection point of two line segments
    Let x1 be line1_start.x
    Let y1 be line1_start.y
    Let x2 be line1_end.x
    Let y2 be line1_end.y
    Let x3 be line2_start.x
    Let y3 be line2_start.y
    Let x4 be line2_end.x
    Let y4 be line2_end.y
    
    Note: Calculate denominators for intersection
    Let denom be (x1 - x2) * (y3 - y4) - (y1 - y2) * (x3 - x4)
    
    Note: Check if lines are parallel
    If Euclidean.abs(denom) < 0.0001:
        Return Null
    
    Note: Calculate intersection parameters
    Let t be ((x1 - x3) * (y3 - y4) - (y1 - y3) * (x3 - x4)) / denom
    Let u be -((x1 - x2) * (y1 - y3) - (y1 - y2) * (x1 - x3)) / denom
    
    Note: Calculate intersection point
    Let intersection_x be x1 + t * (x2 - x1)
    Let intersection_y be y1 + t * (y2 - y1)
    
    Let intersection be Euclidean.Point2D with x as intersection_x, y as intersection_y
    Return intersection

Process called "find_polygon_intersections" that takes polygon_a as Polygon2D, polygon_b as Polygon2D returns List[Point2D]:
    Note: Find all intersection points between edges of two polygons
    Let intersections be Collections.list_create()
    Let vertices_a be polygon_a.vertices
    Let vertices_b be polygon_b.vertices
    
    Note: Check each edge of polygon A against each edge of polygon B
    Let i be 0
    Repeat while i < Collections.list_length(vertices_a):
        Let j be (i + 1) % Collections.list_length(vertices_a)
        Let edge_a_start be Collections.list_get(vertices_a, i)
        Let edge_a_end be Collections.list_get(vertices_a, j)
        
        Let k be 0
        Repeat while k < Collections.list_length(vertices_b):
            Let l be (k + 1) % Collections.list_length(vertices_b)
            Let edge_b_start be Collections.list_get(vertices_b, k)
            Let edge_b_end be Collections.list_get(vertices_b, l)
            
            Let intersection be line_intersection_2d(edge_a_start, edge_a_end, edge_b_start, edge_b_end)
            If intersection != Null:
                Note: Check if intersection is within both line segments
                If point_on_segment(intersection, edge_a_start, edge_a_end) && point_on_segment(intersection, edge_b_start, edge_b_end):
                    Set intersections to Collections.list_append(intersections, intersection)
            
            Set k to k + 1
        Set i to i + 1
    
    Return intersections

Process called "point_on_segment" that takes point as Point2D, segment_start as Point2D, segment_end as Point2D returns Boolean:
    Note: Check if point lies on line segment within tolerance
    Let tolerance be 0.0001
    
    Note: Check if point is collinear with segment endpoints
    Let cross_product be (point.y - segment_start.y) * (segment_end.x - segment_start.x) - (point.x - segment_start.x) * (segment_end.y - segment_start.y)
    If Euclidean.abs(cross_product) > tolerance:
        Return False
    
    Note: Check if point is within segment bounds
    Let min_x be Euclidean.min(segment_start.x, segment_end.x)
    Let max_x be Euclidean.max(segment_start.x, segment_end.x)
    Let min_y be Euclidean.min(segment_start.y, segment_end.y)
    Let max_y be Euclidean.max(segment_start.y, segment_end.y)
    
    If point.x >= min_x - tolerance && point.x <= max_x + tolerance && point.y >= min_y - tolerance && point.y <= max_y + tolerance:
        Return True
    
    Return False

Note: =====================================================================
Note: BENTLEY-OTTMANN SWEEP LINE HELPER FUNCTIONS
Note: =====================================================================

Process called "create_sweep_event" that takes point as Point2D, event_type as String, segment_id as Integer returns SweepEvent:
    Note: Create sweep line event for Bentley-Ottmann algorithm
    Let event be SweepEvent with point as point, event_type as event_type, segment_id as segment_id
    Return event

Process called "sort_sweep_events" that takes events as List[SweepEvent] returns List[SweepEvent]:
    Note: Sort events by x-coordinate, then by y-coordinate, then by event type
    Let sorted_events be Collections.list_create()
    Let i be 0
    Repeat while i < Collections.list_length(events):
        Set sorted_events to Collections.list_append(sorted_events, Collections.list_get(events, i))
        Set i to i + 1
    
    Note: Simple bubble sort implementation
    Let n be Collections.list_length(sorted_events)
    Let outer be 0
    Repeat while outer < n - 1:
        Let inner be 0
        Repeat while inner < n - 1 - outer:
            Let event1 be Collections.list_get(sorted_events, inner)
            Let event2 be Collections.list_get(sorted_events, inner + 1)
            
            Let should_swap be False
            If event1.point.x > event2.point.x:
                Set should_swap to True
            Otherwise:
                If event1.point.x == event2.point.x:
                    If event1.point.y > event2.point.y:
                        Set should_swap to True
                    Otherwise:
                        If event1.point.y == event2.point.y:
                            Note: Process start events before end events at same point
                            If event1.event_type == "end" && event2.event_type == "start":
                                Set should_swap to True
            
            If should_swap:
                Set sorted_events to Collections.list_set(sorted_events, inner, event2)
                Set sorted_events to Collections.list_set(sorted_events, inner + 1, event1)
            
            Set inner to inner + 1
        Set outer to outer + 1
    
    Return sorted_events

Process called "check_segment_intersections_at_point" that takes segments as List[Tuple[Point2D, Point2D]], active_segments as List[Integer], new_segment_id as Integer, sweep_x as Float returns List[Point2D]:
    Note: Check for intersections between new segment and active segments
    Let intersections be Collections.list_create()
    Let new_segment be Collections.list_get(segments, new_segment_id)
    
    Let i be 0
    Repeat while i < Collections.list_length(active_segments):
        Let active_id be Collections.list_get(active_segments, i)
        
        Note: Don't check segment against itself
        If active_id != new_segment_id:
            Let active_segment be Collections.list_get(segments, active_id)
            Let intersection be segment_intersection_test(new_segment, active_segment)
            
            If intersection != Null:
                Note: Only add intersections to the right of sweep line
                If intersection.x >= sweep_x - 0.0001:
                    Set intersections to Collections.list_append(intersections, intersection)
        
        Set i to i + 1
    
    Return intersections

Note: =====================================================================
Note: MESH REFINEMENT HELPER FUNCTIONS
Note: =====================================================================

Process called "compute_triangle_quality" that takes triangle as Tuple3[Integer, Integer, Integer], vertices as List[Point2D] returns Float:
    Note: Compute triangle quality using aspect ratio metric
    Let p1 be Collections.list_get(vertices, triangle.first)
    Let p2 be Collections.list_get(vertices, triangle.second)
    Let p3 be Collections.list_get(vertices, triangle.third)
    
    Note: Calculate edge lengths
    Let a be Euclidean.sqrt((p2.x - p3.x) * (p2.x - p3.x) + (p2.y - p3.y) * (p2.y - p3.y))
    Let b be Euclidean.sqrt((p1.x - p3.x) * (p1.x - p3.x) + (p1.y - p3.y) * (p1.y - p3.y))
    Let c be Euclidean.sqrt((p1.x - p2.x) * (p1.x - p2.x) + (p1.y - p2.y) * (p1.y - p2.y))
    
    Note: Calculate triangle area using cross product
    Let area be 0.5 * Euclidean.abs((p2.x - p1.x) * (p3.y - p1.y) - (p3.x - p1.x) * (p2.y - p1.y))
    
    Note: Calculate perimeter
    Let perimeter be a + b + c
    
    Note: Quality metric: 4 * area / (perimeter^2)
    Note: Perfect equilateral triangle has quality = 1/sqrt(3) ≈ 0.577
    If perimeter < 0.0001:
        Return 0.0
    
    Let quality be (4.0 * area) / (perimeter * perimeter)
    Return quality

Process called "compute_triangle_circumcenter" that takes triangle as Tuple3[Integer, Integer, Integer], vertices as List[Point2D] returns Point2D:
    Note: Compute circumcenter of triangle where circumcircle is centered
    Let p1 be Collections.list_get(vertices, triangle.first)
    Let p2 be Collections.list_get(vertices, triangle.second)
    Let p3 be Collections.list_get(vertices, triangle.third)
    
    Note: Calculate triangle circumcenter using perpendicular bisectors
    Let ax be p1.x
    Let ay be p1.y
    Let bx be p2.x
    Let by be p2.y
    Let cx be p3.x
    Let cy be p3.y
    
    Note: Calculate determinant for circumcenter formula
    Let d be 2.0 * (ax * (by - cy) + bx * (cy - ay) + cx * (ay - by))
    
    If Euclidean.abs(d) < 0.0001:
        Note: Points are collinear, return centroid
        Let centroid_x be (ax + bx + cx) / 3.0
        Let centroid_y be (ay + by + cy) / 3.0
        Let centroid be Euclidean.Point2D with x as centroid_x, y as centroid_y
        Return centroid
    
    Note: Circumcenter coordinates
    Let ux be ((ax * ax + ay * ay) * (by - cy) + (bx * bx + by * by) * (cy - ay) + (cx * cx + cy * cy) * (ay - by)) / d
    Let uy be ((ax * ax + ay * ay) * (cx - bx) + (bx * bx + by * by) * (ax - cx) + (cx * cx + cy * cy) * (bx - ax)) / d
    
    Let circumcenter be Euclidean.Point2D with x as ux, y as uy
    Return circumcenter

Process called "point_in_circumcircle" that takes point as Point2D, triangle as Tuple3[Integer, Integer, Integer], vertices as List[Point2D] returns Boolean:
    Note: Test if point is inside circumcircle of triangle (Delaunay criterion)
    Let p1 be Collections.list_get(vertices, triangle.first)
    Let p2 be Collections.list_get(vertices, triangle.second)
    Let p3 be Collections.list_get(vertices, triangle.third)
    
    Note: Use determinant test for point-in-circumcircle
    Let ax be p1.x - point.x
    Let ay be p1.y - point.y
    Let bx be p2.x - point.x
    Let by be p2.y - point.y
    Let cx be p3.x - point.x
    Let cy be p3.y - point.y
    
    Let det be (ax * ax + ay * ay) * (bx * cy - by * cx) - (bx * bx + by * by) * (ax * cy - ay * cx) + (cx * cx + cy * cy) * (ax * by - ay * bx)
    
    Note: Point is inside if determinant > 0
    Return det > 0.0001

Process called "find_cavity_boundary" that takes cavity_indices as List[Integer], triangles as List[Tuple3[Integer, Integer, Integer]] returns List[Tuple[Integer, Integer]]:
    Note: Find boundary edges of cavity (edges that belong to only one triangle in cavity)
    Let boundary_edges be Collections.list_create()
    Let all_edges be Collections.list_create()
    
    Note: Collect all edges from cavity triangles
    Let i be 0
    Repeat while i < Collections.list_length(cavity_indices):
        Let triangle_index be Collections.list_get(cavity_indices, i)
        Let triangle be Collections.list_get(triangles, triangle_index)
        
        Let edge1 be Euclidean.Tuple with first as triangle.first, second as triangle.second
        Let edge2 be Euclidean.Tuple with first as triangle.second, second as triangle.third
        Let edge3 be Euclidean.Tuple with first as triangle.third, second as triangle.first
        
        Set all_edges to Collections.list_append(all_edges, edge1)
        Set all_edges to Collections.list_append(all_edges, edge2)
        Set all_edges to Collections.list_append(all_edges, edge3)
        Set i to i + 1
    
    Note: Find edges that appear only once (boundary edges)
    Set i to 0
    Repeat while i < Collections.list_length(all_edges):
        Let edge be Collections.list_get(all_edges, i)
        Let reversed_edge be Euclidean.Tuple with first as edge.second, second as edge.first
        
        Note: Count occurrences of this edge and its reverse
        Let count be 0
        Let j be 0
        Repeat while j < Collections.list_length(all_edges):
            Let other_edge be Collections.list_get(all_edges, j)
            If (edge.first == other_edge.first && edge.second == other_edge.second) || (edge.first == other_edge.second && edge.second == other_edge.first):
                Set count to count + 1
            Set j to j + 1
        
        Note: If edge appears only once, it's a boundary edge
        If count == 1:
            If not Collections.list_contains(boundary_edges, edge) && not Collections.list_contains(boundary_edges, reversed_edge):
                Set boundary_edges to Collections.list_append(boundary_edges, edge)
        Set i to i + 1
    
    Return boundary_edges

Process called "remove_triangles_at_indices" that takes triangles as List[Tuple3[Integer, Integer, Integer]], indices_to_remove as List[Integer] returns List[Tuple3[Integer, Integer, Integer]]:
    Note: Remove triangles at specified indices
    Let filtered_triangles be Collections.list_create()
    
    Let i be 0
    Repeat while i < Collections.list_length(triangles):
        If not Collections.list_contains(indices_to_remove, i):
            Set filtered_triangles to Collections.list_append(filtered_triangles, Collections.list_get(triangles, i))
        Set i to i + 1
    
    Return filtered_triangles