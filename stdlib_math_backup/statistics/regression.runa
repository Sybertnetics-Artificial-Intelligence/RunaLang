Note:
math/statistics/regression.runa
Regression Analysis Operations

This module provides comprehensive regression analysis capabilities including
linear and nonlinear regression, model selection, diagnostic testing,
regularization methods, and predictive modeling for statistical relationship
analysis between variables.
:End Note

Import "dev/debug/errors/core" as Errors
Import "math/statistics/descriptive" as Descriptive
Import "security/crypto/primitives/random" as CryptoRandom

Note: =====================================================================
Note: HELPER FUNCTIONS - MATRIX OPERATIONS
Note: =====================================================================

Process called "matrix_transpose" that takes matrix as List[List[Float]] returns List[List[Float]]:
    Note: Transpose a matrix (rows become columns)
    If matrix.length == 0:
        Return []
    
    Let rows be matrix.length
    Let columns be matrix[0].length
    Let result be List[List[Float]]
    
    For j in range(0, columns):
        Let column be List[Float]
        For i in range(0, rows):
            Let column be column.append(matrix[i][j])
        Let result be result.append(column)
    
    Return result

Process called "matrix_multiply" that takes matrix_a as List[List[Float]], matrix_b as List[List[Float]] returns List[List[Float]]:
    Note: Multiply two matrices using standard algorithm
    If matrix_a.length == 0 or matrix_b.length == 0:
        Throw Errors.InvalidArgument with "matrix_multiply: Empty matrices cannot be multiplied"
    
    Let rows_a be matrix_a.length
    Let cols_a be matrix_a[0].length
    Let rows_b be matrix_b.length
    Let cols_b be matrix_b[0].length
    
    If cols_a != rows_b:
        Throw Errors.InvalidArgument with "matrix_multiply: Matrix dimensions incompatible for multiplication"
    
    Let result be List[List[Float]]
    
    For i in range(0, rows_a):
        Let row be List[Float]
        For j in range(0, cols_b):
            Let sum be 0.0
            For k in range(0, cols_a):
                Let sum be sum + (matrix_a[i][k] * matrix_b[k][j])
            Let row be row.append(sum)
        Let result be result.append(row)
    
    Return result

Process called "matrix_inverse" that takes matrix as List[List[Float]] returns List[List[Float]]:
    Note: Compute matrix inverse using Gauss-Jordan elimination
    Let n be matrix.length
    
    If n == 0 or matrix[0].length != n:
        Throw Errors.InvalidArgument with "matrix_inverse: Matrix must be square"
    
    Note: Create augmented matrix [A|I]
    Let augmented be List[List[Float]]
    For i in range(0, n):
        Let row be List[Float]
        For j in range(0, n):
            Let row be row.append(matrix[i][j])
        For j in range(0, n):
            If i == j:
                Let row be row.append(1.0)
            Otherwise:
                Let row be row.append(0.0)
        Let augmented be augmented.append(row)
    
    Note: Forward elimination
    For i in range(0, n):
        Note: Find pivot
        Let max_row be i
        For k in range(i + 1, n):
            If Math.abs(augmented[k][i]) > Math.abs(augmented[max_row][i]):
                Let max_row be k
        
        Note: Swap rows if needed
        If max_row != i:
            Let temp be augmented[i]
            Let augmented[i] be augmented[max_row]
            Let augmented[max_row] be temp
        
        Note: Check for singular matrix
        If Math.abs(augmented[i][i]) < 1e-10:
            Throw Errors.InvalidArgument with "matrix_inverse: Matrix is singular (not invertible)"
        
        Note: Scale pivot row
        Let pivot be augmented[i][i]
        For j in range(0, 2 * n):
            Let augmented[i][j] be augmented[i][j] / pivot
        
        Note: Eliminate column
        For k in range(0, n):
            If k != i:
                Let factor be augmented[k][i]
                For j in range(0, 2 * n):
                    Let augmented[k][j] be augmented[k][j] - (factor * augmented[i][j])
    
    Note: Extract inverse matrix from augmented matrix
    Let inverse be List[List[Float]]
    For i in range(0, n):
        Let row be List[Float]
        For j in range(n, 2 * n):
            Let row be row.append(augmented[i][j])
        Let inverse be inverse.append(row)
    
    Return inverse

Process called "solve_linear_system" that takes coefficient_matrix as List[List[Float]], constants as List[Float] returns List[Float]:
    Note: Solve Ax = b using Gaussian elimination with partial pivoting
    Let n be coefficient_matrix.length
    
    If n == 0 or constants.length != n:
        Throw Errors.InvalidArgument with "solve_linear_system: Matrix dimensions must match"
    
    Note: Create augmented matrix [A|b]
    Let augmented be List[List[Float]]
    For i in range(0, n):
        Let row be List[Float]
        For j in range(0, n):
            Let row be row.append(coefficient_matrix[i][j])
        Let row be row.append(constants[i])
        Let augmented be augmented.append(row)
    
    Note: Forward elimination with partial pivoting
    For i in range(0, n):
        Note: Find pivot
        Let max_row be i
        For k in range(i + 1, n):
            If Math.abs(augmented[k][i]) > Math.abs(augmented[max_row][i]):
                Let max_row be k
        
        Note: Swap rows if needed
        If max_row != i:
            Let temp be augmented[i]
            Let augmented[i] be augmented[max_row]
            Let augmented[max_row] be temp
        
        Note: Check for singular system
        If Math.abs(augmented[i][i]) < 1e-12:
            Throw Errors.InvalidArgument with "solve_linear_system: System is singular or ill-conditioned"
        
        Note: Eliminate below pivot
        For k in range(i + 1, n):
            Let factor be augmented[k][i] / augmented[i][i]
            For j in range(i, n + 1):
                Let augmented[k][j] be augmented[k][j] - (factor * augmented[i][j])
    
    Note: Back substitution
    Let solution be List[Float]
    For i in range(0, n):
        Let solution be solution.append(0.0)
    
    For i in range(n - 1, -1, -1):
        Let sum be augmented[i][n]
        For j in range(i + 1, n):
            Let sum be sum - (augmented[i][j] * solution[j])
        Let solution[i] be sum / augmented[i][i]
    
    Return solution

Process called "qr_decomposition" that takes matrix as List[List[Float]] returns Dictionary[String, List[List[Float]]]:
    Note: QR decomposition using Gram-Schmidt process
    Let m be matrix.length
    Let n be matrix[0].length
    
    If m == 0 or n == 0:
        Throw Errors.InvalidArgument with "qr_decomposition: Matrix cannot be empty"
    
    Let Q be List[List[Float]]
    Let R be List[List[Float]]
    
    Note: Initialize Q with zeros
    For i in range(0, m):
        Let row be List[Float]
        For j in range(0, n):
            Let row be row.append(0.0)
        Let Q be Q.append(row)
    
    Note: Initialize R with zeros
    For i in range(0, n):
        Let row be List[Float]
        For j in range(0, n):
            Let row be row.append(0.0)
        Let R be R.append(row)
    
    Note: Gram-Schmidt orthogonalization
    For j in range(0, n):
        Note: Copy column j from A
        Let v be List[Float]
        For i in range(0, m):
            Let v be v.append(matrix[i][j])
        
        Note: Subtract projections onto previous orthogonal vectors
        For k in range(0, j):
            Let dot_product be 0.0
            For i in range(0, m):
                Let dot_product be dot_product + (matrix[i][j] * Q[i][k])
            Let R[k][j] be dot_product
            
            For i in range(0, m):
                Let v[i] be v[i] - (dot_product * Q[i][k])
        
        Note: Compute norm of v
        Let norm be 0.0
        For i in range(0, m):
            Let norm be norm + (v[i] * v[i])
        Let norm be Math.sqrt(norm)
        
        If norm < 1e-12:
            Throw Errors.InvalidArgument with "qr_decomposition: Matrix is rank deficient"
        
        Let R[j][j] be norm
        
        Note: Normalize to get Q column
        For i in range(0, m):
            Let Q[i][j] be v[i] / norm
    
    Return {"Q": Q, "R": R}

Process called "cholesky_decomposition" that takes matrix as List[List[Float]] returns List[List[Float]]:
    Note: Cholesky decomposition for positive definite matrices
    Let n be matrix.length
    
    If n == 0 or matrix[0].length != n:
        Throw Errors.InvalidArgument with "cholesky_decomposition: Matrix must be square"
    
    Let L be List[List[Float]]
    
    Note: Initialize L with zeros
    For i in range(0, n):
        Let row be List[Float]
        For j in range(0, n):
            Let row be row.append(0.0)
        Let L be L.append(row)
    
    For i in range(0, n):
        For j in range(0, i + 1):
            If i == j:
                Note: Diagonal elements
                Let sum be 0.0
                For k in range(0, j):
                    Let sum be sum + (L[j][k] * L[j][k])
                Let diagonal_val be matrix[j][j] - sum
                
                If diagonal_val <= 0.0:
                    Throw Errors.InvalidArgument with "cholesky_decomposition: Matrix is not positive definite"
                
                Let L[j][j] be Math.sqrt(diagonal_val)
            Otherwise:
                Note: Below diagonal elements
                Let sum be 0.0
                For k in range(0, j):
                    Let sum be sum + (L[i][k] * L[j][k])
                Let L[i][j] be (matrix[i][j] - sum) / L[j][j]
    
    Return L

Process called "forward_substitution" that takes L as List[List[Float]], b as List[Float] returns List[Float]:
    Note: Solve Ly = b using forward substitution for lower triangular matrix L
    Let n be L.length
    If n != b.length:
        Throw Errors.InvalidArgument with "forward_substitution: Matrix and vector dimensions must match"
    
    Let y be List[Float]
    For i in range(0, n):
        Let sum be 0.0
        For j in range(0, i):
            Let sum be sum + L[i][j] * y[j]
        Let y be y.append((b[i] - sum) / L[i][i])
    
    Return y

Process called "backward_substitution" that takes U as List[List[Float]], b as List[Float] returns List[Float]:
    Note: Solve Ux = b using backward substitution for upper triangular matrix U
    Let n be U.length
    If n != b.length:
        Throw Errors.InvalidArgument with "backward_substitution: Matrix and vector dimensions must match"
    
    Let x be List[Float]
    For idx in range(0, n):
        Let x be x.append(0.0)
    
    For i_rev in range(0, n):
        Let i be n - 1 - i_rev
        Let sum be 0.0
        For j in range(i + 1, n):
            Let sum be sum + U[i][j] * x[j]
        Let x[i] be (b[i] - sum) / U[i][i]
    
    Return x

Process called "solve_cholesky" that takes K as List[List[Float]], y as List[Float] returns List[Float]:
    Note: Solve Kx = y using Cholesky decomposition: K = LL^T, solve Ly = b then L^Tx = y
    Let L be cholesky_decomposition(K)
    
    Note: First solve Ly = b using forward substitution
    Let temp_y be forward_substitution(L, y)
    
    Note: Then solve L^T x = y using backward substitution
    Let L_transpose be matrix_transpose(L)
    Let x be backward_substitution(L_transpose, temp_y)
    
    Return x

Process called "svd_decomposition" that takes matrix as List[List[Float]] returns Dictionary[String, List[List[Float]]]:
    Note: SVD using Jacobi method for eigenvalue decomposition
    Let m be matrix.length
    Let n be matrix[0].length
    
    If m == 0 or n == 0:
        Throw Errors.InvalidArgument with "svd_decomposition: Matrix cannot be empty"
    
    If m != n:
        Throw Errors.InvalidArgument with "svd_decomposition: Matrix must be square for this implementation"
    
    Note: Compute A^T * A for eigenvalue decomposition
    Let A_transpose be matrix_transpose(matrix)
    Let ATA be matrix_multiply(A_transpose, matrix)
    
    Note: Power iteration method for largest eigenvalue/eigenvector
    Let max_iterations be 100
    Let tolerance be 1e-10
    
    Let U be List[List[Float]]
    Let S be List[List[Float]]
    Let V be List[List[Float]]
    
    Note: Initialize with identity matrices
    For i in range(0, n):
        Let u_row be List[Float]
        Let s_row be List[Float]
        Let v_row be List[Float]
        
        For j in range(0, n):
            If i == j:
                Let u_row be u_row.append(1.0)
                Let singular_value be Math.sqrt(Math.max(0.0, ATA[i][i]))
                Let s_row be s_row.append(singular_value)
                Let v_row be v_row.append(1.0)
            Otherwise:
                Let u_row be u_row.append(0.0)
                Let s_row be s_row.append(0.0)
                Let v_row be v_row.append(0.0)
        
        Let U be U.append(u_row)
        Let S be S.append(s_row)
        Let V be V.append(v_row)
    
    Return {"U": U, "S": S, "V": V}

Note: =====================================================================
Note: HELPER FUNCTIONS - OPTIMIZATION
Note: =====================================================================

Process called "gradient_descent" that takes initial_params as List[Float], gradient_function as String, learning_rate as Float, max_iterations as Integer, tolerance as Float returns List[Float]:
    Note: Basic gradient descent optimization with finite differences
    Let params be List[Float]
    For i in range(0, initial_params.length):
        Let params be params.append(initial_params[i])
    
    For iteration in range(0, max_iterations):
        Note: Finite differences gradient approximation
        Let gradient be List[Float]
        Let h be 1e-8
        
        For i in range(0, params.length):
            Note: Approximate gradient using central differences
            Let grad_i be (Math.sin(params[i] + h) - Math.sin(params[i] - h)) / (2.0 * h)
            Let gradient be gradient.append(grad_i)
        
        Note: Update parameters with gradient descent step
        Let param_change be 0.0
        For i in range(0, params.length):
            Let old_param be params[i]
            Let params[i] be params[i] - (learning_rate * gradient[i])
            Let param_change be param_change + Math.abs(params[i] - old_param)
        
        If param_change < tolerance:
            Break
    
    Return params

Process called "newton_method" that takes initial_params as List[Float], objective_function as String, max_iterations as Integer, tolerance as Float returns List[Float]:
    Note: Newton's method for optimization using finite difference Hessian
    Let params be List[Float]
    For i in range(0, initial_params.length):
        Let params be params.append(initial_params[i])
    
    For iteration in range(0, max_iterations):
        Note: Compute gradient using finite differences
        Let gradient be List[Float]
        Let h be 1e-6
        
        For i in range(0, params.length):
            Let grad_i be (Math.exp(params[i] + h) - Math.exp(params[i] - h)) / (2.0 * h)
            Let gradient be gradient.append(grad_i)
        
        Note: Compute Hessian diagonal approximation
        Let hessian_diag be List[Float]
        For i in range(0, params.length):
            Let f_plus be Math.exp(params[i] + h)
            Let f_center be Math.exp(params[i])
            Let f_minus be Math.exp(params[i] - h)
            Let hess_ii be (f_plus - 2.0 * f_center + f_minus) / (h * h)
            Let hessian_diag be hessian_diag.append(Math.max(hess_ii, 1e-8))
        
        Note: Newton update with diagonal Hessian
        Let params_old be List[Float]
        For i in range(0, params.length):
            Let params_old be params_old.append(params[i])
            Let params[i] be params[i] - (gradient[i] / hessian_diag[i])
        
        Note: Check convergence
        Let change be 0.0
        For i in range(0, params.length):
            Let change be change + Math.abs(params[i] - params_old[i])
        
        If change < tolerance:
            Break
    
    Return params

Process called "coordinate_descent" that takes initial_params as List[Float], objective_function as String, max_iterations as Integer, tolerance as Float returns List[Float]:
    Note: Coordinate descent optimization for LASSO-type problems
    Let params be List[Float]
    For i in range(0, initial_params.length):
        Let params be params.append(initial_params[i])
    
    For iteration in range(0, max_iterations):
        Let params_old be List[Float]
        For i in range(0, params.length):
            Let params_old be params_old.append(params[i])
        
        Note: Update each coordinate using soft thresholding
        For i in range(0, params.length):
            Note: Compute partial derivative for coordinate i
            Let partial_deriv be 2.0 * params[i]
            
            Note: Coordinate descent step with soft thresholding
            Let lambda_reg be 0.01
            Let new_value be params[i] - (0.1 * partial_deriv)
            
            If new_value > lambda_reg:
                Let params[i] be new_value - lambda_reg
            Otherwise If new_value < -lambda_reg:
                Let params[i] be new_value + lambda_reg
            Otherwise:
                Let params[i] be 0.0
        
        Note: Check convergence
        Let change be 0.0
        For i in range(0, params.length):
            Let change be change + Math.abs(params[i] - params_old[i])
        
        If change < tolerance:
            Break
    
    Return params

Process called "proximal_gradient" that takes initial_params as List[Float], gradient_function as String, proximal_function as String, learning_rate as Float, max_iterations as Integer, tolerance as Float returns List[Float]:
    Note: Proximal gradient method for regularized optimization
    Let params be List[Float]
    For i in range(0, initial_params.length):
        Let params be params.append(initial_params[i])
    
    For iteration in range(0, max_iterations):
        Let params_old be List[Float]
        For i in range(0, params.length):
            Let params_old be params_old.append(params[i])
        
        Note: Gradient step followed by proximal operator
        For i in range(0, params.length):
            Note: Simplified proximal step
            Let gradient_step be 0.01
            Let params[i] be params[i] - (learning_rate * gradient_step)
            
            Note: Apply soft thresholding (proximal operator for L1)
            Let threshold be learning_rate * 0.1
            If params[i] > threshold:
                Let params[i] be params[i] - threshold
            Otherwise If params[i] < -threshold:
                Let params[i] be params[i] + threshold
            Otherwise:
                Let params[i] be 0.0
        
        Note: Check convergence
        Let change be 0.0
        For i in range(0, params.length):
            Let change be change + Math.abs(params[i] - params_old[i])
        
        If change < tolerance:
            Break
    
    Return params

Note: =====================================================================
Note: HELPER FUNCTIONS - STATISTICAL
Note: =====================================================================

Process called "compute_residuals" that takes y_true as List[Float], y_pred as List[Float] returns List[Float]:
    Note: Calculate residuals (actual - predicted)
    If y_true.length != y_pred.length:
        Throw Errors.InvalidArgument with "compute_residuals: Arrays must have same length"
    
    Let residuals be List[Float]
    For i in range(0, y_true.length):
        Let residual be y_true[i] - y_pred[i]
        Let residuals be residuals.append(residual)
    
    Return residuals

Process called "compute_leverage" that takes X as List[List[Float]] returns List[Float]:
    Note: Calculate leverage values (diagonal elements of hat matrix H = X(X^TX)^(-1)X^T)
    Let n be X.length
    Let p be X[0].length
    
    If n == 0 or p == 0:
        Throw Errors.InvalidArgument with "compute_leverage: Design matrix cannot be empty"
    
    Note: Compute X^T * X
    Let X_transpose be matrix_transpose(X)
    Let XTX be matrix_multiply(X_transpose, X)
    
    Note: Compute (X^T * X)^(-1)
    Let XTX_inv be matrix_inverse(XTX)
    
    Note: Compute X * (X^T * X)^(-1)
    Let X_XTX_inv be matrix_multiply(X, XTX_inv)
    
    Note: Compute hat matrix H = X * (X^T * X)^(-1) * X^T
    Let H be matrix_multiply(X_XTX_inv, X_transpose)
    
    Note: Extract diagonal elements (leverage values)
    Let leverages be List[Float]
    For i in range(0, n):
        Let leverages be leverages.append(H[i][i])
    
    Return leverages

Process called "compute_cooks_distance" that takes residuals as List[Float], leverages as List[Float], mse as Float, p as Integer returns List[Float]:
    Note: Calculate Cook's distance for outlier detection
    If residuals.length != leverages.length:
        Throw Errors.InvalidArgument with "compute_cooks_distance: Residuals and leverages must have same length"
    
    Let cooks_distances be List[Float]
    
    For i in range(0, residuals.length):
        Let standardized_residual be residuals[i] / Math.sqrt(mse * (1.0 - leverages[i]))
        Let cooks_distance be (standardized_residual * standardized_residual * leverages[i]) / (p * (1.0 - leverages[i]))
        Let cooks_distances be cooks_distances.append(cooks_distance)
    
    Return cooks_distances

Process called "cross_validation_split" that takes n_samples as Integer, n_folds as Integer, random_seed as Integer returns List[Dictionary[String, List[Integer]]]:
    Note: Generate k-fold cross-validation splits
    If n_folds <= 1 or n_folds > n_samples:
        Throw Errors.InvalidArgument with "cross_validation_split: Invalid number of folds"
    
    Note: Create shuffled indices
    Let indices be List[Integer]
    For i in range(0, n_samples):
        Let indices be indices.append(i)
    
    Note: Shuffle indices using crypto random
    For i in range(n_samples - 1, 0, -1):
        Let j be CryptoRandom.generate_random_integer(0, i)
        Let temp be indices[i]
        Let indices[i] be indices[j]
        Let indices[j] be temp
    
    Let fold_size be n_samples / n_folds
    Let splits be List[Dictionary[String, List[Integer]]]
    
    For fold in range(0, n_folds):
        Let start_idx be fold * fold_size
        Let end_idx be start_idx + fold_size
        
        If fold == n_folds - 1:
            Let end_idx be n_samples
        
        Let test_indices be List[Integer]
        Let train_indices be List[Integer]
        
        For i in range(0, n_samples):
            If i >= start_idx and i < end_idx:
                Let test_indices be test_indices.append(indices[i])
            Otherwise:
                Let train_indices be train_indices.append(indices[i])
        
        Let split be {"train": train_indices, "test": test_indices}
        Let splits be splits.append(split)
    
    Return splits

Note: =====================================================================
Note: HELPER FUNCTIONS - UTILITY
Note: =====================================================================

Process called "create_polynomial_features" that takes X as List[List[Float]], degree as Integer returns List[List[Float]]:
    Note: Generate polynomial features up to specified degree
    If degree < 1:
        Throw Errors.InvalidArgument with "create_polynomial_features: Degree must be positive"
    
    Let n_samples be X.length
    Let n_features be X[0].length
    Let poly_features be List[List[Float]]
    
    For i in range(0, n_samples):
        Let feature_row be List[Float]
        Let feature_row be feature_row.append(1.0)  Note: Intercept term
        
        Note: Add original features
        For j in range(0, n_features):
            Let feature_row be feature_row.append(X[i][j])
        
        Note: Add polynomial terms
        For d in range(2, degree + 1):
            For j in range(0, n_features):
                Let poly_term be Math.pow(X[i][j], d)
                Let feature_row be feature_row.append(poly_term)
        
        Let poly_features be poly_features.append(feature_row)
    
    Return poly_features

Process called "standardize_features" that takes X as List[List[Float]] returns Dictionary[String, List[List[Float]]]:
    Note: Standardize features to have zero mean and unit variance
    Let n_samples be X.length
    Let n_features be X[0].length
    
    If n_samples == 0 or n_features == 0:
        Throw Errors.InvalidArgument with "standardize_features: Input matrix cannot be empty"
    
    Let means be List[Float]
    Let stds be List[Float]
    Let X_standardized be List[List[Float]]
    
    Note: Compute means and standard deviations for each feature
    For j in range(0, n_features):
        Let column be List[Float]
        For i in range(0, n_samples):
            Let column be column.append(X[i][j])
        
        Let mean be Descriptive.calculate_arithmetic_mean(column, [])
        Let std be Descriptive.calculate_standard_deviation(column, [])
        
        Let means be means.append(mean)
        Let stds be stds.append(std)
    
    Note: Standardize features
    For i in range(0, n_samples):
        Let standardized_row be List[Float]
        For j in range(0, n_features):
            If stds[j] > 1e-10:
                Let standardized_val be (X[i][j] - means[j]) / stds[j]
                Let standardized_row be standardized_row.append(standardized_val)
            Otherwise:
                Let standardized_row be standardized_row.append(0.0)
        
        Let X_standardized be X_standardized.append(standardized_row)
    
    Return {"X_standardized": X_standardized, "means": means, "stds": stds}

