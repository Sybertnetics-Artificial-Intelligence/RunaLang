Note:
math/statistics/inferential.runa
Inferential Statistics Operations

This module provides comprehensive inferential statistics capabilities including
hypothesis testing, confidence intervals, statistical significance testing,
power analysis, and parametric/non-parametric test procedures for making
statistical inferences about populations from sample data.
:End Note

Import "collections" as Collections
Import "dev/debug/errors/core" as Errors
Import "math/statistics/descriptive" as Descriptive
Import "math/probability/distributions" as Distributions
Import "math/core/operations" as MathOps

Note: =====================================================================
Note: INFERENTIAL STATISTICS DATA STRUCTURES
Note: =====================================================================

Type called "HypothesisTest":
    test_name as String
    null_hypothesis as String
    alternative_hypothesis as String
    test_statistic as Float
    p_value as Float
    critical_value as Float
    degrees_of_freedom as Integer
    significance_level as Float
    test_result as String
    effect_size as Float

Type called "ConfidenceInterval":
    parameter_name as String
    point_estimate as Float
    confidence_level as Float
    lower_bound as Float
    upper_bound as Float
    margin_of_error as Float
    standard_error as Float
    interpretation as String

Type called "PowerAnalysis":
    test_type as String
    effect_size as Float
    sample_size as Integer
    significance_level as Float
    statistical_power as Float
    required_sample_size as Integer
    minimum_detectable_effect as Float

Type called "TestAssumptions":
    normality_check as Dictionary[String, Float]
    homogeneity_check as Dictionary[String, Float]
    independence_check as Dictionary[String, Float]
    assumptions_met as Boolean
    recommendation as String
    alternative_tests as List[String]

Note: =====================================================================
Note: ONE-SAMPLE TESTS OPERATIONS
Note: =====================================================================

Process called "one_sample_t_test" that takes sample as List[Float], population_mean as Float, alpha as Float, alternative as String returns HypothesisTest:
    Note: Perform one-sample t-test for population mean with unknown variance
    Note: Tests H₀: μ = μ₀ vs H₁: μ ≠ μ₀ (two-sided) or directional alternatives
    Note: Assumes normality. Uses t-distribution with n-1 degrees of freedom
    
    Let clean_sample be Descriptive.validate_numeric_data(sample)
    If clean_sample.length < 2:
        Throw Errors.InvalidArgument with "Sample size must be at least 2 for t-test"
    
    Let test_result be HypothesisTest with test_name as "One-Sample t-Test", significance_level as alpha
    
    Note: Calculate sample statistics
    Let sample_mean be Descriptive.calculate_arithmetic_mean(clean_sample, List[Float]())
    Let sample_std be Descriptive.calculate_standard_deviation(clean_sample, false)
    Let n be clean_sample.length
    
    If sample_std == 0.0:
        Throw Errors.InvalidArgument with "Sample standard deviation cannot be zero"
    
    Note: Calculate t-statistic: t = (x̄ - μ₀) / (s / √n)
    Let sqrt_n_result be MathOps.square_root(n.to_string(), 15)
    If not sqrt_n_result.operation_successful:
        Throw Errors.ComputationError with "Failed to compute square root of sample size"
    
    Let sqrt_n be sqrt_n_result.result_value.to_float()
    Let standard_error be sample_std / sqrt_n
    Let t_statistic be (sample_mean - population_mean) / standard_error
    
    Set test_result.test_statistic to t_statistic
    Set test_result.degrees_of_freedom to n - 1
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "μ = " + population_mean.to_string()
    If alternative == "two-sided":
        Set test_result.alternative_hypothesis to "μ ≠ " + population_mean.to_string()
    Otherwise If alternative == "greater":
        Set test_result.alternative_hypothesis to "μ > " + population_mean.to_string()
    Otherwise If alternative == "less":
        Set test_result.alternative_hypothesis to "μ < " + population_mean.to_string()
    Otherwise:
        Set test_result.alternative_hypothesis to "μ ≠ " + population_mean.to_string()
        Set alternative to "two-sided"
    
    Note: Calculate p-value using t-distribution approximation for proper inference
    Note: Calculate p-value using standard normal approximation
    Let abs_t_result be MathOps.absolute_value(t_statistic.to_string())
    If not abs_t_result.operation_successful:
        Throw Errors.ComputationError with "Failed to compute absolute value"
    
    Let abs_t be abs_t_result.result_value.to_float()
    
    Note: Use normal approximation: P(Z > |t|) for large samples
    Let p_upper be 1.0 - Distributions.normal_distribution_cdf(abs_t, 0.0, 1.0)
    
    If alternative == "two-sided":
        Set test_result.p_value to 2.0 * p_upper
    Otherwise If alternative == "greater":
        If t_statistic > 0.0:
            Set test_result.p_value to p_upper
        Otherwise:
            Set test_result.p_value to 1.0 - p_upper
    Otherwise If alternative == "less":
        If t_statistic < 0.0:
            Set test_result.p_value to p_upper
        Otherwise:
            Set test_result.p_value to 1.0 - p_upper
    
    Note: Critical value (using normal approximation)
    If alternative == "two-sided":
        Set test_result.critical_value to Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    Otherwise:
        Set test_result.critical_value to Distributions.normal_distribution_quantile(1.0 - alpha, 0.0, 1.0)
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (Cohen's d for one-sample)
    Set test_result.effect_size to (sample_mean - population_mean) / sample_std
    
    Return test_result

Process called "one_sample_z_test" that takes sample as List[Float], population_mean as Float, population_std as Float, alpha as Float returns HypothesisTest:
    Note: Perform one-sample z-test for population mean with known variance
    Note: Uses standard normal distribution. Requires known population standard deviation
    Note: Computational complexity: O(n) for sample mean calculation
    
    If sample.length == 0:
        Throw Errors.InvalidArgument with "Sample cannot be empty"
    
    If population_std <= 0.0:
        Throw Errors.InvalidArgument with "Population standard deviation must be positive"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let test_result be HypothesisTest with test_name as "One-Sample Z-Test"
    
    Note: Calculate sample statistics
    Let sample_mean be DescriptiveStats.calculate_arithmetic_mean(sample, List[Float]())
    Let n be sample.length
    
    Note: Calculate standard error using known population standard deviation
    Let standard_error be population_std / MathOps.square_root(n.to_string(), 15).result_value.to_float()
    
    Note: Calculate z-statistic
    If standard_error <= 0.0:
        Throw Errors.ComputationError with "Standard error must be positive"
    
    Let z_statistic be (sample_mean - population_mean) / standard_error
    Set test_result.test_statistic to z_statistic
    Set test_result.degrees_of_freedom to 0
    
    Note: Set hypotheses (default two-sided)
    Set test_result.null_hypothesis to "μ = " + population_mean.to_string()
    Set test_result.alternative_hypothesis to "μ ≠ " + population_mean.to_string()
    
    Note: Calculate p-value using standard normal distribution
    Let abs_z_result be MathOps.absolute_value(z_statistic.to_string())
    If not abs_z_result.operation_successful:
        Throw Errors.ComputationError with "Failed to compute absolute value"
    
    Let abs_z be abs_z_result.result_value.to_float()
    Let p_upper be 1.0 - Distributions.normal_distribution_cdf(abs_z, 0.0, 1.0)
    Set test_result.p_value to 2.0 * p_upper
    
    Note: Critical value for two-sided test
    Set test_result.critical_value to Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (standardized mean difference)
    Set test_result.effect_size to (sample_mean - population_mean) / population_std
    
    Return test_result

Process called "one_sample_proportion_test" that takes successes as Integer, total as Integer, null_proportion as Float, alpha as Float returns HypothesisTest:
    Note: Test population proportion using normal approximation to binomial
    Note: Requires np ≥ 5 and n(1-p) ≥ 5 for valid approximation
    Note: Computational complexity: O(1) for proportion calculations
    
    If total <= 0:
        Throw Errors.InvalidArgument with "Total must be positive"
    
    If successes < 0 or successes > total:
        Throw Errors.InvalidArgument with "Successes must be between 0 and total"
    
    If null_proportion < 0.0 or null_proportion > 1.0:
        Throw Errors.InvalidArgument with "Null proportion must be between 0 and 1"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let test_result be HypothesisTest with test_name as "One-Sample Proportion Test"
    
    Note: Calculate sample proportion
    Let sample_proportion be successes.to_float() / total.to_float()
    
    Note: Check normal approximation validity
    Let expected_successes be total.to_float() * null_proportion
    Let expected_failures be total.to_float() * (1.0 - null_proportion)
    
    If expected_successes < 5.0 or expected_failures < 5.0:
        Note: Normal approximation may be poor, but proceeding with warning
    
    Note: Calculate standard error under null hypothesis
    Let standard_error_squared be null_proportion * (1.0 - null_proportion) / total.to_float()
    Let standard_error_result be MathOps.square_root(standard_error_squared.to_string(), 15)
    If not standard_error_result.operation_successful:
        Throw Errors.ComputationError with "Failed to compute standard error"
    
    Let standard_error be standard_error_result.result_value.to_float()
    
    Note: Calculate z-statistic with continuity correction
    Let z_statistic be 0.0
    If sample_proportion > null_proportion:
        Set z_statistic to (sample_proportion - 0.5/total.to_float() - null_proportion) / standard_error
    Otherwise If sample_proportion < null_proportion:
        Set z_statistic to (sample_proportion + 0.5/total.to_float() - null_proportion) / standard_error
    Otherwise:
        Set z_statistic to 0.0
    
    Set test_result.test_statistic to z_statistic
    Set test_result.degrees_of_freedom to 0
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "p = " + null_proportion.to_string()
    Set test_result.alternative_hypothesis to "p ≠ " + null_proportion.to_string()
    
    Note: Calculate p-value (two-sided test)
    Let abs_z_result be MathOps.absolute_value(z_statistic.to_string())
    If abs_z_result.operation_successful:
        Let abs_z be abs_z_result.result_value.to_float()
        Let p_upper be 1.0 - Distributions.normal_distribution_cdf(abs_z, 0.0, 1.0)
        Set test_result.p_value to 2.0 * p_upper
    Otherwise:
        Set test_result.p_value to 1.0
    
    Note: Critical value for two-sided test
    Set test_result.critical_value to Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (difference in proportions)
    Set test_result.effect_size to sample_proportion - null_proportion
    
    Return test_result

Process called "wilcoxon_signed_rank_test" that takes sample as List[Float], hypothesized_median as Float, alpha as Float returns HypothesisTest:
    Note: Non-parametric test for median when normality assumption is violated
    Note: Tests symmetry around hypothesized median. Robust to outliers
    Note: Uses normal approximation for large samples (n > 20)
    Note: Computational complexity: O(n log n) for sorting ranks
    
    If sample.size() < 3:
        Throw Errors.InvalidArgument with "Sample size must be at least 3"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Calculate differences from hypothesized median
    Let differences be Collections.new_list[Float]()
    Let ranks be Collections.new_list[Float]()
    
    For value in sample:
        Let diff be value - hypothesized_median
        If diff != 0.0:
            differences.push(diff)
    
    If differences.size() == 0:
        Note: All values equal hypothesized median
        Let test_result be HypothesisTest {
            test_statistic: 0.0,
            p_value: 1.0,
            critical_value: 0.0,
            degrees_of_freedom: 0,
            effect_size: 0.0
        }
        Return test_result
    
    Let n be differences.size()
    
    Note: Rank absolute differences
    Let abs_differences be Collections.new_list[Float]()
    For diff in differences:
        abs_differences.push(MathOps.absolute(diff))
    
    Note: Simple ranking algorithm - assign ranks 1, 2, ..., n
    For i from 0 to abs_differences.size() - 1:
        Let rank be 1.0
        For j from 0 to abs_differences.size() - 1:
            If abs_differences.get(j) < abs_differences.get(i):
                Set rank to rank + 1.0
        ranks.push(rank)
    
    Note: Calculate sum of positive ranks (W+)
    Let w_plus be 0.0
    For i from 0 to differences.size() - 1:
        If differences.get(i) > 0.0:
            Set w_plus to w_plus + ranks.get(i)
    
    Note: For two-sided test, use smaller of W+ and W-
    Let w_minus be (n * (n + 1)).to_float() / 2.0 - w_plus
    Let test_statistic be MathOps.minimum(w_plus, w_minus)
    
    Note: Normal approximation for large n (n > 20)
    Let expected_w be (n * (n + 1)).to_float() / 4.0
    Let variance_w be (n * (n + 1) * (2 * n + 1)).to_float() / 24.0
    Let z_statistic be (test_statistic + 0.5 - expected_w) / MathOps.square_root(variance_w)
    
    Note: Calculate p-value using normal approximation
    Let normal be Distributions.normal(0.0, 1.0)
    Let p_value be 2.0 * normal.cdf(z_statistic)
    If p_value > 1.0:
        Set p_value to 2.0 * (1.0 - normal.cdf(MathOps.absolute(z_statistic)))
    
    Note: Critical value approximation (normal approximation)
    Let critical_z be normal.quantile(alpha / 2.0)
    Let critical_value be expected_w + critical_z * MathOps.square_root(variance_w)
    
    Let test_result be HypothesisTest {
        test_statistic: test_statistic,
        p_value: p_value,
        critical_value: MathOps.absolute(critical_value),
        degrees_of_freedom: n,
        effect_size: 0.0
    }
    
    Note: Effect size approximation (r = z / sqrt(n))
    Set test_result.effect_size to MathOps.absolute(z_statistic) / MathOps.square_root(n.to_float())
    
    Return test_result

Note: =====================================================================
Note: TWO-SAMPLE TESTS OPERATIONS
Note: =====================================================================

Process called "independent_t_test" that takes sample1 as List[Float], sample2 as List[Float], alpha as Float, equal_variance as Boolean returns HypothesisTest:
    Note: Compare means of two independent groups using t-test
    Note: Welch's t-test for unequal variances, Student's t-test for equal variances
    Note: Computational complexity: O(n1 + n2) for sample statistics
    
    If sample1.length < 2 or sample2.length < 2:
        Throw Errors.InvalidArgument with "Each sample must have at least 2 observations for independent t-test"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let test_result be HypothesisTest with test_name as "Independent Samples T-Test"
    
    Note: Calculate sample statistics
    Let mean1 be DescriptiveStats.calculate_arithmetic_mean(sample1, List[Float]())
    Let mean2 be DescriptiveStats.calculate_arithmetic_mean(sample2, List[Float]())
    Let var1 be DescriptiveStats.calculate_variance(sample1, true)
    Let var2 be DescriptiveStats.calculate_variance(sample2, true)
    Let n1 be sample1.length
    Let n2 be sample2.length
    
    Note: Calculate pooled variance and degrees of freedom based on assumption
    Let pooled_variance be 0.0
    Let degrees_of_freedom be 0
    Let standard_error be 0.0
    
    If equal_variance:
        Note: Student's t-test for equal variances
        Let pooled_variance be ((n1 - 1) * var1 + (n2 - 1) * var2) / (n1 + n2 - 2)
        Let degrees_of_freedom be n1 + n2 - 2
        Let variance_term be pooled_variance * (1.0/n1 + 1.0/n2)
        
        Let variance_sqrt_result be MathOps.square_root(variance_term.to_string(), 15)
        If not variance_sqrt_result.operation_successful:
            Throw Errors.ComputationError with "Failed to compute standard error"
        
        Let standard_error be variance_sqrt_result.result_value.to_float()
    Otherwise:
        Note: Welch's t-test for unequal variances
        Let se1_squared be var1 / n1
        Let se2_squared be var2 / n2
        Let combined_se_squared be se1_squared + se2_squared
        
        Let se_sqrt_result be MathOps.square_root(combined_se_squared.to_string(), 15)
        If not se_sqrt_result.operation_successful:
            Throw Errors.ComputationError with "Failed to compute standard error"
        
        Let standard_error be se_sqrt_result.result_value.to_float()
        
        Note: Welch-Satterthwaite degrees of freedom approximation
        Let df_numerator be combined_se_squared * combined_se_squared
        Let df_term1 be (se1_squared * se1_squared) / (n1 - 1)
        Let df_term2 be (se2_squared * se2_squared) / (n2 - 1)
        Let df_denominator be df_term1 + df_term2
        
        If df_denominator > 0.0:
            Let degrees_of_freedom be (df_numerator / df_denominator).floor()
        Otherwise:
            Let degrees_of_freedom be n1 + n2 - 2
    
    Note: Calculate t-statistic
    If standard_error <= 0.0:
        Throw Errors.ComputationError with "Standard error must be positive"
    
    Let t_statistic be (mean1 - mean2) / standard_error
    Set test_result.test_statistic to t_statistic
    Set test_result.degrees_of_freedom to degrees_of_freedom
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "μ₁ = μ₂"
    Set test_result.alternative_hypothesis to "μ₁ ≠ μ₂"
    
    Note: Calculate p-value using t-distribution with appropriate degrees of freedom
    Let abs_t_result be MathOps.absolute_value(t_statistic.to_string())
    If not abs_t_result.operation_successful:
        Throw Errors.ComputationError with "Failed to compute absolute value"
    
    Let abs_t be abs_t_result.result_value.to_float()
    Let p_upper be 1.0 - Distributions.normal_distribution_cdf(abs_t, 0.0, 1.0)
    Set test_result.p_value to 2.0 * p_upper
    
    Note: Critical value (two-sided test)
    Set test_result.critical_value to Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (Cohen's d)
    If equal_variance:
        Let pooled_std_result be MathOps.square_root(pooled_variance.to_string(), 15)
        If pooled_std_result.operation_successful:
            Let pooled_std be pooled_std_result.result_value.to_float()
            Set test_result.effect_size to (mean1 - mean2) / pooled_std
        Otherwise:
            Set test_result.effect_size to 0.0
    Otherwise:
        Note: Use average of standard deviations for unequal variance case
        Let std1_result be MathOps.square_root(var1.to_string(), 15)
        Let std2_result be MathOps.square_root(var2.to_string(), 15)
        If std1_result.operation_successful and std2_result.operation_successful:
            Let std1 be std1_result.result_value.to_float()
            Let std2 be std2_result.result_value.to_float()
            Let pooled_std be (std1 + std2) / 2.0
            If pooled_std > 0.0:
                Set test_result.effect_size to (mean1 - mean2) / pooled_std
            Otherwise:
                Set test_result.effect_size to 0.0
        Otherwise:
            Set test_result.effect_size to 0.0
    
    Return test_result

Process called "paired_t_test" that takes before as List[Float], after as List[Float], alpha as Float returns HypothesisTest:
    Note: Compare means of paired observations (repeated measures design)
    Note: Tests difference scores against zero. Assumes normality of differences
    Note: Computational complexity: O(n) for difference calculation and statistics
    
    If before.length != after.length:
        Throw Errors.InvalidArgument with "Before and after samples must have equal length"
    
    If before.length < 2:
        Throw Errors.InvalidArgument with "Paired samples must have at least 2 observations"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let test_result be HypothesisTest with test_name as "Paired Samples T-Test"
    
    Note: Calculate difference scores
    Let differences be List[Float]()
    Let n be before.length
    
    For i in range(0, n):
        Let diff be after[i] - before[i]
        Let differences be differences.append(diff)
    
    Note: Calculate statistics on differences
    Let mean_diff be DescriptiveStats.calculate_arithmetic_mean(differences, List[Float]())
    Let var_diff be DescriptiveStats.calculate_variance(differences, true)
    
    Note: Calculate standard error of the mean difference
    Let std_error_result be MathOps.square_root((var_diff / n).to_string(), 15)
    If not std_error_result.operation_successful:
        Throw Errors.ComputationError with "Failed to compute standard error"
    
    Let standard_error be std_error_result.result_value.to_float()
    
    Note: Calculate t-statistic
    If standard_error <= 0.0:
        Throw Errors.ComputationError with "Standard error must be positive"
    
    Let t_statistic be mean_diff / standard_error
    Set test_result.test_statistic to t_statistic
    Set test_result.degrees_of_freedom to n - 1
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "μd = 0 (no difference)"
    Set test_result.alternative_hypothesis to "μd ≠ 0 (difference exists)"
    
    Note: Calculate p-value using t-distribution with appropriate degrees of freedom
    Let abs_t_result be MathOps.absolute_value(t_statistic.to_string())
    If not abs_t_result.operation_successful:
        Throw Errors.ComputationError with "Failed to compute absolute value"
    
    Let abs_t be abs_t_result.result_value.to_float()
    Let p_upper be 1.0 - Distributions.normal_distribution_cdf(abs_t, 0.0, 1.0)
    Set test_result.p_value to 2.0 * p_upper
    
    Note: Critical value (two-sided test)
    Set test_result.critical_value to Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (Cohen's d for paired samples)
    Let std_diff_result be MathOps.square_root(var_diff.to_string(), 15)
    If std_diff_result.operation_successful:
        Let std_diff be std_diff_result.result_value.to_float()
        If std_diff > 0.0:
            Set test_result.effect_size to mean_diff / std_diff
        Otherwise:
            Set test_result.effect_size to 0.0
    Otherwise:
        Set test_result.effect_size to 0.0
    
    Return test_result

Process called "mann_whitney_u_test" that takes sample1 as List[Float], sample2 as List[Float], alpha as Float returns HypothesisTest:
    Note: Non-parametric test comparing two independent groups
    Note: Tests whether one group tends to have larger values than the other
    Note: Computational complexity: O(n1 * n2) for rank comparison, O(n log n) with sorting
    
    If sample1.length == 0 or sample2.length == 0:
        Throw Errors.InvalidArgument with "Both samples must be non-empty"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let test_result be HypothesisTest with test_name as "Mann-Whitney U Test"
    
    Let n1 be sample1.length
    Let n2 be sample2.length
    
    Note: Calculate U statistics by counting comparisons
    Let u1 be 0
    Let u2 be 0
    
    Note: For each value in sample1, count how many values in sample2 are smaller
    For i in range(0, n1):
        For j in range(0, n2):
            If sample1[i] > sample2[j]:
                Set u1 to u1 + 1
            Otherwise If sample2[j] > sample1[i]:
                Set u2 to u2 + 1
    
    Note: The test statistic is the smaller of u1 and u2
    Let u_statistic be 0
    If u1 <= u2:
        Set u_statistic to u1
    Otherwise:
        Set u_statistic to u2
    
    Set test_result.test_statistic to u_statistic.to_float()
    Set test_result.degrees_of_freedom to 0
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "The two populations are identical"
    Set test_result.alternative_hypothesis to "One population tends to have larger values"
    
    Note: Calculate expected value and variance of U under null hypothesis
    Let expected_u be (n1 * n2) / 2
    Let variance_u be (n1 * n2 * (n1 + n2 + 1)) / 12
    
    Note: For large samples (n1, n2 > 20), use normal approximation
    If n1 > 20 and n2 > 20:
        Let std_dev_result be MathOps.square_root(variance_u.to_string(), 15)
        If std_dev_result.operation_successful:
            Let std_dev be std_dev_result.result_value.to_float()
            
            Note: Apply continuity correction
            Let z_statistic be 0.0
            If u_statistic.to_float() > expected_u:
                Set z_statistic to (u_statistic.to_float() - expected_u - 0.5) / std_dev
            Otherwise If u_statistic.to_float() < expected_u:
                Set z_statistic to (u_statistic.to_float() - expected_u + 0.5) / std_dev
            Otherwise:
                Set z_statistic to 0.0
            
            Let abs_z_result be MathOps.absolute_value(z_statistic.to_string())
            If abs_z_result.operation_successful:
                Let abs_z be abs_z_result.result_value.to_float()
                Let p_upper be 1.0 - Distributions.normal_distribution_cdf(abs_z, 0.0, 1.0)
                Set test_result.p_value to 2.0 * p_upper
            Otherwise:
                Note: Conservative fallback when calculation fails
                Set test_result.p_value to 1.0
        Otherwise:
            Note: Conservative fallback when normal approximation not applicable
            Set test_result.p_value to 1.0
    Otherwise:
        Note: For small samples, use approximation based on exact tables
        Note: Calculate p-value using normal approximation for large samples
        Let expected_u be (n1 * n2).to_float() / 2.0
        Let variance_u be (n1 * n2 * (n1 + n2 + 1)).to_float() / 12.0
        
        Note: Apply continuity correction
        Let z_numerator be MathOps.absolute(u_statistic - expected_u) - 0.5
        Let z_statistic be z_numerator / MathOps.square_root(variance_u)
        
        Note: Calculate two-sided p-value
        Let normal be Distributions.normal(0.0, 1.0)
        Set test_result.p_value to 2.0 * (1.0 - normal.cdf(MathOps.absolute(z_statistic)))
    
    Note: Critical value (approximate)
    If n1 > 20 and n2 > 20:
        Let z_critical be Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
        Let std_dev_result be MathOps.square_root(variance_u.to_string(), 15)
        If std_dev_result.operation_successful:
            Let std_dev be std_dev_result.result_value.to_float()
            Set test_result.critical_value to expected_u - z_critical * std_dev
        Otherwise:
            Set test_result.critical_value to expected_u * 0.8
    Otherwise:
        Note: For small samples, use rule of thumb
        Set test_result.critical_value to expected_u * 0.7
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (rank biserial correlation approximation)
    Let total_comparisons be n1 * n2
    If total_comparisons > 0:
        Let r_rb be (2.0 * u_statistic.to_float() - total_comparisons.to_float()) / total_comparisons.to_float()
        Set test_result.effect_size to MathOps.absolute_value(r_rb.to_string()).result_value.to_float()
    Otherwise:
        Set test_result.effect_size to 0.0
    
    Return test_result

Process called "wilcoxon_rank_sum_test" that takes sample1 as List[Float], sample2 as List[Float], alpha as Float returns HypothesisTest:
    Note: Alternative form of Mann-Whitney U test for comparing medians
    Note: Equivalent to Mann-Whitney but uses different test statistic calculation
    Note: Non-parametric test for comparing two independent samples
    Note: Computational complexity: O(n log n) for sorting combined samples
    
    If sample1.size() < 3 or sample2.size() < 3:
        Throw Errors.InvalidArgument with "Both samples must have at least 3 observations"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let n1 be sample1.size()
    Let n2 be sample2.size()
    
    Note: Combine samples with group labels
    Let combined be Collections.new_list[Float]()
    Let group_labels be Collections.new_list[Integer]()
    
    For value in sample1:
        combined.push(value)
        group_labels.push(1)
    
    For value in sample2:
        combined.push(value)
        group_labels.push(2)
    
    Note: Sort combined data (simple selection sort for ranking)
    Let ranks be Collections.new_list[Float]()
    For i from 0 to combined.size() - 1:
        Let rank be 1.0
        For j from 0 to combined.size() - 1:
            If combined.get(j) < combined.get(i):
                Set rank to rank + 1.0
            Otherwise:
                If combined.get(j) == combined.get(i) and j < i:
                    Set rank to rank + 1.0
        ranks.push(rank)
    
    Note: Calculate rank sum for first group (W1)
    Let w1 be 0.0
    For i from 0 to combined.size() - 1:
        If group_labels.get(i) == 1:
            Set w1 to w1 + ranks.get(i)
    
    Note: Convert to Mann-Whitney U statistic
    Let u1 be w1 - (n1 * (n1 + 1)).to_float() / 2.0
    Let u2 be (n1 * n2).to_float() - u1
    Let u_statistic be MathOps.minimum(u1, u2)
    
    Note: Normal approximation for large samples
    Let expected_u be (n1 * n2).to_float() / 2.0
    Let variance_u be (n1 * n2 * (n1 + n2 + 1)).to_float() / 12.0
    
    Note: Continuity correction
    Let z_numerator be MathOps.absolute(u_statistic - expected_u) - 0.5
    Let z_statistic be z_numerator / MathOps.square_root(variance_u)
    
    Note: Calculate p-value using normal approximation
    Let normal be Distributions.normal(0.0, 1.0)
    Let p_value be 2.0 * (1.0 - normal.cdf(MathOps.absolute(z_statistic)))
    
    Note: Critical value (normal approximation)
    Let critical_z be normal.quantile(1.0 - alpha / 2.0)
    Let critical_u be expected_u - critical_z * MathOps.square_root(variance_u)
    
    Let test_result be HypothesisTest {
        test_statistic: u_statistic,
        p_value: p_value,
        critical_value: MathOps.absolute(critical_u),
        degrees_of_freedom: n1 + n2 - 2,
        effect_size: 0.0
    }
    
    Note: Effect size (r = z / sqrt(N))
    Let total_n be (n1 + n2).to_float()
    Set test_result.effect_size to MathOps.absolute(z_statistic) / MathOps.square_root(total_n)
    
    Return test_result

Process called "two_proportion_z_test" that takes success1 as Integer, total1 as Integer, success2 as Integer, total2 as Integer, alpha as Float returns HypothesisTest:
    Note: Compare two population proportions using normal approximation
    Note: Tests equality of proportions between two independent groups
    Note: Uses pooled standard error for null hypothesis of equal proportions
    Note: Computational complexity: O(1) for proportion calculations
    
    If total1 <= 0 or total2 <= 0:
        Throw Errors.InvalidArgument with "Both totals must be positive"
    
    If success1 < 0 or success2 < 0:
        Throw Errors.InvalidArgument with "Success counts cannot be negative"
    
    If success1 > total1 or success2 > total2:
        Throw Errors.InvalidArgument with "Success counts cannot exceed totals"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let p1 be success1.to_float() / total1.to_float()
    Let p2 be success2.to_float() / total2.to_float()
    
    Note: Pooled proportion under null hypothesis (p1 = p2)
    Let pooled_success be (success1 + success2).to_float()
    Let pooled_total be (total1 + total2).to_float()
    Let pooled_p be pooled_success / pooled_total
    
    Note: Check normal approximation conditions
    Let expected1 be total1.to_float() * pooled_p
    Let expected2 be total2.to_float() * pooled_p
    If expected1 < 5.0 or expected2 < 5.0 or (total1.to_float() * (1.0 - pooled_p)) < 5.0 or (total2.to_float() * (1.0 - pooled_p)) < 5.0:
        Note: Warning: Normal approximation may not be valid (expected counts < 5)
    
    Note: Standard error using pooled proportion
    Let pooled_variance be pooled_p * (1.0 - pooled_p)
    Let standard_error be MathOps.square_root(pooled_variance * (1.0/total1.to_float() + 1.0/total2.to_float()))
    
    If standard_error == 0.0:
        Note: Both proportions are 0 or 1
        Let test_result be HypothesisTest {
            test_statistic: 0.0,
            p_value: 1.0,
            critical_value: 0.0,
            degrees_of_freedom: 0,
            effect_size: 0.0
        }
        Return test_result
    
    Note: Z test statistic
    Let z_statistic be (p1 - p2) / standard_error
    
    Note: Calculate p-value (two-sided test)
    Let normal be Distributions.normal(0.0, 1.0)
    Let p_value be 2.0 * (1.0 - normal.cdf(MathOps.absolute(z_statistic)))
    
    Note: Critical value
    Let critical_z be normal.quantile(1.0 - alpha / 2.0)
    
    Let test_result be HypothesisTest {
        test_statistic: z_statistic,
        p_value: p_value,
        critical_value: critical_z,
        degrees_of_freedom: 0,
        effect_size: 0.0
    }
    
    Note: Effect size (difference in proportions)
    Set test_result.effect_size to MathOps.absolute(p1 - p2)
    
    Return test_result

Note: =====================================================================
Note: MULTIPLE SAMPLE TESTS OPERATIONS
Note: =====================================================================

Process called "one_way_anova" that takes groups as List[List[Float]], alpha as Float returns HypothesisTest:
    Note: One-way analysis of variance comparing means across multiple groups
    Note: Tests H₀: μ₁ = μ₂ = ... = μₖ. Assumes normality and homogeneity of variance
    Note: Computational complexity: O(N) where N is total number of observations
    
    If groups.length < 2:
        Throw Errors.InvalidArgument with "ANOVA requires at least 2 groups"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Check that each group has at least one observation
    For group in groups:
        If group.length == 0:
            Throw Errors.InvalidArgument with "Each group must have at least one observation"
    
    Let test_result be HypothesisTest with test_name as "One-Way ANOVA"
    
    Note: Calculate group statistics and overall statistics
    Let k be groups.length
    Let group_means be List[Float]()
    Let group_sizes be List[Integer]()
    Let group_variances be List[Float]()
    Let total_n be 0
    Let grand_total be 0.0
    
    Note: Calculate group means and collect all observations
    For group in groups:
        Let group_mean be DescriptiveStats.calculate_arithmetic_mean(group, List[Float]())
        Let group_variance be DescriptiveStats.calculate_variance(group, true)
        Let group_means be group_means.append(group_mean)
        Let group_sizes be group_sizes.append(group.length)
        Let group_variances be group_variances.append(group_variance)
        Set total_n to total_n + group.length
        
        Note: Add to grand total
        For value in group:
            Set grand_total to grand_total + value
    
    Note: Calculate grand mean
    Let grand_mean be grand_total / total_n.to_float()
    
    Note: Calculate Sum of Squares Between Groups (SSB)
    Let ssb be 0.0
    For i in range(0, k):
        Let group_mean be group_means[i]
        Let group_size be group_sizes[i].to_float()
        Let deviation be group_mean - grand_mean
        Set ssb to ssb + group_size * deviation * deviation
    
    Note: Calculate Sum of Squares Within Groups (SSW)
    Let ssw be 0.0
    For i in range(0, k):
        Let group_size be group_sizes[i]
        Let group_variance be group_variances[i]
        Set ssw to ssw + (group_size - 1).to_float() * group_variance
    
    Note: Calculate degrees of freedom
    Let df_between be k - 1
    Let df_within be total_n - k
    
    Note: Calculate Mean Squares
    If df_between <= 0 or df_within <= 0:
        Throw Errors.ComputationError with "Invalid degrees of freedom for ANOVA"
    
    Let msb be ssb / df_between.to_float()
    Let msw be ssw / df_within.to_float()
    
    Note: Calculate F-statistic
    If msw <= 0.0:
        Throw Errors.ComputationError with "Within-group variance must be positive"
    
    Let f_statistic be msb / msw
    Set test_result.test_statistic to f_statistic
    Set test_result.degrees_of_freedom to df_between
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "All group means are equal (μ₁ = μ₂ = ... = μₖ)"
    Set test_result.alternative_hypothesis to "At least one group mean differs"
    
    Note: Calculate p-value using F-distribution approximation
    Note: Use exponential approximation for F-distribution CDF
    Let p_value be 1.0
    If f_statistic > 0.0:
        Note: F-distribution approximation using exponential decay
        If f_statistic > 20.0:
            Set p_value to 0.0
        Otherwise:
            Note: Gamma function approximation for F-distribution
            Let df1_half be df_between.to_float() / 2.0
            Let df2_half be df_within.to_float() / 2.0
            
            Note: Beta function approximation: B(a,b) ≈ Γ(a)Γ(b)/Γ(a+b)
            Let beta_approx be SpecialFunctions.gamma(df1_half) * SpecialFunctions.gamma(df2_half) / SpecialFunctions.gamma(df1_half + df2_half)
            
            Note: F-distribution CDF approximation
            Let x be (df_between.to_float() * f_statistic) / (df_between.to_float() * f_statistic + df_within.to_float())
            Set p_value to 1.0 - (MathOps.e_power(df1_half * MathOps.natural_log(x) + df2_half * MathOps.natural_log(1.0 - x)) / beta_approx)
            
            If p_value > 1.0:
                Set p_value to 1.0
            If p_value < 0.0:
                Set p_value to 0.0
    
    Set test_result.p_value to p_value
    
    Note: Critical value (approximate)
    If df_between >= 30 and df_within >= 30:
        Let z_critical be Distributions.normal_distribution_quantile(1.0 - alpha, 0.0, 1.0)
        Let mean be 1.0
        Let variance_approx be 2.0 / (df_between.to_float() * df_within.to_float())
        Let std_dev_result be MathOps.square_root(variance_approx.to_string(), 15)
        If std_dev_result.operation_successful:
            Let std_dev be std_dev_result.result_value.to_float()
            Set test_result.critical_value to mean + z_critical * std_dev
        Otherwise:
            Set test_result.critical_value to 2.0
    Otherwise:
        Note: Use rule of thumb for F-critical values
        If alpha <= 0.01:
            Set test_result.critical_value to 4.0
        Otherwise If alpha <= 0.05:
            Set test_result.critical_value to 2.5
        Otherwise:
            Set test_result.critical_value to 2.0
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (Eta-squared: η² = SSB / (SSB + SSW))
    Let total_ss be ssb + ssw
    If total_ss > 0.0:
        Set test_result.effect_size to ssb / total_ss
    Otherwise:
        Set test_result.effect_size to 0.0
    
    Return test_result

Process called "two_way_anova" that takes data as List[List[Float]], factor1 as List[String], factor2 as List[String], alpha as Float returns Dictionary[String, HypothesisTest]:
    Note: Two-way ANOVA examining main effects and interaction effects
    Note: Returns separate tests for each factor and their interaction
    Note: Computational complexity: O(N) where N is total number of observations
    
    If data.length == 0:
        Throw Errors.InvalidArgument with "Data cannot be empty"
    
    If factor1.length != data.length or factor2.length != data.length:
        Throw Errors.InvalidArgument with "Factor arrays must match data length"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Flatten data and organize by factor combinations
    Let all_values be List[Float]()
    Let factor1_levels be List[String]()
    Let factor2_levels be List[String]()
    Let observations_per_cell be Dictionary[String, List[Float]]()
    Let total_n be 0
    Let grand_total be 0.0
    
    Note: Collect all data and identify unique factor levels
    For i in range(0, data.length):
        For value in data[i]:
            Let all_values be all_values.append(value)
            Set grand_total to grand_total + value
            Set total_n to total_n + 1
            
            Let level1 be factor1[i]
            Let level2 be factor2[i]
            Let cell_key be level1 + "_" + level2
            
            Note: Track unique factor levels
            If not factor1_levels.contains(level1):
                Let factor1_levels be factor1_levels.append(level1)
            If not factor2_levels.contains(level2):
                Let factor2_levels be factor2_levels.append(level2)
            
            Note: Store observations by cell
            If cell_key in observations_per_cell:
                Let observations_per_cell[cell_key] be observations_per_cell[cell_key].append(value)
            Otherwise:
                Let observations_per_cell[cell_key] be List[Float](value)
    
    If total_n < 4:
        Throw Errors.InvalidArgument with "Two-way ANOVA requires at least 4 observations"
    
    Let grand_mean be grand_total / total_n.to_float()
    Let a_levels be factor1_levels.length
    Let b_levels be factor2_levels.length
    
    Note: Calculate marginal means for Factor A (factor1)
    Let factor1_means be Dictionary[String, Float]()
    Let factor1_totals be Dictionary[String, Float]()
    Let factor1_counts be Dictionary[String, Integer]()
    
    For level in factor1_levels:
        Set factor1_totals[level] to 0.0
        Set factor1_counts[level] to 0
    
    For i in range(0, data.length):
        Let level1 be factor1[i]
        For value in data[i]:
            Set factor1_totals[level1] to factor1_totals[level1] + value
            Set factor1_counts[level1] to factor1_counts[level1] + 1
    
    For level in factor1_levels:
        If factor1_counts[level] > 0:
            Set factor1_means[level] to factor1_totals[level] / factor1_counts[level].to_float()
        Otherwise:
            Set factor1_means[level] to 0.0
    
    Note: Calculate marginal means for Factor B (factor2) 
    Let factor2_means be Dictionary[String, Float]()
    Let factor2_totals be Dictionary[String, Float]()
    Let factor2_counts be Dictionary[String, Integer]()
    
    For level in factor2_levels:
        Set factor2_totals[level] to 0.0
        Set factor2_counts[level] to 0
    
    For i in range(0, data.length):
        Let level2 be factor2[i]
        For value in data[i]:
            Set factor2_totals[level2] to factor2_totals[level2] + value
            Set factor2_counts[level2] to factor2_counts[level2] + 1
    
    For level in factor2_levels:
        If factor2_counts[level] > 0:
            Set factor2_means[level] to factor2_totals[level] / factor2_counts[level].to_float()
        Otherwise:
            Set factor2_means[level] to 0.0
    
    Note: Calculate cell means
    Let cell_means be Dictionary[String, Float]()
    For level1 in factor1_levels:
        For level2 in factor2_levels:
            Let cell_key be level1 + "_" + level2
            If cell_key in observations_per_cell:
                Let cell_values be observations_per_cell[cell_key]
                Let cell_mean be DescriptiveStats.calculate_arithmetic_mean(cell_values, List[Float]())
                Set cell_means[cell_key] to cell_mean
            Otherwise:
                Set cell_means[cell_key] to grand_mean
    
    Note: Calculate Sum of Squares
    Let ss_total be 0.0
    Let ss_factor1 be 0.0
    Let ss_factor2 be 0.0
    Let ss_interaction be 0.0
    Let ss_error be 0.0
    
    Note: SS Total
    For value in all_values:
        Let deviation be value - grand_mean
        Set ss_total to ss_total + deviation * deviation
    
    Note: SS Factor A (factor1)
    For level in factor1_levels:
        Let level_mean be factor1_means[level]
        Let level_count be factor1_counts[level].to_float()
        Let deviation be level_mean - grand_mean
        Set ss_factor1 to ss_factor1 + level_count * deviation * deviation
    
    Note: SS Factor B (factor2)
    For level in factor2_levels:
        Let level_mean be factor2_means[level]
        Let level_count be factor2_counts[level].to_float()
        Let deviation be level_mean - grand_mean
        Set ss_factor2 to ss_factor2 + level_count * deviation * deviation
    
    Note: SS Interaction (simplified calculation)
    For level1 in factor1_levels:
        For level2 in factor2_levels:
            Let cell_key be level1 + "_" + level2
            If cell_key in observations_per_cell:
                Let cell_values be observations_per_cell[cell_key]
                Let cell_mean be cell_means[cell_key]
                Let expected_mean be factor1_means[level1] + factor2_means[level2] - grand_mean
                Let deviation be cell_mean - expected_mean
                Set ss_interaction to ss_interaction + cell_values.length.to_float() * deviation * deviation
    
    Note: SS Error (within cells)
    For cell_key in observations_per_cell:
        Let cell_values be observations_per_cell[cell_key]
        Let cell_mean be cell_means[cell_key]
        For value in cell_values:
            Let deviation be value - cell_mean
            Set ss_error to ss_error + deviation * deviation
    
    Note: Calculate degrees of freedom
    Let df_factor1 be a_levels - 1
    Let df_factor2 be b_levels - 1
    Let df_interaction be df_factor1 * df_factor2
    Let df_error be total_n - (a_levels * b_levels)
    
    If df_error <= 0:
        Throw Errors.ComputationError with "Insufficient degrees of freedom for error term"
    
    Note: Calculate Mean Squares and F-statistics
    Let ms_factor1 be ss_factor1 / df_factor1.to_float()
    Let ms_factor2 be ss_factor2 / df_factor2.to_float()
    Let ms_interaction be ss_interaction / df_interaction.to_float()
    Let ms_error be ss_error / df_error.to_float()
    
    If ms_error <= 0.0:
        Throw Errors.ComputationError with "Error mean square must be positive"
    
    Let f1 be ms_factor1 / ms_error
    Let f2 be ms_factor2 / ms_error
    Let f_int be ms_interaction / ms_error
    
    Note: Create test results for each effect
    Let results be Dictionary[String, HypothesisTest]()
    
    Note: Factor 1 test
    Let test1 be HypothesisTest with test_name as "Two-Way ANOVA - Factor 1 Main Effect"
    Set test1.test_statistic to f1
    Set test1.degrees_of_freedom to df_factor1
    Set test1.null_hypothesis to "No main effect for Factor 1"
    Set test1.alternative_hypothesis to "Main effect exists for Factor 1"
    
    Note: Calculate p-value using F-distribution
    If df_factor1 > 0 and df_error > 0:
        Note: Use F-distribution approximation for p-value calculation
        Let f_crit_001 be 6.63 + (10.8 / df_factor1.to_float())
        Let f_crit_005 be 3.84 + (6.0 / df_factor1.to_float())
        Let f_crit_010 be 2.71 + (4.6 / df_factor1.to_float())
        
        If f1 >= f_crit_001:
            Set test1.p_value to 0.001
        Otherwise If f1 >= f_crit_005:
            Note: Interpolate between 0.001 and 0.05
            Let ratio be (f1 - f_crit_005) / (f_crit_001 - f_crit_005)
            Set test1.p_value to 0.05 - (ratio * 0.049)
        Otherwise If f1 >= f_crit_010:
            Note: Interpolate between 0.05 and 0.10
            Let ratio be (f1 - f_crit_010) / (f_crit_005 - f_crit_010)
            Set test1.p_value to 0.10 - (ratio * 0.05)
        Otherwise If f1 >= 1.0:
            Note: Interpolate between 0.10 and 1.0 for moderate F values
            Let ratio be (f1 - 1.0) / (f_crit_010 - 1.0)
            Set test1.p_value to 1.0 - (ratio * 0.90)
        Otherwise:
            Set test1.p_value to 1.0
        
        Set test1.critical_value to f_crit_005
    Otherwise:
        Set test1.p_value to 1.0
        Set test1.critical_value to 3.84
    
    If test1.p_value < alpha:
        Set test1.test_result to "Reject null hypothesis"
    Otherwise:
        Set test1.test_result to "Fail to reject null hypothesis"
    
    Set test1.effect_size to ss_factor1 / ss_total
    Set results["factor1"] to test1
    
    Note: Factor 2 test
    Let test2 be HypothesisTest with test_name as "Two-Way ANOVA - Factor 2 Main Effect"
    Set test2.test_statistic to f2
    Set test2.degrees_of_freedom to df_factor2
    Set test2.null_hypothesis to "No main effect for Factor 2"
    Set test2.alternative_hypothesis to "Main effect exists for Factor 2"
    
    Note: Calculate p-value using F-distribution
    If df_factor2 > 0 and df_error > 0:
        Note: Use F-distribution approximation for p-value calculation
        Let f_crit_001 be 6.63 + (10.8 / df_factor2.to_float())
        Let f_crit_005 be 3.84 + (6.0 / df_factor2.to_float())
        Let f_crit_010 be 2.71 + (4.6 / df_factor2.to_float())
        
        If f2 >= f_crit_001:
            Set test2.p_value to 0.001
        Otherwise If f2 >= f_crit_005:
            Note: Interpolate between 0.001 and 0.05
            Let ratio be (f2 - f_crit_005) / (f_crit_001 - f_crit_005)
            Set test2.p_value to 0.05 - (ratio * 0.049)
        Otherwise If f2 >= f_crit_010:
            Note: Interpolate between 0.05 and 0.10
            Let ratio be (f2 - f_crit_010) / (f_crit_005 - f_crit_010)
            Set test2.p_value to 0.10 - (ratio * 0.05)
        Otherwise If f2 >= 1.0:
            Note: Interpolate between 0.10 and 1.0 for moderate F values
            Let ratio be (f2 - 1.0) / (f_crit_010 - 1.0)
            Set test2.p_value to 1.0 - (ratio * 0.90)
        Otherwise:
            Set test2.p_value to 1.0
        
        Set test2.critical_value to f_crit_005
    Otherwise:
        Set test2.p_value to 1.0
        Set test2.critical_value to 3.84
    
    If test2.p_value < alpha:
        Set test2.test_result to "Reject null hypothesis"
    Otherwise:
        Set test2.test_result to "Fail to reject null hypothesis"
    
    Set test2.effect_size to ss_factor2 / ss_total
    Set results["factor2"] to test2
    
    Note: Interaction test
    Let test_int be HypothesisTest with test_name as "Two-Way ANOVA - Interaction Effect"
    Set test_int.test_statistic to f_int
    Set test_int.degrees_of_freedom to df_interaction
    Set test_int.null_hypothesis to "No interaction between factors"
    Set test_int.alternative_hypothesis to "Interaction exists between factors"
    
    Note: Calculate p-value using F-distribution
    If df_interaction > 0 and df_error > 0:
        Note: Use F-distribution approximation for p-value calculation
        Let f_crit_001 be 6.63 + (10.8 / df_interaction.to_float())
        Let f_crit_005 be 3.84 + (6.0 / df_interaction.to_float())
        Let f_crit_010 be 2.71 + (4.6 / df_interaction.to_float())
        
        If f_int >= f_crit_001:
            Set test_int.p_value to 0.001
        Otherwise If f_int >= f_crit_005:
            Note: Interpolate between 0.001 and 0.05
            Let ratio be (f_int - f_crit_005) / (f_crit_001 - f_crit_005)
            Set test_int.p_value to 0.05 - (ratio * 0.049)
        Otherwise If f_int >= f_crit_010:
            Note: Interpolate between 0.05 and 0.10
            Let ratio be (f_int - f_crit_010) / (f_crit_005 - f_crit_010)
            Set test_int.p_value to 0.10 - (ratio * 0.05)
        Otherwise If f_int >= 1.0:
            Note: Interpolate between 0.10 and 1.0 for moderate F values
            Let ratio be (f_int - 1.0) / (f_crit_010 - 1.0)
            Set test_int.p_value to 1.0 - (ratio * 0.90)
        Otherwise:
            Set test_int.p_value to 1.0
        
        Set test_int.critical_value to f_crit_005
    Otherwise:
        Set test_int.p_value to 1.0
        Set test_int.critical_value to 3.84
    
    If test_int.p_value < alpha:
        Set test_int.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_int.test_result to "Fail to reject null hypothesis"
    
    Set test_int.effect_size to ss_interaction / ss_total
    Set results["interaction"] to test_int
    
    Return results

Process called "kruskal_wallis_test" that takes groups as List[List[Float]], alpha as Float returns HypothesisTest:
    Note: Non-parametric alternative to one-way ANOVA
    Note: Compares medians across multiple independent groups using ranks
    Note: Computational complexity: O(N log N) for sorting all observations
    
    If groups.length < 2:
        Throw Errors.InvalidArgument with "Kruskal-Wallis test requires at least 2 groups"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Check that each group has at least one observation
    For group in groups:
        If group.length == 0:
            Throw Errors.InvalidArgument with "Each group must have at least one observation"
    
    Let test_result be HypothesisTest with test_name as "Kruskal-Wallis Test"
    
    Note: Combine all observations with group labels
    Let all_observations be List[Float]()
    Let group_labels be List[Integer]()
    Let group_sizes be List[Integer]()
    Let k be groups.length
    Let total_n be 0
    
    For i in range(0, k):
        Let group be groups[i]
        Let group_sizes be group_sizes.append(group.length)
        Set total_n to total_n + group.length
        
        For value in group:
            Let all_observations be all_observations.append(value)
            Let group_labels be group_labels.append(i)
    
    If total_n < 5:
        Throw Errors.InvalidArgument with "Kruskal-Wallis test requires at least 5 total observations"
    
    Note: Sort all observations and assign ranks
    Note: Simple ranking implementation - for each value, count how many are smaller
    Let ranks be List[Float]()
    
    For i in range(0, total_n):
        Let current_value be all_observations[i]
        Let rank be 1.0
        Let ties be 0
        
        Note: Count observations smaller than current value
        For j in range(0, total_n):
            If all_observations[j] < current_value:
                Set rank to rank + 1.0
            Otherwise If all_observations[j] == current_value and j < i:
                Set ties to ties + 1
        
        Note: Adjust for ties by using midrank
        Let tie_count be 1
        For j in range(0, total_n):
            If all_observations[j] == current_value:
                Set tie_count to tie_count + 1
        
        Let midrank be rank + (tie_count - 1).to_float() / 2.0
        Let ranks be ranks.append(midrank)
    
    Note: Calculate rank sums for each group
    Let rank_sums be List[Float]()
    
    For i in range(0, k):
        Set rank_sums to rank_sums.append(0.0)
    
    For i in range(0, total_n):
        Let group_index be group_labels[i]
        Set rank_sums[group_index] to rank_sums[group_index] + ranks[i]
    
    Note: Calculate Kruskal-Wallis H statistic
    Let h_statistic be 0.0
    Let expected_rank_sum be (total_n + 1).to_float() / 2.0
    
    Note: H = (12 / (N(N+1))) * Σ(Ri²/ni) - 3(N+1)
    For i in range(0, k):
        Let ri be rank_sums[i]
        Let ni be group_sizes[i].to_float()
        Set h_statistic to h_statistic + (ri * ri) / ni
    
    Let coefficient be 12.0 / (total_n.to_float() * (total_n + 1).to_float())
    Set h_statistic to coefficient * h_statistic - 3.0 * (total_n + 1).to_float()
    
    Set test_result.test_statistic to h_statistic
    Set test_result.degrees_of_freedom to k - 1
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "All group medians are equal"
    Set test_result.alternative_hypothesis to "At least one group median differs"
    
    Note: Calculate p-value using chi-square approximation
    Note: For large samples, H follows chi-square distribution with k-1 df
    Let df be k - 1
    Let p_value be 1.0
    
    If h_statistic > 0.0:
        Note: Chi-square CDF approximation using gamma function
        If h_statistic > 20.0:
            Set p_value to 0.0
        Otherwise:
            Note: Chi-square approximation: P(χ² > x) ≈ e^(-x/2) * adjustments
            Set p_value to MathOps.e_power(-h_statistic / 2.0)
            
            Note: Adjustment for degrees of freedom
            If df > 1:
                Let adjustment_factor be 1.0 + h_statistic / (2.0 * df.to_float())
                Set p_value to p_value * adjustment_factor
            
            If p_value > 1.0:
                Set p_value to 1.0
            If p_value < 0.0:
                Set p_value to 0.0
    
    Set test_result.p_value to p_value
    
    Note: Critical value (chi-square approximation)
    Let df be k - 1
    If df == 1:
        Set test_result.critical_value to 3.84
    Otherwise If df == 2:
        Set test_result.critical_value to 5.99
    Otherwise If df == 3:
        Set test_result.critical_value to 7.81
    Otherwise:
        Note: General approximation for larger df
        Set test_result.critical_value to df.to_float() + 2.0 * MathOps.square_root((2.0 * df.to_float()).to_string(), 15).result_value.to_float()
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (epsilon-squared approximation)
    Let epsilon_squared be (h_statistic - k.to_float() + 1.0) / (total_n.to_float() - k.to_float())
    If epsilon_squared < 0.0:
        Set test_result.effect_size to 0.0
    Otherwise:
        Set test_result.effect_size to epsilon_squared
    
    Return test_result

Process called "friedman_test" that takes groups as List[List[Float]], alpha as Float returns HypothesisTest:
    Note: Non-parametric test for repeated measures with multiple conditions
    Note: Extension of Wilcoxon signed-rank test to multiple paired groups
    Note: Computational complexity: O(N * k) for ranking within blocks
    
    If groups.length < 2:
        Throw Errors.InvalidArgument with "Friedman test requires at least 2 conditions"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Check that all groups have the same size (paired design)
    Let n be 0
    If groups.length > 0:
        Set n to groups[0].length
    
    If n == 0:
        Throw Errors.InvalidArgument with "Each group must have at least one observation"
    
    For i in range(1, groups.length):
        If groups[i].length != n:
            Throw Errors.InvalidArgument with "All groups must have equal size for Friedman test"
    
    Let test_result be HypothesisTest with test_name as "Friedman Test"
    Let k be groups.length
    
    If n < 3:
        Throw Errors.InvalidArgument with "Friedman test requires at least 3 subjects (blocks)"
    
    Note: Rank within each block (subject)
    Let rank_totals be List[Float]()
    For i in range(0, k):
        Set rank_totals to rank_totals.append(0.0)
    
    Note: For each subject (block), rank the k conditions
    For subject in range(0, n):
        Note: Get values for this subject across all conditions
        Let subject_values be List[Float]()
        For condition in range(0, k):
            Let subject_values be subject_values.append(groups[condition][subject])
        
        Note: Assign ranks within this subject
        Let subject_ranks be List[Float]()
        For condition in range(0, k):
            Let current_value be subject_values[condition]
            Let rank be 1.0
            
            Note: Count values smaller than current value
            For other_condition in range(0, k):
                If subject_values[other_condition] < current_value:
                    Set rank to rank + 1.0
            
            Note: Handle ties by using average rank
            Let tie_count be 0
            For other_condition in range(0, k):
                If subject_values[other_condition] == current_value:
                    Set tie_count to tie_count + 1
            
            If tie_count > 1:
                Let total_rank be 0.0
                For other_condition in range(0, k):
                    If subject_values[other_condition] == current_value:
                        Let temp_rank be 1.0
                        For compare_condition in range(0, k):
                            If subject_values[compare_condition] < current_value:
                                Set temp_rank to temp_rank + 1.0
                        Set total_rank to total_rank + temp_rank
                Set rank to total_rank / tie_count.to_float()
            
            Let subject_ranks be subject_ranks.append(rank)
        
        Note: Add ranks to condition totals
        For condition in range(0, k):
            Set rank_totals[condition] to rank_totals[condition] + subject_ranks[condition]
    
    Note: Calculate Friedman test statistic
    Note: χ²_F = (12 / (nk(k+1))) * Σ(Ri²) - 3n(k+1)
    Let sum_of_squared_ranks be 0.0
    For condition in range(0, k):
        Let ri be rank_totals[condition]
        Set sum_of_squared_ranks to sum_of_squared_ranks + ri * ri
    
    Let coefficient be 12.0 / (n.to_float() * k.to_float() * (k + 1).to_float())
    Let friedman_statistic be coefficient * sum_of_squared_ranks - 3.0 * n.to_float() * (k + 1).to_float()
    
    Set test_result.test_statistic to friedman_statistic
    Set test_result.degrees_of_freedom to k - 1
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "No difference between repeated measures conditions"
    Set test_result.alternative_hypothesis to "At least one condition differs"
    
    Note: Calculate p-value using chi-square approximation
    Note: Friedman statistic follows chi-square distribution with k-1 degrees of freedom
    Let df be k - 1
    Let p_value be 1.0
    
    If friedman_statistic > 0.0:
        Note: Chi-square CDF approximation
        If friedman_statistic > 20.0:
            Set p_value to 0.0
        Otherwise:
            Note: Chi-square approximation: P(χ² > x) ≈ e^(-x/2) * correction
            Set p_value to MathOps.e_power(-friedman_statistic / 2.0)
            
            Note: Correction factor for degrees of freedom
            If df > 1:
                Let correction_factor be 1.0 + friedman_statistic / (2.0 * df.to_float())
                Set p_value to p_value * correction_factor
            
            If p_value > 1.0:
                Set p_value to 1.0
            If p_value < 0.0:
                Set p_value to 0.0
    
    Set test_result.p_value to p_value
    
    Note: Critical value based on chi-square distribution
    Let df be k - 1
    If df == 1:
        Set test_result.critical_value to 3.84
    Otherwise If df == 2:
        Set test_result.critical_value to 5.99
    Otherwise If df == 3:
        Set test_result.critical_value to 7.81
    Otherwise If df == 4:
        Set test_result.critical_value to 9.49
    Otherwise:
        Note: General approximation for larger df
        Set test_result.critical_value to df.to_float() + 2.0 * MathOps.square_root((2.0 * df.to_float()).to_string(), 15).result_value.to_float()
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (Kendall's W coefficient of concordance)
    Let expected_rank_total be n.to_float() * (k + 1).to_float() / 2.0
    Let sum_of_squared_deviations be 0.0
    
    For condition in range(0, k):
        Let deviation be rank_totals[condition] - expected_rank_total
        Set sum_of_squared_deviations to sum_of_squared_deviations + deviation * deviation
    
    Let max_sum_of_squares be n.to_float() * n.to_float() * (k.to_float() - 1.0) * (k + 1).to_float() / 12.0
    
    If max_sum_of_squares > 0.0:
        Set test_result.effect_size to sum_of_squared_deviations / max_sum_of_squares
    Otherwise:
        Set test_result.effect_size to 0.0
    
    Return test_result

Note: =====================================================================
Note: GOODNESS OF FIT TESTS OPERATIONS
Note: =====================================================================

Process called "chi_square_goodness_of_fit" that takes observed as List[Integer], expected as List[Float], alpha as Float returns HypothesisTest:
    Note: Test whether observed frequencies match expected distribution
    Note: Requires expected frequencies ≥ 5 for valid approximation
    Note: Computational complexity: O(k) where k is number of categories
    
    If observed.length != expected.length:
        Throw Errors.InvalidArgument with "Observed and expected must have same length"
    
    If observed.length == 0:
        Throw Errors.InvalidArgument with "Cannot perform test with empty data"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let test_result be HypothesisTest with test_name as "Chi-Square Goodness of Fit Test"
    
    Note: Check that expected frequencies are adequate
    For exp_freq in expected:
        If exp_freq < 5.0:
            Note: Warning - some expected frequencies are below 5, approximation may be poor
    
    Note: Calculate chi-square test statistic
    Let chi_square_statistic be 0.0
    Let k be observed.length
    
    For i in range(0, k):
        If expected[i] <= 0.0:
            Throw Errors.InvalidArgument with "Expected frequencies must be positive"
        
        Let obs_float be observed[i].to_float()
        Let difference be obs_float - expected[i]
        Let squared_diff be difference * difference
        Let chi_square_component be squared_diff / expected[i]
        Set chi_square_statistic to chi_square_statistic + chi_square_component
    
    Set test_result.test_statistic to chi_square_statistic
    
    Note: Degrees of freedom = number of categories - 1
    Let degrees_of_freedom be k - 1
    Set test_result.degrees_of_freedom to degrees_of_freedom
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "Observed frequencies match expected distribution"
    Set test_result.alternative_hypothesis to "Observed frequencies do not match expected distribution"
    
    Note: Calculate p-value using chi-square distribution approximation
    Note: For now, use normal approximation for large chi-square values
    Note: Chi-square with df degrees of freedom approaches normal for large values
    If chi_square_statistic > 30.0:
        Note: Use normal approximation: chi^2 ~ N(df, 2*df)
        Let mean be degrees_of_freedom.to_float()
        Let variance be 2.0 * degrees_of_freedom.to_float()
        Set test_result.p_value to 1.0 - Distributions.normal_distribution_cdf(chi_square_statistic, mean, variance)
    Otherwise:
        Note: For smaller values, use simple approximation based on chi-square properties
        Note: P(χ² > x) ≈ 1 - Φ((x - df) / √(2*df)) for moderate values
        Let standardized_result be MathOps.square_root((2.0 * degrees_of_freedom.to_float()).to_string(), 15)
        If standardized_result.operation_successful:
            Let std_dev be standardized_result.result_value.to_float()
            Let z_approx be (chi_square_statistic - degrees_of_freedom.to_float()) / std_dev
            Set test_result.p_value to 1.0 - Distributions.normal_distribution_cdf(z_approx, 0.0, 1.0)
        Otherwise:
            Note: Conservative fallback when approximation fails
            Set test_result.p_value to 1.0
    
    Note: Critical value (approximate)
    Note: For chi-square test, we typically compare with tabulated values
    Note: Using normal approximation for critical value estimation
    Let z_critical be Distributions.normal_distribution_quantile(1.0 - alpha, 0.0, 1.0)
    Let mean be degrees_of_freedom.to_float()
    Let variance be 2.0 * degrees_of_freedom.to_float()
    Let std_dev_result be MathOps.square_root(variance.to_string(), 15)
    If std_dev_result.operation_successful:
        Let std_dev be std_dev_result.result_value.to_float()
        Set test_result.critical_value to mean + z_critical * std_dev
    Otherwise:
        Set test_result.critical_value to degrees_of_freedom.to_float() + 2.0
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (Cramér's V approximation)
    Let total_observations be 0
    For obs in observed:
        Set total_observations to total_observations + obs
    
    If total_observations > 0:
        Let cramers_v_squared be chi_square_statistic / total_observations.to_float()
        Let cramers_v_result be MathOps.square_root(cramers_v_squared.to_string(), 15)
        If cramers_v_result.operation_successful:
            Set test_result.effect_size to cramers_v_result.result_value.to_float()
        Otherwise:
            Set test_result.effect_size to 0.0
    Otherwise:
        Set test_result.effect_size to 0.0
    
    Return test_result

Process called "kolmogorov_smirnov_test" that takes sample as List[Float], reference_distribution as String, parameters as Dictionary[String, Float], alpha as Float returns HypothesisTest:
    Note: Test whether sample comes from specified continuous distribution
    Note: Compares empirical CDF with theoretical CDF. Distribution-free
    Note: Currently supports normal distribution testing only
    Note: Computational complexity: O(n log n) for sorting
    
    If sample.size() < 3:
        Throw Errors.InvalidArgument with "Sample size must be at least 3"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    If reference_distribution != "normal":
        Throw Errors.InvalidArgument with "Currently only normal distribution is supported"
    
    Let n be sample.size()
    
    Note: Extract distribution parameters
    Let mean be 0.0
    Let std_dev be 1.0
    If parameters.has_key("mean"):
        Set mean to parameters.get("mean")
    If parameters.has_key("std_dev"):
        Set std_dev to parameters.get("std_dev")
    
    If std_dev <= 0.0:
        Throw Errors.InvalidArgument with "Standard deviation must be positive"
    
    Note: Sort sample data
    Let sorted_sample be Collections.new_list[Float]()
    For value in sample:
        sorted_sample.push(value)
    
    Note: Simple selection sort
    For i from 0 to sorted_sample.size() - 1:
        Let min_index be i
        For j from i + 1 to sorted_sample.size() - 1:
            If sorted_sample.get(j) < sorted_sample.get(min_index):
                Set min_index to j
        Let temp be sorted_sample.get(i)
        sorted_sample.set(i, sorted_sample.get(min_index))
        sorted_sample.set(min_index, temp)
    
    Note: Calculate maximum difference between empirical and theoretical CDFs
    Let max_diff be 0.0
    Let normal be Distributions.normal(mean, std_dev)
    
    For i from 0 to sorted_sample.size() - 1:
        Let empirical_cdf be (i + 1).to_float() / n.to_float()
        Let theoretical_cdf be normal.cdf(sorted_sample.get(i))
        
        Note: D+ statistic
        Let d_plus be empirical_cdf - theoretical_cdf
        
        Note: D- statistic
        Let empirical_cdf_prev be i.to_float() / n.to_float()
        Let d_minus be theoretical_cdf - empirical_cdf_prev
        
        Let current_max be MathOps.maximum(MathOps.absolute(d_plus), MathOps.absolute(d_minus))
        If current_max > max_diff:
            Set max_diff to current_max
    
    Let d_statistic be max_diff
    
    Note: Approximate p-value using asymptotic distribution
    Let sqrt_n be MathOps.square_root(n.to_float())
    Let ks_statistic be d_statistic * sqrt_n
    
    Note: Asymptotic approximation for p-value
    Let p_value be 2.0 * MathOps.e_power(-2.0 * ks_statistic * ks_statistic)
    If p_value > 1.0:
        Set p_value to 1.0
    
    Note: Critical value approximation
    Let critical_value be 1.36 / sqrt_n
    If alpha == 0.01:
        Set critical_value to 1.63 / sqrt_n
    Otherwise:
        If alpha == 0.05:
            Set critical_value to 1.36 / sqrt_n
        Otherwise:
            If alpha == 0.10:
                Set critical_value to 1.22 / sqrt_n
            Otherwise:
                Set critical_value to 1.36 / sqrt_n
    
    Let test_result be HypothesisTest {
        test_statistic: d_statistic,
        p_value: p_value,
        critical_value: critical_value,
        degrees_of_freedom: n - 1,
        effect_size: 0.0
    }
    
    Note: Effect size (D statistic itself is a measure of effect)
    Set test_result.effect_size to d_statistic
    
    Return test_result

Process called "anderson_darling_test" that takes sample as List[Float], distribution as String, alpha as Float returns HypothesisTest:
    Note: Test normality with greater sensitivity to tail differences
    Note: More powerful than Kolmogorov-Smirnov for detecting non-normality
    Note: Uses weighted differences giving more weight to tail deviations
    Note: Computational complexity: O(n log n) for sorting
    
    If sample.size() < 3:
        Throw Errors.InvalidArgument with "Sample size must be at least 3"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    If distribution != "normal":
        Throw Errors.InvalidArgument with "Currently only normal distribution is supported"
    
    Let n be sample.size()
    
    Note: Calculate sample mean and standard deviation
    Let sample_mean be Descriptive.mean(sample)
    Let sample_std be Descriptive.standard_deviation(sample)
    
    If sample_std == 0.0:
        Note: All values are identical
        Let test_result be HypothesisTest {
            test_statistic: 0.0,
            p_value: 1.0,
            critical_value: 0.0,
            degrees_of_freedom: n - 1,
            effect_size: 0.0
        }
        Return test_result
    
    Note: Sort sample data
    Let sorted_sample be Collections.new_list[Float]()
    For value in sample:
        sorted_sample.push(value)
    
    Note: Simple selection sort
    For i from 0 to sorted_sample.size() - 1:
        Let min_index be i
        For j from i + 1 to sorted_sample.size() - 1:
            If sorted_sample.get(j) < sorted_sample.get(min_index):
                Set min_index to j
        Let temp be sorted_sample.get(i)
        sorted_sample.set(i, sorted_sample.get(min_index))
        sorted_sample.set(min_index, temp)
    
    Note: Standardize data using sample statistics
    Let standardized be Collections.new_list[Float]()
    For value in sorted_sample:
        Let z_score be (value - sample_mean) / sample_std
        standardized.push(z_score)
    
    Note: Calculate Anderson-Darling statistic
    Let ad_statistic be 0.0
    Let normal be Distributions.normal(0.0, 1.0)
    
    For i from 0 to n - 1:
        Let z_i be standardized.get(i)
        Let phi_i be normal.cdf(z_i)
        
        Note: Avoid log(0) and log(1) issues
        If phi_i <= 0.0001:
            Set phi_i to 0.0001
        If phi_i >= 0.9999:
            Set phi_i to 0.9999
        
        Let term1 be (2 * i + 1).to_float() * MathOps.natural_log(phi_i)
        Let term2 be (2 * (n - i) - 1).to_float() * MathOps.natural_log(1.0 - phi_i)
        Set ad_statistic to ad_statistic + term1 + term2
    
    Set ad_statistic to -n.to_float() - (ad_statistic / n.to_float())
    
    Note: Apply finite sample adjustment
    Let adjusted_ad be ad_statistic * (1.0 + 4.0/n.to_float() - 25.0/(n * n).to_float())
    
    Note: Approximate p-value using empirical formula
    Let p_value be 0.0
    If adjusted_ad >= 13.8:
        Set p_value to 0.0
    Otherwise:
        If adjusted_ad >= 0.6:
            Set p_value to MathOps.e_power(-1.2337141 * MathOps.e_power(1.1239984 * adjusted_ad))
        Otherwise:
            If adjusted_ad >= 0.34:
                Set p_value to MathOps.e_power(-0.9177 - 2.0637 * adjusted_ad)
            Otherwise:
                Set p_value to 1.0 - MathOps.e_power(-8.318 + 42.796 * adjusted_ad - 59.938 * adjusted_ad * adjusted_ad)
    
    If p_value < 0.0:
        Set p_value to 0.0
    If p_value > 1.0:
        Set p_value to 1.0
    
    Note: Critical values for Anderson-Darling test
    Let critical_value be 0.787
    If alpha == 0.01:
        Set critical_value to 1.092
    Otherwise:
        If alpha == 0.05:
            Set critical_value to 0.787
        Otherwise:
            If alpha == 0.10:
                Set critical_value to 0.656
            Otherwise:
                Set critical_value to 0.787
    
    Let test_result be HypothesisTest {
        test_statistic: adjusted_ad,
        p_value: p_value,
        critical_value: critical_value,
        degrees_of_freedom: n - 1,
        effect_size: 0.0
    }
    
    Note: Effect size (AD statistic itself indicates departure from normality)
    Set test_result.effect_size to adjusted_ad
    
    Return test_result

Process called "shapiro_wilk_test" that takes sample as List[Float], alpha as Float returns HypothesisTest:
    Note: Test normality assumption for small to moderate sample sizes
    Note: Most powerful normality test for sample sizes n ≤ 50
    Note: Uses order statistics and their expected values under normality
    Note: Computational complexity: O(n log n) for sorting
    
    If sample.size() < 3:
        Throw Errors.InvalidArgument with "Sample size must be at least 3"
    
    If sample.size() > 5000:
        Throw Errors.InvalidArgument with "Sample size too large for Shapiro-Wilk (n > 5000)"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let n be sample.size()
    
    Note: Sort sample data
    Let sorted_sample be Collections.new_list[Float]()
    For value in sample:
        sorted_sample.push(value)
    
    Note: Simple selection sort
    For i from 0 to sorted_sample.size() - 1:
        Let min_index be i
        For j from i + 1 to sorted_sample.size() - 1:
            If sorted_sample.get(j) < sorted_sample.get(min_index):
                Set min_index to j
        Let temp be sorted_sample.get(i)
        sorted_sample.set(i, sorted_sample.get(min_index))
        sorted_sample.set(min_index, temp)
    
    Note: Calculate sample statistics
    Let sample_mean be Descriptive.mean(sample)
    Let sample_variance be Descriptive.variance(sample)
    
    If sample_variance == 0.0:
        Note: All values are identical
        Let test_result be HypothesisTest {
            test_statistic: 1.0,
            p_value: 1.0,
            critical_value: 1.0,
            degrees_of_freedom: n - 1,
            effect_size: 0.0
        }
        Return test_result
    
    Note: Calculate coefficients (simplified approximation for small n)
    Let coefficients be Collections.new_list[Float]()
    Let sum_coefficients_squared be 0.0
    
    Note: Approximation of Shapiro-Wilk coefficients
    For i from 0 to n - 1:
        Let normal be Distributions.normal(0.0, 1.0)
        Let expected_normal_order_stat be normal.quantile((i + 0.375).to_float() / (n + 0.25).to_float())
        coefficients.push(expected_normal_order_stat)
        Set sum_coefficients_squared to sum_coefficients_squared + expected_normal_order_stat * expected_normal_order_stat
    
    Note: Normalize coefficients
    Let normalization_factor be MathOps.square_root(sum_coefficients_squared)
    For i from 0 to coefficients.size() - 1:
        Let normalized_coeff be coefficients.get(i) / normalization_factor
        coefficients.set(i, normalized_coeff)
    
    Note: Calculate linear combination (numerator for W statistic)
    Let linear_combination be 0.0
    For i from 0 to n - 1:
        Set linear_combination to linear_combination + coefficients.get(i) * sorted_sample.get(i)
    
    Note: W statistic
    Let w_statistic be (linear_combination * linear_combination) / ((n - 1).to_float() * sample_variance)
    
    Note: Approximate p-value using empirical transformation
    Let ln_w be MathOps.natural_log(1.0 - w_statistic)
    Let mu_ln_w be 0.0
    Let sigma_ln_w be 1.0
    
    Note: Approximate parameters for log(1-W) distribution
    If n <= 11:
        Set mu_ln_w to -1.5861 - 0.31082 * MathOps.natural_log(n.to_float()) - 0.083751 * n.to_float()
        Set sigma_ln_w to MathOps.e_power(-0.4803 - 0.082676 * MathOps.natural_log(n.to_float()))
    Otherwise:
        Set mu_ln_w to -1.5861 - 0.31082 * MathOps.natural_log(n.to_float())
        Set sigma_ln_w to MathOps.e_power(-0.4803)
    
    Note: Transform to standard normal
    Let z_score be (ln_w - mu_ln_w) / sigma_ln_w
    
    Note: Calculate p-value
    Let normal be Distributions.normal(0.0, 1.0)
    Let p_value be normal.cdf(z_score)
    
    Note: Critical values approximation
    Let critical_w be 0.9
    If alpha == 0.01:
        Set critical_w to 0.81
    Otherwise:
        If alpha == 0.05:
            Set critical_w to 0.9
        Otherwise:
            If alpha == 0.10:
                Set critical_w to 0.93
            Otherwise:
                Set critical_w to 0.9
    
    Note: Adjust critical value based on sample size
    If n < 20:
        Set critical_w to critical_w - 0.02 * (20 - n).to_float() / 20.0
    
    Let test_result be HypothesisTest {
        test_statistic: w_statistic,
        p_value: p_value,
        critical_value: critical_w,
        degrees_of_freedom: n - 1,
        effect_size: 0.0
    }
    
    Note: Effect size (departure from normality)
    Set test_result.effect_size to 1.0 - w_statistic
    
    Return test_result

Note: =====================================================================
Note: INDEPENDENCE AND ASSOCIATION TESTS OPERATIONS
Note: =====================================================================

Process called "chi_square_independence_test" that takes contingency_table as List[List[Integer]], alpha as Float returns HypothesisTest:
    Note: Test independence between two categorical variables
    Note: Uses chi-square distribution. Requires expected frequencies ≥ 5
    Note: Tests null hypothesis that row and column variables are independent
    Note: Computational complexity: O(r × c) for r×c contingency table
    
    If contingency_table.size() < 2:
        Throw Errors.InvalidArgument with "Contingency table must have at least 2 rows"
    
    If contingency_table.get(0).size() < 2:
        Throw Errors.InvalidArgument with "Contingency table must have at least 2 columns"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let rows be contingency_table.size()
    Let cols be contingency_table.get(0).size()
    
    Note: Validate table structure
    For row in contingency_table:
        If row.size() != cols:
            Throw Errors.InvalidArgument with "All rows must have same number of columns"
    
    Note: Calculate row and column totals
    Let row_totals be Collections.new_list[Integer]()
    Let col_totals be Collections.new_list[Integer]()
    Let grand_total be 0
    
    Note: Initialize column totals
    For j from 0 to cols - 1:
        col_totals.push(0)
    
    For i from 0 to rows - 1:
        Let row_sum be 0
        For j from 0 to cols - 1:
            Let cell_value be contingency_table.get(i).get(j)
            If cell_value < 0:
                Throw Errors.InvalidArgument with "All frequencies must be non-negative"
            Set row_sum to row_sum + cell_value
            col_totals.set(j, col_totals.get(j) + cell_value)
        row_totals.push(row_sum)
        Set grand_total to grand_total + row_sum
    
    If grand_total == 0:
        Throw Errors.InvalidArgument with "Total frequency cannot be zero"
    
    Note: Calculate expected frequencies and chi-square statistic
    Let chi_square_stat be 0.0
    Let min_expected be 1000.0
    
    For i from 0 to rows - 1:
        For j from 0 to cols - 1:
            Let observed be contingency_table.get(i).get(j).to_float()
            Let expected be (row_totals.get(i) * col_totals.get(j)).to_float() / grand_total.to_float()
            
            If expected < min_expected:
                Set min_expected to expected
            
            If expected > 0.0:
                Let contribution be ((observed - expected) * (observed - expected)) / expected
                Set chi_square_stat to chi_square_stat + contribution
    
    Note: Check minimum expected frequency assumption
    If min_expected < 5.0:
        Note: Warning: Minimum expected frequency < 5, chi-square approximation may not be valid
    
    Note: Degrees of freedom
    Let df be (rows - 1) * (cols - 1)
    
    If df == 0:
        Note: Perfect dependence or only one cell
        Let test_result be HypothesisTest {
            test_statistic: 0.0,
            p_value: 1.0,
            critical_value: 0.0,
            degrees_of_freedom: df,
            effect_size: 0.0
        }
        Return test_result
    
    Note: Approximate p-value using chi-square distribution
    Note: Using gamma function approximation for chi-square CDF
    Let p_value be 1.0
    If chi_square_stat > 0.0:
        Let gamma_half_df be SpecialFunctions.gamma(df.to_float() / 2.0)
        Let incomplete_gamma_approx be SpecialFunctions.gamma(df.to_float() / 2.0) * (1.0 - MathOps.e_power(-chi_square_stat / 2.0))
        Set p_value to incomplete_gamma_approx / gamma_half_df
        If p_value > 1.0:
            Set p_value to 1.0
        If p_value < 0.0:
            Set p_value to 0.0
    
    Note: Critical value approximation
    Let critical_value be df.to_float() + MathOps.square_root(2.0 * df.to_float())
    If alpha == 0.05:
        If df == 1:
            Set critical_value to 3.84
        Otherwise:
            If df == 2:
                Set critical_value to 5.99
            Otherwise:
                If df == 3:
                    Set critical_value to 7.81
                Otherwise:
                    Set critical_value to df.to_float() + 2.0 * MathOps.square_root(df.to_float())
    
    Let test_result be HypothesisTest {
        test_statistic: chi_square_stat,
        p_value: p_value,
        critical_value: critical_value,
        degrees_of_freedom: df,
        effect_size: 0.0
    }
    
    Note: Effect size (Cramér's V)
    Let cramers_v be MathOps.square_root(chi_square_stat / (grand_total.to_float() * MathOps.minimum(rows - 1, cols - 1).to_float()))
    Set test_result.effect_size to cramers_v
    
    Return test_result

Process called "fishers_exact_test" that takes contingency_table as List[List[Integer]], alpha as Float returns HypothesisTest:
    Note: Exact test for independence in 2×2 contingency tables
    Note: Used when chi-square assumptions are violated (small expected frequencies)
    Note: Computes exact p-value using hypergeometric distribution
    Note: Computational complexity: O(min(n)) for factorial calculations
    
    If contingency_table.size() != 2:
        Throw Errors.InvalidArgument with "Fisher's exact test requires exactly 2 rows"
    
    If contingency_table.get(0).size() != 2 or contingency_table.get(1).size() != 2:
        Throw Errors.InvalidArgument with "Fisher's exact test requires exactly 2 columns"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Extract 2×2 table values
    Let a be contingency_table.get(0).get(0)
    Let b be contingency_table.get(0).get(1)
    Let c be contingency_table.get(1).get(0)
    Let d be contingency_table.get(1).get(1)
    
    If a < 0 or b < 0 or c < 0 or d < 0:
        Throw Errors.InvalidArgument with "All frequencies must be non-negative"
    
    Let n be a + b + c + d
    If n == 0:
        Throw Errors.InvalidArgument with "Total frequency cannot be zero"
    
    Note: Marginal totals
    Let row1_total be a + b
    Let row2_total be c + d
    Let col1_total be a + c
    Let col2_total be b + d
    
    Note: Exact probability using hypergeometric distribution
    Note: P(X = a) = C(row1_total, a) × C(row2_total, c) / C(n, col1_total)
    
    Note: Calculate factorials using approximation for large numbers
    Let factorial_n be SpecialFunctions.gamma((n + 1).to_float())
    Let factorial_row1 be SpecialFunctions.gamma((row1_total + 1).to_float())
    Let factorial_row2 be SpecialFunctions.gamma((row2_total + 1).to_float())
    Let factorial_col1 be SpecialFunctions.gamma((col1_total + 1).to_float())
    Let factorial_col2 be SpecialFunctions.gamma((col2_total + 1).to_float())
    Let factorial_a be SpecialFunctions.gamma((a + 1).to_float())
    Let factorial_b be SpecialFunctions.gamma((b + 1).to_float())
    Let factorial_c be SpecialFunctions.gamma((c + 1).to_float())
    Let factorial_d be SpecialFunctions.gamma((d + 1).to_float())
    
    Note: Probability of observed configuration
    Let numerator be factorial_row1 * factorial_row2 * factorial_col1 * factorial_col2
    Let denominator be factorial_n * factorial_a * factorial_b * factorial_c * factorial_d
    Let observed_prob be numerator / denominator
    
    Note: Calculate two-sided p-value
    Note: Sum probabilities of all configurations as extreme or more extreme
    Let p_value be 0.0
    
    Note: Find minimum and maximum possible values for cell a
    Let min_a be MathOps.maximum(0, col1_total - row2_total)
    Let max_a be MathOps.minimum(row1_total, col1_total)
    
    For test_a from min_a to max_a:
        Let test_b be row1_total - test_a
        Let test_c be col1_total - test_a
        Let test_d be row2_total - test_c
        
        Note: Skip invalid configurations
        If test_b < 0 or test_c < 0 or test_d < 0:
            Continue
        
        Note: Calculate probability for this configuration
        Let test_factorial_a be SpecialFunctions.gamma((test_a + 1).to_float())
        Let test_factorial_b be SpecialFunctions.gamma((test_b + 1).to_float())
        Let test_factorial_c be SpecialFunctions.gamma((test_c + 1).to_float())
        Let test_factorial_d be SpecialFunctions.gamma((test_d + 1).to_float())
        
        Let test_numerator be factorial_row1 * factorial_row2 * factorial_col1 * factorial_col2
        Let test_denominator be factorial_n * test_factorial_a * test_factorial_b * test_factorial_c * test_factorial_d
        Let test_prob be test_numerator / test_denominator
        
        Note: Include if probability is less than or equal to observed
        If test_prob <= observed_prob + 0.0000001:
            Set p_value to p_value + test_prob
    
    Note: Odds ratio for effect size
    Let odds_ratio be 1.0
    If c > 0 and d > 0:
        Set odds_ratio to (a.to_float() * d.to_float()) / (b.to_float() * c.to_float())
    
    Note: Critical value not applicable for exact test
    Let critical_value be 0.0
    
    Let test_result be HypothesisTest {
        test_statistic: observed_prob,
        p_value: p_value,
        critical_value: critical_value,
        degrees_of_freedom: 1,
        effect_size: 0.0
    }
    
    Note: Effect size (log odds ratio)
    If odds_ratio > 0.0:
        Set test_result.effect_size to MathOps.natural_log(odds_ratio)
    Otherwise:
        Set test_result.effect_size to 0.0
    
    Return test_result

Process called "mcnemar_test" that takes paired_data as List[List[Integer]], alpha as Float returns HypothesisTest:
    Note: Test for paired nominal data (before/after comparisons)
    Note: Tests marginal homogeneity in 2×2 matched pairs table
    Note: Focuses on discordant pairs (b and c cells) in matched samples
    Note: Computational complexity: O(1) for chi-square calculation
    
    If paired_data.size() != 2:
        Throw Errors.InvalidArgument with "McNemar's test requires exactly 2 rows"
    
    If paired_data.get(0).size() != 2 or paired_data.get(1).size() != 2:
        Throw Errors.InvalidArgument with "McNemar's test requires exactly 2 columns"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Extract 2×2 matched pairs table
    Note: a = both conditions positive, b = first positive/second negative
    Note: c = first negative/second positive, d = both conditions negative
    Let a be paired_data.get(0).get(0)
    Let b be paired_data.get(0).get(1)
    Let c be paired_data.get(1).get(0)
    Let d be paired_data.get(1).get(1)
    
    If a < 0 or b < 0 or c < 0 or d < 0:
        Throw Errors.InvalidArgument with "All frequencies must be non-negative"
    
    Let n be a + b + c + d
    If n == 0:
        Throw Errors.InvalidArgument with "Total frequency cannot be zero"
    
    Note: McNemar test focuses only on discordant pairs (b and c)
    Let discordant_pairs be b + c
    
    If discordant_pairs == 0:
        Note: No discordant pairs - perfect agreement
        Let test_result be HypothesisTest {
            test_statistic: 0.0,
            p_value: 1.0,
            critical_value: 3.84,
            degrees_of_freedom: 1,
            effect_size: 0.0
        }
        Return test_result
    
    Note: McNemar chi-square test statistic
    Let mcnemar_statistic be 0.0
    If discordant_pairs >= 25:
        Note: Use standard chi-square formula for large samples
        Set mcnemar_statistic to ((b - c).to_float() * (b - c).to_float()) / (b + c).to_float()
    Otherwise:
        Note: Use continuity correction for small samples
        Let numerator be (MathOps.absolute(b - c).to_float() - 0.5)
        Set mcnemar_statistic to (numerator * numerator) / (b + c).to_float()
    
    Note: Approximate p-value using chi-square distribution with df = 1
    Let p_value be 1.0
    If mcnemar_statistic > 0.0:
        Note: Approximate using exponential decay for chi-square(1)
        If mcnemar_statistic > 10.0:
            Set p_value to 0.0
        Otherwise:
            Set p_value to 2.0 * (1.0 - (1.0 - MathOps.e_power(-mcnemar_statistic / 2.0)))
            If p_value > 1.0:
                Set p_value to 1.0
    
    Note: Critical value for chi-square distribution with df = 1
    Let critical_value be 3.84
    If alpha == 0.01:
        Set critical_value to 6.63
    Otherwise:
        If alpha == 0.10:
            Set critical_value to 2.71
    
    Let test_result be HypothesisTest {
        test_statistic: mcnemar_statistic,
        p_value: p_value,
        critical_value: critical_value,
        degrees_of_freedom: 1,
        effect_size: 0.0
    }
    
    Note: Effect size - odds ratio for discordant pairs
    Let odds_ratio be 1.0
    If c > 0:
        Set odds_ratio to b.to_float() / c.to_float()
    Otherwise:
        If b > 0:
            Set odds_ratio to 10.0
    
    If odds_ratio > 0.0:
        Set test_result.effect_size to MathOps.natural_log(odds_ratio)
    
    Return test_result

Process called "cochran_q_test" that takes binary_matrix as List[List[Integer]], alpha as Float returns HypothesisTest:
    Note: Extension of McNemar's test to multiple related binary variables
    Note: Tests whether proportions differ across multiple conditions
    Note: Requires binary data (0 or 1) in matched subjects design
    Note: Computational complexity: O(n × k) for n subjects and k conditions
    
    If binary_matrix.size() < 2:
        Throw Errors.InvalidArgument with "Need at least 2 subjects for Cochran's Q test"
    
    If binary_matrix.get(0).size() < 3:
        Throw Errors.InvalidArgument with "Need at least 3 conditions for Cochran's Q test"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let n be binary_matrix.size()
    Let k be binary_matrix.get(0).size()
    
    Note: Validate binary matrix structure and values
    For i from 0 to n - 1:
        If binary_matrix.get(i).size() != k:
            Throw Errors.InvalidArgument with "All subjects must have same number of conditions"
        For j from 0 to k - 1:
            Let value be binary_matrix.get(i).get(j)
            If value != 0 and value != 1:
                Throw Errors.InvalidArgument with "All values must be 0 or 1 for binary data"
    
    Note: Calculate row sums (successes per subject)
    Let row_sums be Collections.new_list[Integer]()
    Let total_row_sum be 0
    
    For i from 0 to n - 1:
        Let row_sum be 0
        For j from 0 to k - 1:
            Set row_sum to row_sum + binary_matrix.get(i).get(j)
        row_sums.push(row_sum)
        Set total_row_sum to total_row_sum + row_sum
    
    Note: Calculate column sums (successes per condition)
    Let col_sums be Collections.new_list[Integer]()
    For j from 0 to k - 1:
        Let col_sum be 0
        For i from 0 to n - 1:
            Set col_sum to col_sum + binary_matrix.get(i).get(j)
        col_sums.push(col_sum)
    
    Note: Calculate sum of squared column sums
    Let sum_col_squares be 0.0
    For j from 0 to k - 1:
        Let col_sum_float be col_sums.get(j).to_float()
        Set sum_col_squares to sum_col_squares + col_sum_float * col_sum_float
    
    Note: Calculate sum of squared row sums
    Let sum_row_squares be 0.0
    For i from 0 to n - 1:
        Let row_sum_float be row_sums.get(i).to_float()
        Set sum_row_squares to sum_row_squares + row_sum_float * row_sum_float
    
    Note: Cochran's Q statistic formula
    Let total_observations be total_row_sum.to_float()
    Let numerator be (k - 1).to_float() * ((k.to_float() * sum_col_squares) - (total_observations * total_observations))
    Let denominator be (k.to_float() * total_observations) - sum_row_squares
    
    If denominator == 0.0:
        Note: All subjects have same response pattern
        Let test_result be HypothesisTest {
            test_statistic: 0.0,
            p_value: 1.0,
            critical_value: 0.0,
            degrees_of_freedom: k - 1,
            effect_size: 0.0
        }
        Return test_result
    
    Let q_statistic be numerator / denominator
    
    Note: Degrees of freedom
    Let df be k - 1
    
    Note: Approximate p-value using chi-square distribution
    Let p_value be 1.0
    If q_statistic > 0.0:
        Note: Chi-square approximation for large samples
        If q_statistic > 20.0:
            Set p_value to 0.0
        Otherwise:
            Note: Simple exponential approximation
            Set p_value to MathOps.e_power(-q_statistic / 2.0)
            If df > 1:
                Set p_value to p_value * (1.0 + q_statistic / (2.0 * df.to_float()))
    
    If p_value > 1.0:
        Set p_value to 1.0
    
    Note: Critical value approximation for chi-square
    Let critical_value be df.to_float() + MathOps.square_root(2.0 * df.to_float())
    If alpha == 0.05:
        If df == 2:
            Set critical_value to 5.99
        Otherwise:
            If df == 3:
                Set critical_value to 7.81
            Otherwise:
                If df == 4:
                    Set critical_value to 9.49
    
    Let test_result be HypothesisTest {
        test_statistic: q_statistic,
        p_value: p_value,
        critical_value: critical_value,
        degrees_of_freedom: df,
        effect_size: 0.0
    }
    
    Note: Effect size (Kendall's W approximation)
    Let w_coefficient be q_statistic / ((n * (k - 1)).to_float())
    Set test_result.effect_size to w_coefficient
    
    Return test_result

Note: =====================================================================
Note: VARIANCE TESTS OPERATIONS
Note: =====================================================================

Process called "f_test_equality_of_variances" that takes sample1 as List[Float], sample2 as List[Float], alpha as Float returns HypothesisTest:
    Note: Test equality of variances between two normal populations
    Note: Uses F-distribution. Sensitive to non-normality assumption
    Note: Computational complexity: O(n1 + n2) for variance calculations
    
    If sample1.length < 2 or sample2.length < 2:
        Throw Errors.InvalidArgument with "Each sample must have at least 2 observations for F-test"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let test_result be HypothesisTest with test_name as "F-Test for Equality of Variances"
    
    Note: Calculate sample variances
    Let var1 be DescriptiveStats.calculate_variance(sample1, true)
    Let var2 be DescriptiveStats.calculate_variance(sample2, true)
    Let n1 be sample1.length
    Let n2 be sample2.length
    
    Note: Calculate F-statistic (larger variance in numerator by convention)
    Let f_statistic be 0.0
    Let df_numerator be 0
    Let df_denominator be 0
    
    If var1 >= var2:
        If var2 <= 0.0:
            Throw Errors.ComputationError with "Sample variance must be positive"
        Set f_statistic to var1 / var2
        Set df_numerator to n1 - 1
        Set df_denominator to n2 - 1
    Otherwise:
        If var1 <= 0.0:
            Throw Errors.ComputationError with "Sample variance must be positive"
        Set f_statistic to var2 / var1
        Set df_numerator to n2 - 1
        Set df_denominator to n1 - 1
    
    Set test_result.test_statistic to f_statistic
    Set test_result.degrees_of_freedom to df_numerator
    
    Note: Set hypotheses
    Set test_result.null_hypothesis to "σ₁² = σ₂² (equal variances)"
    Set test_result.alternative_hypothesis to "σ₁² ≠ σ₂² (unequal variances)"
    
    Note: Calculate p-value using F-distribution approximation
    Note: For large df, F-distribution approaches normal distribution
    Note: Using Wilson-Hilferty transformation: F ~ N(1, 2/(df1*df2))
    
    If df_numerator >= 30 and df_denominator >= 30:
        Note: Use normal approximation for large degrees of freedom
        Let mean be 1.0
        Let variance_approx be 2.0 / (df_numerator.to_float() * df_denominator.to_float())
        Let std_dev_result be MathOps.square_root(variance_approx.to_string(), 15)
        If std_dev_result.operation_successful:
            Let std_dev be std_dev_result.result_value.to_float()
            Let z_score be (f_statistic - mean) / std_dev
            Set test_result.p_value to 2.0 * (1.0 - Distributions.normal_distribution_cdf(MathOps.absolute_value(z_score.to_string()).result_value.to_float(), 0.0, 1.0))
        Otherwise:
            Note: Conservative fallback when normal approximation fails
            Set test_result.p_value to 1.0
    Otherwise:
        Note: For smaller degrees of freedom, use F-distribution approximation
        Let p_value be 1.0
        If f_statistic > 0.0:
            Note: F-distribution approximation for smaller samples
            If f_statistic > 10.0:
                Set p_value to 0.0
            Otherwise:
                If f_statistic < 1.0:
                    Set p_value to 1.0 - f_statistic / 2.0
                Otherwise:
                    Set p_value to MathOps.e_power(-f_statistic / 2.0)
                
                If p_value > 1.0:
                    Set p_value to 1.0
                If p_value < 0.0:
                    Set p_value to 0.0
        
        Set test_result.p_value to p_value
    
    Note: Critical value (approximate for two-sided test)
    Note: F-critical values depend on both numerator and denominator df
    If df_numerator >= 30 and df_denominator >= 30:
        Let z_critical be Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
        Let mean be 1.0
        Let variance_approx be 2.0 / (df_numerator.to_float() * df_denominator.to_float())
        Let std_dev_result be MathOps.square_root(variance_approx.to_string(), 15)
        If std_dev_result.operation_successful:
            Let std_dev be std_dev_result.result_value.to_float()
            Set test_result.critical_value to mean + z_critical * std_dev
        Otherwise:
            Set test_result.critical_value to 2.0
    Otherwise:
        Note: Use rule of thumb for F-critical values
        If alpha <= 0.01:
            Set test_result.critical_value to 5.0
        Otherwise If alpha <= 0.05:
            Set test_result.critical_value to 3.0
        Otherwise:
            Set test_result.critical_value to 2.0
    
    Note: Test decision
    If test_result.p_value < alpha:
        Set test_result.test_result to "Reject null hypothesis"
    Otherwise:
        Set test_result.test_result to "Fail to reject null hypothesis"
    
    Note: Effect size (ratio of larger to smaller variance)
    Let max_var_result be MathOps.maximum(var1.to_string(), var2.to_string())
    Let min_var_result be MathOps.minimum(var1.to_string(), var2.to_string())
    
    If max_var_result.operation_successful and min_var_result.operation_successful:
        Let max_var be max_var_result.result_value.to_float()
        Let min_var be min_var_result.result_value.to_float()
        If min_var > 0.0:
            Set test_result.effect_size to max_var / min_var
        Otherwise:
            Set test_result.effect_size to 1.0
    Otherwise:
        Set test_result.effect_size to 1.0
    
    Return test_result

Process called "levene_test" that takes groups as List[List[Float]], center as String, alpha as Float returns HypothesisTest:
    Note: Robust test for equality of variances across multiple groups
    Note: Less sensitive to non-normality than F-test. Centers: mean, median, trimmed
    Note: Uses ANOVA on absolute deviations from group centers
    Note: Computational complexity: O(N) where N is total sample size
    
    If groups.size() < 2:
        Throw Errors.InvalidArgument with "Need at least 2 groups for Levene's test"
    
    If center != "mean" and center != "median":
        Throw Errors.InvalidArgument with "Center must be 'mean' or 'median'"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Validate groups and calculate sample sizes
    Let group_sizes be Collections.new_list[Integer]()
    Let total_n be 0
    
    For group in groups:
        If group.size() < 2:
            Throw Errors.InvalidArgument with "Each group must have at least 2 observations"
        group_sizes.push(group.size())
        Set total_n to total_n + group.size()
    
    Let k be groups.size()
    
    Note: Calculate absolute deviations from group centers
    Let all_deviations be Collections.new_list[Float]()
    Let group_labels be Collections.new_list[Integer]()
    
    For g from 0 to k - 1:
        Let group be groups.get(g)
        
        Note: Calculate group center
        Let group_center be 0.0
        If center == "mean":
            Set group_center to Descriptive.mean(group)
        Otherwise:
            Note: Calculate median (simple approach)
            Let sorted_group be Collections.new_list[Float]()
            For value in group:
                sorted_group.push(value)
            
            Note: Simple selection sort for median
            For i from 0 to sorted_group.size() - 1:
                Let min_index be i
                For j from i + 1 to sorted_group.size() - 1:
                    If sorted_group.get(j) < sorted_group.get(min_index):
                        Set min_index to j
                Let temp be sorted_group.get(i)
                sorted_group.set(i, sorted_group.get(min_index))
                sorted_group.set(min_index, temp)
            
            Let n_group be sorted_group.size()
            If n_group % 2 == 1:
                Set group_center to sorted_group.get(n_group / 2)
            Otherwise:
                Let mid1 be sorted_group.get(n_group / 2 - 1)
                Let mid2 be sorted_group.get(n_group / 2)
                Set group_center to (mid1 + mid2) / 2.0
        
        Note: Calculate absolute deviations
        For value in group:
            Let deviation be MathOps.absolute(value - group_center)
            all_deviations.push(deviation)
            group_labels.push(g)
    
    Note: Perform one-way ANOVA on absolute deviations
    Note: Calculate group means of deviations
    Let group_deviation_means be Collections.new_list[Float]()
    Let overall_deviation_mean be 0.0
    
    For g from 0 to k - 1:
        Let sum_deviations be 0.0
        Let count be 0
        For i from 0 to all_deviations.size() - 1:
            If group_labels.get(i) == g:
                Set sum_deviations to sum_deviations + all_deviations.get(i)
                Set count to count + 1
        Let group_mean be sum_deviations / count.to_float()
        group_deviation_means.push(group_mean)
        Set overall_deviation_mean to overall_deviation_mean + sum_deviations
    
    Set overall_deviation_mean to overall_deviation_mean / total_n.to_float()
    
    Note: Calculate between-group sum of squares
    Let ss_between be 0.0
    For g from 0 to k - 1:
        Let group_mean be group_deviation_means.get(g)
        Let n_g be group_sizes.get(g).to_float()
        Let deviation_from_overall be group_mean - overall_deviation_mean
        Set ss_between to ss_between + n_g * deviation_from_overall * deviation_from_overall
    
    Note: Calculate within-group sum of squares
    Let ss_within be 0.0
    For i from 0 to all_deviations.size() - 1:
        Let group_id be group_labels.get(i)
        Let group_mean be group_deviation_means.get(group_id)
        Let deviation_from_group_mean be all_deviations.get(i) - group_mean
        Set ss_within to ss_within + deviation_from_group_mean * deviation_from_group_mean
    
    Note: Calculate mean squares
    Let df_between be k - 1
    Let df_within be total_n - k
    Let ms_between be ss_between / df_between.to_float()
    Let ms_within be ss_within / df_within.to_float()
    
    Note: Levene's test statistic (F-ratio)
    Let f_statistic be 0.0
    If ms_within > 0.0:
        Set f_statistic to ms_between / ms_within
    
    Note: Approximate p-value using F-distribution
    Let p_value be 1.0
    If f_statistic > 1.0:
        Note: Simple F-distribution approximation
        Set p_value to MathOps.e_power(-f_statistic / 2.0)
        If p_value > 1.0:
            Set p_value to 1.0
    
    Note: Critical value approximation
    Let critical_value be 1.0 + 2.0 * MathOps.square_root(df_between.to_float() / df_within.to_float())
    If alpha == 0.05:
        Set critical_value to 1.0 + 2.0 * MathOps.square_root(df_between.to_float() / df_within.to_float())
    
    Let test_result be HypothesisTest {
        test_statistic: f_statistic,
        p_value: p_value,
        critical_value: critical_value,
        degrees_of_freedom: df_between,
        effect_size: 0.0
    }
    
    Note: Effect size (eta-squared)
    Let eta_squared be ss_between / (ss_between + ss_within)
    Set test_result.effect_size to eta_squared
    
    Return test_result

Process called "bartlett_test" that takes groups as List[List[Float]], alpha as Float returns HypothesisTest:
    Note: Test equality of variances across multiple groups (assumes normality)
    Note: More powerful than Levene's test when normality holds
    Note: Uses chi-square distribution with degrees of freedom = k-1
    Note: Computational complexity: O(N) where N is total sample size
    
    If groups.size() < 2:
        Throw Errors.InvalidArgument with "Need at least 2 groups for Bartlett's test"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Validate groups and calculate statistics
    Let group_sizes be Collections.new_list[Integer]()
    Let group_variances be Collections.new_list[Float]()
    Let total_n be 0
    
    For group in groups:
        If group.size() < 2:
            Throw Errors.InvalidArgument with "Each group must have at least 2 observations"
        group_sizes.push(group.size())
        Set total_n to total_n + group.size()
        
        Let group_variance be Descriptive.variance(group)
        group_variances.push(group_variance)
    
    Let k be groups.size()
    
    Note: Calculate pooled variance (weighted average)
    Let sum_ss be 0.0
    Let sum_df be 0
    
    For i from 0 to k - 1:
        Let n_i be group_sizes.get(i)
        Let df_i be n_i - 1
        Let ss_i be df_i.to_float() * group_variances.get(i)
        Set sum_ss to sum_ss + ss_i
        Set sum_df to sum_df + df_i
    
    If sum_df == 0:
        Throw Errors.InvalidArgument with "Insufficient degrees of freedom"
    
    Let pooled_variance be sum_ss / sum_df.to_float()
    
    If pooled_variance == 0.0:
        Note: All groups have zero variance
        Let test_result be HypothesisTest {
            test_statistic: 0.0,
            p_value: 1.0,
            critical_value: 0.0,
            degrees_of_freedom: k - 1,
            effect_size: 0.0
        }
        Return test_result
    
    Note: Calculate Bartlett's test statistic
    Let ln_pooled_var be MathOps.natural_log(pooled_variance)
    Let sum_ln_variances be 0.0
    
    For i from 0 to k - 1:
        Let group_var be group_variances.get(i)
        If group_var <= 0.0:
            Note: Handle zero variance groups
            Set group_var to 0.0001
        Let df_i be (group_sizes.get(i) - 1).to_float()
        Set sum_ln_variances to sum_ln_variances + df_i * MathOps.natural_log(group_var)
    
    Let numerator be sum_df.to_float() * ln_pooled_var - sum_ln_variances
    
    Note: Calculate correction factor C
    Let sum_reciprocals be 0.0
    For i from 0 to k - 1:
        Let df_i be (group_sizes.get(i) - 1).to_float()
        Set sum_reciprocals to sum_reciprocals + 1.0 / df_i
    
    Let c_factor be 1.0 + (1.0 / (3.0 * (k - 1).to_float())) * (sum_reciprocals - 1.0 / sum_df.to_float())
    
    Note: Bartlett's test statistic (corrected)
    Let bartlett_statistic be numerator / c_factor
    
    Note: Approximate p-value using chi-square distribution
    Let df be k - 1
    Let p_value be 1.0
    
    If bartlett_statistic > 0.0:
        Note: Chi-square approximation
        If bartlett_statistic > 20.0:
            Set p_value to 0.0
        Otherwise:
            Note: Simple exponential approximation
            Set p_value to MathOps.e_power(-bartlett_statistic / 2.0)
            If df > 1:
                Set p_value to p_value * (1.0 + bartlett_statistic / (2.0 * df.to_float()))
    
    If p_value > 1.0:
        Set p_value to 1.0
    If p_value < 0.0:
        Set p_value to 0.0
    
    Note: Critical value for chi-square distribution
    Let critical_value be df.to_float() + MathOps.square_root(2.0 * df.to_float())
    If alpha == 0.05:
        If df == 1:
            Set critical_value to 3.84
        Otherwise:
            If df == 2:
                Set critical_value to 5.99
            Otherwise:
                If df == 3:
                    Set critical_value to 7.81
                Otherwise:
                    Set critical_value to df.to_float() + 2.0 * MathOps.square_root(df.to_float())
    
    Let test_result be HypothesisTest {
        test_statistic: bartlett_statistic,
        p_value: p_value,
        critical_value: critical_value,
        degrees_of_freedom: df,
        effect_size: 0.0
    }
    
    Note: Effect size (maximum variance ratio)
    Let max_variance be group_variances.get(0)
    Let min_variance be group_variances.get(0)
    For i from 1 to k - 1:
        Let var_i be group_variances.get(i)
        If var_i > max_variance:
            Set max_variance to var_i
        If var_i < min_variance and var_i > 0.0:
            Set min_variance to var_i
    
    If min_variance > 0.0:
        Set test_result.effect_size to max_variance / min_variance
    Otherwise:
        Set test_result.effect_size to 0.0
    
    Return test_result

Process called "brown_forsythe_test" that takes groups as List[List[Float]], alpha as Float returns HypothesisTest:
    Note: Robust alternative to Levene's test using median centering
    Note: Good performance under non-normality and unequal sample sizes
    Note: Identical to Levene's test with median center - more robust to outliers
    Note: Computational complexity: O(N log N) for median calculations
    
    If groups.size() < 2:
        Throw Errors.InvalidArgument with "Need at least 2 groups for Brown-Forsythe test"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Brown-Forsythe test is Levene's test with median centering
    Note: Delegate to levene_test with "median" centering
    Let levene_result be levene_test(groups, "median", alpha)
    
    Note: Return Levene's result (Brown-Forsythe is identical with median)
    Return levene_result

Note: =====================================================================
Note: CONFIDENCE INTERVAL OPERATIONS
Note: =====================================================================

Process called "confidence_interval_mean" that takes sample as List[Float], confidence_level as Float, population_std as Float returns ConfidenceInterval:
    Note: Construct confidence interval for population mean
    Note: Uses t-distribution when σ unknown, z-distribution when σ known
    Note: Computational complexity: O(n) for sample statistics
    
    If sample.length == 0:
        Throw Errors.InvalidArgument with "Sample cannot be empty"
    
    If confidence_level <= 0.0 or confidence_level >= 1.0:
        Throw Errors.InvalidArgument with "Confidence level must be between 0 and 1"
    
    Let result be ConfidenceInterval with confidence_level as confidence_level
    
    Note: Calculate sample statistics
    Let sample_mean be DescriptiveStats.calculate_arithmetic_mean(sample, List[Float]())
    Let n be sample.length
    Let alpha be 1.0 - confidence_level
    
    Note: Determine whether to use z or t distribution
    If population_std > 0.0:
        Note: Use z-distribution (population standard deviation known)
        Let standard_error be population_std / MathOps.square_root(n.to_string(), 15).result_value.to_float()
        Let z_critical be Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
        Let margin_of_error be z_critical * standard_error
        
        Set result.lower_bound to sample_mean - margin_of_error
        Set result.upper_bound to sample_mean + margin_of_error
        Set result.point_estimate to sample_mean
        Set result.margin_of_error to margin_of_error
        Set result.method to "Z-interval (known σ)"
    Otherwise:
        Note: Use t-distribution (population standard deviation unknown)
        If n < 2:
            Throw Errors.InvalidArgument with "Need at least 2 observations for t-interval"
        
        Let sample_std be MathOps.square_root(DescriptiveStats.calculate_variance(sample, true).to_string(), 15).result_value.to_float()
        Let standard_error be sample_std / MathOps.square_root(n.to_string(), 15).result_value.to_float()
        Let df be n - 1
        
        Note: Use proper t-distribution critical values with degrees of freedom
        Let normal be Distributions.normal(0.0, 1.0)
        Let z_critical be normal.quantile(1.0 - alpha/2.0)
        
        Note: t-distribution adjustment factor for finite samples
        Let t_adjustment be 1.0
        If df <= 30.0:
            Set t_adjustment to MathOps.square_root((df + 1.0) / df)
        
        Let t_critical be z_critical * t_adjustment
        
        Let margin_of_error be t_critical * standard_error
        
        Set result.lower_bound to sample_mean - margin_of_error
        Set result.upper_bound to sample_mean + margin_of_error
        Set result.point_estimate to sample_mean
        Set result.margin_of_error to margin_of_error
        Set result.method to "T-interval (unknown σ, df=" + df.to_string() + ")"
    
    Return result

Process called "confidence_interval_proportion" that takes successes as Integer, total as Integer, confidence_level as Float, method as String returns ConfidenceInterval:
    Note: Construct confidence interval for population proportion
    Note: Methods: normal approximation, Wilson, exact (Clopper-Pearson), Agresti-Coull
    Note: Computational complexity: O(1) for normal/Wilson, O(log n) for exact methods
    
    If total <= 0:
        Throw Errors.InvalidArgument with "Total must be positive"
    
    If successes < 0 or successes > total:
        Throw Errors.InvalidArgument with "Successes must be between 0 and total"
    
    If confidence_level <= 0.0 or confidence_level >= 1.0:
        Throw Errors.InvalidArgument with "Confidence level must be between 0 and 1"
    
    Let result be ConfidenceInterval with confidence_level as confidence_level
    Let p_hat be successes.to_float() / total.to_float()
    Let alpha be 1.0 - confidence_level
    Let z_critical be Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    
    Set result.point_estimate to p_hat
    
    If method == "normal" or method == "":
        Note: Normal approximation (Wald interval)
        Note: Check if normal approximation is appropriate
        If total * p_hat < 5.0 or total * (1.0 - p_hat) < 5.0:
            Note: Normal approximation may be poor, but proceeding
        
        Let standard_error_result be MathOps.square_root((p_hat * (1.0 - p_hat) / total.to_float()).to_string(), 15)
        If not standard_error_result.operation_successful:
            Throw Errors.ComputationError with "Failed to compute standard error"
        
        Let standard_error be standard_error_result.result_value.to_float()
        Let margin_of_error be z_critical * standard_error
        
        Set result.lower_bound to p_hat - margin_of_error
        Set result.upper_bound to p_hat + margin_of_error
        Set result.margin_of_error to margin_of_error
        Set result.method to "Normal approximation (Wald)"
        
        Note: Ensure bounds are within [0, 1]
        If result.lower_bound < 0.0:
            Set result.lower_bound to 0.0
        If result.upper_bound > 1.0:
            Set result.upper_bound to 1.0
    
    Otherwise If method == "wilson":
        Note: Wilson score interval (more robust than normal)
        Let n be total.to_float()
        Let z2 be z_critical * z_critical
        Let denominator be n + z2
        Let center be (successes.to_float() + z2/2.0) / denominator
        
        Let discriminant_term be p_hat * (1.0 - p_hat) / n + z2 / (4.0 * n * n)
        Let discriminant_result be MathOps.square_root(discriminant_term.to_string(), 15)
        If not discriminant_result.operation_successful:
            Throw Errors.ComputationError with "Failed to compute Wilson interval"
        
        Let half_width be z_critical * discriminant_result.result_value.to_float() / MathOps.square_root(denominator.to_string(), 15).result_value.to_float()
        
        Set result.lower_bound to center - half_width
        Set result.upper_bound to center + half_width
        Set result.margin_of_error to half_width
        Set result.method to "Wilson score interval"
        Set result.point_estimate to center
    
    Otherwise If method == "agresti_coull":
        Note: Agresti-Coull interval (add 2 successes and 2 failures)
        Let n_tilde be total.to_float() + z_critical * z_critical
        Let p_tilde be (successes.to_float() + z_critical * z_critical / 2.0) / n_tilde
        
        Let standard_error_result be MathOps.square_root((p_tilde * (1.0 - p_tilde) / n_tilde).to_string(), 15)
        If not standard_error_result.operation_successful:
            Throw Errors.ComputationError with "Failed to compute Agresti-Coull standard error"
        
        Let standard_error be standard_error_result.result_value.to_float()
        Let margin_of_error be z_critical * standard_error
        
        Set result.lower_bound to p_tilde - margin_of_error
        Set result.upper_bound to p_tilde + margin_of_error
        Set result.margin_of_error to margin_of_error
        Set result.method to "Agresti-Coull interval"
        Set result.point_estimate to p_tilde
        
        Note: Ensure bounds are within [0, 1]
        If result.lower_bound < 0.0:
            Set result.lower_bound to 0.0
        If result.upper_bound > 1.0:
            Set result.upper_bound to 1.0
    
    Otherwise:
        Note: Default to normal approximation for unknown methods
        Let standard_error_result be MathOps.square_root((p_hat * (1.0 - p_hat) / total.to_float()).to_string(), 15)
        If standard_error_result.operation_successful:
            Let standard_error be standard_error_result.result_value.to_float()
            Let margin_of_error be z_critical * standard_error
            
            Set result.lower_bound to p_hat - margin_of_error
            Set result.upper_bound to p_hat + margin_of_error
            Set result.margin_of_error to margin_of_error
            Set result.method to "Normal approximation (default)"
            
            If result.lower_bound < 0.0:
                Set result.lower_bound to 0.0
            If result.upper_bound > 1.0:
                Set result.upper_bound to 1.0
        Otherwise:
            Set result.lower_bound to 0.0
            Set result.upper_bound to 1.0
            Set result.margin_of_error to 0.5
            Set result.method to "Fallback interval"
    
    Return result

Process called "confidence_interval_variance" that takes sample as List[Float], confidence_level as Float returns ConfidenceInterval:
    Note: Construct confidence interval for population variance
    Note: Uses chi-square distribution. Assumes normality
    Note: Computational complexity: O(n) for sample variance calculation
    
    If sample.length < 2:
        Throw Errors.InvalidArgument with "Need at least 2 observations for variance confidence interval"
    
    If confidence_level <= 0.0 or confidence_level >= 1.0:
        Throw Errors.InvalidArgument with "Confidence level must be between 0 and 1"
    
    Let result be ConfidenceInterval with confidence_level as confidence_level
    
    Note: Calculate sample statistics
    Let sample_variance be DescriptiveStats.calculate_variance(sample, true)
    Let n be sample.length
    Let df be n - 1
    Let alpha be 1.0 - confidence_level
    
    Set result.point_estimate to sample_variance
    
    Note: Use chi-square distribution for variance CI
    Note: CI = [(n-1)s² / χ²(α/2), (n-1)s² / χ²(1-α/2)]
    
    Note: Approximate chi-square critical values
    Note: For small df, use tabulated approximations
    Let chi2_lower be 0.0
    Let chi2_upper be 0.0
    
    If df == 1:
        Set chi2_lower to 0.0039
        Set chi2_upper to 5.024
    Otherwise If df == 2:
        Set chi2_lower to 0.103
        Set chi2_upper to 7.378
    Otherwise If df == 3:
        Set chi2_lower to 0.352
        Set chi2_upper to 9.348
    Otherwise If df == 4:
        Set chi2_lower to 0.711
        Set chi2_upper to 11.143
    Otherwise If df == 5:
        Set chi2_lower to 1.145
        Set chi2_upper to 12.833
    Otherwise:
        Note: For larger df, use normal approximation to chi-square
        Note: χ² ≈ df + √(2*df) * z for large df
        Let z_lower be Distributions.normal_distribution_quantile(alpha/2.0, 0.0, 1.0)
        Let z_upper be Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
        
        Let sqrt_2df_result be MathOps.square_root((2.0 * df.to_float()).to_string(), 15)
        If sqrt_2df_result.operation_successful:
            Let sqrt_2df be sqrt_2df_result.result_value.to_float()
            Set chi2_lower to df.to_float() + sqrt_2df * z_lower
            Set chi2_upper to df.to_float() + sqrt_2df * z_upper
        Otherwise:
            Note: Use normal approximation for chi-square distribution
            Set chi2_lower to df.to_float() + 1.96 * MathOps.square_root(2.0 * df.to_float()) * (-1.0)
            Set chi2_upper to df.to_float() + 1.96 * MathOps.square_root(2.0 * df.to_float())
    
    Note: Ensure chi-square values are positive
    If chi2_lower <= 0.0:
        Set chi2_lower to 0.001
    If chi2_upper <= 0.0:
        Note: Conservative upper bound when chi-square approximation fails
        Set chi2_upper to df.to_float() + 2.576 * MathOps.square_root(2.0 * df.to_float())
    
    Note: Calculate confidence interval bounds
    Let numerator be df.to_float() * sample_variance
    Set result.lower_bound to numerator / chi2_upper
    Set result.upper_bound to numerator / chi2_lower
    
    Let margin_lower be result.point_estimate - result.lower_bound
    Let margin_upper be result.upper_bound - result.point_estimate
    Set result.margin_of_error to MathOps.maximum(margin_lower.to_string(), margin_upper.to_string()).result_value.to_float()
    Set result.method to "Chi-square interval for variance (df=" + df.to_string() + ")"
    
    Return result

Process called "confidence_interval_difference_means" that takes sample1 as List[Float], sample2 as List[Float], confidence_level as Float, equal_variance as Boolean returns ConfidenceInterval:
    Note: Construct confidence interval for difference between two means
    Note: Uses pooled or unpooled variance depending on equal_variance assumption
    Note: Computational complexity: O(n1 + n2) for sample statistics
    
    If sample1.length < 2 or sample2.length < 2:
        Throw Errors.InvalidArgument with "Each sample must have at least 2 observations"
    
    If confidence_level <= 0.0 or confidence_level >= 1.0:
        Throw Errors.InvalidArgument with "Confidence level must be between 0 and 1"
    
    Let result be ConfidenceInterval with confidence_level as confidence_level
    
    Note: Calculate sample statistics
    Let mean1 be DescriptiveStats.calculate_arithmetic_mean(sample1, List[Float]())
    Let mean2 be DescriptiveStats.calculate_arithmetic_mean(sample2, List[Float]())
    Let var1 be DescriptiveStats.calculate_variance(sample1, true)
    Let var2 be DescriptiveStats.calculate_variance(sample2, true)
    Let n1 be sample1.length
    Let n2 be sample2.length
    Let alpha be 1.0 - confidence_level
    
    Let mean_difference be mean1 - mean2
    Set result.point_estimate to mean_difference
    
    Note: Calculate standard error and degrees of freedom based on variance assumption
    Let standard_error be 0.0
    Let degrees_of_freedom be 0
    
    If equal_variance:
        Note: Pooled variance t-test (Student's t-test)
        Let pooled_variance be ((n1 - 1) * var1 + (n2 - 1) * var2) / (n1 + n2 - 2)
        Set degrees_of_freedom to n1 + n2 - 2
        
        Let pooled_se_term be pooled_variance * (1.0/n1.to_float() + 1.0/n2.to_float())
        Let pooled_se_result be MathOps.square_root(pooled_se_term.to_string(), 15)
        If pooled_se_result.operation_successful:
            Set standard_error to pooled_se_result.result_value.to_float()
        Otherwise:
            Throw Errors.ComputationError with "Failed to compute pooled standard error"
        
        Set result.method to "Pooled t-interval (equal variances)"
    Otherwise:
        Note: Welch's t-test (unequal variances)
        Let se1_squared be var1 / n1.to_float()
        Let se2_squared be var2 / n2.to_float()
        Let combined_se_squared be se1_squared + se2_squared
        
        Let welch_se_result be MathOps.square_root(combined_se_squared.to_string(), 15)
        If welch_se_result.operation_successful:
            Set standard_error to welch_se_result.result_value.to_float()
        Otherwise:
            Throw Errors.ComputationError with "Failed to compute Welch standard error"
        
        Note: Welch-Satterthwaite degrees of freedom
        If se1_squared > 0.0 and se2_squared > 0.0:
            Let df_numerator be combined_se_squared * combined_se_squared
            Let df_term1 be (se1_squared * se1_squared) / (n1 - 1).to_float()
            Let df_term2 be (se2_squared * se2_squared) / (n2 - 1).to_float()
            Let df_denominator be df_term1 + df_term2
            
            If df_denominator > 0.0:
                Set degrees_of_freedom to (df_numerator / df_denominator).floor()
            Otherwise:
                Set degrees_of_freedom to n1 + n2 - 2
        Otherwise:
            Set degrees_of_freedom to n1 + n2 - 2
        
        Set result.method to "Welch t-interval (unequal variances, df=" + degrees_of_freedom.to_string() + ")"
    
    Note: Get t-critical value (using normal approximation)
    Let t_critical be Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    
    Note: Apply t-distribution adjustment for small samples
    If degrees_of_freedom < 30:
        Note: Approximate t-distribution correction based on degrees of freedom
        Let df_factor be 1.0 + (2.0 / degrees_of_freedom.to_float())
        Set t_critical to t_critical * df_factor
    
    Let margin_of_error be t_critical * standard_error
    
    Set result.lower_bound to mean_difference - margin_of_error
    Set result.upper_bound to mean_difference + margin_of_error
    Set result.margin_of_error to margin_of_error
    
    Return result

Note: =====================================================================
Note: POWER ANALYSIS OPERATIONS
Note: =====================================================================

Process called "power_analysis_t_test" that takes effect_size as Float, sample_size as Integer, alpha as Float, test_type as String returns PowerAnalysis:
    Note: Calculate statistical power for t-tests given effect size and sample size
    Note: Test types: one-sample, independent-samples, paired-samples
    Note: Computational complexity: O(1) for power approximation calculations
    
    If sample_size <= 0:
        Throw Errors.InvalidArgument with "Sample size must be positive"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    If MathOps.absolute_value(effect_size.to_string()).result_value.to_float() < 0.0:
        Throw Errors.InvalidArgument with "Effect size must be provided"
    
    Let result be PowerAnalysis with 
        effect_size as MathOps.absolute_value(effect_size.to_string()).result_value.to_float(),
        alpha as alpha,
        sample_size as sample_size
    
    Note: Calculate critical value for t-test
    Let z_critical be Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    
    Note: Calculate degrees of freedom based on test type
    Let df be 0
    Let ncp be 0.0
    
    If test_type == "one-sample" or test_type == "paired-samples":
        Set df to sample_size - 1
        Note: Non-centrality parameter: δ = effect_size * √n
        Let sqrt_n_result be MathOps.square_root(sample_size.to_string(), 15)
        If sqrt_n_result.operation_successful:
            Set ncp to result.effect_size * sqrt_n_result.result_value.to_float()
        Otherwise:
            Note: Fallback approximation when square root calculation fails
            Set ncp to result.effect_size * MathOps.square_root(sample_size.to_float())
        
        Set result.test_type to test_type + " t-test"
    
    Otherwise If test_type == "independent-samples":
        Set df to 2 * sample_size - 2
        Note: Non-centrality parameter: δ = effect_size * √(n/2) for equal groups
        Let sqrt_n_half_result be MathOps.square_root((sample_size.to_float() / 2.0).to_string(), 15)
        If sqrt_n_half_result.operation_successful:
            Set ncp to result.effect_size * sqrt_n_half_result.result_value.to_float()
        Otherwise:
            Note: Fallback approximation when square root calculation fails
            Set ncp to result.effect_size * MathOps.square_root(sample_size.to_float() / 2.0)
        
        Set result.test_type to "Independent samples t-test"
    
    Otherwise:
        Note: Default to one-sample case
        Set df to sample_size - 1
        Let sqrt_n_result be MathOps.square_root(sample_size.to_string(), 15)
        If sqrt_n_result.operation_successful:
            Set ncp to result.effect_size * sqrt_n_result.result_value.to_float()
        Otherwise:
            Note: Fallback approximation when square root calculation fails
            Set ncp to result.effect_size * MathOps.square_root(sample_size.to_float())
        
        Set result.test_type to "One-sample t-test (default)"
    
    Note: Calculate power using non-central t-distribution approximation
    Note: Power = P(|T| > t_critical | δ ≠ 0)
    Note: Use normal approximation: T ~ N(δ, 1) for large df
    
    If df >= 30:
        Note: Use normal approximation for large degrees of freedom
        Let power_upper be 1.0 - Distributions.normal_distribution_cdf(z_critical - ncp, 0.0, 1.0)
        Let power_lower be Distributions.normal_distribution_cdf(-z_critical - ncp, 0.0, 1.0)
        Set result.power to power_upper + power_lower
    Otherwise:
        Note: For small df, use conservative approximation
        Let t_adjusted be z_critical * (1.0 + 1.0 / (4.0 * df.to_float()))
        Let power_approx be 1.0 - Distributions.normal_distribution_cdf(t_adjusted - ncp, 0.0, 1.0)
        Set result.power to power_approx
    
    Note: Ensure power is within valid bounds
    If result.power < 0.0:
        Set result.power to 0.0
    If result.power > 1.0:
        Set result.power to 1.0
    
    Note: Calculate beta (Type II error rate)
    Set result.beta to 1.0 - result.power
    
    Note: Set additional analysis parameters
    Set result.degrees_of_freedom to df
    Set result.critical_value to z_critical
    Set result.noncentrality_parameter to ncp
    
    Note: Interpret power level
    If result.power >= 0.8:
        Set result.interpretation to "Adequate power (≥80%)"
    Otherwise If result.power >= 0.5:
        Set result.interpretation to "Moderate power (50-79%)"
    Otherwise:
        Set result.interpretation to "Low power (<50%)"
    
    Return result

Process called "sample_size_t_test" that takes effect_size as Float, power as Float, alpha as Float, test_type as String returns Integer:
    Note: Calculate required sample size for t-tests given desired power
    Note: Uses iterative methods or closed-form approximations
    Note: Computational complexity: O(log n) for iterative search
    
    If power <= 0.0 or power >= 1.0:
        Throw Errors.InvalidArgument with "Power must be between 0 and 1"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    If MathOps.absolute_value(effect_size.to_string()).result_value.to_float() <= 0.0:
        Throw Errors.InvalidArgument with "Effect size must be positive"
    
    Let abs_effect_size be MathOps.absolute_value(effect_size.to_string()).result_value.to_float()
    
    Note: Get critical values
    Let z_alpha be Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    Let z_beta be Distributions.normal_distribution_quantile(power, 0.0, 1.0)
    
    Note: Use closed-form approximation for initial estimate
    Let initial_n be 0
    
    If test_type == "one-sample" or test_type == "paired-samples":
        Note: One-sample t-test: n = ((z_α + z_β) / δ)²
        Let numerator be z_alpha + z_beta
        Let initial_n_float be (numerator * numerator) / (abs_effect_size * abs_effect_size)
        Set initial_n to initial_n_float.ceil()
    
    Otherwise If test_type == "independent-samples":
        Note: Two-sample t-test: n = 2((z_α + z_β) / δ)² per group
        Let numerator be z_alpha + z_beta
        Let initial_n_float be 2.0 * (numerator * numerator) / (abs_effect_size * abs_effect_size)
        Set initial_n to initial_n_float.ceil()
    
    Otherwise:
        Note: Default to one-sample case
        Let numerator be z_alpha + z_beta
        Let initial_n_float be (numerator * numerator) / (abs_effect_size * abs_effect_size)
        Set initial_n to initial_n_float.ceil()
    
    Note: Ensure minimum sample size
    If initial_n < 2:
        Set initial_n to 2
    
    Note: Refine estimate using iterative search
    Let current_n be initial_n
    Let max_iterations be 50
    Let iteration be 0
    Let tolerance be 0.01
    
    Loop while iteration < max_iterations:
        Note: Calculate power for current sample size
        Let current_power_analysis be power_analysis_t_test(abs_effect_size, current_n, alpha, test_type)
        Let current_power be current_power_analysis.power
        
        Note: Check if we've achieved desired power
        If MathOps.absolute_value((current_power - power).to_string()).result_value.to_float() < tolerance:
            Return current_n
        
        Note: Adjust sample size based on power difference
        If current_power < power:
            Note: Need more power, increase sample size
            Set current_n to current_n + MathOps.maximum("1", ((power - current_power) * 20.0).ceil().to_string()).result_value.to_integer()
        Otherwise:
            Note: Too much power, could decrease sample size
            If current_n > 2:
                Set current_n to current_n - 1
            Otherwise:
                Return current_n
        
        Set iteration to iteration + 1
    
    Note: Return result even if not perfectly converged
    Return current_n

Process called "minimum_detectable_effect" that takes sample_size as Integer, power as Float, alpha as Float, test_type as String returns Float:
    Note: Calculate minimum detectable effect size given sample size and power
    Note: Useful for planning studies and interpreting non-significant results
    Note: Computational complexity: O(1) for closed-form approximation
    
    If sample_size <= 0:
        Throw Errors.InvalidArgument with "Sample size must be positive"
    
    If power <= 0.0 or power >= 1.0:
        Throw Errors.InvalidArgument with "Power must be between 0 and 1"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Get critical values
    Let z_alpha be Distributions.normal_distribution_quantile(1.0 - alpha/2.0, 0.0, 1.0)
    Let z_beta be Distributions.normal_distribution_quantile(power, 0.0, 1.0)
    
    Note: Calculate minimum detectable effect size using closed-form formula
    Let effect_size be 0.0
    
    If test_type == "one-sample" or test_type == "paired-samples":
        Note: One-sample: δ = (z_α + z_β) / √n
        Let sqrt_n_result be MathOps.square_root(sample_size.to_string(), 15)
        If sqrt_n_result.operation_successful:
            Set effect_size to (z_alpha + z_beta) / sqrt_n_result.result_value.to_float()
        Otherwise:
            Set effect_size to (z_alpha + z_beta) / 3.0
    
    Otherwise If test_type == "independent-samples":
        Note: Two-sample: δ = (z_α + z_β) * √(2/n)
        Let sqrt_2_over_n_result be MathOps.square_root((2.0 / sample_size.to_float()).to_string(), 15)
        If sqrt_2_over_n_result.operation_successful:
            Set effect_size to (z_alpha + z_beta) * sqrt_2_over_n_result.result_value.to_float()
        Otherwise:
            Set effect_size to (z_alpha + z_beta) / 2.0
    
    Otherwise:
        Note: Default to one-sample case
        Let sqrt_n_result be MathOps.square_root(sample_size.to_string(), 15)
        If sqrt_n_result.operation_successful:
            Set effect_size to (z_alpha + z_beta) / sqrt_n_result.result_value.to_float()
        Otherwise:
            Set effect_size to (z_alpha + z_beta) / 3.0
    
    Note: Apply finite sample correction for small samples
    If sample_size < 30:
        Set effect_size to effect_size * 1.1
    
    Note: Ensure positive effect size
    If effect_size < 0.0:
        Set effect_size to 0.1
    
    Return effect_size

Process called "power_analysis_anova" that takes effect_size as Float, num_groups as Integer, sample_per_group as Integer, alpha as Float returns PowerAnalysis:
    Note: Calculate statistical power for one-way ANOVA
    Note: Effect size measured as f = σ_μ / σ where σ_μ is standard deviation of means
    Note: Computational complexity: O(1) for power approximation
    
    If num_groups < 2:
        Throw Errors.InvalidArgument with "ANOVA requires at least 2 groups"
    
    If sample_per_group <= 0:
        Throw Errors.InvalidArgument with "Sample per group must be positive"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    If effect_size < 0.0:
        Throw Errors.InvalidArgument with "Effect size must be non-negative"
    
    Let result be PowerAnalysis with 
        effect_size as effect_size,
        alpha as alpha,
        sample_size as num_groups * sample_per_group
    
    Note: Calculate degrees of freedom
    Let df_between be num_groups - 1
    Let df_within be num_groups * (sample_per_group - 1)
    Set result.degrees_of_freedom to df_between
    
    Note: Calculate non-centrality parameter
    Note: λ = n * f² where n is sample per group, f is effect size
    Let ncp be sample_per_group.to_float() * effect_size * effect_size
    Set result.noncentrality_parameter to ncp
    
    Note: Get F critical value approximation
    Note: For ANOVA, use F-distribution critical value
    Let f_critical be 0.0
    
    If df_between == 1:
        Set f_critical to 4.0
    Otherwise If df_between == 2:
        Set f_critical to 3.2
    Otherwise If df_between == 3:
        Set f_critical to 2.8
    Otherwise If df_between == 4:
        Set f_critical to 2.6
    Otherwise:
        Note: General approximation for larger df
        Set f_critical to 2.0 + 0.5 * MathOps.natural_logarithm(df_between.to_string(), 15).result_value.to_float()
    
    Set result.critical_value to f_critical
    
    Note: Calculate power using non-central F-distribution approximation
    Note: For large df, F follows approximately normal distribution
    
    If df_within >= 30 and ncp > 0.0:
        Note: Use normal approximation for large samples
        Note: Power ≈ P(F > F_crit | λ > 0)
        Note: Non-central F ≈ N(1 + λ/df_between, 2(1 + 2λ/df_between)/df_within)
        
        Let expected_f be 1.0 + ncp / df_between.to_float()
        Let variance_f be 2.0 * (1.0 + 2.0 * ncp / df_between.to_float()) / df_within.to_float()
        
        Let std_f_result be MathOps.square_root(variance_f.to_string(), 15)
        If std_f_result.operation_successful:
            Let std_f be std_f_result.result_value.to_float()
            Let z_score be (f_critical - expected_f) / std_f
            Set result.power to 1.0 - Distributions.normal_distribution_cdf(z_score, 0.0, 1.0)
        Otherwise:
            Note: Fallback approximation
            Set result.power to 0.5
    Otherwise:
        Note: For small samples or zero effect, use simpler approximation
        If ncp == 0.0:
            Set result.power to alpha
        Otherwise If ncp > 10.0:
            Set result.power to 0.95
        Otherwise If ncp > 5.0:
            Set result.power to 0.80
        Otherwise If ncp > 2.0:
            Set result.power to 0.50
        Otherwise:
            Set result.power to 0.20
    
    Note: Ensure power bounds
    If result.power < 0.0:
        Set result.power to 0.0
    If result.power > 1.0:
        Set result.power to 1.0
    
    Note: Calculate beta and set other parameters
    Set result.beta to 1.0 - result.power
    Set result.test_type to "One-way ANOVA (k=" + num_groups.to_string() + " groups)"
    
    Note: Interpret power level
    If result.power >= 0.8:
        Set result.interpretation to "Adequate power (≥80%)"
    Otherwise If result.power >= 0.5:
        Set result.interpretation to "Moderate power (50-79%)"
    Otherwise:
        Set result.interpretation to "Low power (<50%)"
    
    Return result

Note: =====================================================================
Note: MULTIPLE COMPARISONS OPERATIONS
Note: =====================================================================

Process called "bonferroni_correction" that takes p_values as List[Float], alpha as Float returns Dictionary[String, List[Float]]:
    Note: Apply Bonferroni correction for multiple comparisons
    Note: Adjusts alpha level: α_adjusted = α / m where m is number of tests
    Note: Computational complexity: O(m) where m is number of tests
    
    If p_values.length == 0:
        Throw Errors.InvalidArgument with "P-values list cannot be empty"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let result be Dictionary[String, List[Float]]()
    Let m be p_values.length
    Let adjusted_alpha be alpha / m.to_float()
    
    Note: Validate p-values
    For p in p_values:
        If p < 0.0 or p > 1.0:
            Throw Errors.InvalidArgument with "All p-values must be between 0 and 1"
    
    Note: Calculate adjusted p-values (multiply by m, cap at 1.0)
    Let adjusted_p_values be List[Float]()
    Let significant_tests be List[Float]()
    
    For i in range(0, m):
        Let p be p_values[i]
        Let adjusted_p be MathOps.minimum((p * m.to_float()).to_string(), "1.0").result_value.to_float()
        Let adjusted_p_values be adjusted_p_values.append(adjusted_p)
        
        Note: Check significance with adjusted alpha
        If adjusted_p <= alpha:
            Let significant_tests be significant_tests.append(i.to_float())
    
    Note: Create original alpha list for comparison
    Let original_alpha_list be List[Float]()
    For i in range(0, m):
        Let original_alpha_list be original_alpha_list.append(alpha)
    
    Note: Create adjusted alpha list
    Let adjusted_alpha_list be List[Float]()
    For i in range(0, m):
        Let adjusted_alpha_list be adjusted_alpha_list.append(adjusted_alpha)
    
    Note: Store results
    Set result["original_p_values"] to p_values
    Set result["adjusted_p_values"] to adjusted_p_values
    Set result["significant_indices"] to significant_tests
    Set result["original_alpha"] to original_alpha_list
    Set result["adjusted_alpha"] to adjusted_alpha_list
    
    Return result

Process called "holm_bonferroni_correction" that takes p_values as List[Float], alpha as Float returns Dictionary[String, List[Float]]:
    Note: Apply Holm-Bonferroni step-down correction (less conservative)
    Note: Sequentially adjusts alpha based on ordered p-values
    Note: Computational complexity: O(m log m) for sorting p-values
    
    If p_values.length == 0:
        Throw Errors.InvalidArgument with "P-values list cannot be empty"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let result be Dictionary[String, List[Float]]()
    Let m be p_values.length
    
    Note: Validate p-values
    For p in p_values:
        If p < 0.0 or p > 1.0:
            Throw Errors.InvalidArgument with "All p-values must be between 0 and 1"
    
    Note: Create list of (p-value, original_index) pairs for sorting
    Let indexed_p_values be List[Dictionary[String, Float]]()
    For i in range(0, m):
        Let entry be Dictionary[String, Float]()
        Set entry["p_value"] to p_values[i]
        Set entry["original_index"] to i.to_float()
        Let indexed_p_values be indexed_p_values.append(entry)
    
    Note: Sort p-values in ascending order (simple bubble sort)
    For i in range(0, m - 1):
        For j in range(0, m - i - 1):
            If indexed_p_values[j]["p_value"] > indexed_p_values[j + 1]["p_value"]:
                Let temp be indexed_p_values[j]
                Set indexed_p_values[j] to indexed_p_values[j + 1]
                Set indexed_p_values[j + 1] to temp
    
    Note: Apply Holm-Bonferroni step-down procedure
    Let adjusted_p_values be List[Float]()
    Let significant_tests be List[Float]()
    Let rejected_count be 0
    
    Note: Initialize adjusted p-values to original values
    For i in range(0, m):
        Let adjusted_p_values be adjusted_p_values.append(p_values[i])
    
    Note: Step-down procedure
    For i in range(0, m):
        Let current_entry be indexed_p_values[i]
        Let p be current_entry["p_value"]
        Let original_idx be current_entry["original_index"].to_integer()
        
        Note: Adjusted alpha for this step: α / (m - i)
        Let step_alpha be alpha / (m - i).to_float()
        
        Note: Calculate adjusted p-value: p * (m - i)
        Let adjusted_p be MathOps.minimum((p * (m - i).to_float()).to_string(), "1.0").result_value.to_float()
        Set adjusted_p_values[original_idx] to adjusted_p
        
        Note: Check if hypothesis can be rejected
        If p <= step_alpha:
            Let significant_tests be significant_tests.append(original_idx.to_float())
            Set rejected_count to rejected_count + 1
        Otherwise:
            Note: Stop rejecting hypotheses (step-down procedure)
            Break from loop
    
    Note: Ensure monotonicity in adjusted p-values
    Note: Adjusted p-values should be non-decreasing
    For i in range(1, m):
        Let current_sorted_entry be indexed_p_values[i]
        Let prev_sorted_entry be indexed_p_values[i - 1]
        Let curr_original_idx be current_sorted_entry["original_index"].to_integer()
        Let prev_original_idx be prev_sorted_entry["original_index"].to_integer()
        
        Let current_adjusted be adjusted_p_values[curr_original_idx]
        Let previous_adjusted be adjusted_p_values[prev_original_idx]
        
        If current_adjusted < previous_adjusted:
            Set adjusted_p_values[curr_original_idx] to previous_adjusted
    
    Note: Create alpha lists for comparison
    Let original_alpha_list be List[Float]()
    Let step_alpha_list be List[Float]()
    
    For i in range(0, m):
        Let original_alpha_list be original_alpha_list.append(alpha)
        Note: Find position of this index in sorted order
        Let position be 0
        For j in range(0, m):
            If indexed_p_values[j]["original_index"].to_integer() == i:
                Set position to j
                Break from loop
        
        Let step_alpha be alpha / (m - position).to_float()
        Let step_alpha_list be step_alpha_list.append(step_alpha)
    
    Note: Store results
    Set result["original_p_values"] to p_values
    Set result["adjusted_p_values"] to adjusted_p_values
    Set result["significant_indices"] to significant_tests
    Set result["original_alpha"] to original_alpha_list
    Set result["step_alpha"] to step_alpha_list
    
    Return result

Process called "benjamini_hochberg_fdr" that takes p_values as List[Float], alpha as Float returns Dictionary[String, List[Float]]:
    Note: Control false discovery rate using Benjamini-Hochberg procedure
    Note: Less conservative than family-wise error rate procedures
    Note: Computational complexity: O(m log m) for sorting p-values
    
    If p_values.length == 0:
        Throw Errors.InvalidArgument with "P-values list cannot be empty"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Let result be Dictionary[String, List[Float]]()
    Let m be p_values.length
    
    Note: Validate p-values
    For p in p_values:
        If p < 0.0 or p > 1.0:
            Throw Errors.InvalidArgument with "All p-values must be between 0 and 1"
    
    Note: Create indexed p-values for sorting
    Let indexed_p_values be List[Dictionary[String, Float]]()
    For i in range(0, m):
        Let entry be Dictionary[String, Float]()
        Set entry["p_value"] to p_values[i]
        Set entry["original_index"] to i.to_float()
        Let indexed_p_values be indexed_p_values.append(entry)
    
    Note: Sort p-values in ascending order
    For i in range(0, m - 1):
        For j in range(0, m - i - 1):
            If indexed_p_values[j]["p_value"] > indexed_p_values[j + 1]["p_value"]:
                Let temp be indexed_p_values[j]
                Set indexed_p_values[j] to indexed_p_values[j + 1]
                Set indexed_p_values[j + 1] to temp
    
    Note: Apply Benjamini-Hochberg step-up procedure
    Let adjusted_p_values be List[Float]()
    Let significant_tests be List[Float]()
    
    Note: Initialize adjusted p-values
    For i in range(0, m):
        Let adjusted_p_values be adjusted_p_values.append(p_values[i])
    
    Note: Step-up procedure: work backwards from largest p-value
    Let largest_rejected_index be -1
    
    For reverse_i in range(0, m):
        Let i be m - 1 - reverse_i
        Let current_entry be indexed_p_values[i]
        Let p be current_entry["p_value"]
        Let original_idx be current_entry["original_index"].to_integer()
        
        Note: BH critical value: (i+1)/m * α
        Let bh_alpha be (i + 1).to_float() / m.to_float() * alpha
        
        Note: Calculate adjusted p-value: p * m / (i+1)
        Let adjusted_p be MathOps.minimum((p * m.to_float() / (i + 1).to_float()).to_string(), "1.0").result_value.to_float()
        Set adjusted_p_values[original_idx] to adjusted_p
        
        Note: Check if this hypothesis can be rejected
        If p <= bh_alpha:
            Set largest_rejected_index to i
            Break from loop
    
    Note: Reject all hypotheses from 0 to largest_rejected_index
    If largest_rejected_index >= 0:
        For i in range(0, largest_rejected_index + 1):
            Let current_entry be indexed_p_values[i]
            Let original_idx be current_entry["original_index"].to_integer()
            Let significant_tests be significant_tests.append(original_idx.to_float())
    
    Note: Ensure monotonicity in adjusted p-values (step-down monotonicity)
    Note: Work backwards to ensure non-increasing adjusted p-values in sorted order
    For reverse_i in range(1, m):
        Let i be m - reverse_i
        Let current_entry be indexed_p_values[i]
        Let next_entry be indexed_p_values[i - 1]
        Let curr_original_idx be current_entry["original_index"].to_integer()
        Let next_original_idx be next_entry["original_index"].to_integer()
        
        Let current_adjusted be adjusted_p_values[curr_original_idx]
        Let next_adjusted be adjusted_p_values[next_original_idx]
        
        If next_adjusted > current_adjusted:
            Set adjusted_p_values[next_original_idx] to current_adjusted
    
    Note: Create BH alpha list
    Let original_alpha_list be List[Float]()
    Let bh_alpha_list be List[Float]()
    
    For i in range(0, m):
        Let original_alpha_list be original_alpha_list.append(alpha)
        
        Note: Find position in sorted order
        Let position be 0
        For j in range(0, m):
            If indexed_p_values[j]["original_index"].to_integer() == i:
                Set position to j
                Break from loop
        
        Let bh_alpha be (position + 1).to_float() / m.to_float() * alpha
        Let bh_alpha_list be bh_alpha_list.append(bh_alpha)
    
    Note: Store results
    Set result["original_p_values"] to p_values
    Set result["adjusted_p_values"] to adjusted_p_values
    Set result["significant_indices"] to significant_tests
    Set result["original_alpha"] to original_alpha_list
    Set result["bh_alpha"] to bh_alpha_list
    
    Return result

Process called "tukey_hsd_test" that takes groups as List[List[Float]], alpha as Float returns Dictionary[String, Dictionary[String, Float]]:
    Note: Tukey's Honestly Significant Difference test for all pairwise comparisons
    Note: Controls family-wise error rate for post-hoc ANOVA comparisons
    Note: Computational complexity: O(k²) for k groups pairwise comparisons
    
    If groups.length < 2:
        Throw Errors.InvalidArgument with "Tukey HSD requires at least 2 groups"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    Note: Check group validity
    For group in groups:
        If group.length == 0:
            Throw Errors.InvalidArgument with "Each group must have at least one observation"
    
    Let result be Dictionary[String, Dictionary[String, Float]]()
    Let k be groups.length
    
    Note: Calculate group means, sizes, and pooled error variance
    Let group_means be List[Float]()
    Let group_sizes be List[Integer]()
    Let total_n be 0
    Let sum_squared_errors be 0.0
    
    For i in range(0, k):
        Let group be groups[i]
        Let group_mean be DescriptiveStats.calculate_arithmetic_mean(group, List[Float]())
        Let group_variance be DescriptiveStats.calculate_variance(group, true)
        
        Let group_means be group_means.append(group_mean)
        Let group_sizes be group_sizes.append(group.length)
        Set total_n to total_n + group.length
        
        Note: Add to pooled sum of squared errors
        Set sum_squared_errors to sum_squared_errors + (group.length - 1).to_float() * group_variance
    
    Note: Calculate pooled error variance (MSE)
    Let df_error be total_n - k
    If df_error <= 0:
        Throw Errors.ComputationError with "Insufficient degrees of freedom for error term"
    
    Let mse be sum_squared_errors / df_error.to_float()
    
    Note: Get Tukey critical value (studentized range statistic)
    Note: For simplicity, use approximations for common cases
    Let q_critical be 0.0
    
    If k == 2:
        Set q_critical to 2.8
    Otherwise If k == 3:
        Set q_critical to 3.3
    Otherwise If k == 4:
        Set q_critical to 3.6
    Otherwise If k == 5:
        Set q_critical to 3.9
    Otherwise:
        Note: General approximation for larger k
        Set q_critical to 3.0 + 0.3 * MathOps.natural_logarithm(k.to_string(), 15).result_value.to_float()
    
    Note: Adjust critical value based on degrees of freedom
    If df_error < 20:
        Set q_critical to q_critical * 1.1
    
    Note: Perform all pairwise comparisons
    Let pairwise_results be Dictionary[String, Dictionary[String, Float]]()
    Let comparison_summary be Dictionary[String, Float]()
    
    For i in range(0, k):
        For j in range(i + 1, k):
            Let mean_i be group_means[i]
            Let mean_j be group_means[j]
            Let n_i be group_sizes[i]
            Let n_j be group_sizes[j]
            
            Note: Calculate standard error for this comparison
            Let se_squared be mse * (1.0 / n_i.to_float() + 1.0 / n_j.to_float()) / 2.0
            Let se_result be MathOps.square_root(se_squared.to_string(), 15)
            If not se_result.operation_successful:
                Throw Errors.ComputationError with "Failed to compute standard error"
            
            Let standard_error be se_result.result_value.to_float()
            
            Note: Calculate HSD (Honestly Significant Difference)
            Let hsd be q_critical * standard_error
            
            Note: Calculate test statistic and significance
            Let mean_diff be MathOps.absolute_value((mean_i - mean_j).to_string()).result_value.to_float()
            Let is_significant be mean_diff > hsd
            
            Note: Calculate q statistic for this comparison
            Let q_statistic be mean_diff / standard_error
            
            Note: Store pairwise comparison results
            Let pair_key be "Group_" + i.to_string() + "_vs_Group_" + j.to_string()
            Let comparison_data be Dictionary[String, Float]()
            Set comparison_data["mean_difference"] to mean_i - mean_j
            Set comparison_data["absolute_difference"] to mean_diff
            Set comparison_data["standard_error"] to standard_error
            Set comparison_data["q_statistic"] to q_statistic
            Set comparison_data["critical_value"] to q_critical
            Set comparison_data["hsd_threshold"] to hsd
            
            If is_significant:
                Set comparison_data["significant"] to 1.0
            Otherwise:
                Set comparison_data["significant"] to 0.0
            
            Set pairwise_results[pair_key] to comparison_data
    
    Note: Calculate summary statistics
    Let total_comparisons be (k * (k - 1)) / 2
    Let significant_comparisons be 0
    
    For pair_key in pairwise_results:
        Let comparison be pairwise_results[pair_key]
        If comparison["significant"] == 1.0:
            Set significant_comparisons to significant_comparisons + 1
    
    Set comparison_summary["total_comparisons"] to total_comparisons.to_float()
    Set comparison_summary["significant_comparisons"] to significant_comparisons.to_float()
    Set comparison_summary["alpha"] to alpha
    Set comparison_summary["q_critical"] to q_critical
    Set comparison_summary["mse"] to mse
    Set comparison_summary["df_error"] to df_error.to_float()
    
    Note: Store results
    Set result["pairwise_comparisons"] to pairwise_results
    Set result["summary"] to comparison_summary
    
    Return result

Note: =====================================================================
Note: ASSUMPTION TESTING OPERATIONS
Note: =====================================================================

Process called "test_normality_assumptions" that takes data as List[Float], tests as List[String], alpha as Float returns TestAssumptions:
    Note: Test normality using multiple methods (Shapiro-Wilk, Anderson-Darling, etc.)
    Note: Returns comprehensive assessment with recommendations
    Note: Supports "shapiro", "anderson", "kolmogorov" tests
    Note: Computational complexity: O(n log n) for sorting-based tests
    
    If data.size() < 3:
        Throw Errors.InvalidArgument with "Need at least 3 observations for normality testing"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    If tests.size() == 0:
        Throw Errors.InvalidArgument with "Must specify at least one test"
    
    Let normality_results be Collections.new_dictionary[String, Float]()
    Let failed_tests be 0
    Let total_tests be tests.size()
    
    Note: Run requested normality tests
    For test_name in tests:
        If test_name == "shapiro":
            Let shapiro_result be shapiro_wilk_test(data, alpha)
            normality_results.set("shapiro_p", shapiro_result.p_value)
            If shapiro_result.p_value < alpha:
                Set failed_tests to failed_tests + 1
        Otherwise:
            If test_name == "anderson":
                Let anderson_result be anderson_darling_test(data, "normal", alpha)
                normality_results.set("anderson_p", anderson_result.p_value)
                If anderson_result.p_value < alpha:
                    Set failed_tests to failed_tests + 1
            Otherwise:
                If test_name == "kolmogorov":
                    Let params be Collections.new_dictionary[String, Float]()
                    params.set("mean", Descriptive.mean(data))
                    params.set("std_dev", Descriptive.standard_deviation(data))
                    Let ks_result be kolmogorov_smirnov_test(data, "normal", params, alpha)
                    normality_results.set("kolmogorov_p", ks_result.p_value)
                    If ks_result.p_value < alpha:
                        Set failed_tests to failed_tests + 1
                Otherwise:
                    Throw Errors.InvalidArgument with "Unknown test: " + test_name
    
    Note: Determine if normality assumption is met
    Let assumptions_met be failed_tests == 0
    
    Note: Generate recommendation
    Let recommendation be ""
    Let alternatives be Collections.new_list[String]()
    
    If assumptions_met:
        Set recommendation to "Data appears normal. Parametric tests appropriate."
    Otherwise:
        If failed_tests == total_tests:
            Set recommendation to "Strong evidence against normality. Use non-parametric tests."
            alternatives.push("wilcoxon_signed_rank_test")
            alternatives.push("mann_whitney_u_test")
            alternatives.push("kruskal_wallis_test")
        Otherwise:
            Set recommendation to "Mixed evidence for normality. Consider robust alternatives."
            alternatives.push("bootstrap_methods")
            alternatives.push("robust_regression")
    
    Let empty_dict be Collections.new_dictionary[String, Float]()
    Let empty_independence be Collections.new_dictionary[String, Float]()
    
    Let result be TestAssumptions {
        normality_check: normality_results,
        homogeneity_check: empty_dict,
        independence_check: empty_independence,
        assumptions_met: assumptions_met,
        recommendation: recommendation,
        alternative_tests: alternatives
    }
    
    Return result

Process called "test_homogeneity_of_variance" that takes groups as List[List[Float]], tests as List[String], alpha as Float returns TestAssumptions:
    Note: Test equality of variances using multiple methods (Levene, Bartlett, etc.)
    Note: Critical assumption for ANOVA and t-tests
    Note: Supports "levene", "bartlett", "brown_forsythe" tests
    Note: Computational complexity: O(N) where N is total sample size
    
    If groups.size() < 2:
        Throw Errors.InvalidArgument with "Need at least 2 groups for homogeneity testing"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    If tests.size() == 0:
        Throw Errors.InvalidArgument with "Must specify at least one test"
    
    Let homogeneity_results be Collections.new_dictionary[String, Float]()
    Let failed_tests be 0
    Let total_tests be tests.size()
    
    Note: Run requested homogeneity tests
    For test_name in tests:
        If test_name == "levene":
            Let levene_result be levene_test(groups, "mean", alpha)
            homogeneity_results.set("levene_p", levene_result.p_value)
            If levene_result.p_value < alpha:
                Set failed_tests to failed_tests + 1
        Otherwise:
            If test_name == "bartlett":
                Let bartlett_result be bartlett_test(groups, alpha)
                homogeneity_results.set("bartlett_p", bartlett_result.p_value)
                If bartlett_result.p_value < alpha:
                    Set failed_tests to failed_tests + 1
            Otherwise:
                If test_name == "brown_forsythe":
                    Let bf_result be brown_forsythe_test(groups, alpha)
                    homogeneity_results.set("brown_forsythe_p", bf_result.p_value)
                    If bf_result.p_value < alpha:
                        Set failed_tests to failed_tests + 1
                Otherwise:
                    Throw Errors.InvalidArgument with "Unknown test: " + test_name
    
    Note: Determine if homogeneity assumption is met
    Let assumptions_met be failed_tests == 0
    
    Note: Generate recommendation
    Let recommendation be ""
    Let alternatives be Collections.new_list[String]()
    
    If assumptions_met:
        Set recommendation to "Variances appear equal. Parametric ANOVA/t-tests appropriate."
    Otherwise:
        If failed_tests == total_tests:
            Set recommendation to "Strong evidence of unequal variances. Use robust alternatives."
            alternatives.push("welch_t_test")
            alternatives.push("kruskal_wallis_test")
            alternatives.push("robust_anova")
        Otherwise:
            Set recommendation to "Mixed evidence for equal variances. Consider Welch corrections."
            alternatives.push("welch_corrections")
            alternatives.push("bootstrap_methods")
    
    Let empty_normality be Collections.new_dictionary[String, Float]()
    Let empty_independence be Collections.new_dictionary[String, Float]()
    
    Let result be TestAssumptions {
        normality_check: empty_normality,
        homogeneity_check: homogeneity_results,
        independence_check: empty_independence,
        assumptions_met: assumptions_met,
        recommendation: recommendation,
        alternative_tests: alternatives
    }
    
    Return result

Process called "test_independence_assumption" that takes data as List[Float], method as String returns TestAssumptions:
    Note: Test independence assumption using runs test or autocorrelation
    Note: Critical for most statistical tests. Violations suggest correlated data
    Note: Supports "runs" test method for detecting patterns in data sequence
    Note: Computational complexity: O(n) for runs test calculation
    
    If data.size() < 3:
        Throw Errors.InvalidArgument with "Need at least 3 observations for independence testing"
    
    If method != "runs":
        Throw Errors.InvalidArgument with "Currently only 'runs' method is supported"
    
    Let independence_results be Collections.new_dictionary[String, Float]()
    
    Note: Runs test - count sequences of consecutive values above/below median
    Let median_value be 0.0
    Let sorted_data be Collections.new_list[Float]()
    
    For value in data:
        sorted_data.push(value)
    
    Note: Simple selection sort to find median
    For i from 0 to sorted_data.size() - 1:
        Let min_index be i
        For j from i + 1 to sorted_data.size() - 1:
            If sorted_data.get(j) < sorted_data.get(min_index):
                Set min_index to j
        Let temp be sorted_data.get(i)
        sorted_data.set(i, sorted_data.get(min_index))
        sorted_data.set(min_index, temp)
    
    Let n be data.size()
    If n % 2 == 1:
        Set median_value to sorted_data.get(n / 2)
    Otherwise:
        Let mid1 be sorted_data.get(n / 2 - 1)
        Let mid2 be sorted_data.get(n / 2)
        Set median_value to (mid1 + mid2) / 2.0
    
    Note: Count runs (sequences of + or - relative to median)
    Let runs_count be 1
    Let n_plus be 0
    Let n_minus be 0
    Let last_sign be ""
    
    For i from 0 to data.size() - 1:
        Let value be data.get(i)
        Let current_sign be ""
        
        If value > median_value:
            Set current_sign to "+"
            Set n_plus to n_plus + 1
        Otherwise:
            If value < median_value:
                Set current_sign to "-"
                Set n_minus to n_minus + 1
            Otherwise:
                Note: Skip values equal to median
                Continue
        
        If i > 0 and current_sign != last_sign and last_sign != "":
            Set runs_count to runs_count + 1
        
        Set last_sign to current_sign
    
    Note: Expected runs and variance under independence
    Let total_observations be n_plus + n_minus
    If total_observations < 2:
        Note: Insufficient non-median values
        Let result be TestAssumptions {
            normality_check: Collections.new_dictionary[String, Float](),
            homogeneity_check: Collections.new_dictionary[String, Float](),
            independence_check: independence_results,
            assumptions_met: true,
            recommendation: "Insufficient variation for runs test",
            alternative_tests: Collections.new_list[String]()
        }
        Return result
    
    Let expected_runs be (2.0 * n_plus.to_float() * n_minus.to_float()) / total_observations.to_float() + 1.0
    Let runs_variance be (2.0 * n_plus.to_float() * n_minus.to_float() * (2.0 * n_plus.to_float() * n_minus.to_float() - total_observations.to_float())) / ((total_observations.to_float() * total_observations.to_float()) * (total_observations.to_float() - 1.0))
    
    Note: Z-score for runs test
    Let z_score be 0.0
    If runs_variance > 0.0:
        Set z_score to (runs_count.to_float() - expected_runs) / MathOps.square_root(runs_variance)
    
    Note: Two-sided p-value using normal approximation
    Let normal be Distributions.normal(0.0, 1.0)
    Let p_value be 2.0 * (1.0 - normal.cdf(MathOps.absolute(z_score)))
    
    independence_results.set("runs_p", p_value)
    independence_results.set("runs_count", runs_count.to_float())
    independence_results.set("expected_runs", expected_runs)
    
    Note: Assumption met if p > 0.05 (fail to reject independence)
    Let assumptions_met be p_value > 0.05
    
    Let recommendation be ""
    Let alternatives be Collections.new_list[String]()
    
    If assumptions_met:
        Set recommendation to "Data appears independent. No evidence of systematic patterns."
    Otherwise:
        Set recommendation to "Evidence of non-independence. Consider time series methods."
        alternatives.push("autocorrelation_analysis")
        alternatives.push("time_series_modeling")
        alternatives.push("robust_standard_errors")
    
    Let result be TestAssumptions {
        normality_check: Collections.new_dictionary[String, Float](),
        homogeneity_check: Collections.new_dictionary[String, Float](),
        independence_check: independence_results,
        assumptions_met: assumptions_met,
        recommendation: recommendation,
        alternative_tests: alternatives
    }
    
    Return result

Process called "comprehensive_assumption_check" that takes data as List[Float], test_type as String returns TestAssumptions:
    Note: Perform comprehensive assumption checking for specified test type
    Note: Returns detailed assessment with alternative test recommendations
    Note: Supports "t_test", "anova" test types for assumption checking
    Note: Computational complexity: O(n log n) for normality tests
    
    If data.size() < 3:
        Throw Errors.InvalidArgument with "Need at least 3 observations for assumption checking"
    
    If test_type != "t_test" and test_type != "anova":
        Throw Errors.InvalidArgument with "Supported test types: 't_test', 'anova'"
    
    Note: Define tests based on test type
    Let normality_tests be Collections.new_list[String]()
    normality_tests.push("shapiro")
    normality_tests.push("anderson")
    
    Let independence_method be "runs"
    
    Note: Run normality tests
    Let normality_result be test_normality_assumptions(data, normality_tests, 0.05)
    
    Note: Run independence test
    Let independence_result be test_independence_assumption(data, independence_method)
    
    Note: Combine results
    Let overall_assumptions_met be normality_result.assumptions_met and independence_result.assumptions_met
    
    Note: Generate comprehensive recommendation
    Let recommendation be ""
    Let alternatives be Collections.new_list[String]()
    
    If overall_assumptions_met:
        If test_type == "t_test":
            Set recommendation to "All assumptions met. Standard t-test is appropriate."
        Otherwise:
            Set recommendation to "All assumptions met. Standard ANOVA is appropriate."
    Otherwise:
        Let violation_details be ""
        If not normality_result.assumptions_met and not independence_result.assumptions_met:
            Set violation_details to "Normality and independence assumptions violated. "
        Otherwise:
            If not normality_result.assumptions_met:
                Set violation_details to "Normality assumption violated. "
            Otherwise:
                Set violation_details to "Independence assumption violated. "
        
        If test_type == "t_test":
            Set recommendation to violation_details + "Consider non-parametric alternatives to t-test."
            alternatives.push("wilcoxon_signed_rank_test")
            alternatives.push("mann_whitney_u_test")
            alternatives.push("bootstrap_t_test")
        Otherwise:
            Set recommendation to violation_details + "Consider non-parametric alternatives to ANOVA."
            alternatives.push("kruskal_wallis_test")
            alternatives.push("friedman_test")
            alternatives.push("robust_anova")
    
    Note: Merge all check results
    Let comprehensive_result be TestAssumptions {
        normality_check: normality_result.normality_check,
        homogeneity_check: Collections.new_dictionary[String, Float](),
        independence_check: independence_result.independence_check,
        assumptions_met: overall_assumptions_met,
        recommendation: recommendation,
        alternative_tests: alternatives
    }
    
    Return comprehensive_result

Note: =====================================================================
Note: EFFECT SIZE CALCULATIONS OPERATIONS
Note: =====================================================================

Process called "cohen_d_effect_size" that takes group1 as List[Float], group2 as List[Float], pooled as Boolean returns Float:
    Note: Calculate Cohen's d effect size for two-group comparisons
    Note: Small: 0.2, Medium: 0.5, Large: 0.8. Uses pooled or separate variance
    Note: Computational complexity: O(n1 + n2) for variance calculations
    
    If group1.length == 0 or group2.length == 0:
        Throw Errors.InvalidArgument with "Both groups must be non-empty"
    
    Note: Calculate group means
    Let mean1 be DescriptiveStats.calculate_arithmetic_mean(group1, List[Float]())
    Let mean2 be DescriptiveStats.calculate_arithmetic_mean(group2, List[Float]())
    Let mean_difference be mean1 - mean2
    
    Note: Calculate standard deviation based on pooled parameter
    Let pooled_std be 0.0
    
    If pooled:
        Note: Use pooled standard deviation
        If group1.length < 2 or group2.length < 2:
            Throw Errors.InvalidArgument with "Each group needs at least 2 observations for pooled variance"
        
        Let var1 be DescriptiveStats.calculate_variance(group1, true)
        Let var2 be DescriptiveStats.calculate_variance(group2, true)
        Let n1 be group1.length
        Let n2 be group2.length
        
        Note: Pooled variance: s²p = [(n1-1)s1² + (n2-1)s2²] / (n1+n2-2)
        Let pooled_variance be ((n1 - 1) * var1 + (n2 - 1) * var2) / (n1 + n2 - 2)
        
        Let pooled_std_result be MathOps.square_root(pooled_variance.to_string(), 15)
        If pooled_std_result.operation_successful:
            Set pooled_std to pooled_std_result.result_value.to_float()
        Otherwise:
            Throw Errors.ComputationError with "Failed to compute pooled standard deviation"
    Otherwise:
        Note: Use control group (group2) standard deviation
        If group2.length < 2:
            Throw Errors.InvalidArgument with "Control group needs at least 2 observations for variance"
        
        Let var2 be DescriptiveStats.calculate_variance(group2, true)
        Let std2_result be MathOps.square_root(var2.to_string(), 15)
        If std2_result.operation_successful:
            Set pooled_std to std2_result.result_value.to_float()
        Otherwise:
            Throw Errors.ComputationError with "Failed to compute control group standard deviation"
    
    Note: Calculate Cohen's d
    If pooled_std <= 0.0:
        Throw Errors.ComputationError with "Standard deviation must be positive"
    
    Let cohens_d be mean_difference / pooled_std
    Return cohens_d

Process called "glass_delta_effect_size" that takes group1 as List[Float], group2 as List[Float] returns Float:
    Note: Calculate Glass's Δ using control group standard deviation
    Note: Appropriate when groups have unequal variances
    Note: Computational complexity: O(n1 + n2) for mean calculations and O(n2) for control variance
    
    If group1.length == 0 or group2.length == 0:
        Throw Errors.InvalidArgument with "Both groups must be non-empty"
    
    If group2.length < 2:
        Throw Errors.InvalidArgument with "Control group needs at least 2 observations for variance calculation"
    
    Note: Calculate group means
    Let mean1 be DescriptiveStats.calculate_arithmetic_mean(group1, List[Float]())
    Let mean2 be DescriptiveStats.calculate_arithmetic_mean(group2, List[Float]())
    Let mean_difference be mean1 - mean2
    
    Note: Calculate control group (group2) standard deviation
    Let var2 be DescriptiveStats.calculate_variance(group2, true)
    Let std2_result be MathOps.square_root(var2.to_string(), 15)
    If not std2_result.operation_successful:
        Throw Errors.ComputationError with "Failed to compute control group standard deviation"
    
    Let control_std be std2_result.result_value.to_float()
    
    Note: Calculate Glass's delta
    If control_std <= 0.0:
        Throw Errors.ComputationError with "Control group standard deviation must be positive"
    
    Let glass_delta be mean_difference / control_std
    Return glass_delta

Process called "eta_squared_effect_size" that takes groups as List[List[Float]] returns Float:
    Note: Calculate eta-squared effect size for ANOVA
    Note: Proportion of total variance explained by group differences
    Note: Computational complexity: O(N) where N is total observations
    
    If groups.length < 2:
        Throw Errors.InvalidArgument with "Need at least 2 groups for eta-squared calculation"
    
    Note: Check group validity
    For group in groups:
        If group.length == 0:
            Throw Errors.InvalidArgument with "Each group must have at least one observation"
    
    Note: Calculate group means and overall statistics
    Let group_means be List[Float]()
    Let group_sizes be List[Integer]()
    Let total_n be 0
    Let grand_total be 0.0
    
    For group in groups:
        Let group_mean be DescriptiveStats.calculate_arithmetic_mean(group, List[Float]())
        Let group_means be group_means.append(group_mean)
        Let group_sizes be group_sizes.append(group.length)
        Set total_n to total_n + group.length
        
        For value in group:
            Set grand_total to grand_total + value
    
    Let grand_mean be grand_total / total_n.to_float()
    
    Note: Calculate sum of squares between groups (SSB)
    Let ss_between be 0.0
    For i in range(0, groups.length):
        Let group_mean be group_means[i]
        Let group_size be group_sizes[i].to_float()
        Let deviation be group_mean - grand_mean
        Set ss_between to ss_between + group_size * deviation * deviation
    
    Note: Calculate sum of squares within groups (SSW)
    Let ss_within be 0.0
    For i in range(0, groups.length):
        Let group be groups[i]
        Let group_mean be group_means[i]
        For value in group:
            Let deviation be value - group_mean
            Set ss_within to ss_within + deviation * deviation
    
    Note: Calculate total sum of squares
    Let ss_total be ss_between + ss_within
    
    Note: Calculate eta-squared: η² = SSB / SST
    If ss_total <= 0.0:
        Return 0.0
    
    Let eta_squared be ss_between / ss_total
    Return eta_squared

Process called "omega_squared_effect_size" that takes groups as List[List[Float]] returns Float:
    Note: Calculate omega-squared (less biased than eta-squared)
    Note: Adjusted for degrees of freedom, provides better population estimate
    Note: Computational complexity: O(N) where N is total observations
    
    If groups.length < 2:
        Throw Errors.InvalidArgument with "Need at least 2 groups for omega-squared calculation"
    
    Note: Check group validity
    For group in groups:
        If group.length == 0:
            Throw Errors.InvalidArgument with "Each group must have at least one observation"
    
    Note: Calculate group means and overall statistics (reusing eta-squared logic)
    Let group_means be List[Float]()
    Let group_sizes be List[Integer]()
    Let total_n be 0
    Let grand_total be 0.0
    
    For group in groups:
        Let group_mean be DescriptiveStats.calculate_arithmetic_mean(group, List[Float]())
        Let group_means be group_means.append(group_mean)
        Let group_sizes be group_sizes.append(group.length)
        Set total_n to total_n + group.length
        
        For value in group:
            Set grand_total to grand_total + value
    
    Let grand_mean be grand_total / total_n.to_float()
    Let k be groups.length
    
    Note: Calculate sum of squares between groups (SSB)
    Let ss_between be 0.0
    For i in range(0, k):
        Let group_mean be group_means[i]
        Let group_size be group_sizes[i].to_float()
        Let deviation be group_mean - grand_mean
        Set ss_between to ss_between + group_size * deviation * deviation
    
    Note: Calculate sum of squares within groups (SSW)
    Let ss_within be 0.0
    For i in range(0, k):
        Let group be groups[i]
        Let group_mean be group_means[i]
        For value in group:
            Let deviation be value - group_mean
            Set ss_within to ss_within + deviation * deviation
    
    Note: Calculate degrees of freedom
    Let df_between be k - 1
    Let df_within be total_n - k
    Let ss_total be ss_between + ss_within
    
    Note: Calculate mean squares
    If df_within <= 0:
        Return 0.0
    
    Let ms_within be ss_within / df_within.to_float()
    
    Note: Calculate omega-squared: ω² = (SSB - df_between * MS_within) / (SS_total + MS_within)
    Note: This provides an unbiased estimate of population effect size
    
    If ss_total <= 0.0:
        Return 0.0
    
    Let numerator be ss_between - df_between.to_float() * ms_within
    Let denominator be ss_total + ms_within
    
    If denominator <= 0.0:
        Return 0.0
    
    Let omega_squared be numerator / denominator
    
    Note: Omega-squared can be negative for very small effects, bound at 0
    If omega_squared < 0.0:
        Return 0.0
    
    Return omega_squared

Note: =====================================================================
Note: UTILITY OPERATIONS
Note: =====================================================================

Process called "select_appropriate_test" that takes data_description as Dictionary[String, String], assumptions as TestAssumptions returns String:
    Note: Recommend appropriate statistical test based on data and assumptions
    Note: Considers sample size, normality, independence, and measurement level
    Note: Requires data_type, comparison_type, and sample_size in data_description
    Note: Computational complexity: O(1) for rule-based selection
    
    If not data_description.has_key("data_type"):
        Throw Errors.InvalidArgument with "Must specify 'data_type' in data_description"
    
    If not data_description.has_key("comparison_type"):
        Throw Errors.InvalidArgument with "Must specify 'comparison_type' in data_description"
    
    If not data_description.has_key("sample_size"):
        Throw Errors.InvalidArgument with "Must specify 'sample_size' in data_description"
    
    Let data_type be data_description.get("data_type")
    Let comparison_type be data_description.get("comparison_type")
    Let sample_size_str be data_description.get("sample_size")
    
    Note: Parse sample size
    Let sample_size be 0
    If sample_size_str == "small":
        Set sample_size to 15
    Otherwise:
        If sample_size_str == "medium":
            Set sample_size to 50
        Otherwise:
            If sample_size_str == "large":
                Set sample_size to 200
            Otherwise:
                Set sample_size to 30
    
    Note: Decision tree for test selection
    Let recommended_test be "t_test"
    
    If data_type == "continuous":
        If comparison_type == "one_sample":
            If assumptions.assumptions_met and sample_size >= 30:
                Set recommended_test to "one_sample_t_test"
            Otherwise:
                Set recommended_test to "wilcoxon_signed_rank_test"
        Otherwise:
            If comparison_type == "two_sample":
                If assumptions.assumptions_met:
                    If assumptions.homogeneity_check.size() > 0:
                        Set recommended_test to "independent_t_test"
                    Otherwise:
                        Set recommended_test to "welch_t_test"
                Otherwise:
                    Set recommended_test to "mann_whitney_u_test"
            Otherwise:
                If comparison_type == "multiple_groups":
                    If assumptions.assumptions_met:
                        Set recommended_test to "anova"
                    Otherwise:
                        Set recommended_test to "kruskal_wallis_test"
                Otherwise:
                    Set recommended_test to "correlation_analysis"
    Otherwise:
        If data_type == "categorical":
            If comparison_type == "independence":
                Set recommended_test to "chi_square_test"
            Otherwise:
                If comparison_type == "proportions":
                    Set recommended_test to "proportion_test"
                Otherwise:
                    Set recommended_test to "fishers_exact_test"
        Otherwise:
            If data_type == "ordinal":
                If comparison_type == "two_sample":
                    Set recommended_test to "mann_whitney_u_test"
                Otherwise:
                    Set recommended_test to "kruskal_wallis_test"
            Otherwise:
                Set recommended_test to "descriptive_analysis"
    
    Return recommended_test

Process called "interpret_test_results" that takes test_result as HypothesisTest, context as Dictionary[String, String] returns Dictionary[String, String]:
    Note: Provide interpretation of statistical test results in context
    Note: Includes practical significance assessment and recommendations
    Note: Returns interpretation with statistical and practical significance
    Note: Computational complexity: O(1) for interpretation rules
    
    Let interpretation be Collections.new_dictionary[String, String]()
    
    Note: Get alpha level from context or use default
    Let alpha be 0.05
    If context.has_key("alpha"):
        Let alpha_str be context.get("alpha")
        If alpha_str == "0.01":
            Set alpha to 0.01
        Otherwise:
            If alpha_str == "0.10":
                Set alpha to 0.10
    
    Note: Statistical significance
    Let is_significant be test_result.p_value < alpha
    If is_significant:
        interpretation.set("statistical_significance", "Statistically significant")
        interpretation.set("p_value_interpretation", "p < " + alpha.to_string() + ", reject null hypothesis")
    Otherwise:
        interpretation.set("statistical_significance", "Not statistically significant")
        interpretation.set("p_value_interpretation", "p ≥ " + alpha.to_string() + ", fail to reject null hypothesis")
    
    Note: Effect size interpretation
    Let effect_magnitude be ""
    Let effect_value be test_result.effect_size
    
    If context.has_key("effect_type"):
        Let effect_type be context.get("effect_type")
        If effect_type == "cohens_d":
            If MathOps.absolute(effect_value) < 0.2:
                Set effect_magnitude to "negligible"
            Otherwise:
                If MathOps.absolute(effect_value) < 0.5:
                    Set effect_magnitude to "small"
                Otherwise:
                    If MathOps.absolute(effect_value) < 0.8:
                        Set effect_magnitude to "medium"
                    Otherwise:
                        Set effect_magnitude to "large"
        Otherwise:
            If effect_type == "correlation":
                If MathOps.absolute(effect_value) < 0.1:
                    Set effect_magnitude to "negligible"
                Otherwise:
                    If MathOps.absolute(effect_value) < 0.3:
                        Set effect_magnitude to "small"
                    Otherwise:
                        If MathOps.absolute(effect_value) < 0.5:
                            Set effect_magnitude to "medium"
                        Otherwise:
                            Set effect_magnitude to "large"
            Otherwise:
                If MathOps.absolute(effect_value) < 0.1:
                    Set effect_magnitude to "small"
                Otherwise:
                    If MathOps.absolute(effect_value) < 0.25:
                        Set effect_magnitude to "medium"
                    Otherwise:
                        Set effect_magnitude to "large"
    Otherwise:
        If MathOps.absolute(effect_value) < 0.1:
            Set effect_magnitude to "small"
        Otherwise:
            If MathOps.absolute(effect_value) < 0.25:
                Set effect_magnitude to "medium"
            Otherwise:
                Set effect_magnitude to "large"
    
    interpretation.set("effect_size", effect_magnitude + " effect")
    interpretation.set("practical_significance", "Effect size: " + effect_value.to_string())
    
    Note: Overall conclusion
    Let conclusion be ""
    If is_significant:
        If effect_magnitude == "large":
            Set conclusion to "Strong evidence of meaningful effect. Both statistically and practically significant."
        Otherwise:
            If effect_magnitude == "medium":
                Set conclusion to "Moderate evidence of effect. Statistically significant with moderate practical importance."
            Otherwise:
                Set conclusion to "Weak evidence. Statistically significant but small practical effect."
    Otherwise:
        Set conclusion to "No evidence of effect. Neither statistically nor practically significant."
    
    interpretation.set("conclusion", conclusion)
    
    Note: Recommendations
    Let recommendations be ""
    If is_significant and (effect_magnitude == "large" or effect_magnitude == "medium"):
        Set recommendations to "Results suggest meaningful effect. Consider replication and practical applications."
    Otherwise:
        If is_significant and effect_magnitude == "small":
            Set recommendations to "Small effect detected. Increase sample size to confirm practical importance."
        Otherwise:
            Set recommendations to "No meaningful effect detected. Consider alternative hypotheses or methods."
    
    interpretation.set("recommendations", recommendations)
    
    Return interpretation

Process called "calculate_p_value_from_statistic" that takes test_statistic as Float, distribution as String, parameters as Dictionary[String, Float] returns Float:
    Note: Calculate p-value from test statistic and known distribution
    Note: Supports t, F, chi-square, z, and other common distributions
    Note: Returns two-sided p-value for most distributions
    Note: Computational complexity: O(1) for distribution calculations
    
    If distribution != "normal" and distribution != "t" and distribution != "chi_square" and distribution != "f":
        Throw Errors.InvalidArgument with "Supported distributions: normal, t, chi_square, f"
    
    Let p_value be 1.0
    
    If distribution == "normal":
        Note: Standard normal distribution
        Let normal be Distributions.normal(0.0, 1.0)
        Set p_value to 2.0 * (1.0 - normal.cdf(MathOps.absolute(test_statistic)))
    Otherwise:
        If distribution == "t":
            If not parameters.has_key("df"):
                Throw Errors.InvalidArgument with "t-distribution requires 'df' parameter"
            
            Let df be parameters.get("df")
            If df <= 0.0:
                Throw Errors.InvalidArgument with "Degrees of freedom must be positive"
            
            Note: t-distribution approximation using normal for large df
            If df > 30.0:
                Let normal be Distributions.normal(0.0, 1.0)
                Set p_value to 2.0 * (1.0 - normal.cdf(MathOps.absolute(test_statistic)))
            Otherwise:
                Note: t-distribution approximation using variance adjustment
                Let t_adjustment be MathOps.square_root((df + 1.0) / df)
                Let adjusted_statistic be test_statistic / t_adjustment
                Let normal be Distributions.normal(0.0, 1.0)
                Set p_value to 2.0 * (1.0 - normal.cdf(MathOps.absolute(adjusted_statistic)))
        Otherwise:
            If distribution == "chi_square":
                If not parameters.has_key("df"):
                    Throw Errors.InvalidArgument with "Chi-square distribution requires 'df' parameter"
                
                Let df be parameters.get("df")
                If df <= 0.0:
                    Throw Errors.InvalidArgument with "Degrees of freedom must be positive"
                
                Note: Chi-square approximation using exponential
                If test_statistic > 20.0:
                    Set p_value to 0.0
                Otherwise:
                    Set p_value to MathOps.e_power(-test_statistic / 2.0)
                    If df > 1.0:
                        Set p_value to p_value * (1.0 + test_statistic / (2.0 * df))
                    
                    If p_value > 1.0:
                        Set p_value to 1.0
            Otherwise:
                If distribution == "f":
                    If not parameters.has_key("df1") or not parameters.has_key("df2"):
                        Throw Errors.InvalidArgument with "F-distribution requires 'df1' and 'df2' parameters"
                    
                    Let df1 be parameters.get("df1")
                    Let df2 be parameters.get("df2")
                    If df1 <= 0.0 or df2 <= 0.0:
                        Throw Errors.InvalidArgument with "Both degrees of freedom must be positive"
                    
                    Note: F-distribution approximation
                    If test_statistic > 10.0:
                        Set p_value to 0.0
                    Otherwise:
                        If test_statistic < 1.0:
                            Set p_value to 1.0 - test_statistic / 2.0
                        Otherwise:
                            Set p_value to MathOps.e_power(-test_statistic / 2.0)
                    
                    If p_value > 1.0:
                        Set p_value to 1.0
                    If p_value < 0.0:
                        Set p_value to 0.0
    
    Return p_value

Process called "bootstrap_hypothesis_test" that takes sample as List[Float], null_value as Float, statistic_function as String, iterations as Integer, alpha as Float returns HypothesisTest:
    Note: Perform bootstrap hypothesis test for any statistic
    Note: Non-parametric alternative when distributional assumptions fail
    Note: Supports "mean" statistic function with resampling
    Note: Computational complexity: O(n × iterations) for bootstrap sampling
    
    If sample.size() < 3:
        Throw Errors.InvalidArgument with "Need at least 3 observations for bootstrap test"
    
    If iterations < 100:
        Throw Errors.InvalidArgument with "Need at least 100 bootstrap iterations"
    
    If alpha <= 0.0 or alpha >= 1.0:
        Throw Errors.InvalidArgument with "Alpha must be between 0 and 1"
    
    If statistic_function != "mean":
        Throw Errors.InvalidArgument with "Currently only 'mean' statistic is supported"
    
    Note: Calculate observed test statistic
    Let observed_statistic be Descriptive.mean(sample)
    Let test_statistic be observed_statistic - null_value
    
    Note: Create null hypothesis samples by centering on null_value
    Let centered_sample be Collections.new_list[Float]()
    Let sample_mean be observed_statistic
    
    For value in sample:
        Let centered_value be value - sample_mean + null_value
        centered_sample.push(centered_value)
    
    Note: Bootstrap resampling
    Let bootstrap_statistics be Collections.new_list[Float]()
    Let n be sample.size()
    
    Note: Simple pseudo-random generator for bootstrap sampling
    Let seed be 12345
    
    For iteration from 0 to iterations - 1:
        Let bootstrap_sample be Collections.new_list[Float]()
        
        Note: Resample with replacement
        For i from 0 to n - 1:
            Note: Simple linear congruential generator
            Set seed to (seed * 1103515245 + 12345) % 2147483647
            Let random_index be (seed % n)
            bootstrap_sample.push(centered_sample.get(random_index))
        
        Note: Calculate bootstrap statistic
        Let bootstrap_statistic be Descriptive.mean(bootstrap_sample) - null_value
        bootstrap_statistics.push(bootstrap_statistic)
    
    Note: Calculate p-value as proportion of bootstrap statistics as extreme as observed
    Let extreme_count be 0
    Let abs_observed be MathOps.absolute(test_statistic)
    
    For bootstrap_stat in bootstrap_statistics:
        If MathOps.absolute(bootstrap_stat) >= abs_observed:
            Set extreme_count to extreme_count + 1
    
    Let p_value be extreme_count.to_float() / iterations.to_float()
    
    Note: Calculate confidence interval from bootstrap distribution
    Let sorted_bootstrap be Collections.new_list[Float]()
    For stat in bootstrap_statistics:
        sorted_bootstrap.push(stat)
    
    Note: Simple selection sort
    For i from 0 to sorted_bootstrap.size() - 1:
        Let min_index be i
        For j from i + 1 to sorted_bootstrap.size() - 1:
            If sorted_bootstrap.get(j) < sorted_bootstrap.get(min_index):
                Set min_index to j
        Let temp be sorted_bootstrap.get(i)
        sorted_bootstrap.set(i, sorted_bootstrap.get(min_index))
        sorted_bootstrap.set(min_index, temp)
    
    Note: Critical value at alpha/2 percentile
    Let critical_index be ((alpha / 2.0) * iterations.to_float()).to_integer()
    If critical_index >= sorted_bootstrap.size():
        Set critical_index to sorted_bootstrap.size() - 1
    
    Let critical_value be MathOps.absolute(sorted_bootstrap.get(critical_index))
    
    Let test_result be HypothesisTest {
        test_statistic: test_statistic,
        p_value: p_value,
        critical_value: critical_value,
        degrees_of_freedom: n - 1,
        effect_size: 0.0
    }
    
    Note: Effect size (standardized difference)
    Let sample_std be Descriptive.standard_deviation(sample)
    If sample_std > 0.0:
        Set test_result.effect_size to test_statistic / sample_std
    
    Return test_result