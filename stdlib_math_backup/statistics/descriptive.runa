Note:
math/statistics/descriptive.runa
Descriptive Statistics Operations

This module provides comprehensive descriptive statistics capabilities including
measures of central tendency (mean, median, mode), measures of variability 
(standard deviation, variance, range), distribution shape measures (skewness, 
kurtosis), and quantile analysis for statistical data summarization.
:End Note

Import "dev/debug/errors/core" as Errors
Import "data/collections/algorithms/sorting" as Sorting
Import "data/collections/algorithms/aggregation" as Aggregation
Import "math/core/operations" as MathOps
Import "math/core/comparison" as Compare
Import "security/crypto/primitives/random" as CryptoRandom

Note: =====================================================================
Note: DESCRIPTIVE STATISTICS DATA STRUCTURES
Note: =====================================================================

Type called "StatisticalSummary":
    sample_size as Integer
    mean as Float
    median as Float
    mode as List[Float]
    standard_deviation as Float
    variance as Float
    minimum as Float
    maximum as Float
    range as Float
    interquartile_range as Float
    skewness as Float
    kurtosis as Float

Type called "QuantileConfiguration":
    percentile_levels as List[Float]
    interpolation_method as String
    sample_quantiles as Dictionary[String, Float]
    confidence_intervals as Dictionary[String, List[Float]]
    robust_estimates as Boolean

Type called "MomentsAnalysis":
    raw_moments as List[Float]
    central_moments as List[Float]
    standardized_moments as List[Float]
    moment_generating_function as Dictionary[String, Float]
    cumulants as List[Float]
    moment_order as Integer

Type called "DistributionShape":
    skewness_coefficient as Float
    kurtosis_coefficient as Float
    excess_kurtosis as Float
    shape_classification as String
    normality_indicators as Dictionary[String, Float]
    outlier_detection as List[Integer]

Note: =====================================================================
Note: PRIVATE HELPER FUNCTIONS
Note: =====================================================================

Process called "count_frequencies" that takes data as List[Float] returns Dictionary[String, Integer]:
    Note: Count occurrences of each unique value for mode calculation
    Let frequencies be Dictionary[String, Integer]()
    For value in data:
        Let key be value.to_string()
        If key in frequencies:
            Set frequencies[key] to frequencies[key] + 1
        Otherwise:
            Set frequencies[key] to 1
    Return frequencies

Process called "get_sorted_data" that takes data as List[Float] returns List[Float]:
    Note: Sort numerical data in ascending order
    If data.length <= 1:
        Return data
    
    Let string_data be List[String]()
    For value in data:
        Let string_data be string_data.append(value.to_string())
    
    Let config be Sorting.SortingConfig with algorithm_type as "quicksort", reverse_order as false
    Let sort_result be Sorting.quicksort(string_data, config)
    
    Let sorted_data be List[Float]()
    For str_value in sort_result.sorted_collection:
        Let sorted_data be sorted_data.append(str_value.to_float())
    
    Return sorted_data

Process called "validate_numeric_data" that takes data as List[Float] returns List[Float]:
    Note: Remove NaN, infinity, and invalid values from data
    Let valid_data be List[Float]()
    For value in data:
        Let abs_result be MathOps.absolute_value(value.to_string())
        If abs_result.operation_successful and not abs_result.result_value.contains("infinity") and not abs_result.result_value.contains("nan"):
            Let valid_data be valid_data.append(value)
    Return valid_data

Process called "compute_cumulative_sum" that takes data as List[Float] returns List[Float]:
    Note: Compute cumulative sum for running calculations
    Let cumulative be List[Float]()
    Let running_sum be 0.0
    For value in data:
        Let running_sum be running_sum + value
        Let cumulative be cumulative.append(running_sum)
    Return cumulative

Process called "find_percentile_index" that takes data_length as Integer, percentile as Float returns Dictionary[String, Float]:
    Note: Calculate index and fraction for percentile position
    Let position be (percentile / 100.0) * (data_length - 1)
    Let lower_index be position.floor()
    Let upper_index be position.ceil()
    Let fraction be position - lower_index
    
    Let result be Dictionary[String, Float]()
    Set result["lower_index"] to lower_index
    Set result["upper_index"] to upper_index
    Set result["fraction"] to fraction
    Return result

Process called "linear_interpolation" that takes lower_value as Float, upper_value as Float, fraction as Float returns Float:
    Note: Perform linear interpolation between two values
    Return lower_value + (upper_value - lower_value) * fraction

Process called "compute_product" that takes data as List[Float] returns Float:
    Note: Compute product of all elements for geometric mean
    Let product be 1.0
    For value in data:
        Let product be product * value
    Return product

Note: =====================================================================
Note: CENTRAL TENDENCY OPERATIONS
Note: =====================================================================

Process called "calculate_arithmetic_mean" that takes data as List[Float], weights as List[Float] returns Float:
    Note: Calculate arithmetic mean with optional weights. Formula: Σ(xi * wi) / Σ(wi)
    Note: Assumes equal weights if not specified. Handles missing values and edge cases
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    If weights.length == 0:
        Note: Equal weights case - simple arithmetic mean
        Let sum be 0.0
        For value in clean_data:
            Let sum be sum + value
        Return sum / clean_data.length
    
    If weights.length != clean_data.length:
        Throw Errors.InvalidArgument with "calculate_arithmetic_mean: Weights length must match data length"
    
    Note: Weighted arithmetic mean
    Let weighted_sum be 0.0
    Let total_weight be 0.0
    
    For i in range(0, clean_data.length):
        If weights[i] > 0.0:
            Let weighted_sum be weighted_sum + (clean_data[i] * weights[i])
            Let total_weight be total_weight + weights[i]
    
    If total_weight == 0.0:
        Throw Errors.InvalidArgument with "calculate_arithmetic_mean: Total weight cannot be zero"
    
    Return weighted_sum / total_weight

Process called "calculate_geometric_mean" that takes data as List[Float], handle_negative as Boolean returns Float:
    Note: Calculate geometric mean using nth root of product. Formula: (Π xi)^(1/n)
    Note: Requires positive values unless handle_negative flag transforms data
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    Let processed_data be List[Float]()
    
    For value in clean_data:
        If value > 0.0:
            Let processed_data be processed_data.append(value)
        Otherwise If value < 0.0 and handle_negative:
            Let abs_result be MathOps.absolute_value(value.to_string())
            If abs_result.operation_successful:
                Let processed_data be processed_data.append(abs_result.result_value.to_float())
        Otherwise If value == 0.0:
            Return 0.0
        Otherwise:
            Throw Errors.InvalidArgument with "calculate_geometric_mean: Requires positive values or handle_negative=true"
    
    If processed_data.length == 0:
        Return 0.0
    
    Note: Use logarithmic approach to avoid overflow: exp(Σln(xi)/n)
    Let log_sum be 0.0
    For value in processed_data:
        Let ln_result be MathOps.natural_logarithm(value.to_string(), 15)
        If ln_result.operation_successful:
            Let log_sum be log_sum + ln_result.result_value.to_float()
        Otherwise:
            Throw Errors.ComputationError with "calculate_geometric_mean: Failed to compute natural logarithm"
    
    Let mean_log be log_sum / processed_data.length
    Let exp_result be MathOps.exponential(mean_log.to_string(), 15)
    
    If exp_result.operation_successful:
        Return exp_result.result_value.to_float()
    Otherwise:
        Throw Errors.ComputationError with "calculate_geometric_mean: Failed to compute geometric mean"

Process called "calculate_harmonic_mean" that takes data as List[Float], exclude_zero as Boolean returns Float:
    Note: Calculate harmonic mean as reciprocal of arithmetic mean of reciprocals
    Note: Formula: n / Σ(1/xi). Undefined for zero values unless excluded
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    Let reciprocal_sum be 0.0
    Let count be 0
    
    For value in clean_data:
        If value == 0.0:
            If exclude_zero:
                Note: Skip zero values
            Otherwise:
                Throw Errors.InvalidArgument with "calculate_harmonic_mean: Undefined for zero values"
        Otherwise:
            Let reciprocal_sum be reciprocal_sum + (1.0 / value)
            Let count be count + 1
    
    If count == 0:
        Return 0.0
    
    Return count.to_float() / reciprocal_sum

Process called "find_median" that takes data as List[Float], interpolation_method as String returns Float:
    Note: Find median value using specified interpolation method for even-sized samples
    Note: Methods: linear, lower, higher, midpoint, nearest. Handles sorted/unsorted data
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    Let sorted_data be get_sorted_data(clean_data)
    Let n be sorted_data.length
    
    If n % 2 == 1:
        Note: Odd number of elements - return middle element
        Let middle_index be n / 2
        Return sorted_data[middle_index]
    
    Note: Even number of elements - use interpolation method
    Let lower_index be (n / 2) - 1
    Let upper_index be n / 2
    Let lower_value be sorted_data[lower_index]
    Let upper_value be sorted_data[upper_index]
    
    If interpolation_method == "lower":
        Return lower_value
    Otherwise If interpolation_method == "higher":
        Return upper_value
    Otherwise If interpolation_method == "midpoint":
        Return (lower_value + upper_value) / 2.0
    Otherwise If interpolation_method == "nearest":
        Let middle_position be (n - 1) / 2.0
        If middle_position - lower_index < upper_index - middle_position:
            Return lower_value
        Otherwise:
            Return upper_value
    Otherwise:
        Note: Default to linear interpolation
        Return (lower_value + upper_value) / 2.0

Process called "find_mode" that takes data as List[Float], tolerance as Float returns List[Float]:
    Note: Find mode(s) - most frequently occurring values with configurable tolerance
    Note: Tolerance controls grouping of similar values (0.0001 = very strict, 0.1 = loose)
    Note: Returns multimodal results. Handles continuous data through tolerance-based binning
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return List[Float]()
    
    If clean_data.length == 1:
        Return clean_data
    
    Let frequencies be Dictionary[String, Integer]()
    Let value_map be Dictionary[String, Float]()
    
    For value in clean_data:
        Let found_key be ""
        Let found be false
        
        Note: Check if value is within tolerance of existing key
        For key in frequencies.keys():
            Let existing_value be value_map[key]
            Let abs_diff be MathOps.absolute_value((value - existing_value).to_string())
            If abs_diff.operation_successful and abs_diff.result_value.to_float() <= tolerance:
                Let found_key be key
                Let found be true
                Break
        
        If found:
            Set frequencies[found_key] to frequencies[found_key] + 1
        Otherwise:
            Let key be value.to_string()
            Set frequencies[key] to 1
            Set value_map[key] to value
    
    Note: Find maximum frequency
    Let max_frequency be 0
    For key in frequencies.keys():
        If frequencies[key] > max_frequency:
            Let max_frequency be frequencies[key]
    
    Note: Collect all values with maximum frequency
    Let modes be List[Float]()
    For key in frequencies.keys():
        If frequencies[key] == max_frequency:
            Let modes be modes.append(value_map[key])
    
    Return modes

Note: =====================================================================
Note: VARIABILITY MEASURES OPERATIONS
Note: =====================================================================

Process called "calculate_variance" that takes data as List[Float], population as Boolean, bias_correction as Boolean returns Float:
    Note: Calculate sample or population variance. Formula: Σ(xi - μ)² / (n-δ)
    Note: Uses Bessel's correction (δ=1) for sample variance when bias_correction=true
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    If clean_data.length == 1:
        If population:
            Return 0.0
        Otherwise:
            Note: calculate_variance: Sample variance undefined for single value
            Throw Errors.InvalidArgument with "calculate_variance: Sample variance undefined for single observation"
    
    Note: Calculate mean
    Let mean be calculate_arithmetic_mean(clean_data, List[Float]())
    
    Note: Calculate sum of squared deviations
    Let sum_squared_deviations be 0.0
    For value in clean_data:
        Let deviation be value - mean
        Let sum_squared_deviations be sum_squared_deviations + (deviation * deviation)
    
    Note: Determine denominator
    Let n be clean_data.length
    Let denominator be n.to_float()
    
    If not population and bias_correction:
        Let denominator be (n - 1).to_float()
    
    If denominator == 0.0:
        Throw Errors.InvalidArgument with "calculate_variance: Division by zero in variance calculation"
    
    Return sum_squared_deviations / denominator

Process called "calculate_standard_deviation" that takes data as List[Float], population as Boolean returns Float:
    Note: Calculate standard deviation as square root of variance
    Note: Provides measure of spread around mean in original units
    Let variance be calculate_variance(data, population, true)
    
    If variance < 0.0:
        Throw Errors.ComputationError with "calculate_standard_deviation: Cannot compute standard deviation of negative variance"
    
    Let sqrt_result be MathOps.square_root(variance.to_string(), 15)
    If sqrt_result.operation_successful:
        Return sqrt_result.result_value.to_float()
    Otherwise:
        Throw Errors.ComputationError with "calculate_standard_deviation: Failed to compute square root for standard deviation"

Process called "calculate_range" that takes data as List[Float] returns Dictionary[String, Float]:
    Note: Calculate range, interquartile range, and range-based statistics
    Note: Returns min, max, range, Q1, Q3, IQR, and outlier boundaries
    Let clean_data be validate_numeric_data(data)
    Let result be Dictionary[String, Float]()
    
    If clean_data.length == 0:
        Set result["min"] to 0.0
        Set result["max"] to 0.0
        Set result["range"] to 0.0
        Set result["Q1"] to 0.0
        Set result["Q3"] to 0.0
        Set result["IQR"] to 0.0
        Set result["lower_fence"] to 0.0
        Set result["upper_fence"] to 0.0
        Return result
    
    Let sorted_data be get_sorted_data(clean_data)
    Let min_value be sorted_data[0]
    Let max_value be sorted_data[sorted_data.length - 1]
    
    Set result["min"] to min_value
    Set result["max"] to max_value
    Set result["range"] to max_value - min_value
    
    Note: Calculate quartiles
    Let q1_index be find_percentile_index(sorted_data.length, 25.0)
    Let q3_index be find_percentile_index(sorted_data.length, 75.0)
    
    Let q1 be linear_interpolation(
        sorted_data[q1_index["lower_index"].to_integer()],
        sorted_data[q1_index["upper_index"].to_integer()],
        q1_index["fraction"]
    )
    
    Let q3 be linear_interpolation(
        sorted_data[q3_index["lower_index"].to_integer()],
        sorted_data[q3_index["upper_index"].to_integer()],
        q3_index["fraction"]
    )
    
    Let iqr be q3 - q1
    
    Set result["Q1"] to q1
    Set result["Q3"] to q3
    Set result["IQR"] to iqr
    Set result["lower_fence"] to q1 - (1.5 * iqr)
    Set result["upper_fence"] to q3 + (1.5 * iqr)
    
    Return result

Process called "calculate_coefficient_of_variation" that takes data as List[Float] returns Float:
    Note: Calculate coefficient of variation as ratio of standard deviation to mean
    Note: Provides relative measure of variability. Formula: σ/μ * 100%
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    Let mean be calculate_arithmetic_mean(clean_data, List[Float]())
    If mean == 0.0:
        Throw Errors.InvalidArgument with "calculate_coefficient_of_variation: Undefined when mean is zero"
    
    Let std_dev be calculate_standard_deviation(clean_data, false)
    Return (std_dev / mean) * 100.0

Process called "calculate_mean_absolute_deviation" that takes data as List[Float], center as String returns Float:
    Note: Calculate mean absolute deviation from specified center (mean, median, mode)
    Note: Robust measure of variability. Formula: Σ|xi - center| / n
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    Let center_value be 0.0
    
    If center == "mean":
        Let center_value be calculate_arithmetic_mean(clean_data, List[Float]())
    Otherwise If center == "median":
        Let center_value be find_median(clean_data, "linear")
    Otherwise If center == "mode":
        Let modes be find_mode(clean_data, 0.0001)
        If modes.length > 0:
            Let center_value be modes[0]
        Otherwise:
            Let center_value be calculate_arithmetic_mean(clean_data, List[Float]())
    Otherwise:
        Throw Errors.InvalidArgument with "calculate_mean_absolute_deviation: Center must be 'mean', 'median', or 'mode'"
    
    Let sum_absolute_deviations be 0.0
    For value in clean_data:
        Let deviation be value - center_value
        Let abs_result be MathOps.absolute_value(deviation.to_string())
        If abs_result.operation_successful:
            Let sum_absolute_deviations be sum_absolute_deviations + abs_result.result_value.to_float()
        Otherwise:
            Throw Errors.ComputationError with "calculate_mean_absolute_deviation: Failed to compute absolute deviation"
    
    Return sum_absolute_deviations / clean_data.length

Note: =====================================================================
Note: QUANTILE ANALYSIS OPERATIONS
Note: =====================================================================

Process called "calculate_percentiles" that takes data as List[Float], percentiles as List[Float], method as String returns Dictionary[String, Float]:
    Note: Calculate specified percentiles using chosen interpolation method
    Note: Methods: linear, nearest, lower, higher, midpoint. Returns percentile values
    Let clean_data be validate_numeric_data(data)
    Let result be Dictionary[String, Float]()
    
    If clean_data.length == 0:
        For percentile in percentiles:
            Let key be "P" + percentile.to_string()
            Set result[key] to 0.0
        Return result
    
    Let sorted_data be get_sorted_data(clean_data)
    
    For percentile in percentiles:
        If percentile < 0.0 or percentile > 100.0:
            Throw Errors.InvalidArgument with "calculate_percentiles: Percentile must be between 0 and 100"
        
        Let index_info be find_percentile_index(sorted_data.length, percentile)
        Let lower_idx be index_info["lower_index"].to_integer()
        Let upper_idx be index_info["upper_index"].to_integer()
        Let fraction be index_info["fraction"]
        
        Let percentile_value be 0.0
        
        If lower_idx == upper_idx:
            Let percentile_value be sorted_data[lower_idx]
        Otherwise If method == "lower":
            Let percentile_value be sorted_data[lower_idx]
        Otherwise If method == "higher":
            Let percentile_value be sorted_data[upper_idx]
        Otherwise If method == "midpoint":
            Let percentile_value be (sorted_data[lower_idx] + sorted_data[upper_idx]) / 2.0
        Otherwise If method == "nearest":
            If fraction < 0.5:
                Let percentile_value be sorted_data[lower_idx]
            Otherwise:
                Let percentile_value be sorted_data[upper_idx]
        Otherwise:
            Note: Default to linear interpolation
            Let percentile_value be linear_interpolation(sorted_data[lower_idx], sorted_data[upper_idx], fraction)
        
        Let key be "P" + percentile.to_string()
        Set result[key] to percentile_value
    
    Return result

Process called "calculate_quartiles" that takes data as List[Float] returns Dictionary[String, Float]:
    Note: Calculate first, second (median), and third quartiles with IQR
    Note: Returns Q1, Q2, Q3, IQR, and outlier detection boundaries
    Let quartile_percentiles be List[Float](25.0, 50.0, 75.0)
    Let percentile_results be calculate_percentiles(data, quartile_percentiles, "linear")
    
    Let result be Dictionary[String, Float]()
    Set result["Q1"] to percentile_results["P25.0"]
    Set result["Q2"] to percentile_results["P50.0"]
    Set result["Q3"] to percentile_results["P75.0"]
    
    Let iqr be result["Q3"] - result["Q1"]
    Set result["IQR"] to iqr
    Set result["lower_fence"] to result["Q1"] - (1.5 * iqr)
    Set result["upper_fence"] to result["Q3"] + (1.5 * iqr)
    Set result["lower_outlier_boundary"] to result["Q1"] - (3.0 * iqr)
    Set result["upper_outlier_boundary"] to result["Q3"] + (3.0 * iqr)
    
    Return result

Process called "calculate_quantile_function" that takes data as List[Float], probability_levels as List[Float] returns Dictionary[String, Float]:
    Note: Calculate inverse cumulative distribution (quantile function)
    Note: Maps probabilities to data values. Useful for confidence intervals
    Let percentile_list be List[Float]()
    
    For probability in probability_levels:
        If probability < 0.0 or probability > 1.0:
            Throw Errors.InvalidArgument with "calculate_quantile_function: Probability levels must be between 0 and 1"
        Let percentile be probability * 100.0
        Let percentile_list be percentile_list.append(percentile)
    
    Let percentile_results be calculate_percentiles(data, percentile_list, "linear")
    Let result be Dictionary[String, Float]()
    
    For i in range(0, probability_levels.length):
        Let probability be probability_levels[i]
        Let percentile be probability * 100.0
        Let percentile_key be "P" + percentile.to_string()
        Let quantile_key be "Q" + probability.to_string()
        Set result[quantile_key] to percentile_results[percentile_key]
    
    Return result

Process called "detect_outliers_iqr" that takes data as List[Float], multiplier as Float returns List[Integer]:
    Note: Detect outliers using IQR method with configurable multiplier
    Note: Standard values: 1.5 (mild outliers), 3.0 (extreme outliers)  
    Note: Outliers: values < Q1 - k*IQR or > Q3 + k*IQR. Returns indices
    Let clean_data be validate_numeric_data(data)
    Let outlier_indices be List[Integer]()
    
    If clean_data.length < 4:
        Note: Need at least 4 values for meaningful quartile-based outlier detection
        Return outlier_indices
    
    Let quartiles be calculate_quartiles(clean_data)
    Let q1 be quartiles["Q1"]
    Let q3 be quartiles["Q3"]
    Let iqr be quartiles["IQR"]
    
    Let lower_bound be q1 - (multiplier * iqr)
    Let upper_bound be q3 + (multiplier * iqr)
    
    For i in range(0, clean_data.length):
        Let value be clean_data[i]
        If value < lower_bound or value > upper_bound:
            Let outlier_indices be outlier_indices.append(i)
    
    Return outlier_indices

Note: =====================================================================
Note: DISTRIBUTION SHAPE OPERATIONS
Note: =====================================================================

Process called "calculate_skewness" that takes data as List[Float], method as String returns Float:
    Note: Calculate skewness coefficient using specified method (Fisher, Pearson)
    Note: Measures asymmetry of distribution. Formula: E[(X-μ)³]/σ³
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length < 3:
        Note: Need at least 3 values for meaningful skewness calculation
        Return 0.0
    
    Let mean be calculate_arithmetic_mean(clean_data, List[Float]())
    Let std_dev be calculate_standard_deviation(clean_data, false)
    
    If std_dev == 0.0:
        Return 0.0
    
    Let sum_cubed_deviations be 0.0
    Let n be clean_data.length
    
    For value in clean_data:
        Let standardized_deviation be (value - mean) / std_dev
        Let cubed_deviation be standardized_deviation * standardized_deviation * standardized_deviation
        Let sum_cubed_deviations be sum_cubed_deviations + cubed_deviation
    
    Let skewness be sum_cubed_deviations / n.to_float()
    
    If method == "Fisher":
        Note: Apply Fisher's bias correction
        Let correction_factor be (n.to_float() * (n - 1).to_float()) / ((n - 2).to_float())
        If n > 2:
            Let skewness be skewness * correction_factor
    
    Return skewness

Process called "calculate_kurtosis" that takes data as List[Float], excess as Boolean returns Float:
    Note: Calculate kurtosis coefficient, optionally as excess kurtosis
    Note: Measures tail heaviness. Formula: E[(X-μ)⁴]/σ⁴. Excess = kurtosis - 3
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length < 4:
        Note: Need at least 4 values for meaningful kurtosis calculation
        Return 0.0
    
    Let mean be calculate_arithmetic_mean(clean_data, List[Float]())
    Let std_dev be calculate_standard_deviation(clean_data, false)
    
    If std_dev == 0.0:
        Return 0.0
    
    Let sum_fourth_power_deviations be 0.0
    Let n be clean_data.length
    
    For value in clean_data:
        Let standardized_deviation be (value - mean) / std_dev
        Let fourth_power_deviation be standardized_deviation * standardized_deviation * standardized_deviation * standardized_deviation
        Let sum_fourth_power_deviations be sum_fourth_power_deviations + fourth_power_deviation
    
    Let kurtosis be sum_fourth_power_deviations / n.to_float()
    
    If excess:
        Let kurtosis be kurtosis - 3.0
    
    Return kurtosis

Process called "assess_normality" that takes data as List[Float], alpha as Float returns Dictionary[String, Float]:
    Note: Assess normality using simplified moment-based criteria
    Note: Uses standard thresholds: |skewness| < 2.0 and |excess kurtosis| < 2.0
    Return assess_normality_with_thresholds(data, alpha, 2.0, 2.0)

Process called "assess_normality_with_thresholds" that takes data as List[Float], alpha as Float, skewness_threshold as Float, kurtosis_threshold as Float returns Dictionary[String, Float]:
    Note: Assess normality with configurable skewness and kurtosis thresholds
    Note: Returns test statistics, thresholds used, and normality assessment
    Let clean_data be validate_numeric_data(data)
    Let result be Dictionary[String, Float]()
    
    If clean_data.length < 3:
        Set result["skewness_test"] to 0.0
        Set result["kurtosis_test"] to 0.0
        Set result["combined_test"] to 1.0
        Set result["is_normal"] to 1.0
        Return result
    
    Note: Basic normality indicators using skewness and kurtosis
    Note: This is a simplified normality assessment using moment-based criteria
    Note: Formal tests like Shapiro-Wilk or Anderson-Darling provide more rigorous p-values
    Note: Thresholds: |skewness| < 2.0 and |excess kurtosis| < 2.0 suggest approximate normality
    Let skewness be calculate_skewness(clean_data, "Pearson")
    Let kurtosis be calculate_kurtosis(clean_data, true)
    
    Note: Approximate normality tests based on skewness and kurtosis
    Let abs_skewness be MathOps.absolute_value(skewness.to_string())
    Let abs_kurtosis be MathOps.absolute_value(kurtosis.to_string())
    
    Note: Using configurable thresholds passed as parameters
    
    Let skewness_normal be 0.0
    If abs_skewness.operation_successful and abs_skewness.result_value.to_float() < skewness_threshold:
        Let skewness_normal be 1.0
    
    Let kurtosis_normal be 0.0
    If abs_kurtosis.operation_successful and abs_kurtosis.result_value.to_float() < kurtosis_threshold:
        Let kurtosis_normal be 1.0
    
    Let combined_normal be 0.0
    If skewness_normal == 1.0 and kurtosis_normal == 1.0:
        Let combined_normal be 1.0
    
    Set result["skewness"] to skewness
    Set result["kurtosis"] to kurtosis
    Set result["skewness_test"] to skewness_normal
    Set result["kurtosis_test"] to kurtosis_normal
    Set result["combined_test"] to combined_normal
    Set result["is_normal"] to combined_normal
    Set result["alpha_used"] to alpha
    
    Return result

Process called "calculate_moments" that takes data as List[Float], order as Integer, central as Boolean returns MomentsAnalysis:
    Note: Calculate raw or central moments up to specified order
    Note: Central moments: E[(X-μ)ᵏ]. Raw moments: E[Xᵏ]. Includes standardized moments
    Let clean_data be validate_numeric_data(data)
    Let analysis be MomentsAnalysis with raw_moments as List[Float](), central_moments as List[Float](), standardized_moments as List[Float](), moment_generating_function as Dictionary[String, Float](), cumulants as List[Float](), moment_order as order
    
    If clean_data.length == 0:
        Return analysis
    
    Let mean be calculate_arithmetic_mean(clean_data, List[Float]())
    Let variance be 0.0
    If clean_data.length > 1:
        Let variance be calculate_variance(clean_data, false, true)
    
    Let std_dev be 1.0
    If variance > 0.0:
        Let sqrt_result be MathOps.square_root(variance.to_string(), 15)
        If sqrt_result.operation_successful:
            Let std_dev be sqrt_result.result_value.to_float()
    
    Let n be clean_data.length
    
    For k in range(1, order + 1):
        Let raw_moment be 0.0
        Let central_moment be 0.0
        
        For value in clean_data:
            Note: Raw moment: E[X^k]
            Let power_result be MathOps.power(value.to_string(), k.to_string(), 15)
            If power_result.operation_successful:
                Let raw_moment be raw_moment + power_result.result_value.to_float()
            
            Note: Central moment: E[(X-μ)^k]
            Let deviation be value - mean
            Let central_power_result be MathOps.power(deviation.to_string(), k.to_string(), 15)
            If central_power_result.operation_successful:
                Let central_moment be central_moment + central_power_result.result_value.to_float()
        
        Let raw_moment be raw_moment / n.to_float()
        Let central_moment be central_moment / n.to_float()
        
        Let analysis.raw_moments be analysis.raw_moments.append(raw_moment)
        Let analysis.central_moments be analysis.central_moments.append(central_moment)
        
        Note: Standardized moment: central_moment / σ^k
        Let standardized_moment be central_moment
        If std_dev > 0.0 and k > 0:
            Let std_power_result be MathOps.power(std_dev.to_string(), k.to_string(), 15)
            If std_power_result.operation_successful and std_power_result.result_value.to_float() != 0.0:
                Let standardized_moment be central_moment / std_power_result.result_value.to_float()
        
        Let analysis.standardized_moments be analysis.standardized_moments.append(standardized_moment)
    
    Return analysis

Note: =====================================================================
Note: ROBUST STATISTICS OPERATIONS
Note: =====================================================================

Process called "calculate_trimmed_mean" that takes data as List[Float], trim_percentage as Float returns Float:
    Note: Calculate trimmed mean by removing specified percentage from each tail
    Note: Robust estimator less sensitive to outliers. Typically 5-25% trimming
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    If trim_percentage < 0.0 or trim_percentage >= 50.0:
        Throw Errors.InvalidArgument with "calculate_trimmed_mean: Trim percentage must be between 0 and 50"
    
    If trim_percentage == 0.0:
        Return calculate_arithmetic_mean(clean_data, List[Float]())
    
    Let sorted_data be get_sorted_data(clean_data)
    Let n be sorted_data.length
    
    Let trim_count be ((trim_percentage / 100.0) * n.to_float()).floor().to_integer()
    
    If trim_count * 2 >= n:
        Note: Too much trimming would remove all data
        Let trim_count be (n / 2) - 1
        If trim_count < 0:
            Let trim_count be 0
    
    Let start_index be trim_count
    Let end_index be n - trim_count - 1
    
    If start_index > end_index:
        Return sorted_data[n / 2]
    
    Let sum be 0.0
    Let count be 0
    
    For i in range(start_index, end_index + 1):
        Let sum be sum + sorted_data[i]
        Let count be count + 1
    
    If count == 0:
        Return 0.0
    
    Return sum / count.to_float()

Process called "calculate_winsorized_mean" that takes data as List[Float], limits as List[Float] returns Float:
    Note: Calculate winsorized mean by replacing extreme values with percentile limits
    Note: More conservative than trimmed mean. Limits specify lower/upper percentiles
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    If limits.length != 2:
        Throw Errors.InvalidArgument with "calculate_winsorized_mean: Limits must contain exactly two values: [lower_percentile, upper_percentile]"
    
    Let lower_percentile be limits[0]
    Let upper_percentile be limits[1]
    
    If lower_percentile < 0.0 or lower_percentile > 100.0 or upper_percentile < 0.0 or upper_percentile > 100.0:
        Throw Errors.InvalidArgument with "calculate_winsorized_mean: Percentile limits must be between 0 and 100"
    
    If lower_percentile >= upper_percentile:
        Throw Errors.InvalidArgument with "calculate_winsorized_mean: Lower percentile must be less than upper percentile"
    
    Let percentiles be List[Float](lower_percentile, upper_percentile)
    Let percentile_values be calculate_percentiles(clean_data, percentiles, "linear")
    
    Let lower_limit be percentile_values["P" + lower_percentile.to_string()]
    Let upper_limit be percentile_values["P" + upper_percentile.to_string()]
    
    Let winsorized_data be List[Float]()
    
    For value in clean_data:
        Let winsorized_value be value
        If value < lower_limit:
            Let winsorized_value be lower_limit
        Otherwise If value > upper_limit:
            Let winsorized_value be upper_limit
        
        Let winsorized_data be winsorized_data.append(winsorized_value)
    
    Return calculate_arithmetic_mean(winsorized_data, List[Float]())

Process called "calculate_robust_scale" that takes data as List[Float], estimator as String returns Float:
    Note: Calculate robust scale estimator with standard scaling constants
    Note: MAD constant 1.4826 provides consistency with std dev for normal data
    Note: Rousseeuw-Croux constant 2.219 calibrated similarly. IQR uses direct calculation
    Return calculate_robust_scale_with_constants(data, estimator, 1.4826, 2.219)

Process called "calculate_robust_scale_with_constants" that takes data as List[Float], estimator as String, mad_constant as Float, rousseeuw_constant as Float returns Float:
    Note: Calculate robust scale estimator with configurable scaling constants
    Note: Allows customization of MAD and Rousseeuw-Croux scaling factors
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    If clean_data.length == 1:
        Return 0.0
    
    If estimator == "MAD":
        Note: Median Absolute Deviation
        Let median be find_median(clean_data, "linear")
        Let absolute_deviations be List[Float]()
        
        For value in clean_data:
            Let deviation be value - median
            Let abs_result be MathOps.absolute_value(deviation.to_string())
            If abs_result.operation_successful:
                Let absolute_deviations be absolute_deviations.append(abs_result.result_value.to_float())
        
        Let mad be find_median(absolute_deviations, "linear")
        Return mad * mad_constant
    
    Otherwise If estimator == "IQR":
        Note: Interquartile Range
        Let quartiles be calculate_quartiles(clean_data)
        Return quartiles["IQR"]
    
    Otherwise If estimator == "Rousseeuw-Croux":
        Note: Simplified Rousseeuw-Croux estimator - uses 25th percentile of absolute deviations
        Note: Full algorithm computes all pairwise differences; this approximation uses quartile method
        Note: Scaling constant 2.219 provides consistency with standard deviation for normal data
        Let median be find_median(clean_data, "linear")
        Let absolute_deviations be List[Float]()
        
        For value in clean_data:
            Let deviation be value - median
            Let abs_result be MathOps.absolute_value(deviation.to_string())
            If abs_result.operation_successful:
                Let absolute_deviations be absolute_deviations.append(abs_result.result_value.to_float())
        
        Let sorted_deviations be get_sorted_data(absolute_deviations)
        Let k be (sorted_deviations.length * 0.25).floor().to_integer()
        
        If k >= sorted_deviations.length:
            Let k be sorted_deviations.length - 1
        
        If k < 0:
            Return 0.0
        
        Return sorted_deviations[k] * rousseeuw_constant
    
    Otherwise:
        Throw Errors.InvalidArgument with "calculate_robust_scale: Unknown estimator. Use 'MAD', 'IQR', or 'Rousseeuw-Croux'"

Process called "calculate_hodges_lehmann_estimator" that takes data as List[Float] returns Float:
    Note: Calculate Hodges-Lehmann location estimator as median of pairwise averages
    Note: Robust alternative to mean. Formula: median((xi + xj)/2) for all i ≤ j
    Let clean_data be validate_numeric_data(data)
    
    If clean_data.length == 0:
        Return 0.0
    
    If clean_data.length == 1:
        Return clean_data[0]
    
    Let pairwise_averages be List[Float]()
    
    For i in range(0, clean_data.length):
        For j in range(i, clean_data.length):
            Let pairwise_average be (clean_data[i] + clean_data[j]) / 2.0
            Let pairwise_averages be pairwise_averages.append(pairwise_average)
    
    Return find_median(pairwise_averages, "linear")

Note: =====================================================================
Note: COMPREHENSIVE SUMMARY OPERATIONS
Note: =====================================================================

Process called "generate_descriptive_summary" that takes data as List[Float], include_robust as Boolean returns StatisticalSummary:
    Note: Generate comprehensive descriptive statistics summary
    Note: Includes all central tendency, variability, and shape measures
    Let clean_data be validate_numeric_data(data)
    
    Let summary be StatisticalSummary with sample_size as clean_data.length
    
    If clean_data.length == 0:
        Set summary.mean to 0.0
        Set summary.median to 0.0
        Set summary.mode to List[Float]()
        Set summary.standard_deviation to 0.0
        Set summary.variance to 0.0
        Set summary.minimum to 0.0
        Set summary.maximum to 0.0
        Set summary.range to 0.0
        Set summary.interquartile_range to 0.0
        Set summary.skewness to 0.0
        Set summary.kurtosis to 0.0
        Return summary
    
    Note: Central tendency measures
    Set summary.mean to calculate_arithmetic_mean(clean_data, List[Float]())
    Set summary.median to find_median(clean_data, "linear")
    Set summary.mode to find_mode(clean_data, 0.0001)
    
    Note: Variability measures
    If clean_data.length > 1:
        Set summary.variance to calculate_variance(clean_data, false, true)
        Set summary.standard_deviation to calculate_standard_deviation(clean_data, false)
    Otherwise:
        Set summary.variance to 0.0
        Set summary.standard_deviation to 0.0
    
    Note: Range measures
    Let range_info be calculate_range(clean_data)
    Set summary.minimum to range_info["min"]
    Set summary.maximum to range_info["max"]
    Set summary.range to range_info["range"]
    Set summary.interquartile_range to range_info["IQR"]
    
    Note: Distribution shape measures
    If clean_data.length >= 3:
        Set summary.skewness to calculate_skewness(clean_data, "Pearson")
    Otherwise:
        Set summary.skewness to 0.0
    
    If clean_data.length >= 4:
        Set summary.kurtosis to calculate_kurtosis(clean_data, true)
    Otherwise:
        Set summary.kurtosis to 0.0
    
    Return summary

Process called "create_five_number_summary" that takes data as List[Float] returns Dictionary[String, Float]:
    Note: Create five-number summary: minimum, Q1, median, Q3, maximum
    Note: Foundation for box plot visualization. Includes outlier information
    Let clean_data be validate_numeric_data(data)
    Let result be Dictionary[String, Float]()
    
    If clean_data.length == 0:
        Set result["minimum"] to 0.0
        Set result["Q1"] to 0.0
        Set result["median"] to 0.0
        Set result["Q3"] to 0.0
        Set result["maximum"] to 0.0
        Set result["IQR"] to 0.0
        Set result["outlier_count"] to 0.0
        Return result
    
    Let sorted_data be get_sorted_data(clean_data)
    Let quartiles be calculate_quartiles(clean_data)
    
    Set result["minimum"] to sorted_data[0]
    Set result["Q1"] to quartiles["Q1"]
    Set result["median"] to quartiles["Q2"]
    Set result["Q3"] to quartiles["Q3"]
    Set result["maximum"] to sorted_data[sorted_data.length - 1]
    Set result["IQR"] to quartiles["IQR"]
    Set result["lower_fence"] to quartiles["lower_fence"]
    Set result["upper_fence"] to quartiles["upper_fence"]
    
    Note: Count outliers
    Let outliers be detect_outliers_iqr(clean_data, 1.5)
    Set result["outlier_count"] to outliers.length.to_float()
    
    Return result

Process called "calculate_frequency_distribution" that takes data as List[Float], bins as Integer, method as String returns Dictionary[String, List[Float]]:
    Note: Calculate frequency distribution with specified binning method
    Note: Methods: equal-width, equal-frequency, Sturges, Scott, Freedman-Diaconis
    Let clean_data be validate_numeric_data(data)
    Let result be Dictionary[String, List[Float]]()
    
    If clean_data.length == 0:
        Set result["bin_edges"] to List[Float]()
        Set result["frequencies"] to List[Float]()
        Set result["bin_centers"] to List[Float]()
        Return result
    
    Let sorted_data be get_sorted_data(clean_data)
    Let min_value be sorted_data[0]
    Let max_value be sorted_data[sorted_data.length - 1]
    
    Let actual_bins be bins
    
    If method == "Sturges":
        Let log_n_result be MathOps.natural_logarithm(clean_data.length.to_string(), 10)
        If log_n_result.operation_successful:
            Let log2_n_result be MathOps.natural_logarithm("2", 10)
            If log2_n_result.operation_successful:
                Let log2_n be log_n_result.result_value.to_float() / log2_n_result.result_value.to_float()
                Let actual_bins be (1.0 + log2_n).ceil().to_integer()
    Otherwise If method == "Scott":
        Let std_dev be calculate_standard_deviation(clean_data, false)
        Let n_pow_result be MathOps.power(clean_data.length.to_string(), "0.333", 10)
        If n_pow_result.operation_successful and std_dev > 0.0:
            Let bin_width be 3.5 * std_dev / n_pow_result.result_value.to_float()
            If bin_width > 0.0:
                Let actual_bins be ((max_value - min_value) / bin_width).ceil().to_integer()
    
    If actual_bins <= 0:
        Let actual_bins be 10
    
    Note: Create equal-width bins
    Let bin_width be (max_value - min_value) / actual_bins.to_float()
    Let bin_edges be List[Float]()
    Let frequencies be List[Float]()
    Let bin_centers be List[Float]()
    
    For i in range(0, actual_bins + 1):
        Let edge be min_value + (i.to_float() * bin_width)
        Let bin_edges be bin_edges.append(edge)
    
    For i in range(0, actual_bins):
        Let center be min_value + ((i.to_float() + 0.5) * bin_width)
        Let bin_centers be bin_centers.append(center)
        Let frequencies be frequencies.append(0.0)
    
    For value in sorted_data:
        Let bin_index be ((value - min_value) / bin_width).floor().to_integer()
        If bin_index >= actual_bins:
            Let bin_index be actual_bins - 1
        If bin_index >= 0:
            Set frequencies[bin_index] to frequencies[bin_index] + 1.0
    
    Set result["bin_edges"] to bin_edges
    Set result["frequencies"] to frequencies
    Set result["bin_centers"] to bin_centers
    
    Return result

Process called "generate_statistical_profile" that takes data as List[Float], profile_config as Dictionary[String, String] returns Dictionary[String, Dictionary[String, Float]]:
    Note: Generate comprehensive statistical profile with customizable components
    Note: Includes descriptive stats, distribution fitting, and diagnostic measures
    Let clean_data be validate_numeric_data(data)
    Let profile be Dictionary[String, Dictionary[String, Float]]()
    
    If clean_data.length == 0:
        Return profile
    
    Note: Basic descriptive statistics
    Let descriptive be Dictionary[String, Float]()
    Let summary be generate_descriptive_summary(clean_data, true)
    
    Set descriptive["count"] to summary.sample_size.to_float()
    Set descriptive["mean"] to summary.mean
    Set descriptive["median"] to summary.median
    Set descriptive["std_dev"] to summary.standard_deviation
    Set descriptive["variance"] to summary.variance
    Set descriptive["minimum"] to summary.minimum
    Set descriptive["maximum"] to summary.maximum
    Set descriptive["range"] to summary.range
    Set descriptive["IQR"] to summary.interquartile_range
    Set descriptive["skewness"] to summary.skewness
    Set descriptive["kurtosis"] to summary.kurtosis
    
    Set profile["descriptive"] to descriptive
    
    Note: Robust statistics
    Let robust be Dictionary[String, Float]()
    
    If "include_robust" in profile_config and profile_config["include_robust"] == "true":
        Set robust["trimmed_mean_10"] to calculate_trimmed_mean(clean_data, 10.0)
        Set robust["trimmed_mean_20"] to calculate_trimmed_mean(clean_data, 20.0)
        Set robust["mad"] to calculate_robust_scale(clean_data, "MAD")
        Set robust["hodges_lehmann"] to calculate_hodges_lehmann_estimator(clean_data)
        
        Set profile["robust"] to robust
    
    Note: Quantile information
    Let quantiles be Dictionary[String, Float]()
    Let percentile_list be List[Float](5.0, 10.0, 25.0, 50.0, 75.0, 90.0, 95.0)
    Let percentile_results be calculate_percentiles(clean_data, percentile_list, "linear")
    
    For key in percentile_results.keys():
        Set quantiles[key] to percentile_results[key]
    
    Set profile["quantiles"] to quantiles
    
    Note: Distribution characteristics
    Let distribution be Dictionary[String, Float]()
    Let normality be assess_normality(clean_data, 0.05)
    
    Set distribution["is_normal"] to normality["is_normal"]
    Set distribution["skewness_test"] to normality["skewness_test"]
    Set distribution["kurtosis_test"] to normality["kurtosis_test"]
    
    If clean_data.length > 0:
        Set distribution["coefficient_of_variation"] to calculate_coefficient_of_variation(clean_data)
    
    Set profile["distribution"] to distribution
    
    Note: Outlier information
    Let outlier_info be Dictionary[String, Float]()
    Let outliers be detect_outliers_iqr(clean_data, 1.5)
    
    Set outlier_info["outlier_count"] to outliers.length.to_float()
    Set outlier_info["outlier_percentage"] to (outliers.length.to_float() / clean_data.length.to_float()) * 100.0
    
    Set profile["outliers"] to outlier_info
    
    Return profile

Note: =====================================================================
Note: COMPARATIVE STATISTICS OPERATIONS
Note: =====================================================================

Process called "compare_distributions" that takes data1 as List[Float], data2 as List[Float] returns Dictionary[String, Float]:
    Note: Compare two distributions using multiple statistical measures
    Note: Returns effect sizes, overlap measures, and distribution comparisons
    Let clean_data1 be validate_numeric_data(data1)
    Let clean_data2 be validate_numeric_data(data2)
    Let result be Dictionary[String, Float]()
    
    If clean_data1.length == 0 or clean_data2.length == 0:
        Set result["comparison_possible"] to 0.0
        Return result
    
    Set result["comparison_possible"] to 1.0
    Set result["n1"] to clean_data1.length.to_float()
    Set result["n2"] to clean_data2.length.to_float()
    
    Note: Basic descriptive comparisons
    Let mean1 be calculate_arithmetic_mean(clean_data1, List[Float]())
    Let mean2 be calculate_arithmetic_mean(clean_data2, List[Float]())
    Set result["mean1"] to mean1
    Set result["mean2"] to mean2
    Set result["mean_difference"] to mean2 - mean1
    
    Let median1 be find_median(clean_data1, "linear")
    Let median2 be find_median(clean_data2, "linear")
    Set result["median1"] to median1
    Set result["median2"] to median2
    Set result["median_difference"] to median2 - median1
    
    Let std1 be calculate_standard_deviation(clean_data1, false)
    Let std2 be calculate_standard_deviation(clean_data2, false)
    Set result["std1"] to std1
    Set result["std2"] to std2
    Set result["std_ratio"] to 1.0
    If std1 > 0.0:
        Set result["std_ratio"] to std2 / std1
    
    Note: Effect size (Cohen's d)
    Let effect_size be calculate_effect_size(clean_data1, clean_data2, "cohens_d")
    Set result["cohens_d"] to effect_size
    
    Note: Variance comparison
    Let var1 be calculate_variance(clean_data1, false, true)
    Let var2 be calculate_variance(clean_data2, false, true)
    Set result["variance1"] to var1
    Set result["variance2"] to var2
    Set result["variance_ratio"] to 1.0
    If var1 > 0.0:
        Set result["variance_ratio"] to var2 / var1
    
    Note: Distribution shape comparison
    If clean_data1.length >= 3 and clean_data2.length >= 3:
        Let skew1 be calculate_skewness(clean_data1, "Pearson")
        Let skew2 be calculate_skewness(clean_data2, "Pearson")
        Set result["skewness1"] to skew1
        Set result["skewness2"] to skew2
        Set result["skewness_difference"] to skew2 - skew1
    
    If clean_data1.length >= 4 and clean_data2.length >= 4:
        Let kurt1 be calculate_kurtosis(clean_data1, true)
        Let kurt2 be calculate_kurtosis(clean_data2, true)
        Set result["kurtosis1"] to kurt1
        Set result["kurtosis2"] to kurt2
        Set result["kurtosis_difference"] to kurt2 - kurt1
    
    Return result

Process called "calculate_effect_size" that takes group1 as List[Float], group2 as List[Float], method as String returns Float:
    Note: Calculate effect size using specified method (Cohen's d, Glass's delta, etc.)
    Note: Quantifies practical significance of difference between groups
    Let clean_data1 be validate_numeric_data(group1)
    Let clean_data2 be validate_numeric_data(group2)
    
    If clean_data1.length == 0 or clean_data2.length == 0:
        Return 0.0
    
    Let mean1 be calculate_arithmetic_mean(clean_data1, List[Float]())
    Let mean2 be calculate_arithmetic_mean(clean_data2, List[Float]())
    Let mean_diff be mean2 - mean1
    
    If method == "cohens_d":
        Note: Cohen's d = (mean2 - mean1) / pooled_std
        Let var1 be calculate_variance(clean_data1, false, true)
        Let var2 be calculate_variance(clean_data2, false, true)
        Let n1 be clean_data1.length
        Let n2 be clean_data2.length
        
        Let pooled_variance be ((n1 - 1).to_float() * var1 + (n2 - 1).to_float() * var2) / (n1 + n2 - 2).to_float()
        
        If pooled_variance <= 0.0:
            Return 0.0
        
        Let pooled_std_result be MathOps.square_root(pooled_variance.to_string(), 15)
        If pooled_std_result.operation_successful:
            Let pooled_std be pooled_std_result.result_value.to_float()
            If pooled_std > 0.0:
                Return mean_diff / pooled_std
        
        Return 0.0
    
    Otherwise If method == "glass_delta":
        Note: Glass's delta = (mean2 - mean1) / std1
        Let std1 be calculate_standard_deviation(clean_data1, false)
        If std1 > 0.0:
            Return mean_diff / std1
        Return 0.0
    
    Otherwise If method == "hedges_g":
        Note: Hedges' g = Cohen's d with small sample correction
        Let cohens_d be calculate_effect_size(clean_data1, clean_data2, "cohens_d")
        Let n1 be clean_data1.length
        Let n2 be clean_data2.length
        Let df be (n1 + n2 - 2).to_float()
        
        If df > 0.0:
            Let correction be 1.0 - (3.0 / (4.0 * df - 1.0))
            Return cohens_d * correction
        
        Return cohens_d
    
    Otherwise:
        Throw Errors.InvalidArgument with "calculate_effect_size: Unknown method. Use 'cohens_d', 'glass_delta', or 'hedges_g'"

Process called "assess_distribution_overlap" that takes data1 as List[Float], data2 as List[Float] returns Dictionary[String, Float]:
    Note: Assess overlap between two distributions using multiple measures
    Note: Returns overlap coefficient, Bhattacharyya coefficient, and other metrics
    Let clean_data1 be validate_numeric_data(data1)
    Let clean_data2 be validate_numeric_data(data2)
    Let result be Dictionary[String, Float]()
    
    If clean_data1.length == 0 or clean_data2.length == 0:
        Set result["overlap_possible"] to 0.0
        Return result
    
    Set result["overlap_possible"] to 1.0
    
    Note: Simple range overlap
    Let min1 be calculate_range(clean_data1)["min"]
    Let max1 be calculate_range(clean_data1)["max"]
    Let min2 be calculate_range(clean_data2)["min"]
    Let max2 be calculate_range(clean_data2)["max"]
    
    Let overlap_start be Compare.maximum(min1.to_string(), min2.to_string(), 10).to_float()
    Let overlap_end be Compare.minimum(max1.to_string(), max2.to_string(), 10).to_float()
    
    Let range_overlap be 0.0
    If overlap_end > overlap_start:
        Let overlap_length be overlap_end - overlap_start
        Let range1_length be max1 - min1
        Let range2_length be max2 - min2
        Let avg_range be (range1_length + range2_length) / 2.0
        If avg_range > 0.0:
            Let range_overlap be overlap_length / avg_range
    
    Set result["range_overlap"] to range_overlap
    
    Note: Quartile-based overlap using IQR
    Let quartiles1 be calculate_quartiles(clean_data1)
    Let quartiles2 be calculate_quartiles(clean_data2)
    
    Let q1_1 be quartiles1["Q1"]
    Let q3_1 be quartiles1["Q3"]
    Let q1_2 be quartiles2["Q1"]
    Let q3_2 be quartiles2["Q3"]
    
    Let iqr_overlap_start be Compare.maximum(q1_1.to_string(), q1_2.to_string(), 10).to_float()
    Let iqr_overlap_end be Compare.minimum(q3_1.to_string(), q3_2.to_string(), 10).to_float()
    
    Let iqr_overlap be 0.0
    If iqr_overlap_end > iqr_overlap_start:
        Let iqr_overlap_length be iqr_overlap_end - iqr_overlap_start
        Let avg_iqr be (quartiles1["IQR"] + quartiles2["IQR"]) / 2.0
        If avg_iqr > 0.0:
            Let iqr_overlap be iqr_overlap_length / avg_iqr
    
    Set result["iqr_overlap"] to iqr_overlap
    
    Note: Simplified Bhattacharyya coefficient approximation for normal distributions
    Note: Assumes both distributions are approximately normal with known means and variances
    Note: Formula: BC = exp(-0.25 * (μ1-μ2)² / ((σ1²+σ2²)/2)) for normal case
    Note: Full Bhattacharyya coefficient requires integration over probability distributions
    Let mean1 be calculate_arithmetic_mean(clean_data1, List[Float]())
    Let mean2 be calculate_arithmetic_mean(clean_data2, List[Float]())
    Let var1 be calculate_variance(clean_data1, false, true)
    Let var2 be calculate_variance(clean_data2, false, true)
    
    If var1 > 0.0 and var2 > 0.0:
        Let mean_diff_sq be (mean1 - mean2) * (mean1 - mean2)
        Let avg_var be (var1 + var2) / 2.0
        Let bhattacharyya_approx be (-0.25 * mean_diff_sq / avg_var)
        Set result["bhattacharyya_distance"] to bhattacharyya_approx
        
        Let exp_result be MathOps.exponential(bhattacharyya_approx.to_string(), 10)
        If exp_result.operation_successful:
            Set result["bhattacharyya_coefficient"] to exp_result.result_value.to_float()
        Otherwise:
            Set result["bhattacharyya_coefficient"] to 0.0
    Otherwise:
        Set result["bhattacharyya_distance"] to 0.0
        Set result["bhattacharyya_coefficient"] to 0.0
    
    Return result

Note: =====================================================================
Note: UTILITY OPERATIONS
Note: =====================================================================

Process called "validate_statistical_assumptions" that takes data as List[Float], assumptions as List[String] returns Dictionary[String, Boolean]:
    Note: Validate common statistical assumptions (normality, homoscedasticity, etc.)
    Note: Returns boolean results and diagnostic statistics for each assumption
    Let clean_data be validate_numeric_data(data)
    Let result be Dictionary[String, Boolean]()
    
    If clean_data.length == 0:
        For assumption in assumptions:
            Set result[assumption] to false
        Return result
    
    For assumption in assumptions:
        If assumption == "normality":
            Let normality be assess_normality(clean_data, 0.05)
            Set result["normality"] to normality["is_normal"] == 1.0
        
        Otherwise If assumption == "no_outliers":
            Let outliers be detect_outliers_iqr(clean_data, 1.5)
            Set result["no_outliers"] to outliers.length == 0
        
        Otherwise If assumption == "sufficient_sample_size":
            Set result["sufficient_sample_size"] to clean_data.length >= 30
        
        Otherwise If assumption == "homoscedasticity":
            Note: Simplified homoscedasticity test using coefficient of variation threshold
            Note: CV < 50% suggests reasonable variance stability; not a formal statistical test
            Note: Formal tests (Bartlett, Levene) require multiple groups for comparison
            Let cv be calculate_coefficient_of_variation(clean_data)
            Set result["homoscedasticity"] to cv < 50.0
        
        Otherwise If assumption == "independence":
            Note: Cannot test independence from single dataset - assume true
            Set result["independence"] to true
        
        Otherwise:
            Set result[assumption] to false
    
    Return result

Process called "handle_missing_values" that takes data as List[Float], method as String returns List[Float]:
    Note: Handle missing values using specified method (removal, imputation, etc.)
    Note: Methods: listwise deletion, mean imputation, median imputation, interpolation
    Note: In Runa, Float NaN is represented as special values that fail validation
    Let result be List[Float]()
    
    If method == "listwise_deletion":
        Return validate_numeric_data(data)
    
    Otherwise If method == "mean_imputation":
        Let clean_data be validate_numeric_data(data)
        If clean_data.length == 0:
            Return result
        
        Let mean be calculate_arithmetic_mean(clean_data, List[Float]())
        
        For value in data:
            Let abs_result be MathOps.absolute_value(value.to_string())
            If abs_result.operation_successful and not abs_result.result_value.contains("infinity") and not abs_result.result_value.contains("nan"):
                Let result be result.append(value)
            Otherwise:
                Let result be result.append(mean)
        
        Return result
    
    Otherwise If method == "median_imputation":
        Let clean_data be validate_numeric_data(data)
        If clean_data.length == 0:
            Return result
        
        Let median be find_median(clean_data, "linear")
        
        For value in data:
            Let abs_result be MathOps.absolute_value(value.to_string())
            If abs_result.operation_successful and not abs_result.result_value.contains("infinity") and not abs_result.result_value.contains("nan"):
                Let result be result.append(value)
            Otherwise:
                Let result be result.append(median)
        
        Return result
    
    Otherwise If method == "forward_fill":
        Let last_valid be 0.0
        Let has_valid be false
        
        For value in data:
            Let abs_result be MathOps.absolute_value(value.to_string())
            If abs_result.operation_successful and not abs_result.result_value.contains("infinity") and not abs_result.result_value.contains("nan"):
                Let result be result.append(value)
                Let last_valid be value
                Let has_valid be true
            Otherwise:
                If has_valid:
                    Let result be result.append(last_valid)
                Otherwise:
                    Let result be result.append(0.0)
        
        Return result
    
    Otherwise:
        Throw Errors.InvalidArgument with "handle_missing_values: Unknown method. Use 'listwise_deletion', 'mean_imputation', 'median_imputation', or 'forward_fill'"

Process called "transform_data" that takes data as List[Float], transformation as String returns List[Float]:
    Note: Apply data transformation (log, sqrt, Box-Cox, etc.) for analysis
    Note: Helps achieve normality, homoscedasticity, or linearize relationships
    Let clean_data be validate_numeric_data(data)
    Let result be List[Float]()
    
    If clean_data.length == 0:
        Return result
    
    If transformation == "log":
        For value in clean_data:
            If value > 0.0:
                Let log_result be MathOps.natural_logarithm(value.to_string(), 15)
                If log_result.operation_successful:
                    Let result be result.append(log_result.result_value.to_float())
                Otherwise:
                    Let result be result.append(0.0)
            Otherwise:
                Note: Add small constant to handle zero/negative values
                Let adjusted_value be value + 1.0
                Let log_result be MathOps.natural_logarithm(adjusted_value.to_string(), 15)
                If log_result.operation_successful:
                    Let result be result.append(log_result.result_value.to_float())
                Otherwise:
                    Let result be result.append(0.0)
        
        Return result
    
    Otherwise If transformation == "sqrt":
        For value in clean_data:
            If value >= 0.0:
                Let sqrt_result be MathOps.square_root(value.to_string(), 15)
                If sqrt_result.operation_successful:
                    Let result be result.append(sqrt_result.result_value.to_float())
                Otherwise:
                    Let result be result.append(0.0)
            Otherwise:
                Note: Handle negative values by taking sqrt of absolute value
                Let abs_result be MathOps.absolute_value(value.to_string())
                If abs_result.operation_successful:
                    Let sqrt_result be MathOps.square_root(abs_result.result_value, 15)
                    If sqrt_result.operation_successful:
                        Let result be result.append(-sqrt_result.result_value.to_float())
                    Otherwise:
                        Let result be result.append(0.0)
                Otherwise:
                    Let result be result.append(0.0)
        
        Return result
    
    Otherwise If transformation == "square":
        For value in clean_data:
            Let result be result.append(value * value)
        
        Return result
    
    Otherwise If transformation == "reciprocal":
        For value in clean_data:
            If value != 0.0:
                Let result be result.append(1.0 / value)
            Otherwise:
                Let result be result.append(0.0)
        
        Return result
    
    Otherwise If transformation == "standardize":
        Let mean be calculate_arithmetic_mean(clean_data, List[Float]())
        Let std_dev be calculate_standard_deviation(clean_data, false)
        
        If std_dev > 0.0:
            For value in clean_data:
                Let standardized be (value - mean) / std_dev
                Let result be result.append(standardized)
        Otherwise:
            For value in clean_data:
                Let result be result.append(0.0)
        
        Return result
    
    Otherwise:
        Throw Errors.InvalidArgument with "transform_data: Unknown transformation. Use 'log', 'sqrt', 'square', 'reciprocal', or 'standardize'"

Process called "bootstrap_statistic" that takes data as List[Float], statistic_function as String, samples as Integer returns List[Float]:
    Note: Generate bootstrap samples of specified statistic for uncertainty estimation
    Note: Resamples data with replacement using cryptographically secure random generation
    Let clean_data be validate_numeric_data(data)
    Let bootstrap_results be List[Float]()
    
    If clean_data.length == 0 or samples <= 0:
        Return bootstrap_results
    
    For sample_i in range(0, samples):
        Let bootstrap_sample be List[Float]()
        
        Note: Create bootstrap sample with replacement using crypto-secure random
        For i in range(0, clean_data.length):
            Let index be CryptoRandom.generate_random_integer(0, clean_data.length - 1)
            Let bootstrap_sample be bootstrap_sample.append(clean_data[index])
        
        Note: Calculate statistic on bootstrap sample
        Let statistic_value be 0.0
        
        If statistic_function == "mean":
            Let statistic_value be calculate_arithmetic_mean(bootstrap_sample, List[Float]())
        Otherwise If statistic_function == "median":
            Let statistic_value be find_median(bootstrap_sample, "linear")
        Otherwise If statistic_function == "std":
            Let statistic_value be calculate_standard_deviation(bootstrap_sample, false)
        Otherwise If statistic_function == "variance":
            Let statistic_value be calculate_variance(bootstrap_sample, false, true)
        Otherwise If statistic_function == "min":
            Let range_info be calculate_range(bootstrap_sample)
            Let statistic_value be range_info["min"]
        Otherwise If statistic_function == "max":
            Let range_info be calculate_range(bootstrap_sample)
            Let statistic_value be range_info["max"]
        Otherwise If statistic_function == "iqr":
            Let quartiles be calculate_quartiles(bootstrap_sample)
            Let statistic_value be quartiles["IQR"]
        Otherwise:
            Throw Errors.InvalidArgument with "bootstrap_statistic: Unknown statistic function. Use 'mean', 'median', 'std', 'variance', 'min', 'max', or 'iqr'"
        
        Let bootstrap_results be bootstrap_results.append(statistic_value)
    
    Return bootstrap_results