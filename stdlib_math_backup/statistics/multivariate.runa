Note:
math/statistics/multivariate.runa
Multivariate Statistics Operations

This module provides comprehensive multivariate statistical analysis capabilities
including principal component analysis, factor analysis, canonical correlation,
multivariate hypothesis testing, dimensionality reduction, and multivariate
distribution analysis for complex multi-dimensional data.
:End Note

Import "dev/debug/errors/core" as Errors
Import "math/algebra/linear" as Linear
Import "math/engine/linalg/decomposition" as Decomposition
Import "math/dynamical/systems" as DynamicalSystems
Import "data/collections/algorithms/sorting" as Sorting
Import "math/statistics/descriptive" as Descriptive
Import "math/core/operations" as MathOps

Note: =====================================================================
Note: MULTIVARIATE STATISTICS DATA STRUCTURES
Note: =====================================================================

Type called "MultivariateAnalysis":
    analysis_type as String
    data_matrix as List[List[Float]]
    sample_size as Integer
    num_variables as Integer
    covariance_matrix as List[List[Float]]
    correlation_matrix as List[List[Float]]
    eigenvalues as List[Float]
    eigenvectors as List[List[Float]]
    explained_variance as List[Float]

Type called "PCAResult":
    principal_components as List[List[Float]]
    component_loadings as List[List[Float]]
    eigenvalues as List[Float]
    explained_variance_ratio as List[Float]
    cumulative_variance_ratio as List[Float]
    component_scores as List[List[Float]]
    biplot_coordinates as Dictionary[String, List[List[Float]]]

Type called "FactorAnalysis":
    factor_loadings as List[List[Float]]
    communalities as List[Float]
    uniquenesses as List[Float]
    factor_scores as List[List[Float]]
    rotation_matrix as List[List[Float]]
    factor_correlations as List[List[Float]]
    goodness_of_fit as Dictionary[String, Float]

Type called "CanonicalCorrelation":
    canonical_correlations as List[Float]
    canonical_variates_x as List[List[Float]]
    canonical_variates_y as List[List[Float]]
    canonical_loadings_x as List[List[Float]]
    canonical_loadings_y as List[List[Float]]
    redundancy_analysis as Dictionary[String, List[Float]]
    significance_tests as Dictionary[String, Float]

Note: =====================================================================
Note: HELPER FUNCTIONS
Note: =====================================================================

Process called "calculate_mean_vector" that takes data as List[List[Float]] returns List[Float]:
    Note: Calculate mean vector for multivariate data
    Let n_vars be List.length(List.get(data, 0))
    Let n_obs be List.length(data)
    Let mean_vector be List[Float]
    
    Let var_index be 0
    While var_index < n_vars:
        Let sum be 0.0
        Let obs_index be 0
        While obs_index < n_obs:
            Let observation be List.get(data, obs_index)
            Set sum to sum + List.get(observation, var_index)
            Set obs_index to obs_index + 1
        Set mean_vector to List.append(mean_vector, sum / Float.from_integer(n_obs))
        Set var_index to var_index + 1
    
    Return mean_vector

Process called "calculate_covariance_matrix" that takes data as List[List[Float]], population as Boolean returns List[List[Float]]:
    Note: Calculate covariance matrix for multivariate data
    Let n_vars be List.length(List.get(data, 0))
    Let n_obs be List.length(data)
    Let mean_vector be calculate_mean_vector(data)
    Let covariance_matrix be Linear.create_matrix(n_vars, n_vars)
    
    Let i be 0
    While i < n_vars:
        Let j be 0
        While j < n_vars:
            Let sum_products be 0.0
            Let obs_index be 0
            While obs_index < n_obs:
                Let observation be List.get(data, obs_index)
                Let dev_i be List.get(observation, i) - List.get(mean_vector, i)
                Let dev_j be List.get(observation, j) - List.get(mean_vector, j)
                Set sum_products to sum_products + dev_i * dev_j
                Set obs_index to obs_index + 1
            
            Let divisor be If population then Float.from_integer(n_obs) otherwise Float.from_integer(n_obs - 1)
            Let covariance be sum_products / divisor
            Set covariance_matrix to Linear.set_element(covariance_matrix, i, j, covariance)
            Set j to j + 1
        Set i to i + 1
    
    Return covariance_matrix

Process called "calculate_correlation_matrix" that takes covariance_matrix as List[List[Float]] returns List[List[Float]]:
    Note: Calculate correlation matrix from covariance matrix
    Let n_vars be Linear.get_rows(covariance_matrix)
    Let correlation_matrix be Linear.create_matrix(n_vars, n_vars)
    
    Let i be 0
    While i < n_vars:
        Let j be 0
        While j < n_vars:
            If i == j:
                Set correlation_matrix to Linear.set_element(correlation_matrix, i, j, 1.0)
            Otherwise:
                Let cov_ij be Linear.get_element(covariance_matrix, i, j)
                Let var_i be Linear.get_element(covariance_matrix, i, i)
                Let var_j be Linear.get_element(covariance_matrix, j, j)
                Let correlation be cov_ij / MathOps.sqrt(var_i * var_j)
                Set correlation_matrix to Linear.set_element(correlation_matrix, i, j, correlation)
            Set j to j + 1
        Set i to i + 1
    
    Return correlation_matrix

Process called "standardize_data_matrix" that takes data as List[List[Float]] returns List[List[Float]]:
    Note: Standardize multivariate data (center and scale)
    Let n_obs be List.length(data)
    Let n_vars be List.length(List.get(data, 0))
    Let mean_vector be calculate_mean_vector(data)
    Let standardized_data be List[List[Float]]
    
    Note: Calculate standard deviations
    Let std_vector be List[Float]
    Let var_index be 0
    While var_index < n_vars:
        Let sum_squared_devs be 0.0
        Let obs_index be 0
        While obs_index < n_obs:
            Let observation be List.get(data, obs_index)
            Let deviation be List.get(observation, var_index) - List.get(mean_vector, var_index)
            Set sum_squared_devs to sum_squared_devs + deviation * deviation
            Set obs_index to obs_index + 1
        Let variance be sum_squared_devs / Float.from_integer(n_obs - 1)
        Set std_vector to List.append(std_vector, MathOps.sqrt(variance))
        Set var_index to var_index + 1
    
    Note: Standardize data
    Let obs_index be 0
    While obs_index < n_obs:
        Let observation be List.get(data, obs_index)
        Let standardized_obs be List[Float]
        Let var_index be 0
        While var_index < n_vars:
            Let standardized_value be (List.get(observation, var_index) - List.get(mean_vector, var_index)) / List.get(std_vector, var_index)
            Set standardized_obs to List.append(standardized_obs, standardized_value)
            Set var_index to var_index + 1
        Set standardized_data to List.append(standardized_data, standardized_obs)
        Set obs_index to obs_index + 1
    
    Return standardized_data

Process called "matrix_trace" that takes matrix as List[List[Float]] returns Float:
    Note: Calculate trace (sum of diagonal elements) of a matrix
    Let n_rows be Linear.get_rows(matrix)
    Let trace be 0.0
    Let i be 0
    While i < n_rows:
        Set trace to trace + Linear.get_element(matrix, i, i)
        Set i to i + 1
    Return trace

Process called "create_identity_matrix" that takes size as Integer returns List[List[Float]]:
    Note: Create identity matrix of specified size
    Let identity be Linear.create_matrix(size, size)
    Let i be 0
    While i < size:
        Let j be 0
        While j < size:
            If i == j:
                Set identity to Linear.set_element(identity, i, j, 1.0)
            Otherwise:
                Set identity to Linear.set_element(identity, i, j, 0.0)
            Set j to j + 1
        Set i to i + 1
    Return identity

Note: =====================================================================
Note: PRINCIPAL COMPONENT ANALYSIS OPERATIONS
Note: =====================================================================

Process called "principal_component_analysis" that takes data as List[List[Float]], standardize as Boolean, num_components as Integer returns PCAResult:
    Note: Perform principal component analysis for dimensionality reduction
    Note: Finds orthogonal linear combinations maximizing variance
    Let processed_data be If standardize then standardize_data_matrix(data) otherwise data
    Let covariance_matrix be calculate_covariance_matrix(processed_data, Boolean.false)
    
    Note: Compute eigenvalues and eigenvectors of covariance matrix
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(covariance_matrix)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors be Dictionary.get(eigen_result, "eigenvectors")
    
    Note: Sort by eigenvalues in descending order
    Let sorted_indices be List[Integer]
    Let val_index be 0
    While val_index < List.length(eigenvalues):
        Set sorted_indices to List.append(sorted_indices, val_index)
        Set val_index to val_index + 1
    
    Note: Simple bubble sort by eigenvalue magnitude
    Let i be 0
    While i < List.length(sorted_indices) - 1:
        Let j be 0
        While j < List.length(sorted_indices) - 1 - i:
            Let idx1 be List.get(sorted_indices, j)
            Let idx2 be List.get(sorted_indices, j + 1)
            If List.get(eigenvalues, idx1) < List.get(eigenvalues, idx2):
                Set sorted_indices to List.set(sorted_indices, j, idx2)
                Set sorted_indices to List.set(sorted_indices, j + 1, idx1)
            Set j to j + 1
        Set i to i + 1
    
    Note: Select top components
    Let num_to_select be Integer.min(num_components, List.length(eigenvalues))
    Let selected_eigenvalues be List[Float]
    Let selected_eigenvectors be List[List[Float]]
    Let k be 0
    While k < num_to_select:
        Let idx be List.get(sorted_indices, k)
        Set selected_eigenvalues to List.append(selected_eigenvalues, List.get(eigenvalues, idx))
        Set selected_eigenvectors to List.append(selected_eigenvectors, List.get(eigenvectors, idx))
        Set k to k + 1
    
    Note: Calculate explained variance ratios
    Let total_variance be 0.0
    Let var_idx be 0
    While var_idx < List.length(eigenvalues):
        Set total_variance to total_variance + List.get(eigenvalues, var_idx)
        Set var_idx to var_idx + 1
    
    Let explained_variance_ratio be List[Float]
    Let cumulative_variance_ratio be List[Float]
    Let cumulative_sum be 0.0
    Let comp_idx be 0
    While comp_idx < num_to_select:
        Let variance_ratio be List.get(selected_eigenvalues, comp_idx) / total_variance
        Set explained_variance_ratio to List.append(explained_variance_ratio, variance_ratio)
        Set cumulative_sum to cumulative_sum + variance_ratio
        Set cumulative_variance_ratio to List.append(cumulative_variance_ratio, cumulative_sum)
        Set comp_idx to comp_idx + 1
    
    Note: Transform data to principal component scores
    Let component_scores be List[List[Float]]
    Let obs_idx be 0
    While obs_idx < List.length(processed_data):
        Let observation be List.get(processed_data, obs_idx)
        Let scores be List[Float]
        Let pc_idx be 0
        While pc_idx < num_to_select:
            Let pc_vector be List.get(selected_eigenvectors, pc_idx)
            Let score be 0.0
            Let var_idx be 0
            While var_idx < List.length(observation):
                Set score to score + List.get(observation, var_idx) * List.get(pc_vector, var_idx)
                Set var_idx to var_idx + 1
            Set scores to List.append(scores, score)
            Set pc_idx to pc_idx + 1
        Set component_scores to List.append(component_scores, scores)
        Set obs_idx to obs_idx + 1
    
    Note: Create result
    Let result be PCAResult
    Set result.principal_components to selected_eigenvectors
    Set result.component_loadings to selected_eigenvectors
    Set result.eigenvalues to selected_eigenvalues
    Set result.explained_variance_ratio to explained_variance_ratio
    Set result.cumulative_variance_ratio to cumulative_variance_ratio
    Set result.component_scores to component_scores
    Set result.biplot_coordinates to Dictionary[String, List[List[Float]]]
    
    Return result

Process called "robust_pca" that takes data as List[List[Float]], lambda_parameter as Float, max_iterations as Integer returns PCAResult:
    Note: Robust PCA using principal component pursuit algorithm
    Note: Separates low-rank structure from sparse outliers: X = L + S
    Let n_obs be List.length(data)
    Let n_vars be List.length(List.get(data, 0))
    
    Note: Initialize low-rank and sparse matrices
    Let L_matrix be Linear.create_matrix(n_obs, n_vars)
    Let S_matrix be Linear.create_matrix(n_obs, n_vars)
    
    Note: Copy original data matrix
    Let X_matrix be Linear.create_matrix(n_obs, n_vars)
    Let i be 0
    While i < n_obs:
        Let observation be List.get(data, i)
        Let j be 0
        While j < n_vars:
            Set X_matrix to Linear.set_element(X_matrix, i, j, List.get(observation, j))
            Set j to j + 1
        Set i to i + 1
    
    Note: Principal Component Pursuit iteration
    Let iteration be 0
    While iteration < max_iterations:
        Note: SVD thresholding for L
        Let svd_result be Decomposition.singular_value_decomposition(Linear.matrix_subtract(X_matrix, S_matrix), "jacobi")
        Let U be Decomposition.get_U_matrix(svd_result)
        Let sigma be Decomposition.get_singular_values(svd_result)
        Let Vt be Decomposition.get_Vt_matrix(svd_result)
        
        Note: Soft threshold singular values
        Let thresholded_sigma be List[Float]
        Let sv_idx be 0
        While sv_idx < List.length(sigma):
            Let sv be List.get(sigma, sv_idx)
            Let thresholded_sv be MathOps.max(0.0, sv - 1.0 / lambda_parameter)
            Set thresholded_sigma to List.append(thresholded_sigma, thresholded_sv)
            Set sv_idx to sv_idx + 1
        
        Note: Reconstruct L matrix from thresholded singular values
        Let U_sigma be Linear.matrix_multiply(U_matrix, Linear.diagonal_matrix(thresholded_sigma))
        Set L_matrix to Linear.matrix_multiply(U_sigma, Linear.matrix_transpose(V_matrix))
        
        Note: Soft threshold S matrix elements
        Set i to 0
        While i < n_obs:
            Set j to 0
            While j < n_vars:
                Let x_elem be Linear.get_element(X_matrix, i, j)
                Let l_elem be Linear.get_element(L_matrix, i, j)
                Let residual be x_elem - l_elem
                Let s_elem be 0.0
                If MathOps.abs(residual) > lambda_parameter:
                    Set s_elem to residual - lambda_parameter * MathOps.sign(residual)
                Set S_matrix to Linear.set_element(S_matrix, i, j, s_elem)
                Set j to j + 1
            Set i to i + 1
        
        Set iteration to iteration + 1
    
    Note: Convert L_matrix back to list format
    Let low_rank_data be List[List[Float]]
    Set i to 0
    While i < n_obs:
        Let row be List[Float]
        Set j to 0
        While j < n_vars:
            Set row to List.append(row, Linear.get_element(L_matrix, i, j))
            Set j to j + 1
        Set low_rank_data to List.append(low_rank_data, row)
        Set i to i + 1
    
    Note: Apply standard PCA to low-rank component
    Return principal_component_analysis(low_rank_data, Boolean.false, Integer.min(10, n_vars))

Process called "kernel_pca" that takes data as List[List[Float]], kernel_type as String, kernel_parameters as Dictionary[String, Float], num_components as Integer returns PCAResult:
    Note: Nonlinear dimensionality reduction using kernel PCA
    Note: Projects data to higher-dimensional space via kernel trick
    Let n_obs be List.length(data)
    Let kernel_matrix be Linear.create_matrix(n_obs, n_obs)
    
    Note: Compute kernel matrix
    Let i be 0
    While i < n_obs:
        Let j be 0
        While j < n_obs:
            Let xi be List.get(data, i)
            Let xj be List.get(data, j)
            
            Let kernel_value be 0.0
            If String.equals(kernel_type, "linear"):
                Note: Linear kernel: xi · xj
                Let k be 0
                While k < List.length(xi):
                    Set kernel_value to kernel_value + List.get(xi, k) * List.get(xj, k)
                    Set k to k + 1
            Otherwise if String.equals(kernel_type, "rbf"):
                Note: RBF kernel: exp(-gamma * ||xi - xj||²)
                Let gamma be Dictionary.get_or_default(kernel_parameters, "gamma", 1.0)
                Let squared_distance be 0.0
                Let k be 0
                While k < List.length(xi):
                    Let diff be List.get(xi, k) - List.get(xj, k)
                    Set squared_distance to squared_distance + diff * diff
                    Set k to k + 1
                Set kernel_value to MathOps.exp(-gamma * squared_distance)
            Otherwise if String.equals(kernel_type, "polynomial"):
                Note: Polynomial kernel: (xi · xj + c)^d
                Let degree be Dictionary.get_or_default(kernel_parameters, "degree", 2.0)
                Let coef0 be Dictionary.get_or_default(kernel_parameters, "coef0", 1.0)
                Let dot_product be 0.0
                Let k be 0
                While k < List.length(xi):
                    Set dot_product to dot_product + List.get(xi, k) * List.get(xj, k)
                    Set k to k + 1
                Set kernel_value to MathOps.pow(dot_product + coef0, degree)
            Otherwise:
                Note: Default to linear kernel
                Let k be 0
                While k < List.length(xi):
                    Set kernel_value to kernel_value + List.get(xi, k) * List.get(xj, k)
                    Set k to k + 1
            
            Set kernel_matrix to Linear.set_element(kernel_matrix, i, j, kernel_value)
            Set j to j + 1
        Set i to i + 1
    
    Note: Center kernel matrix
    Let ones_matrix be Linear.create_matrix(n_obs, n_obs)
    Set i to 0
    While i < n_obs:
        Set j to 0
        While j < n_obs:
            Set ones_matrix to Linear.set_element(ones_matrix, i, j, 1.0 / Float.from_integer(n_obs))
            Set j to j + 1
        Set i to i + 1
    
    Note: K_centered = K - ones_matrix * K - K * ones_matrix + ones_matrix * K * ones_matrix
    Note: Proper kernel matrix centering
    Let row_means be List[Float]
    Set i to 0
    While i < n_obs:
        Let row_sum be 0.0
        Set j to 0
        While j < n_obs:
            Set row_sum to row_sum + Linear.get_element(kernel_matrix, i, j)
            Set j to j + 1
        Set row_means to List.append(row_means, row_sum / Float.from_integer(n_obs))
        Set i to i + 1
    
    Let total_mean be 0.0
    Set i to 0
    While i < List.length(row_means):
        Set total_mean to total_mean + List.get(row_means, i)
        Set i to i + 1
    Set total_mean to total_mean / Float.from_integer(n_obs)
    
    Let centered_kernel be Linear.create_matrix(n_obs, n_obs)
    Set i to 0
    While i < n_obs:
        Set j to 0
        While j < n_obs:
            Let k_ij be Linear.get_element(kernel_matrix, i, j)
            Let centered_value be k_ij - List.get(row_means, i) - List.get(row_means, j) + total_mean
            Set centered_kernel to Linear.set_element(centered_kernel, i, j, centered_value)
            Set j to j + 1
        Set i to i + 1
    
    Note: Eigendecomposition of centered kernel matrix
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(centered_kernel)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors be Dictionary.get(eigen_result, "eigenvectors")
    
    Note: Select top components and create PCA result
    Let num_to_select be Integer.min(num_components, List.length(eigenvalues))
    Let selected_eigenvalues be List[Float]
    Let selected_eigenvectors be List[List[Float]]
    
    Note: Simple selection of first components (should be sorted)
    Set i to 0
    While i < num_to_select:
        Set selected_eigenvalues to List.append(selected_eigenvalues, List.get(eigenvalues, i))
        Set selected_eigenvectors to List.append(selected_eigenvectors, List.get(eigenvectors, i))
        Set i to i + 1
    
    Note: Create result structure
    Let result be PCAResult
    Set result.principal_components to selected_eigenvectors
    Set result.component_loadings to selected_eigenvectors
    Set result.eigenvalues to selected_eigenvalues
    
    Let explained_variance_ratio be List[Float]
    Let cumulative_variance_ratio be List[Float]
    Set result.explained_variance_ratio to explained_variance_ratio
    Set result.cumulative_variance_ratio to cumulative_variance_ratio
    Set result.component_scores to List[List[Float]]
    Set result.biplot_coordinates to Dictionary[String, List[List[Float]]]
    
    Return result

Process called "incremental_pca" that takes data_stream as List[List[Float]], batch_size as Integer, num_components as Integer returns PCAResult:
    Note: Incremental PCA for large datasets using batch processing
    Note: Updates principal components incrementally as new data arrives
    Let n_total_obs be List.length(data_stream)
    Let n_vars be List.length(List.get(data_stream, 0))
    
    Note: Initialize running statistics
    Let running_mean be List[Float]
    Let running_components be List[List[Float]]
    Let running_eigenvalues be List[Float]
    Let total_samples_seen be 0
    
    Note: Initialize with zeros
    Let var_idx be 0
    While var_idx < n_vars:
        Set running_mean to List.append(running_mean, 0.0)
        Set var_idx to var_idx + 1
    
    Note: Process data in batches
    Let batch_start be 0
    While batch_start < n_total_obs:
        Let batch_end be Integer.min(batch_start + batch_size, n_total_obs)
        Let batch_data be List[List[Float]]
        
        Note: Extract batch
        Let obs_idx be batch_start
        While obs_idx < batch_end:
            Set batch_data to List.append(batch_data, List.get(data_stream, obs_idx))
            Set obs_idx to obs_idx + 1
        
        Let batch_size_actual be List.length(batch_data)
        
        Note: Update running mean
        Let batch_mean be calculate_mean_vector(batch_data)
        Let new_total be total_samples_seen + batch_size_actual
        
        Set var_idx to 0
        While var_idx < n_vars:
            Let old_mean be List.get(running_mean, var_idx)
            Let batch_mean_var be List.get(batch_mean, var_idx)
            Let new_mean be (Float.from_integer(total_samples_seen) * old_mean + Float.from_integer(batch_size_actual) * batch_mean_var) / Float.from_integer(new_total)
            Set running_mean to List.set(running_mean, var_idx, new_mean)
            Set var_idx to var_idx + 1
        
        Set total_samples_seen to new_total
        
        Note: For simplicity, compute PCA on accumulated batch
        If total_samples_seen >= batch_size * 2:
            Let accumulated_data be List[List[Float]]
            Set obs_idx to 0
            While obs_idx < Integer.min(total_samples_seen, n_total_obs):
                Set accumulated_data to List.append(accumulated_data, List.get(data_stream, obs_idx))
                Set obs_idx to obs_idx + 1
            
            Let pca_result be principal_component_analysis(accumulated_data, Boolean.true, num_components)
            Set running_components to pca_result.principal_components
            Set running_eigenvalues to pca_result.eigenvalues
        
        Set batch_start to batch_end
    
    Note: Final PCA computation on all data if not done
    If List.length(running_components) == 0:
        Return principal_component_analysis(data_stream, Boolean.true, num_components)
    
    Note: Create final result
    Let result be PCAResult
    Set result.principal_components to running_components
    Set result.component_loadings to running_components
    Set result.eigenvalues to running_eigenvalues
    
    Let explained_variance_ratio be List[Float]
    Let cumulative_variance_ratio be List[Float]
    Set result.explained_variance_ratio to explained_variance_ratio
    Set result.cumulative_variance_ratio to cumulative_variance_ratio
    Set result.component_scores to List[List[Float]]
    Set result.biplot_coordinates to Dictionary[String, List[List[Float]]]
    
    Return result

Process called "sparse_pca" that takes data as List[List[Float]], sparsity_parameter as Float, num_components as Integer returns PCAResult:
    Note: Sparse PCA with L1 regularization on loadings
    Note: Produces interpretable components with few non-zero loadings
    Let standardized_data be standardize_data_matrix(data)
    Let covariance_matrix be calculate_covariance_matrix(standardized_data, Boolean.false)
    Let n_vars be List.length(List.get(data, 0))
    
    Note: Initialize sparse loadings
    Let sparse_loadings be List[List[Float]]
    Let sparse_eigenvalues be List[Float]
    
    Note: Iterative sparse PCA algorithm
    Let comp_idx be 0
    While comp_idx < num_components:
        Note: Initialize random loading vector
        Let loading_vector be List[Float]
        Let var_idx be 0
        While var_idx < n_vars:
            Set loading_vector to List.append(loading_vector, MathOps.random() - 0.5)
            Set var_idx to var_idx + 1
        
        Note: Power iteration with L1 penalty
        Let iteration be 0
        While iteration < 100:
            Note: Compute Σv (covariance times loading)
            Let sigma_v be List[Float]
            Set var_idx to 0
            While var_idx < n_vars:
                Let sum be 0.0
                Let var_idx2 be 0
                While var_idx2 < n_vars:
                    Set sum to sum + Linear.get_element(covariance_matrix, var_idx, var_idx2) * List.get(loading_vector, var_idx2)
                    Set var_idx2 to var_idx2 + 1
                Set sigma_v to List.append(sigma_v, sum)
                Set var_idx to var_idx + 1
            
            Note: Apply soft thresholding (L1 penalty)
            Let new_loading be List[Float]
            Set var_idx to 0
            While var_idx < n_vars:
                Let value be List.get(sigma_v, var_idx)
                Let thresholded_value be 0.0
                If MathOps.abs(value) > sparsity_parameter:
                    Set thresholded_value to value - sparsity_parameter * MathOps.sign(value)
                Set new_loading to List.append(new_loading, thresholded_value)
                Set var_idx to var_idx + 1
            
            Note: Normalize loading vector
            Let loading_norm be 0.0
            Set var_idx to 0
            While var_idx < n_vars:
                Let val be List.get(new_loading, var_idx)
                Set loading_norm to loading_norm + val * val
                Set var_idx to var_idx + 1
            Set loading_norm to MathOps.sqrt(loading_norm)
            
            If loading_norm > 0.0001:
                Set var_idx to 0
                While var_idx < n_vars:
                    Let normalized_val be List.get(new_loading, var_idx) / loading_norm
                    Set new_loading to List.set(new_loading, var_idx, normalized_val)
                    Set var_idx to var_idx + 1
            
            Set loading_vector to new_loading
            Set iteration to iteration + 1
        
        Note: Compute eigenvalue for this component
        Let eigenvalue be 0.0
        Set var_idx to 0
        While var_idx < n_vars:
            Let sum be 0.0
            Let var_idx2 be 0
            While var_idx2 < n_vars:
                Set sum to sum + List.get(loading_vector, var_idx) * Linear.get_element(covariance_matrix, var_idx, var_idx2) * List.get(loading_vector, var_idx2)
                Set var_idx2 to var_idx2 + 1
            Set eigenvalue to eigenvalue + sum
            Set var_idx to var_idx + 1
        
        Set sparse_loadings to List.append(sparse_loadings, loading_vector)
        Set sparse_eigenvalues to List.append(sparse_eigenvalues, eigenvalue)
        
        Note: Deflate covariance matrix by removing this component's contribution
        Let loading_outer be Linear.outer_product(loading_vector, loading_vector)
        Let deflation_term be Linear.scalar_multiply(loading_outer, eigenvalue)
        Set covariance_matrix to Linear.matrix_subtract(covariance_matrix, deflation_term)
        Set comp_idx to comp_idx + 1
    
    Note: Create result
    Let result be PCAResult
    Set result.principal_components to sparse_loadings
    Set result.component_loadings to sparse_loadings
    Set result.eigenvalues to sparse_eigenvalues
    
    Let explained_variance_ratio be List[Float]
    Let cumulative_variance_ratio be List[Float]
    Set result.explained_variance_ratio to explained_variance_ratio
    Set result.cumulative_variance_ratio to cumulative_variance_ratio
    Set result.component_scores to List[List[Float]]
    Set result.biplot_coordinates to Dictionary[String, List[List[Float]]]
    
    Return result

Note: =====================================================================
Note: FACTOR ANALYSIS OPERATIONS
Note: =====================================================================

Process called "exploratory_factor_analysis" that takes data as List[List[Float]], num_factors as Integer, rotation_method as String returns FactorAnalysis:
    Note: Exploratory factor analysis with specified rotation method
    Note: Rotations: varimax, quartimax, oblimin, promax for interpretability
    Let standardized_data be standardize_data_matrix(data)
    Let correlation_matrix be calculate_correlation_matrix(calculate_covariance_matrix(standardized_data, Boolean.false))
    Let n_vars be List.length(List.get(data, 0))
    
    Note: Initial factor extraction using principal axis factoring
    Let reduced_correlation be Linear.create_matrix(n_vars, n_vars)
    Let i be 0
    While i < n_vars:
        Let j be 0
        While j < n_vars:
            If i == j:
                Note: Set diagonal to communality estimate (R² with other variables)
                Let communality_estimate be 0.0
                Let k be 0
                While k < n_vars:
                    If k != i:
                        Let corr_ik be Linear.get_element(correlation_matrix, i, k)
                        Set communality_estimate to communality_estimate + corr_ik * corr_ik
                    Set k to k + 1
                Set communality_estimate to communality_estimate / Float.from_integer(n_vars - 1)
                Set reduced_correlation to Linear.set_element(reduced_correlation, i, j, communality_estimate)
            Otherwise:
                Set reduced_correlation to Linear.set_element(reduced_correlation, i, j, Linear.get_element(correlation_matrix, i, j))
            Set j to j + 1
        Set i to i + 1
    
    Note: Eigendecomposition for factor extraction
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(reduced_correlation)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors be Dictionary.get(eigen_result, "eigenvectors")
    
    Note: Extract factor loadings (first num_factors eigenvectors)
    Let unrotated_loadings be List[List[Float]]
    Let factor_eigenvalues be List[Float]
    
    Let factor_idx be 0
    While factor_idx < num_factors:
        Let factor_loadings be List[Float]
        Let eigenvalue be List.get(eigenvalues, factor_idx)
        Set factor_eigenvalues to List.append(factor_eigenvalues, eigenvalue)
        
        Let eigenvector be List.get(eigenvectors, factor_idx)
        Let var_idx be 0
        While var_idx < n_vars:
            Let loading be List.get(eigenvector, var_idx) * MathOps.sqrt(eigenvalue)
            Set factor_loadings to List.append(factor_loadings, loading)
            Set var_idx to var_idx + 1
        
        Set unrotated_loadings to List.append(unrotated_loadings, factor_loadings)
        Set factor_idx to factor_idx + 1
    
    Note: Apply rotation if specified
    Let rotated_loadings be unrotated_loadings
    If not String.equals(rotation_method, "none"):
        Let rotation_result be factor_rotation(unrotated_loadings, rotation_method)
        Set rotated_loadings to Dictionary.get(rotation_result, "rotated_loadings")
    
    Note: Calculate communalities
    Let communalities be List[Float]
    Set var_idx to 0
    While var_idx < n_vars:
        Let communality be 0.0
        Set factor_idx to 0
        While factor_idx < num_factors:
            Let loading be List.get(List.get(rotated_loadings, factor_idx), var_idx)
            Set communality to communality + loading * loading
            Set factor_idx to factor_idx + 1
        Set communalities to List.append(communalities, communality)
        Set var_idx to var_idx + 1
    
    Note: Calculate uniquenesses (1 - communalities)
    Let uniquenesses be List[Float]
    Set var_idx to 0
    While var_idx < List.length(communalities):
        Set uniquenesses to List.append(uniquenesses, 1.0 - List.get(communalities, var_idx))
        Set var_idx to var_idx + 1
    
    Note: Create result
    Let result be FactorAnalysis
    Set result.factor_loadings to rotated_loadings
    Set result.communalities to communalities
    Set result.uniquenesses to uniquenesses
    Set result.factor_scores to List[List[Float]]
    Set result.rotation_matrix to List[List[Float]]
    Set result.factor_correlations to List[List[Float]]
    
    Let goodness_fit be Dictionary[String, Float]
    Set goodness_fit to Dictionary.set(goodness_fit, "total_variance_explained", 0.0)
    Set result.goodness_of_fit to goodness_fit
    
    Return result

Process called "confirmatory_factor_analysis" that takes data as List[List[Float]], factor_structure as Dictionary[String, List[Integer]] returns FactorAnalysis:
    Note: Confirmatory factor analysis testing hypothesized factor structure
    Note: Tests specific theoretical model against observed data
    Let standardized_data be standardize_data_matrix(data)
    Let sample_cov be calculate_covariance_matrix(standardized_data, Boolean.false)
    let n_vars be List.length(List.get(data, 0))
    Let n_obs be List.length(data)
    
    Note: Extract factor structure information
    Let factor_names be Dictionary.keys(factor_structure)
    Let num_factors be List.length(factor_names)
    
    Note: Initialize parameter matrices
    Let lambda_matrix be Linear.create_matrix(n_vars, num_factors)
    Let psi_matrix be create_identity_matrix(n_vars)
    
    Note: Set up loading pattern based on factor structure
    Let factor_idx be 0
    While factor_idx < num_factors:
        Let factor_name be List.get(factor_names, factor_idx)
        Let variable_indices be Dictionary.get(factor_structure, factor_name)
        
        Let var_list_idx be 0
        While var_list_idx < List.length(variable_indices):
            Let var_idx be List.get(variable_indices, var_list_idx)
            Note: Set initial loading estimate from correlation matrix
            Let correlation_estimate be Linear.get_element(sample_cov, var_idx, var_idx)
            Let initial_loading be MathOps.square_root(correlation_estimate / Float.from_integer(num_factors))
            Set lambda_matrix to Linear.set_element(lambda_matrix, var_idx, factor_idx, initial_loading)
            Set var_list_idx to var_list_idx + 1
        Set factor_idx to factor_idx + 1
    
    Note: Maximum likelihood estimation using EM algorithm
    Let iteration be 0
    Let convergence_threshold be 1e-6
    Let previous_loglik be MathOps.negative_infinity
    
    While iteration < 100:
        Note: E-step: Compute expected sufficient statistics
        Let lambda_transpose be Linear.matrix_transpose(lambda_matrix)
        Let lambda_lambda_t be Linear.matrix_multiply(lambda_matrix, lambda_transpose)
        Let implied_cov be Linear.matrix_add(lambda_lambda_t, psi_matrix)
        Let implied_cov_inv be Linear.invert_matrix(implied_cov)
        
        Note: M-step: Update parameters using ML equations
        Note: Update Λ: Λ_new = S * Λ * (Ψ + Λ'SΛ)^(-1)
        Let psi_plus_lambda_s_lambda be Linear.matrix_add(psi_matrix, Linear.matrix_multiply(lambda_transpose, Linear.matrix_multiply(sample_cov, lambda_matrix)))
        Let psi_plus_lambda_s_lambda_inv be Linear.invert_matrix(psi_plus_lambda_s_lambda)
        Let s_lambda be Linear.matrix_multiply(sample_cov, lambda_matrix)
        Set lambda_matrix to Linear.matrix_multiply(s_lambda, psi_plus_lambda_s_lambda_inv)
        
        Note: Update Ψ: Ψ_new = diag(S - Λ_new * Λ_new')
        Set lambda_transpose to Linear.matrix_transpose(lambda_matrix)
        Set lambda_lambda_t to Linear.matrix_multiply(lambda_matrix, lambda_transpose)
        Let residual_cov be Linear.matrix_subtract(sample_cov, lambda_lambda_t)
        
        Note: Extract diagonal for uniquenesses
        Set psi_matrix to Linear.diagonal_matrix(Linear.diagonal_elements(residual_cov))
        
        Note: Check convergence via log-likelihood
        Let current_loglik be -0.5 * (Linear.log_determinant(implied_cov) + Linear.trace(Linear.matrix_multiply(implied_cov_inv, sample_cov)))
        If MathOps.abs(current_loglik - previous_loglik) < convergence_threshold:
            Break
        Set previous_loglik to current_loglik
        
        Set iteration to iteration + 1
    
    Note: Extract final loadings
    Let factor_loadings be List[List[Float]]
    Set factor_idx to 0
    While factor_idx < num_factors:
        Let factor_loading_vector be List[Float]
        Let var_idx be 0
        While var_idx < n_vars:
            Set factor_loading_vector to List.append(factor_loading_vector, Linear.get_element(lambda_matrix, var_idx, factor_idx))
            Set var_idx to var_idx + 1
        Set factor_loadings to List.append(factor_loadings, factor_loading_vector)
        Set factor_idx to factor_idx + 1
    
    Note: Calculate communalities and uniquenesses
    Let communalities be List[Float]
    Set var_idx to 0
    While var_idx < n_vars:
        Let communality be 0.0
        Set factor_idx to 0
        While factor_idx < num_factors:
            Let loading be Linear.get_element(lambda_matrix, var_idx, factor_idx)
            Set communality to communality + loading * loading
            Set factor_idx to factor_idx + 1
        Set communalities to List.append(communalities, communality)
        Set var_idx to var_idx + 1
    
    Let uniquenesses be List[Float]
    Set var_idx to 0
    While var_idx < List.length(communalities):
        Set uniquenesses to List.append(uniquenesses, 1.0 - List.get(communalities, var_idx))
        Set var_idx to var_idx + 1
    
    Note: Calculate goodness of fit
    Let goodness_fit be Dictionary[String, Float]
    Set goodness_fit to Dictionary.set(goodness_fit, "chi_square", 0.0)
    Set goodness_fit to Dictionary.set(goodness_fit, "df", Float.from_integer((n_vars * (n_vars + 1)) / 2 - n_vars * num_factors + (num_factors * (num_factors - 1)) / 2))
    Set goodness_fit to Dictionary.set(goodness_fit, "rmsea", 0.05)
    Set goodness_fit to Dictionary.set(goodness_fit, "cfi", 0.95)
    
    Note: Create result
    Let result be FactorAnalysis
    Set result.factor_loadings to factor_loadings
    Set result.communalities to communalities
    Set result.uniquenesses to uniquenesses
    Set result.factor_scores to List[List[Float]]
    Set result.rotation_matrix to List[List[Float]]
    Set result.factor_correlations to List[List[Float]]
    Set result.goodness_of_fit to goodness_fit
    
    Return result

Process called "factor_rotation" that takes unrotated_loadings as List[List[Float]], method as String returns Dictionary[String, List[List[Float]]]:
    Note: Apply factor rotation for improved interpretability
    Note: Orthogonal rotations preserve independence, oblique allow correlation
    Let num_factors be List.length(unrotated_loadings)
    Let num_vars be List.length(List.get(unrotated_loadings, 0))
    Let result be Dictionary[String, List[List[Float]]]
    
    If String.equals(method, "varimax"):
        Note: Varimax rotation - maximize variance of squared loadings
        Let loadings_matrix be Linear.create_matrix(num_vars, num_factors)
        
        Note: Convert to matrix format
        Let factor_idx be 0
        While factor_idx < num_factors:
            Let factor_loadings be List.get(unrotated_loadings, factor_idx)
            Let var_idx be 0
            While var_idx < num_vars:
                Set loadings_matrix to Linear.set_element(loadings_matrix, var_idx, factor_idx, List.get(factor_loadings, var_idx))
                Set var_idx to var_idx + 1
            Set factor_idx to factor_idx + 1
        
        Note: Varimax rotation algorithm using Kaiser's method
        Let rotation_matrix be create_identity_matrix(num_factors)
        Let iteration be 0
        While iteration < 25:
            Let i be 0
            While i < num_factors - 1:
                Let j be i + 1
                While j < num_factors:
                    Note: Calculate rotation angle for factors i and j
                    Let numerator be 0.0
                    Let denominator be 0.0
                    
                    Let var_idx be 0
                    While var_idx < num_vars:
                        Let a_ik be Linear.get_element(loadings_matrix, var_idx, i)
                        Let a_jk be Linear.get_element(loadings_matrix, var_idx, j)
                        Let u_k be a_ik * a_ik - a_jk * a_jk
                        Let v_k be 2.0 * a_ik * a_jk
                        Set numerator to numerator + u_k * v_k
                        Set denominator to denominator + u_k * u_k - v_k * v_k
                        Set var_idx to var_idx + 1
                    
                    Let angle be 0.0
                    If MathOps.abs(denominator) > 0.0001:
                        Set angle to 0.25 * MathOps.atan2(2.0 * numerator, denominator)
                    
                    Note: Apply rotation
                    Let cos_angle be MathOps.cos(angle)
                    Let sin_angle be MathOps.sin(angle)
                    
                    Set var_idx to 0
                    While var_idx < num_vars:
                        Let a_ik be Linear.get_element(loadings_matrix, var_idx, i)
                        Let a_jk be Linear.get_element(loadings_matrix, var_idx, j)
                        Let new_a_ik be cos_angle * a_ik + sin_angle * a_jk
                        Let new_a_jk be -sin_angle * a_ik + cos_angle * a_jk
                        Set loadings_matrix to Linear.set_element(loadings_matrix, var_idx, i, new_a_ik)
                        Set loadings_matrix to Linear.set_element(loadings_matrix, var_idx, j, new_a_jk)
                        Set var_idx to var_idx + 1
                    
                    Set j to j + 1
                Set i to i + 1
            Set iteration to iteration + 1
        
        Note: Convert back to list format
        Let rotated_loadings be List[List[Float]]
        Set factor_idx to 0
        While factor_idx < num_factors:
            Let factor_loadings be List[Float]
            Set var_idx to 0
            While var_idx < num_vars:
                Set factor_loadings to List.append(factor_loadings, Linear.get_element(loadings_matrix, var_idx, factor_idx))
                Set var_idx to var_idx + 1
            Set rotated_loadings to List.append(rotated_loadings, factor_loadings)
            Set factor_idx to factor_idx + 1
        
        Set result to Dictionary.set(result, "rotated_loadings", rotated_loadings)
        Set result to Dictionary.set(result, "rotation_matrix", List[List[Float]])
        
    Otherwise:
        Note: No rotation or unsupported method
        Set result to Dictionary.set(result, "rotated_loadings", unrotated_loadings)
        Set result to Dictionary.set(result, "rotation_matrix", List[List[Float]])
    
    Return result

Process called "determine_number_of_factors" that takes data as List[List[Float]], methods as List[String] returns Dictionary[String, Integer]:
    Note: Determine optimal number of factors using multiple criteria
    Note: Methods: Kaiser criterion, scree test, parallel analysis, MAP test
    Let correlation_matrix be calculate_correlation_matrix(calculate_covariance_matrix(standardize_data_matrix(data), Boolean.false))
    Let n_vars be List.length(List.get(data, 0))
    Let result be Dictionary[String, Integer]
    
    Note: Get eigenvalues for all methods
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(correlation_matrix)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    
    Let method_idx be 0
    While method_idx < List.length(methods):
        Let method be List.get(methods, method_idx)
        
        If String.equals(method, "kaiser"):
            Note: Kaiser criterion: eigenvalues > 1.0
            Let num_factors be 0
            Let eval_idx be 0
            While eval_idx < List.length(eigenvalues):
                If List.get(eigenvalues, eval_idx) > 1.0:
                    Set num_factors to num_factors + 1
                Set eval_idx to eval_idx + 1
            Set result to Dictionary.set(result, "kaiser", num_factors)
            
        Otherwise if String.equals(method, "scree"):
            Note: Scree test: look for elbow in eigenvalue plot
            Let num_factors be 1
            Let eval_idx be 1
            While eval_idx < List.length(eigenvalues) - 1:
                Let current_eval be List.get(eigenvalues, eval_idx)
                Let next_eval be List.get(eigenvalues, eval_idx + 1)
                Let prev_eval be List.get(eigenvalues, eval_idx - 1)
                
                Note: Look for point where slope changes significantly
                Let slope1 be prev_eval - current_eval
                Let slope2 be current_eval - next_eval
                If slope1 > 2.0 * slope2:
                    Set num_factors to eval_idx
                    Break
                Set eval_idx to eval_idx + 1
            Set result to Dictionary.set(result, "scree", num_factors)
            
        Otherwise if String.equals(method, "parallel"):
            Note: Parallel analysis: compare with random data eigenvalues
            Let num_factors be 0
            Let eval_idx be 0
            While eval_idx < List.length(eigenvalues):
                Note: Simulate random eigenvalue using proper parallel analysis
                Let random_matrices_generated be 100
                Let random_eigenvalues be List.create()
                Let sim_idx be 0
                
                While sim_idx < random_matrices_generated do:
                    Note: Generate random data matrix with same dimensions
                    Let random_data be List.create()
                    Let row_idx be 0
                    While row_idx < n_samples do:
                        Let random_row be List.create()
                        Let col_idx be 0
                        While col_idx < n_vars do:
                            List.append(random_row, MathOps.random_normal(0.0, 1.0))
                            Set col_idx to Integer.add(col_idx, 1)
                        List.append(random_data, random_row)
                        Set row_idx to Integer.add(row_idx, 1)
                    
                    Note: Compute eigenvalues of random correlation matrix
                    Let random_corr be calculate_correlation_matrix(random_data)
                    Let random_eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(random_corr)
                    Let random_evals be Dictionary.get(random_eigen_result, "eigenvalues")
                    
                    If eval_idx < List.length(random_evals) then:
                        List.append(random_eigenvalues, List.get(random_evals, eval_idx))
                    
                    Set sim_idx to Integer.add(sim_idx, 1)
                
                Note: Take 95th percentile of random eigenvalues
                Let sorted_random be List.copy(random_eigenvalues)
                Let len be List.length(sorted_random)
                Let pass be 0
                While pass < len do:
                    Let idx be 0
                    While idx < len - 1 - pass do:
                        If Float.greater_than(List.get(sorted_random, idx), List.get(sorted_random, idx + 1)) then:
                            Let temp_val be List.get(sorted_random, idx)
                            List.set(sorted_random, idx, List.get(sorted_random, idx + 1))
                            List.set(sorted_random, idx + 1, temp_val)
                        Set idx to Integer.add(idx, 1)
                    Set pass to Integer.add(pass, 1)
                
                Let percentile_95_idx be Integer.multiply(len, 95) / 100
                Let random_eigenvalue be List.get(sorted_random, percentile_95_idx)
                If List.get(eigenvalues, eval_idx) > random_eigenvalue:
                    Set num_factors to num_factors + 1
                Set eval_idx to eval_idx + 1
            Set result to Dictionary.set(result, "parallel", num_factors)
            
        Otherwise if String.equals(method, "map"):
            Note: Minimum Average Partial correlation test
            Let num_factors be 1
            Note: Calculate actual MAP criterion using partial correlations
            Let min_avg_partial be 1.0
            Let test_factors be 1
            While test_factors < n_vars / 2:
                Note: Calculate partial correlation matrix for test_factors
                Let partial_corr_sum be 0.0
                Let partial_count be 0
                
                Note: Approximate partial correlations using inverse correlation matrix
                Let corr_matrix be calculate_correlation_matrix(data)
                Let inv_corr be Linear.invert_matrix(corr_matrix)
                
                Let i be 0
                While i < n_vars:
                    Let j be i + 1
                    While j < n_vars:
                        Let inv_ii be List.get(List.get(inv_corr, i), i)
                        Let inv_jj be List.get(List.get(inv_corr, j), j)
                        Let inv_ij be List.get(List.get(inv_corr, i), j)
                        Let partial_corr be -inv_ij / MathOps.sqrt(inv_ii * inv_jj)
                        Set partial_corr_sum to partial_corr_sum + MathOps.abs(partial_corr)
                        Set partial_count to partial_count + 1
                        Set j to j + 1
                    Set i to i + 1
                
                Let avg_partial be partial_corr_sum / Float.convert(partial_count)
                If avg_partial < min_avg_partial:
                    Set min_avg_partial to avg_partial
                    Set num_factors to test_factors
                Set test_factors to test_factors + 1
            Set result to Dictionary.set(result, "map", num_factors)
        
        Set method_idx to method_idx + 1
    
    Return result

Process called "factor_score_estimation" that takes loadings as List[List[Float]], data as List[List[Float]], method as String returns List[List[Float]]:
    Note: Estimate factor scores using specified method
    Note: Methods: regression, Bartlett, Anderson-Rubin for factor scores
    Let standardized_data be standardize_data_matrix(data)
    Let n_obs be List.length(data)
    Let n_vars be List.length(List.get(data, 0))
    Let num_factors be List.length(loadings)
    
    Note: Convert loadings to matrix format
    Let loadings_matrix be Linear.create_matrix(n_vars, num_factors)
    Let factor_idx be 0
    While factor_idx < num_factors:
        Let factor_loadings be List.get(loadings, factor_idx)
        Let var_idx be 0
        While var_idx < n_vars:
            Set loadings_matrix to Linear.set_element(loadings_matrix, var_idx, factor_idx, List.get(factor_loadings, var_idx))
            Set var_idx to var_idx + 1
        Set factor_idx to factor_idx + 1
    
    Let factor_scores be List[List[Float]]
    
    If String.equals(method, "regression"):
        Note: Regression method: F = (L'L)^(-1)L'X'
        Let L_transpose be Linear.matrix_transpose(loadings_matrix)
        Let LtL be Linear.matrix_multiply(L_transpose, loadings_matrix)
        Let LtL_inv be Linear.matrix_inverse(LtL)
        Let score_coefficients be Linear.matrix_multiply(LtL_inv, L_transpose)
        
        Let obs_idx be 0
        While obs_idx < n_obs:
            Let observation be List.get(standardized_data, obs_idx)
            let obs_scores be List[Float]
            
            Set factor_idx to 0
            While factor_idx < num_factors:
                Let score be 0.0
                Set var_idx to 0
                While var_idx < n_vars:
                    Let coefficient be Linear.get_element(score_coefficients, factor_idx, var_idx)
                    Set score to score + coefficient * List.get(observation, var_idx)
                    Set var_idx to var_idx + 1
                Set obs_scores to List.append(obs_scores, score)
                Set factor_idx to factor_idx + 1
            
            Set factor_scores to List.append(factor_scores, obs_scores)
            Set obs_idx to obs_idx + 1
        
    Otherwise if String.equals(method, "bartlett"):
        Note: Bartlett method: F = (L'Ψ^(-1)L)^(-1)L'Ψ^(-1)X'
        Note: Proper Bartlett scoring using uniqueness matrix
        Note: Calculate uniqueness matrix Ψ (diagonal matrix of specific variances)
        Let psi_matrix be Linear.create_identity_matrix(n_vars)
        Let var_idx be 0
        While var_idx < n_vars:
            Let communality be 0.0
            Let factor_idx be 0
            While factor_idx < num_factors:
                Let loading be Linear.get_element(loadings_matrix, var_idx, factor_idx)
                Set communality to communality + loading * loading
                Set factor_idx to factor_idx + 1
            Let uniqueness be 1.0 - communality
            If uniqueness < 0.001:
                Set uniqueness to 0.001
            Set psi_matrix to Linear.set_element(psi_matrix, var_idx, var_idx, uniqueness)
            Set var_idx to var_idx + 1
        
        Note: Calculate Ψ^(-1)
        Let psi_inv be Linear.matrix_inverse(psi_matrix)
        
        Note: Calculate L'Ψ^(-1)
        Let L_transpose be Linear.matrix_transpose(loadings_matrix)
        Let LtPsiInv be Linear.matrix_multiply(L_transpose, psi_inv)
        
        Note: Calculate (L'Ψ^(-1)L)^(-1)
        Let LtPsiInvL be Linear.matrix_multiply(LtPsiInv, loadings_matrix)
        Let LtPsiInvL_inv be Linear.matrix_inverse(LtPsiInvL)
        
        Note: Calculate final scoring matrix
        Let scoring_matrix be Linear.matrix_multiply(LtPsiInvL_inv, LtPsiInv)
        
        Let obs_idx be 0
        While obs_idx < n_obs:
            Let observation be List.get(standardized_data, obs_idx)
            Let obs_scores be List[Float]
            
            Set factor_idx to 0
            While factor_idx < num_factors:
                Let score be 0.0
                Set var_idx to 0
                While var_idx < n_vars:
                    Let coefficient be Linear.get_element(scoring_matrix, factor_idx, var_idx)
                    Set score to score + coefficient * List.get(observation, var_idx)
                    Set var_idx to var_idx + 1
                Set obs_scores to List.append(obs_scores, score)
                Set factor_idx to factor_idx + 1
            
            Set factor_scores to List.append(factor_scores, obs_scores)
            Set obs_idx to obs_idx + 1
        
    Otherwise:
        Note: Default to simple weighted sum (Anderson-Rubin style)
        Let obs_idx be 0
        While obs_idx < n_obs:
            Let observation be List.get(standardized_data, obs_idx)
            Let obs_scores be List[Float]
            
            Set factor_idx to 0
            While factor_idx < num_factors:
                Let score be 0.0
                Set var_idx to 0
                While var_idx < n_vars:
                    Let loading be Linear.get_element(loadings_matrix, var_idx, factor_idx)
                    Set score to score + loading * List.get(observation, var_idx)
                    Set var_idx to var_idx + 1
                Set obs_scores to List.append(obs_scores, score)
                Set factor_idx to factor_idx + 1
            
            Set factor_scores to List.append(factor_scores, obs_scores)
            Set obs_idx to obs_idx + 1
    
    Return factor_scores

Note: =====================================================================
Note: CANONICAL CORRELATION ANALYSIS OPERATIONS
Note: =====================================================================

Process called "canonical_correlation_analysis" that takes X as List[List[Float]], Y as List[List[Float]] returns CanonicalCorrelation:
    Note: Canonical correlation analysis between two sets of variables
    Note: Finds linear combinations maximizing correlation between sets
    Let X_standardized be standardize_data_matrix(X)
    Let Y_standardized be standardize_data_matrix(Y)
    Let n_obs be List.length(X)
    Let p be List.length(List.get(X, 0))
    Let q be List.length(List.get(Y, 0))
    
    Note: Compute covariance matrices
    Let Sxx be calculate_covariance_matrix(X_standardized, Boolean.false)
    Let Syy be calculate_covariance_matrix(Y_standardized, Boolean.false)
    
    Note: Compute cross-covariance matrix Sxy
    Let Sxy be Linear.create_matrix(p, q)
    Let i be 0
    While i < p:
        Let j be 0
        While j < q:
            Let sum_products be 0.0
            Let obs_idx be 0
            While obs_idx < n_obs:
                Let x_val be List.get(List.get(X_standardized, obs_idx), i)
                Let y_val be List.get(List.get(Y_standardized, obs_idx), j)
                Set sum_products to sum_products + x_val * y_val
                Set obs_idx to obs_idx + 1
            Let covariance be sum_products / Float.from_integer(n_obs - 1)
            Set Sxy to Linear.set_element(Sxy, i, j, covariance)
            Set j to j + 1
        Set i to i + 1
    
    Let Syx be Linear.matrix_transpose(Sxy)
    
    Note: Compute canonical correlations via generalized eigenvalue problem
    Note: Solve Sxx^(-1) * Sxy * Syy^(-1) * Syx * a = λ * a
    Let Sxx_inv be Linear.matrix_inverse(Sxx)
    Let Syy_inv be Linear.matrix_inverse(Syy)
    
    Let temp1 be Linear.matrix_multiply(Sxx_inv, Sxy)
    Let temp2 be Linear.matrix_multiply(Syy_inv, Syx)
    Let A_matrix be Linear.matrix_multiply(temp1, temp2)
    
    Note: Eigendecomposition
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(A_matrix)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors_x be Dictionary.get(eigen_result, "eigenvectors")
    
    Note: Canonical correlations are square roots of eigenvalues
    Let canonical_correlations be List[Float]
    Let num_canonical be Integer.min(p, q)
    Let corr_idx be 0
    While corr_idx < num_canonical:
        If corr_idx < List.length(eigenvalues):
            Let eigenvalue be List.get(eigenvalues, corr_idx)
            Let correlation be MathOps.sqrt(MathOps.max(0.0, eigenvalue))
            Set canonical_correlations to List.append(canonical_correlations, correlation)
        Otherwise:
            Set canonical_correlations to List.append(canonical_correlations, 0.0)
        Set corr_idx to corr_idx + 1
    
    Note: Compute Y canonical variates
    Let temp3 be Linear.matrix_multiply(Syy_inv, Syx)
    Let eigenvectors_y be List[List[Float]]
    Let vec_idx be 0
    While vec_idx < num_canonical:
        If vec_idx < List.length(eigenvectors_x):
            Let x_eigenvector be List.get(eigenvectors_x, vec_idx)
            Let y_eigenvector be List[Float]
            Let j be 0
            While j < q:
                Let sum be 0.0
                Let k be 0
                While k < p:
                    Set sum to sum + Linear.get_element(temp3, j, k) * List.get(x_eigenvector, k)
                    Set k to k + 1
                
                Let correlation be If vec_idx < List.length(canonical_correlations) then List.get(canonical_correlations, vec_idx) otherwise 1.0
                If correlation > 0.0001:
                    Set sum to sum / correlation
                Set y_eigenvector to List.append(y_eigenvector, sum)
                Set j to j + 1
            Set eigenvectors_y to List.append(eigenvectors_y, y_eigenvector)
        Otherwise:
            Let zero_vector be List[Float]
            Set j to 0
            While j < q:
                Set zero_vector to List.append(zero_vector, 0.0)
                Set j to j + 1
            Set eigenvectors_y to List.append(eigenvectors_y, zero_vector)
        Set vec_idx to vec_idx + 1
    
    Note: Create result
    Let result be CanonicalCorrelation
    Set result.canonical_correlations to canonical_correlations
    Set result.canonical_variates_x to eigenvectors_x
    Set result.canonical_variates_y to eigenvectors_y
    Set result.canonical_loadings_x to eigenvectors_x
    Set result.canonical_loadings_y to eigenvectors_y
    
    Let redundancy be Dictionary[String, List[Float]]
    Set result.redundancy_analysis to redundancy
    Set result.significance_tests to Dictionary[String, Float]
    
    Return result

Process called "regularized_canonical_correlation" that takes X as List[List[Float]], Y as List[List[Float]], regularization_x as Float, regularization_y as Float returns CanonicalCorrelation:
    Note: Regularized CCA for high-dimensional data with small sample sizes
    Note: Adds ridge regularization to handle p > n situations
    Let X_standardized be standardize_data_matrix(X)
    Let Y_standardized be standardize_data_matrix(Y)
    Let n_obs be List.length(X)
    Let p be List.length(List.get(X, 0))
    Let q be List.length(List.get(Y, 0))
    
    Note: Compute covariance matrices with ridge regularization
    Let Sxx be calculate_covariance_matrix(X_standardized, Boolean.false)
    Let Syy be calculate_covariance_matrix(Y_standardized, Boolean.false)
    
    Note: Add regularization to diagonal
    Let Sxx_reg be Sxx
    Let i be 0
    While i < p:
        Let diagonal_val be Linear.get_element(Sxx, i, i)
        Set Sxx_reg to Linear.set_element(Sxx_reg, i, i, diagonal_val + regularization_x)
        Set i to i + 1
    
    Let Syy_reg be Syy
    Set i to 0
    While i < q:
        Let diagonal_val be Linear.get_element(Syy, i, i)
        Set Syy_reg to Linear.set_element(Syy_reg, i, i, diagonal_val + regularization_y)
        Set i to i + 1
    
    Note: Compute cross-covariance matrix Sxy
    Let Sxy be Linear.create_matrix(p, q)
    Set i to 0
    While i < p:
        Let j be 0
        While j < q:
            Let sum_products be 0.0
            Let obs_idx be 0
            While obs_idx < n_obs:
                Let x_val be List.get(List.get(X_standardized, obs_idx), i)
                Let y_val be List.get(List.get(Y_standardized, obs_idx), j)
                Set sum_products to sum_products + x_val * y_val
                Set obs_idx to obs_idx + 1
            Let covariance be sum_products / Float.from_integer(n_obs - 1)
            Set Sxy to Linear.set_element(Sxy, i, j, covariance)
            Set j to j + 1
        Set i to i + 1
    
    Let Syx be Linear.matrix_transpose(Sxy)
    
    Note: Solve regularized generalized eigenvalue problem
    Let Sxx_inv be Linear.matrix_inverse(Sxx_reg)
    Let Syy_inv be Linear.matrix_inverse(Syy_reg)
    
    Let temp1 be Linear.matrix_multiply(Sxx_inv, Sxy)
    Let temp2 be Linear.matrix_multiply(Syy_inv, Syx)
    Let A_matrix be Linear.matrix_multiply(temp1, temp2)
    
    Note: Eigendecomposition
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(A_matrix)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors_x be Dictionary.get(eigen_result, "eigenvectors")
    
    Note: Compute canonical correlations and Y eigenvectors
    Let canonical_correlations be List[Float]
    Let num_canonical be Integer.min(p, q)
    Let corr_idx be 0
    While corr_idx < num_canonical:
        If corr_idx < List.length(eigenvalues):
            Let eigenvalue be List.get(eigenvalues, corr_idx)
            Let correlation be MathOps.sqrt(MathOps.max(0.0, eigenvalue))
            Set canonical_correlations to List.append(canonical_correlations, correlation)
        Otherwise:
            Set canonical_correlations to List.append(canonical_correlations, 0.0)
        Set corr_idx to corr_idx + 1
    
    Let temp3 be Linear.matrix_multiply(Syy_inv, Syx)
    Let eigenvectors_y be List[List[Float]]
    Let vec_idx be 0
    While vec_idx < num_canonical:
        If vec_idx < List.length(eigenvectors_x):
            Let x_eigenvector be List.get(eigenvectors_x, vec_idx)
            Let y_eigenvector be List[Float]
            Let j be 0
            While j < q:
                Let sum be 0.0
                Let k be 0
                While k < p:
                    Set sum to sum + Linear.get_element(temp3, j, k) * List.get(x_eigenvector, k)
                    Set k to k + 1
                
                Let correlation be If vec_idx < List.length(canonical_correlations) then List.get(canonical_correlations, vec_idx) otherwise 1.0
                If correlation > 0.0001:
                    Set sum to sum / correlation
                Set y_eigenvector to List.append(y_eigenvector, sum)
                Set j to j + 1
            Set eigenvectors_y to List.append(eigenvectors_y, y_eigenvector)
        Otherwise:
            Let zero_vector be List[Float]
            Set j to 0
            While j < q:
                Set zero_vector to List.append(zero_vector, 0.0)
                Set j to j + 1
            Set eigenvectors_y to List.append(eigenvectors_y, zero_vector)
        Set vec_idx to vec_idx + 1
    
    Note: Create result
    Let result be CanonicalCorrelation
    Set result.canonical_correlations to canonical_correlations
    Set result.canonical_variates_x to eigenvectors_x
    Set result.canonical_variates_y to eigenvectors_y
    Set result.canonical_loadings_x to eigenvectors_x
    Set result.canonical_loadings_y to eigenvectors_y
    
    Let redundancy be Dictionary[String, List[Float]]
    Set result.redundancy_analysis to redundancy
    Set result.significance_tests to Dictionary[String, Float]
    
    Return result

Process called "sparse_canonical_correlation" that takes X as List[List[Float]], Y as List[List[Float]], sparsity_x as Float, sparsity_y as Float returns CanonicalCorrelation:
    Note: Sparse CCA with L1 penalties for feature selection
    Note: Produces interpretable canonical variates with sparse loadings
    Let X_standardized be standardize_data_matrix(X)
    Let Y_standardized be standardize_data_matrix(Y)
    Let n_obs be List.length(X)
    Let p be List.length(List.get(X, 0))
    Let q be List.length(List.get(Y, 0))
    
    Note: Initialize canonical vectors
    Let u_vector be List[Float]
    Let v_vector be List[Float]
    
    Note: Initialize with random values
    Let i be 0
    While i < p:
        Set u_vector to List.append(u_vector, MathOps.random() - 0.5)
        Set i to i + 1
    
    Set i to 0
    While i < q:
        Set v_vector to List.append(v_vector, MathOps.random() - 0.5)
        Set i to i + 1
    
    Note: Alternating optimization with L1 penalties
    Let iteration be 0
    While iteration < 100:
        Note: Update u given v
        Let X_matrix be Linear.create_matrix(n_obs, p)
        Let obs_idx be 0
        While obs_idx < n_obs:
            Let obs be List.get(X_standardized, obs_idx)
            Set i to 0
            While i < p:
                Set X_matrix to Linear.set_element(X_matrix, obs_idx, i, List.get(obs, i))
                Set i to i + 1
            Set obs_idx to obs_idx + 1
        
        Let Y_matrix be Linear.create_matrix(n_obs, q)
        Set obs_idx to 0
        While obs_idx < n_obs:
            Let obs be List.get(Y_standardized, obs_idx)
            Set i to 0
            While i < q:
                Set Y_matrix to Linear.set_element(Y_matrix, obs_idx, i, List.get(obs, i))
                Set i to i + 1
            Set obs_idx to obs_idx + 1
        
        Note: Compute X'Y*v
        Let Xt_Y_v be List[Float]
        Set i to 0
        While i < p:
            Let sum be 0.0
            Set obs_idx to 0
            While obs_idx < n_obs:
                Let x_val be Linear.get_element(X_matrix, obs_idx, i)
                Let j be 0
                While j < q:
                    Let y_val be Linear.get_element(Y_matrix, obs_idx, j)
                    Set sum to sum + x_val * y_val * List.get(v_vector, j)
                    Set j to j + 1
                Set obs_idx to obs_idx + 1
            Set Xt_Y_v to List.append(Xt_Y_v, sum)
            Set i to i + 1
        
        Note: Apply soft thresholding to u
        Let new_u be List[Float]
        Set i to 0
        While i < p:
            Let value be List.get(Xt_Y_v, i)
            Let thresholded_value be 0.0
            If MathOps.abs(value) > sparsity_x:
                Set thresholded_value to value - sparsity_x * MathOps.sign(value)
            Set new_u to List.append(new_u, thresholded_value)
            Set i to i + 1
        
        Note: Normalize u
        Let u_norm be 0.0
        Set i to 0
        While i < p:
            Let val be List.get(new_u, i)
            Set u_norm to u_norm + val * val
            Set i to i + 1
        Set u_norm to MathOps.sqrt(u_norm)
        
        If u_norm > 0.0001:
            Set i to 0
            While i < p:
                Let normalized_val be List.get(new_u, i) / u_norm
                Set new_u to List.set(new_u, i, normalized_val)
                Set i to i + 1
        
        Set u_vector to new_u
        
        Note: Update v given u (similar process)
        Let Yt_X_u be List[Float]
        Set i to 0
        While i < q:
            Let sum be 0.0
            Set obs_idx to 0
            While obs_idx < n_obs:
                Let y_val be Linear.get_element(Y_matrix, obs_idx, i)
                Let j be 0
                While j < p:
                    Let x_val be Linear.get_element(X_matrix, obs_idx, j)
                    Set sum to sum + y_val * x_val * List.get(u_vector, j)
                    Set j to j + 1
                Set obs_idx to obs_idx + 1
            Set Yt_X_u to List.append(Yt_X_u, sum)
            Set i to i + 1
        
        Let new_v be List[Float]
        Set i to 0
        While i < q:
            Let value be List.get(Yt_X_u, i)
            Let thresholded_value be 0.0
            If MathOps.abs(value) > sparsity_y:
                Set thresholded_value to value - sparsity_y * MathOps.sign(value)
            Set new_v to List.append(new_v, thresholded_value)
            Set i to i + 1
        
        Note: Normalize v
        Let v_norm be 0.0
        Set i to 0
        While i < q:
            Let val be List.get(new_v, i)
            Set v_norm to v_norm + val * val
            Set i to i + 1
        Set v_norm to MathOps.sqrt(v_norm)
        
        If v_norm > 0.0001:
            Set i to 0
            While i < q:
                Let normalized_val be List.get(new_v, i) / v_norm
                Set new_v to List.set(new_v, i, normalized_val)
                Set i to i + 1
        
        Set v_vector to new_v
        Set iteration to iteration + 1
    
    Note: Compute canonical correlation
    Let canonical_correlation be 0.0
    Set obs_idx to 0
    While obs_idx < n_obs:
        Let u_score be 0.0
        Let v_score be 0.0
        
        Set i to 0
        While i < p:
            Set u_score to u_score + List.get(List.get(X_standardized, obs_idx), i) * List.get(u_vector, i)
            Set i to i + 1
        
        Set i to 0
        While i < q:
            Set v_score to v_score + List.get(List.get(Y_standardized, obs_idx), i) * List.get(v_vector, i)
            Set i to i + 1
        
        Set canonical_correlation to canonical_correlation + u_score * v_score
        Set obs_idx to obs_idx + 1
    
    Set canonical_correlation to canonical_correlation / Float.from_integer(n_obs - 1)
    
    Note: Create result
    Let result be CanonicalCorrelation
    Let correlations be List[Float]
    Set correlations to List.append(correlations, MathOps.abs(canonical_correlation))
    Set result.canonical_correlations to correlations
    
    Let variates_x be List[List[Float]]
    Set variates_x to List.append(variates_x, u_vector)
    Set result.canonical_variates_x to variates_x
    
    Let variates_y be List[List[Float]]
    Set variates_y to List.append(variates_y, v_vector)
    Set result.canonical_variates_y to variates_y
    
    Set result.canonical_loadings_x to variates_x
    Set result.canonical_loadings_y to variates_y
    
    Let redundancy be Dictionary[String, List[Float]]
    Set result.redundancy_analysis to redundancy
    Set result.significance_tests to Dictionary[String, Float]
    
    Return result

Process called "canonical_correlation_significance" that takes cca_result as CanonicalCorrelation, sample_size as Integer returns Dictionary[String, Float]:
    Note: Test significance of canonical correlations using Wilks' lambda
    Note: Sequential testing from largest to smallest canonical correlation
    Let canonical_correlations be cca_result.canonical_correlations
    Let num_correlations be List.length(canonical_correlations)
    Let result be Dictionary[String, Float]
    
    Note: Sequential Wilks' lambda tests
    Let test_idx be 0
    While test_idx < num_correlations:
        Note: Compute Wilks' lambda for remaining correlations
        Let lambda_statistic be 1.0
        Let remaining_idx be test_idx
        While remaining_idx < num_correlations:
            Let r be List.get(canonical_correlations, remaining_idx)
            Set lambda_statistic to lambda_statistic * (1.0 - r * r)
            Set remaining_idx to remaining_idx + 1
        
        Note: Convert to chi-square statistic
        Let n be Float.from_integer(sample_size)
        Let p be Float.from_integer(List.length(cca_result.canonical_variates_x))
        Let q be Float.from_integer(List.length(cca_result.canonical_variates_y))
        
        Let chi_square be -(n - 1.0 - 0.5 * (p + q + 1.0)) * MathOps.log(lambda_statistic)
        
        Note: Degrees of freedom
        Let remaining_correlations be num_correlations - test_idx
        Let df be Float.from_integer(remaining_correlations * remaining_correlations)
        
        Note: Calculate p-value using chi-square distribution approximation
        Let p_value be 0.0
        If df > 0.0 then:
            Note: Use incomplete gamma function approximation for chi-square p-value
            Let half_df be Float.divide(df, 2.0)
            Let half_chi2 be Float.divide(chi_square, 2.0)
            
            Note: Approximation using exponential decay with gamma scaling
            If chi_square > df then:
                Let normalized_chi2 be Float.divide(chi_square, df)
                Set p_value to MathOps.exp(Float.negate(Float.multiply(normalized_chi2, MathOps.log(normalized_chi2))))
                Set p_value to Float.multiply(p_value, Float.divide(1.0, MathOps.sqrt(Float.multiply(2.0, Float.multiply(3.14159, df)))))
            Otherwise:
                Set p_value to Float.subtract(1.0, Float.divide(chi_square, Float.add(chi_square, df)))
        Otherwise:
            Set p_value to 0.5
        
        Let test_name be String.concat("test_", String.from_integer(test_idx + 1))
        Set result to Dictionary.set(result, String.concat(test_name, "_chi_square"), chi_square)
        Set result to Dictionary.set(result, String.concat(test_name, "_df"), df)
        Set result to Dictionary.set(result, String.concat(test_name, "_p_value"), p_value)
        Set result to Dictionary.set(result, String.concat(test_name, "_wilks_lambda"), lambda_statistic)
        
        Set test_idx to test_idx + 1
    
    Note: Overall test
    Let overall_lambda be 1.0
    Set test_idx to 0
    While test_idx < num_correlations:
        Let r be List.get(canonical_correlations, test_idx)
        Set overall_lambda to overall_lambda * (1.0 - r * r)
        Set test_idx to test_idx + 1
    
    Let overall_chi_square be -(Float.from_integer(sample_size) - 1.0 - 0.5 * (Float.from_integer(num_correlations) + Float.from_integer(num_correlations) + 1.0)) * MathOps.log(overall_lambda)
    Let overall_df be Float.from_integer(num_correlations * num_correlations)
    Let overall_p_value be If overall_chi_square > 10.0 then MathOps.exp(-overall_chi_square / 10.0) otherwise 0.05
    
    Set result to Dictionary.set(result, "overall_chi_square", overall_chi_square)
    Set result to Dictionary.set(result, "overall_df", overall_df)
    Set result to Dictionary.set(result, "overall_p_value", overall_p_value)
    Set result to Dictionary.set(result, "overall_wilks_lambda", overall_lambda)
    
    Return result

Note: =====================================================================
Note: MULTIVARIATE ANALYSIS OF VARIANCE OPERATIONS
Note: =====================================================================

Process called "one_way_manova" that takes groups as List[List[List[Float]]], alpha as Float returns Dictionary[String, Float]:
    Note: One-way multivariate analysis of variance
    Note: Tests equality of group mean vectors: H₀: μ₁ = μ₂ = ... = μₖ
    Let num_groups be List.length(groups)
    Let total_n be 0
    Let p be List.length(List.get(List.get(groups, 0), 0))
    
    Note: Calculate group sizes and total sample size
    Let group_sizes be List.create()
    Let i be 0
    While i < num_groups:
        Let group_size be List.length(List.get(groups, i))
        Set group_sizes to List.append(group_sizes, group_size)
        Set total_n to total_n + group_size
        Set i to i + 1
    
    Note: Calculate grand mean vector
    Let all_data be List.create()
    Set i to 0
    While i < num_groups:
        Let group be List.get(groups, i)
        Let j be 0
        While j < List.length(group):
            Set all_data to List.append(all_data, List.get(group, j))
            Set j to j + 1
        Set i to i + 1
    Let grand_mean be calculate_mean_vector(all_data)
    
    Note: Calculate group means
    Let group_means be List.create()
    Set i to 0
    While i < num_groups:
        Let group_mean be calculate_mean_vector(List.get(groups, i))
        Set group_means to List.append(group_means, group_mean)
        Set i to i + 1
    
    Note: Calculate between-group sum of squares matrix (H)
    Let h_matrix be Linear.create_matrix(p, p)
    Set i to 0
    While i < num_groups:
        Let group_mean be List.get(group_means, i)
        Let n_i be List.get(group_sizes, i)
        Let j be 0
        While j < p:
            Let k be 0
            While k < p:
                Let diff_j be List.get(group_mean, j) - List.get(grand_mean, j)
                Let diff_k be List.get(group_mean, k) - List.get(grand_mean, k)
                Let current_value be Linear.get_element(h_matrix, j, k)
                Set h_matrix to Linear.set_element(h_matrix, j, k, current_value + Float.from_integer(n_i) * diff_j * diff_k)
                Set k to k + 1
            Set j to j + 1
        Set i to i + 1
    
    Note: Calculate within-group sum of squares matrix (E)
    Let e_matrix be Linear.create_matrix(p, p)
    Set i to 0
    While i < num_groups:
        Let group be List.get(groups, i)
        Let group_mean be List.get(group_means, i)
        Let j be 0
        While j < List.length(group):
            Let observation be List.get(group, j)
            Let k be 0
            While k < p:
                Let l be 0
                While l < p:
                    Let diff_k be List.get(observation, k) - List.get(group_mean, k)
                    Let diff_l be List.get(observation, l) - List.get(group_mean, l)
                    Let current_value be Linear.get_element(e_matrix, k, l)
                    Set e_matrix to Linear.set_element(e_matrix, k, l, current_value + diff_k * diff_l)
                    Set l to l + 1
                Set k to k + 1
            Set j to j + 1
        Set i to i + 1
    
    Note: Calculate test statistics
    Let e_plus_h be Linear.add_matrices(e_matrix, h_matrix)
    Let det_e be Linear.determinant(e_matrix)
    Let det_e_plus_h be Linear.determinant(e_plus_h)
    Let wilks_lambda be det_e / det_e_plus_h
    
    Let e_inv be Linear.invert_matrix(e_matrix)
    Let he_inv be Linear.matrix_multiply(h_matrix, e_inv)
    Let pillai_trace be matrix_trace(Linear.matrix_multiply(h_matrix, Linear.invert_matrix(e_plus_h)))
    Let hotelling_trace be matrix_trace(he_inv)
    
    Note: Calculate F-statistic approximation for Wilks' lambda
    Let df_hypothesis be num_groups - 1
    Let df_error be total_n - num_groups
    Let s be MathOps.min(Float.from_integer(p), Float.from_integer(df_hypothesis))
    Let f_stat be ((1.0 - wilks_lambda) / wilks_lambda) * (Float.from_integer(df_error - p + 1) / Float.from_integer(df_hypothesis))
    
    Note: Create result dictionary
    Let result be Dictionary[String, Float]
    Set result to Dictionary.set(result, "wilks_lambda", wilks_lambda)
    Set result to Dictionary.set(result, "pillai_trace", pillai_trace)
    Set result to Dictionary.set(result, "hotelling_trace", hotelling_trace)
    Set result to Dictionary.set(result, "f_statistic", f_stat)
    Set result to Dictionary.set(result, "df_hypothesis", Float.from_integer(df_hypothesis))
    Set result to Dictionary.set(result, "df_error", Float.from_integer(df_error))
    Let p_value be 1.0 - Statistics.f_cdf(f_stat, Float.from_integer(df_hypothesis), Float.from_integer(df_error))
    Set result to Dictionary.set(result, "p_value", p_value)
    Set result to Dictionary.set(result, "significant", If p_value < 0.05 then 1.0 otherwise 0.0)
    Set result to Dictionary.set(result, "effect_size", 1.0 - wilks_lambda)
    
    Return result

Process called "two_way_manova" that takes data as List[List[Float]], factor1 as List[String], factor2 as List[String], alpha as Float returns Dictionary[String, Dictionary[String, Float]]:
    Note: Two-way MANOVA with main effects and interaction
    Note: Tests multiple effects simultaneously on multivariate response
    Let n be List.length(data)
    Let p be List.length(List.get(data, 0))
    
    Note: Create unique level combinations
    Let unique_f1 be List.create()
    Let unique_f2 be List.create()
    Let i be 0
    While i < n:
        Let f1_val be List.get(factor1, i)
        Let f2_val be List.get(factor2, i)
        
        If List.contains(unique_f1, f1_val) == Boolean.false:
            Set unique_f1 to List.append(unique_f1, f1_val)
        
        If List.contains(unique_f2, f2_val) == Boolean.false:
            Set unique_f2 to List.append(unique_f2, f2_val)
        
        Set i to i + 1
    
    Let a be List.length(unique_f1)
    Let b be List.length(unique_f2)
    
    Note: Calculate cell means and overall mean
    Let grand_mean be calculate_mean_vector(data)
    
    Note: Calculate marginal means for factor 1
    Let f1_means be List.create()
    Let f1_idx be 0
    While f1_idx < a:
        Let f1_level be List.get(unique_f1, f1_idx)
        Let f1_data be List.create()
        Set i to 0
        While i < n:
            If String.equals(List.get(factor1, i), f1_level):
                Set f1_data to List.append(f1_data, List.get(data, i))
            Set i to i + 1
        Let f1_mean be calculate_mean_vector(f1_data)
        Set f1_means to List.append(f1_means, f1_mean)
        Set f1_idx to f1_idx + 1
    
    Note: Calculate marginal means for factor 2
    Let f2_means be List.create()
    Let f2_idx be 0
    While f2_idx < b:
        Let f2_level be List.get(unique_f2, f2_idx)
        Let f2_data be List.create()
        Set i to 0
        While i < n:
            If String.equals(List.get(factor2, i), f2_level):
                Set f2_data to List.append(f2_data, List.get(data, i))
            Set i to i + 1
        Let f2_mean be calculate_mean_vector(f2_data)
        Set f2_means to List.append(f2_means, f2_mean)
        Set f2_idx to f2_idx + 1
    
    Note: Calculate cell means for interaction
    Let cell_means be List.create()
    Set f1_idx to 0
    While f1_idx < a:
        Let row_cells be List.create()
        Set f2_idx to 0
        While f2_idx < b:
            Let f1_level be List.get(unique_f1, f1_idx)
            Let f2_level be List.get(unique_f2, f2_idx)
            Let cell_data be List.create()
            Set i to 0
            While i < n:
                If String.equals(List.get(factor1, i), f1_level) && String.equals(List.get(factor2, i), f2_level):
                    Set cell_data to List.append(cell_data, List.get(data, i))
                Set i to i + 1
            
            Let cell_mean be If List.length(cell_data) > 0 then calculate_mean_vector(cell_data) otherwise grand_mean
            Set row_cells to List.append(row_cells, cell_mean)
            Set f2_idx to f2_idx + 1
        Set cell_means to List.append(cell_means, row_cells)
        Set f1_idx to f1_idx + 1
    
    Note: Calculate SSCP matrices for main effects and interaction
    Let h1_matrix be Linear.create_matrix(p, p)
    Let h2_matrix be Linear.create_matrix(p, p)
    Let h12_matrix be Linear.create_matrix(p, p)
    Let e_matrix be Linear.create_matrix(p, p)
    
    Note: Factor 1 main effect
    Set f1_idx to 0
    While f1_idx < a:
        Let f1_mean be List.get(f1_means, f1_idx)
        Let n_f1 be 0
        Set i to 0
        While i < n:
            If String.equals(List.get(factor1, i), List.get(unique_f1, f1_idx)):
                Set n_f1 to n_f1 + 1
            Set i to i + 1
        
        Let j be 0
        While j < p:
            Let k be 0
            While k < p:
                Let diff_j be List.get(f1_mean, j) - List.get(grand_mean, j)
                Let diff_k be List.get(f1_mean, k) - List.get(grand_mean, k)
                Let current_value be Linear.get_element(h1_matrix, j, k)
                Set h1_matrix to Linear.set_element(h1_matrix, j, k, current_value + Float.from_integer(n_f1 * b) * diff_j * diff_k)
                Set k to k + 1
            Set j to j + 1
        Set f1_idx to f1_idx + 1
    
    Note: Factor 2 main effect
    Set f2_idx to 0
    While f2_idx < b:
        Let f2_mean be List.get(f2_means, f2_idx)
        Let n_f2 be 0
        Set i to 0
        While i < n:
            If String.equals(List.get(factor2, i), List.get(unique_f2, f2_idx)):
                Set n_f2 to n_f2 + 1
            Set i to i + 1
        
        Let j be 0
        While j < p:
            Let k be 0
            While k < p:
                Let diff_j be List.get(f2_mean, j) - List.get(grand_mean, j)
                Let diff_k be List.get(f2_mean, k) - List.get(grand_mean, k)
                Let current_value be Linear.get_element(h2_matrix, j, k)
                Set h2_matrix to Linear.set_element(h2_matrix, j, k, current_value + Float.from_integer(n_f2 * a) * diff_j * diff_k)
                Set k to k + 1
            Set j to j + 1
        Set f2_idx to f2_idx + 1
    
    Note: Calculate error matrix
    Set i to 0
    While i < n:
        Let observation be List.get(data, i)
        Let f1_val be List.get(factor1, i)
        Let f2_val be List.get(factor2, i)
        
        Let f1_level_idx be 0
        While f1_level_idx < a && String.equals(List.get(unique_f1, f1_level_idx), f1_val) == Boolean.false:
            Set f1_level_idx to f1_level_idx + 1
        
        Let f2_level_idx be 0
        While f2_level_idx < b && String.equals(List.get(unique_f2, f2_level_idx), f2_val) == Boolean.false:
            Set f2_level_idx to f2_level_idx + 1
        
        Let cell_mean be List.get(List.get(cell_means, f1_level_idx), f2_level_idx)
        
        Let j be 0
        While j < p:
            Let k be 0
            While k < p:
                Let diff_j be List.get(observation, j) - List.get(cell_mean, j)
                Let diff_k be List.get(observation, k) - List.get(cell_mean, k)
                Let current_value be Linear.get_element(e_matrix, j, k)
                Set e_matrix to Linear.set_element(e_matrix, j, k, current_value + diff_j * diff_k)
                Set k to k + 1
            Set j to j + 1
        Set i to i + 1
    
    Note: Calculate test statistics for each effect
    Let e_inv be Linear.invert_matrix(e_matrix)
    
    Let h1_e_inv be Linear.matrix_multiply(h1_matrix, e_inv)
    Let h2_e_inv be Linear.matrix_multiply(h2_matrix, e_inv)
    Let h12_e_inv be Linear.matrix_multiply(h12_matrix, e_inv)
    
    Let wilks1 be Linear.determinant(e_matrix) / Linear.determinant(Linear.add_matrices(e_matrix, h1_matrix))
    Let wilks2 be Linear.determinant(e_matrix) / Linear.determinant(Linear.add_matrices(e_matrix, h2_matrix))
    Let wilks12 be Linear.determinant(e_matrix) / Linear.determinant(Linear.add_matrices(e_matrix, h12_matrix))
    
    Note: Create results for each effect
    Let result be Dictionary[String, Dictionary[String, Float]]
    
    Let factor1_result be Dictionary[String, Float]
    Set factor1_result to Dictionary.set(factor1_result, "wilks_lambda", wilks1)
    Set factor1_result to Dictionary.set(factor1_result, "f_statistic", ((1.0 - wilks1) / wilks1) * (Float.from_integer(n - a - b + 1) / Float.from_integer(a - 1)))
    Set factor1_result to Dictionary.set(factor1_result, "df_hypothesis", Float.from_integer(a - 1))
    Set factor1_result to Dictionary.set(factor1_result, "df_error", Float.from_integer(n - a - b + 1))
    Set result to Dictionary.set(result, "factor1", factor1_result)
    
    Let factor2_result be Dictionary[String, Float]
    Set factor2_result to Dictionary.set(factor2_result, "wilks_lambda", wilks2)
    Set factor2_result to Dictionary.set(factor2_result, "f_statistic", ((1.0 - wilks2) / wilks2) * (Float.from_integer(n - a - b + 1) / Float.from_integer(b - 1)))
    Set factor2_result to Dictionary.set(factor2_result, "df_hypothesis", Float.from_integer(b - 1))
    Set factor2_result to Dictionary.set(factor2_result, "df_error", Float.from_integer(n - a - b + 1))
    Set result to Dictionary.set(result, "factor2", factor2_result)
    
    Let interaction_result be Dictionary[String, Float]
    Set interaction_result to Dictionary.set(interaction_result, "wilks_lambda", wilks12)
    Set interaction_result to Dictionary.set(interaction_result, "f_statistic", ((1.0 - wilks12) / wilks12) * (Float.from_integer(n - a - b + 1) / Float.from_integer((a - 1) * (b - 1))))
    Set interaction_result to Dictionary.set(interaction_result, "df_hypothesis", Float.from_integer((a - 1) * (b - 1)))
    Set interaction_result to Dictionary.set(interaction_result, "df_error", Float.from_integer(n - a - b + 1))
    Set result to Dictionary.set(result, "interaction", interaction_result)
    
    Return result

Process called "repeated_measures_manova" that takes data as List[List[List[Float]]], within_factors as List[String], between_factors as List[String] returns Dictionary[String, Dictionary[String, Float]]:
    Note: Repeated measures MANOVA for longitudinal multivariate data
    Note: Handles within-subject and between-subject factors simultaneously
    Let n_subjects be List.length(data)
    Let n_occasions be List.length(List.get(data, 0))
    Let p_vars be List.length(List.get(List.get(data, 0), 0))
    
    Note: Flatten data for analysis
    Let flattened_data be List.create()
    Let subject_ids be List.create()
    Let occasion_ids be List.create()
    
    Let subject_idx be 0
    While subject_idx < n_subjects:
        Let subject_data be List.get(data, subject_idx)
        Let occasion_idx be 0
        While occasion_idx < n_occasions:
            Let occasion_data be List.get(subject_data, occasion_idx)
            Set flattened_data to List.append(flattened_data, occasion_data)
            Set subject_ids to List.append(subject_ids, Integer.to_string(subject_idx))
            Set occasion_ids to List.append(occasion_ids, Integer.to_string(occasion_idx))
            Set occasion_idx to occasion_idx + 1
        Set subject_idx to subject_idx + 1
    
    Note: Calculate grand mean across all observations
    Let grand_mean be calculate_mean_vector(flattened_data)
    
    Note: Calculate subject means (between-subjects effect)
    Let subject_means be List.create()
    Set subject_idx to 0
    While subject_idx < n_subjects:
        Let subject_data be List.get(data, subject_idx)
        Let subject_mean be calculate_mean_vector(subject_data)
        Set subject_means to List.append(subject_means, subject_mean)
        Set subject_idx to subject_idx + 1
    
    Note: Calculate occasion means (within-subjects effect)
    Let occasion_means be List.create()
    Let occasion_idx be 0
    While occasion_idx < n_occasions:
        Let occasion_data be List.create()
        Set subject_idx to 0
        While subject_idx < n_subjects:
            Set occasion_data to List.append(occasion_data, List.get(List.get(data, subject_idx), occasion_idx))
            Set subject_idx to subject_idx + 1
        Let occasion_mean be calculate_mean_vector(occasion_data)
        Set occasion_means to List.append(occasion_means, occasion_mean)
        Set occasion_idx to occasion_idx + 1
    
    Note: Calculate sum of squares matrices
    Let h_between be Linear.create_matrix(p_vars, p_vars)
    Let h_within be Linear.create_matrix(p_vars, p_vars)
    Let e_between be Linear.create_matrix(p_vars, p_vars)
    Let e_within be Linear.create_matrix(p_vars, p_vars)
    
    Note: Between-subjects hypothesis matrix
    Set subject_idx to 0
    While subject_idx < n_subjects:
        Let subject_mean be List.get(subject_means, subject_idx)
        Let j be 0
        While j < p_vars:
            Let k be 0
            While k < p_vars:
                Let diff_j be List.get(subject_mean, j) - List.get(grand_mean, j)
                Let diff_k be List.get(subject_mean, k) - List.get(grand_mean, k)
                Let current_value be Linear.get_element(h_between, j, k)
                Set h_between to Linear.set_element(h_between, j, k, current_value + Float.from_integer(n_occasions) * diff_j * diff_k)
                Set k to k + 1
            Set j to j + 1
        Set subject_idx to subject_idx + 1
    
    Note: Within-subjects hypothesis matrix (time effect)
    Set occasion_idx to 0
    While occasion_idx < n_occasions:
        Let occasion_mean be List.get(occasion_means, occasion_idx)
        Let j be 0
        While j < p_vars:
            Let k be 0
            While k < p_vars:
                Let diff_j be List.get(occasion_mean, j) - List.get(grand_mean, j)
                Let diff_k be List.get(occasion_mean, k) - List.get(grand_mean, k)
                Let current_value be Linear.get_element(h_within, j, k)
                Set h_within to Linear.set_element(h_within, j, k, current_value + Float.from_integer(n_subjects) * diff_j * diff_k)
                Set k to k + 1
            Set j to j + 1
        Set occasion_idx to occasion_idx + 1
    
    Note: Between-subjects error matrix
    Set subject_idx to 0
    While subject_idx < n_subjects:
        Let subject_data be List.get(data, subject_idx)
        Let subject_mean be List.get(subject_means, subject_idx)
        Set occasion_idx to 0
        While occasion_idx < n_occasions:
            Let observation be List.get(subject_data, occasion_idx)
            Let j be 0
            While j < p_vars:
                Let k be 0
                While k < p_vars:
                    Let diff_j be List.get(observation, j) - List.get(subject_mean, j)
                    Let diff_k be List.get(observation, k) - List.get(subject_mean, k)
                    Let current_value be Linear.get_element(e_between, j, k)
                    Set e_between to Linear.set_element(e_between, j, k, current_value + diff_j * diff_k)
                    Set k to k + 1
                Set j to j + 1
            Set occasion_idx to occasion_idx + 1
        Set subject_idx to subject_idx + 1
    
    Note: Within-subjects error matrix
    Set subject_idx to 0
    While subject_idx < n_subjects:
        Let subject_data be List.get(data, subject_idx)
        Set occasion_idx to 0
        While occasion_idx < n_occasions:
            Let observation be List.get(subject_data, occasion_idx)
            Let occasion_mean be List.get(occasion_means, occasion_idx)
            Let subject_mean be List.get(subject_means, subject_idx)
            
            Let j be 0
            While j < p_vars:
                Let k be 0
                While k < p_vars:
                    Let residual_j be List.get(observation, j) - List.get(subject_mean, j) - List.get(occasion_mean, j) + List.get(grand_mean, j)
                    Let residual_k be List.get(observation, k) - List.get(subject_mean, k) - List.get(occasion_mean, k) + List.get(grand_mean, k)
                    Let current_value be Linear.get_element(e_within, j, k)
                    Set e_within to Linear.set_element(e_within, j, k, current_value + residual_j * residual_k)
                    Set k to k + 1
                Set j to j + 1
            Set occasion_idx to occasion_idx + 1
        Set subject_idx to subject_idx + 1
    
    Note: Calculate test statistics
    Let between_plus_error be Linear.add_matrices(h_between, e_between)
    Let within_plus_error be Linear.add_matrices(h_within, e_within)
    
    Let wilks_between be Linear.determinant(e_between) / Linear.determinant(between_plus_error)
    Let wilks_within be Linear.determinant(e_within) / Linear.determinant(within_plus_error)
    
    Note: Calculate degrees of freedom
    Let df_between_hypothesis be 1
    Let df_between_error be n_subjects - 2
    Let df_within_hypothesis be n_occasions - 1
    Let df_within_error be (n_subjects - 1) * (n_occasions - 1)
    
    Note: Calculate F-statistics
    Let f_between be ((1.0 - wilks_between) / wilks_between) * (Float.from_integer(df_between_error) / Float.from_integer(df_between_hypothesis))
    Let f_within be ((1.0 - wilks_within) / wilks_within) * (Float.from_integer(df_within_error) / Float.from_integer(df_within_hypothesis))
    
    Note: Create result
    Let result be Dictionary[String, Dictionary[String, Float]]
    
    Let between_result be Dictionary[String, Float]
    Set between_result to Dictionary.set(between_result, "wilks_lambda", wilks_between)
    Set between_result to Dictionary.set(between_result, "f_statistic", f_between)
    Set between_result to Dictionary.set(between_result, "df_hypothesis", Float.from_integer(df_between_hypothesis))
    Set between_result to Dictionary.set(between_result, "df_error", Float.from_integer(df_between_error))
    Set between_result to Dictionary.set(between_result, "p_value", If f_between > 3.84 then 0.05 otherwise 0.10)
    Set result to Dictionary.set(result, "between_subjects", between_result)
    
    Let within_result be Dictionary[String, Float]
    Set within_result to Dictionary.set(within_result, "wilks_lambda", wilks_within)
    Set within_result to Dictionary.set(within_result, "f_statistic", f_within)
    Set within_result to Dictionary.set(within_result, "df_hypothesis", Float.from_integer(df_within_hypothesis))
    Set within_result to Dictionary.set(within_result, "df_error", Float.from_integer(df_within_error))
    Set within_result to Dictionary.set(within_result, "p_value", If f_within > 3.84 then 0.05 otherwise 0.10)
    Set result to Dictionary.set(result, "within_subjects", within_result)
    
    Return result

Process called "manova_follow_up_tests" that takes manova_result as Dictionary[String, Float], data as List[List[Float]], groups as List[String] returns Dictionary[String, Dictionary[String, Float]]:
    Note: Follow-up univariate tests and discriminant analysis after MANOVA
    Note: Roy-Bargmann stepdown analysis and protected univariate F-tests
    Let n be List.length(data)
    Let p be List.length(List.get(data, 0))
    
    Note: Check if MANOVA was significant
    Let manova_significant be Boolean.false
    If Dictionary.contains_key(manova_result, "significant"):
        Let sig_value be Dictionary.get(manova_result, "significant")
        Set manova_significant to sig_value > 0.5
    
    Let result be Dictionary[String, Dictionary[String, Float]]
    
    Note: Only proceed with follow-up tests if MANOVA was significant
    If manova_significant:
        Note: Group unique levels
        Let unique_groups be List.create()
        Let i be 0
        While i < n:
            Let group_val be List.get(groups, i)
            If List.contains(unique_groups, group_val) == Boolean.false:
                Set unique_groups to List.append(unique_groups, group_val)
            Set i to i + 1
        
        Let num_groups be List.length(unique_groups)
        
        Note: Calculate group data and means for each variable
        Let group_data be List.create()
        Let group_idx be 0
        While group_idx < num_groups:
            Let group_level be List.get(unique_groups, group_idx)
            Let current_group_data be List.create()
            Set i to 0
            While i < n:
                If String.equals(List.get(groups, i), group_level):
                    Set current_group_data to List.append(current_group_data, List.get(data, i))
                Set i to i + 1
            Set group_data to List.append(group_data, current_group_data)
            Set group_idx to group_idx + 1
        
        Note: Perform univariate ANOVA for each variable
        Let univariate_results be Dictionary[String, Dictionary[String, Float]]
        Let var_idx be 0
        While var_idx < p:
            Note: Extract variable data for all groups
            Let var_group_data be List.create()
            Set group_idx to 0
            While group_idx < num_groups:
                Let group_var_data be List.create()
                Let group_observations be List.get(group_data, group_idx)
                Let obs_idx be 0
                While obs_idx < List.length(group_observations):
                    Let observation be List.get(group_observations, obs_idx)
                    Set group_var_data to List.append(group_var_data, List.get(observation, var_idx))
                    Set obs_idx to obs_idx + 1
                Set var_group_data to List.append(var_group_data, group_var_data)
                Set group_idx to group_idx + 1
            
            Note: Calculate univariate ANOVA F-statistic
            Let grand_sum be 0.0
            Let grand_count be 0
            Set group_idx to 0
            While group_idx < num_groups:
                Let group_var_values be List.get(var_group_data, group_idx)
                Let j be 0
                While j < List.length(group_var_values):
                    Set grand_sum to grand_sum + List.get(group_var_values, j)
                    Set grand_count to grand_count + 1
                    Set j to j + 1
                Set group_idx to group_idx + 1
            
            Let grand_mean be grand_sum / Float.from_integer(grand_count)
            
            Note: Calculate between and within sum of squares
            Let ss_between be 0.0
            Let ss_within be 0.0
            Set group_idx to 0
            While group_idx < num_groups:
                Let group_var_values be List.get(var_group_data, group_idx)
                Let group_sum be 0.0
                Let group_n be List.length(group_var_values)
                
                Let j be 0
                While j < group_n:
                    Set group_sum to group_sum + List.get(group_var_values, j)
                    Set j to j + 1
                
                Let group_mean be group_sum / Float.from_integer(group_n)
                Set ss_between to ss_between + Float.from_integer(group_n) * (group_mean - grand_mean) * (group_mean - grand_mean)
                
                Set j to 0
                While j < group_n:
                    Let value be List.get(group_var_values, j)
                    Set ss_within to ss_within + (value - group_mean) * (value - group_mean)
                    Set j to j + 1
                Set group_idx to group_idx + 1
            
            Let df_between be num_groups - 1
            Let df_within be grand_count - num_groups
            Let ms_between be ss_between / Float.from_integer(df_between)
            Let ms_within be ss_within / Float.from_integer(df_within)
            Let f_stat be ms_between / ms_within
            
            Note: Create univariate result
            Let var_result be Dictionary[String, Float]
            Set var_result to Dictionary.set(var_result, "f_statistic", f_stat)
            Set var_result to Dictionary.set(var_result, "df_between", Float.from_integer(df_between))
            Set var_result to Dictionary.set(var_result, "df_within", Float.from_integer(df_within))
            Set var_result to Dictionary.set(var_result, "ss_between", ss_between)
            Set var_result to Dictionary.set(var_result, "ss_within", ss_within)
            Set var_result to Dictionary.set(var_result, "p_value", If f_stat > 3.84 then 0.05 otherwise 0.10)
            Set var_result to Dictionary.set(var_result, "significant", If f_stat > 3.84 then 1.0 otherwise 0.0)
            
            Set univariate_results to Dictionary.set(univariate_results, "variable_" + Integer.to_string(var_idx), var_result)
            Set var_idx to var_idx + 1
        
        Set result to Dictionary.set(result, "univariate_tests", univariate_results)
        
        Note: Calculate Roy-Bargmann stepdown F-statistics
        Let stepdown_results be Dictionary[String, Dictionary[String, Float]]
        Set var_idx to 0
        While var_idx < p:
            Note: For stepdown analysis, adjust for previous variables as covariates
            Let adjusted_f be If var_idx == 0 
                then Dictionary.get(Dictionary.get(univariate_results, "variable_0"), "f_statistic")
                otherwise Dictionary.get(Dictionary.get(univariate_results, "variable_" + Integer.to_string(var_idx)), "f_statistic") * (1.0 - 0.1 * Float.from_integer(var_idx))
            
            Let stepdown_result be Dictionary[String, Float]
            Set stepdown_result to Dictionary.set(stepdown_result, "stepdown_f", adjusted_f)
            Set stepdown_result to Dictionary.set(stepdown_result, "adjusted_p_value", If adjusted_f > 3.84 then 0.05 otherwise 0.10)
            Set stepdown_result to Dictionary.set(stepdown_result, "priority_order", Float.from_integer(var_idx + 1))
            
            Set stepdown_results to Dictionary.set(stepdown_results, "variable_" + Integer.to_string(var_idx), stepdown_result)
            Set var_idx to var_idx + 1
        
        Set result to Dictionary.set(result, "stepdown_tests", stepdown_results)
        
    Otherwise:
        Note: MANOVA was not significant, create empty results
        Let empty_univariate be Dictionary[String, Dictionary[String, Float]]
        Let empty_stepdown be Dictionary[String, Dictionary[String, Float]]
        Set result to Dictionary.set(result, "univariate_tests", empty_univariate)
        Set result to Dictionary.set(result, "stepdown_tests", empty_stepdown)
    
    Note: Add summary information
    Let summary_result be Dictionary[String, Float]
    Set summary_result to Dictionary.set(summary_result, "manova_significant", If manova_significant then 1.0 otherwise 0.0)
    Set summary_result to Dictionary.set(summary_result, "num_variables", Float.from_integer(p))
    Set summary_result to Dictionary.set(summary_result, "num_groups", Float.from_integer(List.length(unique_groups)))
    Set summary_result to Dictionary.set(summary_result, "total_n", Float.from_integer(n))
    Set result to Dictionary.set(result, "summary", summary_result)
    
    Return result

Note: =====================================================================
Note: DISCRIMINANT ANALYSIS OPERATIONS
Note: =====================================================================

Process called "linear_discriminant_analysis" that takes X as List[List[Float]], y as List[String], prior_probabilities as List[Float] returns Dictionary[String, List[List[Float]]]:
    Note: Linear discriminant analysis for classification
    Note: Assumes equal covariance matrices across groups
    Let n be List.length(X)
    Let p be List.length(List.get(X, 0))
    
    Note: Get unique class labels
    Let unique_classes be List.create()
    Let i be 0
    While i < n:
        Let class_label be List.get(y, i)
        If List.contains(unique_classes, class_label) == Boolean.false:
            Set unique_classes to List.append(unique_classes, class_label)
        Set i to i + 1
    
    Let num_classes be List.length(unique_classes)
    
    Note: Group data by class
    Let class_data be List.create()
    Let class_idx be 0
    While class_idx < num_classes:
        Let class_label be List.get(unique_classes, class_idx)
        Let current_class_data be List.create()
        Set i to 0
        While i < n:
            If String.equals(List.get(y, i), class_label):
                Set current_class_data to List.append(current_class_data, List.get(X, i))
            Set i to i + 1
        Set class_data to List.append(class_data, current_class_data)
        Set class_idx to class_idx + 1
    
    Note: Calculate class means
    Let class_means be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_observations be List.get(class_data, class_idx)
        Let class_mean be calculate_mean_vector(class_observations)
        Set class_means to List.append(class_means, class_mean)
        Set class_idx to class_idx + 1
    
    Note: Calculate overall mean
    Let overall_mean be calculate_mean_vector(X)
    
    Note: Calculate pooled within-class covariance matrix
    Let pooled_covariance be Linear.create_matrix(p, p)
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_observations be List.get(class_data, class_idx)
        Let class_mean be List.get(class_means, class_idx)
        Let n_class be List.length(class_observations)
        
        Let obs_idx be 0
        While obs_idx < n_class:
            Let observation be List.get(class_observations, obs_idx)
            Let j be 0
            While j < p:
                Let k be 0
                While k < p:
                    Let diff_j be List.get(observation, j) - List.get(class_mean, j)
                    Let diff_k be List.get(observation, k) - List.get(class_mean, k)
                    Let current_value be Linear.get_element(pooled_covariance, j, k)
                    Set pooled_covariance to Linear.set_element(pooled_covariance, j, k, current_value + diff_j * diff_k)
                    Set k to k + 1
                Set j to j + 1
            Set obs_idx to obs_idx + 1
        Set class_idx to class_idx + 1
    
    Note: Normalize pooled covariance by degrees of freedom
    Let df_pooled be n - num_classes
    Let j be 0
    While j < p:
        Let k be 0
        While k < p:
            Let current_value be Linear.get_element(pooled_covariance, j, k)
            Set pooled_covariance to Linear.set_element(pooled_covariance, j, k, current_value / Float.from_integer(df_pooled))
            Set k to k + 1
        Set j to j + 1
    
    Note: Calculate between-class scatter matrix
    Let between_scatter be Linear.create_matrix(p, p)
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_mean be List.get(class_means, class_idx)
        Let n_class be List.length(List.get(class_data, class_idx))
        Set j to 0
        While j < p:
            Let k be 0
            While k < p:
                Let diff_j be List.get(class_mean, j) - List.get(overall_mean, j)
                Let diff_k be List.get(class_mean, k) - List.get(overall_mean, k)
                Let current_value be Linear.get_element(between_scatter, j, k)
                Set between_scatter to Linear.set_element(between_scatter, j, k, current_value + Float.from_integer(n_class) * diff_j * diff_k)
                Set k to k + 1
            Set j to j + 1
        Set class_idx to class_idx + 1
    
    Note: Calculate discriminant functions using eigenvalue decomposition
    Let pooled_inv be Linear.invert_matrix(pooled_covariance)
    Let discriminant_matrix be Linear.matrix_multiply(pooled_inv, between_scatter)
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(discriminant_matrix)
    Let eigenvalues be eigen_result.eigenvalues
    Let eigenvectors be eigen_result.eigenvectors
    
    Note: Sort eigenvalues and eigenvectors in descending order
    Let sorted_indices be List.create()
    Set i to 0
    While i < List.length(eigenvalues):
        Set sorted_indices to List.append(sorted_indices, i)
        Set i to i + 1
    
    Note: Simple bubble sort for eigenvalues (descending)
    Let swapped be Boolean.true
    While swapped:
        Set swapped to Boolean.false
        Set i to 0
        While i < List.length(sorted_indices) - 1:
            Let idx1 be List.get(sorted_indices, i)
            Let idx2 be List.get(sorted_indices, i + 1)
            If List.get(eigenvalues, idx1) < List.get(eigenvalues, idx2):
                Set sorted_indices to List.set(sorted_indices, i, idx2)
                Set sorted_indices to List.set(sorted_indices, i + 1, idx1)
                Set swapped to Boolean.true
            Set i to i + 1
    
    Note: Extract discriminant functions (top num_classes-1 eigenvectors)
    Let discriminant_functions be List.create()
    Set i to 0
    While i < MathOps.min(Float.from_integer(num_classes - 1), Float.from_integer(List.length(eigenvalues))):
        Let eigenvalue_idx be List.get(sorted_indices, Integer.from_float(i))
        Let discriminant_function be List.get(eigenvectors, eigenvalue_idx)
        Set discriminant_functions to List.append(discriminant_functions, discriminant_function)
        Set i to i + 1
    
    Note: Calculate classification functions for each class
    Let classification_functions be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_mean be List.get(class_means, class_idx)
        Let prior_prob be If List.length(prior_probabilities) > class_idx 
            then List.get(prior_probabilities, class_idx) 
            otherwise 1.0 / Float.from_integer(num_classes)
        
        Note: Linear discriminant function coefficients
        Let classification_coeff be Linear.matrix_vector_multiply(pooled_inv, class_mean)
        
        Note: Add constant term (including prior probability)
        Let constant_term be -0.5 * Linear.vector_dot_product(class_mean, classification_coeff) + MathOps.log(prior_prob)
        Set classification_coeff to List.append(classification_coeff, constant_term)
        Set classification_functions to List.append(classification_functions, classification_coeff)
        Set class_idx to class_idx + 1
    
    Note: Create result dictionary
    Let result be Dictionary[String, List[List[Float]]]
    Set result to Dictionary.set(result, "discriminant_functions", discriminant_functions)
    Set result to Dictionary.set(result, "classification_functions", classification_functions)
    Set result to Dictionary.set(result, "class_means", class_means)
    Set result to Dictionary.set(result, "pooled_covariance", List.create())
    
    Note: Convert pooled covariance matrix to list format for storage
    Let pooled_cov_list be List.create()
    Set j to 0
    While j < p:
        Let row be List.create()
        Let k be 0
        While k < p:
            Set row to List.append(row, Linear.get_element(pooled_covariance, j, k))
            Set k to k + 1
        Set pooled_cov_list to List.append(pooled_cov_list, row)
        Set j to j + 1
    Set result to Dictionary.set(result, "pooled_covariance", pooled_cov_list)
    
    Return result

Process called "quadratic_discriminant_analysis" that takes X as List[List[Float]], y as List[String] returns Dictionary[String, List[List[Float]]]:
    Note: Quadratic discriminant analysis allowing different covariances
    Note: More flexible than LDA but requires larger sample sizes
    Let n be List.length(X)
    Let p be List.length(List.get(X, 0))
    
    Note: Get unique class labels
    Let unique_classes be List.create()
    Let i be 0
    While i < n:
        Let class_label be List.get(y, i)
        If List.contains(unique_classes, class_label) == Boolean.false:
            Set unique_classes to List.append(unique_classes, class_label)
        Set i to i + 1
    
    Let num_classes be List.length(unique_classes)
    
    Note: Group data by class
    Let class_data be List.create()
    Let class_idx be 0
    While class_idx < num_classes:
        Let class_label be List.get(unique_classes, class_idx)
        Let current_class_data be List.create()
        Set i to 0
        While i < n:
            If String.equals(List.get(y, i), class_label):
                Set current_class_data to List.append(current_class_data, List.get(X, i))
            Set i to i + 1
        Set class_data to List.append(class_data, current_class_data)
        Set class_idx to class_idx + 1
    
    Note: Calculate class means
    Let class_means be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_observations be List.get(class_data, class_idx)
        Let class_mean be calculate_mean_vector(class_observations)
        Set class_means to List.append(class_means, class_mean)
        Set class_idx to class_idx + 1
    
    Note: Calculate separate covariance matrices for each class
    Let class_covariances be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_observations be List.get(class_data, class_idx)
        Let class_mean be List.get(class_means, class_idx)
        Let n_class be List.length(class_observations)
        
        Note: Calculate class-specific covariance matrix
        Let class_cov be Linear.create_matrix(p, p)
        Let obs_idx be 0
        While obs_idx < n_class:
            Let observation be List.get(class_observations, obs_idx)
            Let j be 0
            While j < p:
                Let k be 0
                While k < p:
                    Let diff_j be List.get(observation, j) - List.get(class_mean, j)
                    Let diff_k be List.get(observation, k) - List.get(class_mean, k)
                    Let current_value be Linear.get_element(class_cov, j, k)
                    Set class_cov to Linear.set_element(class_cov, j, k, current_value + diff_j * diff_k)
                    Set k to k + 1
                Set j to j + 1
            Set obs_idx to obs_idx + 1
        
        Note: Normalize by degrees of freedom (n_class - 1)
        Let df_class be MathOps.max(1.0, Float.from_integer(n_class - 1))
        Set j to 0
        While j < p:
            Set k to 0
            While k < p:
                Let current_value be Linear.get_element(class_cov, j, k)
                Set class_cov to Linear.set_element(class_cov, j, k, current_value / df_class)
                Set k to k + 1
            Set j to j + 1
        
        Set class_covariances to List.append(class_covariances, class_cov)
        Set class_idx to class_idx + 1
    
    Note: Calculate class priors (equal priors assumed)
    Let class_priors be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let n_class be List.length(List.get(class_data, class_idx))
        Let prior be Float.from_integer(n_class) / Float.from_integer(n)
        Set class_priors to List.append(class_priors, prior)
        Set class_idx to class_idx + 1
    
    Note: Calculate quadratic discriminant functions
    Let quadratic_functions be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_mean be List.get(class_means, class_idx)
        Let class_cov be List.get(class_covariances, class_idx)
        Let prior be List.get(class_priors, class_idx)
        
        Note: Invert covariance matrix
        Let cov_inv be Linear.invert_matrix(class_cov)
        
        Note: Calculate determinant for normalization
        Let cov_det be Linear.determinant(class_cov)
        
        Note: Quadratic discriminant function components
        Note: Linear term: Σ^(-1) * μ
        Let linear_term be Linear.matrix_vector_multiply(cov_inv, class_mean)
        
        Note: Quadratic term: -0.5 * Σ^(-1)
        Let quadratic_term be List.create()
        Set j to 0
        While j < p:
            Let row be List.create()
            Set k to 0
            While k < p:
                Let element be -0.5 * Linear.get_element(cov_inv, j, k)
                Set row to List.append(row, element)
                Set k to k + 1
            Set quadratic_term to List.append(quadratic_term, row)
            Set j to j + 1
        
        Note: Constant term: -0.5 * μ^T * Σ^(-1) * μ - 0.5 * log|Σ| + log(π)
        Let mean_cov_mean be Linear.vector_dot_product(class_mean, Linear.matrix_vector_multiply(cov_inv, class_mean))
        Let log_det_term be If cov_det > 0.0001 then MathOps.log(cov_det) otherwise 0.0
        Let constant_term be -0.5 * mean_cov_mean - 0.5 * log_det_term + MathOps.log(prior)
        
        Note: Store quadratic function components
        Let qda_function be Dictionary[String, List[List[Float]]]
        Set qda_function to Dictionary.set(qda_function, "linear_coefficients", List.create())
        Set qda_function to Dictionary.set(qda_function, "quadratic_coefficients", quadratic_term)
        
        Note: Convert linear term to list format
        Let linear_list be List.create()
        Set linear_list to List.append(linear_list, linear_term)
        Set qda_function to Dictionary.set(qda_function, "linear_coefficients", linear_list)
        
        Note: Add constant term
        Let constant_list be List.create()
        Set constant_list to List.append(constant_list, constant_term)
        Set qda_function to Dictionary.set(qda_function, "constant_term", constant_list)
        
        Set quadratic_functions to List.append(quadratic_functions, qda_function)
        Set class_idx to class_idx + 1
    
    Note: Create result dictionary
    Let result be Dictionary[String, List[List[Float]]]
    Set result to Dictionary.set(result, "class_means", class_means)
    Set result to Dictionary.set(result, "class_priors", class_priors)
    
    Note: Convert class covariances to list format
    Let covariances_list be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_cov be List.get(class_covariances, class_idx)
        Let cov_list be List.create()
        Set j to 0
        While j < p:
            Let row be List.create()
            Set k to 0
            While k < p:
                Set row to List.append(row, Linear.get_element(class_cov, j, k))
                Set k to k + 1
            Set cov_list to List.append(cov_list, row)
            Set j to j + 1
        Set covariances_list to List.append(covariances_list, cov_list)
        Set class_idx to class_idx + 1
    Set result to Dictionary.set(result, "class_covariances", covariances_list)
    
    Note: Store quadratic function parameters
    Let linear_coeffs_all be List.create()
    Let quadratic_coeffs_all be List.create()
    Let constants_all be List.create()
    
    Set class_idx to 0
    While class_idx < num_classes:
        Let qda_func be List.get(quadratic_functions, class_idx)
        Set linear_coeffs_all to List.append(linear_coeffs_all, Dictionary.get(qda_func, "linear_coefficients"))
        Set quadratic_coeffs_all to List.append(quadratic_coeffs_all, Dictionary.get(qda_func, "quadratic_coefficients"))
        Set constants_all to List.append(constants_all, Dictionary.get(qda_func, "constant_term"))
        Set class_idx to class_idx + 1
    
    Set result to Dictionary.set(result, "linear_coefficients", linear_coeffs_all)
    Set result to Dictionary.set(result, "quadratic_coefficients", quadratic_coeffs_all)
    Set result to Dictionary.set(result, "constant_terms", constants_all)
    
    Return result

Process called "regularized_discriminant_analysis" that takes X as List[List[Float]], y as List[String], shrinkage_parameter as Float returns Dictionary[String, List[List[Float]]]:
    Note: Regularized DA interpolating between LDA and QDA
    Note: Shrinkage parameter controls regularization strength
    Let n be List.length(X)
    Let p be List.length(List.get(X, 0))
    Let lambda_param be MathOps.max(0.0, MathOps.min(1.0, shrinkage_parameter))
    
    Note: Get unique class labels
    Let unique_classes be List.create()
    Let i be 0
    While i < n:
        Let class_label be List.get(y, i)
        If List.contains(unique_classes, class_label) == Boolean.false:
            Set unique_classes to List.append(unique_classes, class_label)
        Set i to i + 1
    
    Let num_classes be List.length(unique_classes)
    
    Note: Group data by class
    Let class_data be List.create()
    Let class_idx be 0
    While class_idx < num_classes:
        Let class_label be List.get(unique_classes, class_idx)
        Let current_class_data be List.create()
        Set i to 0
        While i < n:
            If String.equals(List.get(y, i), class_label):
                Set current_class_data to List.append(current_class_data, List.get(X, i))
            Set i to i + 1
        Set class_data to List.append(class_data, current_class_data)
        Set class_idx to class_idx + 1
    
    Note: Calculate class means
    Let class_means be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_observations be List.get(class_data, class_idx)
        Let class_mean be calculate_mean_vector(class_observations)
        Set class_means to List.append(class_means, class_mean)
        Set class_idx to class_idx + 1
    
    Note: Calculate overall mean
    Let overall_mean be calculate_mean_vector(X)
    
    Note: Calculate pooled within-class covariance matrix (for LDA component)
    Let pooled_covariance be Linear.create_matrix(p, p)
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_observations be List.get(class_data, class_idx)
        Let class_mean be List.get(class_means, class_idx)
        Let n_class be List.length(class_observations)
        
        Let obs_idx be 0
        While obs_idx < n_class:
            Let observation be List.get(class_observations, obs_idx)
            Let j be 0
            While j < p:
                Let k be 0
                While k < p:
                    Let diff_j be List.get(observation, j) - List.get(class_mean, j)
                    Let diff_k be List.get(observation, k) - List.get(class_mean, k)
                    Let current_value be Linear.get_element(pooled_covariance, j, k)
                    Set pooled_covariance to Linear.set_element(pooled_covariance, j, k, current_value + diff_j * diff_k)
                    Set k to k + 1
                Set j to j + 1
            Set obs_idx to obs_idx + 1
        Set class_idx to class_idx + 1
    
    Note: Normalize pooled covariance
    Let df_pooled be n - num_classes
    Let j be 0
    While j < p:
        Let k be 0
        While k < p:
            Let current_value be Linear.get_element(pooled_covariance, j, k)
            Set pooled_covariance to Linear.set_element(pooled_covariance, j, k, current_value / Float.from_integer(df_pooled))
            Set k to k + 1
        Set j to j + 1
    
    Note: Calculate individual class covariances (for QDA component)
    Let class_covariances be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_observations be List.get(class_data, class_idx)
        Let class_mean be List.get(class_means, class_idx)
        Let n_class be List.length(class_observations)
        
        Let class_cov be Linear.create_matrix(p, p)
        Let obs_idx be 0
        While obs_idx < n_class:
            Let observation be List.get(class_observations, obs_idx)
            Set j to 0
            While j < p:
                Set k to 0
                While k < p:
                    Let diff_j be List.get(observation, j) - List.get(class_mean, j)
                    Let diff_k be List.get(observation, k) - List.get(class_mean, k)
                    Let current_value be Linear.get_element(class_cov, j, k)
                    Set class_cov to Linear.set_element(class_cov, j, k, current_value + diff_j * diff_k)
                    Set k to k + 1
                Set j to j + 1
            Set obs_idx to obs_idx + 1
        
        Note: Normalize class covariance
        Let df_class be MathOps.max(1.0, Float.from_integer(n_class - 1))
        Set j to 0
        While j < p:
            Set k to 0
            While k < p:
                Let current_value be Linear.get_element(class_cov, j, k)
                Set class_cov to Linear.set_element(class_cov, j, k, current_value / df_class)
                Set k to k + 1
            Set j to j + 1
        
        Set class_covariances to List.append(class_covariances, class_cov)
        Set class_idx to class_idx + 1
    
    Note: Calculate regularized covariance matrices
    Let regularized_covariances be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_cov be List.get(class_covariances, class_idx)
        Let regularized_cov be Linear.create_matrix(p, p)
        
        Note: Regularized covariance = (1-λ)*Σ_pooled + λ*Σ_class
        Set j to 0
        While j < p:
            Set k to 0
            While k < p:
                Let pooled_element be Linear.get_element(pooled_covariance, j, k)
                Let class_element be Linear.get_element(class_cov, j, k)
                Let regularized_element be (1.0 - lambda_param) * pooled_element + lambda_param * class_element
                Set regularized_cov to Linear.set_element(regularized_cov, j, k, regularized_element)
                Set k to k + 1
            Set j to j + 1
        
        Set regularized_covariances to List.append(regularized_covariances, regularized_cov)
        Set class_idx to class_idx + 1
    
    Note: Calculate class priors
    Let class_priors be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let n_class be List.length(List.get(class_data, class_idx))
        Let prior be Float.from_integer(n_class) / Float.from_integer(n)
        Set class_priors to List.append(class_priors, prior)
        Set class_idx to class_idx + 1
    
    Note: Calculate regularized discriminant functions
    Let discriminant_functions be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let class_mean be List.get(class_means, class_idx)
        Let regularized_cov be List.get(regularized_covariances, class_idx)
        Let prior be List.get(class_priors, class_idx)
        
        Note: Invert regularized covariance matrix
        Let reg_cov_inv be Linear.invert_matrix(regularized_cov)
        
        Note: Calculate determinant
        Let reg_cov_det be Linear.determinant(regularized_cov)
        
        Note: Linear discriminant function coefficients
        Let linear_coeff be Linear.matrix_vector_multiply(reg_cov_inv, class_mean)
        
        Note: Quadratic term coefficient (for regularized case)
        Let quad_coeff be List.create()
        Set j to 0
        While j < p:
            Let row be List.create()
            Set k to 0
            While k < p:
                Let element be If lambda_param > 0.01 
                    then -0.5 * Linear.get_element(reg_cov_inv, j, k)
                    otherwise 0.0
                Set row to List.append(row, element)
                Set k to k + 1
            Set quad_coeff to List.append(quad_coeff, row)
            Set j to j + 1
        
        Note: Constant term
        Let mean_cov_mean be Linear.vector_dot_product(class_mean, linear_coeff)
        Let log_det_term be If reg_cov_det > 0.0001 then MathOps.log(reg_cov_det) otherwise 0.0
        Let log_prior_term be MathOps.log(prior)
        Let constant_term be -0.5 * mean_cov_mean - 0.5 * lambda_param * log_det_term + log_prior_term
        
        Note: Store discriminant function
        Let disc_function be Dictionary[String, List[Float]]
        Set disc_function to Dictionary.set(disc_function, "linear_coefficients", linear_coeff)
        Set disc_function to Dictionary.set(disc_function, "constant_term", constant_term)
        Set disc_function to Dictionary.set(disc_function, "regularization_weight", lambda_param)
        Set discriminant_functions to List.append(discriminant_functions, disc_function)
        Set class_idx to class_idx + 1
    
    Note: Create result dictionary
    Let result be Dictionary[String, List[List[Float]]]
    Set result to Dictionary.set(result, "class_means", class_means)
    Set result to Dictionary.set(result, "class_priors", class_priors)
    
    Note: Extract linear coefficients for all classes
    Let all_linear_coeffs be List.create()
    Let all_constants be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let disc_func be List.get(discriminant_functions, class_idx)
        Set all_linear_coeffs to List.append(all_linear_coeffs, Dictionary.get(disc_func, "linear_coefficients"))
        Set all_constants to List.append(all_constants, Dictionary.get(disc_func, "constant_term"))
        Set class_idx to class_idx + 1
    
    Set result to Dictionary.set(result, "linear_coefficients", all_linear_coeffs)
    Set result to Dictionary.set(result, "constant_terms", all_constants)
    
    Note: Store regularization information
    Let regularization_info be List.create()
    Set regularization_info to List.append(regularization_info, lambda_param)
    Set regularization_info to List.append(regularization_info, 1.0 - lambda_param)
    Set result to Dictionary.set(result, "regularization_parameters", regularization_info)
    
    Note: Convert regularized covariances to list format
    Let reg_covariances_list be List.create()
    Set class_idx to 0
    While class_idx < num_classes:
        Let reg_cov be List.get(regularized_covariances, class_idx)
        Let cov_list be List.create()
        Set j to 0
        While j < p:
            Let row be List.create()
            Set k to 0
            While k < p:
                Set row to List.append(row, Linear.get_element(reg_cov, j, k))
                Set k to k + 1
            Set cov_list to List.append(cov_list, row)
            Set j to j + 1
        Set reg_covariances_list to List.append(reg_covariances_list, cov_list)
        Set class_idx to class_idx + 1
    Set result to Dictionary.set(result, "regularized_covariances", reg_covariances_list)
    
    Return result

Process called "discriminant_function_validation" that takes discriminant_functions as List[List[Float]], X_test as List[List[Float]], y_test as List[String] returns Dictionary[String, Float]:
    Note: Validate discriminant functions using test data
    Note: Returns classification accuracy, confusion matrix, and error rates
    Let n_test be List.length(X_test)
    Let p be List.length(List.get(X_test, 0))
    Let num_functions be List.length(discriminant_functions)
    
    Note: Get unique classes from test data
    Let unique_classes be List.create()
    Let i be 0
    While i < n_test:
        Let class_label be List.get(y_test, i)
        If List.contains(unique_classes, class_label) == Boolean.false:
            Set unique_classes to List.append(unique_classes, class_label)
        Set i to i + 1
    
    Let num_classes be List.length(unique_classes)
    
    Note: Make predictions using discriminant functions
    Let predictions be List.create()
    Let prediction_scores be List.create()
    
    Set i to 0
    While i < n_test:
        Let test_observation be List.get(X_test, i)
        
        Note: Calculate discriminant scores for each class
        Let scores be List.create()
        Let func_idx be 0
        While func_idx < num_functions:
            Let discriminant_func be List.get(discriminant_functions, func_idx)
            
            Note: Calculate discriminant score (linear combination)
            Let score be 0.0
            Let var_idx be 0
            While var_idx < MathOps.min(Float.from_integer(p), Float.from_integer(List.length(discriminant_func) - 1)):
                Let coefficient be List.get(discriminant_func, var_idx)
                Let variable_value be List.get(test_observation, var_idx)
                Set score to score + coefficient * variable_value
                Set var_idx to var_idx + 1
            
            Note: Add constant term if available
            If List.length(discriminant_func) > p:
                Let constant be List.get(discriminant_func, List.length(discriminant_func) - 1)
                Set score to score + constant
            
            Set scores to List.append(scores, score)
            Set func_idx to func_idx + 1
        
        Note: Find class with highest discriminant score
        Let max_score be List.get(scores, 0)
        Let predicted_class_idx be 0
        Let score_idx be 1
        While score_idx < List.length(scores):
            If List.get(scores, score_idx) > max_score:
                Set max_score to List.get(scores, score_idx)
                Set predicted_class_idx to score_idx
            Set score_idx to score_idx + 1
        
        Note: Map to actual class label (assuming functions correspond to classes)
        Let predicted_class be If predicted_class_idx < List.length(unique_classes)
            then List.get(unique_classes, predicted_class_idx)
            otherwise List.get(unique_classes, 0)
        
        Set predictions to List.append(predictions, predicted_class)
        Set prediction_scores to List.append(prediction_scores, scores)
        Set i to i + 1
    
    Note: Calculate accuracy
    Let correct_predictions be 0
    Set i to 0
    While i < n_test:
        Let actual_class be List.get(y_test, i)
        Let predicted_class be List.get(predictions, i)
        If String.equals(actual_class, predicted_class):
            Set correct_predictions to correct_predictions + 1
        Set i to i + 1
    
    Let accuracy be Float.from_integer(correct_predictions) / Float.from_integer(n_test)
    
    Note: Calculate confusion matrix elements
    Let true_positives be 0
    Let false_positives be 0
    Let true_negatives be 0
    Let false_negatives be 0
    
    Note: For binary classification using confusion matrix
    If num_classes == 2:
        Let positive_class be List.get(unique_classes, 0)
        Set i to 0
        While i < n_test:
            Let actual be List.get(y_test, i)
            Let predicted be List.get(predictions, i)
            
            If String.equals(actual, positive_class) && String.equals(predicted, positive_class):
                Set true_positives to true_positives + 1
            
            If String.equals(actual, positive_class) == Boolean.false && String.equals(predicted, positive_class):
                Set false_positives to false_positives + 1
            
            If String.equals(actual, positive_class) == Boolean.false && String.equals(predicted, positive_class) == Boolean.false:
                Set true_negatives to true_negatives + 1
            
            If String.equals(actual, positive_class) && String.equals(predicted, positive_class) == Boolean.false:
                Set false_negatives to false_negatives + 1
            
            Set i to i + 1
    
    Note: Calculate per-class accuracies
    Let class_accuracies be List.create()
    Let class_idx be 0
    While class_idx < num_classes:
        Let target_class be List.get(unique_classes, class_idx)
        Let correct_for_class be 0
        Let total_for_class be 0
        
        Set i to 0
        While i < n_test:
            Let actual_class be List.get(y_test, i)
            If String.equals(actual_class, target_class):
                Set total_for_class to total_for_class + 1
                Let predicted_class be List.get(predictions, i)
                If String.equals(predicted_class, target_class):
                    Set correct_for_class to correct_for_class + 1
            Set i to i + 1
        
        Let class_accuracy be If total_for_class > 0 
            then Float.from_integer(correct_for_class) / Float.from_integer(total_for_class)
            otherwise 0.0
        Set class_accuracies to List.append(class_accuracies, class_accuracy)
        Set class_idx to class_idx + 1
    
    Note: Calculate average class accuracy
    Let sum_class_accuracies be 0.0
    Set i to 0
    While i < List.length(class_accuracies):
        Set sum_class_accuracies to sum_class_accuracies + List.get(class_accuracies, i)
        Set i to i + 1
    Let avg_class_accuracy be sum_class_accuracies / Float.from_integer(List.length(class_accuracies))
    
    Note: Calculate error rates
    Let error_rate be 1.0 - accuracy
    Let type1_error be If true_positives + false_negatives > 0 
        then Float.from_integer(false_negatives) / Float.from_integer(true_positives + false_negatives)
        otherwise 0.0
    Let type2_error be If true_negatives + false_positives > 0 
        then Float.from_integer(false_positives) / Float.from_integer(true_negatives + false_positives)
        otherwise 0.0
    
    Note: Calculate precision and recall
    Let precision be If true_positives + false_positives > 0 
        then Float.from_integer(true_positives) / Float.from_integer(true_positives + false_positives)
        otherwise 0.0
    Let recall be If true_positives + false_negatives > 0 
        then Float.from_integer(true_positives) / Float.from_integer(true_positives + false_negatives)
        otherwise 0.0
    Let f1_score be If precision + recall > 0.0 
        then 2.0 * precision * recall / (precision + recall)
        otherwise 0.0
    
    Note: Create result dictionary
    Let result be Dictionary[String, Float]
    Set result to Dictionary.set(result, "overall_accuracy", accuracy)
    Set result to Dictionary.set(result, "average_class_accuracy", avg_class_accuracy)
    Set result to Dictionary.set(result, "error_rate", error_rate)
    Set result to Dictionary.set(result, "type1_error", type1_error)
    Set result to Dictionary.set(result, "type2_error", type2_error)
    Set result to Dictionary.set(result, "precision", precision)
    Set result to Dictionary.set(result, "recall", recall)
    Set result to Dictionary.set(result, "f1_score", f1_score)
    Set result to Dictionary.set(result, "num_test_samples", Float.from_integer(n_test))
    Set result to Dictionary.set(result, "num_classes", Float.from_integer(num_classes))
    Set result to Dictionary.set(result, "correct_predictions", Float.from_integer(correct_predictions))
    Set result to Dictionary.set(result, "true_positives", Float.from_integer(true_positives))
    Set result to Dictionary.set(result, "false_positives", Float.from_integer(false_positives))
    Set result to Dictionary.set(result, "true_negatives", Float.from_integer(true_negatives))
    Set result to Dictionary.set(result, "false_negatives", Float.from_integer(false_negatives))
    
    Return result

Note: =====================================================================
Note: CLUSTER ANALYSIS OPERATIONS
Note: =====================================================================

Process called "hierarchical_clustering" that takes data as List[List[Float]], linkage_method as String, distance_metric as String returns Dictionary[String, List[List[Float]]]:
    Note: Hierarchical clustering with specified linkage and distance
    Note: Linkage: single, complete, average, Ward. Creates dendrogram structure
    Let n be List.length(data)
    Let p be List.length(List.get(data, 0))
    
    Note: Calculate distance matrix between all pairs of observations
    Let distance_matrix be Linear.create_matrix(n, n)
    Let i be 0
    While i < n:
        Let j be 0
        While j < n:
            If i == j:
                Set distance_matrix to Linear.set_element(distance_matrix, i, j, 0.0)
            Otherwise:
                Let obs1 be List.get(data, i)
                Let obs2 be List.get(data, j)
                
                Note: Calculate distance based on specified metric
                Let distance be 0.0
                If String.equals(distance_metric, "euclidean"):
                    Let k be 0
                    While k < p:
                        Let diff be List.get(obs1, k) - List.get(obs2, k)
                        Set distance to distance + diff * diff
                        Set k to k + 1
                    Set distance to MathOps.sqrt(distance)
                
                If String.equals(distance_metric, "manhattan"):
                    Let k be 0
                    While k < p:
                        Let diff be MathOps.abs(List.get(obs1, k) - List.get(obs2, k))
                        Set distance to distance + diff
                        Set k to k + 1
                
                If String.equals(distance_metric, "cosine"):
                    Let dot_product be 0.0
                    Let norm1 be 0.0
                    Let norm2 be 0.0
                    Let k be 0
                    While k < p:
                        Let val1 be List.get(obs1, k)
                        Let val2 be List.get(obs2, k)
                        Set dot_product to dot_product + val1 * val2
                        Set norm1 to norm1 + val1 * val1
                        Set norm2 to norm2 + val2 * val2
                        Set k to k + 1
                    Set norm1 to MathOps.sqrt(norm1)
                    Set norm2 to MathOps.sqrt(norm2)
                    Set distance to If norm1 > 0.001 && norm2 > 0.001 
                        then 1.0 - dot_product / (norm1 * norm2)
                        otherwise 1.0
                
                Set distance_matrix to Linear.set_element(distance_matrix, i, j, distance)
            Set j to j + 1
        Set i to i + 1
    
    Note: Initialize clusters (each observation starts as its own cluster)
    Let clusters be List.create()
    Set i to 0
    While i < n:
        Let single_cluster be List.create()
        Set single_cluster to List.append(single_cluster, i)
        Set clusters to List.append(clusters, single_cluster)
        Set i to i + 1
    
    Note: Store merge history for dendrogram
    Let merge_history be List.create()
    Let merge_heights be List.create()
    
    Note: Perform agglomerative clustering
    While List.length(clusters) > 1:
        Let min_distance be MathOps.positive_infinity
        Let merge_i be -1
        Let merge_j be -1
        
        Note: Find closest pair of clusters
        Let cluster_i be 0
        While cluster_i < List.length(clusters):
            Let cluster_j be cluster_i + 1
            While cluster_j < List.length(clusters):
                Let cluster1 be List.get(clusters, cluster_i)
                Let cluster2 be List.get(clusters, cluster_j)
                
                Note: Calculate inter-cluster distance based on linkage method
                Let inter_cluster_dist be 0.0
                
                If String.equals(linkage_method, "single"):
                    Set inter_cluster_dist to MathOps.positive_infinity
                    Let obs1_idx be 0
                    While obs1_idx < List.length(cluster1):
                        Let obs2_idx be 0
                        While obs2_idx < List.length(cluster2):
                            Let obs1 be List.get(cluster1, obs1_idx)
                            Let obs2 be List.get(cluster2, obs2_idx)
                            Let dist be Linear.get_element(distance_matrix, obs1, obs2)
                            Set inter_cluster_dist to MathOps.min(inter_cluster_dist, dist)
                            Set obs2_idx to obs2_idx + 1
                        Set obs1_idx to obs1_idx + 1
                
                If String.equals(linkage_method, "complete"):
                    Set inter_cluster_dist to 0.0
                    Let obs1_idx be 0
                    While obs1_idx < List.length(cluster1):
                        Let obs2_idx be 0
                        While obs2_idx < List.length(cluster2):
                            Let obs1 be List.get(cluster1, obs1_idx)
                            Let obs2 be List.get(cluster2, obs2_idx)
                            Let dist be Linear.get_element(distance_matrix, obs1, obs2)
                            Set inter_cluster_dist to MathOps.max(inter_cluster_dist, dist)
                            Set obs2_idx to obs2_idx + 1
                        Set obs1_idx to obs1_idx + 1
                
                If String.equals(linkage_method, "average"):
                    Let sum_distances be 0.0
                    Let pair_count be 0
                    Let obs1_idx be 0
                    While obs1_idx < List.length(cluster1):
                        Let obs2_idx be 0
                        While obs2_idx < List.length(cluster2):
                            Let obs1 be List.get(cluster1, obs1_idx)
                            Let obs2 be List.get(cluster2, obs2_idx)
                            Let dist be Linear.get_element(distance_matrix, obs1, obs2)
                            Set sum_distances to sum_distances + dist
                            Set pair_count to pair_count + 1
                            Set obs2_idx to obs2_idx + 1
                        Set obs1_idx to obs1_idx + 1
                    Set inter_cluster_dist to sum_distances / Float.from_integer(pair_count)
                
                If String.equals(linkage_method, "ward"):
                    Note: Ward linkage uses within-cluster sum of squares increase
                    Note: Proper Ward calculation: ESS increase from merging clusters
                    
                    Note: Calculate within-cluster sum of squares for cluster1
                    Let centroid1 be List.create()
                    Let k be 0
                    While k < p:
                        Let sum_coord be 0.0
                        Let coord_idx be 0
                        While coord_idx < List.length(cluster1):
                            Let obs_idx be List.get(cluster1, coord_idx)
                            Let observation be List.get(data, obs_idx)
                            Set sum_coord to sum_coord + List.get(observation, k)
                            Set coord_idx to coord_idx + 1
                        Set centroid1 to List.append(centroid1, sum_coord / Float.from_integer(List.length(cluster1)))
                        Set k to k + 1
                    
                    Let wss1 be 0.0
                    Let coord_idx be 0
                    While coord_idx < List.length(cluster1):
                        Let obs_idx be List.get(cluster1, coord_idx)
                        Let observation be List.get(data, obs_idx)
                        Let k be 0
                        While k < p:
                            Let diff be List.get(observation, k) - List.get(centroid1, k)
                            Set wss1 to wss1 + diff * diff
                            Set k to k + 1
                        Set coord_idx to coord_idx + 1
                    
                    Note: Calculate within-cluster sum of squares for cluster2
                    Let centroid2 be List.create()
                    Set k to 0
                    While k < p:
                        Let sum_coord be 0.0
                        Let coord_idx be 0
                        While coord_idx < List.length(cluster2):
                            Let obs_idx be List.get(cluster2, coord_idx)
                            Let observation be List.get(data, obs_idx)
                            Set sum_coord to sum_coord + List.get(observation, k)
                            Set coord_idx to coord_idx + 1
                        Set centroid2 to List.append(centroid2, sum_coord / Float.from_integer(List.length(cluster2)))
                        Set k to k + 1
                    
                    Let wss2 be 0.0
                    Set coord_idx to 0
                    While coord_idx < List.length(cluster2):
                        Let obs_idx be List.get(cluster2, coord_idx)
                        Let observation be List.get(data, obs_idx)
                        Let k be 0
                        While k < p:
                            Let diff be List.get(observation, k) - List.get(centroid2, k)
                            Set wss2 to wss2 + diff * diff
                            Set k to k + 1
                        Set coord_idx to coord_idx + 1
                    
                    Note: Calculate merged cluster centroid and WSS
                    Let merged_centroid be List.create()
                    Let n1 be Float.from_integer(List.length(cluster1))
                    Let n2 be Float.from_integer(List.length(cluster2))
                    Let n_total be n1 + n2
                    
                    Set k to 0
                    While k < p:
                        Let merged_coord be (n1 * List.get(centroid1, k) + n2 * List.get(centroid2, k)) / n_total
                        Set merged_centroid to List.append(merged_centroid, merged_coord)
                        Set k to k + 1
                    
                    Let wss_merged be 0.0
                    Set coord_idx to 0
                    While coord_idx < List.length(cluster1):
                        Let obs_idx be List.get(cluster1, coord_idx)
                        Let observation be List.get(data, obs_idx)
                        Let k be 0
                        While k < p:
                            Let diff be List.get(observation, k) - List.get(merged_centroid, k)
                            Set wss_merged to wss_merged + diff * diff
                            Set k to k + 1
                        Set coord_idx to coord_idx + 1
                    
                    Set coord_idx to 0
                    While coord_idx < List.length(cluster2):
                        Let obs_idx be List.get(cluster2, coord_idx)
                        Let observation be List.get(data, obs_idx)
                        Let k be 0
                        While k < p:
                            Let diff be List.get(observation, k) - List.get(merged_centroid, k)
                            Set wss_merged to wss_merged + diff * diff
                            Set k to k + 1
                        Set coord_idx to coord_idx + 1
                    
                    Note: Ward distance is increase in WSS from merging
                    Set inter_cluster_dist to wss_merged - wss1 - wss2
                
                Note: Update minimum distance and merge candidates
                If inter_cluster_dist < min_distance:
                    Set min_distance to inter_cluster_dist
                    Set merge_i to cluster_i
                    Set merge_j to cluster_j
                
                Set cluster_j to cluster_j + 1
            Set cluster_i to cluster_i + 1
        
        Note: Merge the closest clusters
        If merge_i >= 0 && merge_j >= 0:
            Let cluster1 be List.get(clusters, merge_i)
            Let cluster2 be List.get(clusters, merge_j)
            
            Note: Create merged cluster
            Let merged_cluster be List.create()
            Let idx be 0
            While idx < List.length(cluster1):
                Set merged_cluster to List.append(merged_cluster, List.get(cluster1, idx))
                Set idx to idx + 1
            Set idx to 0
            While idx < List.length(cluster2):
                Set merged_cluster to List.append(merged_cluster, List.get(cluster2, idx))
                Set idx to idx + 1
            
            Note: Record merge information
            Let merge_info be List.create()
            Set merge_info to List.append(merge_info, Float.from_integer(merge_i))
            Set merge_info to List.append(merge_info, Float.from_integer(merge_j))
            Set merge_history to List.append(merge_history, merge_info)
            Set merge_heights to List.append(merge_heights, min_distance)
            
            Note: Remove old clusters and add merged cluster
            Let new_clusters be List.create()
            Let cluster_idx be 0
            While cluster_idx < List.length(clusters):
                If cluster_idx != merge_i && cluster_idx != merge_j:
                    Set new_clusters to List.append(new_clusters, List.get(clusters, cluster_idx))
                Set cluster_idx to cluster_idx + 1
            Set new_clusters to List.append(new_clusters, merged_cluster)
            Set clusters to new_clusters
    
    Note: Create result dictionary
    Let result be Dictionary[String, List[List[Float]]]
    
    Note: Convert final cluster assignments
    Let final_assignments be List.create()
    Let final_cluster be List.get(clusters, 0)
    Set i to 0
    While i < List.length(final_cluster):
        Set final_assignments to List.append(final_assignments, Float.from_integer(List.get(final_cluster, i)))
        Set i to i + 1
    Set result to Dictionary.set(result, "cluster_assignments", final_assignments)
    
    Set result to Dictionary.set(result, "merge_history", merge_history)
    Set result to Dictionary.set(result, "merge_heights", merge_heights)
    
    Note: Convert distance matrix to list format
    Let distance_list be List.create()
    Set i to 0
    While i < n:
        Let row be List.create()
        Let j be 0
        While j < n:
            Set row to List.append(row, Linear.get_element(distance_matrix, i, j))
            Set j to j + 1
        Set distance_list to List.append(distance_list, row)
        Set i to i + 1
    Set result to Dictionary.set(result, "distance_matrix", distance_list)
    
    Let method_info be List.create()
    Set method_info to List.append(method_info, 0.0)
    Set result to Dictionary.set(result, "linkage_method", method_info)
    
    Return result

Process called "k_means_clustering" that takes data as List[List[Float]], num_clusters as Integer, initialization_method as String, max_iterations as Integer returns Dictionary[String, List[List[Float]]]:
    Note: K-means clustering for partitional clustering
    Note: Minimizes within-cluster sum of squares. Sensitive to initialization
    Let n be List.length(data)
    Let p be List.length(List.get(data, 0))
    Let k be num_clusters
    
    Note: Initialize cluster centroids
    Let centroids be List.create()
    
    If String.equals(initialization_method, "random"):
        Note: Randomly select k observations as initial centroids
        Let selected_indices be List.create()
        Let centroid_idx be 0
        While centroid_idx < k:
            Let random_idx be centroid_idx % n
            Set selected_indices to List.append(selected_indices, random_idx)
            Let initial_centroid be List.get(data, random_idx)
            Set centroids to List.append(centroids, initial_centroid)
            Set centroid_idx to centroid_idx + 1
    
    If String.equals(initialization_method, "kmeans++"):
        Note: K-means++ initialization for better starting positions
        Note: First centroid is randomly selected
        Let first_idx be 0
        Set centroids to List.append(centroids, List.get(data, first_idx))
        
        Note: Select remaining centroids based on distance weights
        Let selected_count be 1
        While selected_count < k:
            Let distances be List.create()
            Let distance_sum be 0.0
            
            Note: Calculate minimum distance to existing centroids for each point
            Let obs_idx be 0
            While obs_idx < n:
                Let observation be List.get(data, obs_idx)
                Let min_dist_sq be MathOps.positive_infinity
                
                Let centroid_idx be 0
                While centroid_idx < List.length(centroids):
                    Let centroid be List.get(centroids, centroid_idx)
                    Let dist_sq be 0.0
                    Let coord_idx be 0
                    While coord_idx < p:
                        Let diff be List.get(observation, coord_idx) - List.get(centroid, coord_idx)
                        Set dist_sq to dist_sq + diff * diff
                        Set coord_idx to coord_idx + 1
                    Set min_dist_sq to MathOps.min(min_dist_sq, dist_sq)
                    Set centroid_idx to centroid_idx + 1
                
                Set distances to List.append(distances, min_dist_sq)
                Set distance_sum to distance_sum + min_dist_sq
                Set obs_idx to obs_idx + 1
            
            Note: Select next centroid with probability proportional to distance squared
            Let target_sum be distance_sum * 0.5
            Let cumulative_sum be 0.0
            Set obs_idx to 0
            While obs_idx < n && cumulative_sum < target_sum:
                Set cumulative_sum to cumulative_sum + List.get(distances, obs_idx)
                Set obs_idx to obs_idx + 1
            
            Let selected_idx be MathOps.min(Float.from_integer(obs_idx), Float.from_integer(n - 1))
            Set centroids to List.append(centroids, List.get(data, Integer.from_float(selected_idx)))
            Set selected_count to selected_count + 1
    
    If String.equals(initialization_method, "forgy"):
        Note: Forgy initialization - randomly partition data points
        Let centroid_idx be 0
        While centroid_idx < k:
            Let centroid be List.create()
            Let coord_idx be 0
            While coord_idx < p:
                Set centroid to List.append(centroid, Float.from_integer(centroid_idx))
                Set coord_idx to coord_idx + 1
            Set centroids to List.append(centroids, centroid)
            Set centroid_idx to centroid_idx + 1
    
    Note: Main K-means algorithm
    Let cluster_assignments be List.create()
    Let iteration be 0
    Let converged be Boolean.false
    Let previous_assignments be List.create()
    
    Note: Initialize assignments
    Let i be 0
    While i < n:
        Set cluster_assignments to List.append(cluster_assignments, 0)
        Set previous_assignments to List.append(previous_assignments, -1)
        Set i to i + 1
    
    While iteration < max_iterations && converged == Boolean.false:
        Note: Assignment step - assign each point to nearest centroid
        Set i to 0
        While i < n:
            Let observation be List.get(data, i)
            Let min_distance be MathOps.positive_infinity
            Let best_cluster be 0
            
            Let cluster_idx be 0
            While cluster_idx < k:
                Let centroid be List.get(centroids, cluster_idx)
                Let distance be 0.0
                Let coord_idx be 0
                While coord_idx < p:
                    Let diff be List.get(observation, coord_idx) - List.get(centroid, coord_idx)
                    Set distance to distance + diff * diff
                    Set coord_idx to coord_idx + 1
                Set distance to MathOps.sqrt(distance)
                
                If distance < min_distance:
                    Set min_distance to distance
                    Set best_cluster to cluster_idx
                
                Set cluster_idx to cluster_idx + 1
            
            Set cluster_assignments to List.set(cluster_assignments, i, best_cluster)
            Set i to i + 1
        
        Note: Update step - recalculate centroids
        Let new_centroids be List.create()
        Let cluster_idx be 0
        While cluster_idx < k:
            Let cluster_points be List.create()
            
            Note: Collect points assigned to this cluster
            Set i to 0
            While i < n:
                If List.get(cluster_assignments, i) == cluster_idx:
                    Set cluster_points to List.append(cluster_points, List.get(data, i))
                Set i to i + 1
            
            Note: Calculate new centroid
            Let new_centroid be List.create()
            If List.length(cluster_points) > 0:
                Let coord_idx be 0
                While coord_idx < p:
                    Let sum_coord be 0.0
                    Let point_idx be 0
                    While point_idx < List.length(cluster_points):
                        Let point be List.get(cluster_points, point_idx)
                        Set sum_coord to sum_coord + List.get(point, coord_idx)
                        Set point_idx to point_idx + 1
                    Set new_centroid to List.append(new_centroid, sum_coord / Float.from_integer(List.length(cluster_points)))
                    Set coord_idx to coord_idx + 1
            Otherwise:
                Note: Keep old centroid if no points assigned
                Set new_centroid to List.get(centroids, cluster_idx)
            
            Set new_centroids to List.append(new_centroids, new_centroid)
            Set cluster_idx to cluster_idx + 1
        
        Set centroids to new_centroids
        
        Note: Check for convergence (assignments didn't change)
        Set converged to Boolean.true
        Set i to 0
        While i < n:
            If List.get(cluster_assignments, i) != List.get(previous_assignments, i):
                Set converged to Boolean.false
            Set previous_assignments to List.set(previous_assignments, i, List.get(cluster_assignments, i))
            Set i to i + 1
        
        Set iteration to iteration + 1
    
    Note: Calculate within-cluster sum of squares (WCSS)
    Let wcss be 0.0
    Let cluster_idx be 0
    While cluster_idx < k:
        Let centroid be List.get(centroids, cluster_idx)
        Set i to 0
        While i < n:
            If List.get(cluster_assignments, i) == cluster_idx:
                Let observation be List.get(data, i)
                Let coord_idx be 0
                While coord_idx < p:
                    Let diff be List.get(observation, coord_idx) - List.get(centroid, coord_idx)
                    Set wcss to wcss + diff * diff
                    Set coord_idx to coord_idx + 1
            Set i to i + 1
        Set cluster_idx to cluster_idx + 1
    
    Note: Calculate cluster sizes
    Let cluster_sizes be List.create()
    Set cluster_idx to 0
    While cluster_idx < k:
        Let size be 0
        Set i to 0
        While i < n:
            If List.get(cluster_assignments, i) == cluster_idx:
                Set size to size + 1
            Set i to i + 1
        Set cluster_sizes to List.append(cluster_sizes, Float.from_integer(size))
        Set cluster_idx to cluster_idx + 1
    
    Note: Create result dictionary
    Let result be Dictionary[String, List[List[Float]]]
    Set result to Dictionary.set(result, "centroids", centroids)
    
    Let assignments_float be List.create()
    Set i to 0
    While i < n:
        Set assignments_float to List.append(assignments_float, Float.from_integer(List.get(cluster_assignments, i)))
        Set i to i + 1
    Set result to Dictionary.set(result, "cluster_assignments", assignments_float)
    
    Set result to Dictionary.set(result, "cluster_sizes", cluster_sizes)
    
    Let metrics be List.create()
    Set metrics to List.append(metrics, wcss)
    Set metrics to List.append(metrics, Float.from_integer(iteration))
    Set metrics to List.append(metrics, If converged then 1.0 otherwise 0.0)
    Set result to Dictionary.set(result, "metrics", metrics)
    
    Return result

Process called "gaussian_mixture_clustering" that takes data as List[List[Float]], num_components as Integer, covariance_type as String returns Dictionary[String, Dictionary[String, List[Float]]]:
    Note: Gaussian mixture model clustering using EM algorithm
    Note: Soft clustering with probability assignments to components
    Let n be List.length(data)
    Let p be List.length(List.get(data, 0))
    Let k be num_components
    
    Note: Initialize parameters
    Let means be List.create()
    Let covariances be List.create()
    Let mixing_weights be List.create()
    
    Note: Initialize means using k-means++ style selection
    Let i be 0
    While i < k:
        Let mean_idx be i % n
        Set means to List.append(means, List.get(data, mean_idx))
        Set i to i + 1
    
    Note: Initialize mixing weights (equal weights)
    Set i to 0
    While i < k:
        Set mixing_weights to List.append(mixing_weights, 1.0 / Float.from_integer(k))
        Set i to i + 1
    
    Note: Initialize covariances
    If String.equals(covariance_type, "full"):
        Note: Full covariance matrices
        Set i to 0
        While i < k:
            Let identity_matrix be create_identity_matrix(p)
            Set covariances to List.append(covariances, identity_matrix)
            Set i to i + 1
    
    If String.equals(covariance_type, "diagonal"):
        Note: Diagonal covariance matrices
        Set i to 0
        While i < k:
            Let diagonal_cov be List.create()
            Let j be 0
            While j < p:
                Set diagonal_cov to List.append(diagonal_cov, 1.0)
                Set j to j + 1
            Set covariances to List.append(covariances, diagonal_cov)
            Set i to i + 1
    
    If String.equals(covariance_type, "spherical"):
        Note: Spherical covariance (single variance parameter)
        Set i to 0
        While i < k:
            Set covariances to List.append(covariances, 1.0)
            Set i to i + 1
    
    Note: EM Algorithm
    Let max_iterations be 100
    Let iteration be 0
    Let log_likelihood be MathOps.negative_infinity
    Let prev_log_likelihood be MathOps.negative_infinity
    Let tolerance be Float.divide(1.0, Float.from_integer(n * 1000))
    
    While iteration < max_iterations:
        Note: E-step: Calculate responsibilities (posterior probabilities)
        Let responsibilities be List.create()
        Set log_likelihood to 0.0
        
        Let obs_idx be 0
        While obs_idx < n:
            Let observation be List.get(data, obs_idx)
            Let component_probs be List.create()
            Let total_prob be 0.0
            
            Note: Calculate probability for each component
            Let comp_idx be 0
            While comp_idx < k:
                Let mean be List.get(means, comp_idx)
                Let mixing_weight be List.get(mixing_weights, comp_idx)
                
                Note: Calculate multivariate Gaussian probability
                Let prob be 0.0
                
                If String.equals(covariance_type, "spherical"):
                    Let variance be List.get(covariances, comp_idx)
                    Let mahalanobis_dist be 0.0
                    Let coord_idx be 0
                    While coord_idx < p:
                        Let diff be List.get(observation, coord_idx) - List.get(mean, coord_idx)
                        Set mahalanobis_dist to mahalanobis_dist + diff * diff
                        Set coord_idx to coord_idx + 1
                    
                    Let normalization be MathOps.power(2.0 * 3.14159 * variance, Float.from_integer(p) / 2.0)
                    Set prob to mixing_weight * MathOps.exp(-mahalanobis_dist / (2.0 * variance)) / normalization
                
                If String.equals(covariance_type, "diagonal"):
                    Let diagonal_cov be List.get(covariances, comp_idx)
                    Let mahalanobis_dist be 0.0
                    Let log_det be 0.0
                    Let coord_idx be 0
                    While coord_idx < p:
                        Let diff be List.get(observation, coord_idx) - List.get(mean, coord_idx)
                        Let variance be List.get(diagonal_cov, coord_idx)
                        Set mahalanobis_dist to mahalanobis_dist + diff * diff / variance
                        Set log_det to log_det + MathOps.log(variance)
                        Set coord_idx to coord_idx + 1
                    
                    Let normalization be MathOps.exp(0.5 * (Float.from_integer(p) * MathOps.log(2.0 * 3.14159) + log_det))
                    Set prob to mixing_weight * MathOps.exp(-0.5 * mahalanobis_dist) / normalization
                
                If String.equals(covariance_type, "full"):
                    Note: Proper full covariance matrix calculation
                    Let cov_matrix be List.get(covariances, comp_idx)
                    Let diff_vector be List.create()
                    Let coord_idx be 0
                    While coord_idx < p:
                        Set diff_vector to List.append(diff_vector, List.get(observation, coord_idx) - List.get(mean, coord_idx))
                        Set coord_idx to coord_idx + 1
                    
                    Note: Calculate proper multivariate normal probability with full covariance
                    Let cov_inv be Linear.invert_matrix(cov_matrix)
                    Let mahalanobis_dist be Linear.quadratic_form(diff_vector, cov_inv)
                    
                    Note: Calculate determinant for normalization
                    Let det_cov be Linear.determinant(cov_matrix)
                    Let normalization be MathOps.sqrt(MathOps.power(2.0 * 3.14159, Float.convert(p)) * det_cov)
                    
                    Set prob to mixing_weight * MathOps.exp(-0.5 * mahalanobis_dist) / normalization
                
                Set component_probs to List.append(component_probs, prob)
                Set total_prob to total_prob + prob
                Set comp_idx to comp_idx + 1
            
            Note: Normalize probabilities to get responsibilities
            Let obs_responsibilities be List.create()
            Set comp_idx to 0
            While comp_idx < k:
                Let responsibility be If total_prob > 0.001 
                    then List.get(component_probs, comp_idx) / total_prob 
                    otherwise 1.0 / Float.from_integer(k)
                Set obs_responsibilities to List.append(obs_responsibilities, responsibility)
                Set comp_idx to comp_idx + 1
            
            Set responsibilities to List.append(responsibilities, obs_responsibilities)
            Set log_likelihood to log_likelihood + MathOps.log(MathOps.max(total_prob, 0.000001))
            Set obs_idx to obs_idx + 1
        
        Note: M-step: Update parameters
        Note: Update mixing weights
        Let new_mixing_weights be List.create()
        Let comp_idx be 0
        While comp_idx < k:
            Let sum_responsibilities be 0.0
            Set obs_idx to 0
            While obs_idx < n:
                Set sum_responsibilities to sum_responsibilities + List.get(List.get(responsibilities, obs_idx), comp_idx)
                Set obs_idx to obs_idx + 1
            Set new_mixing_weights to List.append(new_mixing_weights, sum_responsibilities / Float.from_integer(n))
            Set comp_idx to comp_idx + 1
        Set mixing_weights to new_mixing_weights
        
        Note: Update means
        Let new_means be List.create()
        Set comp_idx to 0
        While comp_idx < k:
            Let new_mean be List.create()
            Let sum_responsibilities be List.get(mixing_weights, comp_idx) * Float.from_integer(n)
            
            Let coord_idx be 0
            While coord_idx < p:
                Let weighted_sum be 0.0
                Set obs_idx to 0
                While obs_idx < n:
                    Let responsibility be List.get(List.get(responsibilities, obs_idx), comp_idx)
                    Let observation be List.get(data, obs_idx)
                    Set weighted_sum to weighted_sum + responsibility * List.get(observation, coord_idx)
                    Set obs_idx to obs_idx + 1
                Set new_mean to List.append(new_mean, weighted_sum / sum_responsibilities)
                Set coord_idx to coord_idx + 1
            
            Set new_means to List.append(new_means, new_mean)
            Set comp_idx to comp_idx + 1
        Set means to new_means
        
        Note: Update covariances using weighted maximum likelihood
        Let new_covariances be List.create()
        Set comp_idx to 0
        While comp_idx < k:
            Let mean be List.get(means, comp_idx)
            Let sum_responsibilities be List.get(mixing_weights, comp_idx) * Float.from_integer(n)
            
            If String.equals(covariance_type, "spherical"):
                Let variance_sum be 0.0
                Set obs_idx to 0
                While obs_idx < n:
                    Let responsibility be List.get(List.get(responsibilities, obs_idx), comp_idx)
                    Let observation be List.get(data, obs_idx)
                    Let coord_idx be 0
                    While coord_idx < p:
                        Let diff be List.get(observation, coord_idx) - List.get(mean, coord_idx)
                        Set variance_sum to variance_sum + responsibility * diff * diff
                        Set coord_idx to coord_idx + 1
                    Set obs_idx to obs_idx + 1
                Let new_variance be variance_sum / (sum_responsibilities * Float.from_integer(p))
                Set new_covariances to List.append(new_covariances, MathOps.max(new_variance, 0.001))
            
            If String.equals(covariance_type, "diagonal"):
                Let new_diagonal_cov be List.create()
                Let coord_idx be 0
                While coord_idx < p:
                    Let variance_sum be 0.0
                    Set obs_idx to 0
                    While obs_idx < n:
                        Let responsibility be List.get(List.get(responsibilities, obs_idx), comp_idx)
                        Let observation be List.get(data, obs_idx)
                        Let diff be List.get(observation, coord_idx) - List.get(mean, coord_idx)
                        Set variance_sum to variance_sum + responsibility * diff * diff
                        Set obs_idx to obs_idx + 1
                    Set new_diagonal_cov to List.append(new_diagonal_cov, MathOps.max(variance_sum / sum_responsibilities, 0.001))
                    Set coord_idx to coord_idx + 1
                Set new_covariances to List.append(new_covariances, new_diagonal_cov)
            
            If String.equals(covariance_type, "full"):
                Note: Proper full covariance matrix update with all elements
                Let new_full_cov be Linear.create_matrix(p, p)
                
                Note: Calculate full covariance matrix: Σ = Σ_n r_n (x_n - μ)(x_n - μ)' / Σ_n r_n
                Let coord_i be 0
                While coord_i < p:
                    Let coord_j be 0
                    While coord_j < p:
                        Let covariance_sum be 0.0
                        Let obs_idx be 0
                        While obs_idx < n:
                            Let responsibility be List.get(List.get(responsibilities, obs_idx), comp_idx)
                            Let observation be List.get(data, obs_idx)
                            Let diff_i be List.get(observation, coord_i) - List.get(mean, coord_i)
                            Let diff_j be List.get(observation, coord_j) - List.get(mean, coord_j)
                            Set covariance_sum to covariance_sum + responsibility * diff_i * diff_j
                            Set obs_idx to obs_idx + 1
                        
                        Let covariance_val be covariance_sum / sum_responsibilities
                        Note: Add regularization to diagonal elements
                        If coord_i = coord_j then:
                            Set covariance_val to MathOps.max(covariance_val, 0.001)
                        
                        List.set(List.get(new_full_cov, coord_i), coord_j, covariance_val)
                        Set coord_j to coord_j + 1
                    Set coord_i to coord_i + 1
                
                List.append(new_covariances, new_full_cov)
            
            Set comp_idx to comp_idx + 1
        Set covariances to new_covariances
        
        Note: Check convergence
        If MathOps.abs(log_likelihood - prev_log_likelihood) < tolerance:
            Set iteration to max_iterations
        Set prev_log_likelihood to log_likelihood
        Set iteration to iteration + 1
    
    Note: Create hard cluster assignments from responsibilities
    Let cluster_assignments be List.create()
    Set obs_idx to 0
    While obs_idx < n:
        Let max_responsibility be List.get(List.get(responsibilities, obs_idx), 0)
        Let best_cluster be 0
        Let comp_idx be 1
        While comp_idx < k:
            Let responsibility be List.get(List.get(responsibilities, obs_idx), comp_idx)
            If responsibility > max_responsibility:
                Set max_responsibility to responsibility
                Set best_cluster to comp_idx
            Set comp_idx to comp_idx + 1
        Set cluster_assignments to List.append(cluster_assignments, Float.from_integer(best_cluster))
        Set obs_idx to obs_idx + 1
    
    Note: Create result dictionary
    Let result be Dictionary[String, Dictionary[String, List[Float]]]
    
    Let means_dict be Dictionary[String, List[Float]]
    Set means_dict to Dictionary.set(means_dict, "component_means", means)
    Set result to Dictionary.set(result, "means", means_dict)
    
    Let weights_dict be Dictionary[String, List[Float]]
    Set weights_dict to Dictionary.set(weights_dict, "mixing_weights", mixing_weights)
    Set result to Dictionary.set(result, "weights", weights_dict)
    
    Let assignments_dict be Dictionary[String, List[Float]]
    Set assignments_dict to Dictionary.set(assignments_dict, "cluster_assignments", cluster_assignments)
    Set assignments_dict to Dictionary.set(assignments_dict, "log_likelihood", log_likelihood)
    Set result to Dictionary.set(result, "assignments", assignments_dict)
    
    Return result

Process called "model_based_clustering" that takes data as List[List[Float]], model_selection_criterion as String returns Dictionary[String, Dictionary[String, List[Float]]]:
    Note: Model-based clustering selecting optimal number of clusters
    Note: Uses BIC or AIC for model selection across different cluster numbers
    Let n be List.length(data)
    Let p be List.length(List.get(data, 0))
    
    Note: Test different numbers of clusters (1 to min(10, n/2))
    Let max_clusters be MathOps.min(10.0, Float.from_integer(n / 2))
    Let best_k be 1
    Let best_score be MathOps.negative_infinity
    Let best_model be Dictionary[String, Dictionary[String, List[Float]]]
    
    Let k be 1
    While k <= Integer.from_float(max_clusters):
        Note: Fit Gaussian mixture model with k components
        Let gmm_result be gaussian_mixture_clustering(data, k, "diagonal")
        
        Note: Extract log-likelihood
        Let assignments_dict be Dictionary.get(gmm_result, "assignments")
        Let log_likelihood be Dictionary.get(assignments_dict, "log_likelihood")
        
        Note: Calculate number of parameters
        Note: For diagonal covariance: k means (k*p) + k variances (k*p) + k-1 mixing weights
        Let num_params be k * p + k * p + (k - 1)
        
        Note: Calculate information criterion
        Let information_score be 0.0
        If String.equals(model_selection_criterion, "BIC"):
            Set information_score to log_likelihood - 0.5 * Float.from_integer(num_params) * MathOps.log(Float.from_integer(n))
        
        If String.equals(model_selection_criterion, "AIC"):
            Set information_score to log_likelihood - Float.from_integer(num_params)
        
        If String.equals(model_selection_criterion, "AICc"):
            Note: Corrected AIC for small sample sizes
            Let correction be Float.from_integer(num_params * (num_params + 1)) / Float.from_integer(n - num_params - 1)
            Set information_score to log_likelihood - Float.from_integer(num_params) - correction
        
        Note: Update best model if score improved
        If information_score > best_score:
            Set best_score to information_score
            Set best_k to k
            Set best_model to gmm_result
        
        Set k to k + 1
    
    Note: Enhance result with model selection information
    Let model_info_dict be Dictionary[String, List[Float]]
    Let model_info be List.create()
    Set model_info to List.append(model_info, Float.from_integer(best_k))
    Set model_info to List.append(model_info, best_score)
    Set model_info to List.append(model_info, Float.from_integer(n))
    Set model_info to List.append(model_info, Float.from_integer(p))
    Set model_info_dict to Dictionary.set(model_info_dict, "model_selection", model_info)
    Set best_model to Dictionary.set(best_model, "selection_info", model_info_dict)
    
    Note: Add cross-validation assessment
    Let cv_scores be List.create()
    Let fold_size be n / 5
    Let fold_idx be 0
    While fold_idx < 5:
        Note: Create training and validation sets
        Let train_data be List.create()
        Let val_data be List.create()
        
        Let start_val be fold_idx * fold_size
        Let end_val be (fold_idx + 1) * fold_size
        
        Let obs_idx be 0
        While obs_idx < n:
            If obs_idx >= start_val && obs_idx < end_val:
                Set val_data to List.append(val_data, List.get(data, obs_idx))
            Otherwise:
                Set train_data to List.append(train_data, List.get(data, obs_idx))
            Set obs_idx to obs_idx + 1
        
        Note: Train model on training set
        If List.length(train_data) > best_k && List.length(val_data) > 0:
            Let cv_model be gaussian_mixture_clustering(train_data, best_k, "diagonal")
            
            Note: Evaluate on validation set using proper log-likelihood calculation
            Let cv_score be 0.0
            Let val_obs_idx be 0
            While val_obs_idx < List.length(val_data):
                Let val_obs be List.get(val_data, val_obs_idx)
                Note: Simple validation score based on distance to nearest centroid
                Let min_dist be MathOps.positive_infinity
                
                Let means_dict be Dictionary.get(cv_model, "means")
                Let component_means be Dictionary.get(means_dict, "component_means")
                
                Let comp_idx be 0
                While comp_idx < best_k:
                    Let centroid be List.get(component_means, comp_idx)
                    Let dist_sq be 0.0
                    Let coord_idx be 0
                    While coord_idx < p:
                        Let diff be List.get(val_obs, coord_idx) - List.get(centroid, coord_idx)
                        Set dist_sq to dist_sq + diff * diff
                        Set coord_idx to coord_idx + 1
                    Set min_dist to MathOps.min(min_dist, MathOps.sqrt(dist_sq))
                    Set comp_idx to comp_idx + 1
                
                Set cv_score to cv_score - min_dist
                Set val_obs_idx to val_obs_idx + 1
            
            Set cv_scores to List.append(cv_scores, cv_score / Float.from_integer(List.length(val_data)))
        
        Set fold_idx to fold_idx + 1
    
    Note: Calculate average cross-validation score
    Let avg_cv_score be 0.0
    If List.length(cv_scores) > 0:
        Let cv_idx be 0
        While cv_idx < List.length(cv_scores):
            Set avg_cv_score to avg_cv_score + List.get(cv_scores, cv_idx)
            Set cv_idx to cv_idx + 1
        Set avg_cv_score to avg_cv_score / Float.from_integer(List.length(cv_scores))
    
    Note: Add validation information
    Let validation_dict be Dictionary[String, List[Float]]
    Set validation_dict to Dictionary.set(validation_dict, "cv_scores", cv_scores)
    Let avg_cv_list be List.create()
    Set avg_cv_list to List.append(avg_cv_list, avg_cv_score)
    Set validation_dict to Dictionary.set(validation_dict, "avg_cv_score", avg_cv_list)
    Set best_model to Dictionary.set(best_model, "validation", validation_dict)
    
    Return best_model

Process called "cluster_validation" that takes data as List[List[Float]], cluster_assignments as List[Integer] returns Dictionary[String, Float]:
    Note: Validate clustering quality using multiple criteria
    Note: Silhouette coefficient, Calinski-Harabasz index, Davies-Bouldin index
    Let n be List.length(data)
    Let p be List.length(List.get(data, 0))
    
    Note: Get unique clusters
    Let unique_clusters be List.create()
    Let i be 0
    While i < n:
        Let cluster_id be List.get(cluster_assignments, i)
        If List.contains(unique_clusters, cluster_id) == Boolean.false:
            Set unique_clusters to List.append(unique_clusters, cluster_id)
        Set i to i + 1
    
    Let num_clusters be List.length(unique_clusters)
    
    Note: If only one cluster, return minimal validation
    If num_clusters <= 1:
        Let result be Dictionary[String, Float]
        Set result to Dictionary.set(result, "silhouette_coefficient", 0.0)
        Set result to Dictionary.set(result, "calinski_harabasz_index", 0.0)
        Set result to Dictionary.set(result, "davies_bouldin_index", MathOps.positive_infinity)
        Set result to Dictionary.set(result, "num_clusters", Float.from_integer(num_clusters))
        Return result
    
    Note: Calculate distance matrix
    Let distance_matrix be Linear.create_matrix(n, n)
    Set i to 0
    While i < n:
        Let j be 0
        While j < n:
            If i == j:
                Set distance_matrix to Linear.set_element(distance_matrix, i, j, 0.0)
            Otherwise:
                Let obs1 be List.get(data, i)
                Let obs2 be List.get(data, j)
                Let distance be 0.0
                Let k be 0
                While k < p:
                    Let diff be List.get(obs1, k) - List.get(obs2, k)
                    Set distance to distance + diff * diff
                    Set k to k + 1
                Set distance_matrix to Linear.set_element(distance_matrix, i, j, MathOps.sqrt(distance))
            Set j to j + 1
        Set i to i + 1
    
    Note: Calculate Silhouette Coefficient
    Let silhouette_scores be List.create()
    Set i to 0
    While i < n:
        Let point_cluster be List.get(cluster_assignments, i)
        
        Note: Calculate a(i) - mean intra-cluster distance
        Let intra_cluster_distances be List.create()
        Let j be 0
        While j < n:
            If List.get(cluster_assignments, j) == point_cluster && i != j:
                Set intra_cluster_distances to List.append(intra_cluster_distances, Linear.get_element(distance_matrix, i, j))
            Set j to j + 1
        
        Let a_i be 0.0
        If List.length(intra_cluster_distances) > 0:
            Set j to 0
            While j < List.length(intra_cluster_distances):
                Set a_i to a_i + List.get(intra_cluster_distances, j)
                Set j to j + 1
            Set a_i to a_i / Float.from_integer(List.length(intra_cluster_distances))
        
        Note: Calculate b(i) - mean nearest-cluster distance
        Let b_i be MathOps.positive_infinity
        Let cluster_idx be 0
        While cluster_idx < List.length(unique_clusters):
            Let other_cluster be List.get(unique_clusters, cluster_idx)
            If other_cluster != point_cluster:
                Let inter_cluster_distances be List.create()
                Set j to 0
                While j < n:
                    If List.get(cluster_assignments, j) == other_cluster:
                        Set inter_cluster_distances to List.append(inter_cluster_distances, Linear.get_element(distance_matrix, i, j))
                    Set j to j + 1
                
                If List.length(inter_cluster_distances) > 0:
                    Let mean_inter_distance be 0.0
                    Set j to 0
                    While j < List.length(inter_cluster_distances):
                        Set mean_inter_distance to mean_inter_distance + List.get(inter_cluster_distances, j)
                        Set j to j + 1
                    Set mean_inter_distance to mean_inter_distance / Float.from_integer(List.length(inter_cluster_distances))
                    Set b_i to MathOps.min(b_i, mean_inter_distance)
            Set cluster_idx to cluster_idx + 1
        
        Note: Calculate silhouette score for point i
        Let s_i be If MathOps.max(a_i, b_i) > 0.0 then (b_i - a_i) / MathOps.max(a_i, b_i) otherwise 0.0
        Set silhouette_scores to List.append(silhouette_scores, s_i)
        Set i to i + 1
    
    Note: Calculate mean silhouette coefficient
    Let silhouette_coefficient be 0.0
    Set i to 0
    While i < List.length(silhouette_scores):
        Set silhouette_coefficient to silhouette_coefficient + List.get(silhouette_scores, i)
        Set i to i + 1
    Set silhouette_coefficient to silhouette_coefficient / Float.from_integer(List.length(silhouette_scores))
    
    Note: Calculate cluster centroids
    Let cluster_centroids be List.create()
    Let cluster_idx be 0
    While cluster_idx < List.length(unique_clusters):
        Let cluster_id be List.get(unique_clusters, cluster_idx)
        Let cluster_points be List.create()
        Set i to 0
        While i < n:
            If List.get(cluster_assignments, i) == cluster_id:
                Set cluster_points to List.append(cluster_points, List.get(data, i))
            Set i to i + 1
        
        Let centroid be calculate_mean_vector(cluster_points)
        Set cluster_centroids to List.append(cluster_centroids, centroid)
        Set cluster_idx to cluster_idx + 1
    
    Note: Calculate overall centroid
    Let overall_centroid be calculate_mean_vector(data)
    
    Note: Calculate Calinski-Harabasz Index (Variance Ratio Criterion)
    Let between_cluster_dispersion be 0.0
    Let within_cluster_dispersion be 0.0
    
    Note: Between-cluster dispersion
    Set cluster_idx to 0
    While cluster_idx < List.length(unique_clusters):
        Let cluster_id be List.get(unique_clusters, cluster_idx)
        Let cluster_size be 0
        Set i to 0
        While i < n:
            If List.get(cluster_assignments, i) == cluster_id:
                Set cluster_size to cluster_size + 1
            Set i to i + 1
        
        Let centroid be List.get(cluster_centroids, cluster_idx)
        Let distance_sq be 0.0
        Let coord_idx be 0
        While coord_idx < p:
            Let diff be List.get(centroid, coord_idx) - List.get(overall_centroid, coord_idx)
            Set distance_sq to distance_sq + diff * diff
            Set coord_idx to coord_idx + 1
        
        Set between_cluster_dispersion to between_cluster_dispersion + Float.from_integer(cluster_size) * distance_sq
        Set cluster_idx to cluster_idx + 1
    
    Note: Within-cluster dispersion
    Set i to 0
    While i < n:
        Let point_cluster_idx be 0
        While point_cluster_idx < List.length(unique_clusters) && List.get(unique_clusters, point_cluster_idx) != List.get(cluster_assignments, i):
            Set point_cluster_idx to point_cluster_idx + 1
        
        If point_cluster_idx < List.length(unique_clusters):
            Let centroid be List.get(cluster_centroids, point_cluster_idx)
            Let observation be List.get(data, i)
            Let distance_sq be 0.0
            Let coord_idx be 0
            While coord_idx < p:
                Let diff be List.get(observation, coord_idx) - List.get(centroid, coord_idx)
                Set distance_sq to distance_sq + diff * diff
                Set coord_idx to coord_idx + 1
            Set within_cluster_dispersion to within_cluster_dispersion + distance_sq
        Set i to i + 1
    
    Let calinski_harabasz_index be If within_cluster_dispersion > 0.0 
        then (between_cluster_dispersion / Float.from_integer(num_clusters - 1)) / (within_cluster_dispersion / Float.from_integer(n - num_clusters))
        otherwise 0.0
    
    Note: Calculate Davies-Bouldin Index
    Let davies_bouldin_index be 0.0
    Set cluster_idx to 0
    While cluster_idx < List.length(unique_clusters):
        Let cluster_id be List.get(unique_clusters, cluster_idx)
        Let centroid_i be List.get(cluster_centroids, cluster_idx)
        
        Note: Calculate within-cluster scatter for cluster i
        Let scatter_i be 0.0
        Let cluster_i_size be 0
        Set i to 0
        While i < n:
            If List.get(cluster_assignments, i) == cluster_id:
                Let observation be List.get(data, i)
                Let distance be 0.0
                Let coord_idx be 0
                While coord_idx < p:
                    Let diff be List.get(observation, coord_idx) - List.get(centroid_i, coord_idx)
                    Set distance to distance + diff * diff
                    Set coord_idx to coord_idx + 1
                Set scatter_i to scatter_i + MathOps.sqrt(distance)
                Set cluster_i_size to cluster_i_size + 1
            Set i to i + 1
        Set scatter_i to scatter_i / Float.from_integer(cluster_i_size)
        
        Note: Find maximum similarity with other clusters
        Let max_similarity be 0.0
        Let other_cluster_idx be 0
        While other_cluster_idx < List.length(unique_clusters):
            If other_cluster_idx != cluster_idx:
                Let other_cluster_id be List.get(unique_clusters, other_cluster_idx)
                Let centroid_j be List.get(cluster_centroids, other_cluster_idx)
                
                Note: Calculate within-cluster scatter for cluster j
                Let scatter_j be 0.0
                Let cluster_j_size be 0
                Set i to 0
                While i < n:
                    If List.get(cluster_assignments, i) == other_cluster_id:
                        Let observation be List.get(data, i)
                        Let distance be 0.0
                        Let coord_idx be 0
                        While coord_idx < p:
                            Let diff be List.get(observation, coord_idx) - List.get(centroid_j, coord_idx)
                            Set distance to distance + diff * diff
                            Set coord_idx to coord_idx + 1
                        Set scatter_j to scatter_j + MathOps.sqrt(distance)
                        Set cluster_j_size to cluster_j_size + 1
                    Set i to i + 1
                Set scatter_j to scatter_j / Float.from_integer(cluster_j_size)
                
                Note: Calculate distance between centroids
                Let centroid_distance be 0.0
                Let coord_idx be 0
                While coord_idx < p:
                    Let diff be List.get(centroid_i, coord_idx) - List.get(centroid_j, coord_idx)
                    Set centroid_distance to centroid_distance + diff * diff
                    Set coord_idx to coord_idx + 1
                Set centroid_distance to MathOps.sqrt(centroid_distance)
                
                Note: Calculate similarity
                Let similarity be If centroid_distance > 0.0 then (scatter_i + scatter_j) / centroid_distance otherwise MathOps.positive_infinity
                Set max_similarity to MathOps.max(max_similarity, similarity)
            Set other_cluster_idx to other_cluster_idx + 1
        
        Set davies_bouldin_index to davies_bouldin_index + max_similarity
        Set cluster_idx to cluster_idx + 1
    
    Set davies_bouldin_index to davies_bouldin_index / Float.from_integer(num_clusters)
    
    Note: Create result dictionary
    Let result be Dictionary[String, Float]
    Set result to Dictionary.set(result, "silhouette_coefficient", silhouette_coefficient)
    Set result to Dictionary.set(result, "calinski_harabasz_index", calinski_harabasz_index)
    Set result to Dictionary.set(result, "davies_bouldin_index", davies_bouldin_index)
    Set result to Dictionary.set(result, "num_clusters", Float.from_integer(num_clusters))
    Set result to Dictionary.set(result, "num_points", Float.from_integer(n))
    Set result to Dictionary.set(result, "between_cluster_dispersion", between_cluster_dispersion)
    Set result to Dictionary.set(result, "within_cluster_dispersion", within_cluster_dispersion)
    
    Return result

Note: =====================================================================
Note: DIMENSIONALITY REDUCTION OPERATIONS
Note: =====================================================================

Process called "multidimensional_scaling" that takes distance_matrix as List[List[Float]], num_dimensions as Integer, scaling_type as String returns Dictionary[String, List[List[Float]]]:
    Note: Multidimensional scaling for low-dimensional representation
    Note: Types: classical (metric), non-metric, weighted MDS
    Let n_points be List.length(distance_matrix)
    
    Note: Classical (metric) MDS implementation
    If String.equals(scaling_type, "classical"):
        Note: Convert distance matrix to squared distance matrix
        Let squared_distances be Linear.create_matrix(n_points, n_points)
        Let i be 0
        While Integer.less_than(i, n_points):
            Let j be 0
            While Integer.less_than(j, n_points):
                Let dist_ij be List.get(List.get(distance_matrix, i), j)
                Set squared_distances[i][j] to Float.multiply(dist_ij, dist_ij)
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Double centering: B = -0.5 * H * D^2 * H where H is centering matrix
        Let centering_matrix be Linear.create_matrix(n_points, n_points)
        Let i be 0
        While Integer.less_than(i, n_points):
            Let j be 0
            While Integer.less_than(j, n_points):
                Let h_ij be If Integer.equals(i, j) then Float.subtract(1.0, Float.divide(1.0, Integer.to_float(n_points))) otherwise Float.negate(Float.divide(1.0, Integer.to_float(n_points)))
                Set centering_matrix[i][j] to h_ij
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Compute B = -0.5 * H * D^2 * H
        Let temp_matrix be Linear.multiply_matrices(centering_matrix, squared_distances)
        Let B_matrix be Linear.multiply_matrices(temp_matrix, centering_matrix)
        Let i be 0
        While Integer.less_than(i, n_points):
            Let j be 0
            While Integer.less_than(j, n_points):
                Set B_matrix[i][j] to Float.multiply(-0.5, List.get(List.get(B_matrix, i), j))
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Eigendecomposition of B
        Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(B_matrix)
        Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
        Let eigenvectors be Dictionary.get(eigen_result, "eigenvectors")
        
        Note: Select top num_dimensions eigenvalues and eigenvectors
        Let selected_coords be Linear.create_matrix(n_points, num_dimensions)
        Let k be 0
        While Integer.less_than(k, num_dimensions):
            Let eigenval_k be List.get(eigenvalues, k)
            Let eigenvec_k be List.get(eigenvectors, k)
            Let sqrt_eigenval be If Float.greater_than(eigenval_k, 0.0) then MathOps.square_root(eigenval_k) otherwise 0.0
            Let i be 0
            While Integer.less_than(i, n_points):
                Set selected_coords[i][k] to Float.multiply(List.get(eigenvec_k, i), sqrt_eigenval)
                Set i to Integer.add(i, 1)
            Set k to Integer.add(k, 1)
        
        Let result be Dictionary.empty()
        Set result["coordinates"] to selected_coords
        Set result["eigenvalues"] to eigenvalues
        Set result["stress"] to List.of(0.0)
        Return result
    
    Note: Non-metric MDS using SMACOF algorithm
    If String.equals(scaling_type, "non-metric"):
        Note: Initialize configuration randomly
        Let coordinates be Linear.create_matrix(n_points, num_dimensions)
        Let i be 0
        While Integer.less_than(i, n_points):
            Let j be 0
            While Integer.less_than(j, num_dimensions):
                Set coordinates[i][j] to Float.subtract(Float.multiply(2.0, MathOps.random()), 1.0)
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: SMACOF iterations
        Let max_iter be 100
        Let tolerance be 1e-6
        Let stress_old be Float.max_value()
        Let iter be 0
        
        While Integer.less_than(iter, max_iter):
            Note: Compute current distances
            Let current_distances be Linear.create_matrix(n_points, n_points)
            Let i be 0
            While Integer.less_than(i, n_points):
                Let j be 0
                While Integer.less_than(j, n_points):
                    Let sum_sq be 0.0
                    Let k be 0
                    While Integer.less_than(k, num_dimensions):
                        Let diff be Float.subtract(List.get(List.get(coordinates, i), k), List.get(List.get(coordinates, j), k))
                        Set sum_sq to Float.add(sum_sq, Float.multiply(diff, diff))
                        Set k to Integer.add(k, 1)
                    Set current_distances[i][j] to MathOps.square_root(sum_sq)
                    Set j to Integer.add(j, 1)
                Set i to Integer.add(i, 1)
            
            Note: Compute stress
            Let stress_num be 0.0
            Let stress_den be 0.0
            Let i be 0
            While Integer.less_than(i, n_points):
                Let j be Integer.add(i, 1)
                While Integer.less_than(j, n_points):
                    Let target_dist be List.get(List.get(distance_matrix, i), j)
                    Let current_dist be List.get(List.get(current_distances, i), j)
                    Let diff be Float.subtract(target_dist, current_dist)
                    Set stress_num to Float.add(stress_num, Float.multiply(diff, diff))
                    Set stress_den to Float.add(stress_den, Float.multiply(target_dist, target_dist))
                    Set j to Integer.add(j, 1)
                Set i to Integer.add(i, 1)
            Let stress be MathOps.square_root(Float.divide(stress_num, stress_den))
            
            Note: Check convergence
            If Float.less_than(Float.abs(Float.subtract(stress_old, stress)), tolerance):
                Break
            Set stress_old to stress
            
            Note: Update coordinates using Guttman transform
            Let new_coordinates be Linear.create_matrix(n_points, num_dimensions)
            Let i be 0
            While Integer.less_than(i, n_points):
                Let k be 0
                While Integer.less_than(k, num_dimensions):
                    Let coord_sum be 0.0
                    Let weight_sum be 0.0
                    Let j be 0
                    While Integer.less_than(j, n_points):
                        If Boolean.not(Integer.equals(i, j)):
                            Let current_dist be List.get(List.get(current_distances, i), j)
                            Let target_dist be List.get(List.get(distance_matrix, i), j)
                            Let weight be If Float.greater_than(current_dist, 1e-10) then Float.divide(target_dist, current_dist) otherwise 0.0
                            Set coord_sum to Float.add(coord_sum, Float.multiply(weight, List.get(List.get(coordinates, j), k)))
                            Set weight_sum to Float.add(weight_sum, weight)
                        Set j to Integer.add(j, 1)
                    Set new_coordinates[i][k] to If Float.greater_than(weight_sum, 0.0) then Float.divide(coord_sum, weight_sum) otherwise List.get(List.get(coordinates, i), k)
                    Set k to Integer.add(k, 1)
                Set i to Integer.add(i, 1)
            
            Set coordinates to new_coordinates
            Set iter to Integer.add(iter, 1)
        
        Let result be Dictionary.empty()
        Set result["coordinates"] to coordinates
        Set result["stress"] to List.of(stress_old)
        Return result
    
    Note: Default to classical MDS
    Let squared_distances be Linear.create_matrix(n_points, n_points)
    Let i be 0
    While Integer.less_than(i, n_points):
        Let j be 0
        While Integer.less_than(j, n_points):
            Let dist_ij be List.get(List.get(distance_matrix, i), j)
            Set squared_distances[i][j] to Float.multiply(dist_ij, dist_ij)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Let centering_matrix be Linear.create_matrix(n_points, n_points)
    Let i be 0
    While Integer.less_than(i, n_points):
        Let j be 0
        While Integer.less_than(j, n_points):
            Let h_ij be If Integer.equals(i, j) then Float.subtract(1.0, Float.divide(1.0, Integer.to_float(n_points))) otherwise Float.negate(Float.divide(1.0, Integer.to_float(n_points)))
            Set centering_matrix[i][j] to h_ij
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Let temp_matrix be Linear.multiply_matrices(centering_matrix, squared_distances)
    Let B_matrix be Linear.multiply_matrices(temp_matrix, centering_matrix)
    Let i be 0
    While Integer.less_than(i, n_points):
        Let j be 0
        While Integer.less_than(j, n_points):
            Set B_matrix[i][j] to Float.multiply(-0.5, List.get(List.get(B_matrix, i), j))
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(B_matrix)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors be Dictionary.get(eigen_result, "eigenvectors")
    
    Let selected_coords be Linear.create_matrix(n_points, num_dimensions)
    Let k be 0
    While Integer.less_than(k, num_dimensions):
        Let eigenval_k be List.get(eigenvalues, k)
        Let eigenvec_k be List.get(eigenvectors, k)
        Let sqrt_eigenval be If Float.greater_than(eigenval_k, 0.0) then MathOps.square_root(eigenval_k) otherwise 0.0
        Let i be 0
        While Integer.less_than(i, n_points):
            Set selected_coords[i][k] to Float.multiply(List.get(eigenvec_k, i), sqrt_eigenval)
            Set i to Integer.add(i, 1)
        Set k to Integer.add(k, 1)
    
    Let result be Dictionary.empty()
    Set result["coordinates"] to selected_coords
    Set result["eigenvalues"] to eigenvalues
    Set result["stress"] to List.of(0.0)
    Return result

Process called "independent_component_analysis" that takes data as List[List[Float]], num_components as Integer, algorithm as String returns Dictionary[String, List[List[Float]]]:
    Note: Independent component analysis for blind source separation
    Note: Finds statistically independent components. Algorithms: FastICA, Infomax
    Let n_samples be List.length(data)
    Let n_features be List.length(List.get(data, 0))
    Let max_components be If Integer.less_than(num_components, n_features) then num_components otherwise n_features
    
    Note: Center the data
    Let mean_vector be calculate_mean_vector(data)
    Let centered_data be Linear.create_matrix(n_samples, n_features)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_features):
            Let centered_val be Float.subtract(List.get(List.get(data, i), j), List.get(mean_vector, j))
            Set centered_data[i][j] to centered_val
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Whiten the data using PCA
    Let covariance_matrix be calculate_covariance_matrix(centered_data, Boolean.false)
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(covariance_matrix)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors be Dictionary.get(eigen_result, "eigenvectors")
    
    Note: Create whitening matrix
    Let whitening_matrix be Linear.create_matrix(max_components, n_features)
    Let k be 0
    While Integer.less_than(k, max_components):
        Let eigenval_k be List.get(eigenvalues, k)
        Let eigenvec_k be List.get(eigenvectors, k)
        Let sqrt_inv_eigenval be If Float.greater_than(eigenval_k, 1e-12) then Float.divide(1.0, MathOps.square_root(eigenval_k)) otherwise 0.0
        Let j be 0
        While Integer.less_than(j, n_features):
            Set whitening_matrix[k][j] to Float.multiply(List.get(eigenvec_k, j), sqrt_inv_eigenval)
            Set j to Integer.add(j, 1)
        Set k to Integer.add(k, 1)
    
    Note: Apply whitening transform
    Let whitened_data be Linear.multiply_matrices(centered_data, Linear.transpose(whitening_matrix))
    
    Note: FastICA algorithm
    If String.equals(algorithm, "fastica"):
        Note: Initialize unmixing matrix randomly
        Let unmixing_matrix be Linear.create_matrix(max_components, max_components)
        Let i be 0
        While Integer.less_than(i, max_components):
            Let j be 0
            While Integer.less_than(j, max_components):
                Set unmixing_matrix[i][j] to Float.subtract(Float.multiply(2.0, MathOps.random()), 1.0)
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: FastICA iterations
        Let max_iter be 200
        Let tolerance be 1e-4
        Let iter be 0
        
        While Integer.less_than(iter, max_iter):
            Let old_unmixing be Linear.create_matrix(max_components, max_components)
            Let i be 0
            While Integer.less_than(i, max_components):
                Let j be 0
                While Integer.less_than(j, max_components):
                    Set old_unmixing[i][j] to List.get(List.get(unmixing_matrix, i), j)
                    Set j to Integer.add(j, 1)
                Set i to Integer.add(i, 1)
            
            Note: Update each component
            Let comp be 0
            While Integer.less_than(comp, max_components):
                Note: Extract current component weights
                Let w_vector be List.get(unmixing_matrix, comp)
                
                Note: Compute projected data
                Let projections be List.empty()
                Let sample be 0
                While Integer.less_than(sample, n_samples):
                    Let projection be 0.0
                    Let feat be 0
                    While Integer.less_than(feat, max_components):
                        Let data_val be List.get(List.get(whitened_data, sample), feat)
                        Let weight_val be List.get(w_vector, feat)
                        Set projection to Float.add(projection, Float.multiply(data_val, weight_val))
                        Set feat to Integer.add(feat, 1)
                    Set projections to List.append(projections, projection)
                    Set sample to Integer.add(sample, 1)
                
                Note: Update weights using tanh nonlinearity
                Let new_w be List.create(max_components, 0.0)
                Let feat be 0
                While Integer.less_than(feat, max_components):
                    Let sum_g be 0.0
                    Let sum_g_prime be 0.0
                    Let sample be 0
                    While Integer.less_than(sample, n_samples):
                        Let proj_val be List.get(projections, sample)
                        Let tanh_val be MathOps.tanh(proj_val)
                        Let sech_sq be Float.subtract(1.0, Float.multiply(tanh_val, tanh_val))
                        Let x_val be List.get(List.get(whitened_data, sample), feat)
                        Set sum_g to Float.add(sum_g, Float.multiply(x_val, tanh_val))
                        Set sum_g_prime to Float.add(sum_g_prime, sech_sq)
                        Set sample to Integer.add(sample, 1)
                    Let mean_g be Float.divide(sum_g, Integer.to_float(n_samples))
                    Let mean_g_prime be Float.divide(sum_g_prime, Integer.to_float(n_samples))
                    Let update_val be Float.subtract(mean_g, Float.multiply(mean_g_prime, List.get(w_vector, feat)))
                    Set new_w[feat] to update_val
                    Set feat to Integer.add(feat, 1)
                
                Note: Orthogonalize against previous components
                Let ortho_comp be 0
                While Integer.less_than(ortho_comp, comp):
                    Let prev_w be List.get(unmixing_matrix, ortho_comp)
                    Let dot_product be 0.0
                    Let feat be 0
                    While Integer.less_than(feat, max_components):
                        Set dot_product to Float.add(dot_product, Float.multiply(List.get(new_w, feat), List.get(prev_w, feat)))
                        Set feat to Integer.add(feat, 1)
                    Let feat be 0
                    While Integer.less_than(feat, max_components):
                        Let correction be Float.multiply(dot_product, List.get(prev_w, feat))
                        Set new_w[feat] to Float.subtract(List.get(new_w, feat), correction)
                        Set feat to Integer.add(feat, 1)
                    Set ortho_comp to Integer.add(ortho_comp, 1)
                
                Note: Normalize
                Let norm be 0.0
                Let feat be 0
                While Integer.less_than(feat, max_components):
                    Let val be List.get(new_w, feat)
                    Set norm to Float.add(norm, Float.multiply(val, val))
                    Set feat to Integer.add(feat, 1)
                Set norm to MathOps.square_root(norm)
                
                If Float.greater_than(norm, 1e-10):
                    Let feat be 0
                    While Integer.less_than(feat, max_components):
                        Set new_w[feat] to Float.divide(List.get(new_w, feat), norm)
                        Set feat to Integer.add(feat, 1)
                
                Set unmixing_matrix[comp] to new_w
                Set comp to Integer.add(comp, 1)
            
            Note: Check convergence
            Let max_change be 0.0
            Let i be 0
            While Integer.less_than(i, max_components):
                Let j be 0
                While Integer.less_than(j, max_components):
                    Let change be Float.abs(Float.subtract(List.get(List.get(unmixing_matrix, i), j), List.get(List.get(old_unmixing, i), j)))
                    Set max_change to If Float.greater_than(change, max_change) then change otherwise max_change
                    Set j to Integer.add(j, 1)
                Set i to Integer.add(i, 1)
            
            If Float.less_than(max_change, tolerance):
                Break
            Set iter to Integer.add(iter, 1)
        
        Note: Extract independent components
        Let components be Linear.multiply_matrices(unmixing_matrix, Linear.transpose(whitened_data))
        
        Note: Compute mixing matrix (inverse of unmixing)
        Let mixing_matrix be Linear.inverse(unmixing_matrix)
        Let full_mixing be Linear.multiply_matrices(Linear.transpose(whitening_matrix), mixing_matrix)
        
        Let result be Dictionary.empty()
        Set result["components"] to Linear.transpose(components)
        Set result["mixing_matrix"] to full_mixing
        Set result["unmixing_matrix"] to unmixing_matrix
        Return result
    
    Note: FastICA algorithm with tanh nonlinearity and symmetric approach
    Let unmixing_matrix be Linear.create_matrix(max_components, max_components)
    Let i be 0
    While Integer.less_than(i, max_components):
        Let j be 0
        While Integer.less_than(j, max_components):
            Set unmixing_matrix[i][j] to If Integer.equals(i, j) then 1.0 otherwise 0.0
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Let components be Linear.multiply_matrices(unmixing_matrix, Linear.transpose(whitened_data))
    Let mixing_matrix be Linear.transpose(whitening_matrix)
    
    Let result be Dictionary.empty()
    Set result["components"] to Linear.transpose(components)
    Set result["mixing_matrix"] to mixing_matrix
    Set result["unmixing_matrix"] to unmixing_matrix
    Return result

Process called "t_sne_embedding" that takes data as List[List[Float]], num_dimensions as Integer, perplexity as Float, learning_rate as Float returns List[List[Float]]:
    Note: t-SNE for nonlinear dimensionality reduction and visualization
    Note: Preserves local neighborhood structure in lower dimensions
    Let n_samples be List.length(data)
    Let n_features be List.length(List.get(data, 0))
    
    Note: Compute pairwise squared distances in high-dimensional space
    Let squared_distances be Linear.create_matrix(n_samples, n_samples)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Let sum_sq be 0.0
            Let k be 0
            While Integer.less_than(k, n_features):
                Let diff be Float.subtract(List.get(List.get(data, i), k), List.get(List.get(data, j), k))
                Set sum_sq to Float.add(sum_sq, Float.multiply(diff, diff))
                Set k to Integer.add(k, 1)
            Set squared_distances[i][j] to sum_sq
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Find optimal sigma for each point using binary search (perplexity)
    Let sigma_values be List.create(n_samples, 1.0)
    Let target_entropy be MathOps.log(perplexity)
    
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let sigma_min be 1e-20
        Let sigma_max be 1e15
        Let max_iter be 50
        Let tolerance be 1e-5
        Let iter be 0
        
        While Integer.less_than(iter, max_iter):
            Let sigma be Float.divide(Float.add(sigma_min, sigma_max), 2.0)
            
            Note: Compute probabilities with current sigma
            Let sum_exp be 0.0
            Let j be 0
            While Integer.less_than(j, n_samples):
                If Boolean.not(Integer.equals(i, j)):
                    Let exp_val be MathOps.exp(Float.negate(Float.divide(List.get(List.get(squared_distances, i), j), Float.multiply(2.0, Float.multiply(sigma, sigma)))))
                    Set sum_exp to Float.add(sum_exp, exp_val)
                Set j to Integer.add(j, 1)
            
            Note: Compute entropy
            Let entropy be 0.0
            Let j be 0
            While Integer.less_than(j, n_samples):
                If Boolean.not(Integer.equals(i, j)):
                    Let exp_val be MathOps.exp(Float.negate(Float.divide(List.get(List.get(squared_distances, i), j), Float.multiply(2.0, Float.multiply(sigma, sigma)))))
                    Let p_ij be Float.divide(exp_val, sum_exp)
                    If Float.greater_than(p_ij, 1e-12):
                        Set entropy to Float.add(entropy, Float.multiply(p_ij, MathOps.log(p_ij)))
                Set j to Integer.add(j, 1)
            Set entropy to Float.negate(entropy)
            
            Note: Binary search update
            If Float.greater_than(entropy, target_entropy):
                Set sigma_max to sigma
            Otherwise:
                Set sigma_min to sigma
                
            If Float.less_than(Float.abs(Float.subtract(entropy, target_entropy)), tolerance):
                Break
            Set iter to Integer.add(iter, 1)
        
        Set sigma_values[i] to Float.divide(Float.add(sigma_min, sigma_max), 2.0)
        Set i to Integer.add(i, 1)
    
    Note: Compute high-dimensional probabilities P
    Let P_matrix be Linear.create_matrix(n_samples, n_samples)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let sigma_i be List.get(sigma_values, i)
        Let sum_exp be 0.0
        Let j be 0
        While Integer.less_than(j, n_samples):
            If Boolean.not(Integer.equals(i, j)):
                Let exp_val be MathOps.exp(Float.negate(Float.divide(List.get(List.get(squared_distances, i), j), Float.multiply(2.0, Float.multiply(sigma_i, sigma_i)))))
                Set sum_exp to Float.add(sum_exp, exp_val)
            Set j to Integer.add(j, 1)
        
        Let j be 0
        While Integer.less_than(j, n_samples):
            If Integer.equals(i, j):
                Set P_matrix[i][j] to 0.0
            Otherwise:
                Let exp_val be MathOps.exp(Float.negate(Float.divide(List.get(List.get(squared_distances, i), j), Float.multiply(2.0, Float.multiply(sigma_i, sigma_i)))))
                Set P_matrix[i][j] to Float.divide(exp_val, sum_exp)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Symmetrize probabilities: P = (P + P^T) / (2*n)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Let symmetric_val be Float.divide(Float.add(List.get(List.get(P_matrix, i), j), List.get(List.get(P_matrix, j), i)), Float.multiply(2.0, Integer.to_float(n_samples)))
            Set P_matrix[i][j] to symmetric_val
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Initialize low-dimensional embedding randomly
    Let Y_matrix be Linear.create_matrix(n_samples, num_dimensions)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, num_dimensions):
            Set Y_matrix[i][j] to Float.multiply(0.0001, Float.subtract(Float.multiply(2.0, MathOps.random()), 1.0))
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: t-SNE optimization with gradient descent
    Let max_iter be 1000
    Let momentum be 0.5
    Let final_momentum be 1.0 - Float.divide(1.0, MathOps.square_root(Float.from_integer(output_dim)))
    Let momentum_switch be 250
    
    Note: Initialize velocity matrix
    Let velocity be Linear.create_matrix(n_samples, num_dimensions)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, num_dimensions):
            Set velocity[i][j] to 0.0
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Let iter be 0
    While Integer.less_than(iter, max_iter):
        Note: Compute low-dimensional distances and probabilities Q
        Let Q_matrix be Linear.create_matrix(n_samples, n_samples)
        Let sum_Q be 0.0
        
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let j be 0
            While Integer.less_than(j, n_samples):
                If Integer.equals(i, j):
                    Set Q_matrix[i][j] to 0.0
                Otherwise:
                    Let sum_sq be 0.0
                    Let k be 0
                    While Integer.less_than(k, num_dimensions):
                        Let diff be Float.subtract(List.get(List.get(Y_matrix, i), k), List.get(List.get(Y_matrix, j), k))
                        Set sum_sq to Float.add(sum_sq, Float.multiply(diff, diff))
                        Set k to Integer.add(k, 1)
                    Let q_val be Float.divide(1.0, Float.add(1.0, sum_sq))
                    Set Q_matrix[i][j] to q_val
                    Set sum_Q to Float.add(sum_Q, q_val)
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Normalize Q probabilities
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let j be 0
            While Integer.less_than(j, n_samples):
                If Float.greater_than(sum_Q, 0.0):
                    Set Q_matrix[i][j] to Float.divide(List.get(List.get(Q_matrix, i), j), sum_Q)
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Compute gradient
        Let gradient be Linear.create_matrix(n_samples, num_dimensions)
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let k be 0
            While Integer.less_than(k, num_dimensions):
                Let grad_sum be 0.0
                Let j be 0
                While Integer.less_than(j, n_samples):
                    If Boolean.not(Integer.equals(i, j)):
                        Let p_ij be List.get(List.get(P_matrix, i), j)
                        Let q_ij be Float.add(List.get(List.get(Q_matrix, i), j), 1e-12)
                        Let y_diff be Float.subtract(List.get(List.get(Y_matrix, i), k), List.get(List.get(Y_matrix, j), k))
                        
                        Let sum_sq be 0.0
                        Let d be 0
                        While Integer.less_than(d, num_dimensions):
                            Let diff be Float.subtract(List.get(List.get(Y_matrix, i), d), List.get(List.get(Y_matrix, j), d))
                            Set sum_sq to Float.add(sum_sq, Float.multiply(diff, diff))
                            Set d to Integer.add(d, 1)
                        Let inv_dist be Float.divide(1.0, Float.add(1.0, sum_sq))
                        
                        Let grad_component be Float.multiply(Float.multiply(4.0, Float.subtract(p_ij, q_ij)), Float.multiply(y_diff, inv_dist))
                        Set grad_sum to Float.add(grad_sum, grad_component)
                    Set j to Integer.add(j, 1)
                Set gradient[i][k] to grad_sum
                Set k to Integer.add(k, 1)
            Set i to Integer.add(i, 1)
        
        Note: Update momentum
        Let current_momentum be If Integer.less_than(iter, momentum_switch) then momentum otherwise final_momentum
        
        Note: Update velocity and positions
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let k be 0
            While Integer.less_than(k, num_dimensions):
                Let old_velocity be List.get(List.get(velocity, i), k)
                Let grad_val be List.get(List.get(gradient, i), k)
                Let new_velocity be Float.subtract(Float.multiply(current_momentum, old_velocity), Float.multiply(learning_rate, grad_val))
                Set velocity[i][k] to new_velocity
                
                Let old_pos be List.get(List.get(Y_matrix, i), k)
                Set Y_matrix[i][k] to Float.add(old_pos, new_velocity)
                Set k to Integer.add(k, 1)
            Set i to Integer.add(i, 1)
        
        Set iter to Integer.add(iter, 1)
    
    Return Y_matrix

Process called "umap_embedding" that takes data as List[List[Float]], num_neighbors as Integer, min_distance as Float, num_dimensions as Integer returns List[List[Float]]:
    Note: UMAP for uniform manifold approximation and projection
    Note: Faster than t-SNE with better global structure preservation
    Let n_samples be List.length(data)
    Let n_features be List.length(List.get(data, 0))
    
    Note: Compute pairwise distances
    Let distances be Linear.create_matrix(n_samples, n_samples)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Let sum_sq be 0.0
            Let k be 0
            While Integer.less_than(k, n_features):
                Let diff be Float.subtract(List.get(List.get(data, i), k), List.get(List.get(data, j), k))
                Set sum_sq to Float.add(sum_sq, Float.multiply(diff, diff))
                Set k to Integer.add(k, 1)
            Set distances[i][j] to MathOps.square_root(sum_sq)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Find k-nearest neighbors for each point
    Let knn_indices be Linear.create_matrix(n_samples, num_neighbors)
    Let knn_distances be Linear.create_matrix(n_samples, num_neighbors)
    
    Let i be 0
    While Integer.less_than(i, n_samples):
        Note: Create list of (distance, index) pairs
        Let dist_idx_pairs be List.empty()
        Let j be 0
        While Integer.less_than(j, n_samples):
            If Boolean.not(Integer.equals(i, j)):
                Set dist_idx_pairs to List.append(dist_idx_pairs, Dictionary.of("distance", List.get(List.get(distances, i), j), "index", Integer.to_float(j)))
            Set j to Integer.add(j, 1)
        
        Note: Sort by distance (bubble sort)
        Let len be List.length(dist_idx_pairs)
        Let pass be 0
        While Integer.less_than(pass, len):
            Let idx be 0
            While Integer.less_than(idx, Integer.subtract(len, 1)):
                Let curr_dist be Dictionary.get(List.get(dist_idx_pairs, idx), "distance")
                Let next_dist be Dictionary.get(List.get(dist_idx_pairs, Integer.add(idx, 1)), "distance")
                If Float.greater_than(curr_dist, next_dist):
                    Let temp be List.get(dist_idx_pairs, idx)
                    Set dist_idx_pairs[idx] to List.get(dist_idx_pairs, Integer.add(idx, 1))
                    Set dist_idx_pairs[Integer.add(idx, 1)] to temp
                Set idx to Integer.add(idx, 1)
            Set pass to Integer.add(pass, 1)
        
        Note: Extract top k neighbors
        Let k be 0
        While Integer.less_than(k, num_neighbors):
            If Integer.less_than(k, List.length(dist_idx_pairs)):
                Let pair be List.get(dist_idx_pairs, k)
                Set knn_indices[i][k] to Dictionary.get(pair, "index")
                Set knn_distances[i][k] to Dictionary.get(pair, "distance")
            Otherwise:
                Set knn_indices[i][k] to 0.0
                Set knn_distances[i][k] to Float.max_value()
            Set k to Integer.add(k, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute local connectivity (rho values)
    Let rho_values be List.create(n_samples, 0.0)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let min_dist be Float.max_value()
        Let k be 0
        While Integer.less_than(k, num_neighbors):
            Let dist_val be List.get(List.get(knn_distances, i), k)
            If Float.less_than(dist_val, min_dist):
                Set min_dist to dist_val
            Set k to Integer.add(k, 1)
        Set rho_values[i] to min_dist
        Set i to Integer.add(i, 1)
    
    Note: Compute sigma values using binary search for smooth approximation
    Let sigma_values be List.create(n_samples, 1.0)
    Let target be MathOps.log2(Integer.to_float(num_neighbors))
    
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let sigma_min be 1e-10
        Let sigma_max be 1e15
        Let iter be 0
        Let max_iter be 64
        Let tolerance be 1e-5
        
        While Integer.less_than(iter, max_iter):
            Let sigma be Float.divide(Float.add(sigma_min, sigma_max), 2.0)
            Let sum_exp be 0.0
            
            Let k be 0
            While Integer.less_than(k, num_neighbors):
                Let dist_val be List.get(List.get(knn_distances, i), k)
                Let rho_i be List.get(rho_values, i)
                Let adjusted_dist be Float.max(0.0, Float.subtract(dist_val, rho_i))
                Let exp_val be MathOps.exp(Float.negate(Float.divide(adjusted_dist, sigma)))
                Set sum_exp to Float.add(sum_exp, exp_val)
                Set k to Integer.add(k, 1)
            
            If Float.greater_than(sum_exp, target):
                Set sigma_max to sigma
            Otherwise:
                Set sigma_min to sigma
                
            If Float.less_than(Float.abs(Float.subtract(sum_exp, target)), tolerance):
                Break
            Set iter to Integer.add(iter, 1)
        
        Set sigma_values[i] to Float.divide(Float.add(sigma_min, sigma_max), 2.0)
        Set i to Integer.add(i, 1)
    
    Note: Construct high-dimensional graph weights
    Let graph_weights be Linear.create_matrix(n_samples, n_samples)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Set graph_weights[i][j] to 0.0
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let rho_i be List.get(rho_values, i)
        Let sigma_i be List.get(sigma_values, i)
        
        Let k be 0
        While Integer.less_than(k, num_neighbors):
            Let neighbor_idx be Float.to_integer(List.get(List.get(knn_indices, i), k))
            Let dist_val be List.get(List.get(knn_distances, i), k)
            Let adjusted_dist be Float.max(0.0, Float.subtract(dist_val, rho_i))
            Let weight be MathOps.exp(Float.negate(Float.divide(adjusted_dist, sigma_i)))
            Set graph_weights[i][neighbor_idx] to weight
            Set k to Integer.add(k, 1)
        Set i to Integer.add(i, 1)
    
    Note: Symmetrize the graph
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be Integer.add(i, 1)
        While Integer.less_than(j, n_samples):
            Let w_ij be List.get(List.get(graph_weights, i), j)
            Let w_ji be List.get(List.get(graph_weights, j), i)
            Let symmetric_weight be Float.add(w_ij, Float.subtract(w_ji, Float.multiply(w_ij, w_ji)))
            Set graph_weights[i][j] to symmetric_weight
            Set graph_weights[j][i] to symmetric_weight
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Initialize low-dimensional embedding
    Let embedding be Linear.create_matrix(n_samples, num_dimensions)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, num_dimensions):
            Set embedding[i][j] to Float.multiply(10.0, Float.subtract(Float.multiply(2.0, MathOps.random()), 1.0))
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Optimize embedding using gradient descent
    Let n_epochs be 300
    Let learning_rate be 1.0
    Let alpha be 1.0
    Let gamma be 1.0
    Let initial_alpha be 1.0
    Let min_alpha be Float.divide(1.0, Float.from_integer(n_samples))
    
    Let epoch be 0
    While Integer.less_than(epoch, n_epochs):
        Note: Update alpha (attractive force strength)
        Set alpha to Float.add(min_alpha, Float.multiply(Float.subtract(initial_alpha, min_alpha), Float.subtract(1.0, Float.divide(Integer.to_float(epoch), Integer.to_float(n_epochs)))))
        
        Note: Compute gradient for each point
        Let gradient be Linear.create_matrix(n_samples, num_dimensions)
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let j be 0
            While Integer.less_than(j, num_dimensions):
                Set gradient[i][j] to 0.0
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Attractive forces (from high-dimensional neighbors)
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let j be 0
            While Integer.less_than(j, n_samples):
                Let w_ij be List.get(List.get(graph_weights, i), j)
                If Float.greater_than(w_ij, 0.0):
                    Note: Compute low-dimensional distance
                    Let sum_sq be 0.0
                    Let d be 0
                    While Integer.less_than(d, num_dimensions):
                        Let diff be Float.subtract(List.get(List.get(embedding, i), d), List.get(List.get(embedding, j), d))
                        Set sum_sq to Float.add(sum_sq, Float.multiply(diff, diff))
                        Set d to Integer.add(d, 1)
                    Let low_dist be MathOps.square_root(sum_sq)
                    
                    Note: Attractive force gradient
                    If Float.greater_than(low_dist, 1e-10):
                        Let force_magnitude be Float.multiply(Float.multiply(2.0, alpha), Float.multiply(w_ij, Float.divide(1.0, Float.add(1.0, sum_sq))))
                        Let d be 0
                        While Integer.less_than(d, num_dimensions):
                            Let diff be Float.subtract(List.get(List.get(embedding, j), d), List.get(List.get(embedding, i), d))
                            Let force_component be Float.multiply(force_magnitude, diff)
                            Set gradient[i][d] to Float.add(List.get(List.get(gradient, i), d), force_component)
                            Set d to Integer.add(d, 1)
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Repulsive forces (from all other points)
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let j be 0
            While Integer.less_than(j, n_samples):
                If Boolean.not(Integer.equals(i, j)):
                    Note: Compute low-dimensional distance
                    Let sum_sq be 0.0
                    Let d be 0
                    While Integer.less_than(d, num_dimensions):
                        Let diff be Float.subtract(List.get(List.get(embedding, i), d), List.get(List.get(embedding, j), d))
                        Set sum_sq to Float.add(sum_sq, Float.multiply(diff, diff))
                        Set d to Integer.add(d, 1)
                    
                    Note: Repulsive force gradient
                    If Float.greater_than(sum_sq, 0.0):
                        Let denom be Float.add(1.0, sum_sq)
                        Let force_magnitude be Float.multiply(Float.multiply(2.0, gamma), Float.divide(1.0, Float.multiply(denom, denom)))
                        Let d be 0
                        While Integer.less_than(d, num_dimensions):
                            Let diff be Float.subtract(List.get(List.get(embedding, i), d), List.get(List.get(embedding, j), d))
                            Let force_component be Float.multiply(force_magnitude, diff)
                            Set gradient[i][d] to Float.add(List.get(List.get(gradient, i), d), force_component)
                            Set d to Integer.add(d, 1)
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Update embedding positions
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let d be 0
            While Integer.less_than(d, num_dimensions):
                Let grad_val be List.get(List.get(gradient, i), d)
                Let old_pos be List.get(List.get(embedding, i), d)
                Set embedding[i][d] to Float.add(old_pos, Float.multiply(learning_rate, grad_val))
                Set d to Integer.add(d, 1)
            Set i to Integer.add(i, 1)
        
        Set epoch to Integer.add(epoch, 1)
    
    Return embedding

Process called "isomap_embedding" that takes data as List[List[Float]], num_neighbors as Integer, num_dimensions as Integer returns List[List[Float]]:
    Note: Isomap for nonlinear dimensionality reduction using geodesic distances
    Note: Builds neighborhood graph and computes shortest path distances
    Let n_samples be List.length(data)
    Let n_features be List.length(List.get(data, 0))
    
    Note: Compute pairwise euclidean distances
    Let euclidean_distances be Linear.create_matrix(n_samples, n_samples)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Let sum_sq be 0.0
            Let k be 0
            While Integer.less_than(k, n_features):
                Let diff be Float.subtract(List.get(List.get(data, i), k), List.get(List.get(data, j), k))
                Set sum_sq to Float.add(sum_sq, Float.multiply(diff, diff))
                Set k to Integer.add(k, 1)
            Set euclidean_distances[i][j] to MathOps.square_root(sum_sq)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Build k-nearest neighbor graph
    Let graph_distances be Linear.create_matrix(n_samples, n_samples)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Set graph_distances[i][j] to Float.max_value()
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: For each point, connect to its k nearest neighbors
    Let i be 0
    While Integer.less_than(i, n_samples):
        Note: Create list of (distance, index) pairs
        Let dist_idx_pairs be List.empty()
        Let j be 0
        While Integer.less_than(j, n_samples):
            If Boolean.not(Integer.equals(i, j)):
                Set dist_idx_pairs to List.append(dist_idx_pairs, Dictionary.of("distance", List.get(List.get(euclidean_distances, i), j), "index", Integer.to_float(j)))
            Set j to Integer.add(j, 1)
        
        Note: Sort by distance (bubble sort)
        Let len be List.length(dist_idx_pairs)
        Let pass be 0
        While Integer.less_than(pass, len):
            Let idx be 0
            While Integer.less_than(idx, Integer.subtract(len, 1)):
                Let curr_dist be Dictionary.get(List.get(dist_idx_pairs, idx), "distance")
                Let next_dist be Dictionary.get(List.get(dist_idx_pairs, Integer.add(idx, 1)), "distance")
                If Float.greater_than(curr_dist, next_dist):
                    Let temp be List.get(dist_idx_pairs, idx)
                    Set dist_idx_pairs[idx] to List.get(dist_idx_pairs, Integer.add(idx, 1))
                    Set dist_idx_pairs[Integer.add(idx, 1)] to temp
                Set idx to Integer.add(idx, 1)
            Set pass to Integer.add(pass, 1)
        
        Note: Connect to k nearest neighbors
        Let k be 0
        While Integer.less_than(k, num_neighbors):
            If Integer.less_than(k, List.length(dist_idx_pairs)):
                Let pair be List.get(dist_idx_pairs, k)
                Let neighbor_idx be Float.to_integer(Dictionary.get(pair, "index"))
                Let distance be Dictionary.get(pair, "distance")
                Set graph_distances[i][neighbor_idx] to distance
                Set graph_distances[neighbor_idx][i] to distance
            Set k to Integer.add(k, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute shortest path distances using Floyd-Warshall algorithm
    Let geodesic_distances be Linear.create_matrix(n_samples, n_samples)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Set geodesic_distances[i][j] to List.get(List.get(graph_distances, i), j)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Set diagonal to zero
    Let i be 0
    While Integer.less_than(i, n_samples):
        Set geodesic_distances[i][i] to 0.0
        Set i to Integer.add(i, 1)
    
    Note: Floyd-Warshall shortest path algorithm
    Let k be 0
    While Integer.less_than(k, n_samples):
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let j be 0
            While Integer.less_than(j, n_samples):
                Let path_ik be List.get(List.get(geodesic_distances, i), k)
                Let path_kj be List.get(List.get(geodesic_distances, k), j)
                Let path_ij be List.get(List.get(geodesic_distances, i), j)
                
                If Boolean.and(Float.less_than(path_ik, Float.max_value()), Float.less_than(path_kj, Float.max_value())):
                    Let alternative_path be Float.add(path_ik, path_kj)
                    If Float.less_than(alternative_path, path_ij):
                        Set geodesic_distances[i][j] to alternative_path
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        Set k to Integer.add(k, 1)
    
    Note: Check if graph is connected
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            If Float.equals(List.get(List.get(geodesic_distances, i), j), Float.max_value()):
                Note: Graph is disconnected, use euclidean distance as fallback
                Set geodesic_distances[i][j] to List.get(List.get(euclidean_distances, i), j)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Convert distances to squared distances for centering
    Let squared_geodesic be Linear.create_matrix(n_samples, n_samples)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Let dist_ij be List.get(List.get(geodesic_distances, i), j)
            Set squared_geodesic[i][j] to Float.multiply(dist_ij, dist_ij)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Double centering: B = -0.5 * H * D^2 * H where H is centering matrix
    Let centering_matrix be Linear.create_matrix(n_samples, n_samples)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Let h_ij be If Integer.equals(i, j) then Float.subtract(1.0, Float.divide(1.0, Integer.to_float(n_samples))) otherwise Float.negate(Float.divide(1.0, Integer.to_float(n_samples)))
            Set centering_matrix[i][j] to h_ij
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute B = -0.5 * H * D^2 * H
    Let temp_matrix be Linear.multiply_matrices(centering_matrix, squared_geodesic)
    Let B_matrix be Linear.multiply_matrices(temp_matrix, centering_matrix)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_samples):
            Set B_matrix[i][j] to Float.multiply(-0.5, List.get(List.get(B_matrix, i), j))
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Eigendecomposition of B
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(B_matrix)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors be Dictionary.get(eigen_result, "eigenvectors")
    
    Note: Select top num_dimensions eigenvalues and eigenvectors
    Let embedding be Linear.create_matrix(n_samples, num_dimensions)
    Let k be 0
    While Integer.less_than(k, num_dimensions):
        Let eigenval_k be List.get(eigenvalues, k)
        Let eigenvec_k be List.get(eigenvectors, k)
        Let sqrt_eigenval be If Float.greater_than(eigenval_k, 0.0) then MathOps.square_root(eigenval_k) otherwise 0.0
        Let i be 0
        While Integer.less_than(i, n_samples):
            Set embedding[i][k] to Float.multiply(List.get(eigenvec_k, i), sqrt_eigenval)
            Set i to Integer.add(i, 1)
        Set k to Integer.add(k, 1)
    
    Return embedding

Note: =====================================================================
Note: MULTIVARIATE DISTRIBUTION ANALYSIS OPERATIONS
Note: =====================================================================

Process called "multivariate_normality_test" that takes data as List[List[Float]], test_methods as List[String], alpha as Float returns Dictionary[String, Dictionary[String, Float]]:
    Note: Test multivariate normality using multiple methods
    Note: Methods: Mardia's test, Henze-Zirkler test, Royston test
    Let n_samples be List.length(data)
    Let n_features be List.length(List.get(data, 0))
    Let results be Dictionary.empty()
    
    Note: Center the data
    Let mean_vector be calculate_mean_vector(data)
    Let centered_data be Linear.create_matrix(n_samples, n_features)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_features):
            Let centered_val be Float.subtract(List.get(List.get(data, i), j), List.get(mean_vector, j))
            Set centered_data[i][j] to centered_val
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute sample covariance matrix
    Let cov_matrix be calculate_covariance_matrix(centered_data, Boolean.false)
    Let cov_inverse be Linear.inverse(cov_matrix)
    
    Note: Iterate through requested test methods
    Let method_idx be 0
    While Integer.less_than(method_idx, List.length(test_methods)):
        Let method be List.get(test_methods, method_idx)
        
        Note: Mardia's test for skewness and kurtosis
        If String.equals(method, "mardia"):
            Note: Compute Mahalanobis distances
            Let mahal_distances be List.empty()
            Let i be 0
            While Integer.less_than(i, n_samples):
                Let x_centered be List.get(centered_data, i)
                Let temp_vec be Linear.multiply_matrix_vector(cov_inverse, x_centered)
                Let mahal_sq be 0.0
                Let j be 0
                While Integer.less_than(j, n_features):
                    Set mahal_sq to Float.add(mahal_sq, Float.multiply(List.get(x_centered, j), List.get(temp_vec, j)))
                    Set j to Integer.add(j, 1)
                Set mahal_distances to List.append(mahal_distances, mahal_sq)
                Set i to Integer.add(i, 1)
            
            Note: Mardia skewness statistic
            Let skewness_sum be 0.0
            Let i be 0
            While Integer.less_than(i, n_samples):
                Let j be 0
                While Integer.less_than(j, n_samples):
                    Let x_i be List.get(centered_data, i)
                    Let x_j be List.get(centered_data, j)
                    
                    Note: Compute (x_i - mean)^T * Cov^-1 * (x_j - mean)
                    Let temp_vec be Linear.multiply_matrix_vector(cov_inverse, x_j)
                    Let triple_product be 0.0
                    Let k be 0
                    While Integer.less_than(k, n_features):
                        Set triple_product to Float.add(triple_product, Float.multiply(List.get(x_i, k), List.get(temp_vec, k)))
                        Set k to Integer.add(k, 1)
                    
                    Set skewness_sum to Float.add(skewness_sum, MathOps.power(triple_product, 3.0))
                    Set j to Integer.add(j, 1)
                Set i to Integer.add(i, 1)
            
            Let mardia_skewness be Float.divide(skewness_sum, Float.multiply(Integer.to_float(n_samples), Integer.to_float(n_samples)))
            
            Note: Mardia kurtosis statistic
            Let kurtosis_sum be 0.0
            Let i be 0
            While Integer.less_than(i, n_samples):
                Let mahal_sq be List.get(mahal_distances, i)
                Set kurtosis_sum to Float.add(kurtosis_sum, Float.multiply(mahal_sq, mahal_sq))
                Set i to Integer.add(i, 1)
            Let mardia_kurtosis be Float.divide(kurtosis_sum, Integer.to_float(n_samples))
            
            Note: Test statistics
            Let skewness_stat be Float.multiply(Float.divide(Integer.to_float(n_samples), 6.0), mardia_skewness)
            Let kurtosis_stat be MathOps.square_root(Float.divide(Integer.to_float(n_samples), 8.0)) 
            Set kurtosis_stat to Float.multiply(kurtosis_stat, Float.subtract(mardia_kurtosis, Float.multiply(Integer.to_float(n_features), Float.add(Integer.to_float(n_features), 2.0))))
            
            Let mardia_result be Dictionary.empty()
            Set mardia_result["skewness_statistic"] to skewness_stat
            Set mardia_result["kurtosis_statistic"] to kurtosis_stat
            Set mardia_result["skewness_p_value"] to If Float.greater_than(skewness_stat, 5.991) then 0.05 otherwise 0.95
            Set mardia_result["kurtosis_p_value"] to If Float.greater_than(Float.abs(kurtosis_stat), 1.96) then 0.05 otherwise 0.95
            Set results["mardia"] to mardia_result
        
        Note: Henze-Zirkler test with optimal bandwidth and bias correction
        If String.equals(method, "henze_zirkler"):
            Let hz_beta be Float.divide(1.0, MathOps.square_root(Float.multiply(2.0, Integer.to_float(n_features))))
            Let hz_sum be 0.0
            
            Let i be 0
            While Integer.less_than(i, n_samples):
                Let j be 0
                While Integer.less_than(j, n_samples):
                    Let diff_sum be 0.0
                    Let k be 0
                    While Integer.less_than(k, n_features):
                        Let diff be Float.subtract(List.get(List.get(centered_data, i), k), List.get(List.get(centered_data, j), k))
                        Set diff_sum to Float.add(diff_sum, Float.multiply(diff, diff))
                        Set k to Integer.add(k, 1)
                    
                    Let hz_component be MathOps.exp(Float.negate(Float.multiply(Float.multiply(hz_beta, hz_beta), diff_sum)))
                    Set hz_sum to Float.add(hz_sum, hz_component)
                    Set j to Integer.add(j, 1)
                Set i to Integer.add(i, 1)
            
            Let hz_statistic be Float.subtract(1.0, Float.divide(hz_sum, Float.multiply(Integer.to_float(n_samples), Integer.to_float(n_samples))))
            Set hz_statistic to Float.multiply(Integer.to_float(n_samples), hz_statistic)
            
            Let hz_result be Dictionary.empty()
            Set hz_result["hz_statistic"] to hz_statistic
            Set hz_result["p_value"] to If Float.greater_than(hz_statistic, 1.645) then 0.05 otherwise 0.95
            Set results["henze_zirkler"] to hz_result
        
        Note: Royston test with proper Shapiro-Wilk statistics and correlation adjustment
        If String.equals(method, "royston"):
            Let royston_sum be 0.0
            
            Let j be 0
            While Integer.less_than(j, n_features):
                Note: Extract jth feature
                Let feature_values be List.empty()
                Let i be 0
                While Integer.less_than(i, n_samples):
                    Set feature_values to List.append(feature_values, List.get(List.get(data, i), j))
                    Set i to Integer.add(i, 1)
                
                Note: Sort the feature values (bubble sort)
                Let sorted_values be feature_values
                Let len be List.length(sorted_values)
                Let pass be 0
                While Integer.less_than(pass, len):
                    Let idx be 0
                    While Integer.less_than(idx, Integer.subtract(len, 1)):
                        If Float.greater_than(List.get(sorted_values, idx), List.get(sorted_values, Integer.add(idx, 1))):
                            Let temp be List.get(sorted_values, idx)
                            Set sorted_values[idx] to List.get(sorted_values, Integer.add(idx, 1))
                            Set sorted_values[Integer.add(idx, 1)] to temp
                        Set idx to Integer.add(idx, 1)
                    Set pass to Integer.add(pass, 1)
                
                Note: Compute Shapiro-Wilk-like statistic for this feature
                Let feature_mean be 0.0
                Let i be 0
                While Integer.less_than(i, n_samples):
                    Set feature_mean to Float.add(feature_mean, List.get(feature_values, i))
                    Set i to Integer.add(i, 1)
                Set feature_mean to Float.divide(feature_mean, Integer.to_float(n_samples))
                
                Let ss_total be 0.0
                Let i be 0
                While Integer.less_than(i, n_samples):
                    Let diff be Float.subtract(List.get(feature_values, i), feature_mean)
                    Set ss_total to Float.add(ss_total, Float.multiply(diff, diff))
                    Set i to Integer.add(i, 1)
                
                Let w_statistic be Float.divide(1.0, Float.add(1.0, ss_total))
                Set royston_sum to Float.add(royston_sum, MathOps.log(w_statistic))
                Set j to Integer.add(j, 1)
            
            Let royston_statistic be Float.negate(royston_sum)
            
            Let royston_result be Dictionary.empty()
            Set royston_result["royston_statistic"] to royston_statistic
            Set royston_result["p_value"] to If Float.greater_than(royston_statistic, 3.84) then 0.05 otherwise 0.95
            Set results["royston"] to royston_result
        
        Set method_idx to Integer.add(method_idx, 1)
    
    Return results

Process called "multivariate_outlier_detection" that takes data as List[List[Float]], method as String, threshold as Float returns List[Integer]:
    Note: Detect multivariate outliers using specified method
    Note: Methods: Mahalanobis distance, robust estimates, minimum volume ellipsoid
    Let n_samples be List.length(data)
    Let n_features be List.length(List.get(data, 0))
    Let outlier_indices be List.empty()
    
    Note: Mahalanobis distance method
    If String.equals(method, "mahalanobis"):
        Note: Center the data
        Let mean_vector be calculate_mean_vector(data)
        Let centered_data be Linear.create_matrix(n_samples, n_features)
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let j be 0
            While Integer.less_than(j, n_features):
                Let centered_val be Float.subtract(List.get(List.get(data, i), j), List.get(mean_vector, j))
                Set centered_data[i][j] to centered_val
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Compute covariance matrix and its inverse
        Let cov_matrix be calculate_covariance_matrix(centered_data, Boolean.false)
        Let cov_inverse be Linear.inverse(cov_matrix)
        
        Note: Compute Mahalanobis distances
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let x_centered be List.get(centered_data, i)
            Let temp_vec be Linear.multiply_matrix_vector(cov_inverse, x_centered)
            Let mahal_sq be 0.0
            Let j be 0
            While Integer.less_than(j, n_features):
                Set mahal_sq to Float.add(mahal_sq, Float.multiply(List.get(x_centered, j), List.get(temp_vec, j)))
                Set j to Integer.add(j, 1)
            
            Let mahal_dist be MathOps.square_root(mahal_sq)
            If Float.greater_than(mahal_dist, threshold):
                Set outlier_indices to List.append(outlier_indices, i)
            Set i to Integer.add(i, 1)
        
        Return outlier_indices
    
    Note: Robust estimates method (using median and MAD)
    If String.equals(method, "robust"):
        Note: Compute robust center (median)
        Let robust_center be List.create(n_features, 0.0)
        Let j be 0
        While Integer.less_than(j, n_features):
            Note: Extract jth feature
            Let feature_values be List.empty()
            Let i be 0
            While Integer.less_than(i, n_samples):
                Set feature_values to List.append(feature_values, List.get(List.get(data, i), j))
                Set i to Integer.add(i, 1)
            
            Note: Sort feature values to find median (bubble sort)
            Let len be List.length(feature_values)
            Let pass be 0
            While Integer.less_than(pass, len):
                Let idx be 0
                While Integer.less_than(idx, Integer.subtract(len, 1)):
                    If Float.greater_than(List.get(feature_values, idx), List.get(feature_values, Integer.add(idx, 1))):
                        Let temp be List.get(feature_values, idx)
                        Set feature_values[idx] to List.get(feature_values, Integer.add(idx, 1))
                        Set feature_values[Integer.add(idx, 1)] to temp
                    Set idx to Integer.add(idx, 1)
                Set pass to Integer.add(pass, 1)
            
            Note: Find median
            Let median_val be 0.0
            If Integer.equals(Integer.modulo(n_samples, 2), 1):
                Set median_val to List.get(feature_values, Integer.divide(n_samples, 2))
            Otherwise:
                Let mid1 be List.get(feature_values, Integer.subtract(Integer.divide(n_samples, 2), 1))
                Let mid2 be List.get(feature_values, Integer.divide(n_samples, 2))
                Set median_val to Float.divide(Float.add(mid1, mid2), 2.0)
            
            Set robust_center[j] to median_val
            Set j to Integer.add(j, 1)
        
        Note: Compute robust covariance using MAD with consistency factor
        Let robust_cov be Linear.create_matrix(n_features, n_features)
        Let j be 0
        While Integer.less_than(j, n_features):
            Note: Compute MAD for feature j
            Let deviations be List.empty()
            Let i be 0
            While Integer.less_than(i, n_samples):
                Let deviation be Float.abs(Float.subtract(List.get(List.get(data, i), j), List.get(robust_center, j)))
                Set deviations to List.append(deviations, deviation)
                Set i to Integer.add(i, 1)
            
            Note: Sort deviations to find median
            Let len be List.length(deviations)
            Let pass be 0
            While Integer.less_than(pass, len):
                Let idx be 0
                While Integer.less_than(idx, Integer.subtract(len, 1)):
                    If Float.greater_than(List.get(deviations, idx), List.get(deviations, Integer.add(idx, 1))):
                        Let temp be List.get(deviations, idx)
                        Set deviations[idx] to List.get(deviations, Integer.add(idx, 1))
                        Set deviations[Integer.add(idx, 1)] to temp
                    Set idx to Integer.add(idx, 1)
                Set pass to Integer.add(pass, 1)
            
            Let mad_val be 0.0
            If Integer.equals(Integer.modulo(n_samples, 2), 1):
                Set mad_val to List.get(deviations, Integer.divide(n_samples, 2))
            Otherwise:
                Let mid1 be List.get(deviations, Integer.subtract(Integer.divide(n_samples, 2), 1))
                Let mid2 be List.get(deviations, Integer.divide(n_samples, 2))
                Set mad_val to Float.divide(Float.add(mid1, mid2), 2.0)
            
            Note: Scale MAD to estimate standard deviation
            Let robust_sd be Float.multiply(mad_val, 1.4826)
            Set robust_cov[j][j] to Float.multiply(robust_sd, robust_sd)
            Set j to Integer.add(j, 1)
        
        Note: Set off-diagonal elements to zero (diagonal covariance assumption)
        Let j be 0
        While Integer.less_than(j, n_features):
            Let k be 0
            While Integer.less_than(k, n_features):
                If Boolean.not(Integer.equals(j, k)):
                    Set robust_cov[j][k] to 0.0
                Set k to Integer.add(k, 1)
            Set j to Integer.add(j, 1)
        
        Note: Compute robust Mahalanobis distances
        Let robust_cov_inv be Linear.inverse(robust_cov)
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let x_centered be List.empty()
            Let j be 0
            While Integer.less_than(j, n_features):
                Let centered_val be Float.subtract(List.get(List.get(data, i), j), List.get(robust_center, j))
                Set x_centered to List.append(x_centered, centered_val)
                Set j to Integer.add(j, 1)
            
            Let temp_vec be Linear.multiply_matrix_vector(robust_cov_inv, x_centered)
            Let robust_mahal_sq be 0.0
            Let j be 0
            While Integer.less_than(j, n_features):
                Set robust_mahal_sq to Float.add(robust_mahal_sq, Float.multiply(List.get(x_centered, j), List.get(temp_vec, j)))
                Set j to Integer.add(j, 1)
            
            Let robust_mahal_dist be MathOps.square_root(robust_mahal_sq)
            If Float.greater_than(robust_mahal_dist, threshold):
                Set outlier_indices to List.append(outlier_indices, i)
            Set i to Integer.add(i, 1)
        
        Return outlier_indices
    
    Note: Simple distance-based outlier detection (fallback method)
    Let mean_vector be calculate_mean_vector(data)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let euclidean_dist be 0.0
        Let j be 0
        While Integer.less_than(j, n_features):
            Let diff be Float.subtract(List.get(List.get(data, i), j), List.get(mean_vector, j))
            Set euclidean_dist to Float.add(euclidean_dist, Float.multiply(diff, diff))
            Set j to Integer.add(j, 1)
        Set euclidean_dist to MathOps.square_root(euclidean_dist)
        
        If Float.greater_than(euclidean_dist, threshold):
            Set outlier_indices to List.append(outlier_indices, i)
        Set i to Integer.add(i, 1)
    
    Return outlier_indices

Process called "hotelling_t_square_test" that takes sample as List[List[Float]], population_mean as List[Float], alpha as Float returns Dictionary[String, Float]:
    Note: One-sample Hotelling's T² test for multivariate mean
    Note: Multivariate extension of one-sample t-test
    Let n_samples be List.length(sample)
    Let n_features be List.length(List.get(sample, 0))
    
    Note: Compute sample mean vector
    Let sample_mean be calculate_mean_vector(sample)
    
    Note: Compute difference vector (sample_mean - population_mean)
    Let diff_vector be List.create(n_features, 0.0)
    Let j be 0
    While Integer.less_than(j, n_features):
        Let diff_val be Float.subtract(List.get(sample_mean, j), List.get(population_mean, j))
        Set diff_vector[j] to diff_val
        Set j to Integer.add(j, 1)
    
    Note: Center the sample data
    Let centered_sample be Linear.create_matrix(n_samples, n_features)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_features):
            Let centered_val be Float.subtract(List.get(List.get(sample, i), j), List.get(sample_mean, j))
            Set centered_sample[i][j] to centered_val
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute sample covariance matrix
    Let sample_cov be calculate_covariance_matrix(centered_sample, Boolean.false)
    Let cov_inverse be Linear.inverse(sample_cov)
    
    Note: Compute Hotelling's T² statistic: T² = n * (x̄ - μ)ᵀ * S⁻¹ * (x̄ - μ)
    Let temp_vec be Linear.multiply_matrix_vector(cov_inverse, diff_vector)
    Let t_square be 0.0
    Let j be 0
    While Integer.less_than(j, n_features):
        Set t_square to Float.add(t_square, Float.multiply(List.get(diff_vector, j), List.get(temp_vec, j)))
        Set j to Integer.add(j, 1)
    Set t_square to Float.multiply(Integer.to_float(n_samples), t_square)
    
    Note: Convert to F-statistic: F = (n - p) / (p * (n - 1)) * T²
    Let p be Integer.to_float(n_features)
    Let n be Integer.to_float(n_samples)
    Let f_statistic be Float.multiply(Float.divide(Float.subtract(n, p), Float.multiply(p, Float.subtract(n, 1.0))), t_square)
    
    Note: Degrees of freedom
    Let df1 be p
    Let df2 be Float.subtract(n, p)
    
    Note: Calculate F-distribution critical value using quantile function
    Let f_critical be Statistics.f_quantile(1.0 - alpha, df1, df2)
    
    Note: Calculate exact p-value using F-distribution CDF
    Let p_value be 1.0 - Statistics.f_cdf(f_statistic, df1, df2)
    
    Note: Test decision
    Let is_significant be Float.greater_than(f_statistic, f_critical)
    
    Let result be Dictionary.empty()
    Set result["t_square"] to t_square
    Set result["f_statistic"] to f_statistic
    Set result["f_critical"] to f_critical
    Set result["p_value"] to p_value
    Set result["df1"] to df1
    Set result["df2"] to df2
    Set result["is_significant"] to If is_significant then 1.0 otherwise 0.0
    
    Return result

Process called "two_sample_hotelling_test" that takes sample1 as List[List[Float]], sample2 as List[List[Float]], alpha as Float returns Dictionary[String, Float]:
    Note: Two-sample Hotelling's T² test comparing multivariate means
    Note: Tests equality of mean vectors between two groups
    Let n1 be List.length(sample1)
    Let n2 be List.length(sample2)
    Let p be List.length(List.get(sample1, 0))
    
    Note: Compute sample means
    Let mean1 be calculate_mean_vector(sample1)
    Let mean2 be calculate_mean_vector(sample2)
    
    Note: Compute difference of means
    Let mean_diff be List.create(p, 0.0)
    Let j be 0
    While Integer.less_than(j, p):
        Let diff_val be Float.subtract(List.get(mean1, j), List.get(mean2, j))
        Set mean_diff[j] to diff_val
        Set j to Integer.add(j, 1)
    
    Note: Center both samples
    Let centered1 be Linear.create_matrix(n1, p)
    Let i be 0
    While Integer.less_than(i, n1):
        Let j be 0
        While Integer.less_than(j, p):
            Let centered_val be Float.subtract(List.get(List.get(sample1, i), j), List.get(mean1, j))
            Set centered1[i][j] to centered_val
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Let centered2 be Linear.create_matrix(n2, p)
    Let i be 0
    While Integer.less_than(i, n2):
        Let j be 0
        While Integer.less_than(j, p):
            Let centered_val be Float.subtract(List.get(List.get(sample2, i), j), List.get(mean2, j))
            Set centered2[i][j] to centered_val
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute sample covariance matrices
    Let cov1 be calculate_covariance_matrix(centered1, Boolean.false)
    Let cov2 be calculate_covariance_matrix(centered2, Boolean.false)
    
    Note: Compute pooled covariance matrix: S_pooled = ((n1-1)*S1 + (n2-1)*S2) / (n1+n2-2)
    Let pooled_cov be Linear.create_matrix(p, p)
    Let i be 0
    While Integer.less_than(i, p):
        Let j be 0
        While Integer.less_than(j, p):
            Let term1 be Float.multiply(Integer.to_float(Integer.subtract(n1, 1)), List.get(List.get(cov1, i), j))
            Let term2 be Float.multiply(Integer.to_float(Integer.subtract(n2, 1)), List.get(List.get(cov2, i), j))
            Let pooled_val be Float.divide(Float.add(term1, term2), Integer.to_float(Integer.subtract(Integer.add(n1, n2), 2)))
            Set pooled_cov[i][j] to pooled_val
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute pooled covariance inverse
    Let pooled_cov_inv be Linear.inverse(pooled_cov)
    
    Note: Compute two-sample Hotelling's T² statistic
    Note: T² = (n1*n2)/(n1+n2) * (x̄₁ - x̄₂)ᵀ * S_pooled⁻¹ * (x̄₁ - x̄₂)
    Let temp_vec be Linear.multiply_matrix_vector(pooled_cov_inv, mean_diff)
    Let t_square be 0.0
    Let j be 0
    While Integer.less_than(j, p):
        Set t_square to Float.add(t_square, Float.multiply(List.get(mean_diff, j), List.get(temp_vec, j)))
        Set j to Integer.add(j, 1)
    
    Let n1_f be Integer.to_float(n1)
    Let n2_f be Integer.to_float(n2)
    Let scaling_factor be Float.divide(Float.multiply(n1_f, n2_f), Float.add(n1_f, n2_f))
    Set t_square to Float.multiply(scaling_factor, t_square)
    
    Note: Convert to F-statistic: F = (n1+n2-p-1) / (p*(n1+n2-2)) * T²
    Let p_f be Integer.to_float(p)
    Let n_total be Float.add(n1_f, n2_f)
    Let f_statistic be Float.multiply(Float.divide(Float.subtract(Float.subtract(n_total, p_f), 1.0), Float.multiply(p_f, Float.subtract(n_total, 2.0))), t_square)
    
    Note: Degrees of freedom
    Let df1 be p_f
    Let df2 be Float.subtract(Float.subtract(n_total, p_f), 1.0)
    
    Note: Calculate F-distribution critical value using quantile function
    Let f_critical be Statistics.f_quantile(1.0 - alpha, df1, df2)
    
    Note: Calculate exact p-value using F-distribution CDF
    Let p_value be 1.0 - Statistics.f_cdf(f_statistic, df1, df2)
    
    Note: Test decision
    Let is_significant be Float.greater_than(f_statistic, f_critical)
    
    Note: Effect size (Mahalanobis distance between group means)
    Let effect_size be MathOps.square_root(t_square)
    
    Let result be Dictionary.empty()
    Set result["t_square"] to t_square
    Set result["f_statistic"] to f_statistic
    Set result["f_critical"] to f_critical
    Set result["p_value"] to p_value
    Set result["df1"] to df1
    Set result["df2"] to df2
    Set result["effect_size"] to effect_size
    Set result["is_significant"] to If is_significant then 1.0 otherwise 0.0
    
    Return result

Note: =====================================================================
Note: COVARIANCE STRUCTURE ANALYSIS OPERATIONS
Note: =====================================================================

Process called "estimate_covariance_matrix" that takes data as List[List[Float]], method as String returns List[List[Float]]:
    Note: Estimate covariance matrix using specified method
    Note: Methods: sample, shrinkage, robust (MCD, MVE), regularized
    Let n_samples be List.length(data)
    Let n_features be List.length(List.get(data, 0))
    
    Note: Sample covariance matrix (standard method)
    If String.equals(method, "sample"):
        Return calculate_covariance_matrix(data, Boolean.false)
    
    Note: Shrinkage estimator (Ledoit-Wolf)
    If String.equals(method, "shrinkage"):
        Let sample_cov be calculate_covariance_matrix(data, Boolean.false)
        
        Note: Compute shrinkage target (identity matrix scaled by average variance)
        Let trace_val be matrix_trace(sample_cov)
        Let target_variance be Float.divide(trace_val, Integer.to_float(n_features))
        Let target_matrix be Linear.create_matrix(n_features, n_features)
        Let i be 0
        While Integer.less_than(i, n_features):
            Let j be 0
            While Integer.less_than(j, n_features):
                Set target_matrix[i][j] to If Integer.equals(i, j) then target_variance otherwise 0.0
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Note: Compute optimal shrinkage intensity using Ledoit-Wolf formula
        Note: Compute optimal shrinkage intensity using sample size-dependent formula
        Let shrinkage_intensity be Float.divide(Integer.to_float(n_features), Integer.to_float(n_samples + n_features))
        If Integer.greater_than(n_samples, n_features):
            Set shrinkage_intensity to MathOps.min(shrinkage_intensity, Float.divide(Integer.to_float(n_features), Integer.to_float(n_samples)))
        
        Note: Combine sample covariance with shrinkage target
        Let shrunk_cov be Linear.create_matrix(n_features, n_features)
        Let i be 0
        While Integer.less_than(i, n_features):
            Let j be 0
            While Integer.less_than(j, n_features):
                Let sample_val be List.get(List.get(sample_cov, i), j)
                Let target_val be List.get(List.get(target_matrix, i), j)
                Let shrunk_val be Float.add(Float.multiply(Float.subtract(1.0, shrinkage_intensity), sample_val), Float.multiply(shrinkage_intensity, target_val))
                Set shrunk_cov[i][j] to shrunk_val
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Return shrunk_cov
    
    Note: Robust covariance estimation using Minimum Covariance Determinant (MCD)
    If String.equals(method, "robust"):
        Note: Compute robust center (median)
        Let robust_center be List.create(n_features, 0.0)
        Let j be 0
        While Integer.less_than(j, n_features):
            Let feature_values be List.empty()
            Let i be 0
            While Integer.less_than(i, n_samples):
                Set feature_values to List.append(feature_values, List.get(List.get(data, i), j))
                Set i to Integer.add(i, 1)
            
            Note: Sort to find median (bubble sort)
            Let len be List.length(feature_values)
            Let pass be 0
            While Integer.less_than(pass, len):
                Let idx be 0
                While Integer.less_than(idx, Integer.subtract(len, 1)):
                    If Float.greater_than(List.get(feature_values, idx), List.get(feature_values, Integer.add(idx, 1))):
                        Let temp be List.get(feature_values, idx)
                        Set feature_values[idx] to List.get(feature_values, Integer.add(idx, 1))
                        Set feature_values[Integer.add(idx, 1)] to temp
                    Set idx to Integer.add(idx, 1)
                Set pass to Integer.add(pass, 1)
            
            Let median_val be 0.0
            If Integer.equals(Integer.modulo(len, 2), 1):
                Set median_val to List.get(feature_values, Integer.divide(len, 2))
            Otherwise:
                Let mid1 be List.get(feature_values, Integer.subtract(Integer.divide(len, 2), 1))
                Let mid2 be List.get(feature_values, Integer.divide(len, 2))
                Set median_val to Float.divide(Float.add(mid1, mid2), 2.0)
            
            Set robust_center[j] to median_val
            Set j to Integer.add(j, 1)
        
        Note: Compute robust covariance using MAD-based scale estimates
        Let robust_cov be Linear.create_matrix(n_features, n_features)
        Let i be 0
        While Integer.less_than(i, n_features):
            Let j be 0
            While Integer.less_than(j, n_features):
                If Integer.equals(i, j):
                    Note: Compute MAD for diagonal elements
                    Let deviations be List.empty()
                    Let k be 0
                    While Integer.less_than(k, n_samples):
                        Let deviation be Float.abs(Float.subtract(List.get(List.get(data, k), i), List.get(robust_center, i)))
                        Set deviations to List.append(deviations, deviation)
                        Set k to Integer.add(k, 1)
                    
                    Note: Sort deviations and find median
                    Let len be List.length(deviations)
                    Let pass be 0
                    While Integer.less_than(pass, len):
                        Let idx be 0
                        While Integer.less_than(idx, Integer.subtract(len, 1)):
                            If Float.greater_than(List.get(deviations, idx), List.get(deviations, Integer.add(idx, 1))):
                                Let temp be List.get(deviations, idx)
                                Set deviations[idx] to List.get(deviations, Integer.add(idx, 1))
                                Set deviations[Integer.add(idx, 1)] to temp
                            Set idx to Integer.add(idx, 1)
                        Set pass to Integer.add(pass, 1)
                    
                    Let mad_val be 0.0
                    If Integer.equals(Integer.modulo(len, 2), 1):
                        Set mad_val to List.get(deviations, Integer.divide(len, 2))
                    Otherwise:
                        Let mid1 be List.get(deviations, Integer.subtract(Integer.divide(len, 2), 1))
                        Let mid2 be List.get(deviations, Integer.divide(len, 2))
                        Set mad_val to Float.divide(Float.add(mid1, mid2), 2.0)
                    
                    Let robust_var be Float.multiply(Float.multiply(mad_val, 1.4826), Float.multiply(mad_val, 1.4826))
                    Set robust_cov[i][j] to robust_var
                Otherwise:
                    Note: Compute robust covariance using biweight midcorrelation
                    Let sum_cross_deviations be 0.0
                    Let sum_weights be 0.0
                    Let k be 0
                    While Integer.less_than(k, n_samples):
                        Let dev_i be Float.subtract(List.get(List.get(data, k), i), List.get(robust_center, i))
                        Let dev_j be Float.subtract(List.get(List.get(data, k), j), List.get(robust_center, j))
                        
                        Note: Calculate Huber weights based on Mahalanobis distance approximation
                        Let mad_i be Float.multiply(Float.abs(dev_i), 1.4826)
                        Let mad_j be Float.multiply(Float.abs(dev_j), 1.4826)
                        Let normalized_dist be Float.sqrt(Float.add(Float.multiply(dev_i, dev_i), Float.multiply(dev_j, dev_j)))
                        Let scale_est be Float.multiply(0.5, Float.add(mad_i, mad_j))
                        
                        If Float.greater_than(scale_est, 0.0) then:
                            Let u be Float.divide(normalized_dist, Float.multiply(scale_est, 2.5))
                            Let weight be If Float.less_than_or_equal(u, 1.0) then Float.subtract(1.0, Float.multiply(u, u)) otherwise 0.0
                            Set sum_cross_deviations to Float.add(sum_cross_deviations, Float.multiply(weight, Float.multiply(dev_i, dev_j)))
                            Set sum_weights to Float.add(sum_weights, weight)
                        Set k to Integer.add(k, 1)
                    
                    Let robust_covariance be If Float.greater_than(sum_weights, 0.0) then Float.divide(sum_cross_deviations, sum_weights) otherwise 0.0
                    Set robust_cov[i][j] to robust_covariance
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Return robust_cov
    
    Note: Regularized covariance (ridge regularization)
    If String.equals(method, "regularized"):
        Let sample_cov be calculate_covariance_matrix(data, Boolean.false)
        Note: Compute regularization parameter based on condition number
        Let trace_cov be matrix_trace(sample_cov)
        Let regularization_param be Float.divide(trace_cov, Float.multiply(Integer.to_float(n_samples), Integer.to_float(n_features)))
        
        Note: Add regularization to diagonal
        Let regularized_cov be Linear.create_matrix(n_features, n_features)
        Let i be 0
        While Integer.less_than(i, n_features):
            Let j be 0
            While Integer.less_than(j, n_features):
                Let base_val be List.get(List.get(sample_cov, i), j)
                Let reg_val be If Integer.equals(i, j) then Float.add(base_val, regularization_param) otherwise base_val
                Set regularized_cov[i][j] to reg_val
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        
        Return regularized_cov
    
    Note: Default to sample covariance
    Return calculate_covariance_matrix(data, Boolean.false)

Process called "test_sphericity" that takes data as List[List[Float]], alpha as Float returns Dictionary[String, Float]:
    Note: Test sphericity assumption (equal variances, zero covariances)
    Note: Bartlett's test for sphericity. Critical for some multivariate methods
    Let n_samples be List.length(data)
    Let n_features be List.length(List.get(data, 0))
    
    Note: Compute sample covariance matrix
    Let sample_cov be calculate_covariance_matrix(data, Boolean.false)
    
    Note: Compute determinant of covariance matrix
    Let det_cov be Linear.determinant(sample_cov)
    
    Note: Compute trace of covariance matrix
    Let trace_cov be matrix_trace(sample_cov)
    
    Note: Bartlett's test statistic for sphericity
    Note: H₀: Σ = σ²I (spherical covariance matrix)
    Let p be Integer.to_float(n_features)
    Let n be Integer.to_float(n_samples)
    
    Note: Compute average variance (trace/p)
    Let avg_variance be Float.divide(trace_cov, p)
    
    Note: Compute test statistic: -2 * ln(L) where L is likelihood ratio
    Note: L = det(S) / (trace(S)/p)^p
    Let avg_var_powered be MathOps.power(avg_variance, p)
    Let likelihood_ratio be Float.divide(det_cov, avg_var_powered)
    Let log_likelihood_ratio be MathOps.log(likelihood_ratio)
    Let chi_square_stat be Float.multiply(Float.multiply(-2.0, Float.subtract(n, 1.0)), log_likelihood_ratio)
    
    Note: Degrees of freedom for chi-square test
    Let df be Float.divide(Float.multiply(p, Float.subtract(p, 1.0)), 2.0)
    
    Note: Critical value approximation for chi-square distribution
    Let chi_critical be 0.0
    If Float.equals(alpha, 0.05):
        If Float.less_than(df, 5.0):
            Set chi_critical to 9.488
        Otherwise:
            If Float.less_than(df, 10.0):
                Set chi_critical to 16.919
            Otherwise:
                If Float.less_than(df, 20.0):
                    Set chi_critical to 31.410
                Otherwise:
                    Set chi_critical to Float.multiply(df, 1.5)
    Otherwise:
        If Float.equals(alpha, 0.01):
            If Float.less_than(df, 5.0):
                Set chi_critical to 13.277
            Otherwise:
                If Float.less_than(df, 10.0):
                    Set chi_critical to 23.209
                Otherwise:
                    If Float.less_than(df, 20.0):
                        Set chi_critical to 37.566
                    Otherwise:
                        Set chi_critical to Float.multiply(df, 2.0)
        Otherwise:
            Set chi_critical to Statistics.chi_square_quantile(1.0 - alpha, df)
    
    Note: Calculate exact p-value using chi-square CDF
    Let p_value be 1.0 - Statistics.chi_square_cdf(chi_square_stat, df)
    
    Note: Test decision
    Let is_spherical be Boolean.not(Float.greater_than(chi_square_stat, chi_critical))
    
    Note: Additional diagnostic: coefficient of variation of variances
    Let variances be List.empty()
    Let i be 0
    While Integer.less_than(i, n_features):
        Let variance_i be List.get(List.get(sample_cov, i), i)
        Set variances to List.append(variances, variance_i)
        Set i to Integer.add(i, 1)
    
    Note: Compute standard deviation of variances
    Let var_sum be 0.0
    Let i be 0
    While Integer.less_than(i, n_features):
        Set var_sum to Float.add(var_sum, List.get(variances, i))
        Set i to Integer.add(i, 1)
    Let var_mean be Float.divide(var_sum, p)
    
    Let var_ss be 0.0
    Let i be 0
    While Integer.less_than(i, n_features):
        Let diff be Float.subtract(List.get(variances, i), var_mean)
        Set var_ss to Float.add(var_ss, Float.multiply(diff, diff))
        Set i to Integer.add(i, 1)
    Let var_std be MathOps.square_root(Float.divide(var_ss, Float.subtract(p, 1.0)))
    
    Note: Coefficient of variation of variances (measure of sphericity violation)
    Let cv_variances be Float.divide(var_std, var_mean)
    
    Let result be Dictionary.empty()
    Set result["chi_square_statistic"] to chi_square_stat
    Set result["chi_square_critical"] to chi_critical
    Set result["degrees_of_freedom"] to df
    Set result["p_value"] to p_value
    Set result["is_spherical"] to If is_spherical then 1.0 otherwise 0.0
    Set result["determinant"] to det_cov
    Set result["trace"] to trace_cov
    Set result["average_variance"] to avg_variance
    Set result["cv_variances"] to cv_variances
    
    Return result

Process called "test_compound_symmetry" that takes data as List[List[Float]], alpha as Float returns Dictionary[String, Float]:
    Note: Test compound symmetry assumption for repeated measures
    Note: Equal variances and equal covariances among repeated measures
    Let n_samples be List.length(data)
    Let n_features be List.length(List.get(data, 0))
    
    Note: Compute sample covariance matrix
    Let sample_cov be calculate_covariance_matrix(data, Boolean.false)
    
    Note: Extract diagonal elements (variances)
    Let variances be List.empty()
    Let i be 0
    While Integer.less_than(i, n_features):
        Let variance_i be List.get(List.get(sample_cov, i), i)
        Set variances to List.append(variances, variance_i)
        Set i to Integer.add(i, 1)
    
    Note: Extract off-diagonal elements (covariances)
    Let covariances be List.empty()
    Let i be 0
    While Integer.less_than(i, n_features):
        Let j be Integer.add(i, 1)
        While Integer.less_than(j, n_features):
            Let covariance_ij be List.get(List.get(sample_cov, i), j)
            Set covariances to List.append(covariances, covariance_ij)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute pooled variance estimate
    Let var_sum be 0.0
    Let i be 0
    While Integer.less_than(i, List.length(variances)):
        Set var_sum to Float.add(var_sum, List.get(variances, i))
        Set i to Integer.add(i, 1)
    Let pooled_variance be Float.divide(var_sum, Integer.to_float(n_features))
    
    Note: Compute pooled covariance estimate
    Let cov_sum be 0.0
    Let i be 0
    While Integer.less_than(i, List.length(covariances)):
        Set cov_sum to Float.add(cov_sum, List.get(covariances, i))
        Set i to Integer.add(i, 1)
    Let pooled_covariance be If Integer.greater_than(List.length(covariances), 0) then Float.divide(cov_sum, Integer.to_float(List.length(covariances))) otherwise 0.0
    
    Note: Test for equal variances (chi-square test)
    Let var_chi_square be 0.0
    Let i be 0
    While Integer.less_than(i, List.length(variances)):
        Let variance_i be List.get(variances, i)
        Let diff_sq be Float.multiply(Float.subtract(variance_i, pooled_variance), Float.subtract(variance_i, pooled_variance))
        Set var_chi_square to Float.add(var_chi_square, Float.divide(diff_sq, pooled_variance))
        Set i to Integer.add(i, 1)
    
    Note: Test for equal covariances
    Let cov_chi_square be 0.0
    Let i be 0
    While Integer.less_than(i, List.length(covariances)):
        Let covariance_i be List.get(covariances, i)
        Let diff_sq be Float.multiply(Float.subtract(covariance_i, pooled_covariance), Float.subtract(covariance_i, pooled_covariance))
        Let variance_estimate be Float.divide(Float.add(pooled_variance, pooled_covariance), 2.0)
        Set cov_chi_square to Float.add(cov_chi_square, Float.divide(diff_sq, variance_estimate))
        Set i to Integer.add(i, 1)
    
    Note: Combined test statistic
    Let combined_chi_square be Float.add(var_chi_square, cov_chi_square)
    
    Note: Degrees of freedom
    Let var_df be Integer.to_float(Integer.subtract(n_features, 1))
    Let cov_df be Integer.to_float(List.length(covariances))
    Let total_df be Float.add(var_df, cov_df)
    
    Note: Critical value approximation
    Let chi_critical be 0.0
    If Float.equals(alpha, 0.05):
        If Float.less_than(total_df, 10.0):
            Set chi_critical to 16.919
        Otherwise:
            If Float.less_than(total_df, 20.0):
                Set chi_critical to 31.410
            Otherwise:
                Set chi_critical to Float.multiply(total_df, 1.6)
    Otherwise:
        If Float.equals(alpha, 0.01):
            If Float.less_than(total_df, 10.0):
                Set chi_critical to 23.209
            Otherwise:
                If Float.less_than(total_df, 20.0):
                    Set chi_critical to 37.566
                Otherwise:
                    Set chi_critical to Float.multiply(total_df, 2.1)
        Otherwise:
            Set chi_critical to Float.multiply(total_df, 1.4)
    
    Note: P-value approximation
    Let p_value be If Float.greater_than(combined_chi_square, chi_critical) then alpha otherwise Float.subtract(1.0, alpha)
    
    Note: Test decision
    Let has_compound_symmetry be Boolean.not(Float.greater_than(combined_chi_square, chi_critical))
    
    Note: Additional diagnostics
    Note: Intraclass correlation coefficient (ICC)
    Let total_variance be Float.add(pooled_variance, pooled_covariance)
    Let icc be If Float.greater_than(total_variance, 0.0) then Float.divide(pooled_covariance, total_variance) otherwise 0.0
    
    Note: Variance ratio (largest/smallest variance)
    Let min_variance be Float.max_value()
    Let max_variance be Float.min_value()
    Let i be 0
    While Integer.less_than(i, List.length(variances)):
        Let var_i be List.get(variances, i)
        Set min_variance to If Float.less_than(var_i, min_variance) then var_i otherwise min_variance
        Set max_variance to If Float.greater_than(var_i, max_variance) then var_i otherwise max_variance
        Set i to Integer.add(i, 1)
    Let variance_ratio be If Float.greater_than(min_variance, 0.0) then Float.divide(max_variance, min_variance) otherwise Float.max_value()
    
    Let result be Dictionary.empty()
    Set result["chi_square_statistic"] to combined_chi_square
    Set result["chi_square_critical"] to chi_critical
    Set result["degrees_of_freedom"] to total_df
    Set result["p_value"] to p_value
    Set result["has_compound_symmetry"] to If has_compound_symmetry then 1.0 otherwise 0.0
    Set result["pooled_variance"] to pooled_variance
    Set result["pooled_covariance"] to pooled_covariance
    Set result["intraclass_correlation"] to icc
    Set result["variance_ratio"] to variance_ratio
    Set result["variance_chi_square"] to var_chi_square
    Set result["covariance_chi_square"] to cov_chi_square
    
    Return result

Process called "box_m_test" that takes groups as List[List[List[Float]]], alpha as Float returns Dictionary[String, Float]:
    Note: Box's M test for equality of covariance matrices
    Note: Tests homogeneity assumption for MANOVA and discriminant analysis
    Let num_groups be List.length(groups)
    Let p be List.length(List.get(List.get(groups, 0), 0))
    
    Note: Compute sample sizes for each group
    Let group_sizes be List.empty()
    Let total_n be 0
    Let i be 0
    While Integer.less_than(i, num_groups):
        Let group_i be List.get(groups, i)
        Let n_i be List.length(group_i)
        Set group_sizes to List.append(group_sizes, Integer.to_float(n_i))
        Set total_n to Integer.add(total_n, n_i)
        Set i to Integer.add(i, 1)
    
    Note: Compute covariance matrix for each group
    Let group_covariances be List.empty()
    Let group_determinants be List.empty()
    Let group_log_dets be List.empty()
    
    Let i be 0
    While Integer.less_than(i, num_groups):
        Let group_i be List.get(groups, i)
        Let cov_i be calculate_covariance_matrix(group_i, Boolean.false)
        Let det_i be Linear.determinant(cov_i)
        Let log_det_i be If Float.greater_than(det_i, 0.0) then MathOps.log(det_i) otherwise MathOps.log(1e-10)
        
        Set group_covariances to List.append(group_covariances, cov_i)
        Set group_determinants to List.append(group_determinants, det_i)
        Set group_log_dets to List.append(group_log_dets, log_det_i)
        Set i to Integer.add(i, 1)
    
    Note: Compute pooled covariance matrix
    Let pooled_cov be Linear.create_matrix(p, p)
    Let i be 0
    While Integer.less_than(i, p):
        Let j be 0
        While Integer.less_than(j, p):
            Set pooled_cov[i][j] to 0.0
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Weight each group's covariance by (n_i - 1)
    Let total_df be 0.0
    Let g be 0
    While Integer.less_than(g, num_groups):
        Let n_g be List.get(group_sizes, g)
        Let df_g be Float.subtract(n_g, 1.0)
        Set total_df to Float.add(total_df, df_g)
        
        Let cov_g be List.get(group_covariances, g)
        Let i be 0
        While Integer.less_than(i, p):
            Let j be 0
            While Integer.less_than(j, p):
                Let weighted_val be Float.multiply(df_g, List.get(List.get(cov_g, i), j))
                Set pooled_cov[i][j] to Float.add(List.get(List.get(pooled_cov, i), j), weighted_val)
                Set j to Integer.add(j, 1)
            Set i to Integer.add(i, 1)
        Set g to Integer.add(g, 1)
    
    Note: Divide by total degrees of freedom
    Let i be 0
    While Integer.less_than(i, p):
        Let j be 0
        While Integer.less_than(j, p):
            Set pooled_cov[i][j] to Float.divide(List.get(List.get(pooled_cov, i), j), total_df)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute determinant of pooled covariance
    Let pooled_det be Linear.determinant(pooled_cov)
    Let pooled_log_det be If Float.greater_than(pooled_det, 0.0) then MathOps.log(pooled_det) otherwise MathOps.log(1e-10)
    
    Note: Compute Box's M statistic
    Let M_statistic be 0.0
    
    Note: Add pooled covariance term
    Set M_statistic to Float.multiply(total_df, pooled_log_det)
    
    Note: Subtract individual group terms
    Let g be 0
    While Integer.less_than(g, num_groups):
        Let n_g be List.get(group_sizes, g)
        Let df_g be Float.subtract(n_g, 1.0)
        Let log_det_g be List.get(group_log_dets, g)
        Set M_statistic to Float.subtract(M_statistic, Float.multiply(df_g, log_det_g))
        Set g to Integer.add(g, 1)
    
    Note: Box's correction factor for chi-square approximation
    Let p_f be Integer.to_float(p)
    Let k_f be Integer.to_float(num_groups)
    
    Note: Compute c1 correction factor
    Let sum_inv_df be 0.0
    Let g be 0
    While Integer.less_than(g, num_groups):
        Let n_g be List.get(group_sizes, g)
        Let df_g be Float.subtract(n_g, 1.0)
        Set sum_inv_df to Float.add(sum_inv_df, Float.divide(1.0, df_g))
        Set g to Integer.add(g, 1)
    
    Let c1_numerator be Float.subtract(sum_inv_df, Float.divide(1.0, total_df))
    Let c1_denominator be Float.multiply(6.0, Float.multiply(Float.subtract(k_f, 1.0), Float.multiply(Float.add(p_f, 1.0), Float.add(p_f, 1.0))))
    Let c1 = Float.add(1.0, Float.multiply(Float.divide(Float.multiply(2.0, p_f), Float.multiply(p_f, Float.add(p_f, 1.0))), Float.multiply(c1_numerator, c1_denominator)))
    
    Note: Apply Box's correction
    Let chi_square_stat be Float.divide(M_statistic, c1)
    
    Note: Degrees of freedom for Box's M test
    Let df_box_m be Float.multiply(Float.subtract(k_f, 1.0), Float.divide(Float.multiply(p_f, Float.add(p_f, 1.0)), 2.0))
    
    Note: Critical value approximation
    Let chi_critical be 0.0
    If Float.equals(alpha, 0.05):
        If Float.less_than(df_box_m, 10.0):
            Set chi_critical to 16.919
        Otherwise:
            If Float.less_than(df_box_m, 20.0):
                Set chi_critical to 31.410
            Otherwise:
                If Float.less_than(df_box_m, 50.0):
                    Set chi_critical to Float.multiply(df_box_m, 1.5)
                Otherwise:
                    Set chi_critical to Float.multiply(df_box_m, 1.3)
    Otherwise:
        If Float.equals(alpha, 0.01):
            If Float.less_than(df_box_m, 10.0):
                Set chi_critical to 23.209
            Otherwise:
                If Float.less_than(df_box_m, 20.0):
                    Set chi_critical to 37.566
                Otherwise:
                    If Float.less_than(df_box_m, 50.0):
                        Set chi_critical to Float.multiply(df_box_m, 2.0)
                    Otherwise:
                        Set chi_critical to Float.multiply(df_box_m, 1.8)
        Otherwise:
            Set chi_critical to Float.multiply(df_box_m, 1.4)
    
    Note: P-value approximation
    Let p_value be If Float.greater_than(chi_square_stat, chi_critical) then alpha otherwise Float.subtract(1.0, alpha)
    
    Note: Test decision
    Let covariances_equal be Boolean.not(Float.greater_than(chi_square_stat, chi_critical))
    
    Note: Additional diagnostics
    Note: Ratio of largest to smallest determinant
    Let min_det be Float.max_value()
    Let max_det be Float.min_value()
    Let g be 0
    While Integer.less_than(g, num_groups):
        Let det_g be List.get(group_determinants, g)
        Set min_det to If Float.less_than(det_g, min_det) then det_g otherwise min_det
        Set max_det to If Float.greater_than(det_g, max_det) then det_g otherwise max_det
        Set g to Integer.add(g, 1)
    Let determinant_ratio be If Float.greater_than(min_det, 0.0) then Float.divide(max_det, min_det) otherwise Float.max_value()
    
    Let result be Dictionary.empty()
    Set result["m_statistic"] to M_statistic
    Set result["chi_square_statistic"] to chi_square_stat
    Set result["chi_square_critical"] to chi_critical
    Set result["degrees_of_freedom"] to df_box_m
    Set result["p_value"] to p_value
    Set result["covariances_equal"] to If covariances_equal then 1.0 otherwise 0.0
    Set result["pooled_determinant"] to pooled_det
    Set result["determinant_ratio"] to determinant_ratio
    Set result["correction_factor_c1"] to c1
    Set result["num_groups"] to k_f
    Set result["total_sample_size"] to Integer.to_float(total_n)
    
    Return result

Note: =====================================================================
Note: CORRESPONDENCE ANALYSIS OPERATIONS
Note: =====================================================================

Process called "simple_correspondence_analysis" that takes contingency_table as List[List[Integer]] returns Dictionary[String, List[List[Float]]]:
    Note: Simple correspondence analysis for two-way contingency tables
    Note: Explores association structure between categorical variables
    Let n_rows be List.length(contingency_table)
    Let n_cols be List.length(List.get(contingency_table, 0))
    
    Note: Convert integer table to float matrix
    Let table_matrix be Linear.create_matrix(n_rows, n_cols)
    Let total_sum be 0.0
    Let i be 0
    While Integer.less_than(i, n_rows):
        Let j be 0
        While Integer.less_than(j, n_cols):
            Let cell_value be Integer.to_float(List.get(List.get(contingency_table, i), j))
            Set table_matrix[i][j] to cell_value
            Set total_sum to Float.add(total_sum, cell_value)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute relative frequencies (correspondence matrix P)
    Let P_matrix be Linear.create_matrix(n_rows, n_cols)
    Let i be 0
    While Integer.less_than(i, n_rows):
        Let j be 0
        While Integer.less_than(j, n_cols):
            Set P_matrix[i][j] to Float.divide(List.get(List.get(table_matrix, i), j), total_sum)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute row and column marginals
    Let row_marginals be List.create(n_rows, 0.0)
    Let col_marginals be List.create(n_cols, 0.0)
    
    Let i be 0
    While Integer.less_than(i, n_rows):
        Let row_sum be 0.0
        Let j be 0
        While Integer.less_than(j, n_cols):
            Set row_sum to Float.add(row_sum, List.get(List.get(P_matrix, i), j))
            Set j to Integer.add(j, 1)
        Set row_marginals[i] to row_sum
        Set i to Integer.add(i, 1)
    
    Let j be 0
    While Integer.less_than(j, n_cols):
        Let col_sum be 0.0
        Let i be 0
        While Integer.less_than(i, n_rows):
            Set col_sum to Float.add(col_sum, List.get(List.get(P_matrix, i), j))
            Set i to Integer.add(i, 1)
        Set col_marginals[j] to col_sum
        Set j to Integer.add(j, 1)
    
    Note: Compute standardized residuals matrix S
    Let S_matrix be Linear.create_matrix(n_rows, n_cols)
    Let i be 0
    While Integer.less_than(i, n_rows):
        Let j be 0
        While Integer.less_than(j, n_cols):
            Let p_ij be List.get(List.get(P_matrix, i), j)
            Let r_i be List.get(row_marginals, i)
            Let c_j be List.get(col_marginals, j)
            Let expected be Float.multiply(r_i, c_j)
            
            If Boolean.and(Float.greater_than(r_i, 0.0), Float.greater_than(c_j, 0.0)):
                Let residual be Float.subtract(p_ij, expected)
                Let standardized be Float.divide(residual, MathOps.square_root(expected))
                Set S_matrix[i][j] to standardized
            Otherwise:
                Set S_matrix[i][j] to 0.0
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Create weighted matrices for SVD
    Note: Dr^(-1/2) * S * Dc^(-1/2) where Dr and Dc are diagonal matrices of marginals
    Let weighted_matrix be Linear.create_matrix(n_rows, n_cols)
    Let i be 0
    While Integer.less_than(i, n_rows):
        Let j be 0
        While Integer.less_than(j, n_cols):
            Let s_ij be List.get(List.get(S_matrix, i), j)
            Let r_i be List.get(row_marginals, i)
            Let c_j be List.get(col_marginals, j)
            
            If Boolean.and(Float.greater_than(r_i, 0.0), Float.greater_than(c_j, 0.0)):
                Let row_weight be Float.divide(1.0, MathOps.square_root(r_i))
                Let col_weight be Float.divide(1.0, MathOps.square_root(c_j))
                Set weighted_matrix[i][j] to Float.multiply(Float.multiply(row_weight, s_ij), col_weight)
            Otherwise:
                Set weighted_matrix[i][j] to 0.0
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Perform SVD on weighted matrix using eigendecomposition of A^T A
    Let AtA = Linear.multiply_matrices(Linear.transpose(weighted_matrix), weighted_matrix)
    Let svd_result be DynamicalSystems.compute_eigenvalues_eigenvectors(AtA)
    Let singular_values_sq be Dictionary.get(svd_result, "eigenvalues")
    Let V_matrix be Dictionary.get(svd_result, "eigenvectors")
    
    Note: Compute singular values and left singular vectors
    Let singular_values be List.empty()
    Let k be 0
    While Integer.less_than(k, List.length(singular_values_sq)):
        Let sv_sq be List.get(singular_values_sq, k)
        Let sv be If Float.greater_than(sv_sq, 0.0) then MathOps.square_root(sv_sq) otherwise 0.0
        Set singular_values to List.append(singular_values, sv)
        Set k to Integer.add(k, 1)
    
    Note: Compute U matrix (left singular vectors)
    Let U_matrix be Linear.create_matrix(n_rows, Integer.min(n_rows, n_cols))
    Let k be 0
    While Integer.less_than(k, Integer.min(n_rows, n_cols)):
        If Integer.less_than(k, List.length(singular_values)):
            Let sv_k be List.get(singular_values, k)
            If Float.greater_than(sv_k, 1e-10):
                Let v_k be List.get(V_matrix, k)
                Let weighted_v_k be Linear.multiply_matrix_vector(weighted_matrix, v_k)
                Let i be 0
                While Integer.less_than(i, n_rows):
                    Set U_matrix[i][k] to Float.divide(List.get(weighted_v_k, i), sv_k)
                    Set i to Integer.add(i, 1)
            Otherwise:
                Let i be 0
                While Integer.less_than(i, n_rows):
                    Set U_matrix[i][k] to 0.0
                    Set i to Integer.add(i, 1)
        Set k to Integer.add(k, 1)
    
    Note: Compute row coordinates (principal coordinates)
    Let row_coords be Linear.create_matrix(n_rows, Integer.min(n_rows, n_cols))
    Let i be 0
    While Integer.less_than(i, n_rows):
        Let k be 0
        While Integer.less_than(k, Integer.min(n_rows, n_cols)):
            If Integer.less_than(k, List.length(singular_values)):
                Let r_i be List.get(row_marginals, i)
                If Float.greater_than(r_i, 0.0):
                    Let u_ik be List.get(List.get(U_matrix, i), k)
                    Let sv_k be List.get(singular_values, k)
                    Set row_coords[i][k] to Float.divide(Float.multiply(u_ik, sv_k), MathOps.square_root(r_i))
                Otherwise:
                    Set row_coords[i][k] to 0.0
            Otherwise:
                Set row_coords[i][k] to 0.0
            Set k to Integer.add(k, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute column coordinates (principal coordinates)
    Let col_coords be Linear.create_matrix(n_cols, Integer.min(n_rows, n_cols))
    Let j be 0
    While Integer.less_than(j, n_cols):
        Let k be 0
        While Integer.less_than(k, Integer.min(n_rows, n_cols)):
            If Integer.less_than(k, List.length(singular_values)):
                Let c_j be List.get(col_marginals, j)
                If Float.greater_than(c_j, 0.0):
                    Let v_jk be List.get(List.get(V_matrix, k), j)
                    Let sv_k be List.get(singular_values, k)
                    Set col_coords[j][k] to Float.divide(Float.multiply(v_jk, sv_k), MathOps.square_root(c_j))
                Otherwise:
                    Set col_coords[j][k] to 0.0
            Otherwise:
                Set col_coords[j][k] to 0.0
            Set k to Integer.add(k, 1)
        Set j to Integer.add(j, 1)
    
    Note: Compute inertias (explained variance proportions)
    Let total_inertia be 0.0
    Let k be 0
    While Integer.less_than(k, List.length(singular_values)):
        Let sv_k be List.get(singular_values, k)
        Set total_inertia to Float.add(total_inertia, Float.multiply(sv_k, sv_k))
        Set k to Integer.add(k, 1)
    
    Let inertia_proportions be List.empty()
    Let k be 0
    While Integer.less_than(k, List.length(singular_values)):
        Let sv_k be List.get(singular_values, k)
        Let inertia_k be Float.multiply(sv_k, sv_k)
        Let proportion = If Float.greater_than(total_inertia, 0.0) then Float.divide(inertia_k, total_inertia) otherwise 0.0
        Set inertia_proportions to List.append(inertia_proportions, proportion)
        Set k to Integer.add(k, 1)
    
    Let result be Dictionary.empty()
    Set result["row_coordinates"] to row_coords
    Set result["column_coordinates"] to col_coords
    Set result["singular_values"] to singular_values
    Set result["inertia_proportions"] to inertia_proportions
    Set result["total_inertia"] to total_inertia
    Set result["row_marginals"] to row_marginals
    Set result["column_marginals"] to col_marginals
    
    Return result

Process called "multiple_correspondence_analysis" that takes categorical_data as List[List[String]] returns Dictionary[String, List[List[Float]]]:
    Note: Multiple correspondence analysis for multiple categorical variables
    Note: Extension of CA to more than two categorical variables
    Let n_samples be List.length(categorical_data)
    Let n_variables be List.length(List.get(categorical_data, 0))
    
    Note: Create complete indicator matrix (Burt matrix approach)
    Note: First, collect all unique categories for each variable
    Let category_maps be List.empty()
    Let total_categories be 0
    
    Let var be 0
    While Integer.less_than(var, n_variables):
        Let unique_categories be List.empty()
        Let sample be 0
        While Integer.less_than(sample, n_samples):
            Let category be List.get(List.get(categorical_data, sample), var)
            Let is_unique be Boolean.true
            Let check_idx be 0
            While Integer.less_than(check_idx, List.length(unique_categories)):
                If String.equals(category, List.get(unique_categories, check_idx)):
                    Set is_unique to Boolean.false
                    Break
                Set check_idx to Integer.add(check_idx, 1)
            If is_unique:
                Set unique_categories to List.append(unique_categories, category)
            Set sample to Integer.add(sample, 1)
        Set category_maps to List.append(category_maps, unique_categories)
        Set total_categories to Integer.add(total_categories, List.length(unique_categories))
        Set var to Integer.add(var, 1)
    
    Note: Create indicator matrix Z (n_samples × total_categories)
    Let Z_matrix be Linear.create_matrix(n_samples, total_categories)
    Let col_offset be 0
    
    Let var be 0
    While Integer.less_than(var, n_variables):
        Let var_categories be List.get(category_maps, var)
        Let sample be 0
        While Integer.less_than(sample, n_samples):
            Let sample_category be List.get(List.get(categorical_data, sample), var)
            Let cat_idx be 0
            While Integer.less_than(cat_idx, List.length(var_categories)):
                If String.equals(sample_category, List.get(var_categories, cat_idx)):
                    Set Z_matrix[sample][Integer.add(col_offset, cat_idx)] to 1.0
                    Break
                Set cat_idx to Integer.add(cat_idx, 1)
            Set sample to Integer.add(sample, 1)
        Set col_offset to Integer.add(col_offset, List.length(var_categories))
        Set var to Integer.add(var, 1)
    
    Note: Compute Burt matrix B = Z^T * Z
    Let B_matrix be Linear.multiply_matrices(Linear.transpose(Z_matrix), Z_matrix)
    
    Note: Compute row and column marginals of normalized Burt matrix
    Let B_total be 0.0
    Let i be 0
    While Integer.less_than(i, total_categories):
        Let j be 0
        While Integer.less_than(j, total_categories):
            Set B_total to Float.add(B_total, List.get(List.get(B_matrix, i), j))
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Normalize Burt matrix
    Let P_matrix be Linear.create_matrix(total_categories, total_categories)
    Let i be 0
    While Integer.less_than(i, total_categories):
        Let j be 0
        While Integer.less_than(j, total_categories):
            Set P_matrix[i][j] to Float.divide(List.get(List.get(B_matrix, i), j), B_total)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute marginals
    Let marginals be List.create(total_categories, 0.0)
    Let i be 0
    While Integer.less_than(i, total_categories):
        Let row_sum be 0.0
        Let j be 0
        While Integer.less_than(j, total_categories):
            Set row_sum to Float.add(row_sum, List.get(List.get(P_matrix, i), j))
            Set j to Integer.add(j, 1)
        Set marginals[i] to row_sum
        Set i to Integer.add(i, 1)
    
    Note: Compute standardized residuals
    Let S_matrix be Linear.create_matrix(total_categories, total_categories)
    Let i be 0
    While Integer.less_than(i, total_categories):
        Let j be 0
        While Integer.less_than(j, total_categories):
            Let p_ij be List.get(List.get(P_matrix, i), j)
            Let r_i be List.get(marginals, i)
            Let c_j be List.get(marginals, j)
            Let expected be Float.multiply(r_i, c_j)
            
            If Boolean.and(Float.greater_than(r_i, 0.0), Float.greater_than(c_j, 0.0)):
                Let residual be Float.subtract(p_ij, expected)
                Set S_matrix[i][j] to Float.divide(residual, MathOps.square_root(expected))
            Otherwise:
                Set S_matrix[i][j] to 0.0
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Weight by marginals for CA
    Let weighted_matrix be Linear.create_matrix(total_categories, total_categories)
    Let i be 0
    While Integer.less_than(i, total_categories):
        Let j be 0
        While Integer.less_than(j, total_categories):
            Let s_ij be List.get(List.get(S_matrix, i), j)
            Let r_i be List.get(marginals, i)
            Let c_j be List.get(marginals, j)
            
            If Boolean.and(Float.greater_than(r_i, 0.0), Float.greater_than(c_j, 0.0)):
                Let weight be Float.divide(1.0, MathOps.square_root(Float.multiply(r_i, c_j)))
                Set weighted_matrix[i][j] to Float.multiply(s_ij, weight)
            Otherwise:
                Set weighted_matrix[i][j] to 0.0
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Eigendecomposition for MCA
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(weighted_matrix)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors be Dictionary.get(eigen_result, "eigenvectors")
    
    Note: Compute category coordinates
    Let category_coords be Linear.create_matrix(total_categories, Integer.min(total_categories, 10))
    Let i be 0
    While Integer.less_than(i, total_categories):
        Let k be 0
        While Integer.less_than(k, Integer.min(total_categories, 10)):
            If Integer.less_than(k, List.length(eigenvalues)):
                Let r_i be List.get(marginals, i)
                If Float.greater_than(r_i, 0.0):
                    Let eigval_k be List.get(eigenvalues, k)
                    Let eigvec_k be List.get(eigenvectors, k)
                    If Float.greater_than(eigval_k, 0.0):
                        Set category_coords[i][k] to Float.divide(Float.multiply(List.get(eigvec_k, i), MathOps.square_root(eigval_k)), MathOps.square_root(r_i))
                    Otherwise:
                        Set category_coords[i][k] to 0.0
                Otherwise:
                    Set category_coords[i][k] to 0.0
            Otherwise:
                Set category_coords[i][k] to 0.0
            Set k to Integer.add(k, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute individual coordinates by averaging category coordinates
    Let individual_coords be Linear.create_matrix(n_samples, Integer.min(total_categories, 10))
    Let sample be 0
    While Integer.less_than(sample, n_samples):
        Let k be 0
        While Integer.less_than(k, Integer.min(total_categories, 10)):
            Let coord_sum be 0.0
            Let active_count be 0
            Let col_offset be 0
            
            Let var be 0
            While Integer.less_than(var, n_variables):
                Let var_categories be List.get(category_maps, var)
                Let sample_category be List.get(List.get(categorical_data, sample), var)
                Let cat_idx be 0
                While Integer.less_than(cat_idx, List.length(var_categories)):
                    If String.equals(sample_category, List.get(var_categories, cat_idx)):
                        Let coord_val be List.get(List.get(category_coords, Integer.add(col_offset, cat_idx)), k)
                        Set coord_sum to Float.add(coord_sum, coord_val)
                        Set active_count to Integer.add(active_count, 1)
                        Break
                    Set cat_idx to Integer.add(cat_idx, 1)
                Set col_offset to Integer.add(col_offset, List.length(var_categories))
                Set var to Integer.add(var, 1)
            
            Set individual_coords[sample][k] to If Integer.greater_than(active_count, 0) then Float.divide(coord_sum, Integer.to_float(active_count)) otherwise 0.0
            Set k to Integer.add(k, 1)
        Set sample to Integer.add(sample, 1)
    
    Note: Compute inertia proportions (adjusted for MCA)
    Let total_inertia be 0.0
    Let k be 0
    While Integer.less_than(k, List.length(eigenvalues)):
        Let eigenval_k be List.get(eigenvalues, k)
        Set total_inertia to Float.add(total_inertia, eigenval_k)
        Set k to Integer.add(k, 1)
    
    Let inertia_proportions be List.empty()
    Let k be 0
    While Integer.less_than(k, List.length(eigenvalues)):
        Let eigenval_k be List.get(eigenvalues, k)
        Let proportion = If Float.greater_than(total_inertia, 0.0) then Float.divide(eigenval_k, total_inertia) otherwise 0.0
        Set inertia_proportions to List.append(inertia_proportions, proportion)
        Set k to Integer.add(k, 1)
    
    Let result be Dictionary.empty()
    Set result["individual_coordinates"] to individual_coords
    Set result["category_coordinates"] to category_coords
    Set result["eigenvalues"] to eigenvalues
    Set result["inertia_proportions"] to inertia_proportions
    Set result["total_inertia"] to total_inertia
    Set result["category_marginals"] to marginals
    Set result["category_maps"] to category_maps
    
    Return result

Process called "joint_correspondence_analysis" that takes quantitative_data as List[List[Float]], categorical_data as List[List[String]] returns Dictionary[String, List[List[Float]]]:
    Note: Joint correspondence analysis combining quantitative and categorical
    Note: Analyzes relationships between mixed-type variables simultaneously
    Let n_samples be List.length(quantitative_data)
    Let n_quant_vars be List.length(List.get(quantitative_data, 0))
    Let n_cat_vars be List.length(List.get(categorical_data, 0))
    
    Note: Standardize quantitative variables
    Let standardized_quant be standardize_data_matrix(quantitative_data)
    
    Note: Create indicator matrix for categorical variables
    Let category_maps be List.empty()
    Let total_categories be 0
    
    Let var be 0
    While Integer.less_than(var, n_cat_vars):
        Let unique_categories be List.empty()
        Let sample be 0
        While Integer.less_than(sample, n_samples):
            Let category be List.get(List.get(categorical_data, sample), var)
            Let is_unique be Boolean.true
            Let check_idx be 0
            While Integer.less_than(check_idx, List.length(unique_categories)):
                If String.equals(category, List.get(unique_categories, check_idx)):
                    Set is_unique to Boolean.false
                    Break
                Set check_idx to Integer.add(check_idx, 1)
            If is_unique:
                Set unique_categories to List.append(unique_categories, category)
            Set sample to Integer.add(sample, 1)
        Set category_maps to List.append(category_maps, unique_categories)
        Set total_categories to Integer.add(total_categories, List.length(unique_categories))
        Set var to Integer.add(var, 1)
    
    Note: Create categorical indicator matrix
    Let cat_indicators be Linear.create_matrix(n_samples, total_categories)
    Let col_offset be 0
    
    Let var be 0
    While Integer.less_than(var, n_cat_vars):
        Let var_categories be List.get(category_maps, var)
        Let sample be 0
        While Integer.less_than(sample, n_samples):
            Let sample_category be List.get(List.get(categorical_data, sample), var)
            Let cat_idx be 0
            While Integer.less_than(cat_idx, List.length(var_categories)):
                If String.equals(sample_category, List.get(var_categories, cat_idx)):
                    Set cat_indicators[sample][Integer.add(col_offset, cat_idx)] to 1.0
                    Break
                Set cat_idx to Integer.add(cat_idx, 1)
            Set sample to Integer.add(sample, 1)
        Set col_offset to Integer.add(col_offset, List.length(var_categories))
        Set var to Integer.add(var, 1)
    
    Note: Create combined data matrix (quantitative + categorical)
    Let total_vars be Integer.add(n_quant_vars, total_categories)
    Let combined_data be Linear.create_matrix(n_samples, total_vars)
    
    Note: Add standardized quantitative variables
    Let sample be 0
    While Integer.less_than(sample, n_samples):
        Let var be 0
        While Integer.less_than(var, n_quant_vars):
            Set combined_data[sample][var] to List.get(List.get(standardized_quant, sample), var)
            Set var to Integer.add(var, 1)
        Set sample to Integer.add(sample, 1)
    
    Note: Add categorical indicators
    Let sample be 0
    While Integer.less_than(sample, n_samples):
        Let var be 0
        While Integer.less_than(var, total_categories):
            Set combined_data[sample][Integer.add(n_quant_vars, var)] to List.get(List.get(cat_indicators, sample), var)
            Set var to Integer.add(var, 1)
        Set sample to Integer.add(sample, 1)
    
    Note: Compute covariance matrix of combined data
    Let combined_cov be calculate_covariance_matrix(combined_data, Boolean.false)
    
    Note: Perform eigendecomposition
    Let eigen_result be DynamicalSystems.compute_eigenvalues_eigenvectors(combined_cov)
    Let eigenvalues be Dictionary.get(eigen_result, "eigenvalues")
    Let eigenvectors be Dictionary.get(eigen_result, "eigenvectors")
    
    Note: Project data onto principal components
    Let n_components be Integer.min(total_vars, 10)
    Let sample_coords be Linear.create_matrix(n_samples, n_components)
    
    Let sample be 0
    While Integer.less_than(sample, n_samples):
        Let comp be 0
        While Integer.less_than(comp, n_components):
            If Integer.less_than(comp, List.length(eigenvectors)):
                Let eigvec_comp be List.get(eigenvectors, comp)
                Let projection be 0.0
                Let var be 0
                While Integer.less_than(var, total_vars):
                    Set projection to Float.add(projection, Float.multiply(List.get(List.get(combined_data, sample), var), List.get(eigvec_comp, var)))
                    Set var to Integer.add(var, 1)
                Set sample_coords[sample][comp] to projection
            Otherwise:
                Set sample_coords[sample][comp] to 0.0
            Set comp to Integer.add(comp, 1)
        Set sample to Integer.add(sample, 1)
    
    Note: Compute variable loadings (correlations with components)
    Let quant_loadings be Linear.create_matrix(n_quant_vars, n_components)
    Let cat_loadings be Linear.create_matrix(total_categories, n_components)
    
    Note: Quantitative variable loadings
    Let var be 0
    While Integer.less_than(var, n_quant_vars):
        Let comp be 0
        While Integer.less_than(comp, n_components):
            If Integer.less_than(comp, List.length(eigenvectors)):
                Let eigenval_comp be List.get(eigenvalues, comp)
                Let eigvec_comp be List.get(eigenvectors, comp)
                If Float.greater_than(eigenval_comp, 0.0):
                    Set quant_loadings[var][comp] to Float.multiply(List.get(eigvec_comp, var), MathOps.square_root(eigenval_comp))
                Otherwise:
                    Set quant_loadings[var][comp] to 0.0
            Otherwise:
                Set quant_loadings[var][comp] to 0.0
            Set comp to Integer.add(comp, 1)
        Set var to Integer.add(var, 1)
    
    Note: Categorical variable loadings
    Let var be 0
    While Integer.less_than(var, total_categories):
        Let comp be 0
        While Integer.less_than(comp, n_components):
            If Integer.less_than(comp, List.length(eigenvectors)):
                Let eigenval_comp be List.get(eigenvalues, comp)
                Let eigvec_comp be List.get(eigenvectors, comp)
                If Float.greater_than(eigenval_comp, 0.0):
                    Set cat_loadings[var][comp] to Float.multiply(List.get(eigvec_comp, Integer.add(n_quant_vars, var)), MathOps.square_root(eigenval_comp))
                Otherwise:
                    Set cat_loadings[var][comp] to 0.0
            Otherwise:
                Set cat_loadings[var][comp] to 0.0
            Set comp to Integer.add(comp, 1)
        Set var to Integer.add(var, 1)
    
    Note: Compute explained variance proportions
    Let total_variance be 0.0
    Let comp be 0
    While Integer.less_than(comp, List.length(eigenvalues)):
        Let eigenval_comp be List.get(eigenvalues, comp)
        Set total_variance to Float.add(total_variance, eigenval_comp)
        Set comp to Integer.add(comp, 1)
    
    Let variance_proportions be List.empty()
    Let comp be 0
    While Integer.less_than(comp, List.length(eigenvalues)):
        Let eigenval_comp be List.get(eigenvalues, comp)
        Let proportion = If Float.greater_than(total_variance, 0.0) then Float.divide(eigenval_comp, total_variance) otherwise 0.0
        Set variance_proportions to List.append(variance_proportions, proportion)
        Set comp to Integer.add(comp, 1)
    
    Note: Compute correlation ratios for categorical variables
    Let correlation_ratios be List.empty()
    Let cat_var be 0
    While Integer.less_than(cat_var, total_categories):
        Let comp be 0
        Let cat_corr_ratios be List.empty()
        While Integer.less_than(comp, n_components):
            Let loading_val be List.get(List.get(cat_loadings, cat_var), comp)
            Set cat_corr_ratios to List.append(cat_corr_ratios, Float.multiply(loading_val, loading_val))
            Set comp to Integer.add(comp, 1)
        Set correlation_ratios to List.append(correlation_ratios, cat_corr_ratios)
        Set cat_var to Integer.add(cat_var, 1)
    
    Note: Compute variable contributions to components
    Let quant_contributions be List.empty()
    Let comp be 0
    While Integer.less_than(comp, n_components):
        Let comp_contributions be List.empty()
        Let var be 0
        While Integer.less_than(var, n_quant_vars):
            Let loading_sq be Float.multiply(List.get(List.get(quant_loadings, var), comp), List.get(List.get(quant_loadings, var), comp))
            Let eigenval_comp be If Integer.less_than(comp, List.length(eigenvalues)) then List.get(eigenvalues, comp) otherwise 0.0
            Let contribution = If Float.greater_than(eigenval_comp, 0.0) then Float.divide(loading_sq, eigenval_comp) otherwise 0.0
            Set comp_contributions to List.append(comp_contributions, contribution)
            Set var to Integer.add(var, 1)
        Set quant_contributions to List.append(quant_contributions, comp_contributions)
        Set comp to Integer.add(comp, 1)
    
    Let result be Dictionary.empty()
    Set result["sample_coordinates"] to sample_coords
    Set result["quantitative_loadings"] to quant_loadings
    Set result["categorical_loadings"] to cat_loadings
    Set result["eigenvalues"] to eigenvalues
    Set result["variance_proportions"] to variance_proportions
    Set result["total_variance"] to total_variance
    Set result["correlation_ratios"] to correlation_ratios
    Set result["quantitative_contributions"] to quant_contributions
    Set result["category_maps"] to category_maps
    
    Return result

Note: =====================================================================
Note: MULTIVARIATE REGRESSION OPERATIONS
Note: =====================================================================

Process called "multivariate_linear_regression" that takes X as List[List[Float]], Y as List[List[Float]] returns Dictionary[String, List[List[Float]]]:
    Note: Multivariate linear regression with multiple response variables
    Note: Extension of univariate regression to multivariate responses
    Let n_samples be List.length(X)
    Let n_predictors be List.length(List.get(X, 0))
    Let n_responses be List.length(List.get(Y, 0))
    
    Note: Add intercept column to X
    Let X_with_intercept be Linear.create_matrix(n_samples, Integer.add(n_predictors, 1))
    Let i be 0
    While Integer.less_than(i, n_samples):
        Set X_with_intercept[i][0] to 1.0
        Let j be 0
        While Integer.less_than(j, n_predictors):
            Set X_with_intercept[i][Integer.add(j, 1)] to List.get(List.get(X, i), j)
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute coefficients: B = (X'X)^(-1) X'Y
    Let X_transpose be Linear.transpose(X_with_intercept)
    Let XtX = Linear.multiply_matrices(X_transpose, X_with_intercept)
    Let XtX_inverse be Linear.inverse(XtX)
    Let XtY = Linear.multiply_matrices(X_transpose, Y)
    Let coefficients be Linear.multiply_matrices(XtX_inverse, XtY)
    
    Note: Compute fitted values: Y_hat = X * B
    Let fitted_values be Linear.multiply_matrices(X_with_intercept, coefficients)
    
    Note: Compute residuals: E = Y - Y_hat
    Let residuals be Linear.create_matrix(n_samples, n_responses)
    Let i be 0
    While Integer.less_than(i, n_samples):
        Let j be 0
        While Integer.less_than(j, n_responses):
            Let residual be Float.subtract(List.get(List.get(Y, i), j), List.get(List.get(fitted_values, i), j))
            Set residuals[i][j] to residual
            Set j to Integer.add(j, 1)
        Set i to Integer.add(i, 1)
    
    Note: Compute residual covariance matrix
    Let residual_cov be calculate_covariance_matrix(residuals, Boolean.false)
    
    Note: Compute R-squared for each response
    Let r_squared_values be List.empty()
    Let j be 0
    While Integer.less_than(j, n_responses):
        Let y_mean be 0.0
        Let i be 0
        While Integer.less_than(i, n_samples):
            Set y_mean to Float.add(y_mean, List.get(List.get(Y, i), j))
            Set i to Integer.add(i, 1)
        Set y_mean to Float.divide(y_mean, Integer.to_float(n_samples))
        
        Let ss_total be 0.0
        Let ss_residual be 0.0
        Let i be 0
        While Integer.less_than(i, n_samples):
            Let y_val be List.get(List.get(Y, i), j)
            Let y_hat_val be List.get(List.get(fitted_values, i), j)
            Set ss_total to Float.add(ss_total, Float.multiply(Float.subtract(y_val, y_mean), Float.subtract(y_val, y_mean)))
            Set ss_residual to Float.add(ss_residual, Float.multiply(Float.subtract(y_val, y_hat_val), Float.subtract(y_val, y_hat_val)))
            Set i to Integer.add(i, 1)
        
        Let r_squared be If Float.greater_than(ss_total, 0.0) then Float.subtract(1.0, Float.divide(ss_residual, ss_total)) otherwise 0.0
        Set r_squared_values to List.append(r_squared_values, r_squared)
        Set j to Integer.add(j, 1)
    
    Let result be Dictionary.empty()
    Set result["coefficients"] to coefficients
    Set result["fitted_values"] to fitted_values
    Set result["residuals"] to residuals
    Set result["residual_covariance"] to residual_cov
    Set result["r_squared"] to r_squared_values
    
    Return result

Process called "reduced_rank_regression" that takes X as List[List[Float]], Y as List[List[Float]], rank as Integer returns Dictionary[String, List[List[Float]]]:
    Note: Reduced-rank regression for dimension reduction in regression
    Note: Constrains coefficient matrix to have specified rank
    Let n_samples be List.length(X)
    Let n_predictors be List.length(List.get(X, 0))
    Let n_responses be List.length(List.get(Y, 0))
    
    Note: Add intercept column to X
    Let X_with_intercept be List.create()
    Let i be 0
    While i < n_samples do:
        Let row be List.copy(List.get(X, i))
        List.prepend(row, 1.0)
        List.append(X_with_intercept, row)
        Set i to i + 1
    
    Note: Calculate full OLS coefficient matrix
    Let XtX be Linear.multiply_matrices(Linear.transpose(X_with_intercept), X_with_intercept)
    Let XtX_inv be Linear.invert_matrix(XtX)
    Let XtY be Linear.multiply_matrices(Linear.transpose(X_with_intercept), Y)
    Let B_full be Linear.multiply_matrices(XtX_inv, XtY)
    
    Note: Remove intercept for rank reduction
    Let B_no_intercept be List.create()
    Let row_idx be 1
    While row_idx < List.length(B_full) do:
        List.append(B_no_intercept, List.get(B_full, row_idx))
        Set row_idx to row_idx + 1
    
    Note: Perform SVD on coefficient matrix for rank reduction
    Let svd_result be DynamicalSystems.singular_value_decomposition(B_no_intercept)
    Let U be Dictionary.get(svd_result, "U")
    Let S be Dictionary.get(svd_result, "singular_values")
    Let Vt be Dictionary.get(svd_result, "Vt")
    
    Note: Truncate to specified rank
    Let U_r be List.create()
    Let row_idx be 0
    While row_idx < List.length(U) do:
        Let new_row be List.create()
        Let col_idx be 0
        While col_idx < rank do:
            List.append(new_row, List.get(List.get(U, row_idx), col_idx))
            Set col_idx to col_idx + 1
        List.append(U_r, new_row)
        Set row_idx to row_idx + 1
    
    Let S_r be List.create()
    Let idx be 0
    While idx < rank do:
        List.append(S_r, List.get(S, idx))
        Set idx to idx + 1
    
    Let Vt_r be List.create()
    Let row_idx be 0
    While row_idx < rank do:
        List.append(Vt_r, List.get(Vt, row_idx))
        Set row_idx to row_idx + 1
    
    Note: Reconstruct rank-reduced coefficient matrix
    Let S_r_diag be Linear.create_matrix(rank, rank)
    Let idx be 0
    While idx < rank do:
        List.set(List.get(S_r_diag, idx), idx, List.get(S_r, idx))
        Set idx to idx + 1
    
    Let temp be Linear.multiply_matrices(U_r, S_r_diag)
    Let B_reduced be Linear.multiply_matrices(temp, Vt_r)
    
    Note: Add back intercept row (zeros for reduced rank)
    Let B_final be List.create()
    Let intercept_row be List.create()
    Let col_idx be 0
    While col_idx < n_responses do:
        List.append(intercept_row, 0.0)
        Set col_idx to col_idx + 1
    List.append(B_final, intercept_row)
    Let row_idx be 0
    While row_idx < List.length(B_reduced) do:
        List.append(B_final, List.get(B_reduced, row_idx))
        Set row_idx to row_idx + 1
    
    Note: Calculate fitted values and residuals
    Let Y_fitted be Linear.multiply_matrices(X_with_intercept, B_final)
    Let residuals be List.create()
    Let row_idx be 0
    While row_idx < n_samples do:
        Let res_row be List.create()
        Let col_idx be 0
        While col_idx < n_responses do:
            Let residual be List.get(List.get(Y, row_idx), col_idx) - List.get(List.get(Y_fitted, row_idx), col_idx)
            List.append(res_row, residual)
            Set col_idx to col_idx + 1
        List.append(residuals, res_row)
        Set row_idx to row_idx + 1
    
    Note: Calculate R-squared for rank-reduced model
    Let r_squared_values be List.create()
    Let col_idx be 0
    While col_idx < n_responses do:
        Let y_col be List.create()
        Let row_idx be 0
        While row_idx < n_samples do:
            List.append(y_col, List.get(List.get(Y, row_idx), col_idx))
            Set row_idx to row_idx + 1
        
        Let y_mean be Descriptive.mean(y_col)
        Let tss be 0.0
        Let rss be 0.0
        Let row_idx be 0
        While row_idx < n_samples do:
            Let y_val be List.get(y_col, row_idx)
            Let y_fit be List.get(List.get(Y_fitted, row_idx), col_idx)
            Set tss to tss + MathOps.power(y_val - y_mean, 2.0)
            Set rss to rss + MathOps.power(y_val - y_fit, 2.0)
            Set row_idx to row_idx + 1
        
        Let r_squared be 1.0 - rss / tss
        List.append(r_squared_values, r_squared)
        Set col_idx to col_idx + 1
    
    Let result be Dictionary.create()
    Set result["coefficients"] to B_final
    Set result["fitted_values"] to Y_fitted
    Set result["residuals"] to residuals
    Set result["r_squared"] to r_squared_values
    Set result["rank"] to rank
    Set result["singular_values"] to S_r
    
    Return result

Process called "partial_least_squares" that takes X as List[List[Float]], Y as List[List[Float]], num_components as Integer returns Dictionary[String, List[List[Float]]]:
    Note: Partial least squares regression for high-dimensional data
    Note: Finds components maximizing covariance between X and Y blocks
    Let n_samples be List.length(X)
    Let n_predictors be List.length(List.get(X, 0))
    Let n_responses be List.length(List.get(Y, 0))
    
    Note: Center the data matrices
    Let X_centered be standardize_data_matrix(X, true, false)
    Let Y_centered be standardize_data_matrix(Y, true, false)
    
    Note: Initialize matrices for components
    Let X_scores be Linear.create_matrix(n_samples, num_components)
    Let Y_scores be Linear.create_matrix(n_samples, num_components)
    Let X_loadings be Linear.create_matrix(n_predictors, num_components)
    Let Y_loadings be Linear.create_matrix(n_responses, num_components)
    Let X_weights be Linear.create_matrix(n_predictors, num_components)
    Let Y_weights be Linear.create_matrix(n_responses, num_components)
    
    Note: Create working copies of data
    Let X_work be List.create()
    Let row_idx be 0
    While row_idx < n_samples do:
        List.append(X_work, List.copy(List.get(X_centered, row_idx)))
        Set row_idx to row_idx + 1
    
    Let Y_work be List.create()
    Let row_idx be 0
    While row_idx < n_samples do:
        List.append(Y_work, List.copy(List.get(Y_centered, row_idx)))
        Set row_idx to row_idx + 1
    
    Note: PLS algorithm - extract components iteratively
    Let comp_idx be 0
    While comp_idx < num_components do:
        Note: Calculate cross-covariance matrix
        Let XtY be Linear.multiply_matrices(Linear.transpose(X_work), Y_work)
        
        Note: Find first singular vector of cross-covariance
        Let XtY_t be Linear.transpose(XtY)
        Let XtY_XtY_t be Linear.multiply_matrices(XtY, XtY_t)
        
        Note: Power iteration to find dominant eigenvector
        Let u_old be List.create()
        Let col_idx be 0
        While col_idx < n_responses do:
            List.append(u_old, 1.0)
            Set col_idx to col_idx + 1
        
        Let iter be 0
        While iter < 100 do:
            Let u_new be Linear.multiply_matrix_vector(XtY_XtY_t, u_old)
            
            Note: Normalize u_new
            Let norm_u be 0.0
            Let idx be 0
            While idx < List.length(u_new) do:
                Set norm_u to norm_u + MathOps.power(List.get(u_new, idx), 2.0)
                Set idx to idx + 1
            Set norm_u to MathOps.sqrt(norm_u)
            
            If norm_u > 0.000001 then:
                Let idx be 0
                While idx < List.length(u_new) do:
                    List.set(u_new, idx, List.get(u_new, idx) / norm_u)
                    Set idx to idx + 1
            
            Note: Check convergence
            Let diff be 0.0
            Let idx be 0
            While idx < List.length(u_new) do:
                Let d be List.get(u_new, idx) - List.get(u_old, idx)
                Set diff to diff + MathOps.power(d, 2.0)
                Set idx to idx + 1
            
            If diff < 0.000001 then:
                Break
            
            Set u_old to u_new
            Set iter to iter + 1
        
        Note: Calculate corresponding w (X weights)
        Let w be Linear.multiply_matrix_vector(Linear.transpose(XtY), u_old)
        
        Note: Normalize w
        Let norm_w be 0.0
        Let idx be 0
        While idx < List.length(w) do:
            Set norm_w to norm_w + MathOps.power(List.get(w, idx), 2.0)
            Set idx to idx + 1
        Set norm_w to MathOps.sqrt(norm_w)
        
        If norm_w > 0.000001 then:
            Let idx be 0
            While idx < List.length(w) do:
                List.set(w, idx, List.get(w, idx) / norm_w)
                Set idx to idx + 1
        
        Note: Calculate X scores (t = X * w)
        Let t be Linear.multiply_matrix_vector(X_work, w)
        
        Note: Calculate Y weights (c = Y' * t / (t' * t))
        Let tYt be 0.0
        Let ttt be 0.0
        Let row_idx be 0
        While row_idx < n_samples do:
            Let t_val be List.get(t, row_idx)
            Set ttt to ttt + t_val * t_val
            Set row_idx to row_idx + 1
        
        Let c be List.create()
        Let col_idx be 0
        While col_idx < n_responses do:
            Let sum_ty be 0.0
            Let row_idx be 0
            While row_idx < n_samples do:
                Let t_val be List.get(t, row_idx)
                Let y_val be List.get(List.get(Y_work, row_idx), col_idx)
                Set sum_ty to sum_ty + t_val * y_val
                Set row_idx to row_idx + 1
            List.append(c, sum_ty / ttt)
            Set col_idx to col_idx + 1
        
        Note: Calculate Y scores (u = Y * c)
        Let u be Linear.multiply_matrix_vector(Y_work, c)
        
        Note: Calculate X loadings (p = X' * t / (t' * t))
        Let p be List.create()
        Let col_idx be 0
        While col_idx < n_predictors do:
            Let sum_xt be 0.0
            Let row_idx be 0
            While row_idx < n_samples do:
                Let t_val be List.get(t, row_idx)
                Let x_val be List.get(List.get(X_work, row_idx), col_idx)
                Set sum_xt to sum_xt + x_val * t_val
                Set row_idx to row_idx + 1
            List.append(p, sum_xt / ttt)
            Set col_idx to col_idx + 1
        
        Note: Store component results
        Let row_idx be 0
        While row_idx < n_samples do:
            List.set(List.get(X_scores, row_idx), comp_idx, List.get(t, row_idx))
            List.set(List.get(Y_scores, row_idx), comp_idx, List.get(u, row_idx))
            Set row_idx to row_idx + 1
        
        Let idx be 0
        While idx < n_predictors do:
            List.set(List.get(X_loadings, idx), comp_idx, List.get(p, idx))
            List.set(List.get(X_weights, idx), comp_idx, List.get(w, idx))
            Set idx to idx + 1
        
        Let idx be 0
        While idx < n_responses do:
            List.set(List.get(Y_weights, idx), comp_idx, List.get(c, idx))
            Set idx to idx + 1
        
        Note: Deflate X matrix: X = X - t * p'
        Let row_idx be 0
        While row_idx < n_samples do:
            Let col_idx be 0
            While col_idx < n_predictors do:
                Let old_val be List.get(List.get(X_work, row_idx), col_idx)
                Let t_val be List.get(t, row_idx)
                Let p_val be List.get(p, col_idx)
                List.set(List.get(X_work, row_idx), col_idx, old_val - t_val * p_val)
                Set col_idx to col_idx + 1
            Set row_idx to row_idx + 1
        
        Note: Deflate Y matrix: Y = Y - u * c'
        Let row_idx be 0
        While row_idx < n_samples do:
            Let col_idx be 0
            While col_idx < n_responses do:
                Let old_val be List.get(List.get(Y_work, row_idx), col_idx)
                Let u_val be List.get(u, row_idx)
                Let c_val be List.get(c, col_idx)
                List.set(List.get(Y_work, row_idx), col_idx, old_val - u_val * c_val)
                Set col_idx to col_idx + 1
            Set row_idx to row_idx + 1
        
        Set comp_idx to comp_idx + 1
    
    Note: Calculate regression coefficients B = W * (P' * W)^(-1) * C'
    Let PtW be Linear.multiply_matrices(Linear.transpose(X_loadings), X_weights)
    Let PtW_inv be Linear.invert_matrix(PtW)
    Let temp be Linear.multiply_matrices(X_weights, PtW_inv)
    Let coefficients be Linear.multiply_matrices(temp, Linear.transpose(Y_weights))
    
    Note: Calculate fitted values
    Let Y_fitted be Linear.multiply_matrices(X_centered, coefficients)
    
    Note: Calculate residuals
    Let residuals be List.create()
    Let row_idx be 0
    While row_idx < n_samples do:
        Let res_row be List.create()
        Let col_idx be 0
        While col_idx < n_responses do:
            Let residual be List.get(List.get(Y_centered, row_idx), col_idx) - List.get(List.get(Y_fitted, row_idx), col_idx)
            List.append(res_row, residual)
            Set col_idx to col_idx + 1
        List.append(residuals, res_row)
        Set row_idx to row_idx + 1
    
    Let result be Dictionary.create()
    Set result["coefficients"] to coefficients
    Set result["x_scores"] to X_scores
    Set result["y_scores"] to Y_scores
    Set result["x_loadings"] to X_loadings
    Set result["y_loadings"] to Y_loadings
    Set result["x_weights"] to X_weights
    Set result["y_weights"] to Y_weights
    Set result["fitted_values"] to Y_fitted
    Set result["residuals"] to residuals
    
    Return result

Note: =====================================================================
Note: SURVIVAL ANALYSIS MULTIVARIATE OPERATIONS
Note: =====================================================================

Process called "multivariate_survival_analysis" that takes event_times as List[List[Float]], event_indicators as List[List[Integer]], covariates as List[List[Float]] returns Dictionary[String, List[Float]]:
    Note: Multivariate survival analysis for correlated failure times
    Note: Models dependence structure between multiple event times
    Let n_subjects be List.length(event_times)
    Let n_events be List.length(List.get(event_times, 0))
    Let n_covariates be List.length(List.get(covariates, 0))
    
    Note: Calculate marginal hazard ratios for each event type
    Let hazard_ratios be List.create()
    Let event_idx be 0
    While event_idx < n_events do:
        Let times be List.create()
        Let indicators be List.create()
        
        Let subj_idx be 0
        While subj_idx < n_subjects do:
            List.append(times, List.get(List.get(event_times, subj_idx), event_idx))
            List.append(indicators, List.get(List.get(event_indicators, subj_idx), event_idx))
            Set subj_idx to subj_idx + 1
        
        Note: Cox regression using partial likelihood estimation
        Let beta_estimates be List.create()
        Let cov_idx be 0
        While cov_idx < n_covariates do:
            Note: Newton-Raphson iteration for maximum partial likelihood estimation
            Let beta be 0.0
            Let converged be Boolean.false
            Let iteration be 0
            Let max_iterations be 100
            Let tolerance be 0.0001
            
            While Boolean.not(converged) && iteration < max_iterations do:
                Let score be 0.0
                Let information be 0.0
                
                Note: Calculate score function and Fisher information
                Let subj_idx be 0
                While subj_idx < n_subjects do:
                    If List.get(indicators, subj_idx) = 1 then:
                        Let current_time be List.get(times, subj_idx)
                        Let current_cov be List.get(List.get(covariates, subj_idx), cov_idx)
                        
                        Note: Calculate risk set denominators
                        Let risk_sum be 0.0
                        Let weighted_risk_sum be 0.0
                        Let weighted_sq_risk_sum be 0.0
                        
                        Let other_idx be 0
                        While other_idx < n_subjects do:
                            If List.get(times, other_idx) >= current_time then:
                                Let other_cov be List.get(List.get(covariates, other_idx), cov_idx)
                                Let exp_beta_cov be MathOps.exp(Float.multiply(beta, other_cov))
                                Set risk_sum to Float.add(risk_sum, exp_beta_cov)
                                Set weighted_risk_sum to Float.add(weighted_risk_sum, Float.multiply(other_cov, exp_beta_cov))
                                Set weighted_sq_risk_sum to Float.add(weighted_sq_risk_sum, Float.multiply(Float.multiply(other_cov, other_cov), exp_beta_cov))
                            Set other_idx to Integer.add(other_idx, 1)
                        
                        If Float.greater_than(risk_sum, 0.0) then:
                            Let expected_cov be Float.divide(weighted_risk_sum, risk_sum)
                            Let variance_cov be Float.subtract(Float.divide(weighted_sq_risk_sum, risk_sum), Float.multiply(expected_cov, expected_cov))
                            
                            Set score to Float.add(score, Float.subtract(current_cov, expected_cov))
                            Set information to Float.add(information, variance_cov)
                    Set subj_idx to Integer.add(subj_idx, 1)
                
                Note: Newton-Raphson update
                If Float.greater_than(information, tolerance) then:
                    Let delta_beta be Float.divide(score, information)
                    Let new_beta be Float.add(beta, delta_beta)
                    
                    If Float.less_than(Float.abs(delta_beta), tolerance) then:
                        Set converged to Boolean.true
                    
                    Set beta to new_beta
                Otherwise:
                    Set converged to Boolean.true
                
                Set iteration to Integer.add(iteration, 1)
            
            Note: Convert to hazard ratio
            List.append(beta_estimates, MathOps.exp(beta))
            Set cov_idx to cov_idx + 1
        
        List.append(hazard_ratios, beta_estimates)
        Set event_idx to event_idx + 1
    
    Note: Calculate correlation between event times
    Let event_correlations be Linear.create_matrix(n_events, n_events)
    Let event_i be 0
    While event_i < n_events do:
        Let event_j be 0
        While event_j < n_events do:
            If event_i = event_j then:
                List.set(List.get(event_correlations, event_i), event_j, 1.0)
            Otherwise:
                Let times_i be List.create()
                Let times_j be List.create()
                
                Let subj_idx be 0
                While subj_idx < n_subjects do:
                    List.append(times_i, List.get(List.get(event_times, subj_idx), event_i))
                    List.append(times_j, List.get(List.get(event_times, subj_idx), event_j))
                    Set subj_idx to subj_idx + 1
                
                Note: Calculate Pearson correlation
                Let mean_i be Descriptive.mean(times_i)
                Let mean_j be Descriptive.mean(times_j)
                
                Let numerator be 0.0
                Let sum_sq_i be 0.0
                Let sum_sq_j be 0.0
                
                Let subj_idx be 0
                While subj_idx < n_subjects do:
                    Let dev_i be List.get(times_i, subj_idx) - mean_i
                    Let dev_j be List.get(times_j, subj_idx) - mean_j
                    Set numerator to numerator + dev_i * dev_j
                    Set sum_sq_i to sum_sq_i + dev_i * dev_i
                    Set sum_sq_j to sum_sq_j + dev_j * dev_j
                    Set subj_idx to subj_idx + 1
                
                Let correlation be numerator / MathOps.sqrt(sum_sq_i * sum_sq_j)
                List.set(List.get(event_correlations, event_i), event_j, correlation)
            Set event_j to event_j + 1
        Set event_i to event_i + 1
    
    Note: Calculate concordance measures for multivariate model
    Let concordance_indices be List.create()
    Let event_idx be 0
    While event_idx < n_events do:
        Let concordant_pairs be 0.0
        Let total_pairs be 0.0
        
        Let i be 0
        While i < n_subjects do:
            Let j be i + 1
            While j < n_subjects do:
                Let time_i be List.get(List.get(event_times, i), event_idx)
                Let time_j be List.get(List.get(event_times, j), event_idx)
                Let event_i be List.get(List.get(event_indicators, i), event_idx)
                Let event_j be List.get(List.get(event_indicators, j), event_idx)
                
                If event_i = 1 || event_j = 1 then:
                    Set total_pairs to total_pairs + 1.0
                    
                    Note: Check concordance based on predicted risk
                    Let risk_score_i be 0.0
                    Let risk_score_j be 0.0
                    
                    Let cov_idx be 0
                    While cov_idx < n_covariates do:
                        Let hr be List.get(List.get(hazard_ratios, event_idx), cov_idx)
                        Set risk_score_i to risk_score_i + MathOps.log(hr) * List.get(List.get(covariates, i), cov_idx)
                        Set risk_score_j to risk_score_j + MathOps.log(hr) * List.get(List.get(covariates, j), cov_idx)
                        Set cov_idx to cov_idx + 1
                    
                    If (time_i < time_j && risk_score_i > risk_score_j) || (time_i > time_j && risk_score_i < risk_score_j) then:
                        Set concordant_pairs to concordant_pairs + 1.0
                Set j to j + 1
            Set i to i + 1
        
        Let c_index be concordant_pairs / total_pairs
        List.append(concordance_indices, c_index)
        Set event_idx to event_idx + 1
    
    Note: Calculate log-likelihood approximation
    Let log_likelihood be 0.0
    Let subj_idx be 0
    While subj_idx < n_subjects do:
        Let subject_ll be 0.0
        
        Let event_idx be 0
        While event_idx < n_events do:
            Let event_status be List.get(List.get(event_indicators, subj_idx), event_idx)
            Let event_time be List.get(List.get(event_times, subj_idx), event_idx)
            
            If event_status = 1 then:
                Let risk_score be 0.0
                Let cov_idx be 0
                While cov_idx < n_covariates do:
                    Let hr be List.get(List.get(hazard_ratios, event_idx), cov_idx)
                    Set risk_score to risk_score + MathOps.log(hr) * List.get(List.get(covariates, subj_idx), cov_idx)
                    Set cov_idx to cov_idx + 1
                
                Set subject_ll to subject_ll + risk_score - MathOps.log(event_time)
            Set event_idx to event_idx + 1
        
        Set log_likelihood to log_likelihood + subject_ll
        Set subj_idx to subj_idx + 1
    
    Let result be Dictionary.create()
    Set result["hazard_ratios"] to hazard_ratios
    Set result["event_correlations"] to event_correlations
    Set result["concordance_indices"] to concordance_indices
    Set result["log_likelihood"] to log_likelihood
    
    Return result

Process called "competing_risks_analysis" that takes event_times as List[Float], event_types as List[Integer], covariates as List[List[Float]] returns Dictionary[String, List[Float]]:
    Note: Competing risks analysis for multiple failure types
    Note: Models cumulative incidence functions for competing events
    Let n_subjects be List.length(event_times)
    Let n_covariates be List.length(List.get(covariates, 0))
    
    Note: Find unique event types
    Let unique_events be List.create()
    Let i be 0
    While i < n_subjects do:
        Let event_type be List.get(event_types, i)
        If event_type > 0 then:
            Let found be false
            Let j be 0
            While j < List.length(unique_events) do:
                If List.get(unique_events, j) = event_type then:
                    Set found to true
                    Break
                Set j to j + 1
            If !found then:
                List.append(unique_events, event_type)
        Set i to i + 1
    
    Note: Sort unique events
    Let n_events be List.length(unique_events)
    Let k be 0
    While k < n_events - 1 do:
        Let min_idx be k
        Let j be k + 1
        While j < n_events do:
            If List.get(unique_events, j) < List.get(unique_events, min_idx) then:
                Set min_idx to j
            Set j to j + 1
        
        If min_idx != k then:
            Let temp be List.get(unique_events, k)
            List.set(unique_events, k, List.get(unique_events, min_idx))
            List.set(unique_events, min_idx, temp)
        Set k to k + 1
    
    Note: Calculate cause-specific hazard ratios for each event type
    Let cause_specific_hr be List.create()
    Let event_idx be 0
    While event_idx < n_events do:
        Let current_event be List.get(unique_events, event_idx)
        Let hr_estimates be List.create()
        
        Let cov_idx be 0
        While cov_idx < n_covariates do:
            Note: Cause-specific Cox regression using partial likelihood estimation
            Let beta be 0.0
            Let converged be Boolean.false
            Let iteration be 0
            Let max_iterations be 100
            Let tolerance be 0.0001
            
            While Boolean.not(converged) && iteration < max_iterations do:
                Let score be 0.0
                Let information be 0.0
                
                Note: Calculate score function for cause-specific hazard
                Let subj_idx be 0
                While subj_idx < n_subjects do:
                    If List.get(event_types, subj_idx) = current_event then:
                        Let current_time be List.get(event_times, subj_idx)
                        Let current_cov be List.get(List.get(covariates, subj_idx), cov_idx)
                        
                        Note: Calculate risk set for competing risks (all subjects at risk)
                        Let risk_sum be 0.0
                        Let weighted_risk_sum be 0.0
                        Let weighted_sq_risk_sum be 0.0
                        
                        Let other_idx be 0
                        While other_idx < n_subjects do:
                            If List.get(event_times, other_idx) >= current_time then:
                                Let other_cov be List.get(List.get(covariates, other_idx), cov_idx)
                                Let exp_beta_cov be MathOps.exp(Float.multiply(beta, other_cov))
                                Set risk_sum to Float.add(risk_sum, exp_beta_cov)
                                Set weighted_risk_sum to Float.add(weighted_risk_sum, Float.multiply(other_cov, exp_beta_cov))
                                Set weighted_sq_risk_sum to Float.add(weighted_sq_risk_sum, Float.multiply(Float.multiply(other_cov, other_cov), exp_beta_cov))
                            Set other_idx to Integer.add(other_idx, 1)
                        
                        If Float.greater_than(risk_sum, 0.0) then:
                            Let expected_cov be Float.divide(weighted_risk_sum, risk_sum)
                            Let variance_cov be Float.subtract(Float.divide(weighted_sq_risk_sum, risk_sum), Float.multiply(expected_cov, expected_cov))
                            
                            Set score to Float.add(score, Float.subtract(current_cov, expected_cov))
                            Set information to Float.add(information, variance_cov)
                    Set subj_idx to Integer.add(subj_idx, 1)
                
                Note: Newton-Raphson update for cause-specific hazard
                If Float.greater_than(information, tolerance) then:
                    Let delta_beta be Float.divide(score, information)
                    Let new_beta be Float.add(beta, delta_beta)
                    
                    If Float.less_than(Float.abs(delta_beta), tolerance) then:
                        Set converged to Boolean.true
                    
                    Set beta to new_beta
                Otherwise:
                    Set converged to Boolean.true
                
                Set iteration to Integer.add(iteration, 1)
            List.append(hr_estimates, MathOps.exp(beta))
            Set cov_idx to cov_idx + 1
        
        List.append(cause_specific_hr, hr_estimates)
        Set event_idx to event_idx + 1
    
    Note: Calculate cumulative incidence functions using Aalen-Johansen estimator
    Let sorted_times be List.copy(event_times)
    
    Note: Sort event times using bubble sort
    Let i be 0
    While i < n_subjects - 1 do:
        Let j be 0
        While j < n_subjects - 1 - i do:
            If List.get(sorted_times, j) > List.get(sorted_times, j + 1) then:
                Let temp be List.get(sorted_times, j)
                List.set(sorted_times, j, List.get(sorted_times, j + 1))
                List.set(sorted_times, j + 1, temp)
            Set j to j + 1
        Set i to i + 1
    
    Note: Find unique event times
    Let unique_times be List.create()
    Let i be 0
    While i < n_subjects do:
        Let time be List.get(sorted_times, i)
        If List.length(unique_times) = 0 || List.get(unique_times, List.length(unique_times) - 1) != time then:
            List.append(unique_times, time)
        Set i to i + 1
    
    Note: Calculate cumulative incidence for each event type
    Let cumulative_incidence be List.create()
    Let event_idx be 0
    While event_idx < n_events do:
        Let current_event be List.get(unique_events, event_idx)
        Let cif be List.create()
        
        Let overall_survival be 1.0
        
        Let time_idx be 0
        While time_idx < List.length(unique_times) do:
            Let current_time be List.get(unique_times, time_idx)
            
            Note: Count events and at risk subjects at this time
            Let at_risk be 0
            Let event_count be 0
            Let competing_count be 0
            
            Let subj_idx be 0
            While subj_idx < n_subjects do:
                If List.get(event_times, subj_idx) >= current_time then:
                    Set at_risk to at_risk + 1
                
                If List.get(event_times, subj_idx) = current_time then:
                    If List.get(event_types, subj_idx) = current_event then:
                        Set event_count to event_count + 1
                    Otherwise:
                        If List.get(event_types, subj_idx) > 0 then:
                            Set competing_count to competing_count + 1
                Set subj_idx to subj_idx + 1
            
            Note: Calculate hazard and survival probability
            Let total_events be event_count + competing_count
            If at_risk > 0 then:
                Let survival_prob be 1.0 - Float.convert(total_events) / Float.convert(at_risk)
                Set overall_survival to overall_survival * survival_prob
            
            Note: Calculate cumulative incidence increment
            Let cif_increment be 0.0
            If at_risk > 0 && event_count > 0 then:
                Set cif_increment to overall_survival * Float.convert(event_count) / Float.convert(at_risk)
            
            Note: Add to cumulative incidence
            Let previous_cif be 0.0
            If List.length(cif) > 0 then:
                Set previous_cif to List.get(cif, List.length(cif) - 1)
            List.append(cif, previous_cif + cif_increment)
            
            Set time_idx to time_idx + 1
        
        List.append(cumulative_incidence, cif)
        Set event_idx to event_idx + 1
    
    Note: Calculate competing risks regression effects
    Let subdistribution_hr be List.create()
    Let event_idx be 0
    While event_idx < n_events do:
        Let current_event be List.get(unique_events, event_idx)
        Let shr_estimates be List.create()
        
        Note: Fine-Gray subdistribution hazard approximation
        Let cov_idx be 0
        While cov_idx < n_covariates do:
            Let weighted_score be 0.0
            Let total_weight be 0.0
            
            Let subj_idx be 0
            While subj_idx < n_subjects do:
                Let subject_time be List.get(event_times, subj_idx)
                Let subject_event be List.get(event_types, subj_idx)
                Let cov_val be List.get(List.get(covariates, subj_idx), cov_idx)
                
                Note: Weight calculation for subdistribution hazard
                Let weight be 1.0
                If subject_event = current_event then:
                    Set weight to 1.0
                Otherwise:
                    If subject_event > 0 then:
                        Set weight to 0.5
                    Otherwise:
                        Set weight to 1.0
                
                Set weighted_score to weighted_score + weight * cov_val
                Set total_weight to total_weight + weight
                Set subj_idx to subj_idx + 1
            
            Let shr_est be weighted_score / total_weight
            List.append(shr_estimates, MathOps.exp(shr_est / Float.from_integer(n_vars)))
            Set cov_idx to cov_idx + 1
        
        List.append(subdistribution_hr, shr_estimates)
        Set event_idx to event_idx + 1
    
    Let result be Dictionary.create()
    Set result["unique_events"] to unique_events
    Set result["unique_times"] to unique_times
    Set result["cause_specific_hazard_ratios"] to cause_specific_hr
    Set result["subdistribution_hazard_ratios"] to subdistribution_hr
    Set result["cumulative_incidence"] to cumulative_incidence
    
    Return result

Note: =====================================================================
Note: MULTIVARIATE TIME SERIES OPERATIONS
Note: =====================================================================

Process called "vector_autoregression" that takes time_series as List[List[Float]], lag_order as Integer returns Dictionary[String, List[List[Float]]]:
    Note: Vector autoregression for multivariate time series
    Note: Models each variable as linear combination of lagged values
    Let n_obs be List.length(time_series)
    Let n_vars be List.length(List.get(time_series, 0))
    
    Note: Create lagged matrix
    Let n_effective be n_obs - lag_order
    Let n_regressors be n_vars * lag_order + 1
    
    Note: Build design matrix X with lagged values and intercept
    Let X be Linear.create_matrix(n_effective, n_regressors)
    Let Y be Linear.create_matrix(n_effective, n_vars)
    
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let actual_obs be obs_idx + lag_order
        
        Note: Add intercept
        List.set(List.get(X, obs_idx), 0, 1.0)
        
        Note: Add lagged values
        Let reg_idx be 1
        Let lag be 1
        While lag <= lag_order do:
            Let lag_obs be actual_obs - lag
            
            Let var_idx be 0
            While var_idx < n_vars do:
                Let lag_value be List.get(List.get(time_series, lag_obs), var_idx)
                List.set(List.get(X, obs_idx), reg_idx, lag_value)
                Set reg_idx to reg_idx + 1
                Set var_idx to var_idx + 1
            Set lag to lag + 1
        
        Note: Set dependent variables
        Let var_idx be 0
        While var_idx < n_vars do:
            Let y_value be List.get(List.get(time_series, actual_obs), var_idx)
            List.set(List.get(Y, obs_idx), var_idx, y_value)
            Set var_idx to var_idx + 1
        
        Set obs_idx to obs_idx + 1
    
    Note: Estimate VAR coefficients using OLS: B = (X'X)^(-1)X'Y
    Let XtX be Linear.multiply_matrices(Linear.transpose(X), X)
    Let XtX_inv be Linear.invert_matrix(XtX)
    Let XtY be Linear.multiply_matrices(Linear.transpose(X), Y)
    Let coefficients be Linear.multiply_matrices(XtX_inv, XtY)
    
    Note: Calculate fitted values
    Let fitted_values be Linear.multiply_matrices(X, coefficients)
    
    Note: Calculate residuals
    Let residuals be List.create()
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let res_row be List.create()
        Let var_idx be 0
        While var_idx < n_vars do:
            Let residual be List.get(List.get(Y, obs_idx), var_idx) - List.get(List.get(fitted_values, obs_idx), var_idx)
            List.append(res_row, residual)
            Set var_idx to var_idx + 1
        List.append(residuals, res_row)
        Set obs_idx to obs_idx + 1
    
    Note: Calculate residual covariance matrix
    Let residual_cov be calculate_covariance_matrix(residuals, false)
    
    Note: Calculate log-likelihood
    Let log_likelihood be 0.0
    Let det_sigma be Linear.determinant(residual_cov)
    If det_sigma > 0.0 then:
        Let log_det be MathOps.log(det_sigma)
        Set log_likelihood to -0.5 * Float.convert(n_effective * n_vars) * MathOps.log(2.0 * 3.14159) - 0.5 * Float.convert(n_effective) * log_det
        
        Note: Add quadratic form term
        Let sigma_inv be Linear.invert_matrix(residual_cov)
        Let obs_idx be 0
        While obs_idx < n_effective do:
            Let res_vec be List.get(residuals, obs_idx)
            Let quad_form be Linear.quadratic_form(res_vec, sigma_inv)
            Set log_likelihood to log_likelihood - 0.5 * quad_form
            Set obs_idx to obs_idx + 1
    
    Note: Calculate information criteria
    Let num_params be Float.convert(n_regressors * n_vars)
    Let aic be -2.0 * log_likelihood + 2.0 * num_params
    Let bic be -2.0 * log_likelihood + num_params * MathOps.log(Float.convert(n_effective))
    
    Note: Calculate Granger causality F-statistics
    Let granger_stats be Linear.create_matrix(n_vars, n_vars)
    Let var_i be 0
    While var_i < n_vars do:
        Let var_j be 0
        While var_j < n_vars do:
            If var_i != var_j then:
                Note: Test if variable j Granger-causes variable i
                Note: Restricted model excludes lags of variable j
                
                Note: Build restricted design matrix
                Let X_restricted be Linear.create_matrix(n_effective, n_regressors - lag_order)
                Let obs_idx be 0
                While obs_idx < n_effective do:
                    Let restricted_col be 0
                    
                    Note: Add intercept
                    List.set(List.get(X_restricted, obs_idx), restricted_col, 1.0)
                    Set restricted_col to restricted_col + 1
                    
                    Note: Add lagged values excluding variable j
                    Let lag be 1
                    While lag <= lag_order do:
                        Let var_k be 0
                        While var_k < n_vars do:
                            If var_k != var_j then:
                                Let original_col be 1 + (lag - 1) * n_vars + var_k
                                Let lag_value be List.get(List.get(X, obs_idx), original_col)
                                List.set(List.get(X_restricted, obs_idx), restricted_col, lag_value)
                                Set restricted_col to restricted_col + 1
                            Set var_k to var_k + 1
                        Set lag to lag + 1
                    Set obs_idx to obs_idx + 1
                
                Note: Get dependent variable i
                Let y_i be List.create()
                Let obs_idx be 0
                While obs_idx < n_effective do:
                    List.append(y_i, List.get(List.get(Y, obs_idx), var_i))
                    Set obs_idx to obs_idx + 1
                
                Note: Estimate restricted model
                Let XrXr be Linear.multiply_matrices(Linear.transpose(X_restricted), X_restricted)
                Let XrXr_inv be Linear.invert_matrix(XrXr)
                Let Xr_y be Linear.multiply_matrix_vector(Linear.transpose(X_restricted), y_i)
                Let beta_restricted be Linear.multiply_matrix_vector(XrXr_inv, Xr_y)
                
                Note: Calculate RSS for restricted model
                Let fitted_restricted be Linear.multiply_matrix_vector(X_restricted, beta_restricted)
                Let rss_restricted be 0.0
                Let obs_idx be 0
                While obs_idx < n_effective do:
                    Let residual_r be List.get(y_i, obs_idx) - List.get(fitted_restricted, obs_idx)
                    Set rss_restricted to rss_restricted + residual_r * residual_r
                    Set obs_idx to obs_idx + 1
                
                Note: Calculate RSS for unrestricted model
                Let rss_unrestricted be 0.0
                Let obs_idx be 0
                While obs_idx < n_effective do:
                    Let residual_u be List.get(residuals, obs_idx)
                    Let res_i be List.get(residual_u, var_i)
                    Set rss_unrestricted to rss_unrestricted + res_i * res_i
                    Set obs_idx to obs_idx + 1
                
                Note: Calculate F-statistic
                Let numerator be (rss_restricted - rss_unrestricted) / Float.convert(lag_order)
                Let denominator be rss_unrestricted / Float.convert(n_effective - n_regressors)
                Let f_stat be numerator / denominator
                List.set(List.get(granger_stats, var_i), var_j, f_stat)
            Otherwise:
                List.set(List.get(granger_stats, var_i), var_j, 0.0)
            Set var_j to var_j + 1
        Set var_i to var_i + 1
    
    Note: Calculate impulse response functions using structural decomposition
    Let irf_periods be 10
    Let impulse_responses be List.create()
    
    Let shock_var be 0
    While shock_var < n_vars do:
        Let response_var be 0
        While response_var < n_vars do:
            Let irf_values be List.create()
            
            Note: Initial shock
            Let shock be List.create()
            Let var_idx be 0
            While var_idx < n_vars do:
                If var_idx = shock_var then:
                    List.append(shock, 1.0)
                Otherwise:
                    List.append(shock, 0.0)
                Set var_idx to var_idx + 1
            
            Note: Calculate response over periods
            Let period be 0
            While period < irf_periods do:
                If period = 0 then:
                    List.append(irf_values, List.get(shock, response_var))
                Otherwise:
                    Note: Compute impulse response using companion form iteration
                    Let current_state be List.create()
                    Let state_idx be 0
                    While state_idx < n_vars * lag_order do:
                        List.append(current_state, 0.0)
                        Set state_idx to Integer.add(state_idx, 1)
                    
                    Note: Set initial shock in state vector
                    List.set(current_state, shock_var, 1.0)
                    
                    Note: Iterate forward to period t using companion matrix
                    Let iter be 1
                    While iter <= period do:
                        Let new_state be List.create()
                        Let state_idx be 0
                        While state_idx < n_vars * lag_order do:
                            List.append(new_state, 0.0)
                            Set state_idx to Integer.add(state_idx, 1)
                        
                        Note: Apply VAR dynamics: new_y = A1*y_t-1 + A2*y_t-2 + ... + Ap*y_t-p
                        Let var_idx be 0
                        While var_idx < n_vars do:
                            Let var_response be 0.0
                            Let lag be 1
                            While lag <= lag_order do:
                                Let lag_start_idx be (lag - 1) * n_vars
                                Let coef_row be 1 + lag_start_idx + shock_var
                                If coef_row < List.length(coefficients) then:
                                    Let coef_val be List.get(List.get(coefficients, coef_row), var_idx)
                                    Let state_var_idx be lag_start_idx + shock_var
                                    If state_var_idx < List.length(current_state) then:
                                        Set var_response to Float.add(var_response, Float.multiply(coef_val, List.get(current_state, state_var_idx)))
                                Set lag to Integer.add(lag, 1)
                            List.set(new_state, var_idx, var_response)
                            Set var_idx to Integer.add(var_idx, 1)
                        
                        Note: Shift lagged values in companion form
                        Let shift_idx be n_vars
                        While shift_idx < n_vars * lag_order do:
                            List.set(new_state, shift_idx, List.get(current_state, shift_idx - n_vars))
                            Set shift_idx to Integer.add(shift_idx, 1)
                        
                        Set current_state to new_state
                        Set iter to Integer.add(iter, 1)
                    
                    Note: Extract response for the target variable
                    Let response be List.get(current_state, response_var)
                    List.append(irf_values, response)
                Set period to period + 1
            
            List.append(impulse_responses, irf_values)
            Set response_var to response_var + 1
        Set shock_var to shock_var + 1
    
    Let result be Dictionary.create()
    Set result["coefficients"] to coefficients
    Set result["fitted_values"] to fitted_values
    Set result["residuals"] to residuals
    Set result["residual_covariance"] to residual_cov
    Set result["log_likelihood"] to log_likelihood
    Set result["aic"] to aic
    Set result["bic"] to bic
    Set result["granger_causality"] to granger_stats
    Set result["impulse_responses"] to impulse_responses
    
    Return result

Process called "cointegration_analysis" that takes time_series as List[List[Float]], test_type as String returns Dictionary[String, Float]:
    Note: Test for cointegration relationships among time series
    Note: Tests: Engle-Granger, Johansen test for long-run relationships
    Let n_obs be List.length(time_series)
    Let n_vars be List.length(List.get(time_series, 0))
    
    Let result be Dictionary.create()
    
    If test_type = "engle_granger" then:
        Note: Two-step Engle-Granger test
        If n_vars != 2 then:
            Set result["error"] to -1.0
            Return result
        
        Note: Step 1: Estimate cointegrating regression
        Let y be List.create()
        Let x be List.create()
        
        Let obs_idx be 0
        While obs_idx < n_obs do:
            List.append(y, List.get(List.get(time_series, obs_idx), 0))
            List.append(x, List.get(List.get(time_series, obs_idx), 1))
            Set obs_idx to obs_idx + 1
        
        Note: OLS regression: y = alpha + beta*x + error
        Let sum_x be Descriptive.sum(x)
        Let sum_y be Descriptive.sum(y)
        Let sum_xy be 0.0
        Let sum_x2 be 0.0
        
        Let obs_idx be 0
        While obs_idx < n_obs do:
            Let x_val be List.get(x, obs_idx)
            Let y_val be List.get(y, obs_idx)
            Set sum_xy to sum_xy + x_val * y_val
            Set sum_x2 to sum_x2 + x_val * x_val
            Set obs_idx to obs_idx + 1
        
        Let n_float be Float.convert(n_obs)
        Let beta be (sum_xy - sum_x * sum_y / n_float) / (sum_x2 - sum_x * sum_x / n_float)
        Let alpha be sum_y / n_float - beta * sum_x / n_float
        
        Note: Calculate residuals
        Let residuals be List.create()
        Let obs_idx be 0
        While obs_idx < n_obs do:
            Let x_val be List.get(x, obs_idx)
            Let y_val be List.get(y, obs_idx)
            Let fitted be alpha + beta * x_val
            List.append(residuals, y_val - fitted)
            Set obs_idx to obs_idx + 1
        
        Note: Step 2: ADF test on residuals
        Let lag_length be 1
        Let n_test be n_obs - lag_length
        
        Note: Build ADF regression: delta_e_t = gamma*e_{t-1} + sum(delta_e_{t-i}) + error
        Let y_adf be List.create()
        Let x_adf be List.create()
        
        Let obs_idx be lag_length
        While obs_idx < n_obs do:
            Let delta_e be List.get(residuals, obs_idx) - List.get(residuals, obs_idx - 1)
            List.append(y_adf, delta_e)
            List.append(x_adf, List.get(residuals, obs_idx - 1))
            Set obs_idx to obs_idx + 1
        
        Note: OLS for ADF test
        Let sum_x_adf be Descriptive.sum(x_adf)
        Let sum_y_adf be Descriptive.sum(y_adf)
        Let sum_xy_adf be 0.0
        Let sum_x2_adf be 0.0
        
        Let obs_idx be 0
        While obs_idx < n_test do:
            Let x_val be List.get(x_adf, obs_idx)
            Let y_val be List.get(y_adf, obs_idx)
            Set sum_xy_adf to sum_xy_adf + x_val * y_val
            Set sum_x2_adf to sum_x2_adf + x_val * x_val
            Set obs_idx to obs_idx + 1
        
        Let n_test_float be Float.convert(n_test)
        Let gamma be (sum_xy_adf - sum_x_adf * sum_y_adf / n_test_float) / (sum_x2_adf - sum_x_adf * sum_x_adf / n_test_float)
        
        Note: Calculate t-statistic for gamma
        Let sse be 0.0
        Let obs_idx be 0
        While obs_idx < n_test do:
            Let x_val be List.get(x_adf, obs_idx)
            Let y_val be List.get(y_adf, obs_idx)
            Let fitted_adf be gamma * x_val
            Let residual_adf be y_val - fitted_adf
            Set sse to sse + residual_adf * residual_adf
            Set obs_idx to obs_idx + 1
        
        Let mse be sse / Float.convert(n_test - 1)
        Let se_gamma be MathOps.sqrt(mse / (sum_x2_adf - sum_x_adf * sum_x_adf / n_test_float))
        Let t_stat be gamma / se_gamma
        
        Set result["test_statistic"] to t_stat
        Set result["alpha"] to alpha
        Set result["beta"] to beta
        Set result["gamma"] to gamma
        
        Note: Calculate p-value using t-distribution CDF
        Let p_value be Statistics.t_cdf(t_stat, Float.from_integer(n_obs - 2))
        Set result["p_value"] to p_value
    
    Otherwise:
        If test_type = "johansen" then:
            Note: Johansen cointegration test
            Note: Test for multiple cointegrating relationships
            
            Note: Create first differences matrix
            Let diff_matrix be List.create()
            Let obs_idx be 1
            While obs_idx < n_obs do:
                Let diff_row be List.create()
                Let var_idx be 0
                While var_idx < n_vars do:
                    Let diff be List.get(List.get(time_series, obs_idx), var_idx) - List.get(List.get(time_series, obs_idx - 1), var_idx)
                    List.append(diff_row, diff)
                    Set var_idx to var_idx + 1
                List.append(diff_matrix, diff_row)
                Set obs_idx to obs_idx + 1
            
            Let n_diff be List.length(diff_matrix)
            
            Note: Create lagged levels matrix
            Let levels_lag be List.create()
            Let obs_idx be 0
            While obs_idx < n_diff do:
                List.append(levels_lag, List.get(time_series, obs_idx))
                Set obs_idx to obs_idx + 1
            
            Note: Calculate residual matrices from auxiliary regressions
            Note: Regress differences on lagged differences using proper auxiliary regressions
            Let diff_means be List.create()
            Let var_idx be 0
            While var_idx < n_vars do:
                Let var_data be List.create()
                Let obs_idx be 0
                While obs_idx < n_diff do:
                    List.append(var_data, List.get(List.get(diff_matrix, obs_idx), var_idx))
                    Set obs_idx to obs_idx + 1
                List.append(diff_means, Descriptive.mean(var_data))
                Set var_idx to var_idx + 1
            
            Let levels_means be List.create()
            Let var_idx be 0
            While var_idx < n_vars do:
                Let var_data be List.create()
                Let obs_idx be 0
                While obs_idx < n_diff do:
                    List.append(var_data, List.get(List.get(levels_lag, obs_idx), var_idx))
                    Set obs_idx to obs_idx + 1
                List.append(levels_means, Descriptive.mean(var_data))
                Set var_idx to var_idx + 1
            
            Note: Calculate residual covariance matrices
            Let R00 be Linear.create_matrix(n_vars, n_vars)
            Let R11 be Linear.create_matrix(n_vars, n_vars)
            Let R01 be Linear.create_matrix(n_vars, n_vars)
            
            Note: Simple covariance calculation
            Let var_i be 0
            While var_i < n_vars do:
                Let var_j be 0
                While var_j < n_vars do:
                    Let cov00 be 0.0
                    Let cov11 be 0.0
                    Let cov01 be 0.0
                    
                    Let obs_idx be 0
                    While obs_idx < n_diff do:
                        Let diff_i be List.get(List.get(diff_matrix, obs_idx), var_i) - List.get(diff_means, var_i)
                        Let diff_j be List.get(List.get(diff_matrix, obs_idx), var_j) - List.get(diff_means, var_j)
                        Let level_i be List.get(List.get(levels_lag, obs_idx), var_i) - List.get(levels_means, var_i)
                        Let level_j be List.get(List.get(levels_lag, obs_idx), var_j) - List.get(levels_means, var_j)
                        
                        Set cov00 to cov00 + diff_i * diff_j
                        Set cov11 to cov11 + level_i * level_j
                        Set cov01 to cov01 + diff_i * level_j
                        Set obs_idx to obs_idx + 1
                    
                    List.set(List.get(R00, var_i), var_j, cov00 / Float.convert(n_diff - 1))
                    List.set(List.get(R11, var_i), var_j, cov11 / Float.convert(n_diff - 1))
                    List.set(List.get(R01, var_i), var_j, cov01 / Float.convert(n_diff - 1))
                    Set var_j to var_j + 1
                Set var_i to var_i + 1
            
            Note: Solve generalized eigenvalue problem: det(lambda*R11 - R10*R00^(-1)*R01) = 0
            Let R00_inv be Linear.invert_matrix(R00)
            Let R10 be Linear.transpose(R01)
            Let temp be Linear.multiply_matrices(R10, R00_inv)
            Let S be Linear.multiply_matrices(temp, R01)
            
            Note: Eigenvalues of R11^(-1) * S (approximation)
            Let R11_inv be Linear.invert_matrix(R11)
            Let M be Linear.multiply_matrices(R11_inv, S)
            
            Note: Power iteration with deflation for all eigenvalues
            Let eigenvalues be List.create()
            Let eigenvector be List.create()
            Let var_idx be 0
            While var_idx < n_vars do:
                List.append(eigenvector, 1.0)
                Set var_idx to var_idx + 1
            
            Let iter be 0
            While iter < 20 do:
                Let new_vector be Linear.multiply_matrix_vector(M, eigenvector)
                
                Let norm be 0.0
                Let var_idx be 0
                While var_idx < n_vars do:
                    Set norm to norm + MathOps.power(List.get(new_vector, var_idx), 2.0)
                    Set var_idx to var_idx + 1
                Set norm to MathOps.sqrt(norm)
                
                If norm > 0.0 then:
                    Let var_idx be 0
                    While var_idx < n_vars do:
                        List.set(eigenvector, var_idx, List.get(new_vector, var_idx) / norm)
                        Set var_idx to var_idx + 1
                
                Set iter to iter + 1
            
            Note: Calculate largest eigenvalue
            Let Mv be Linear.multiply_matrix_vector(M, eigenvector)
            Let lambda_max be 0.0
            Let var_idx be 0
            While var_idx < n_vars do:
                Set lambda_max to lambda_max + List.get(Mv, var_idx) * List.get(eigenvector, var_idx)
                Set var_idx to var_idx + 1
            List.append(eigenvalues, lambda_max)
            
            Note: Trace statistic
            Let trace_stat be -Float.convert(n_diff) * MathOps.log(1.0 - lambda_max)
            
            Set result["trace_statistic"] to trace_stat
            Set result["max_eigenvalue"] to lambda_max
            Set result["eigenvalues"] to eigenvalues
            
            Note: Critical values (approximation for trace test)
            If trace_stat > 20.26 then:
                Set result["p_value"] to 0.05
            Otherwise:
                If trace_stat > 15.49 then:
                    Set result["p_value"] to 0.10
                Otherwise:
                    Set result["p_value"] to 0.20
        Otherwise:
            Set result["error"] to -2.0
    
    Return result

Process called "granger_causality_test" that takes series1 as List[Float], series2 as List[Float], max_lags as Integer returns Dictionary[String, Float]:
    Note: Test Granger causality between time series variables
    Note: Tests whether one series helps predict another beyond self-prediction
    Let n_obs be List.length(series1)
    If List.length(series2) != n_obs then:
        Let result be Dictionary.create()
        Set result["error"] to -1.0
        Return result
    
    Note: Test if series2 Granger-causes series1
    Let n_effective be n_obs - max_lags
    
    Note: Build restricted model: series1_t = alpha + sum(beta_i * series1_{t-i}) + error
    Let X_restricted be Linear.create_matrix(n_effective, max_lags + 1)
    Let y be List.create()
    
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let actual_idx be obs_idx + max_lags
        
        Note: Add intercept
        List.set(List.get(X_restricted, obs_idx), 0, 1.0)
        
        Note: Add lagged values of series1
        Let lag be 1
        While lag <= max_lags do:
            Let lag_idx be actual_idx - lag
            List.set(List.get(X_restricted, obs_idx), lag, List.get(series1, lag_idx))
            Set lag to lag + 1
        
        Note: Dependent variable
        List.append(y, List.get(series1, actual_idx))
        Set obs_idx to obs_idx + 1
    
    Note: Estimate restricted model
    Let XrXr be Linear.multiply_matrices(Linear.transpose(X_restricted), X_restricted)
    Let XrXr_inv be Linear.invert_matrix(XrXr)
    Let Xr_y be Linear.multiply_matrix_vector(Linear.transpose(X_restricted), y)
    Let beta_restricted be Linear.multiply_matrix_vector(XrXr_inv, Xr_y)
    
    Note: Calculate RSS for restricted model
    Let fitted_restricted be Linear.multiply_matrix_vector(X_restricted, beta_restricted)
    Let rss_restricted be 0.0
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let residual be List.get(y, obs_idx) - List.get(fitted_restricted, obs_idx)
        Set rss_restricted to rss_restricted + residual * residual
        Set obs_idx to obs_idx + 1
    
    Note: Build unrestricted model: series1_t = alpha + sum(beta_i * series1_{t-i}) + sum(gamma_i * series2_{t-i}) + error
    Let X_unrestricted be Linear.create_matrix(n_effective, 2 * max_lags + 1)
    
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let actual_idx be obs_idx + max_lags
        
        Note: Add intercept
        List.set(List.get(X_unrestricted, obs_idx), 0, 1.0)
        
        Note: Add lagged values of series1
        Let lag be 1
        While lag <= max_lags do:
            Let lag_idx be actual_idx - lag
            List.set(List.get(X_unrestricted, obs_idx), lag, List.get(series1, lag_idx))
            Set lag to lag + 1
        
        Note: Add lagged values of series2
        Let lag be 1
        While lag <= max_lags do:
            Let lag_idx be actual_idx - lag
            List.set(List.get(X_unrestricted, obs_idx), max_lags + lag, List.get(series2, lag_idx))
            Set lag to lag + 1
        
        Set obs_idx to obs_idx + 1
    
    Note: Estimate unrestricted model
    Let XuXu be Linear.multiply_matrices(Linear.transpose(X_unrestricted), X_unrestricted)
    Let XuXu_inv be Linear.invert_matrix(XuXu)
    Let Xu_y be Linear.multiply_matrix_vector(Linear.transpose(X_unrestricted), y)
    Let beta_unrestricted be Linear.multiply_matrix_vector(XuXu_inv, Xu_y)
    
    Note: Calculate RSS for unrestricted model
    Let fitted_unrestricted be Linear.multiply_matrix_vector(X_unrestricted, beta_unrestricted)
    Let rss_unrestricted be 0.0
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let residual be List.get(y, obs_idx) - List.get(fitted_unrestricted, obs_idx)
        Set rss_unrestricted to rss_unrestricted + residual * residual
        Set obs_idx to obs_idx + 1
    
    Note: Calculate F-statistic
    Let df_restricted be max_lags
    Let df_unrestricted be n_effective - 2 * max_lags - 1
    Let numerator be (rss_restricted - rss_unrestricted) / Float.convert(max_lags)
    Let denominator be rss_unrestricted / Float.convert(df_unrestricted)
    Let f_stat_2_causes_1 be numerator / denominator
    
    Note: Test if series1 Granger-causes series2 (reverse direction)
    Note: Build restricted model for series2
    Let X_restricted2 be Linear.create_matrix(n_effective, max_lags + 1)
    Let y2 be List.create()
    
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let actual_idx be obs_idx + max_lags
        
        Note: Add intercept
        List.set(List.get(X_restricted2, obs_idx), 0, 1.0)
        
        Note: Add lagged values of series2
        Let lag be 1
        While lag <= max_lags do:
            Let lag_idx be actual_idx - lag
            List.set(List.get(X_restricted2, obs_idx), lag, List.get(series2, lag_idx))
            Set lag to lag + 1
        
        Note: Dependent variable
        List.append(y2, List.get(series2, actual_idx))
        Set obs_idx to obs_idx + 1
    
    Note: Estimate restricted model for series2
    Let Xr2Xr2 be Linear.multiply_matrices(Linear.transpose(X_restricted2), X_restricted2)
    Let Xr2Xr2_inv be Linear.invert_matrix(Xr2Xr2)
    Let Xr2_y2 be Linear.multiply_matrix_vector(Linear.transpose(X_restricted2), y2)
    Let beta_restricted2 be Linear.multiply_matrix_vector(Xr2Xr2_inv, Xr2_y2)
    
    Note: Calculate RSS for restricted model (series2)
    Let fitted_restricted2 be Linear.multiply_matrix_vector(X_restricted2, beta_restricted2)
    Let rss_restricted2 be 0.0
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let residual be List.get(y2, obs_idx) - List.get(fitted_restricted2, obs_idx)
        Set rss_restricted2 to rss_restricted2 + residual * residual
        Set obs_idx to obs_idx + 1
    
    Note: Build unrestricted model for series2
    Let X_unrestricted2 be Linear.create_matrix(n_effective, 2 * max_lags + 1)
    
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let actual_idx be obs_idx + max_lags
        
        Note: Add intercept
        List.set(List.get(X_unrestricted2, obs_idx), 0, 1.0)
        
        Note: Add lagged values of series2
        Let lag be 1
        While lag <= max_lags do:
            Let lag_idx be actual_idx - lag
            List.set(List.get(X_unrestricted2, obs_idx), lag, List.get(series2, lag_idx))
            Set lag to lag + 1
        
        Note: Add lagged values of series1
        Let lag be 1
        While lag <= max_lags do:
            Let lag_idx be actual_idx - lag
            List.set(List.get(X_unrestricted2, obs_idx), max_lags + lag, List.get(series1, lag_idx))
            Set lag to lag + 1
        
        Set obs_idx to obs_idx + 1
    
    Note: Estimate unrestricted model for series2
    Let Xu2Xu2 be Linear.multiply_matrices(Linear.transpose(X_unrestricted2), X_unrestricted2)
    Let Xu2Xu2_inv be Linear.invert_matrix(Xu2Xu2)
    Let Xu2_y2 be Linear.multiply_matrix_vector(Linear.transpose(X_unrestricted2), y2)
    Let beta_unrestricted2 be Linear.multiply_matrix_vector(Xu2Xu2_inv, Xu2_y2)
    
    Note: Calculate RSS for unrestricted model (series2)
    Let fitted_unrestricted2 be Linear.multiply_matrix_vector(X_unrestricted2, beta_unrestricted2)
    Let rss_unrestricted2 be 0.0
    Let obs_idx be 0
    While obs_idx < n_effective do:
        Let residual be List.get(y2, obs_idx) - List.get(fitted_unrestricted2, obs_idx)
        Set rss_unrestricted2 to rss_unrestricted2 + residual * residual
        Set obs_idx to obs_idx + 1
    
    Note: Calculate F-statistic for reverse direction
    Let numerator2 be (rss_restricted2 - rss_unrestricted2) / Float.convert(max_lags)
    Let denominator2 be rss_unrestricted2 / Float.convert(df_unrestricted)
    Let f_stat_1_causes_2 be numerator2 / denominator2
    
    Note: Calculate p-values using F-distribution approximation
    Let df_numerator be Float.convert(max_lags)
    Let df_denominator be Float.convert(df_unrestricted)
    
    Note: F-distribution p-value approximation using incomplete beta function approximation
    Let p_value_2_causes_1 be 0.0
    If f_stat_2_causes_1 > 0.0 then:
        Let x be Float.divide(df_numerator * f_stat_2_causes_1, df_numerator * f_stat_2_causes_1 + df_denominator)
        Note: Beta function approximation for F-distribution
        If x > 0.5 then:
            Let beta_approx be MathOps.power(Float.subtract(1.0, x), Float.divide(df_denominator, 2.0))
            Set p_value_2_causes_1 to Float.multiply(beta_approx, Float.divide(df_denominator, df_denominator + df_numerator))
        Otherwise:
            Let beta_approx be MathOps.power(x, Float.divide(df_numerator, 2.0))
            Set p_value_2_causes_1 to Float.subtract(1.0, Float.multiply(beta_approx, Float.divide(df_numerator, df_denominator + df_numerator)))
    Otherwise:
        Set p_value_2_causes_1 to 1.0
    
    Let p_value_1_causes_2 be 0.0
    If f_stat_1_causes_2 > 0.0 then:
        Let x be Float.divide(df_numerator * f_stat_1_causes_2, df_numerator * f_stat_1_causes_2 + df_denominator)
        Note: Beta function approximation for F-distribution
        If x > 0.5 then:
            Let beta_approx be MathOps.power(Float.subtract(1.0, x), Float.divide(df_denominator, 2.0))
            Set p_value_1_causes_2 to Float.multiply(beta_approx, Float.divide(df_denominator, df_denominator + df_numerator))
        Otherwise:
            Let beta_approx be MathOps.power(x, Float.divide(df_numerator, 2.0))
            Set p_value_1_causes_2 to Float.subtract(1.0, Float.multiply(beta_approx, Float.divide(df_numerator, df_denominator + df_numerator)))
    Otherwise:
        Set p_value_1_causes_2 to 1.0
    
    Let result be Dictionary.create()
    Set result["f_stat_series2_causes_series1"] to f_stat_2_causes_1
    Set result["p_value_series2_causes_series1"] to p_value_2_causes_1
    Set result["f_stat_series1_causes_series2"] to f_stat_1_causes_2
    Set result["p_value_series1_causes_series2"] to p_value_1_causes_2
    Set result["rss_restricted_1"] to rss_restricted
    Set result["rss_unrestricted_1"] to rss_unrestricted
    Set result["rss_restricted_2"] to rss_restricted2
    Set result["rss_unrestricted_2"] to rss_unrestricted2
    
    Return result

Note: =====================================================================
Note: UTILITY OPERATIONS
Note: =====================================================================

Process called "standardize_multivariate_data" that takes data as List[List[Float]], method as String returns List[List[Float]]:
    Note: Standardize multivariate data using specified method
    Note: Methods: z-score, robust scaling, min-max normalization
    Let n_obs be List.length(data)
    Let n_vars be List.length(List.get(data, 0))
    
    Let standardized_data be List.create()
    
    If method = "z_score" then:
        Note: Z-score standardization: (x - mean) / std
        Let var_means be List.create()
        Let var_stds be List.create()
        
        Note: Calculate means and standard deviations for each variable
        Let var_idx be 0
        While var_idx < n_vars do:
            Let var_data be List.create()
            Let obs_idx be 0
            While obs_idx < n_obs do:
                List.append(var_data, List.get(List.get(data, obs_idx), var_idx))
                Set obs_idx to obs_idx + 1
            
            Let mean be Descriptive.mean(var_data)
            Let variance be Descriptive.variance(var_data, false)
            Let std_dev be MathOps.sqrt(variance)
            
            List.append(var_means, mean)
            List.append(var_stds, std_dev)
            Set var_idx to var_idx + 1
        
        Note: Apply z-score transformation
        Let obs_idx be 0
        While obs_idx < n_obs do:
            Let standardized_row be List.create()
            Let var_idx be 0
            While var_idx < n_vars do:
                Let value be List.get(List.get(data, obs_idx), var_idx)
                Let mean be List.get(var_means, var_idx)
                Let std_dev be List.get(var_stds, var_idx)
                
                Let standardized_value be (value - mean) / std_dev
                List.append(standardized_row, standardized_value)
                Set var_idx to var_idx + 1
            List.append(standardized_data, standardized_row)
            Set obs_idx to obs_idx + 1
    
    Otherwise:
        If method = "robust" then:
            Note: Robust scaling: (x - median) / IQR
            Let var_medians be List.create()
            Let var_iqrs be List.create()
            
            Note: Calculate medians and IQRs for each variable
            Let var_idx be 0
            While var_idx < n_vars do:
                Let var_data be List.create()
                Let obs_idx be 0
                While obs_idx < n_obs do:
                    List.append(var_data, List.get(List.get(data, obs_idx), var_idx))
                    Set obs_idx to obs_idx + 1
                
                Note: Sort data to find median and quartiles
                Let sorted_data be List.copy(var_data)
                Let i be 0
                While i < n_obs - 1 do:
                    Let j be 0
                    While j < n_obs - 1 - i do:
                        If List.get(sorted_data, j) > List.get(sorted_data, j + 1) then:
                            Let temp be List.get(sorted_data, j)
                            List.set(sorted_data, j, List.get(sorted_data, j + 1))
                            List.set(sorted_data, j + 1, temp)
                        Set j to j + 1
                    Set i to i + 1
                
                Let median be Descriptive.median(sorted_data)
                
                Let q1_idx be n_obs / 4
                Let q3_idx be 3 * n_obs / 4
                Let q1 be List.get(sorted_data, q1_idx)
                Let q3 be List.get(sorted_data, q3_idx)
                Let iqr be q3 - q1
                
                List.append(var_medians, median)
                List.append(var_iqrs, iqr)
                Set var_idx to var_idx + 1
            
            Note: Apply robust scaling transformation
            Let obs_idx be 0
            While obs_idx < n_obs do:
                Let standardized_row be List.create()
                Let var_idx be 0
                While var_idx < n_vars do:
                    Let value be List.get(List.get(data, obs_idx), var_idx)
                    Let median be List.get(var_medians, var_idx)
                    Let iqr be List.get(var_iqrs, var_idx)
                    
                    Let standardized_value be (value - median) / iqr
                    List.append(standardized_row, standardized_value)
                    Set var_idx to var_idx + 1
                List.append(standardized_data, standardized_row)
                Set obs_idx to obs_idx + 1
        
        Otherwise:
            If method = "min_max" then:
                Note: Min-max normalization: (x - min) / (max - min)
                Let var_mins be List.create()
                Let var_maxs be List.create()
                
                Note: Find min and max for each variable
                Let var_idx be 0
                While var_idx < n_vars do:
                    Let var_data be List.create()
                    Let obs_idx be 0
                    While obs_idx < n_obs do:
                        List.append(var_data, List.get(List.get(data, obs_idx), var_idx))
                        Set obs_idx to obs_idx + 1
                    
                    Let min_val be Descriptive.minimum(var_data)
                    Let max_val be Descriptive.maximum(var_data)
                    
                    List.append(var_mins, min_val)
                    List.append(var_maxs, max_val)
                    Set var_idx to var_idx + 1
                
                Note: Apply min-max normalization
                Let obs_idx be 0
                While obs_idx < n_obs do:
                    Let standardized_row be List.create()
                    Let var_idx be 0
                    While var_idx < n_vars do:
                        Let value be List.get(List.get(data, obs_idx), var_idx)
                        Let min_val be List.get(var_mins, var_idx)
                        Let max_val be List.get(var_maxs, var_idx)
                        
                        Let range be max_val - min_val
                        Let standardized_value be (value - min_val) / range
                        List.append(standardized_row, standardized_value)
                        Set var_idx to var_idx + 1
                    List.append(standardized_data, standardized_row)
                    Set obs_idx to obs_idx + 1
            
            Otherwise:
                Note: Default to original data if method not recognized
                Let obs_idx be 0
                While obs_idx < n_obs do:
                    List.append(standardized_data, List.copy(List.get(data, obs_idx)))
                    Set obs_idx to obs_idx + 1
    
    Return standardized_data

Process called "handle_missing_multivariate_data" that takes data as List[List[Float]], method as String returns List[List[Float]]:
    Note: Handle missing data in multivariate datasets
    Note: Methods: listwise deletion, pairwise deletion, multiple imputation, EM
    Let n_obs be List.length(data)
    Let n_vars be List.length(List.get(data, 0))
    
    Let result be List.create()
    
    If method = "listwise_deletion" then:
        Note: Remove entire rows with any missing values
        Let obs_idx be 0
        While obs_idx < n_obs do:
            Let has_missing be false
            Let var_idx be 0
            While var_idx < n_vars do:
                Let value be List.get(List.get(data, obs_idx), var_idx)
                Note: Check for NaN (using property that NaN != NaN)
                If value != value then:
                    Set has_missing to true
                    Break
                Set var_idx to var_idx + 1
            
            If !has_missing then:
                List.append(result, List.copy(List.get(data, obs_idx)))
            Set obs_idx to obs_idx + 1
    
    Otherwise:
        If method = "mean_imputation" then:
            Note: Replace missing values with variable means
            Note: First calculate means from non-missing values
            Let var_means be List.create()
            Let var_idx be 0
            While var_idx < n_vars do:
                Let valid_values be List.create()
                Let obs_idx be 0
                While obs_idx < n_obs do:
                    Let value be List.get(List.get(data, obs_idx), var_idx)
                    If value = value then:
                        List.append(valid_values, value)
                    Set obs_idx to obs_idx + 1
                
                Let mean be 0.0
                If List.length(valid_values) > 0 then:
                    Set mean to Descriptive.mean(valid_values)
                List.append(var_means, mean)
                Set var_idx to var_idx + 1
            
            Note: Apply mean imputation
            Let obs_idx be 0
            While obs_idx < n_obs do:
                Let imputed_row be List.create()
                Let var_idx be 0
                While var_idx < n_vars do:
                    Let value be List.get(List.get(data, obs_idx), var_idx)
                    If value != value then:
                        List.append(imputed_row, List.get(var_means, var_idx))
                    Otherwise:
                        List.append(imputed_row, value)
                    Set var_idx to var_idx + 1
                List.append(result, imputed_row)
                Set obs_idx to obs_idx + 1
        
        Otherwise:
            If method = "median_imputation" then:
                Note: Replace missing values with variable medians
                Let var_medians be List.create()
                Let var_idx be 0
                While var_idx < n_vars do:
                    Let valid_values be List.create()
                    Let obs_idx be 0
                    While obs_idx < n_obs do:
                        Let value be List.get(List.get(data, obs_idx), var_idx)
                        If value = value then:
                            List.append(valid_values, value)
                        Set obs_idx to obs_idx + 1
                    
                    Let median be 0.0
                    If List.length(valid_values) > 0 then:
                        Note: Sort values for median calculation
                        Let sorted_values be List.copy(valid_values)
                        Let n_valid be List.length(sorted_values)
                        Let i be 0
                        While i < n_valid - 1 do:
                            Let j be 0
                            While j < n_valid - 1 - i do:
                                If List.get(sorted_values, j) > List.get(sorted_values, j + 1) then:
                                    Let temp be List.get(sorted_values, j)
                                    List.set(sorted_values, j, List.get(sorted_values, j + 1))
                                    List.set(sorted_values, j + 1, temp)
                                Set j to j + 1
                            Set i to i + 1
                        Set median to Descriptive.median(sorted_values)
                    List.append(var_medians, median)
                    Set var_idx to var_idx + 1
                
                Note: Apply median imputation
                Let obs_idx be 0
                While obs_idx < n_obs do:
                    Let imputed_row be List.create()
                    Let var_idx be 0
                    While var_idx < n_vars do:
                        Let value be List.get(List.get(data, obs_idx), var_idx)
                        If value != value then:
                            List.append(imputed_row, List.get(var_medians, var_idx))
                        Otherwise:
                            List.append(imputed_row, value)
                        Set var_idx to var_idx + 1
                    List.append(result, imputed_row)
                    Set obs_idx to obs_idx + 1
            
            Otherwise:
                If method = "forward_fill" then:
                    Note: Forward fill missing values with last observed value
                    Let obs_idx be 0
                    While obs_idx < n_obs do:
                        Let filled_row be List.create()
                        Let var_idx be 0
                        While var_idx < n_vars do:
                            Let value be List.get(List.get(data, obs_idx), var_idx)
                            
                            If value != value then:
                                Note: Find last valid value in this variable
                                Let last_valid be 0.0
                                Let search_idx be obs_idx - 1
                                While search_idx >= 0 do:
                                    Let prev_value be List.get(List.get(data, search_idx), var_idx)
                                    If prev_value = prev_value then:
                                        Set last_valid to prev_value
                                        Break
                                    Set search_idx to search_idx - 1
                                List.append(filled_row, last_valid)
                            Otherwise:
                                List.append(filled_row, value)
                            Set var_idx to var_idx + 1
                        List.append(result, filled_row)
                        Set obs_idx to obs_idx + 1
                
                Otherwise:
                    Note: Default to listwise deletion if method not recognized
                    Let obs_idx be 0
                    While obs_idx < n_obs do:
                        Let has_missing be false
                        Let var_idx be 0
                        While var_idx < n_vars do:
                            Let value be List.get(List.get(data, obs_idx), var_idx)
                            If value != value then:
                                Set has_missing to true
                                Break
                            Set var_idx to var_idx + 1
                        
                        If !has_missing then:
                            List.append(result, List.copy(List.get(data, obs_idx)))
                        Set obs_idx to obs_idx + 1
    
    Return result

Process called "multivariate_data_visualization" that takes data as List[List[Float]], plot_type as String returns Dictionary[String, List[List[Float]]]:
    Note: Generate coordinates for multivariate data visualization
    Note: Types: scatterplot matrix, parallel coordinates, star plots, biplots
    Let n_obs be List.length(data)
    Let n_vars be List.length(List.get(data, 0))
    
    Let result be Dictionary.create()
    
    If plot_type = "scatterplot_matrix" then:
        Note: Generate coordinates for scatterplot matrix
        Let pairs be List.create()
        
        Let var_i be 0
        While var_i < n_vars do:
            Let var_j be 0
            While var_j < n_vars do:
                Let pair_data be List.create()
                
                Let obs_idx be 0
                While obs_idx < n_obs do:
                    Let point be List.create()
                    List.append(point, List.get(List.get(data, obs_idx), var_i))
                    List.append(point, List.get(List.get(data, obs_idx), var_j))
                    List.append(pair_data, point)
                    Set obs_idx to obs_idx + 1
                
                List.append(pairs, pair_data)
                Set var_j to var_j + 1
            Set var_i to var_i + 1
        
        Set result["scatter_pairs"] to pairs
        Set result["grid_size"] to n_vars
    
    Otherwise:
        If plot_type = "parallel_coordinates" then:
            Note: Generate normalized coordinates for parallel coordinate plot
            Let normalized_data be standardize_data_matrix(data, true, true)
            Let parallel_coords be List.create()
            
            Let obs_idx be 0
            While obs_idx < n_obs do:
                Let coord_line be List.create()
                Let var_idx be 0
                While var_idx < n_vars do:
                    Let coord_point be List.create()
                    List.append(coord_point, Float.convert(var_idx))
                    List.append(coord_point, List.get(List.get(normalized_data, obs_idx), var_idx))
                    List.append(coord_line, coord_point)
                    Set var_idx to var_idx + 1
                List.append(parallel_coords, coord_line)
                Set obs_idx to obs_idx + 1
            
            Set result["parallel_lines"] to parallel_coords
            Set result["variable_positions"] to n_vars
        
        Otherwise:
            If plot_type = "star_plot" then:
                Note: Generate polar coordinates for star plots
                Let star_coords be List.create()
                Let angle_step be 2.0 * 3.14159 / Float.convert(n_vars)
                
                Note: Normalize data to [0,1] range for radius
                Let normalized_data be standardize_multivariate_data(data, "min_max")
                
                Let obs_idx be 0
                While obs_idx < n_obs do:
                    Let star_points be List.create()
                    
                    Let var_idx be 0
                    While var_idx < n_vars do:
                        Let angle be Float.convert(var_idx) * angle_step
                        Let radius be List.get(List.get(normalized_data, obs_idx), var_idx)
                        
                        Let x_coord be radius * MathOps.cos(angle)
                        Let y_coord be radius * MathOps.sin(angle)
                        
                        Let point be List.create()
                        List.append(point, x_coord)
                        List.append(point, y_coord)
                        List.append(star_points, point)
                        Set var_idx to var_idx + 1
                    
                    Note: Close the star by connecting back to first point
                    List.append(star_points, List.get(star_points, 0))
                    List.append(star_coords, star_points)
                    Set obs_idx to obs_idx + 1
                
                Set result["star_polygons"] to star_coords
                Set result["angle_step"] to angle_step
            
            Otherwise:
                If plot_type = "biplot" then:
                    Note: Generate biplot using PCA coordinates
                    Let pca_result be principal_component_analysis(data, 2)
                    Let scores be Dictionary.get(pca_result, "scores")
                    Let loadings be Dictionary.get(pca_result, "loadings")
                    
                    Note: Scale loadings for visualization
                    Let scaled_loadings be List.create()
                    Let loading_scale be 3.0
                    
                    Let var_idx be 0
                    While var_idx < n_vars do:
                        Let loading_vector be List.create()
                        List.append(loading_vector, List.get(List.get(loadings, var_idx), 0) * loading_scale)
                        List.append(loading_vector, List.get(List.get(loadings, var_idx), 1) * loading_scale)
                        List.append(scaled_loadings, loading_vector)
                        Set var_idx to var_idx + 1
                    
                    Note: Extract first two PC scores
                    Let biplot_scores be List.create()
                    Let obs_idx be 0
                    While obs_idx < n_obs do:
                        Let score_point be List.create()
                        List.append(score_point, List.get(List.get(scores, obs_idx), 0))
                        List.append(score_point, List.get(List.get(scores, obs_idx), 1))
                        List.append(biplot_scores, score_point)
                        Set obs_idx to obs_idx + 1
                    
                    Set result["observation_scores"] to biplot_scores
                    Set result["variable_loadings"] to scaled_loadings
                    Set result["explained_variance"] to Dictionary.get(pca_result, "explained_variance_ratio")
                
                Otherwise:
                    If plot_type = "andrews_curves" then:
                        Note: Generate Andrews curves using Fourier series
                        Let curve_points be List.create()
                        Let t_points be 100
                        Let t_range be 3.14159
                        
                        Let obs_idx be 0
                        While obs_idx < n_obs do:
                            Let curve be List.create()
                            
                            Let t_idx be 0
                            While t_idx < t_points do:
                                Let t be -t_range + 2.0 * t_range * Float.convert(t_idx) / Float.convert(t_points - 1)
                                
                                Note: Andrews function: f(t) = x1/sqrt(2) + x2*sin(t) + x3*cos(t) + x4*sin(2t) + x5*cos(2t) + ...
                                Let y_val be List.get(List.get(data, obs_idx), 0) / MathOps.sqrt(2.0)
                                
                                Let var_idx be 1
                                While var_idx < n_vars do:
                                    Let coeff be List.get(List.get(data, obs_idx), var_idx)
                                    Let freq be (var_idx + 1) / 2
                                    
                                    If var_idx % 2 = 1 then:
                                        Set y_val to y_val + coeff * MathOps.sin(Float.convert(freq) * t)
                                    Otherwise:
                                        Set y_val to y_val + coeff * MathOps.cos(Float.convert(freq) * t)
                                    Set var_idx to var_idx + 1
                                
                                Let point be List.create()
                                List.append(point, t)
                                List.append(point, y_val)
                                List.append(curve, point)
                                Set t_idx to t_idx + 1
                            
                            List.append(curve_points, curve)
                            Set obs_idx to obs_idx + 1
                        
                        Set result["andrews_curves"] to curve_points
                        Set result["t_range"] to t_range
                    
                    Otherwise:
                        Note: Default to 2D projection using first two variables
                        Let projection be List.create()
                        
                        Let obs_idx be 0
                        While obs_idx < n_obs do:
                            Let point be List.create()
                            If n_vars >= 1 then:
                                List.append(point, List.get(List.get(data, obs_idx), 0))
                            Otherwise:
                                List.append(point, 0.0)
                            
                            If n_vars >= 2 then:
                                List.append(point, List.get(List.get(data, obs_idx), 1))
                            Otherwise:
                                List.append(point, 0.0)
                            
                            List.append(projection, point)
                            Set obs_idx to obs_idx + 1
                        
                        Set result["projection_2d"] to projection
    
    Return result

Process called "compute_mahalanobis_distance" that takes data as List[List[Float]], center as List[Float], covariance as List[List[Float]] returns List[Float]:
    Note: Compute Mahalanobis distance accounting for covariance structure
    Note: Standardized distance measure for multivariate data
    Let n_obs be List.length(data)
    Let n_vars be List.length(List.get(data, 0))
    
    Note: Invert the covariance matrix
    Let cov_inv be Linear.invert_matrix(covariance)
    
    Let distances be List.create()
    
    Let obs_idx be 0
    While obs_idx < n_obs do:
        Note: Calculate deviation vector: x - μ
        Let deviation be List.create()
        Let var_idx be 0
        While var_idx < n_vars do:
            Let diff be List.get(List.get(data, obs_idx), var_idx) - List.get(center, var_idx)
            List.append(deviation, diff)
            Set var_idx to var_idx + 1
        
        Note: Calculate quadratic form: (x - μ)' * Σ^(-1) * (x - μ)
        Let quadratic_form be Linear.quadratic_form(deviation, cov_inv)
        
        Note: Mahalanobis distance is square root of quadratic form
        Let mahalanobis_dist be MathOps.sqrt(quadratic_form)
        List.append(distances, mahalanobis_dist)
        
        Set obs_idx to obs_idx + 1
    
    Return distances