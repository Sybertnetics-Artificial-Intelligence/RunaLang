Process called "kalman_filter" that takes observations as List[Float], state_space_matrices as Dictionary[String, List[List[Float]]], initial_state as List[Float] returns Dictionary[String, List[List[Float]]]:
    Note: Kalman filter for linear Gaussian state space models
    Note: Optimal recursive estimation of hidden state variables
    
    If observations.length == 0:
        Throw Errors.InvalidArgument with "Observations cannot be empty"
    
    If initial_state.length == 0:
        Throw Errors.InvalidArgument with "Initial state cannot be empty"
    
    Note: Extract matrices from input
    If not ("F" in state_space_matrices and "H" in state_space_matrices and "Q" in state_space_matrices and "R" in state_space_matrices):
        Throw Errors.InvalidArgument with "Must provide F, H, Q, R matrices"
    
    Let F be state_space_matrices["F"]  Note: State transition matrix
    Let H be state_space_matrices["H"]  Note: Observation matrix
    Let Q be state_space_matrices["Q"]  Note: Process noise covariance
    Let R be state_space_matrices["R"]  Note: Observation noise covariance
    
    Let state_dim be initial_state.length
    Let obs_dim be H.length
    
    Note: Validate matrix dimensions
    If F.length != state_dim or F[0].length != state_dim:
        Throw Errors.InvalidArgument with "F matrix dimensions inconsistent with state dimension"
    
    If H[0].length != state_dim:
        Throw Errors.InvalidArgument with "H matrix dimensions inconsistent with state dimension"
    
    Note: Initialize covariance matrix
    Let P be List[List[Float]]
    If "P0" in state_space_matrices:
        Let P be state_space_matrices["P0"]
    Otherwise:
        Note: Default initial covariance
        For i in range(0, state_dim):
            Let row be List[Float]
            For j in range(0, state_dim):
                If i == j:
                    Let row be row.append(1.0)
                Otherwise:
                    Let row be row.append(0.0)
            Let P be P.append(row)
    
    Note: Storage for results
    Let filtered_states be List[List[Float]]
    Let predicted_states be List[List[Float]]
    Let filtered_covariances be List[List[List[Float]]]
    Let predicted_covariances be List[List[List[Float]]]
    Let innovations be List[Float]
    Let innovation_covariances be List[Float]
    
    Let state_estimate be initial_state.copy()
    Let n be observations.length
    
    For t in range(0, n):
        Note: Prediction step
        Let state_pred_matrix be Regression.matrix_multiply(F, List[List[Float]]().append(state_estimate))
        Let state_pred be List[Float]
        For i in range(0, state_pred_matrix.length):
            Let state_pred be state_pred.append(state_pred_matrix[i][0])
        
        Let F_transpose be Regression.matrix_transpose(F)
        Let FPF_t be Regression.matrix_multiply(Regression.matrix_multiply(F, P), F_transpose)
        Let P_pred be List[List[Float]]
        For i in range(0, FPF_t.length):
            Let row be List[Float]
            For j in range(0, FPF_t[i].length):
                Let row be row.append(FPF_t[i][j] + Q[i][j])
            Let P_pred be P_pred.append(row)
        
        Let predicted_states be predicted_states.append(state_pred.copy())
        Let predicted_covariances be predicted_covariances.append(P_pred.copy())
        
        Note: Update step
        Let observation_pred_matrix be Regression.matrix_multiply(H, List[List[Float]]().append(state_pred))
        Let observation_pred be observation_pred_matrix[0][0]
        Let innovation be observations[t] - observation_pred
        Let innovations be innovations.append(innovation)
        
        Note: Innovation covariance S = HPH' + R
        Let H_transpose be Regression.matrix_transpose(H)
        Let HPH_t be Regression.matrix_multiply(Regression.matrix_multiply(H, P_pred), H_transpose)
        Let S be HPH_t[0][0] + R[0][0]
        Let innovation_covariances be innovation_covariances.append(S)
        
        If MathOps.absolute_value(S) > 1e-10:  Note: Avoid division by zero
            Note: Kalman gain K = PH'S^(-1)
            Let PH_t be Regression.matrix_multiply(P_pred, H_transpose)
            Let K be List[Float]
            For i in range(0, PH_t.length):
                Let K be K.append(PH_t[i][0] / S)
            
            Note: State update: x = x_pred + K * innovation
            For i in range(0, state_dim):
                Let state_estimate[i] be state_pred[i] + K[i] * innovation
            
            Note: Covariance update: P = (I - KH) * P_pred
            Let I_KH be List[List[Float]]
            For i in range(0, state_dim):
                Let row be List[Float]
                For j in range(0, state_dim):
                    Let kh_ij be K[i] * H[0][j]
                    If i == j:
                        Let row be row.append(1.0 - kh_ij)
                    Otherwise:
                        Let row be row.append(-kh_ij)
                Let I_KH be I_KH.append(row)
            
            Let P be Regression.matrix_multiply(I_KH, P_pred)
        Otherwise:
            Note: Singular innovation covariance - no update
            Let state_estimate be state_pred
            Let P be P_pred
        
        Let filtered_states be filtered_states.append(state_estimate.copy())
        Let filtered_covariances be filtered_covariances.append(P.copy())
    
    Note: Calculate log-likelihood
    Let log_likelihood be 0.0
    For t in range(0, n):
        Let S be innovation_covariances[t]
        If S > 1e-10:
            Let innov be innovations[t]
            Let log_2pi be MathOps.natural_logarithm((2.0 * Constants.get_pi().result_value.to_float()).to_string(), 15).result_value.to_float()
            Let log_S be MathOps.natural_logarithm(S.to_string(), 15).result_value.to_float()
            Let log_likelihood be log_likelihood - 0.5 * (log_2pi + log_S + (innov * innov) / S)
    
    Let result be Dictionary[String, List[List[Float]]]
    Let result be result.set("filtered_states", filtered_states)
    Let result be result.set("predicted_states", predicted_states)
    Let result be result.set("filtered_covariances", filtered_covariances)
    Let result be result.set("predicted_covariances", predicted_covariances)
    Let result be result.set("innovations", List[List[Float]]().append(innovations))
    Let result be result.set("innovation_covariances", List[List[Float]]().append(innovation_covariances))
    Let result be result.set("log_likelihood", List[List[Float]]().append(List[Float](log_likelihood)))
    
    Return result

