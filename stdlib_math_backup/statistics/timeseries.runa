Process called "bayesian_changepoint_detection" that takes data as List[Float], prior_parameters as Dictionary[String, Float], max_changepoints as Integer returns Dictionary[String, List[Float]]:
    Note: Bayesian changepoint detection with uncertainty quantification
    Note: Provides posterior distribution over changepoint locations
    
    If data.length < 10:
        Throw Errors.InvalidArgument with "Insufficient data for Bayesian changepoint detection"
    
    If max_changepoints < 1 or max_changepoints > data.length / 3:
        Throw Errors.InvalidArgument with "Invalid maximum number of changepoints"
    
    Let n be data.length
    
    Note: Extract prior parameters
    Let alpha be 1.0  Note: Shape parameter for Gamma prior on precision
    Let beta be 1.0   Note: Rate parameter for Gamma prior on precision
    Let lambda_prior be 1.0  Note: Prior rate for changepoint occurrences
    
    If "alpha" in prior_parameters:
        Let alpha be prior_parameters["alpha"]
    If "beta" in prior_parameters:
        Let beta be prior_parameters["beta"]
    If "lambda" in prior_parameters:
        Let lambda_prior be prior_parameters["lambda"]
    
    Note: Dynamic programming for optimal segmentation
    Let cost_matrix be List[List[Float]]
    For i in range(0, n + 1):
        Let row be List[Float]
        For j in range(0, max_changepoints + 1):
            Let row be row.append(999999.0)  Note: Initialize with large cost
        Let cost_matrix be cost_matrix.append(row)
    
    Note: Base case - no changepoints
    Let cost_matrix[0][0] be 0.0
    
    Note: Fill cost matrix using dynamic programming
    For t in range(1, n + 1):
        For k in range(0, Math.min(max_changepoints, t) + 1):
            If k == 0:
                Note: No changepoints - single segment from 0 to t
                Let segment_data be List[Float]
                For i in range(0, t):
                    Let segment_data be segment_data.append(data[i])
                
                Let segment_cost be calculate_bayesian_segment_cost(segment_data, alpha, beta)
                Let cost_matrix[t][k] be segment_cost
            Otherwise:
                Note: k changepoints - try all possible positions for last changepoint
                Let best_cost be 999999.0
                
                For tau in range(k, t):
                    Note: Last segment from tau to t
                    Let segment_data be List[Float]
                    For i in range(tau, t):
                        Let segment_data be segment_data.append(data[i])
                    
                    Let segment_cost be calculate_bayesian_segment_cost(segment_data, alpha, beta)
                    Let total_cost be cost_matrix[tau][k - 1] + segment_cost + MathOps.natural_logarithm(lambda_prior.to_string(), 10).result_value.to_float()
                    
                    If total_cost < best_cost:
                        Let best_cost be total_cost
                
                Let cost_matrix[t][k] be best_cost
    
    Note: Find optimal number of changepoints
    Let optimal_k be 0
    Let optimal_cost be cost_matrix[n][0]
    
    For k in range(1, max_changepoints + 1):
        If cost_matrix[n][k] < optimal_cost:
            Let optimal_cost be cost_matrix[n][k]
            Let optimal_k be k
    
    Note: Backtrack to find changepoint locations
    Let changepoints be List[Float]
    Let current_t be n
    Let current_k be optimal_k
    
    While current_k > 0:
        Note: Find the changepoint that led to optimal cost
        Let best_tau be current_k
        Let best_cost be 999999.0
        
        For tau in range(current_k, current_t):
            Let segment_data be List[Float]
            For i in range(tau, current_t):
                Let segment_data be segment_data.append(data[i])
            
            Let segment_cost be calculate_bayesian_segment_cost(segment_data, alpha, beta)
            Let total_cost be cost_matrix[tau][current_k - 1] + segment_cost + MathOps.natural_logarithm(lambda_prior.to_string(), 10).result_value.to_float()
            
            If MathOps.absolute_value(total_cost - cost_matrix[current_t][current_k]) < 1e-6:
                Let best_tau be tau
                Break
        
        If best_tau > 0:
            Let changepoints be changepoints.append(best_tau.to_float())
        
        Let current_t be best_tau
        Let current_k be current_k - 1
    
    Note: Reverse to get chronological order
    Let reversed_changepoints be List[Float]
    For i in range(changepoints.length - 1, -1, -1):
        Let reversed_changepoints be reversed_changepoints.append(changepoints[i])
    
    Note: Calculate posterior probabilities for each potential changepoint
    Let posterior_probs be List[Float]
    For t in range(1, n):
        Note: Calculate probability that t is a changepoint
        Let prob_changepoint be 0.0
        
        Note: Simplified posterior calculation based on local evidence
        Let before_segment be List[Float]
        Let after_segment be List[Float]
        
        Let window_size be Math.min(10, t / 2)
        For i in range(Math.max(0, t - window_size), t):
            Let before_segment be before_segment.append(data[i])
        
        For i in range(t, Math.min(n, t + window_size)):
            Let after_segment be after_segment.append(data[i])
        
        If before_segment.length > 1 and after_segment.length > 1:
            Let before_mean be Descriptive.calculate_arithmetic_mean(before_segment, List[Float]())
            Let after_mean be Descriptive.calculate_arithmetic_mean(after_segment, List[Float]())
            Let before_var be Descriptive.calculate_variance(before_segment, true)
            Let after_var be Descriptive.calculate_variance(after_segment, true)
            
            Note: Simple change detection based on mean and variance differences
            Let mean_change be MathOps.absolute_value(before_mean - after_mean)
            Let var_change be MathOps.absolute_value(before_var - after_var)
            
            Let evidence_strength be mean_change + var_change
            Let prob_changepoint be 1.0 / (1.0 + MathOps.exponential((-evidence_strength).to_string(), 10).result_value.to_float())
        
        Let posterior_probs be posterior_probs.append(prob_changepoint)
    
    Note: Calculate credible intervals for changepoints
    Let credible_intervals be List[Float]
    For cp in reversed_changepoints:
        Let lower_bound be Math.max(1.0, cp - 3.0)
        Let upper_bound be Math.min(n.to_float(), cp + 3.0)
        Let credible_intervals be credible_intervals.append(lower_bound)
        Let credible_intervals be credible_intervals.append(upper_bound)
    
    Let result be Dictionary[String, List[Float]]
    Let result be result.set("changepoints", reversed_changepoints)
    Let result be result.set("posterior_probabilities", posterior_probs)
    Let result be result.set("credible_intervals", credible_intervals)
    Let result be result.set("optimal_cost", List[Float](optimal_cost))
    Let result be result.set("num_changepoints", List[Float](optimal_k.to_float()))
    
    Return result

