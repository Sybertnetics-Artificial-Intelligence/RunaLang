Process called "interpolate_time_series" that takes data as List[Float], timestamps as List[Integer], method as String, target_frequency as String returns List[Float]:
    Note: Interpolate time series to regular frequency
    Note: Methods: linear, cubic spline, PCHIP, Akima for temporal interpolation
    
    If data.length != timestamps.length:
        Throw Errors.InvalidArgument with "Data and timestamps must have same length"
    
    If data.length < 2:
        Return data
    
    Note: Determine target time grid based on frequency
    Let start_time be timestamps[0]
    Let end_time be timestamps[timestamps.length - 1]
    Let time_span be end_time - start_time
    
    Let interval be 1
    If target_frequency == "daily":
        Let interval be 1
    Otherwise If target_frequency == "weekly":
        Let interval be 7
    Otherwise If target_frequency == "monthly":
        Let interval be 30
    Otherwise:
        Let interval be 1
    
    Let target_times be List[Integer]
    Let current_time be start_time
    While current_time <= end_time:
        Let target_times be target_times.append(current_time)
        Let current_time be current_time + interval
    
    Let interpolated_values be List[Float]
    
    If method == "linear":
        For target_time in target_times:
            Note: Find surrounding points
            Let left_idx be -1
            Let right_idx be -1
            
            For i in range(0, timestamps.length):
                If timestamps[i] <= target_time:
                    Let left_idx be i
                If timestamps[i] >= target_time and right_idx == -1:
                    Let right_idx be i
            
            If left_idx == -1:
                Let interpolated_values be interpolated_values.append(data[0])
            Otherwise If right_idx == -1:
                Let interpolated_values be interpolated_values.append(data[data.length - 1])
            Otherwise If left_idx == right_idx:
                Let interpolated_values be interpolated_values.append(data[left_idx])
            Otherwise:
                Let time_diff be timestamps[right_idx] - timestamps[left_idx]
                Let weight be (target_time - timestamps[left_idx]).to_float() / time_diff.to_float()
                Let interpolated_value be data[left_idx] + weight * (data[right_idx] - data[left_idx])
                Let interpolated_values be interpolated_values.append(interpolated_value)
    
    Otherwise:
        Note: Default to nearest neighbor for unsupported methods
        For target_time in target_times:
            Let nearest_idx be 0
            Let min_distance be MathOps.absolute_value((timestamps[0] - target_time).to_float())
            
            For i in range(1, timestamps.length):
                Let distance be MathOps.absolute_value((timestamps[i] - target_time).to_float())
                If distance < min_distance:
                    Let nearest_idx be i
                    Let min_distance be distance
            
            Let interpolated_values be interpolated_values.append(data[nearest_idx])
    
    Return interpolated_values

