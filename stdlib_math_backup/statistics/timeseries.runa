Note: =====================================================================
Note: FORECAST EVALUATION OPERATIONS
Note: =====================================================================

Process called "forecast_accuracy_metrics" that takes actual as List[Float], predicted as List[Float] returns Dictionary[String, Float]:
    Note: Calculate forecast accuracy metrics
    Note: MAE, MAPE, RMSE, sMAPE, MASE, Theil's U statistic
    
    If actual.length != predicted.length:
        Throw Errors.InvalidArgument with "Actual and predicted must have same length"
    
    If actual.length == 0:
        Throw Errors.InvalidArgument with "Empty forecast vectors"
    
    Let n be actual.length.to_float()
    Let errors be List[Float]
    Let abs_errors be List[Float]
    Let pct_errors be List[Float]
    Let squared_errors be List[Float]
    
    For i in range(0, actual.length):
        Let error be actual[i] - predicted[i]
        Let abs_error be MathOps.absolute_value(error)
        
        Let errors be errors.append(error)
        Let abs_errors be abs_errors.append(abs_error)
        Let squared_errors be squared_errors.append(error * error)
        
        Note: Percentage error (handle division by zero)
        If MathOps.absolute_value(actual[i]) > 0.001:
            Let pct_error be (error / actual[i]) * 100.0
            Let pct_errors be pct_errors.append(MathOps.absolute_value(pct_error))
        Otherwise:
            Let pct_errors be pct_errors.append(0.0)
    
    Note: Mean Absolute Error
    Let mae be Descriptive.calculate_arithmetic_mean(abs_errors, List[Float]())
    
    Note: Mean Absolute Percentage Error
    Let mape be 0.0
    If pct_errors.length > 0:
        Let mape be Descriptive.calculate_arithmetic_mean(pct_errors, List[Float]())
    
    Note: Root Mean Square Error
    Let mse be Descriptive.calculate_arithmetic_mean(squared_errors, List[Float]())
    Let rmse be MathOps.square_root(mse.to_string(), 10).result_value.to_float()
    
    Note: Symmetric Mean Absolute Percentage Error
    Let smape_values be List[Float]
    For i in range(0, actual.length):
        Let denominator be (MathOps.absolute_value(actual[i]) + MathOps.absolute_value(predicted[i])) / 2.0
        If denominator > 0.001:
            Let smape_val be (MathOps.absolute_value(actual[i] - predicted[i]) / denominator) * 100.0
            Let smape_values be smape_values.append(smape_val)
        Otherwise:
            Let smape_values be smape_values.append(0.0)
    
    Let smape be 0.0
    If smape_values.length > 0:
        Let smape be Descriptive.calculate_arithmetic_mean(smape_values, List[Float]())
    
    Note: Mean Error (bias)
    Let me be Descriptive.calculate_arithmetic_mean(errors, List[Float]())
    
    Note: Theil's U statistic (simplified version)
    Let actual_changes be List[Float]
    For i in range(1, actual.length):
        Let actual_changes be actual_changes.append(MathOps.absolute_value(actual[i] - actual[i - 1]))
    
    Let naive_mse be 0.0
    If actual_changes.length > 0:
        Let naive_errors be List[Float]
        For i in range(1, actual.length):
            Let naive_error be actual[i] - actual[i - 1]  Note: Naive forecast = last observation
            Let naive_errors be naive_errors.append(naive_error * naive_error)
        
        Let naive_mse be Descriptive.calculate_arithmetic_mean(naive_errors, List[Float]())
    
    Let theil_u be 1.0
    If naive_mse > 0.0:
        Let theil_u be MathOps.square_root((mse / naive_mse).to_string(), 10).result_value.to_float()
    
    Let metrics be Dictionary[String, Float]
    Let metrics be metrics.set("MAE", mae)
    Let metrics be metrics.set("MAPE", mape)
    Let metrics be metrics.set("RMSE", rmse)
    Let metrics be metrics.set("sMAPE", smape)
    Let metrics be metrics.set("ME", me)
    Let metrics be metrics.set("MSE", mse)
    Let metrics be metrics.set("Theil_U", theil_u)
    
    Return metrics

