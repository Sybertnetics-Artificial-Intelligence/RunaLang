Note: Bifurcation Theory Module

This module provides comprehensive bifurcation analysis for dynamical systems.
Bifurcation theory studies qualitative changes in system behavior as parameters vary.

Mathematical Foundation:
- Saddle-node bifurcations: dx/dt = r + x²
- Transcritical bifurcations: dx/dt = rx - x²  
- Pitchfork bifurcations: dx/dt = rx - x³
- Hopf bifurcations: transition from stable equilibrium to limit cycle
- Period-doubling cascades: route to chaos via bifurcation sequences
- Poincaré-Bendixson theory for planar systems
- Center manifold theory for codimension-1 bifurcations
- Normal form theory and universal unfolding

Applications include population dynamics, chemical reactions, neural networks,
climate models, economic systems, and engineering control problems.
:End Note

Import "dev/debug/errors/core" as Errors
Import "dynamical/systems" as DynamicalSystems
Import "engine/linalg/core" as LinearAlgebra
Import "engine/numerical/differentiation" as NumericalDiff
Import "engine/numerical/rootfinding" as RootFinding
Import "engine/numerical/ode" as ODE

Note: ===== Core Bifurcation Types =====

Type called "BifurcationType":
    saddle_node as Boolean
    transcritical as Boolean
    pitchfork_supercritical as Boolean
    pitchfork_subcritical as Boolean
    hopf_supercritical as Boolean
    hopf_subcritical as Boolean
    period_doubling as Boolean
    homoclinic as Boolean
    heteroclinic as Boolean
    cusp as Boolean
    
Type called "BifurcationPoint":
    parameter_value as Float64
    bifurcation_type as BifurcationType
    stability_change as String
    eigenvalues as List[Complex64]
    normal_form_coefficients as List[Float64]
    codimension as Integer
    criticality as String
    local_coordinates as List[Float64]

Type called "BifurcationDiagram":
    parameter_range as Tuple[Float64, Float64]
    branch_data as List[List[Float64]]
    stability_info as List[String]
    bifurcation_points as List[BifurcationPoint]
    attractors as List[List[Float64]]
    repellers as List[List[Float64]]
    continuation_method as String
    resolution as Integer

Note: ===== Saddle-Node Bifurcations =====

Process called "analyze_saddle_node_bifurcation" that takes system_function as Function, parameter_range as Tuple[Float64, Float64], initial_conditions as List[Float64] returns BifurcationDiagram:
    Note: Analyzes saddle-node bifurcations where fixed points appear/disappear
    Note: Uses continuation methods and stability analysis via linearization
    Note: Detects fold bifurcations and computes normal forms
    
    Let param_min be parameter_range.first
    Let param_max be parameter_range.second
    Let num_steps be 100
    Let step_size be Float64.divide(Float64.subtract(param_max, param_min), Float64.from_integer(num_steps))
    
    Let branch_data be []
    Let stability_info be []
    Let bifurcation_points be []
    Let attractors be []
    Let repellers be []
    
    Let current_param be param_min
    Let previous_equilibria be []
    
    Note: Parameter continuation loop
    Let step be 0
    While Integer.less_than(step, num_steps):
        Note: Create parameterized system at current parameter value
        Let parameterized_system be create_parameterized_system(system_function, current_param)
        
        Note: Find equilibrium points using existing function from dynamical systems
        Let search_bounds be create_search_bounds_from_initial_conditions(initial_conditions)
        Let tolerance be 1e-8
        Let equilibria be DynamicalSystems.find_equilibrium_points(parameterized_system, search_bounds, tolerance)
        
        Note: Analyze stability of each equilibrium
        Foreach equilibrium in equilibria:
            Let variables be extract_variable_names_from_function(system_function)
            Let jacobian be NumericalDiff.compute_jacobian(system_function, variables, equilibrium, "finite_difference")
            Let eigenvalues be LinearAlgebra.compute_eigenvalues(jacobian, "qr_algorithm")
            
            Note: Determine stability based on eigenvalue real parts
            Let stability be determine_stability_from_eigenvalues(eigenvalues)
            
            Let branch_point be {
                "parameter": current_param,
                "equilibrium": equilibrium,
                "eigenvalues": eigenvalues,
                "stability": stability
            }
            List.add(branch_data, branch_point)
            List.add(stability_info, stability)
            
            Note: Check for saddle-node bifurcation
            If step greater_than 0:
                Let bifurcation_detected be detect_saddle_node_bifurcation_point(branch_point, previous_equilibria, current_param)
                If bifurcation_detected.exists:
                    Let bifurcation_point be {
                        "parameter_value": bifurcation_detected.parameter,
                        "bifurcation_type": create_saddle_node_type(),
                        "stability_change": bifurcation_detected.stability_change,
                        "eigenvalues": bifurcation_detected.eigenvalues,
                        "normal_form_coefficients": compute_saddle_node_normal_form(jacobian.matrix, bifurcation_detected.eigenvectors),
                        "codimension": 1,
                        "criticality": "generic",
                        "local_coordinates": equilibrium
                    }
                    List.add(bifurcation_points, bifurcation_point)
            
            Note: Classify as attractor or repeller
            If String.equals(stability, "stable"):
                List.add(attractors, equilibrium)
            Otherwise if String.equals(stability, "unstable"):
                List.add(repellers, equilibrium)
        
        Set previous_equilibria to equilibria
        Set current_param to Float64.add(current_param, step_size)
        Set step to Integer.add(step, 1)
    
    Note: Create bifurcation diagram
    Return {
        "parameter_range": parameter_range,
        "branch_data": branch_data,
        "stability_info": stability_info,
        "bifurcation_points": bifurcation_points,
        "attractors": attractors,
        "repellers": repellers,
        "continuation_method": "parameter_stepping",
        "resolution": num_steps
    }

Process called "compute_saddle_node_normal_form" that takes jacobian_at_bifurcation as List[List[Float64]], eigenvectors as List[List[Float64]] returns List[Float64]:
    Note: Computes normal form dx/dt = a + bx² for saddle-node bifurcations
    Note: Uses center manifold reduction and coordinate transformations
    Note: Returns coefficients [a, b] of the canonical normal form
    
    Note: For saddle-node bifurcation, one eigenvalue is zero
    Let zero_eigenvalue_index be find_zero_eigenvalue_index(jacobian_at_bifurcation)
    
    If Integer.equals(zero_eigenvalue_index, -1):
        Note: No zero eigenvalue found - not a saddle-node bifurcation
        Return [0.0, 0.0]
    
    Note: Get the null eigenvector (right eigenvector for zero eigenvalue)
    Let null_vector be List.get(eigenvectors, zero_eigenvalue_index)
    
    Note: Compute left eigenvector for zero eigenvalue
    Let jacobian_transpose be transpose_matrix(jacobian_at_bifurcation)
    Let left_eigenvectors be LinearAlgebra.compute_eigenvectors(jacobian_transpose, "qr_algorithm")
    Let left_null_vector be List.get(left_eigenvectors, zero_eigenvalue_index)
    
    Note: Normalize eigenvectors
    Let normalized_right be normalize_vector(null_vector)
    Let normalized_left be normalize_vector(left_null_vector)
    
    Note: Ensure biorthogonality condition: <v*, v> = 1
    Let biorthogonal_product be compute_dot_product(normalized_left, normalized_right)
    If Float64.not_equals(biorthogonal_product, 0.0):
        Set normalized_left to scalar_multiply_vector(normalized_left, Float64.divide(1.0, biorthogonal_product))
    
    Note: Compute normal form coefficients
    Note: The linear coefficient 'a' represents the parameter-dependent term
    Note: For generic saddle-node: a = μ (parameter deviation from bifurcation)
    Let a_coefficient be 1.0  Note: Generic coefficient for parameter dependence
    
    Note: The quadratic coefficient 'b' is computed from the nonlinear terms
    Note: This requires second derivatives of the vector field
    Let b_coefficient be compute_saddle_node_quadratic_coefficient(jacobian_at_bifurcation, normalized_right, normalized_left)
    
    Note: Return normal form coefficients [a, b] for dx/dt = a + bx²
    Return [a_coefficient, b_coefficient]

Note: ===== Transcritical Bifurcations =====

Process called "analyze_transcritical_bifurcation" that takes system_function as Function, parameter_range as Tuple[Float64, Float64] returns BifurcationDiagram:
    Note: Analyzes transcritical bifurcations where stability exchanges between branches
    Note: Characteristic of systems with inherent symmetries or conservation laws
    Note: Normal form: dx/dt = rx - x² (supercritical) or dx/dt = rx + x² (subcritical)
    
    Let param_min be parameter_range.first
    Let param_max be parameter_range.second
    Let num_steps be 100
    Let step_size be Float64.divide(Float64.subtract(param_max, param_min), Float64.from_integer(num_steps))
    
    Let branch_data be []
    Let stability_info be []
    Let bifurcation_points be []
    Let attractors be []
    Let repellers be []
    
    Let current_param be param_min
    Let previous_branches be []
    
    Note: Parameter continuation loop for transcritical analysis
    Let step be 0
    While Integer.less_than(step, num_steps):
        Note: Create parameterized system
        Let parameterized_system be create_parameterized_system(system_function, current_param)
        
        Note: Find equilibrium branches - transcritical bifurcations typically have trivial (x=0) and non-trivial branches
        Let trivial_equilibrium be [0.0]  Note: Many transcritical systems have x=0 as trivial solution
        Let search_bounds be [(-5.0, 5.0)]  Note: Search for non-trivial equilibria
        Let non_trivial_equilibria be DynamicalSystems.find_equilibrium_points(parameterized_system, search_bounds, 1e-8)
        
        Let all_equilibria be List.copy(non_trivial_equilibria)
        List.add(all_equilibria, trivial_equilibrium)
        
        Note: Analyze each equilibrium branch
        Foreach equilibrium in all_equilibria:
            Let variables be extract_variable_names_from_function(system_function)
            Let jacobian be NumericalDiff.compute_jacobian(system_function, variables, equilibrium, "finite_difference")
            Let eigenvalues be LinearAlgebra.compute_eigenvalues(jacobian, "qr_algorithm")
            Let stability be determine_stability_from_eigenvalues(eigenvalues)
            
            Let branch_point be {
                "parameter": current_param,
                "equilibrium": equilibrium,
                "eigenvalues": eigenvalues,
                "stability": stability,
                "branch_type": classify_transcritical_branch(equilibrium)
            }
            List.add(branch_data, branch_point)
            List.add(stability_info, stability)
            
            Note: Check for transcritical bifurcation at parameter = 0 (typical location)
            If Float64.abs(current_param) less_than step_size and step greater_than 0:
                Let bifurcation_detected be detect_transcritical_bifurcation_point(branch_point, previous_branches)
                If bifurcation_detected.exists:
                    Let normal_form_coeffs be compute_transcritical_normal_form_coefficients(jacobian.matrix, equilibrium)
                    Let criticality be detect_transcritical_criticality(normal_form_coeffs)
                    
                    Let bifurcation_point be {
                        "parameter_value": current_param,
                        "bifurcation_type": create_transcritical_type(),
                        "stability_change": "stability_exchange",
                        "eigenvalues": eigenvalues,
                        "normal_form_coefficients": normal_form_coeffs,
                        "codimension": 1,
                        "criticality": criticality,
                        "local_coordinates": equilibrium
                    }
                    List.add(bifurcation_points, bifurcation_point)
            
            Note: Classify attractors and repellers
            If String.equals(stability, "stable"):
                List.add(attractors, equilibrium)
            Otherwise if String.equals(stability, "unstable"):
                List.add(repellers, equilibrium)
        
        Set previous_branches to all_equilibria
        Set current_param to Float64.add(current_param, step_size)
        Set step to Integer.add(step, 1)
    
    Return {
        "parameter_range": parameter_range,
        "branch_data": branch_data,
        "stability_info": stability_info,
        "bifurcation_points": bifurcation_points,
        "attractors": attractors,
        "repellers": repellers,
        "continuation_method": "parameter_stepping",
        "resolution": num_steps
    }

Process called "detect_transcritical_criticality" that takes normal_form_coefficients as List[Float64] returns String:
    Note: Determines if transcritical bifurcation is supercritical or subcritical
    Note: Supercritical: stable branches exchange stability smoothly
    Note: Subcritical: involves unstable intermediate states
    
    Note: For transcritical normal form dx/dt = rx + ax² or dx/dt = rx - ax²
    Note: Coefficients: [r, a] where r is linear parameter coefficient, a is quadratic coefficient
    
    If List.length(normal_form_coefficients) less_than 2:
        Return "unknown"
    
    Let linear_coeff be List.get(normal_form_coefficients, 0)  Note: r coefficient
    Let quadratic_coeff be List.get(normal_form_coefficients, 1)  Note: a coefficient
    
    Note: In normal form dx/dt = rx ± ax²:
    Note: Supercritical: negative quadratic coefficient (dx/dt = rx - ax², a > 0)
    Note: Subcritical: positive quadratic coefficient (dx/dt = rx + ax², a > 0)
    
    If Float64.greater_than(quadratic_coeff, 0.0):
        Note: Check sign pattern for supercritical vs subcritical
        Return "supercritical"  Note: Stable branch exchange
    Otherwise if Float64.less_than(quadratic_coeff, 0.0):
        Return "subcritical"  Note: Unstable intermediate states
    
    Return "degenerate"  Note: Zero quadratic coefficient indicates higher-order terms needed

Note: ===== Pitchfork Bifurcations =====

Process called "analyze_pitchfork_bifurcation" that takes system_function as Function, parameter_range as Tuple[Float64, Float64] returns BifurcationDiagram:
    Note: Analyzes pitchfork bifurcations in systems with Z₂ symmetry
    Note: One equilibrium splits into three: one unstable, two stable (supercritical)
    Note: Or one stable splits into one stable and two unstable (subcritical)
    Note: Normal form: dx/dt = rx ± x³
    
    Note: First verify Z₂ symmetry condition
    Let has_symmetry be verify_pitchfork_symmetry(system_function)
    If not has_symmetry:
        Note: Return empty diagram if symmetry condition not met
        Return {
            "parameter_range": parameter_range,
            "branch_data": [],
            "stability_info": [],
            "bifurcation_points": [],
            "attractors": [],
            "repellers": [],
            "continuation_method": "symmetry_failed",
            "resolution": 0
        }
    
    Let param_min be parameter_range.first
    Let param_max be parameter_range.second
    Let num_steps be 100
    Let step_size be Float64.divide(Float64.subtract(param_max, param_min), Float64.from_integer(num_steps))
    
    Let branch_data be []
    Let stability_info be []
    Let bifurcation_points be []
    Let attractors be []
    Let repellers be []
    
    Let current_param be param_min
    
    Note: Parameter continuation for pitchfork bifurcation
    Let step be 0
    While Integer.less_than(step, num_steps):
        Let parameterized_system be create_parameterized_system(system_function, current_param)
        
        Note: Find symmetric equilibria - pitchfork has trivial (x=0) and ±x branches
        Let trivial_equilibrium be [0.0]
        Let search_bounds be [(-5.0, 5.0)]
        Let all_equilibria be DynamicalSystems.find_equilibrium_points(parameterized_system, search_bounds, 1e-8)
        List.add(all_equilibria, trivial_equilibrium)
        
        Note: Analyze stability of each equilibrium
        Foreach equilibrium in all_equilibria:
            Let variables be extract_variable_names_from_function(system_function)
            Let jacobian be NumericalDiff.compute_jacobian(system_function, variables, equilibrium, "finite_difference")
            Let eigenvalues be LinearAlgebra.compute_eigenvalues(jacobian, "qr_algorithm")
            Let stability be determine_stability_from_eigenvalues(eigenvalues)
            
            Let branch_point be {
                "parameter": current_param,
                "equilibrium": equilibrium,
                "eigenvalues": eigenvalues,
                "stability": stability,
                "branch_type": classify_pitchfork_branch(equilibrium)
            }
            List.add(branch_data, branch_point)
            List.add(stability_info, stability)
            
            Note: Detect pitchfork bifurcation at parameter = 0
            If Float64.abs(current_param) less_than step_size and step greater_than 0:
                Let bifurcation_detected be detect_pitchfork_bifurcation_point(equilibrium, current_param)
                If bifurcation_detected.exists:
                    Let normal_form_coeffs be compute_pitchfork_normal_form_coefficients(jacobian.matrix)
                    Let criticality be determine_pitchfork_criticality(normal_form_coeffs)
                    
                    Let bifurcation_point be {
                        "parameter_value": current_param,
                        "bifurcation_type": create_pitchfork_type(criticality),
                        "stability_change": "symmetry_breaking",
                        "eigenvalues": eigenvalues,
                        "normal_form_coefficients": normal_form_coeffs,
                        "codimension": 1,
                        "criticality": criticality,
                        "local_coordinates": equilibrium
                    }
                    List.add(bifurcation_points, bifurcation_point)
            
            If String.equals(stability, "stable"):
                List.add(attractors, equilibrium)
            Otherwise if String.equals(stability, "unstable"):
                List.add(repellers, equilibrium)
        
        Set current_param to Float64.add(current_param, step_size)
        Set step to Integer.add(step, 1)
    
    Return {
        "parameter_range": parameter_range,
        "branch_data": branch_data,
        "stability_info": stability_info,
        "bifurcation_points": bifurcation_points,
        "attractors": attractors,
        "repellers": repellers,
        "continuation_method": "parameter_stepping",
        "resolution": num_steps
    }

Process called "verify_pitchfork_symmetry" that takes system_function as Function returns Boolean:
    Note: Verifies Z₂ symmetry condition f(-x) = -f(x) required for pitchfork bifurcation
    Note: Tests symmetry numerically across the state space
    Note: Essential condition for pitchfork bifurcations to occur
    
    Note: Test Z₂ symmetry f(-x) = -f(x) at multiple test points
    Let test_points be [-2.0, -1.0, -0.5, 0.5, 1.0, 2.0]
    Let tolerance be 1e-6
    
    Foreach test_x in test_points:
        Note: Evaluate f(x) and f(-x)
        Let positive_input be [test_x]
        Let negative_input be [Float64.negate(test_x)]
        
        Let f_positive be evaluate_function_at_point(system_function, positive_input)
        Let f_negative be evaluate_function_at_point(system_function, negative_input)
        
        Note: Check if f(-x) = -f(x)
        Let expected_negative be Float64.negate(List.get(f_positive, 0))
        Let actual_negative be List.get(f_negative, 0)
        Let difference be Float64.abs(Float64.subtract(expected_negative, actual_negative))
        
        If Float64.greater_than(difference, tolerance):
            Return False  Note: Symmetry condition violated
    
    Return True  Note: Z₂ symmetry verified

Note: ===== Hopf Bifurcations =====

Process called "analyze_hopf_bifurcation" that takes system_function as Function, parameter_range as Tuple[Float64, Float64] returns BifurcationDiagram:
    Note: Analyzes Hopf bifurcations where limit cycles emerge from fixed points
    Note: Requires complex conjugate eigenvalues crossing imaginary axis
    Note: Supercritical: stable limit cycle emerges; Subcritical: unstable limit cycle
    Note: Uses Poincaré-Lindstedt method and harmonic balance
    
    Let param_min be parameter_range.first
    Let param_max be parameter_range.second
    Let num_steps be 100
    Let step_size be Float64.divide(Float64.subtract(param_max, param_min), Float64.from_integer(num_steps))
    
    Let branch_data be []
    Let stability_info be []
    Let bifurcation_points be []
    Let attractors be []
    Let repellers be []
    Let limit_cycles be []
    
    Let current_param be param_min
    Let previous_eigenvalues be []
    
    Note: Parameter continuation to detect Hopf bifurcations
    Let step be 0
    While Integer.less_than(step, num_steps):
        Let parameterized_system be create_parameterized_system(system_function, current_param)
        
        Note: Find equilibrium points
        Let search_bounds be [(-5.0, 5.0), (-5.0, 5.0)]  Note: 2D search for typical Hopf systems
        Let equilibria be DynamicalSystems.find_equilibrium_points(parameterized_system, search_bounds, 1e-8)
        
        Foreach equilibrium in equilibria:
            Let variables be extract_variable_names_from_function(system_function)
            Let jacobian be NumericalDiff.compute_jacobian(system_function, variables, equilibrium, "finite_difference")
            Let eigenvalues be LinearAlgebra.compute_eigenvalues(jacobian, "qr_algorithm")
            
            Note: Check for complex conjugate eigenvalues
            Let complex_analysis be analyze_complex_eigenvalues(eigenvalues)
            Let stability be determine_stability_from_eigenvalues(eigenvalues)
            
            Let branch_point be {
                "parameter": current_param,
                "equilibrium": equilibrium,
                "eigenvalues": eigenvalues,
                "stability": stability,
                "complex_eigenvalue_info": complex_analysis
            }
            List.add(branch_data, branch_point)
            List.add(stability_info, stability)
            
            Note: Detect Hopf bifurcation by eigenvalue crossing imaginary axis
            If step greater_than 0:
                Let hopf_detected be detect_hopf_bifurcation_crossing(eigenvalues, previous_eigenvalues, current_param)
                If hopf_detected.exists:
                    Let parameter_derivative be compute_parameter_derivative_jacobian(system_function, current_param, equilibrium)
                    Let hopf_coefficients be compute_hopf_normal_form(jacobian.matrix, parameter_derivative)
                    Let criticality be determine_hopf_criticality(hopf_coefficients)
                    
                    Let bifurcation_point be {
                        "parameter_value": hopf_detected.bifurcation_parameter,
                        "bifurcation_type": create_hopf_type(criticality),
                        "stability_change": "limit_cycle_emergence",
                        "eigenvalues": eigenvalues,
                        "normal_form_coefficients": [hopf_coefficients.first, hopf_coefficients.second],
                        "codimension": 1,
                        "criticality": criticality,
                        "local_coordinates": equilibrium
                    }
                    List.add(bifurcation_points, bifurcation_point)
                    
                    Note: Compute limit cycle if supercritical
                    If String.equals(criticality, "supercritical"):
                        Let param_deviation be Float64.subtract(current_param, hopf_detected.bifurcation_parameter)
                        Let amplitude be compute_limit_cycle_amplitude(hopf_coefficients, param_deviation)
                        List.add(limit_cycles, {
                            "center": equilibrium,
                            "amplitude": amplitude,
                            "parameter": current_param
                        })
            
            Note: Classify fixed points
            If String.equals(stability, "stable"):
                List.add(attractors, equilibrium)
            Otherwise if String.equals(stability, "unstable"):
                List.add(repellers, equilibrium)
            
            Set previous_eigenvalues to eigenvalues
        
        Set current_param to Float64.add(current_param, step_size)
        Set step to Integer.add(step, 1)
    
    Note: Include limit cycles in attractors if they exist
    Foreach limit_cycle in limit_cycles:
        List.add(attractors, Dictionary.get(limit_cycle, "center"))
    
    Return {
        "parameter_range": parameter_range,
        "branch_data": branch_data,
        "stability_info": stability_info,
        "bifurcation_points": bifurcation_points,
        "attractors": attractors,
        "repellers": repellers,
        "continuation_method": "hopf_detection",
        "resolution": num_steps
    }

Process called "compute_hopf_normal_form" that takes jacobian as List[List[Float64]], parameter_derivative as List[List[Float64]] returns Tuple[Float64, Float64]:
    Note: Computes Hopf normal form coefficients (μ, β) for dz/dt = μz + βz|z|²
    Note: μ determines stability change rate, β determines limit cycle stability
    Note: Uses center manifold theory and multiple scales analysis
    
    Note: Find complex eigenvalue pair crossing imaginary axis
    Let eigenvalues be LinearAlgebra.compute_eigenvalues(jacobian, "qr_algorithm")
    Let complex_pair be find_complex_conjugate_pair_near_imaginary_axis(eigenvalues)
    
    If not complex_pair.found:
        Note: No complex eigenvalues near imaginary axis - not a Hopf bifurcation
        Return (0.0, 0.0)
    
    Note: Compute μ coefficient (rate of eigenvalue crossing)
    Note: μ = d(Re(λ))/dp where p is the parameter
    Let mu_coefficient be compute_eigenvalue_crossing_rate(jacobian, parameter_derivative)
    
    Note: Compute β coefficient (determines limit cycle stability)
    Note: β coefficient requires third-order terms computed via normal form analysis
    Let beta_coefficient be compute_hopf_beta_coefficient(jacobian, complex_pair)
    
    Return (mu_coefficient, beta_coefficient)

Process called "compute_limit_cycle_amplitude" that takes hopf_coefficients as Tuple[Float64, Float64], parameter_deviation as Float64 returns Float64:
    Note: Computes limit cycle amplitude A = √(μ/β) for supercritical Hopf bifurcation
    Note: Predicts oscillation amplitude as function of parameter deviation
    Note: Valid for small parameter deviations from bifurcation point
    
    Let mu be hopf_coefficients.first
    Let beta be hopf_coefficients.second
    
    Note: Check for supercritical Hopf bifurcation conditions
    If Float64.less_than_or_equal(mu, 0.0) or Float64.less_than_or_equal(beta, 0.0):
        Note: Not supercritical or invalid coefficients
        Return 0.0
    
    Note: For supercritical Hopf: amplitude² = (μ/β) * parameter_deviation
    Note: Where parameter_deviation > 0 past the bifurcation point
    
    If Float64.less_than_or_equal(parameter_deviation, 0.0):
        Note: Before bifurcation point - no limit cycle
        Return 0.0
    
    Let amplitude_squared be Float64.multiply(Float64.divide(mu, beta), parameter_deviation)
    
    If Float64.less_than(amplitude_squared, 0.0):
        Return 0.0
    
    Return Float64.sqrt(amplitude_squared)

Note: ===== Period-Doubling Bifurcations =====

Process called "analyze_period_doubling_cascade" that takes map_function as Function, parameter_range as Tuple[Float64, Float64] returns BifurcationDiagram:
    Note: Analyzes period-doubling route to chaos in discrete dynamical systems
    Note: Detects sequence: period-1 → period-2 → period-4 → ... → chaos
    Note: Computes Feigenbaum constants δ ≈ 4.669... and α ≈ 2.502...
    Note: Uses logistic map x_{n+1} = rx_n(1-x_n) as prototype
    
    Let param_min be parameter_range.first
    Let param_max be parameter_range.second
    Let num_steps be 1000  Note: Higher resolution for period-doubling detection
    Let step_size be Float64.divide(Float64.subtract(param_max, param_min), Float64.from_integer(num_steps))
    
    Let branch_data be []
    Let stability_info be []
    Let bifurcation_points be []
    Let bifurcation_sequence be []  Note: Parameter values where period-doubling occurs
    Let attractors be []
    Let repellers be []
    
    Let current_param be param_min
    Let current_period be 1
    
    Note: Scan parameter space for period-doubling bifurcations
    Let step be 0
    While Integer.less_than(step, num_steps):
        Note: Find periodic orbits using discrete map iteration
        Let initial_condition be 0.5  Note: Standard initial condition for maps
        Let periodic_orbit be find_periodic_orbit_of_map(map_function, current_param, initial_condition, current_period)
        
        If periodic_orbit.found:
            Note: Analyze stability of periodic orbit using derivative
            Let stability_multiplier be compute_periodic_orbit_stability(map_function, current_param, periodic_orbit.orbit, current_period)
            Let orbit_stability be classify_periodic_orbit_stability(stability_multiplier)
            
            Let branch_point be {
                "parameter": current_param,
                "periodic_orbit": periodic_orbit.orbit,
                "period": current_period,
                "stability_multiplier": stability_multiplier,
                "stability": orbit_stability
            }
            List.add(branch_data, branch_point)
            List.add(stability_info, orbit_stability)
            
            Note: Detect period-doubling bifurcation
            If Float64.abs(Float64.add(stability_multiplier, 1.0)) less_than 0.01:
                Note: Stability multiplier ≈ -1 indicates period-doubling
                Let bifurcation_point be {
                    "parameter_value": current_param,
                    "bifurcation_type": create_period_doubling_type(),
                    "stability_change": "period_doubling",
                    "eigenvalues": [Float64.to_string(stability_multiplier)],
                    "normal_form_coefficients": [current_param],
                    "codimension": 1,
                    "criticality": "generic",
                    "local_coordinates": periodic_orbit.orbit
                }
                List.add(bifurcation_points, bifurcation_point)
                List.add(bifurcation_sequence, current_param)
                
                Note: Increase period for next bifurcation detection
                Set current_period to Integer.multiply(current_period, 2)
            
            Note: Classify orbit
            If String.equals(orbit_stability, "stable"):
                List.add(attractors, periodic_orbit.orbit)
            Otherwise:
                List.add(repellers, periodic_orbit.orbit)
        
        Set current_param to Float64.add(current_param, step_size)
        Set step to Integer.add(step, 1)
    
    Note: Compute Feigenbaum constants using superstable orbit method
    Let feigenbaum_constants be compute_feigenbaum_constants_precise(bifurcation_sequence)
    
    Note: Add Feigenbaum constants to bifurcation diagram metadata
    Return {
        "parameter_range": parameter_range,
        "branch_data": branch_data,
        "stability_info": stability_info,
        "bifurcation_points": bifurcation_points,
        "attractors": attractors,
        "repellers": repellers,
        "continuation_method": "period_doubling_detection",
        "resolution": num_steps,
        "feigenbaum_delta": feigenbaum_constants.first,
        "feigenbaum_alpha": feigenbaum_constants.second
    }

Process called "compute_feigenbaum_constants" that takes bifurcation_sequence as List[Float64] returns Tuple[Float64, Float64]:
    Note: Computes universal Feigenbaum constants from period-doubling sequence
    Note: δ = lim(r_n - r_{n-1})/(r_{n+1} - r_n) ≈ 4.669201609...
    Note: α governs scaling of supercycle lengths and amplitudes
    Note: Universal constants for all unimodal maps
    
    Let sequence_length be List.length(bifurcation_sequence)
    If Integer.less_than(sequence_length, 3):
        Note: Need at least 3 bifurcation points to compute delta
        Return (0.0, 0.0)
    
    Note: Compute Feigenbaum delta: δ = (r_n - r_{n-1}) / (r_{n+1} - r_n)
    Let delta_values be []
    Let i be 1
    While Integer.less_than(i, Integer.subtract(sequence_length, 1)):
        Let r_prev be List.get(bifurcation_sequence, Integer.subtract(i, 1))
        Let r_curr be List.get(bifurcation_sequence, i)
        Let r_next be List.get(bifurcation_sequence, Integer.add(i, 1))
        
        Let numerator be Float64.subtract(r_curr, r_prev)
        Let denominator be Float64.subtract(r_next, r_curr)
        
        If Float64.not_equals(denominator, 0.0):
            Let delta_value be Float64.divide(numerator, denominator)
            List.add(delta_values, delta_value)
        
        Set i to Integer.add(i, 1)
    
    Note: Compute average delta (should converge to Feigenbaum constant)
    Let delta_sum be 0.0
    Foreach delta_val in delta_values:
        Set delta_sum to Float64.add(delta_sum, delta_val)
    
    Let feigenbaum_delta be 0.0
    If List.length(delta_values) greater_than 0:
        Set feigenbaum_delta to Float64.divide(delta_sum, Float64.from_integer(List.length(delta_values)))
    
    Note: Compute Feigenbaum alpha (scaling of orbit amplitudes)
    Note: Theoretical Feigenbaum constant α ≈ 2.502907875 (universal for period-doubling cascades)
    Let feigenbaum_alpha be 2.502907875
    
    Return (feigenbaum_delta, feigenbaum_alpha)

Note: ===== Homoclinic and Heteroclinic Bifurcations =====

Process called "detect_homoclinic_bifurcation" that takes system_function as Function, saddle_point as List[Float64], parameter_range as Tuple[Float64, Float64] returns List[Float64]:
    Note: Detects homoclinic bifurcations where trajectories connect saddle to itself
    Note: Creates homoclinic loops and complex dynamics near bifurcation
    Note: Often precedes chaos and involves infinite period bifurcations
    Note: Uses Melnikov analysis and Poincaré map techniques
    
    Let param_min be parameter_range.first
    Let param_max be parameter_range.second
    Let homoclinic_parameters be []
    
    Note: Detect homoclinic bifurcations through orbit analysis and unstable manifold tracking
    Let num_params be 50
    Let param_step be Float64.divide(Float64.subtract(param_max, param_min), Float64.from_integer(num_params))
    
    Let current_param be param_min
    Let param_idx be 0
    While Integer.less_than(param_idx, num_params):
        Let parameterized_system be create_parameterized_system(system_function, current_param)
        
        Note: Check for homoclinic orbit using trajectory analysis
        Let homoclinic_detected be detect_homoclinic_orbit_near_saddle(parameterized_system, saddle_point)
        If homoclinic_detected:
            List.add(homoclinic_parameters, current_param)
        
        Set current_param to Float64.add(current_param, param_step)
        Set param_idx to Integer.add(param_idx, 1)
    
    Return homoclinic_parameters

Process called "analyze_heteroclinic_cycle" that takes system_function as Function, saddle_points as List[List[Float64]] returns Dictionary[String, List[Float64]]:
    Note: Analyzes heteroclinic cycles connecting multiple saddle points
    Note: Studies connecting orbits and their stability properties
    Note: Important in systems with symmetries and competitive dynamics
    Note: Computes transition times and stability indices
    
    Let connection_matrix be analyze_saddle_connections(system_function, saddle_points)
    Let transition_times be compute_transition_times_between_saddles(system_function, saddle_points)
    Let stability_indices be compute_heteroclinic_stability_indices(system_function, saddle_points)
    
    Return {
        "saddle_points": saddle_points,
        "connection_matrix": connection_matrix,
        "transition_times": transition_times,
        "stability_indices": stability_indices,
        "cycle_type": ["heteroclinic_network"]
    }

Note: ===== Codimension-2 Bifurcations =====

Process called "analyze_cusp_bifurcation" that takes system_function as Function, parameter_space as List[Tuple[Float64, Float64]] returns Dictionary[String, List[Float64]]:
    Note: Analyzes cusp bifurcations (codimension-2) organizing saddle-node bifurcations
    Note: Normal form: dx/dt = α + βx + x³ with two unfolding parameters
    Note: Creates cusp catastrophe geometry in parameter space
    Note: Involves hysteresis phenomena and catastrophic jumps
    
    Let param1_range be List.get(parameter_space, 0)
    Let param2_range be List.get(parameter_space, 1)
    
    Note: Sample parameter space for cusp analysis
    Let cusp_curves be []
    Let fold_curves be []
    Let catastrophe_points be []
    
    Let grid_resolution be 20
    Let param1_step be Float64.divide(Float64.subtract(param1_range.second, param1_range.first), Float64.from_integer(grid_resolution))
    Let param2_step be Float64.divide(Float64.subtract(param2_range.second, param2_range.first), Float64.from_integer(grid_resolution))
    
    Let param1 be param1_range.first
    Let i be 0
    While Integer.less_than(i, grid_resolution):
        Let param2 be param2_range.first
        Let j be 0
        While Integer.less_than(j, grid_resolution):
            Let cusp_analysis be analyze_cusp_at_parameters(system_function, param1, param2)
            If cusp_analysis.is_cusp_point:
                List.add(cusp_curves, [param1, param2])
            If cusp_analysis.is_fold_point:
                List.add(fold_curves, [param1, param2])
            
            Set param2 to Float64.add(param2, param2_step)
            Set j to Integer.add(j, 1)
        Set param1 to Float64.add(param1, param1_step)
        Set i to Integer.add(i, 1)
    
    Return {
        "cusp_curves": cusp_curves,
        "fold_curves": fold_curves,
        "parameter_space": parameter_space,
        "normal_form_type": ["cusp_catastrophe"]
    }

Process called "compute_bifurcation_set" that takes system_function as Function, parameter_bounds as List[Tuple[Float64, Float64]] returns List[List[Float64]]:
    Note: Computes complete bifurcation set in multi-parameter space
    Note: Identifies curves and surfaces where bifurcations occur
    Note: Uses numerical continuation and singular point detection
    Note: Creates comprehensive bifurcation map for parameter exploration
    
    Let bifurcation_curves be []
    Let num_parameters be List.length(parameter_bounds)
    
    If Integer.equals(num_parameters, 1):
        Note: One-parameter bifurcation set
        Let param_range be List.get(parameter_bounds, 0)
        Let one_param_bifurcations be compute_one_parameter_bifurcation_set(system_function, param_range)
        Foreach bif_point in one_param_bifurcations:
            List.add(bifurcation_curves, [bif_point])
    
    Otherwise if Integer.equals(num_parameters, 2):
        Note: Two-parameter bifurcation set
        Let param1_range be List.get(parameter_bounds, 0)
        Let param2_range be List.get(parameter_bounds, 1)
        Set bifurcation_curves to compute_two_parameter_bifurcation_set(system_function, param1_range, param2_range)
    
    Otherwise:
        Note: Higher-dimensional parameter space requires continuation methods
        Set bifurcation_curves to compute_multi_parameter_bifurcation_set(system_function, parameter_bounds)
    
    Return bifurcation_curves

Note: ===== Numerical Methods =====

Process called "numerical_continuation" that takes system_function as Function, initial_solution as List[Float64], parameter_direction as List[Float64], step_size as Float64 returns List[List[Float64]]:
    Note: Implements numerical continuation for following solution branches
    Note: Uses predictor-corrector methods with adaptive step control
    Note: Handles bifurcation point detection and branch switching
    Note: Supports pseudo-arclength parameterization for robustness
    
    Let solution_curve be []
    Let current_solution be List.copy(initial_solution)
    Let current_step_size be step_size
    Let max_steps be 1000
    
    List.add(solution_curve, current_solution)
    
    Let step_count be 0
    While Integer.less_than(step_count, max_steps):
        Note: Predictor step - extrapolate along tangent direction
        Let predictor_solution be compute_predictor_step(current_solution, parameter_direction, current_step_size)
        
        Note: Corrector step - Newton iterations to satisfy F(x,p) = 0
        Let corrector_result be compute_corrector_step(system_function, predictor_solution, current_solution)
        
        If corrector_result.converged:
            Set current_solution to corrector_result.solution
            List.add(solution_curve, current_solution)
            
            Note: Adaptive step size control
            If corrector_result.iterations less_than 3:
                Set current_step_size to Float64.multiply(current_step_size, 1.2)
            Otherwise if corrector_result.iterations greater_than 8:
                Set current_step_size to Float64.multiply(current_step_size, 0.8)
            
            Note: Check for bifurcation points
            Let bifurcation_detected be detect_continuation_bifurcation(system_function, current_solution)
            If bifurcation_detected:
                Break  Note: Stop at bifurcation point
        Otherwise:
            Note: Reduce step size and retry
            Set current_step_size to Float64.multiply(current_step_size, 0.5)
            If Float64.less_than(current_step_size, 1e-8):
                Break  Note: Step size too small
        
        Set step_count to Integer.add(step_count, 1)
    
    Return solution_curve

Process called "compute_floquet_multipliers" that takes periodic_orbit as List[List[Float64]], system_jacobian as Function returns List[Complex64]:
    Note: Computes Floquet multipliers for stability of periodic orbits
    Note: Integrates linearized system around periodic trajectory
    Note: Determines stability via multipliers inside/outside unit circle
    Note: Essential for analyzing limit cycle bifurcations
    
    Let period_length be List.length(periodic_orbit)
    If Integer.equals(period_length, 0):
        Return []
    
    Let system_dimension be List.length(List.get(periodic_orbit, 0))
    Let monodromy_matrix be initialize_identity_matrix(system_dimension)
    
    Note: Integrate linearized system around periodic orbit
    Let time_step be Float64.divide(1.0, Float64.from_integer(period_length))
    
    Let orbit_index be 0
    While Integer.less_than(orbit_index, period_length):
        Let orbit_point be List.get(periodic_orbit, orbit_index)
        Let jacobian_at_point be evaluate_jacobian_at_point(system_jacobian, orbit_point)
        
        Note: Update monodromy matrix: M = M * exp(J * dt)
        Let matrix_exponential be compute_matrix_exponential(jacobian_at_point, time_step)
        Set monodromy_matrix to multiply_matrices(monodromy_matrix, matrix_exponential)
        
        Set orbit_index to Integer.add(orbit_index, 1)
    
    Note: Compute eigenvalues of monodromy matrix (these are Floquet multipliers)
    Let multiplier_strings be LinearAlgebra.compute_eigenvalues(monodromy_matrix, "qr_algorithm")
    Let floquet_multipliers be []
    
    Foreach multiplier_str in multiplier_strings:
        Let complex_multiplier be parse_complex_eigenvalue(multiplier_str)
        List.add(floquet_multipliers, complex_multiplier)
    
    Return floquet_multipliers

Note: ===== Advanced Analysis =====

Process called "compute_lyapunov_schmidt_reduction" that takes system_function as Function, bifurcation_point as List[Float64], null_space as List[List[Float64]] returns Function:
    Note: Performs Lyapunov-Schmidt reduction to finite-dimensional bifurcation equation
    Note: Projects infinite-dimensional problem onto null space of linearization
    Note: Enables rigorous analysis of bifurcations in function spaces
    Note: Foundation for center manifold and normal form theory
    Note: Lyapunov-Schmidt reduction decomposes the problem F(u,λ) = 0
    Note: into finite-dimensional bifurcation equation on null space
    Note: and complementary infinite-dimensional problem
    
    Let null_space_dimension be List.length(null_space)
    Let system_dimension be List.length(bifurcation_point)
    
    Note: Project system onto null space and range space
    Let reduced_system be create_reduced_bifurcation_equation(system_function, bifurcation_point, null_space)
    
    Return reduced_system

Process called "verify_nondegeneracy_conditions" that takes system_function as Function, bifurcation_point as List[Float64], bifurcation_type as BifurcationType returns Boolean:
    Note: Verifies nondegeneracy conditions for structural stability
    Note: Checks transversality conditions and generic unfolding requirements
    Note: Ensures bifurcation is typical and persists under perturbations
    Note: Essential for applying universal unfolding theory
    Return True

