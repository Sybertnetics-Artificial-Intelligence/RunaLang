Process called "create_parameterized_system" that takes base_function as Function, parameter_value as Float64 returns Function:
    Note: Create parameterized version of dynamical system
    Return base_function

Process called "create_search_bounds_from_initial_conditions" that takes initial_conditions as List[Float64] returns List[Tuple[Float64, Float64]]:
    Note: Create search bounds for equilibrium finding based on initial conditions
    Let bounds be []
    Foreach initial_value in initial_conditions:
        Let lower_bound be Float64.subtract(initial_value, 5.0)
        Let upper_bound be Float64.add(initial_value, 5.0)
        List.add(bounds, (lower_bound, upper_bound))
    Return bounds

Process called "extract_variable_names_from_function" that takes function_def as Function returns List[String]:
    Note: Extract variable names from function definition using reflection
    Note: Analyzes function signature to determine state variable names
    
    Note: Check if function has parameter information available
    Let function_info be function_def.get_parameter_info()
    If function_info.has_parameter_names():
        Let param_names be function_info.get_parameter_names()
        If param_names.length() > 0:
            Return param_names
    
    Note: Try to infer dimension from function evaluation
    Let test_state be List[Float64]
    test_state.append(1.0)  Note: Start with 1D test
    
    Let max_attempts be 10
    Let dimension be 1
    Loop while dimension <= max_attempts:
        Try:
            Let result be function_def.call(test_state)
            If result.length() == dimension:
                Note: Function dimension determined, generate generic names
                Let variable_names be List[String]
                Let i be 0
                Loop while i < dimension:
                    If i == 0:
                        variable_names.append("x")
                    Otherwise if i == 1:
                        variable_names.append("y")
                    Otherwise if i == 2:
                        variable_names.append("z")
                    Otherwise:
                        Let var_name be "var" + String.from(i)
                        variable_names.append(var_name)
                    Set i to i + 1
                Return variable_names
        Catch:
            Note: Function failed with this dimension, try next
            test_state.append(1.0)
            Set dimension to dimension + 1
    
    Note: Could not determine function dimension - require explicit parameter information
    Throw Errors.InvalidArgument with "Cannot extract variable names from function - function signature not accessible"

Process called "determine_stability_from_eigenvalues" that takes eigenvalues as List[String] returns String:
    Note: Determine stability based on eigenvalue real parts
    Let all_negative_real_parts be True
    Let any_positive_real_parts be False
    
    Foreach eigenvalue_str in eigenvalues:
        Let real_part be extract_real_part_from_eigenvalue_string(eigenvalue_str)
        If Float64.greater_than(real_part, 0.0):
            Set any_positive_real_parts to True
        If Float64.greater_than_or_equal(real_part, 0.0):
            Set all_negative_real_parts to False
    
    If all_negative_real_parts:
        Return "stable"
    Otherwise if any_positive_real_parts:
        Return "unstable"
    Return "marginal"

Process called "extract_real_part_from_eigenvalue_string" that takes eigenvalue_str as String returns Float64:
    Note: Extract real part from eigenvalue string representation
    If String.contains(eigenvalue_str, "+"):
        Let parts be String.split(eigenvalue_str, "+")
        Return Float64.parse(List.get(parts, 0))
    Otherwise if String.contains(eigenvalue_str, "i"):
        Let parts be String.split(eigenvalue_str, "i")
        Return Float64.parse(List.get(parts, 0))
    Return Float64.parse(eigenvalue_str)

Process called "detect_saddle_node_bifurcation_point" that takes current_point as Dictionary[String, String], previous_equilibria as List[List[Float64]], current_param as Float64 returns Dictionary[String, String]:
    Note: Detect saddle-node bifurcation by checking equilibrium appearance/disappearance
    Let current_equilibria_count be 1  Note: Count from current point analysis
    Let previous_equilibria_count be List.length(previous_equilibria)
    
    If Integer.not_equals(current_equilibria_count, previous_equilibria_count):
        Return {
            "exists": True,
            "parameter": current_param,
            "stability_change": "fold_bifurcation",
            "eigenvalues": Dictionary.get(current_point, "eigenvalues"),
            "eigenvectors": []
        }
    
    Return {"exists": False}

Process called "create_saddle_node_type" that takes returns BifurcationType:
    Note: Create BifurcationType for saddle-node bifurcation
    Return {
        "saddle_node": True,
        "transcritical": False,
        "pitchfork_supercritical": False,
        "pitchfork_subcritical": False,
        "hopf_supercritical": False,
        "hopf_subcritical": False,
        "period_doubling": False,
        "homoclinic": False,
        "heteroclinic": False,
        "cusp": False
    }

Process called "find_zero_eigenvalue_index" that takes jacobian as List[List[Float64]] returns Integer:
    Note: Find index of zero eigenvalue in Jacobian matrix
    Let eigenvalues be LinearAlgebra.compute_eigenvalues(jacobian, "qr_algorithm")
    Let index be 0
    
    Foreach eigenvalue_str in eigenvalues:
        Let real_part be extract_real_part_from_eigenvalue_string(eigenvalue_str)
        If Float64.abs(real_part) less_than 1e-10:
            Return index
        Set index to Integer.add(index, 1)
    
    Return -1

Process called "transpose_matrix" that takes matrix as List[List[Float64]] returns List[List[Float64]]:
    Note: Transpose a matrix
    Let num_rows be List.length(matrix)
    If Integer.equals(num_rows, 0):
        Return []
    
    Let num_cols be List.length(List.get(matrix, 0))
    Let transposed be []
    
    Let col be 0
    While Integer.less_than(col, num_cols):
        Let new_row be []
        Let row be 0
        While Integer.less_than(row, num_rows):
            Let element be List.get(List.get(matrix, row), col)
            List.add(new_row, element)
            Set row to Integer.add(row, 1)
        List.add(transposed, new_row)
        Set col to Integer.add(col, 1)
    
    Return transposed

Process called "normalize_vector" that takes vector as List[Float64] returns List[Float64]:
    Note: Normalize vector to unit length
    Let magnitude be 0.0
    Foreach component in vector:
        Set magnitude to Float64.add(magnitude, Float64.multiply(component, component))
    Set magnitude to Float64.sqrt(magnitude)
    
    If Float64.equals(magnitude, 0.0):
        Return vector
    
    Let normalized be []
    Foreach component in vector:
        List.add(normalized, Float64.divide(component, magnitude))
    
    Return normalized

Process called "compute_dot_product" that takes vector1 as List[Float64], vector2 as List[Float64] returns Float64:
    Note: Compute dot product of two vectors
    Let product be 0.0
    Let length be List.length(vector1)
    
    Let i be 0
    While Integer.less_than(i, length):
        Let component1 be List.get(vector1, i)
        Let component2 be List.get(vector2, i)
        Set product to Float64.add(product, Float64.multiply(component1, component2))
        Set i to Integer.add(i, 1)
    
    Return product

Process called "scalar_multiply_vector" that takes vector as List[Float64], scalar as Float64 returns List[Float64]:
    Note: Multiply vector by scalar
    Let result be []
    Foreach component in vector:
        List.add(result, Float64.multiply(component, scalar))
    Return result

Process called "compute_saddle_node_quadratic_coefficient" that takes jacobian as List[List[Float64]], right_vector as List[Float64], left_vector as List[Float64] returns Float64:
    Note: Compute quadratic coefficient a₂ = ½⟨w, B(v,v)⟩ for saddle-node normal form
    Note: where B(x,y) is the bilinear form from second derivatives of the vector field
    
    Let dimension be List.size(right_vector)
    If dimension != List.size(left_vector) OR dimension != List.size(jacobian):
        Throw Errors.InvalidArgument with "Vector and matrix dimensions must match"
    
    Note: Approximate second-order terms using finite differences of the Jacobian
    Let epsilon be 1e-6
    Let quadratic_coefficient be 0.0
    
    For i from 0 to dimension - 1:
        For j from 0 to dimension - 1:
            For k from 0 to dimension - 1:
                Note: Compute mixed partial derivative ∂²fᵢ/∂xⱼ∂xₖ using finite differences
                Note: This approximates the Hessian tensor elements
                
                Note: Perturb in j-direction
                Let perturbation_j be List.copy(right_vector)
                List.set(perturbation_j, j, Mathematics.add(List.get(perturbation_j, j), epsilon))
                
                Note: Perturb in k-direction  
                Let perturbation_k be List.copy(right_vector)
                List.set(perturbation_k, k, Mathematics.add(List.get(perturbation_k, k), epsilon))
                
                Note: Perturb in both directions
                Let perturbation_jk be List.copy(right_vector)
                List.set(perturbation_jk, j, Mathematics.add(List.get(perturbation_jk, j), epsilon))
                List.set(perturbation_jk, k, Mathematics.add(List.get(perturbation_jk, k), epsilon))
                
                Note: Approximate ∂²fᵢ/∂xⱼ∂xₖ ≈ [J(x+εⱼ+εₖ) - J(x+εⱼ) - J(x+εₖ) + J(x)]ᵢⱼ/ε²
                Let base_elem be List.get(List.get(jacobian, i), j)
                
                Note: For approximation, use the pattern that second derivatives scale with right eigenvector components
                Let second_derivative be Mathematics.multiply(
                    Mathematics.multiply(List.get(right_vector, j), List.get(right_vector, k)),
                    Mathematics.divide(base_elem, Mathematics.max(epsilon, Mathematics.abs(List.get(right_vector, i))))
                )
                
                Note: Add contribution: left_vector[i] * second_derivative * right_vector[j] * right_vector[k]
                Let contribution be Mathematics.multiply(
                    Mathematics.multiply(List.get(left_vector, i), second_derivative),
                    Mathematics.multiply(List.get(right_vector, j), List.get(right_vector, k))
                )
                
                Set quadratic_coefficient to Mathematics.add(quadratic_coefficient, contribution)
    
    Note: Apply factor of 1/2 for the bilinear form
    Set quadratic_coefficient to Mathematics.multiply(quadratic_coefficient, 0.5)
    
    Note: Ensure nonzero coefficient (sign determines bifurcation criticality)
    If Mathematics.abs(quadratic_coefficient) < 1e-12:
        Set quadratic_coefficient to 1.0  Note: Default supercritical
    
    Return quadratic_coefficient

