Note: ===== Chaotic System Characteristics =====

Type called "ChaoticMetrics":
    largest_lyapunov_exponent as Float64
    lyapunov_spectrum as List[Float64]
    correlation_dimension as Float64
    fractal_dimension as Float64
    kolmogorov_entropy as Float64
    attractor_dimension as Float64
    embedding_dimension as Integer
    time_delay as Float64
    prediction_horizon as Float64

Type called "StrangeAttractor":
    attractor_points as List[List[Float64]]
    fractal_dimension as Float64
    box_counting_dimension as Float64
    correlation_dimension as Float64
    lyapunov_dimension as Float64
    basin_of_attraction as List[List[Float64]]
    homoclinic_tangles as List[List[Float64]]
    invariant_measure as Function
    symbolic_dynamics as List[String]

Type called "ChaoticSystem":
    system_equations as Function
    parameters as Dictionary[String, Float64]
    phase_space_dimension as Integer
    attractor as StrangeAttractor
    metrics as ChaoticMetrics
    poincare_section as List[List[Float64]]
    return_map as Function
    symbolic_sequence as List[String]

Note: ===== Lyapunov Exponents =====

Process called "compute_lyapunov_spectrum" that takes system_function as Function, initial_condition as List[Float64], integration_time as Float64, time_step as Float64 returns List[Float64]:
    Note: Computes complete Lyapunov spectrum using QR decomposition method
    Note: Measures exponential divergence rates in all phase space directions
    Note: Positive exponent indicates chaotic direction; zero for flow direction
    Note: Sum equals divergence: Σλᵢ = ∇·f for continuous systems
    
    Let dimension be List.size(initial_condition)
    If dimension = 0:
        Throw Errors.InvalidArgument with "Initial condition cannot be empty"
    If integration_time <= 0.0:
        Throw Errors.InvalidArgument with "Integration time must be positive"
    If time_step <= 0.0:
        Throw Errors.InvalidArgument with "Time step must be positive"
    
    Note: Initialize tangent space with identity matrix
    Let tangent_vectors be List.create()
    Let i be 0
    While i < dimension:
        Let tangent_vector be List.create()
        Let j be 0
        While j < dimension:
            If i = j:
                List.push(tangent_vector, 1.0)
            Otherwise:
                List.push(tangent_vector, 0.0)
            Set j to Mathematics.add(j, 1)
        List.push(tangent_vectors, tangent_vector)
        Set i to Mathematics.add(i, 1)
    
    Note: Initialize state and accumulate exponents
    Let current_state be List.copy(initial_condition)
    Let accumulated_exponents be List.create()
    Set i to 0
    While i < dimension:
        List.push(accumulated_exponents, 0.0)
        Set i to Mathematics.add(i, 1)
    
    Note: Integration parameters
    Let num_steps be Mathematics.floor(Mathematics.divide(integration_time, time_step))
    Let qr_interval be 10
    Let step_count be 0
    
    Note: Main integration loop with QR orthogonalization
    While step_count < num_steps:
        Note: Compute numerical Jacobian at current state
        Let jacobian be compute_jacobian(system_function, current_state, 1e-8)
        
        Note: Evolve state using RK4
        Set current_state to runge_kutta_step(system_function, current_state, time_step)
        
        Note: Evolve tangent vectors using linearization
        Set i to 0
        While i < dimension:
            Let tangent be List.get(tangent_vectors, i)
            Let evolved_tangent be matrix_vector_multiply(jacobian, tangent)
            List.set(tangent_vectors, i, evolved_tangent)
            Set i to Mathematics.add(i, 1)
        
        Note: Perform QR decomposition every qr_interval steps
        If Mathematics.mod(step_count, qr_interval) = 0 AND step_count > 0:
            Let qr_result be Decomposition.qr_decomposition(tangent_vectors)
            Let q_matrix be Dictionary.get(qr_result, "Q")
            Let r_matrix be Dictionary.get(qr_result, "R")
            
            Note: Update accumulated exponents from R diagonal
            Set i to 0
            While i < dimension:
                Let r_diagonal be List.get(List.get(r_matrix, i), i)
                Let log_r be Mathematics.log(Mathematics.abs(r_diagonal))
                Let current_exp be List.get(accumulated_exponents, i)
                List.set(accumulated_exponents, i, Mathematics.add(current_exp, log_r))
                Set i to Mathematics.add(i, 1)
            
            Note: Use orthogonalized vectors for next iteration
            Set tangent_vectors to q_matrix
        
        Set step_count to Mathematics.add(step_count, 1)
    
    Note: Normalize by integration time to get Lyapunov exponents
    Let lyapunov_spectrum be List.create()
    Set i to 0
    While i < dimension:
        Let accumulated to List.get(accumulated_exponents, i)
        Let lyapunov_exp be Mathematics.divide(accumulated, integration_time)
        List.push(lyapunov_spectrum, lyapunov_exp)
        Set i to Mathematics.add(i, 1)
    
    Return lyapunov_spectrum

Process called "largest_lyapunov_exponent" that takes trajectory_data as List[List[Float64]], embedding_dimension as Integer, time_delay as Integer returns Float64:
    Note: Computes largest Lyapunov exponent from time series data
    Note: Uses Rosenstein's algorithm with nearest neighbor tracking
    Note: Positive value confirms chaotic behavior in the system
    Note: Critical for distinguishing chaos from noise or periodic motion
    
    If List.size(trajectory_data) = 0:
        Throw Errors.InvalidArgument with "Trajectory data cannot be empty"
    If embedding_dimension <= 0:
        Throw Errors.InvalidArgument with "Embedding dimension must be positive"
    If time_delay <= 0:
        Throw Errors.InvalidArgument with "Time delay must be positive"
    
    Note: Reconstruct phase space using time delay embedding
    Let embedded_points be List.create()
    Let data_length be List.size(trajectory_data)
    Let max_index be Mathematics.subtract(data_length, Mathematics.multiply(Mathematics.subtract(embedding_dimension, 1), time_delay))
    
    If max_index <= 0:
        Throw Errors.InvalidArgument with "Insufficient data for embedding"
    
    Let i be 0
    While i < max_index:
        Let embedded_point be List.create()
        Let j be 0
        While j < embedding_dimension:
            Let time_index be Mathematics.add(i, Mathematics.multiply(j, time_delay))
            If List.size(List.get(trajectory_data, time_index)) > 0:
                List.push(embedded_point, List.get(List.get(trajectory_data, time_index), 0))
            Otherwise:
                List.push(embedded_point, 0.0)
            Set j to Mathematics.add(j, 1)
        List.push(embedded_points, embedded_point)
        Set i to Mathematics.add(i, 1)
    
    Note: Find nearest neighbors for each point
    Let neighbor_distances be List.create()
    Let neighbor_indices be List.create()
    Let num_points be List.size(embedded_points)
    
    Set i to 0
    While i < Mathematics.subtract(num_points, 1):
        Let current_point be List.get(embedded_points, i)
        Let min_distance be 1e10
        Let min_index be Mathematics.add(i, 1)
        
        Let j be Mathematics.add(i, 1)
        While j < num_points:
            Let candidate_point be List.get(embedded_points, j)
            Let distance be euclidean_distance(current_point, candidate_point)
            
            If distance < min_distance:
                Set min_distance to distance
                Set min_index to j
            Set j to Mathematics.add(j, 1)
        
        List.push(neighbor_distances, min_distance)
        List.push(neighbor_indices, min_index)
        Set i to Mathematics.add(i, 1)
    
    Note: Track divergence of nearest neighbors over time
    Let log_divergences be List.create()
    Let evolution_steps be Mathematics.min(50, Mathematics.subtract(num_points, List.size(neighbor_distances)))
    
    Let step be 1
    While step <= evolution_steps:
        Let sum_log_divergence be 0.0
        Let valid_pairs be 0
        
        Set i to 0
        While i < List.size(neighbor_distances):
            Let original_index be i
            Let neighbor_index be List.get(neighbor_indices, i)
            Let evolved_original_index be Mathematics.add(original_index, step)
            Let evolved_neighbor_index be Mathematics.add(neighbor_index, step)
            
            If evolved_original_index < num_points AND evolved_neighbor_index < num_points:
                Let original_evolved be List.get(embedded_points, evolved_original_index)
                Let neighbor_evolved be List.get(embedded_points, evolved_neighbor_index)
                Let evolved_distance be euclidean_distance(original_evolved, neighbor_evolved)
                
                If evolved_distance > 0.0:
                    Set sum_log_divergence to Mathematics.add(sum_log_divergence, Mathematics.log(evolved_distance))
                    Set valid_pairs to Mathematics.add(valid_pairs, 1)
            
            Set i to Mathematics.add(i, 1)
        
        If valid_pairs > 0:
            Let average_log_divergence be Mathematics.divide(sum_log_divergence, valid_pairs)
            List.push(log_divergences, average_log_divergence)
        Otherwise:
            List.push(log_divergences, 0.0)
        
        Set step to Mathematics.add(step, 1)
    
    Note: Linear regression to find slope (Lyapunov exponent)
    If List.size(log_divergences) < 2:
        Throw Errors.InvalidArgument with "Insufficient data points for Lyapunov exponent calculation"
    
    Let n be List.size(log_divergences)
    Let sum_x be 0.0
    Let sum_y be 0.0
    Let sum_xy be 0.0
    Let sum_x2 be 0.0
    
    Set i to 0
    While i < n:
        Let x be i
        Let y be List.get(log_divergences, i)
        Set sum_x to Mathematics.add(sum_x, x)
        Set sum_y to Mathematics.add(sum_y, y)
        Set sum_xy to Mathematics.add(sum_xy, Mathematics.multiply(x, y))
        Set sum_x2 to Mathematics.add(sum_x2, Mathematics.multiply(x, x))
        Set i to Mathematics.add(i, 1)
    
    Let denominator be Mathematics.subtract(Mathematics.multiply(n, sum_x2), Mathematics.multiply(sum_x, sum_x))
    If Mathematics.abs(denominator) < 1e-12:
        Note: Denominator near zero indicates degenerate case - use robust estimation
        Note: Apply Theil-Sen estimator for robust slope estimation when normal regression fails
        Return compute_theil_sen_slope(log_divergences)
    
    Let slope be Mathematics.divide(Mathematics.subtract(Mathematics.multiply(n, sum_xy), Mathematics.multiply(sum_x, sum_y)), denominator)
    
    Return slope

Process called "lyapunov_dimension" that takes lyapunov_spectrum as List[Float64] returns Float64:
    Note: Computes Lyapunov (Kaplan-Yorke) dimension: DL = j + Σᵢ₌₁ʲλᵢ/|λⱼ₊₁|
    Note: Estimates attractor dimension from Lyapunov exponent spectrum
    Note: j is largest index where sum of first j exponents is positive
    Note: Provides dimension estimate without embedding reconstruction
    
    If List.size(lyapunov_spectrum) = 0:
        Throw Errors.InvalidArgument with "Lyapunov spectrum cannot be empty"
    
    Note: Sort spectrum in descending order
    Let sorted_spectrum be List.create()
    Let i be 0
    While i < List.size(lyapunov_spectrum):
        List.push(sorted_spectrum, List.get(lyapunov_spectrum, i))
        Set i to Mathematics.add(i, 1)
    
    Note: Simple bubble sort for descending order
    Let n be List.size(sorted_spectrum)
    Let pass be 0
    While pass < Mathematics.subtract(n, 1):
        Set i to 0
        While i < Mathematics.subtract(n, pass, 1):
            Let current be List.get(sorted_spectrum, i)
            Let next be List.get(sorted_spectrum, Mathematics.add(i, 1))
            If current < next:
                List.set(sorted_spectrum, i, next)
                List.set(sorted_spectrum, Mathematics.add(i, 1), current)
            Set i to Mathematics.add(i, 1)
        Set pass to Mathematics.add(pass, 1)
    
    Note: Find largest j where sum of first j exponents is positive
    Let cumulative_sum be 0.0
    Let j be 0
    
    Set i to 0
    While i < n:
        Set cumulative_sum to Mathematics.add(cumulative_sum, List.get(sorted_spectrum, i))
        If cumulative_sum > 0.0:
            Set j to Mathematics.add(i, 1)
        Otherwise:
            Break
        Set i to Mathematics.add(i, 1)
    
    Note: Handle edge cases
    If j = 0:
        Note: All exponents negative - system contracts to fixed point or periodic orbit
        Note: Dimension approaches zero but may have small positive contribution from noise/perturbations
        Note: Return small positive dimension reflecting statistical fluctuations
        Let largest_exponent be List.get(sorted_spectrum, 0)
        Let dimension_perturbation be Float64.max(1e-6, Float64.abs(largest_exponent) * 1e-3)
        Return dimension_perturbation
    If j = n:
        Return n  Note: All exponents positive, integer dimension
    
    Note: Compute fractional part: Σᵢ₌₁ʲλᵢ/|λⱼ₊₁|
    Let numerator_sum be 0.0
    Set i to 0
    While i < j:
        Set numerator_sum to Mathematics.add(numerator_sum, List.get(sorted_spectrum, i))
        Set i to Mathematics.add(i, 1)
    
    Let next_exponent be List.get(sorted_spectrum, j)
    If Mathematics.abs(next_exponent) < 1e-12:
        Return j  Note: Avoid division by zero, return integer dimension
    
    Let fractional_part be Mathematics.divide(numerator_sum, Mathematics.abs(next_exponent))
    Let lyapunov_dimension be Mathematics.add(j, fractional_part)
    
    Return lyapunov_dimension

Note: ===== Strange Attractors =====

Process called "analyze_lorenz_attractor" that takes sigma as Float64, rho as Float64, beta as Float64, integration_time as Float64 returns StrangeAttractor:
    Note: Analyzes the famous Lorenz attractor with butterfly-shaped structure
    Note: Lorenz equations: dx/dt = σ(y-x), dy/dt = x(ρ-z)-y, dz/dt = xy-βz
    Note: Classic parameters: σ=10, ρ=28, β=8/3 yield chaotic attractor
    Note: Computes fractal dimension ≈ 2.06 and Lyapunov exponents
    
    If sigma <= 0.0:
        Throw Errors.InvalidArgument with "Sigma parameter must be positive"
    If rho <= 0.0:
        Throw Errors.InvalidArgument with "Rho parameter must be positive" 
    If beta <= 0.0:
        Throw Errors.InvalidArgument with "Beta parameter must be positive"
    If integration_time <= 0.0:
        Throw Errors.InvalidArgument with "Integration time must be positive"
    
    Note: Define Lorenz system equations
    Let lorenz_system be Function(state, params):
        Let x be List.get(state, 0)
        Let y be List.get(state, 1) 
        Let z be List.get(state, 2)
        Let s be Dictionary.get(params, "sigma")
        Let r be Dictionary.get(params, "rho")
        Let b be Dictionary.get(params, "beta")
        
        Let dx_dt be Mathematics.multiply(s, Mathematics.subtract(y, x))
        Let dy_dt be Mathematics.subtract(Mathematics.multiply(x, Mathematics.subtract(r, z)), y)
        Let dz_dt be Mathematics.subtract(Mathematics.multiply(x, y), Mathematics.multiply(b, z))
        
        Return [dx_dt, dy_dt, dz_dt]
    
    Note: Set up parameters and initial conditions
    Let parameters be Dictionary.create()
    Dictionary.set(parameters, "sigma", sigma)
    Dictionary.set(parameters, "rho", rho)
    Dictionary.set(parameters, "beta", beta)
    
    Let initial_state be [1.0, 1.0, 1.0]  Note: Standard initial condition
    Let time_step be 0.01
    Let num_steps be Mathematics.floor(Mathematics.divide(integration_time, time_step))
    
    Note: Integrate the Lorenz system
    Let trajectory be List.create()
    Let current_state be List.copy(initial_state)
    List.push(trajectory, List.copy(current_state))
    
    Let step be 0
    While step < num_steps:
        Set current_state to runge_kutta_step(lorenz_system, current_state, time_step, parameters)
        
        Note: Store every 10th point to reduce memory usage
        If Mathematics.mod(step, 10) = 0:
            List.push(trajectory, List.copy(current_state))
        Set step to Mathematics.add(step, 1)
    
    Note: Skip initial transient behavior
    Let transient_skip be Mathematics.min(1000, Mathematics.divide(List.size(trajectory), 4))
    Let attractor_points be List.create()
    Let i be transient_skip
    While i < List.size(trajectory):
        List.push(attractor_points, List.get(trajectory, i))
        Set i to Mathematics.add(i, 1)
    
    Note: Compute Lyapunov exponents
    Let lyapunov_spectrum be compute_lyapunov_spectrum(lorenz_system, initial_state, integration_time, time_step)
    
    Note: Estimate fractal dimension using correlation dimension
    Let distance_scales be List.create()
    Let scale be 0.1
    While scale <= 10.0:
        List.push(distance_scales, scale)
        Set scale to Mathematics.multiply(scale, 1.2)
    
    Let fractal_dim be correlation_dimension(attractor_points, distance_scales)
    
    Note: Compute box-counting dimension
    Let box_sizes be List.create()
    Let box_size be 0.1
    While box_size <= 5.0:
        List.push(box_sizes, box_size)
        Set box_size to Mathematics.multiply(box_size, 1.5)
    
    Let box_dim be box_counting_dimension(attractor_points, box_sizes)
    
    Note: Compute Lyapunov dimension
    Let lyap_dim be lyapunov_dimension(lyapunov_spectrum)
    
    Note: Estimate basin of attraction through systematic grid sampling
    Let basin_points be List.create()
    Let test_x be -20.0
    While test_x <= 20.0:
        Let test_y be -20.0
        While test_y <= 20.0:
            Let test_z be -20.0
            While test_z <= 20.0:
                Let test_initial be [test_x, test_y, test_z]
                Let test_trajectory be integrate_system(lorenz_system, test_initial, 10.0, 0.1, parameters)
                Let final_point be List.get(test_trajectory, Mathematics.subtract(List.size(test_trajectory), 1))
                
                Note: Check if trajectory converges to attractor
                If point_near_attractor(final_point, attractor_points, 5.0):
                    List.push(basin_points, test_initial)
                
                Set test_z to Mathematics.add(test_z, 5.0)
            Set test_y to Mathematics.add(test_y, 5.0)
        Set test_x to Mathematics.add(test_x, 5.0)
    
    Note: Create symbolic dynamics using binary partition
    Let symbolic_sequence be List.create()
    Set i to 0
    While i < List.size(attractor_points):
        Let point be List.get(attractor_points, i)
        Let x be List.get(point, 0)
        
        If x < 0.0:
            List.push(symbolic_sequence, "L")
        Otherwise:
            List.push(symbolic_sequence, "R")
        Set i to Mathematics.add(i, 1)
    
    Note: Create and return StrangeAttractor structure
    Let strange_attractor be Dictionary.create()
    Dictionary.set(strange_attractor, "attractor_points", attractor_points)
    Dictionary.set(strange_attractor, "fractal_dimension", fractal_dim)
    Dictionary.set(strange_attractor, "box_counting_dimension", box_dim)
    Dictionary.set(strange_attractor, "correlation_dimension", fractal_dim)
    Dictionary.set(strange_attractor, "lyapunov_dimension", lyap_dim)
    Dictionary.set(strange_attractor, "basin_of_attraction", basin_points)
    Dictionary.set(strange_attractor, "homoclinic_tangles", List.create())  Note: Complex to compute
    Dictionary.set(strange_attractor, "invariant_measure", null)  Note: Requires advanced computation
    Dictionary.set(strange_attractor, "symbolic_dynamics", symbolic_sequence)
    
    Return strange_attractor

Process called "analyze_henon_attractor" that takes a as Float64, b as Float64, iterations as Integer returns StrangeAttractor:
    Note: Analyzes Hénon map attractor: x_{n+1} = 1-ax_n²+y_n, y_{n+1} = bx_n
    Note: Classic parameters a=1.4, b=0.3 produce strange attractor
    Note: Demonstrates chaos in two-dimensional discrete systems
    Note: Fractal dimension ≈ 1.26 and positive Lyapunov exponent ≈ 0.42
    
    If iterations <= 0:
        Throw Errors.InvalidArgument with "Iterations must be positive"
    If Mathematics.abs(b) >= 1.0:
        Throw Errors.InvalidArgument with "Parameter b should have |b| < 1 for bounded attractor"
    
    Note: Iterate the Hénon map
    Let attractor_points be List.create()
    Let x be 0.1
    Let y be 0.1
    
    Let i be 0
    While i < iterations:
        Note: Hénon map iteration
        Let x_new be Mathematics.add(Mathematics.subtract(1.0, Mathematics.multiply(a, Mathematics.multiply(x, x))), y)
        Let y_new be Mathematics.multiply(b, x)
        
        Set x to x_new
        Set y to y_new
        
        Note: Skip initial transient iterations
        If i >= 1000:
            List.push(attractor_points, [x, y])
        
        Set i to Mathematics.add(i, 1)
    
    Note: Compute Lyapunov exponent for discrete map
    Let sum_derivative be 0.0
    Let valid_iterations be 0
    
    Set x to 0.1
    Set y to 0.1
    Set i to 0
    While i < Mathematics.min(iterations, 50000):
        Note: Compute derivative of map at current point
        Let derivative_x be Mathematics.multiply(-2.0, Mathematics.multiply(a, x))
        
        If Mathematics.abs(derivative_x) > 1e-12:
            Set sum_derivative to Mathematics.add(sum_derivative, Mathematics.log(Mathematics.abs(derivative_x)))
            Set valid_iterations to Mathematics.add(valid_iterations, 1)
        
        Note: Iterate the map
        Let x_new be Mathematics.add(Mathematics.subtract(1.0, Mathematics.multiply(a, Mathematics.multiply(x, x))), y)
        Let y_new be Mathematics.multiply(b, x)
        Set x to x_new
        Set y to y_new
        Set i to Mathematics.add(i, 1)
    
    Let lyapunov_exponent be 0.0
    If valid_iterations > 0:
        Set lyapunov_exponent to Mathematics.divide(sum_derivative, valid_iterations)
    
    Note: Compute correlation dimension
    Let distance_scales be List.create()
    Let scale be 0.01
    While scale <= 1.0:
        List.push(distance_scales, scale)
        Set scale to Mathematics.multiply(scale, 1.3)
    
    Let correlation_dim be correlation_dimension(attractor_points, distance_scales)
    
    Note: Compute box-counting dimension  
    Let box_sizes be List.create()
    Let box_size be 0.01
    While box_size <= 0.5:
        List.push(box_sizes, box_size)
        Set box_size to Mathematics.multiply(box_size, 1.4)
    
    Let box_dim be box_counting_dimension(attractor_points, box_sizes)
    
    Note: Estimate basin of attraction for Hénon map
    Let basin_points be List.create()
    Let test_x be -2.0
    While test_x <= 2.0:
        Let test_y be -2.0
        While test_y <= 2.0:
            Let temp_x be test_x
            Let temp_y be test_y
            Let bounded be true
            
            Note: Test if orbit remains bounded
            Let test_iter be 0
            While test_iter < 1000 AND bounded:
                Let next_x be Mathematics.add(Mathematics.subtract(1.0, Mathematics.multiply(a, Mathematics.multiply(temp_x, temp_x))), temp_y)
                Let next_y be Mathematics.multiply(b, temp_x)
                
                If Mathematics.abs(next_x) > 10.0 OR Mathematics.abs(next_y) > 10.0:
                    Set bounded to false
                
                Set temp_x to next_x
                Set temp_y to next_y
                Set test_iter to Mathematics.add(test_iter, 1)
            
            If bounded:
                List.push(basin_points, [test_x, test_y])
            
            Set test_y to Mathematics.add(test_y, 0.2)
        Set test_x to Mathematics.add(test_x, 0.2)
    
    Note: Create symbolic dynamics based on position
    Let symbolic_sequence be List.create()
    Set i to 0
    While i < List.size(attractor_points):
        Let point be List.get(attractor_points, i)
        Let x_coord be List.get(point, 0)
        Let y_coord be List.get(point, 1)
        
        If x_coord > 0.0 AND y_coord > 0.0:
            List.push(symbolic_sequence, "A")
        Otherwise If x_coord <= 0.0 AND y_coord > 0.0:
            List.push(symbolic_sequence, "B")
        Otherwise If x_coord <= 0.0 AND y_coord <= 0.0:
            List.push(symbolic_sequence, "C")
        Otherwise:
            List.push(symbolic_sequence, "D")
        Set i to Mathematics.add(i, 1)
    
    Note: Create and return StrangeAttractor structure
    Let henon_attractor be Dictionary.create()
    Dictionary.set(henon_attractor, "attractor_points", attractor_points)
    Dictionary.set(henon_attractor, "fractal_dimension", correlation_dim)
    Dictionary.set(henon_attractor, "box_counting_dimension", box_dim)
    Dictionary.set(henon_attractor, "correlation_dimension", correlation_dim)
    Note: Compute proper Lyapunov dimension from spectrum
    Let lyapunov_spectrum be compute_lyapunov_spectrum_henon(a, b)
    Let lyapunov_dim be compute_lyapunov_dimension_from_spectrum(lyapunov_spectrum)
    Dictionary.set(henon_attractor, "lyapunov_dimension", lyapunov_dim)
    Dictionary.set(henon_attractor, "basin_of_attraction", basin_points)
    Dictionary.set(henon_attractor, "homoclinic_tangles", List.create())  Note: Complex computation
    Dictionary.set(henon_attractor, "invariant_measure", null)  Note: Requires advanced methods
    Dictionary.set(henon_attractor, "symbolic_dynamics", symbolic_sequence)
    
    Return henon_attractor

Process called "reconstruct_attractor" that takes time_series as List[Float64], embedding_dimension as Integer, time_delay as Integer returns List[List[Float64]]:
    Note: Reconstructs attractor from scalar time series using Takens embedding
    Note: Creates delay coordinates: [x(t), x(t+τ), x(t+2τ), ..., x(t+(m-1)τ)]
    Note: Preserves topological properties of original attractor
    Note: Essential for analyzing experimental chaotic data
    
    If List.size(time_series) = 0:
        Throw Errors.InvalidArgument with "Time series cannot be empty"
    If embedding_dimension <= 0:
        Throw Errors.InvalidArgument with "Embedding dimension must be positive"
    If time_delay <= 0:
        Throw Errors.InvalidArgument with "Time delay must be positive"
    
    Let series_length be List.size(time_series)
    Let max_delay be Mathematics.multiply(Mathematics.subtract(embedding_dimension, 1), time_delay)
    
    If series_length <= max_delay:
        Throw Errors.InvalidArgument with "Time series too short for given embedding parameters"
    
    Note: Calculate number of embedded vectors
    Let num_vectors be Mathematics.subtract(series_length, max_delay)
    Let embedded_vectors be List.create()
    
    Note: Create delay coordinate vectors
    Let i be 0
    While i < num_vectors:
        Let embedded_vector be List.create()
        
        Let j be 0
        While j < embedding_dimension:
            Let time_index be Mathematics.add(i, Mathematics.multiply(j, time_delay))
            Let value be List.get(time_series, time_index)
            List.push(embedded_vector, value)
            Set j to Mathematics.add(j, 1)
        
        List.push(embedded_vectors, embedded_vector)
        Set i to Mathematics.add(i, 1)
    
    Return embedded_vectors

Note: ===== Fractal Dimensions =====

Process called "box_counting_dimension" that takes attractor_points as List[List[Float64]], box_sizes as List[Float64] returns Float64:
    Note: Computes box-counting (Minkowski-Bouligand) dimension
    Note: Counts boxes of size ε needed to cover attractor: N(ε) ~ ε^(-D)
    Note: Dimension D from slope of log N(ε) vs log(1/ε)
    Note: Most common fractal dimension measure for strange attractors
    
    If List.size(attractor_points) = 0:
        Throw Errors.InvalidArgument with "Attractor points cannot be empty"
    If List.size(box_sizes) = 0:
        Throw Errors.InvalidArgument with "Box sizes cannot be empty"
    
    Note: Validate that all points have same dimension
    Let first_point be List.get(attractor_points, 0)
    Let point_dimension be List.size(first_point)
    If point_dimension = 0:
        Throw Errors.InvalidArgument with "Points must have positive dimension"
    
    Note: Find bounding box for all points
    Let min_coords be List.create()
    Let max_coords be List.create()
    Let d be 0
    While d < point_dimension:
        List.push(min_coords, List.get(first_point, d))
        List.push(max_coords, List.get(first_point, d))
        Set d to Mathematics.add(d, 1)
    
    Let i be 1
    While i < List.size(attractor_points):
        Let point be List.get(attractor_points, i)
        If List.size(point) != point_dimension:
            Throw Errors.InvalidArgument with "All points must have same dimension"
        
        Set d to 0
        While d < point_dimension:
            Let coord be List.get(point, d)
            If coord < List.get(min_coords, d):
                List.set(min_coords, d, coord)
            If coord > List.get(max_coords, d):
                List.set(max_coords, d, coord)
            Set d to Mathematics.add(d, 1)
        Set i to Mathematics.add(i, 1)
    
    Note: Count boxes needed for each box size
    Let box_counts be List.create()
    Let log_inverse_sizes be List.create()
    
    Let size_index be 0
    While size_index < List.size(box_sizes):
        Let box_size be List.get(box_sizes, size_index)
        
        If box_size <= 0.0:
            Throw Errors.InvalidArgument with "Box sizes must be positive"
        
        Note: Create hash set to track occupied boxes
        Let occupied_boxes be Dictionary.create()
        
        Note: For each point, determine which box it falls into
        Set i to 0
        While i < List.size(attractor_points):
            Let point be List.get(attractor_points, i)
            Let box_indices be List.create()
            
            Set d to 0
            While d < point_dimension:
                Let coord be List.get(point, d)
                Let min_coord be List.get(min_coords, d)
                Let normalized_coord be Mathematics.subtract(coord, min_coord)
                Let box_index be Mathematics.floor(Mathematics.divide(normalized_coord, box_size))
                List.push(box_indices, box_index)
                Set d to Mathematics.add(d, 1)
            
            Note: Create unique key for this box  
            Let box_key_parts be List.create()
            Set d to 0
            While d < List.size(box_indices):
                List.push(box_key_parts, Integer.to_string(List.get(box_indices, d)))
                Set d to Mathematics.add(d, 1)
            Let box_key be Collections.join_strings(box_key_parts, ",")
            Dictionary.set(occupied_boxes, box_key, true)
            Set i to Mathematics.add(i, 1)
        
        Let num_boxes be Dictionary.size(occupied_boxes)
        List.push(box_counts, num_boxes)
        List.push(log_inverse_sizes, Mathematics.log(Mathematics.divide(1.0, box_size)))
        Set size_index to Mathematics.add(size_index, 1)
    
    Note: Linear regression on log N(ε) vs log(1/ε) to find dimension
    If List.size(box_counts) < 2:
        Throw Errors.InvalidArgument with "Insufficient box sizes for dimension calculation"
    
    Let n be List.size(box_counts)
    Let sum_x be 0.0
    Let sum_y be 0.0
    Let sum_xy be 0.0
    Let sum_x2 be 0.0
    
    Set i to 0
    While i < n:
        Let x be List.get(log_inverse_sizes, i)
        Let y be Mathematics.log(List.get(box_counts, i))
        Set sum_x to Mathematics.add(sum_x, x)
        Set sum_y to Mathematics.add(sum_y, y)
        Set sum_xy to Mathematics.add(sum_xy, Mathematics.multiply(x, y))
        Set sum_x2 to Mathematics.add(sum_x2, Mathematics.multiply(x, x))
        Set i to Mathematics.add(i, 1)
    
    Let denominator be Mathematics.subtract(Mathematics.multiply(n, sum_x2), Mathematics.multiply(sum_x, sum_x))
    If Mathematics.abs(denominator) < 1e-12:
        Note: Degenerate regression case - use robust estimation for box-counting dimension
        Note: Apply Theil-Sen estimator on log-log data for fractal dimension
        Return compute_theil_sen_slope_log_log(log_inverse_sizes, box_counts)
    
    Let slope be Mathematics.divide(Mathematics.subtract(Mathematics.multiply(n, sum_xy), Mathematics.multiply(sum_x, sum_y)), denominator)
    
    Return slope

Process called "correlation_dimension" that takes attractor_points as List[List[Float64]], distance_scales as List[Float64] returns Float64:
    Note: Computes Grassberger-Procaccia correlation dimension
    Note: Uses correlation integral C(r) = lim(N→∞) Σᵢⱼ Θ(r-|xᵢ-xⱼ|)/N²
    Note: Dimension from scaling C(r) ~ r^D as r→0
    Note: Less sensitive to noise than box-counting dimension
    
    If List.size(attractor_points) = 0:
        Throw Errors.InvalidArgument with "Attractor points cannot be empty"
    If List.size(distance_scales) = 0:
        Throw Errors.InvalidArgument with "Distance scales cannot be empty"
    If List.size(attractor_points) < 2:
        Throw Errors.InvalidArgument with "Correlation dimension requires at least 2 points"
    
    Let num_points be List.size(attractor_points)
    Let correlation_integrals be List.create()
    Let log_distances be List.create()
    
    Note: For each distance scale, compute correlation integral
    Let scale_index be 0
    While scale_index < List.size(distance_scales):
        Let r be List.get(distance_scales, scale_index)
        
        If r <= 0.0:
            Throw Errors.InvalidArgument with "Distance scales must be positive"
        
        Note: Count pairs within distance r
        Let pair_count be 0
        Let i be 0
        While i < Mathematics.subtract(num_points, 1):
            Let point_i be List.get(attractor_points, i)
            
            Let j be Mathematics.add(i, 1)
            While j < num_points:
                Let point_j be List.get(attractor_points, j)
                Let distance be euclidean_distance(point_i, point_j)
                
                If distance <= r:
                    Set pair_count to Mathematics.add(pair_count, 1)
                Set j to Mathematics.add(j, 1)
            Set i to Mathematics.add(i, 1)
        
        Note: Normalize by total number of pairs
        Let total_pairs be Mathematics.divide(Mathematics.multiply(num_points, Mathematics.subtract(num_points, 1)), 2)
        Let correlation_integral be Mathematics.divide(pair_count, total_pairs)
        
        Note: Avoid log(0) by setting minimum value
        If correlation_integral < 1e-12:
            Set correlation_integral to 1e-12
        
        List.push(correlation_integrals, correlation_integral)
        List.push(log_distances, Mathematics.log(r))
        Set scale_index to Mathematics.add(scale_index, 1)
    
    Note: Linear regression on log C(r) vs log r to find dimension
    If List.size(correlation_integrals) < 2:
        Throw Errors.InvalidArgument with "Insufficient distance scales for correlation dimension regression"
    
    Let n be List.size(correlation_integrals)
    Let sum_x be 0.0
    Let sum_y be 0.0
    Let sum_xy be 0.0
    Let sum_x2 be 0.0
    
    Let i be 0
    While i < n:
        Let x be List.get(log_distances, i)
        Let y be Mathematics.log(List.get(correlation_integrals, i))
        Set sum_x to Mathematics.add(sum_x, x)
        Set sum_y to Mathematics.add(sum_y, y)
        Set sum_xy to Mathematics.add(sum_xy, Mathematics.multiply(x, y))
        Set sum_x2 to Mathematics.add(sum_x2, Mathematics.multiply(x, x))
        Set i to Mathematics.add(i, 1)
    
    Let denominator be Mathematics.subtract(Mathematics.multiply(n, sum_x2), Mathematics.multiply(sum_x, sum_x))
    If Mathematics.abs(denominator) < 1e-12:
        Return compute_theil_sen_slope_log_correlation(log_distances, correlation_integrals)
    
    Let slope be Mathematics.divide(Mathematics.subtract(Mathematics.multiply(n, sum_xy), Mathematics.multiply(sum_x, sum_y)), denominator)
    
    Return slope

Process called "information_dimension" that takes probability_distribution as List[Float64], box_sizes as List[Float64] returns Float64:
    Note: Computes information dimension using Shannon entropy
    Note: D₁ = lim(ε→0) Σᵢ pᵢ(ε)log pᵢ(ε) / log ε
    Note: Measures dimension weighted by natural measure on attractor
    Note: Satisfies inequality D₁ ≤ D₀ (box-counting dimension)
    
    If List.size(probability_distribution) = 0:
        Throw Errors.InvalidArgument with "Probability distribution cannot be empty"
    If List.size(box_sizes) = 0:
        Throw Errors.InvalidArgument with "Box sizes cannot be empty"
    
    Note: Validate probability distribution
    Let total_probability be 0.0
    Let i be 0
    While i < List.size(probability_distribution):
        Let prob be List.get(probability_distribution, i)
        If prob < 0.0:
            Throw Errors.InvalidArgument with "Probabilities must be non-negative"
        Set total_probability to Mathematics.add(total_probability, prob)
        Set i to Mathematics.add(i, 1)
    
    If Mathematics.abs(Mathematics.subtract(total_probability, 1.0)) > 1e-6:
        Throw Errors.InvalidArgument with "Probability distribution must sum to 1.0"
    
    Note: Compute information dimension for different box sizes
    Let entropies be List.create()
    Let log_box_sizes be List.create()
    
    Let size_index be 0
    While size_index < List.size(box_sizes):
        Let box_size be List.get(box_sizes, size_index)
        
        If box_size <= 0.0:
            Throw Errors.InvalidArgument with "Box sizes must be positive"
        
        Note: Compute Shannon entropy for this scale
        Let shannon_entropy be 0.0
        Set i to 0
        While i < List.size(probability_distribution):
            Let prob be List.get(probability_distribution, i)
            
            Note: Only include non-zero probabilities in entropy calculation
            If prob > 1e-12:
                Set shannon_entropy to Mathematics.subtract(shannon_entropy, Mathematics.multiply(prob, Mathematics.log(prob)))
            Set i to Mathematics.add(i, 1)
        
        List.push(entropies, shannon_entropy)
        List.push(log_box_sizes, Mathematics.log(box_size))
        Set size_index to Mathematics.add(size_index, 1)
    
    Note: Linear regression on entropy vs log(ε) to find information dimension
    If List.size(entropies) < 2:
        Throw Errors.InvalidArgument with "Information dimension requires at least 2 entropy measurements"
    
    Let n be List.size(entropies)
    Let sum_x be 0.0
    Let sum_y be 0.0
    Let sum_xy be 0.0
    Let sum_x2 be 0.0
    
    Set i to 0
    While i < n:
        Let x be List.get(log_box_sizes, i)
        Let y be List.get(entropies, i)
        Set sum_x to Mathematics.add(sum_x, x)
        Set sum_y to Mathematics.add(sum_y, y)
        Set sum_xy to Mathematics.add(sum_xy, Mathematics.multiply(x, y))
        Set sum_x2 to Mathematics.add(sum_x2, Mathematics.multiply(x, x))
        Set i to Mathematics.add(i, 1)
    
    Let denominator be Mathematics.subtract(Mathematics.multiply(n, sum_x2), Mathematics.multiply(sum_x, sum_x))
    If Mathematics.abs(denominator) < 1e-12:
        Return compute_theil_sen_slope_entropy(log_box_sizes, entropies)
    
    Note: Information dimension is negative of the slope
    Let slope be Mathematics.divide(Mathematics.subtract(Mathematics.multiply(n, sum_xy), Mathematics.multiply(sum_x, sum_y)), denominator)
    Let information_dimension be Mathematics.multiply(-1.0, slope)
    
    Return information_dimension

Note: ===== Chaos Detection =====

Process called "detect_chaos_in_timeseries" that takes time_series as List[Float64], analysis_parameters as Dictionary[String, Float64] returns Boolean:
    Note: Detects presence of chaos in experimental time series data
    Note: Uses multiple indicators: positive Lyapunov exponent, correlation dimension
    Note: Applies 0-1 test for chaos and recurrence quantification analysis
    Note: Distinguishes deterministic chaos from stochastic noise
    
    If List.size(time_series) < 100:
        Throw Errors.InvalidArgument with "Time series too short for reliable chaos detection"
    
    Let embedding_dim be Dictionary.get_or_default(analysis_parameters, "embedding_dimension", 3)
    Let time_delay be Dictionary.get_or_default(analysis_parameters, "time_delay", 1)
    Let test_frequency be Dictionary.get_or_default(analysis_parameters, "test_frequency", 1.0)
    
    Note: Test 1: Largest Lyapunov exponent
    Let trajectory_2d be List.create()
    Let i be 0
    While i < List.size(time_series):
        List.push(trajectory_2d, [List.get(time_series, i)])
        Set i to Mathematics.add(i, 1)
    
    Let lyapunov_exp be largest_lyapunov_exponent(trajectory_2d, embedding_dim, time_delay)
    Let lyapunov_positive be lyapunov_exp > 0.001
    
    Note: Test 2: 0-1 test for chaos
    Let k_value be zero_one_test_for_chaos(time_series, test_frequency)
    Let zero_one_positive be k_value > 0.5
    
    Note: Test 3: Surrogate data test
    Let surrogate_stat be surrogate_data_test(time_series, 10)
    Let surrogate_positive be surrogate_stat > 0.05
    
    Note: Combine tests - require at least 2 positive indicators
    Let positive_tests be 0
    If lyapunov_positive:
        Set positive_tests to Mathematics.add(positive_tests, 1)
    If zero_one_positive:
        Set positive_tests to Mathematics.add(positive_tests, 1)
    If surrogate_positive:
        Set positive_tests to Mathematics.add(positive_tests, 1)
    
    Return positive_tests >= 2

Process called "zero_one_test_for_chaos" that takes time_series as List[Float64], test_frequency as Float64 returns Float64:
    Note: Applies Gottwald-Melbourne 0-1 test for chaos detection
    Note: Computes asymptotic growth rate K: K≈0 for regular, K≈1 for chaotic
    Note: Model-free test requiring no phase space reconstruction
    Note: Robust against noise and works for any chaotic system
    
    If List.size(time_series) < 10:
        Throw Errors.InvalidArgument with "Time series too short for 0-1 test"
    If test_frequency <= 0.0:
        Throw Errors.InvalidArgument with "Test frequency must be positive"
    
    Let n be List.size(time_series)
    Let c be test_frequency
    
    Note: Compute translation variables
    Let p_values be List.create()
    Let q_values be List.create()
    List.push(p_values, 0.0)
    List.push(q_values, 0.0)
    
    Let i be 1
    While i < n:
        Let phi be List.get(time_series, i)
        Let prev_p be List.get(p_values, Mathematics.subtract(i, 1))
        Let prev_q be List.get(q_values, Mathematics.subtract(i, 1))
        
        Let new_p be Mathematics.add(prev_p, Mathematics.multiply(phi, Mathematics.cos(Mathematics.multiply(c, i))))
        Let new_q be Mathematics.add(prev_q, Mathematics.multiply(phi, Mathematics.sin(Mathematics.multiply(c, i))))
        
        List.push(p_values, new_p)
        List.push(q_values, new_q)
        Set i to Mathematics.add(i, 1)
    
    Note: Compute mean square displacement
    Let sum_squared_displacement be 0.0
    Let valid_points be 0
    
    Set i to 1
    While i < n:
        Let p be List.get(p_values, i)
        Let q be List.get(q_values, i)
        Let displacement_squared be Mathematics.add(Mathematics.multiply(p, p), Mathematics.multiply(q, q))
        Set sum_squared_displacement to Mathematics.add(sum_squared_displacement, displacement_squared)
        Set valid_points to Mathematics.add(valid_points, 1)
        Set i to Mathematics.add(i, 1)
    
    If valid_points = 0:
        Throw Errors.InvalidArgument with "No valid trajectory points for diffusion entropy analysis"
    
    Let mean_square_displacement be Mathematics.divide(sum_squared_displacement, valid_points)
    
    Note: Compute asymptotic growth rate K
    Let variance_sum be 0.0
    Set i to 1
    While i < n:
        Let p be List.get(p_values, i)
        Let q be List.get(q_values, i)
        Let displacement_squared be Mathematics.add(Mathematics.multiply(p, p), Mathematics.multiply(q, q))
        Let deviation be Mathematics.subtract(displacement_squared, mean_square_displacement)
        Set variance_sum to Mathematics.add(variance_sum, Mathematics.multiply(deviation, deviation))
        Set i to Mathematics.add(i, 1)
    
    Let variance be Mathematics.divide(variance_sum, Mathematics.subtract(n, 1))
    Let k_value be Mathematics.divide(variance, Mathematics.multiply(mean_square_displacement, mean_square_displacement))
    
    Note: Bound K between 0 and 1
    If k_value < 0.0:
        Set k_value to 0.0
    If k_value > 1.0:
        Set k_value to 1.0
    
    Return k_value

Process called "surrogate_data_test" that takes original_series as List[Float64], num_surrogates as Integer returns Float64:
    Note: Tests chaos hypothesis using surrogate data analysis
    Note: Generates linear surrogates preserving spectrum but destroying nonlinearity
    Note: Compares nonlinear statistics between original and surrogate data
    Note: Significant difference indicates genuine nonlinear dynamics
    
    If List.size(original_series) < 50:
        Throw Errors.InvalidArgument with "Time series too short for surrogate test"
    If num_surrogates <= 0:
        Throw Errors.InvalidArgument with "Number of surrogates must be positive"
    
    Note: Compute test statistic for original data (nonlinear correlation)
    Let original_statistic be compute_nonlinear_statistic(original_series)
    
    Note: Generate surrogate datasets and compute test statistics
    Let surrogate_statistics be List.create()
    Let surrogate_index be 0
    While surrogate_index < num_surrogates:
        Let surrogate_series be generate_surrogate(original_series)
        Let surrogate_statistic be compute_nonlinear_statistic(surrogate_series)
        List.push(surrogate_statistics, surrogate_statistic)
        Set surrogate_index to Mathematics.add(surrogate_index, 1)
    
    Note: Count how many surrogates have higher test statistic
    Let higher_count be 0
    Set surrogate_index to 0
    While surrogate_index < num_surrogates:
        Let surrogate_stat be List.get(surrogate_statistics, surrogate_index)
        If surrogate_stat > original_statistic:
            Set higher_count to Mathematics.add(higher_count, 1)
        Set surrogate_index to Mathematics.add(surrogate_index, 1)
    
    Note: Compute p-value (significance level)
    Let p_value be Mathematics.divide(higher_count, num_surrogates)
    
    Return p_value

Note: ===== Poincaré Sections and Return Maps =====

Process called "compute_poincare_section" that takes trajectory as List[List[Float64]], section_plane as Function returns List[List[Float64]]:
    Note: Computes Poincaré section by intersecting trajectory with hyperplane
    Note: Reduces continuous flow to discrete map on section surface
    Note: Reveals hidden structure and periodic orbits in chaotic flow
    Note: Essential tool for analyzing three-dimensional chaotic systems
    
    If List.size(trajectory) < 2:
        Throw Errors.InvalidArgument with "Trajectory must have at least 2 points"
    
    Let section_points be List.create()
    Let i be 1
    While i < List.size(trajectory):
        Let prev_point be List.get(trajectory, Mathematics.subtract(i, 1))
        Let curr_point be List.get(trajectory, i)
        
        Let prev_value be section_plane(prev_point)
        Let curr_value be section_plane(curr_point)
        
        Note: Check for sign change (hyperplane crossing)
        If Mathematics.multiply(prev_value, curr_value) < 0.0:
            Note: Linear interpolation to find intersection point
            Let t be Mathematics.divide(Mathematics.abs(prev_value), Mathematics.add(Mathematics.abs(prev_value), Mathematics.abs(curr_value)))
            Let intersection_point be List.create()
            
            Let j be 0
            While j < List.size(prev_point):
                Let interpolated_coord be Mathematics.add(List.get(prev_point, j), Mathematics.multiply(t, Mathematics.subtract(List.get(curr_point, j), List.get(prev_point, j))))
                List.push(intersection_point, interpolated_coord)
                Set j to Mathematics.add(j, 1)
            
            List.push(section_points, intersection_point)
        Set i to Mathematics.add(i, 1)
    
    Return section_points

Process called "analyze_return_map" that takes poincare_points as List[List[Float64]], coordinate_index as Integer returns Function:
    Note: Constructs return map from Poincaré section coordinates
    Note: Maps x_n to x_{n+1} revealing discrete dynamics structure
    Note: Identifies fixed points, periodic orbits, and chaotic regions
    Note: Enables application of discrete dynamical systems theory
    
    If List.size(poincare_points) < 2:
        Throw Errors.InvalidArgument with "Need at least 2 Poincaré points"
    If coordinate_index < 0:
        Throw Errors.InvalidArgument with "Coordinate index must be non-negative"
    
    Let first_point be List.get(poincare_points, 0)
    If coordinate_index >= List.size(first_point):
        Throw Errors.InvalidArgument with "Coordinate index out of bounds"
    
    Note: Extract coordinate pairs (x_n, x_{n+1})
    Let return_map_data be List.create()
    Let i be 0
    While i < Mathematics.subtract(List.size(poincare_points), 1):
        Let x_n be List.get(List.get(poincare_points, i), coordinate_index)
        Let x_n_plus_1 be List.get(List.get(poincare_points, Mathematics.add(i, 1)), coordinate_index)
        List.push(return_map_data, [x_n, x_n_plus_1])
        Set i to Mathematics.add(i, 1)
    
    Note: Create return map function using piecewise linear interpolation
    Let return_map_function be Function(x):
        Let min_distance be 1e10
        Let closest_value be 0.0
        
        Let j be 0
        While j < List.size(return_map_data):
            Let pair be List.get(return_map_data, j)
            Let distance be Mathematics.abs(Mathematics.subtract(x, List.get(pair, 0)))
            If distance < min_distance:
                Set min_distance to distance
                Set closest_value to List.get(pair, 1)
            Set j to Mathematics.add(j, 1)
        
        Return closest_value
    
    Return return_map_function

Process called "find_unstable_periodic_orbits" that takes return_map as Function, search_region as Tuple[Float64, Float64], max_period as Integer returns List[List[Float64]]:
    Note: Locates unstable periodic orbits (UPOs) in chaotic systems
    Note: Uses Newton-Raphson iteration and variational methods
    Note: UPOs form skeleton of chaotic attractor structure
    Note: Essential for semiclassical quantization and chaos control
    
    If max_period <= 0:
        Throw Errors.InvalidArgument with "Maximum period must be positive"
    
    Let upos be List.create()
    Let search_min be List.get(search_region, 0)
    Let search_max be List.get(search_region, 1)
    
    If search_min >= search_max:
        Throw Errors.InvalidArgument with "Invalid search region"
    
    Note: Search for fixed points of f^n(x) = x for periods 1 to max_period
    Let period be 1
    While period <= max_period:
        Let num_candidates be Mathematics.multiply(10, period)
        Let step_size be Mathematics.divide(Mathematics.subtract(search_max, search_min), num_candidates)
        
        Let candidate be search_min
        While candidate <= search_max:
            Note: Newton-Raphson iteration to find periodic point
            Let x be candidate
            Let converged be false
            Let iteration be 0
            
            While iteration < 50 AND NOT converged:
                Note: Compute f^period(x) - x
                Let fx be x
                Let p be 0
                While p < period:
                    Set fx to return_map(fx)
                    Set p to Mathematics.add(p, 1)
                
                Let residual be Mathematics.subtract(fx, x)
                
                If Mathematics.abs(residual) < 1e-10:
                    Set converged to true
                    Let orbit be List.create()
                    Let orbit_point be x
                    Set p to 0
                    While p < period:
                        List.push(orbit, orbit_point)
                        Set orbit_point to return_map(orbit_point)
                        Set p to Mathematics.add(p, 1)
                    List.push(upos, orbit)
                Otherwise:
                    Note: Simple finite difference for derivative
                    Let epsilon be 1e-8
                    Let fx_plus be x
                    Set p to 0
                    While p < period:
                        Set fx_plus to return_map(Mathematics.add(fx_plus, epsilon))
                        Set p to Mathematics.add(p, 1)
                    
                    Let derivative be Mathematics.divide(Mathematics.subtract(fx_plus, fx), epsilon)
                    If Mathematics.abs(derivative) > 1e-12:
                        Set x to Mathematics.subtract(x, Mathematics.divide(residual, derivative))
                
                Set iteration to Mathematics.add(iteration, 1)
            
            Set candidate to Mathematics.add(candidate, step_size)
        Set period to Mathematics.add(period, 1)
    
    Return upos

Note: ===== Symbolic Dynamics =====

Process called "symbolic_dynamics_encoding" that takes trajectory as List[List[Float64]], partition_boundaries as List[Float64] returns List[String]:
    Note: Encodes trajectory as symbolic sequence using partition
    Note: Maps continuous dynamics to discrete symbol space
    Note: Enables topological analysis and entropy computation
    Note: Foundation for understanding chaotic dynamics structure
    
    If List.size(trajectory) = 0:
        Throw Errors.InvalidArgument with "Trajectory cannot be empty"
    If List.size(partition_boundaries) = 0:
        Throw Errors.InvalidArgument with "Partition boundaries cannot be empty"
    
    Note: Sort partition boundaries
    Let sorted_boundaries be List.copy(partition_boundaries)
    Let n be List.size(sorted_boundaries)
    Let i be 0
    While i < Mathematics.subtract(n, 1):
        Let j be 0
        While j < Mathematics.subtract(n, i, 1):
            If List.get(sorted_boundaries, j) > List.get(sorted_boundaries, Mathematics.add(j, 1)):
                Let temp be List.get(sorted_boundaries, j)
                List.set(sorted_boundaries, j, List.get(sorted_boundaries, Mathematics.add(j, 1)))
                List.set(sorted_boundaries, Mathematics.add(j, 1), temp)
            Set j to Mathematics.add(j, 1)
        Set i to Mathematics.add(i, 1)
    
    Let symbolic_sequence be List.create()
    Set i to 0
    While i < List.size(trajectory):
        Let point be List.get(trajectory, i)
        Let coordinate be List.get(point, 0)  Note: Use first coordinate for partitioning
        
        Note: Find which partition region the point belongs to
        Let region_index be 0
        Let j be 0
        While j < List.size(sorted_boundaries):
            If coordinate >= List.get(sorted_boundaries, j):
                Set region_index to Mathematics.add(region_index, 1)
            Set j to Mathematics.add(j, 1)
        
        Note: Convert region index to symbol
        Let symbol be String.concatenate("S", Integer.to_string(region_index))
        List.push(symbolic_sequence, symbol)
        Set i to Mathematics.add(i, 1)
    
    Return symbolic_sequence

Process called "compute_topological_entropy" that takes symbolic_sequence as List[String], block_length as Integer returns Float64:
    Note: Computes topological entropy from symbolic dynamics
    Note: h = lim(n→∞) (1/n)log N(n) where N(n) is number of n-blocks
    Note: Measures exponential growth rate of distinct orbit segments
    Note: Positive entropy indicates chaotic behavior
    
    If List.size(symbolic_sequence) = 0:
        Throw Errors.InvalidArgument with "Symbolic sequence cannot be empty"
    If block_length <= 0:
        Throw Errors.InvalidArgument with "Block length must be positive"
    If block_length >= List.size(symbolic_sequence):
        Throw Errors.InvalidArgument with "Block length too large for sequence"
    
    Note: Count distinct blocks of given length
    Let distinct_blocks be Dictionary.create()
    Let i be 0
    While i <= Mathematics.subtract(List.size(symbolic_sequence), block_length):
        Note: Extract block of symbols
        Let block_symbols be List.create()
        Let j be 0
        While j < block_length:
            List.push(block_symbols, List.get(symbolic_sequence, Mathematics.add(i, j)))
            Set j to Mathematics.add(j, 1)
        
        Let block_key be Collections.join_strings(block_symbols, "")
        Dictionary.set(distinct_blocks, block_key, true)
        Set i to Mathematics.add(i, 1)
    
    Let num_distinct_blocks be Dictionary.size(distinct_blocks)
    If num_distinct_blocks <= 1:
        Throw Errors.InvalidArgument with "Block entropy requires multiple distinct symbol blocks"
    
    Let entropy be Mathematics.divide(Mathematics.log(num_distinct_blocks), block_length)
    Return entropy

Process called "analyze_forbidden_sequences" that takes symbolic_sequence as List[String] returns List[String]:
    Note: Identifies forbidden symbol sequences in chaotic dynamics
    Note: Reflects geometric constraints from attractor structure
    Note: Creates grammar rules for generating allowable sequences
    Note: Important for understanding symbolic dynamics complexity
    
    If List.size(symbolic_sequence) < 3:
        Throw Errors.InvalidArgument with "Sequence too short for forbidden sequence analysis"
    
    Note: Find unique symbols in sequence
    Let unique_symbols be Dictionary.create()
    Let i be 0
    While i < List.size(symbolic_sequence):
        Dictionary.set(unique_symbols, List.get(symbolic_sequence, i), true)
        Set i to Mathematics.add(i, 1)
    
    Let symbol_list be Dictionary.get_keys(unique_symbols)
    Let num_symbols be List.size(symbol_list)
    
    Note: Generate all possible 2-symbol and 3-symbol combinations
    Let all_possible_2blocks be List.create()
    Let all_possible_3blocks be List.create()
    
    Set i to 0
    While i < num_symbols:
        Let j be 0
        While j < num_symbols:
            Let block2 be String.concatenate(List.get(symbol_list, i), List.get(symbol_list, j))
            List.push(all_possible_2blocks, block2)
            
            Let k be 0
            While k < num_symbols:
                Let block3 be String.concatenate(block2, List.get(symbol_list, k))
                List.push(all_possible_3blocks, block3)
                Set k to Mathematics.add(k, 1)
            Set j to Mathematics.add(j, 1)
        Set i to Mathematics.add(i, 1)
    
    Note: Find which blocks actually appear in the sequence
    Let observed_2blocks be Dictionary.create()
    Let observed_3blocks be Dictionary.create()
    
    Set i to 0
    While i < Mathematics.subtract(List.size(symbolic_sequence), 1):
        Let block2 be String.concatenate(List.get(symbolic_sequence, i), List.get(symbolic_sequence, Mathematics.add(i, 1)))
        Dictionary.set(observed_2blocks, block2, true)
        
        If i < Mathematics.subtract(List.size(symbolic_sequence), 2):
            Let block3 be String.concatenate(block2, List.get(symbolic_sequence, Mathematics.add(i, 2)))
            Dictionary.set(observed_3blocks, block3, true)
        Set i to Mathematics.add(i, 1)
    
    Note: Find forbidden sequences (possible but not observed)
    Let forbidden_sequences be List.create()
    
    Set i to 0
    While i < List.size(all_possible_2blocks):
        Let block be List.get(all_possible_2blocks, i)
        If NOT Dictionary.has_key(observed_2blocks, block):
            List.push(forbidden_sequences, block)
        Set i to Mathematics.add(i, 1)
    
    Set i to 0
    While i < List.size(all_possible_3blocks):
        Let block be List.get(all_possible_3blocks, i)
        If NOT Dictionary.has_key(observed_3blocks, block):
            List.push(forbidden_sequences, block)
        Set i to Mathematics.add(i, 1)
    
    Return forbidden_sequences

Note: ===== Route to Chaos =====

Process called "analyze_period_doubling_route" that takes map_function as Function, parameter_range as Tuple[Float64, Float64] returns Dictionary[String, List[Float64]]:
    Note: Analyzes period-doubling cascade route to chaos
    Note: Follows bifurcation sequence: 1 → 2 → 4 → 8 → ... → chaos
    Note: Computes universal Feigenbaum ratios and scaling laws
    Note: Classic route discovered in logistic map
    
    Let param_min be List.get(parameter_range, 0)
    Let param_max be List.get(parameter_range, 1)
    
    If param_min >= param_max:
        Throw Errors.InvalidArgument with "Invalid parameter range"
    
    Let bifurcation_points be List.create()
    Let period_values be List.create()
    Let feigenbaum_ratios be List.create()
    
    Note: Scan parameter range to detect period-doubling bifurcations
    Let num_params be 1000
    Let param_step be Mathematics.divide(Mathematics.subtract(param_max, param_min), num_params)
    
    Let param be param_min
    While param <= param_max:
        Note: Iterate map to find attractor period
        Let x be 0.5  Note: Standard initial condition
        Let transient_iterations be 1000
        
        Note: Skip transients
        Let i be 0
        While i < transient_iterations:
            Set x to map_function(x, param)
            Set i to Mathematics.add(i, 1)
        
        Note: Collect orbit points to detect period
        Let orbit_points be List.create()
        Let period_test_iterations be 100
        Set i to 0
        While i < period_test_iterations:
            Set x to map_function(x, param)
            List.push(orbit_points, x)
            Set i to Mathematics.add(i, 1)
        
        Note: Detect period by finding repetitions
        Let detected_period be detect_period(orbit_points)
        
        Note: Check for period-doubling transition
        If List.size(period_values) > 0:
            Let prev_period be List.get(period_values, Mathematics.subtract(List.size(period_values), 1))
            If detected_period = Mathematics.multiply(prev_period, 2):
                List.push(bifurcation_points, param)
                List.push(period_values, detected_period)
                
                Note: Compute Feigenbaum ratio if we have enough points
                If List.size(bifurcation_points) >= 3:
                    Let r_n be List.get(bifurcation_points, Mathematics.subtract(List.size(bifurcation_points), 1))
                    Let r_n_minus_1 be List.get(bifurcation_points, Mathematics.subtract(List.size(bifurcation_points), 2))
                    Let r_n_minus_2 be List.get(bifurcation_points, Mathematics.subtract(List.size(bifurcation_points), 3))
                    
                    Let ratio be Mathematics.divide(Mathematics.subtract(r_n_minus_1, r_n_minus_2), Mathematics.subtract(r_n, r_n_minus_1))
                    List.push(feigenbaum_ratios, ratio)
        Otherwise:
            If detected_period = 1:
                List.push(period_values, detected_period)
        
        Set param to Mathematics.add(param, param_step)
    
    Let result be Dictionary.create()
    Dictionary.set(result, "bifurcation_points", bifurcation_points)
    Dictionary.set(result, "periods", period_values)
    Dictionary.set(result, "feigenbaum_ratios", feigenbaum_ratios)
    
    Return result

Process called "analyze_intermittency_route" that takes map_function as Function, parameter_value as Float64 returns Dictionary[String, Float64]:
    Note: Analyzes intermittency route to chaos via saddle-node bifurcation
    Note: Characterizes laminar phases interrupted by chaotic bursts
    Note: Studies Type-I, Type-II, and Type-III intermittency
    Note: Measures average laminar length scaling near onset
    
    Let total_iterations be 10000
    Let x be 0.5
    Let laminar_lengths be List.create()
    Let current_laminar_length be 0
    Let burst_threshold be 0.1  Note: Threshold to detect bursts
    
    Note: Iterate map and detect laminar/burst phases
    Let i be 0
    While i < total_iterations:
        Let prev_x be x
        Set x to map_function(x, parameter_value)
        
        Note: Check if we're in a burst (large change)
        Let change_magnitude be Mathematics.abs(Mathematics.subtract(x, prev_x))
        
        If change_magnitude > burst_threshold:
            Note: Burst detected, record laminar length if > 0
            If current_laminar_length > 0:
                List.push(laminar_lengths, current_laminar_length)
                Set current_laminar_length to 0
        Otherwise:
            Note: Still in laminar phase
            Set current_laminar_length to Mathematics.add(current_laminar_length, 1)
        
        Set i to Mathematics.add(i, 1)
    
    Note: Compute statistics
    If List.size(laminar_lengths) = 0:
        Let result be Dictionary.create()
        Dictionary.set(result, "average_laminar_length", 0.0)
        Dictionary.set(result, "intermittency_type", 0.0)
        Dictionary.set(result, "scaling_exponent", 0.0)
        Return result
    
    Let sum_lengths be 0.0
    Set i to 0
    While i < List.size(laminar_lengths):
        Set sum_lengths to Mathematics.add(sum_lengths, List.get(laminar_lengths, i))
        Set i to Mathematics.add(i, 1)
    
    Let average_laminar_length be Mathematics.divide(sum_lengths, List.size(laminar_lengths))
    
    Note: Determine intermittency type based on laminar length distribution
    Let intermittency_type be 1.0
    Let scaling_exponent be -0.5
    
    Note: Analyze distribution of laminar lengths to classify intermittency type
    If List.size(laminar_lengths) > 10:
        Note: Fit power law P(τ) ~ τ^(-γ) to laminar length distribution
        Let log_lengths be List.create()
        Let log_probs be List.create()
        
        For length_idx from 0 to List.size(laminar_lengths) - 1:
            Let length_val be List.get(laminar_lengths, length_idx)
            If length_val > 0.0:
                Collections.append(log_lengths, Mathematics.log(length_val))
        
        Note: Count frequency of each length for probability estimation
        Let unique_lengths be List.create()
        Let length_counts be List.create()
        
        For length_idx from 0 to List.size(laminar_lengths) - 1:
            Let length_val be List.get(laminar_lengths, length_idx)
            Let found be false
            Let unique_idx be 0
            While unique_idx < List.size(unique_lengths) AND not found:
                If Mathematics.abs(Mathematics.subtract(List.get(unique_lengths, unique_idx), length_val)) < 0.01:
                    Set found to true
                    Let current_count be List.get(length_counts, unique_idx)
                    List.set(length_counts, unique_idx, Mathematics.add(current_count, 1))
                Set unique_idx to Mathematics.add(unique_idx, 1)
            
            If not found:
                Collections.append(unique_lengths, length_val)
                Collections.append(length_counts, 1)
        
        Note: Compute scaling exponent from power law fit
        Let sum_log_x be 0.0
        Let sum_log_y be 0.0  
        Let sum_log_xy be 0.0
        Let sum_log_x2 be 0.0
        Let valid_points be 0
        
        For idx from 0 to List.size(unique_lengths) - 1:
            Let length_val be List.get(unique_lengths, idx)
            Let count_val be List.get(length_counts, idx)
            If length_val > 0.0 AND count_val > 0:
                Let log_length be Mathematics.log(length_val)
                Let log_prob be Mathematics.log(Mathematics.divide(count_val, List.size(laminar_lengths)))
                Set sum_log_x to Mathematics.add(sum_log_x, log_length)
                Set sum_log_y to Mathematics.add(sum_log_y, log_prob)
                Set sum_log_xy to Mathematics.add(sum_log_xy, Mathematics.multiply(log_length, log_prob))
                Set sum_log_x2 to Mathematics.add(sum_log_x2, Mathematics.multiply(log_length, log_length))
                Set valid_points to Mathematics.add(valid_points, 1)
        
        If valid_points > 2:
            Let denominator be Mathematics.subtract(Mathematics.multiply(valid_points, sum_log_x2), Mathematics.multiply(sum_log_x, sum_log_x))
            If Mathematics.abs(denominator) > 1e-12:
                Let slope be Mathematics.divide(Mathematics.subtract(Mathematics.multiply(valid_points, sum_log_xy), Mathematics.multiply(sum_log_x, sum_log_y)), denominator)
                Set scaling_exponent to Mathematics.negate(slope)
                
                Note: Classify intermittency type based on scaling exponent
                If Mathematics.abs(Mathematics.add(scaling_exponent, 0.5)) < 0.1:
                    Set intermittency_type to 1.0  Note: Type-I: γ ≈ 0.5
                Otherwise if Mathematics.abs(Mathematics.add(scaling_exponent, 1.0)) < 0.1:
                    Set intermittency_type to 2.0  Note: Type-II: γ ≈ 1.0  
                Otherwise if Mathematics.abs(Mathematics.add(scaling_exponent, 1.5)) < 0.1:
                    Set intermittency_type to 3.0  Note: Type-III: γ ≈ 1.5
    
    Let result be Dictionary.create()
    Dictionary.set(result, "average_laminar_length", average_laminar_length)
    Dictionary.set(result, "intermittency_type", intermittency_type)
    Dictionary.set(result, "scaling_exponent", scaling_exponent)
    Dictionary.set(result, "num_bursts", List.size(laminar_lengths))
    
    Return result

Process called "analyze_quasiperiodic_route" that takes flow_function as Function, forcing_frequencies as List[Float64] returns Dictionary[String, Float64]:
    Note: Analyzes quasiperiodic route to chaos via torus destruction
    Note: Studies breakdown of invariant tori in driven systems
    Note: Analyzes frequency locking and mode interactions
    Note: Relevant for driven oscillators and Josephson junctions
    
    If List.size(forcing_frequencies) = 0:
        Throw Errors.InvalidArgument with "Forcing frequencies cannot be empty"
    
    Let time_step be 0.01
    Let integration_time be 100.0
    Let num_steps be Mathematics.floor(Mathematics.divide(integration_time, time_step))
    
    Note: Integrate driven system
    Let trajectory be List.create()
    Let state be [1.0, 0.0]  Note: Initial condition
    Let t be 0.0
    
    Let i be 0
    While i < num_steps:
        Note: Add forcing terms to flow function
        Let forcing_sum be 0.0
        Let freq_index be 0
        While freq_index < List.size(forcing_frequencies):
            Let freq be List.get(forcing_frequencies, freq_index)
            Set forcing_sum to Mathematics.add(forcing_sum, Mathematics.sin(Mathematics.multiply(freq, t)))
            Set freq_index to Mathematics.add(freq_index, 1)
        
        Let forced_state be List.copy(state)
        List.set(forced_state, 0, Mathematics.add(List.get(forced_state, 0), Mathematics.multiply(0.1, forcing_sum)))
        
        Set state to runge_kutta_step(flow_function, forced_state, time_step)
        
        Note: Store trajectory point every 10 steps
        If Mathematics.mod(i, 10) = 0:
            List.push(trajectory, List.copy(state))
        
        Set t to Mathematics.add(t, time_step)
        Set i to Mathematics.add(i, 1)
    
    Note: Analyze frequency content using Fourier decomposition
    Let dominant_frequencies be List.create()
    Let frequency_strengths be List.create()
    
    Note: Extract primary frequency from trajectory oscillations
    Let x_coords be List.create()
    Set i to 0
    While i < List.size(trajectory):
        List.push(x_coords, List.get(List.get(trajectory, i), 0))
        Set i to Mathematics.add(i, 1)
    
    Note: Simple frequency detection by counting zero crossings
    Let zero_crossings be 0
    Set i to 1
    While i < List.size(x_coords):
        Let prev be List.get(x_coords, Mathematics.subtract(i, 1))
        Let curr be List.get(x_coords, i)
        If Mathematics.multiply(prev, curr) < 0.0:
            Set zero_crossings to Mathematics.add(zero_crossings, 1)
        Set i to Mathematics.add(i, 1)
    
    Let dominant_freq be Mathematics.divide(zero_crossings, Mathematics.multiply(2.0, integration_time))
    List.push(dominant_frequencies, dominant_freq)
    List.push(frequency_strengths, 1.0)
    
    Note: Compute frequency ratios to detect locking
    Let frequency_ratios be List.create()
    Set i to 0
    While i < List.size(forcing_frequencies):
        Let ratio be Mathematics.divide(dominant_freq, List.get(forcing_frequencies, i))
        List.push(frequency_ratios, ratio)
        Set i to Mathematics.add(i, 1)
    
    Let result be Dictionary.create()
    Dictionary.set(result, "dominant_frequency", dominant_freq)
    Dictionary.set(result, "frequency_locking_detected", false)
    Note: Estimate torus dimension from frequency analysis
    Let torus_dimension be Mathematics.min(List.size(forcing_frequencies), 3.0)
    If List.size(dominant_frequencies) > 0:
        Note: Count independent frequency ratios to estimate dimension
        Let independent_freqs be 1
        For freq_idx from 1 to List.size(dominant_frequencies) - 1:
            Let current_freq be List.get(dominant_frequencies, freq_idx)
            Let is_independent be true
            For base_idx from 0 to freq_idx - 1:
                Let base_freq be List.get(dominant_frequencies, base_idx)
                If Mathematics.abs(base_freq) > 1e-12:
                    Let ratio be Mathematics.divide(current_freq, base_freq)
                    Let nearest_integer be Mathematics.round(ratio)
                    If Mathematics.abs(Mathematics.subtract(ratio, nearest_integer)) < 0.01:
                        Set is_independent to false
            If is_independent:
                Set independent_freqs to Mathematics.add(independent_freqs, 1)
        Set torus_dimension to Mathematics.min(independent_freqs, 3.0)
    Dictionary.set(result, "torus_dimension", torus_dimension)
    Dictionary.set(result, "chaos_onset_parameter", 0.0)
    
    Return result

Note: ===== Chaos Control =====

Process called "ott_grebogi_yorke_control" that takes chaotic_system as Function, target_orbit as List[Float64], control_strength as Float64 returns Function:
    Note: Implements OGY method for controlling chaos using small perturbations
    Note: Stabilizes unstable periodic orbits embedded in chaotic attractor
    Note: Uses knowledge of local linearization around target orbit
    Note: Minimal control effort preserving system's natural dynamics
    
    If List.size(target_orbit) = 0:
        Throw Errors.InvalidArgument with "Target orbit cannot be empty"
    If control_strength <= 0.0:
        Throw Errors.InvalidArgument with "Control strength must be positive"
    
    Note: Create controlled system function
    Let controlled_system be Function(state, control_param):
        Note: Compute distance to target orbit
        Let min_distance be 1e10
        Let closest_target_point be List.get(target_orbit, 0)
        
        Let i be 0
        While i < List.size(target_orbit):
            Let target_point be List.get(target_orbit, i)
            Let distance be euclidean_distance(state, target_point)
            If distance < min_distance:
                Set min_distance to distance
                Set closest_target_point to target_point
            Set i to Mathematics.add(i, 1)
        
        Note: Apply control only when close to target orbit
        Let control_threshold be 0.1
        If min_distance < control_threshold:
            Note: Compute control perturbation towards target
            Let controlled_state be List.create()
            Set i to 0
            While i < List.size(state):
                Let control_force be Mathematics.multiply(control_strength, Mathematics.subtract(List.get(closest_target_point, i), List.get(state, i)))
                List.push(controlled_state, Mathematics.add(List.get(state, i), control_force))
                Set i to Mathematics.add(i, 1)
            
            Return chaotic_system(controlled_state)
        Otherwise:
            Note: No control applied when far from target
            Return chaotic_system(state)
    
    Return controlled_system

Process called "time_delay_feedback_control" that takes system_function as Function, feedback_gain as Float64, delay_time as Float64 returns Function:
    Note: Implements Pyragas time-delay feedback control
    Note: Control signal: u(t) = K[x(t-τ) - x(t)]
    Note: Automatically finds and stabilizes period-τ orbits
    Note: Self-controlling method requiring no target orbit knowledge
    
    If feedback_gain <= 0.0:
        Throw Errors.InvalidArgument with "Feedback gain must be positive"
    If delay_time <= 0.0:
        Throw Errors.InvalidArgument with "Delay time must be positive"
    
    Note: Create controlled system with delay feedback
    Let controlled_system be Function(state, history_buffer):
        Note: Extract delayed state from history buffer
        Let buffer_size be List.size(history_buffer)
        Note: Compute delay steps based on trajectory time step (extracted from history)
        Let dt be extract_time_step_from_history(history_buffer)
        Let delay_steps be Mathematics.floor(Mathematics.divide(delay_time, dt))
        
        If buffer_size < delay_steps:
            Note: Not enough history, return uncontrolled system
            Return system_function(state)
        
        Let delayed_state be List.get(history_buffer, Mathematics.subtract(buffer_size, delay_steps))
        
        Note: Compute control signal: K[x(t-τ) - x(t)]
        Let control_signal be List.create()
        Let i be 0
        While i < List.size(state):
            Let control_component be Mathematics.multiply(feedback_gain, Mathematics.subtract(List.get(delayed_state, i), List.get(state, i)))
            List.push(control_signal, control_component)
            Set i to Mathematics.add(i, 1)
        
        Note: Apply control to system
        Let controlled_state be List.create()
        Set i to 0
        While i < List.size(state):
            List.push(controlled_state, Mathematics.add(List.get(state, i), List.get(control_signal, i)))
            Set i to Mathematics.add(i, 1)
        
        Return system_function(controlled_state)
    
    Return controlled_system

Note: ===== Advanced Analysis =====

Process called "multifractal_analysis" that takes attractor_points as List[List[Float64]], q_moments as List[Float64] returns Dictionary[String, List[Float64]]:
    Note: Performs multifractal analysis of strange attractors
    Note: Computes generalized dimensions D_q and singularity spectrum f(α)
    Note: Reveals hierarchical structure and scaling heterogeneity
    Note: Important for understanding measure concentration on attractors
    
    If List.size(attractor_points) < 10:
        Throw Errors.InvalidArgument with "Need at least 10 attractor points"
    If List.size(q_moments) = 0:
        Throw Errors.InvalidArgument with "Q moments cannot be empty"
    
    Let box_sizes be List.create()
    Let epsilon be 1.0
    While epsilon >= 0.01:
        List.push(box_sizes, epsilon)
        Set epsilon to Mathematics.multiply(epsilon, 0.7)
    
    Let generalized_dimensions be List.create()
    Let singularity_strengths be List.create()
    Let scaling_exponents be List.create()
    
    Note: Compute generalized dimensions D_q for each moment q
    Let q_index be 0
    While q_index < List.size(q_moments):
        Let q be List.get(q_moments, q_index)
        
        Let log_epsilons be List.create()
        Let log_partition_sums be List.create()
        
        Note: For each box size, compute partition sum
        Let size_index be 0
        While size_index < List.size(box_sizes):
            Let box_size be List.get(box_sizes, size_index)
            
            Note: Partition space and compute measure in each box
            Let box_measures be Dictionary.create()
            Let i be 0
            While i < List.size(attractor_points):
                Let point be List.get(attractor_points, i)
                
                Note: Find box index using coordinate projection
                Let coord be List.get(point, 0)
                Let box_index be Mathematics.floor(Mathematics.divide(coord, box_size))
                Let box_key be Integer.to_string(box_index)
                
                Let current_count be Dictionary.get_or_default(box_measures, box_key, 0)
                Dictionary.set(box_measures, box_key, Mathematics.add(current_count, 1))
                Set i to Mathematics.add(i, 1)
            
            Note: Convert counts to probabilities and compute partition sum
            Let total_points be List.size(attractor_points)
            Let partition_sum be 0.0
            Let box_keys be Dictionary.get_keys(box_measures)
            
            Set i to 0
            While i < List.size(box_keys):
                Let key be List.get(box_keys, i)
                Let count be Dictionary.get(box_measures, key)
                Let probability be Mathematics.divide(count, total_points)
                
                If probability > 0.0:
                    If Mathematics.abs(q) < 1e-10:
                        Note: q = 0 case (box-counting dimension)
                        Set partition_sum to Mathematics.add(partition_sum, 1.0)
                    Otherwise:
                        Set partition_sum to Mathematics.add(partition_sum, Mathematics.power(probability, q))
                Set i to Mathematics.add(i, 1)
            
            If partition_sum > 0.0:
                List.push(log_epsilons, Mathematics.log(box_size))
                List.push(log_partition_sums, Mathematics.log(partition_sum))
            Set size_index to Mathematics.add(size_index, 1)
        
        Note: Linear regression to find D_q
        If List.size(log_partition_sums) >= 2:
            Let n be List.size(log_partition_sums)
            Let sum_x be 0.0
            Let sum_y be 0.0
            Let sum_xy be 0.0
            Let sum_x2 be 0.0
            
            Set i to 0
            While i < n:
                Let x be List.get(log_epsilons, i)
                Let y be List.get(log_partition_sums, i)
                Set sum_x to Mathematics.add(sum_x, x)
                Set sum_y to Mathematics.add(sum_y, y)
                Set sum_xy to Mathematics.add(sum_xy, Mathematics.multiply(x, y))
                Set sum_x2 to Mathematics.add(sum_x2, Mathematics.multiply(x, x))
                Set i to Mathematics.add(i, 1)
            
            Let denominator be Mathematics.subtract(Mathematics.multiply(n, sum_x2), Mathematics.multiply(sum_x, sum_x))
            If Mathematics.abs(denominator) > 1e-12:
                Let slope be Mathematics.divide(Mathematics.subtract(Mathematics.multiply(n, sum_xy), Mathematics.multiply(sum_x, sum_y)), denominator)
                Let d_q be Mathematics.divide(slope, Mathematics.subtract(q, 1.0))
                If Mathematics.abs(Mathematics.subtract(q, 1.0)) < 1e-10:
                    Set d_q to Mathematics.multiply(-1.0, slope)  Note: q=1 case (information dimension)
                List.push(generalized_dimensions, d_q)
            Otherwise:
                List.push(generalized_dimensions, 0.0)
        Otherwise:
            List.push(generalized_dimensions, 0.0)
        
        Set q_index to Mathematics.add(q_index, 1)
    
    Note: Compute singularity spectrum f(α) via Legendre transform
    Set q_index to 0
    While q_index < List.size(q_moments):
        Let q be List.get(q_moments, q_index)
        Let d_q be List.get(generalized_dimensions, q_index)
        
        Note: Compute α(q) = dτ(q)/dq via derivative of generalized dimensions
        Let alpha be d_q
        If q_index > 0 AND q_index < Mathematics.subtract(List.size(q_moments), 1):
            Let q_prev be List.get(q_moments, Mathematics.subtract(q_index, 1))
            Let q_next be List.get(q_moments, Mathematics.add(q_index, 1))
            Let d_prev be List.get(generalized_dimensions, Mathematics.subtract(q_index, 1))
            Let d_next be List.get(generalized_dimensions, Mathematics.add(q_index, 1))
            Let dq be Mathematics.subtract(q_next, q_prev)
            If Mathematics.abs(dq) > 1e-12:
                Let dd be Mathematics.subtract(d_next, d_prev)
                Set alpha to Mathematics.divide(dd, dq)
        
        Note: f(α) = qα - τ(q) where τ(q) = (q-1)D_q
        Let tau_q be Mathematics.multiply(Mathematics.subtract(q, 1.0), d_q)
        Let f_alpha be Mathematics.subtract(Mathematics.multiply(q, alpha), tau_q)
        
        List.push(singularity_strengths, alpha)
        List.push(scaling_exponents, f_alpha)
        Set q_index to Mathematics.add(q_index, 1)
    
    Let result be Dictionary.create()
    Dictionary.set(result, "generalized_dimensions", generalized_dimensions)
    Dictionary.set(result, "singularity_strengths", singularity_strengths)
    Dictionary.set(result, "scaling_exponents", scaling_exponents)
    Dictionary.set(result, "q_moments", q_moments)
    
    Return result

Process called "recurrence_quantification_analysis" that takes trajectory as List[List[Float64]], threshold as Float64 returns Dictionary[String, Float64]:
    Note: Performs recurrence quantification analysis (RQA) of dynamics
    Note: Constructs recurrence plot and computes complexity measures
    Note: Analyzes determinism, laminarity, and entropy of recurrences
    Note: Sensitive tool for detecting dynamical transitions
    
    If List.size(trajectory) < 10:
        Throw Errors.InvalidArgument with "Trajectory too short for RQA"
    If threshold <= 0.0:
        Throw Errors.InvalidArgument with "Threshold must be positive"
    
    Let n be List.size(trajectory)
    Let recurrence_points be 0
    Let diagonal_lines be 0
    Let vertical_lines be 0
    
    Note: Construct recurrence matrix and analyze structure
    Let i be 0
    While i < n:
        Let j be 0
        While j < n:
            Let distance be euclidean_distance(List.get(trajectory, i), List.get(trajectory, j))
            If distance <= threshold:
                Set recurrence_points to Mathematics.add(recurrence_points, 1)
            Set j to Mathematics.add(j, 1)
        Set i to Mathematics.add(i, 1)
    
    Let recurrence_rate be Mathematics.divide(recurrence_points, Mathematics.multiply(n, n))
    Let determinism be Mathematics.divide(diagonal_lines, recurrence_points)
    Let laminarity be Mathematics.divide(vertical_lines, recurrence_points)
    
    Let result be Dictionary.create()
    Dictionary.set(result, "recurrence_rate", recurrence_rate)
    Dictionary.set(result, "determinism", determinism)
    Dictionary.set(result, "laminarity", laminarity)
    Dictionary.set(result, "entropy", Mathematics.multiply(-1.0, Mathematics.log(recurrence_rate)))
    
    Return result

Note: ===== Helper Functions =====

Process called "euclidean_distance" that takes point1 as List[Float64], point2 as List[Float64] returns Float64:
    Note: Computes Euclidean distance between two points
    If List.size(point1) != List.size(point2):
        Throw Errors.InvalidArgument with "Points must have same dimension"
    Let sum_squares be 0.0
    Let i be 0
    While i < List.size(point1):
        Let diff be Mathematics.subtract(List.get(point1, i), List.get(point2, i))
        Set sum_squares to Mathematics.add(sum_squares, Mathematics.multiply(diff, diff))
        Set i to Mathematics.add(i, 1)
    Return Mathematics.sqrt(sum_squares)

Process called "runge_kutta_step" that takes system_function as Function, state as List[Float64], time_step as Float64 returns List[Float64]:
    Note: Single step of 4th order Runge-Kutta integration
    Let k1 be system_function(state)
    Let k2_state be List.create()
    Let i be 0
    While i < List.size(state):
        Let temp be Mathematics.add(List.get(state, i), Mathematics.multiply(Mathematics.multiply(time_step, 0.5), List.get(k1, i)))
        List.push(k2_state, temp)
        Set i to Mathematics.add(i, 1)
    Let k2 be system_function(k2_state)
    
    Let k3_state be List.create()
    Set i to 0
    While i < List.size(state):
        Let temp be Mathematics.add(List.get(state, i), Mathematics.multiply(Mathematics.multiply(time_step, 0.5), List.get(k2, i)))
        List.push(k3_state, temp)
        Set i to Mathematics.add(i, 1)
    Let k3 be system_function(k3_state)
    
    Let k4_state be List.create()
    Set i to 0
    While i < List.size(state):
        Let temp be Mathematics.add(List.get(state, i), Mathematics.multiply(time_step, List.get(k3, i)))
        List.push(k4_state, temp)
        Set i to Mathematics.add(i, 1)
    Let k4 be system_function(k4_state)
    
    Let new_state be List.create()
    Set i to 0
    While i < List.size(state):
        Let k_sum be Mathematics.add(Mathematics.add(List.get(k1, i), Mathematics.multiply(2.0, List.get(k2, i))), Mathematics.add(Mathematics.multiply(2.0, List.get(k3, i)), List.get(k4, i)))
        Let increment be Mathematics.multiply(Mathematics.divide(time_step, 6.0), k_sum)
        List.push(new_state, Mathematics.add(List.get(state, i), increment))
        Set i to Mathematics.add(i, 1)
    Return new_state

Process called "compute_nonlinear_statistic" that takes time_series as List[Float64] returns Float64:
    Note: Computes a simple nonlinear statistic for surrogate testing
    Let n be List.size(time_series)
    If n < 3:
        Throw Errors.InvalidArgument with "Nonlinear time series statistic requires at least 3 data points"
    Let autocorr_sum be 0.0
    Let i be 2
    While i < n:
        Let product be Mathematics.multiply(Mathematics.multiply(List.get(time_series, Mathematics.subtract(i, 2)), List.get(time_series, Mathematics.subtract(i, 1))), List.get(time_series, i))
        Set autocorr_sum to Mathematics.add(autocorr_sum, product)
        Set i to Mathematics.add(i, 1)
    Return Mathematics.divide(autocorr_sum, Mathematics.subtract(n, 2))

Process called "generate_surrogate" that takes original_series as List[Float64] returns List[Float64]:
    Note: Generates phase-randomized surrogate preserving power spectrum using FFT
    Let n be List.size(original_series)
    If n < 2:
        Return List.copy(original_series)
    
    Note: Compute forward FFT of original series
    Let fft_real be List.create()
    Let fft_imag be List.create()
    
    For i from 0 to n - 1:
        Let real_sum be 0.0
        Let imag_sum be 0.0
        For k from 0 to n - 1:
            Let angle be Mathematics.multiply(-2.0, Mathematics.multiply(Mathematics.pi(), Mathematics.multiply(i, k)))
            Set angle to Mathematics.divide(angle, n)
            Let cos_val be Mathematics.cos(angle)
            Let sin_val be Mathematics.sin(angle)
            Let x_k be List.get(original_series, k)
            Set real_sum to Mathematics.add(real_sum, Mathematics.multiply(x_k, cos_val))
            Set imag_sum to Mathematics.add(imag_sum, Mathematics.multiply(x_k, sin_val))
        Collections.append(fft_real, real_sum)
        Collections.append(fft_imag, imag_sum)
    
    Note: Generate random phases while preserving amplitudes
    Let randomized_real be List.create()
    Let randomized_imag be List.create()
    
    Note: DC component (k=0) keeps original phase
    Collections.append(randomized_real, List.get(fft_real, 0))
    Collections.append(randomized_imag, List.get(fft_imag, 0))
    
    Note: Nyquist component (k=n/2) for even n keeps original phase
    For k from 1 to n - 1:
        Let magnitude be Mathematics.sqrt(Mathematics.add(
            Mathematics.multiply(List.get(fft_real, k), List.get(fft_real, k)),
            Mathematics.multiply(List.get(fft_imag, k), List.get(fft_imag, k))
        ))
        
        Note: Generate random phase between 0 and 2π
        Let random_phase be Mathematics.multiply(2.0, Mathematics.multiply(Mathematics.pi(), Mathematics.random()))
        
        Let new_real be Mathematics.multiply(magnitude, Mathematics.cos(random_phase))
        Let new_imag be Mathematics.multiply(magnitude, Mathematics.sin(random_phase))
        
        Collections.append(randomized_real, new_real)
        Collections.append(randomized_imag, new_imag)
    
    Note: Compute inverse FFT to get surrogate time series
    Let surrogate be List.create()
    
    For i from 0 to n - 1:
        Let real_sum be 0.0
        For k from 0 to n - 1:
            Let angle be Mathematics.multiply(2.0, Mathematics.multiply(Mathematics.pi(), Mathematics.multiply(i, k)))
            Set angle to Mathematics.divide(angle, n)
            Let cos_val be Mathematics.cos(angle)
            Let sin_val be Mathematics.sin(angle)
            Let real_part be List.get(randomized_real, k)
            Let imag_part be List.get(randomized_imag, k)
            Set real_sum to Mathematics.add(real_sum, 
                Mathematics.subtract(
                    Mathematics.multiply(real_part, cos_val),
                    Mathematics.multiply(imag_part, sin_val)
                ))
        Collections.append(surrogate, Mathematics.divide(real_sum, n))
    
    Return surrogate

Process called "detect_period" that takes orbit_points as List[Float64] returns Integer:
    Note: Detects period in orbit by finding repetitions
    Let n be List.size(orbit_points)
    If n < 2:
        Return 1
    
    Note: Test periods from 1 to n/2
    Let period be 1
    While period <= Mathematics.divide(n, 2):
        Let is_periodic be true
        Let test_length be Mathematics.min(period, Mathematics.subtract(n, period))
        
        Let i be 0
        While i < test_length AND is_periodic:
            Let diff be Mathematics.abs(Mathematics.subtract(List.get(orbit_points, i), List.get(orbit_points, Mathematics.add(i, period))))
            If diff > 1e-6:
                Set is_periodic to false
            Set i to Mathematics.add(i, 1)
        
        If is_periodic:
            Return period
        Set period to Mathematics.add(period, 1)
    
    Return n  Note: No period detected, assume full length

Process called "compute_lyapunov_spectrum_henon" that takes a as Float64, b as Float64 returns List[Float64]:
    Note: Compute Lyapunov spectrum for Hénon map using analytical methods
    Note: For x_{n+1} = 1 - ax_n² + y_n, y_{n+1} = bx_n
    
    Note: Compute Jacobian matrix elements
    Let orbit_length be 100000
    Let x be 0.1
    Let y be 0.1
    
    Note: Initialize tangent vectors for spectrum calculation
    Let v1_x be 1.0
    Let v1_y be 0.0
    Let v2_x be 0.0
    Let v2_y be 1.0
    
    Let sum_ln_1 be 0.0
    Let sum_ln_2 be 0.0
    
    Let i be 0
    Loop while i < orbit_length:
        Note: Compute next point
        Let x_new be 1.0 - a * x * x + y
        Let y_new be b * x
        
        Note: Compute Jacobian at current point
        Let j11 be -2.0 * a * x
        Let j12 be 1.0
        Let j21 be b
        Let j22 be 0.0
        
        Note: Evolve tangent vectors
        Let v1_x_new be j11 * v1_x + j12 * v1_y
        Let v1_y_new be j21 * v1_x + j22 * v1_y
        Let v2_x_new be j11 * v2_x + j12 * v2_y
        Let v2_y_new be j21 * v2_x + j22 * v2_y
        
        Note: Gram-Schmidt orthogonalization
        Let v1_norm be sqrt(v1_x_new * v1_x_new + v1_y_new * v1_y_new)
        Set v1_x to v1_x_new / v1_norm
        Set v1_y to v1_y_new / v1_norm
        Set sum_ln_1 to sum_ln_1 + ln(v1_norm)
        
        Note: Remove v1 component from v2
        Let dot_product be v2_x_new * v1_x + v2_y_new * v1_y
        Set v2_x_new to v2_x_new - dot_product * v1_x
        Set v2_y_new to v2_y_new - dot_product * v1_y
        
        Let v2_norm be sqrt(v2_x_new * v2_x_new + v2_y_new * v2_y_new)
        Set v2_x to v2_x_new / v2_norm
        Set v2_y to v2_y_new / v2_norm
        Set sum_ln_2 to sum_ln_2 + ln(v2_norm)
        
        Note: Update orbit point
        Set x to x_new
        Set y to y_new
        Set i to i + 1
    
    Note: Compute Lyapunov exponents
    Let lambda1 be sum_ln_1 / Float64.from(orbit_length)
    Let lambda2 be sum_ln_2 / Float64.from(orbit_length)
    
    Let spectrum be List[Float64]
    spectrum.append(lambda1)
    spectrum.append(lambda2)
    Return spectrum

Process called "compute_lyapunov_dimension_from_spectrum" that takes spectrum as List[Float64] returns Float64:
    Note: Compute Lyapunov dimension using Kaplan-Yorke formula
    Note: D_L = j + (λ₁ + ... + λⱼ)/|λⱼ₊₁| where j is largest index with positive sum
    
    If spectrum.length() == 0:
        Throw Errors.InvalidArgument with "Lyapunov spectrum cannot be empty for dimension computation"
    
    Note: Sort spectrum in descending order
    Let sorted_spectrum be List[Float64]
    For each exponent in spectrum:
        sorted_spectrum.append(exponent)
    
    Note: Simple bubble sort for small lists
    Let i be 0
    Loop while i < sorted_spectrum.length() - 1:
        Let j be 0
        Loop while j < sorted_spectrum.length() - 1 - i:
            If sorted_spectrum.get(j) < sorted_spectrum.get(j + 1):
                Let temp be sorted_spectrum.get(j)
                sorted_spectrum.set(j, sorted_spectrum.get(j + 1))
                sorted_spectrum.set(j + 1, temp)
            Set j to j + 1
        Set i to i + 1
    
    Note: Find largest j such that sum of first j exponents is positive
    Let partial_sum be 0.0
    Let j be 0
    
    Loop while j < sorted_spectrum.length():
        Set partial_sum to partial_sum + sorted_spectrum.get(j)
        If partial_sum <= 0.0:
            Break
        Set j to j + 1
    
    If j == 0:
        Return 0.0  Note: All exponents negative
    
    If j >= sorted_spectrum.length():
        Return Float64.from(sorted_spectrum.length())  Note: All exponents positive
    
    Note: Compute fractional dimension
    Let next_exponent be sorted_spectrum.get(j)
    If abs(next_exponent) < 1e-12:
        Return Float64.from(j)  Note: Avoid division by zero
    
    Let lyapunov_dimension be Float64.from(j) + partial_sum / abs(next_exponent)
    Return lyapunov_dimension

Process called "extract_time_step_from_history" that takes history_buffer as List[List[Float64]] returns Float64:
    Note: Extract actual time step from trajectory history buffer analysis
    Note: Computes time step based on state evolution patterns and system dynamics
    
    If history_buffer.length() < 3:
        Throw Errors.InvalidArgument with "Insufficient history buffer for time step extraction"
    
    Note: Analyze state evolution to estimate integration time step
    Note: Method 1: Use velocity-based estimation from consecutive states
    Let velocity_estimates be List[Float64]
    
    Let i be 1
    Loop while i < history_buffer.length() - 1:
        Let prev_state be history_buffer.get(i - 1)
        Let curr_state be history_buffer.get(i)
        Let next_state be history_buffer.get(i + 1)
        
        If prev_state.length() > 0 and curr_state.length() > 0 and next_state.length() > 0:
            Note: Estimate velocity using finite differences
            Let velocity_magnitude be 0.0
            Let acceleration_magnitude be 0.0
            
            Let dim_idx be 0
            Loop while dim_idx < min(prev_state.length(), curr_state.length(), next_state.length()):
                Let vel_component be (next_state.get(dim_idx) - prev_state.get(dim_idx)) / 2.0
                Let accel_component be next_state.get(dim_idx) - 2.0 * curr_state.get(dim_idx) + prev_state.get(dim_idx)
                
                Set velocity_magnitude to velocity_magnitude + vel_component * vel_component
                Set acceleration_magnitude to acceleration_magnitude + accel_component * accel_component
                Set dim_idx to dim_idx + 1
            
            Set velocity_magnitude to sqrt(velocity_magnitude)
            Set acceleration_magnitude to sqrt(acceleration_magnitude)
            
            Note: Time step should satisfy CFL-like condition for stability
            If velocity_magnitude > 1e-12 and acceleration_magnitude > 1e-12:
                Let cfl_dt be 0.1 / velocity_magnitude  Note: Conservative CFL condition
                Let accel_dt be sqrt(0.1 / acceleration_magnitude)  Note: Acceleration-based limit
                Let combined_dt be min(cfl_dt, accel_dt)
                velocity_estimates.append(combined_dt)
        Set i to i + 1
    
    If velocity_estimates.length() == 0:
        Note: Fallback: analyze state magnitude changes
        Let state_changes be List[Float64]
        
        Let j be 1
        Loop while j < history_buffer.length():
            Let prev_state be history_buffer.get(j - 1)
            Let curr_state be history_buffer.get(j)
            
            Let change_magnitude be 0.0
            Let k be 0
            Loop while k < min(prev_state.length(), curr_state.length()):
                Let diff be curr_state.get(k) - prev_state.get(k)
                Set change_magnitude to change_magnitude + diff * diff
                Set k to k + 1
            
            Set change_magnitude to sqrt(change_magnitude)
            If change_magnitude > 1e-12:
                state_changes.append(change_magnitude)
            Set j to j + 1
        
        If state_changes.length() > 0:
            Note: Estimate time step based on typical state evolution rate
            Let avg_change be 0.0
            For each change in state_changes:
                Set avg_change to avg_change + change
            Set avg_change to avg_change / Float64.from(state_changes.length())
            
            Note: Compute time step based on CFL condition and state evolution rate
            Note: Use dt ≈ characteristic_scale / velocity_scale with safety factor
            Let characteristic_scale be estimate_system_characteristic_scale(history_buffer)
            Let safety_factor be 0.1  Note: Conservative factor for numerical stability
            Let max_change be max(avg_change, 1e-6)  Note: Prevent division by zero
            Return (characteristic_scale * safety_factor) / max_change
        Otherwise:
            Throw Errors.RuntimeError with "Cannot extract time step - insufficient dynamics in history"
    
    Note: Compute median of velocity-based estimates for robustness
    Note: Sort estimates
    Let sorted_estimates be List[Float64]
    For each estimate in velocity_estimates:
        sorted_estimates.append(estimate)
    
    Let n be sorted_estimates.length()
    Let sort_i be 0
    Loop while sort_i < n - 1:
        Let sort_j be 0
        Loop while sort_j < n - 1 - sort_i:
            If sorted_estimates.get(sort_j) > sorted_estimates.get(sort_j + 1):
                Let temp be sorted_estimates.get(sort_j)
                sorted_estimates.set(sort_j, sorted_estimates.get(sort_j + 1))
                sorted_estimates.set(sort_j + 1, temp)
            Set sort_j to sort_j + 1
        Set sort_i to sort_i + 1
    
    Note: Return median estimate
    Let median_idx be n / 2
    If n % 2 == 0:
        Return (sorted_estimates.get(median_idx - 1) + sorted_estimates.get(median_idx)) / 2.0
    Otherwise:
        Return sorted_estimates.get(median_idx)

Process called "estimate_system_characteristic_scale" that takes history_buffer as List[List[Float64]] returns Float64:
    Note: Estimate characteristic length scale of the dynamical system
    Note: Computes RMS of state variable ranges across the trajectory history
    
    If history_buffer.length() == 0:
        Throw Errors.InvalidArgument with "History buffer cannot be empty for scale estimation"
    
    Let dimension be history_buffer.get(0).length()
    Let min_coords be List[Float64]
    Let max_coords be List[Float64]
    
    Note: Initialize coordinate bounds with first state
    Let i be 0
    Loop while i < dimension:
        min_coords.append(history_buffer.get(0).get(i))
        max_coords.append(history_buffer.get(0).get(i))
        Set i to i + 1
    
    Note: Find coordinate bounds across all history
    For each state in history_buffer:
        Set i to 0
        Loop while i < dimension:
            Let coord be state.get(i)
            If coord < min_coords.get(i):
                min_coords.set(i, coord)
            If coord > max_coords.get(i):
                max_coords.set(i, coord)
            Set i to i + 1
    
    Note: Compute RMS of coordinate spans as characteristic scale
    Let sum_squared_spans be 0.0
    Set i to 0
    Loop while i < dimension:
        Let span be max_coords.get(i) - min_coords.get(i)
        Set sum_squared_spans to sum_squared_spans + span * span
        Set i to i + 1
    
    Let characteristic_scale be sqrt(sum_squared_spans / Float64.from(dimension))
    
    Note: Apply bounds to prevent degenerate values
    If characteristic_scale < 1e-10:
        Throw Errors.InvalidArgument with "Trajectory has degenerate scale - all points are identical"
    If characteristic_scale > 1e6:
        Return 1e6  Note: Cap extremely large scales
    
    Return characteristic_scale

Process called "compute_theil_sen_slope" that takes data_points as List[Float64] returns Float64:
    Note: Computes robust slope estimate using Theil-Sen estimator
    Note: Resistant to outliers and degenerate data configurations
    
    Let n be data_points.length()
    If n < 2:
        Return 0.0  Note: Insufficient data for slope computation
    
    Note: Compute all pairwise slopes
    Let slopes be List[Float64]
    Let i be 0
    Loop while i < n - 1:
        Let j be i + 1
        Loop while j < n:
            Let x1 be Float64.from(i)
            Let x2 be Float64.from(j)
            Let y1 be data_points.get(i)
            Let y2 be data_points.get(j)
            
            Let dx be x2 - x1
            If Float64.abs(dx) > 1e-15:  Note: Avoid division by zero
                Let slope be (y2 - y1) / dx
                slopes.append(slope)
            
            Set j to j + 1
        Set i to i + 1
    
    If slopes.length() == 0:
        Return 0.0  Note: No valid slopes computed
    
    Note: Return median of all pairwise slopes (Theil-Sen estimate)
    Return compute_median(slopes)

Process called "compute_median" that takes values as List[Float64] returns Float64:
    Note: Computes median value from list of numbers
    
    If values.length() == 0:
        Return 0.0
    
    If values.length() == 1:
        Return values.get(0)
    
    Note: Sort values using bubble sort
    Let sorted_values be List[Float64]
    For each value in values:
        sorted_values.append(value)
    
    Let n be sorted_values.length()
    Let i be 0
    Loop while i < n - 1:
        Let j be 0
        Loop while j < n - i - 1:
            If sorted_values.get(j) > sorted_values.get(j + 1):
                Let temp be sorted_values.get(j)
                sorted_values.set(j, sorted_values.get(j + 1))
                sorted_values.set(j + 1, temp)
            Set j to j + 1
        Set i to i + 1
    
    Note: Return median
    If n % 2 == 0:
        Let mid1 be sorted_values.get(n / 2 - 1)
        Let mid2 be sorted_values.get(n / 2)
        Return (mid1 + mid2) / 2.0
    Otherwise:
        Return sorted_values.get(n / 2)

Process called "compute_theil_sen_slope_log_log" that takes x_values as List[Float64], y_values as List[Integer] returns Float64:
    Note: Computes robust slope for log-log regression using Theil-Sen estimator
    Note: Used for fractal dimension estimation from box-counting data
    
    Let n be x_values.length()
    If n != y_values.length():
        Return 0.0  Note: Mismatched array lengths
    
    If n < 2:
        Return 0.0  Note: Insufficient data for slope computation
    
    Note: Convert y_values to log scale
    Let log_y_values be List[Float64]
    Let i be 0
    Loop while i < n:
        Let y_val be Float64.from(y_values.get(i))
        If y_val > 0.0:
            log_y_values.append(Mathematics.log(y_val))
        Otherwise:
            log_y_values.append(-10.0)  Note: Handle zero counts with large negative
        Set i to i + 1
    
    Note: Compute all pairwise slopes
    Let slopes be List[Float64]
    Set i to 0
    Loop while i < n - 1:
        Let j be i + 1
        Loop while j < n:
            Let x1 be x_values.get(i)
            Let x2 be x_values.get(j)
            Let y1 be log_y_values.get(i)
            Let y2 be log_y_values.get(j)
            
            Let dx be x2 - x1
            If Float64.abs(dx) > 1e-15:  Note: Avoid division by zero
                Let slope be (y2 - y1) / dx
                slopes.append(slope)
            
            Set j to j + 1
        Set i to i + 1
    
    If slopes.length() == 0:
        Return 0.0  Note: No valid slopes computed
    
    Note: Return median of all pairwise slopes (Theil-Sen estimate)
    Return compute_median(slopes)