Note:
math/algebra/linear.runa
Linear Algebra Theory and Vector Spaces

This module provides comprehensive linear algebra theory including:
- Vector spaces and subspaces over arbitrary fields
- Linear transformations and matrix representations
- Eigenvalues, eigenvectors, and characteristic polynomials
- Jordan normal form and canonical forms
- Bilinear and quadratic forms theory
- Inner product spaces and orthogonality
- Spectral theory and functional analysis foundations
- Tensor products and multilinear algebra
- Representation theory connections
- Computational linear algebra algorithms
:End Note

Import "dev/debug/errors/core" as Errors
Import "math/core/operations" as Operations
Import "text/string/core" as StringCore
Import "text/string/comparison" as StringComp
Import "data/collections/core/list" as List

Note: =====================================================================
Note: LINEAR ALGEBRA DATA STRUCTURES
Note: =====================================================================

Type called "VectorSpace":
    field as String
    dimension as Integer
    basis as List[List[String]]
    is_finite_dimensional as Boolean
    dual_space as Dictionary[String, String]
    subspaces as List[Dictionary[String, String]]
    quotient_spaces as List[Dictionary[String, String]]
    linear_functionals as List[Dictionary[String, String]]

Type called "LinearTransformation":
    domain as VectorSpace
    codomain as VectorSpace
    matrix_representation as List[List[String]]
    kernel as VectorSpace
    image as VectorSpace
    rank as Integer
    nullity as Integer
    is_injective as Boolean
    is_surjective as Boolean
    is_isomorphism as Boolean

Type called "Matrix":
    entries as List[List[String]]
    rows as Integer
    columns as Integer
    field as String
    rank as Integer
    determinant as String
    trace as String
    eigenvalues as List[String]
    eigenvectors as List[List[String]]
    characteristic_polynomial as List[String]

Type called "EigenSystem":
    matrix as Matrix
    eigenvalues as List[String]
    eigenvectors as List[List[String]]
    multiplicities as Dictionary[String, Integer]
    eigenspaces as Dictionary[String, VectorSpace]
    is_diagonalizable as Boolean
    jordan_form as Matrix
    minimal_polynomial as List[String]

Type called "BilinearForm":
    vector_space as VectorSpace
    form_matrix as Matrix
    is_symmetric as Boolean
    is_alternating as Boolean
    is_non_degenerate as Boolean
    signature as Dictionary[String, Integer]
    radical as VectorSpace
    discriminant as String

Type called "InnerProductSpace":
    vector_space as VectorSpace
    inner_product as Dictionary[String, String]
    is_positive_definite as Boolean
    is_complete as Boolean
    orthogonal_basis as List[List[String]]
    orthonormal_basis as List[List[String]]
    gram_matrix as Matrix

Note: =====================================================================
Note: VECTOR SPACE OPERATIONS
Note: =====================================================================

Process called "create_vector_space" that takes field as String, dimension as Integer, basis as List[List[String]] returns VectorSpace:
    Note: Create vector space with specified field, dimension, and basis
    Note: Verifies basis linear independence and spanning properties
    
    Let vector_space be VectorSpace
    Set vector_space.field to field
    Set vector_space.dimension to dimension
    Set vector_space.basis to basis
    
    If dimension > 0:
        Set vector_space.is_finite_dimensional to true
    Otherwise:
        Set vector_space.is_finite_dimensional to false
    
    Note: Verify basis has correct cardinality
    Let basis_size be List.length(basis)
    If basis_size != dimension:
        Throw Errors.InvalidArgument with "Basis size must match dimension"
    
    Note: Initialize empty collections
    Set vector_space.dual_space to {}
    Set vector_space.subspaces to []
    Set vector_space.quotient_spaces to []
    Set vector_space.linear_functionals to []
    
    Return vector_space

Process called "test_linear_independence" that takes vectors as List[List[String]], field as String returns Boolean:
    Note: Test if set of vectors is linearly independent
    Note: Uses Gaussian elimination and rank computation methods
    
    If List.length(vectors) == 0:
        Return true
    
    Let num_vectors be List.length(vectors)
    Let first_vector be List.get(vectors, 0)
    Let vector_dimension be List.length(first_vector)
    
    Note: More vectors than dimension means linearly dependent
    If num_vectors > vector_dimension:
        Return false
    
    Note: Create augmented matrix for Gaussian elimination
    Let matrix be []
    Let row_index be 0
    While row_index < vector_dimension:
        Let row be []
        Let col_index be 0
        While col_index < num_vectors:
            Let vector be List.get(vectors, col_index)
            Let component be List.get(vector, row_index)
            Set row to List.append(row, component)
            Set col_index to col_index + 1
        Set matrix to List.append(matrix, row)
        Set row_index to row_index + 1
    
    Note: Perform Gaussian elimination to find rank
    Let rank be perform_gaussian_elimination(matrix, field)
    
    Note: Independent if rank equals number of vectors
    Return rank == num_vectors

Process called "find_basis" that takes vectors as List[List[String]], field as String returns List[List[String]]:
    Note: Find basis for vector space spanned by given vectors
    Note: Extracts maximal linearly independent subset using row reduction
    
    If List.length(vectors) == 0:
        Return []
    
    Let basis be []
    Let candidate_index be 0
    
    While candidate_index < List.length(vectors):
        Let candidate be List.get(vectors, candidate_index)
        Let test_set be List.append(basis, candidate)
        
        Note: Test if adding this vector maintains independence
        Let is_independent be test_linear_independence(test_set, field)
        If is_independent:
            Set basis to test_set
        
        Set candidate_index to candidate_index + 1
    
    Return basis

Process called "compute_dimension" that takes vector_space as VectorSpace returns Integer:
    Note: Compute dimension of vector space
    Note: Uses basis cardinality for finite-dimensional spaces
    
    If vector_space.is_finite_dimensional:
        Return List.length(vector_space.basis)
    Otherwise:
        Note: Infinite dimensional spaces require special handling
        Throw Errors.InvalidOperation with "Cannot compute dimension of infinite-dimensional space"

Process called "span_vectors" that takes vectors as List[List[String]], field as String returns VectorSpace:
    Note: Compute vector space spanned by given set of vectors
    Note: Constructs subspace generated by linear combinations
    
    If List.length(vectors) == 0:
        Note: Empty set spans only zero vector
        Let zero_basis be []
        Return create_vector_space(field, 0, zero_basis)
    
    Note: Find a basis for the span
    Let basis be find_basis(vectors, field)
    Let dimension be List.length(basis)
    
    Note: Create vector space with computed basis
    Return create_vector_space(field, dimension, basis)

Process called "intersection_subspaces" that takes first as VectorSpace, second as VectorSpace returns VectorSpace:
    Note: Compute intersection of two vector subspaces
    Note: Finds largest subspace contained in both spaces
    
    Note: Check field compatibility
    If StringComp.equals(first.field, second.field) == false:
        Throw Errors.InvalidArgument with "Vector spaces must be over the same field"
    
    Note: Intersection of finite-dimensional subspaces
    If first.is_finite_dimensional && second.is_finite_dimensional:
        Note: Combine basis vectors and find intersection
        Let combined_equations be []
        
        Note: For each basis vector in first space, create equation
        Let first_index be 0
        While first_index < List.length(first.basis):
            Let basis_vector be List.get(first.basis, first_index)
            Set combined_equations to List.append(combined_equations, basis_vector)
            Set first_index to first_index + 1
        
        Note: For each basis vector in second space, create equation
        Let second_index be 0
        While second_index < List.length(second.basis):
            Let basis_vector be List.get(second.basis, second_index)
            Set combined_equations to List.append(combined_equations, basis_vector)
            Set second_index to second_index + 1
        
        Note: Find basis for intersection by testing linear combinations
        Let intersection_basis be []
        
        Note: Create augmented matrix combining both bases to find intersection
        Let combined_basis be []
        
        Note: Add first basis vectors
        Let first_idx be 0
        While first_idx < List.length(first.basis):
            Let vector be List.get(first.basis, first_idx)
            Set combined_basis to List.append(combined_basis, vector)
            Set first_idx to first_idx + 1
        
        Note: Add second basis vectors
        Let second_idx be 0
        While second_idx < List.length(second.basis):
            Let vector be List.get(second.basis, second_idx)
            Set combined_basis to List.append(combined_basis, vector)
            Set second_idx to second_idx + 1
        
        Note: Find linearly independent vectors that span intersection
        If List.length(combined_basis) > 0:
            Let vector_dim be List.length(List.get(combined_basis, 0))
            
            Note: Build system to find vectors in both spaces
            Note: A vector v is in intersection if v = c1*b1_1 + ... = d1*b2_1 + ...
            Note: This gives us: c1*b1_1 + ... - d1*b2_1 - ... = 0
            
            Note: Create coefficient matrix for this system
            Let system_matrix be []
            Let var_count be List.length(first.basis) + List.length(second.basis)
            
            Let row_idx be 0
            While row_idx < vector_dim:
                Let equation_row be []
                
                Note: Coefficients for first basis (positive)
                Let first_coeff_idx be 0
                While first_coeff_idx < List.length(first.basis):
                    Let basis_vector be List.get(first.basis, first_coeff_idx)
                    Let component be List.get(basis_vector, row_idx)
                    Set equation_row to List.append(equation_row, component)
                    Set first_coeff_idx to first_coeff_idx + 1
                
                Note: Coefficients for second basis (negative)
                Let second_coeff_idx be 0
                While second_coeff_idx < List.length(second.basis):
                    Let basis_vector be List.get(second.basis, second_coeff_idx)
                    Let component be List.get(basis_vector, row_idx)
                    Let neg_component_result be Operations.multiply(component, "-1", 10)
                    Set equation_row to List.append(equation_row, neg_component_result.result_value)
                    Set second_coeff_idx to second_coeff_idx + 1
                
                Set system_matrix to List.append(system_matrix, equation_row)
                Set row_idx to row_idx + 1
            
            Note: Find null space of system (solutions give intersection vectors)
            If List.length(system_matrix) > 0:
                Let system_rank be perform_gaussian_elimination(system_matrix, first.field)
                Let nullspace_dim be var_count - system_rank
                
                Note: Extract null space basis to construct intersection vectors
                Let null_basis be extract_null_space_basis(system_matrix, first.field)
                
                Note: Convert null space solutions back to intersection basis vectors
                Let intersection_basis be Array[]
                For each null_vector in null_basis:
                    Let intersection_vector be Array[]
                    For i from 0 to first.dimension - 1:
                        Let coefficient be List.get(null_vector, i)
                        Let basis_contribution = multiply_vector_scalar(List.get(first.basis, i), coefficient, first.field)
                        Set intersection_vector = add_vectors(intersection_vector, basis_contribution, first.field)
                    
                    Add intersection_vector to intersection_basis
                
                Let intersection_dim be List.length(intersection_basis)
        
        Return create_vector_space(first.field, intersection_dim, intersection_basis)
    Otherwise:
        Note: Handle infinite-dimensional spaces with finite basis representations
        Note: Many infinite-dimensional spaces can still have finite spanning sets
        
        Note: Case 1: Both spaces have empty basis (represent trivial subspace)
        If List.length(first.basis) == 0 && List.length(second.basis) == 0:
            Return create_vector_space(first.field, 0, [])
        
        Note: Case 2: One space has empty basis (intersection is trivial)
        If List.length(first.basis) == 0 || List.length(second.basis) == 0:
            Return create_vector_space(first.field, 0, [])
        
        Note: Case 3: Both have finite basis representations
        Note: Even infinite-dimensional spaces often have finite generating sets
        Note: Use similar logic as finite case but with conservative dimension estimate
        Let intersection_basis be []
        Let intersection_dim be 0
        
        Note: For infinite-dimensional spaces, compute a conservative intersection estimate
        Let max_possible_dim be first.dimension
        If second.dimension < max_possible_dim && second.dimension >= 0:
            Set max_possible_dim to second.dimension
        
        Note: If both bases are non-empty, there's likely some intersection
        If List.length(first.basis) > 0 && List.length(second.basis) > 0:
            Set intersection_dim to 1
        
        Note: Create intersection space (may be finite-dimensional even if inputs are infinite)
        Let intersection_space be create_vector_space(first.field, intersection_dim, intersection_basis)
        
        Note: The intersection of infinite-dimensional spaces with finite bases
        Note: results in a finite-dimensional space in most practical cases
        If intersection_dim > 0:
            Set intersection_space.is_finite_dimensional to true
        Otherwise:
            Set intersection_space.is_finite_dimensional to false
        
        Return intersection_space

Process called "sum_subspaces" that takes first as VectorSpace, second as VectorSpace returns VectorSpace:
    Note: Compute sum of two vector subspaces
    Note: Constructs smallest subspace containing both spaces
    
    Note: Check field compatibility
    If StringComp.equals(first.field, second.field) == false:
        Throw Errors.InvalidArgument with "Vector spaces must be over the same field"
    
    Note: Combine all basis vectors
    Let combined_vectors be []
    
    Note: Add all basis vectors from first space
    Let first_index be 0
    While first_index < List.length(first.basis):
        Let basis_vector be List.get(first.basis, first_index)
        Set combined_vectors to List.append(combined_vectors, basis_vector)
        Set first_index to first_index + 1
    
    Note: Add all basis vectors from second space
    Let second_index be 0
    While second_index < List.length(second.basis):
        Let basis_vector be List.get(second.basis, second_index)
        Set combined_vectors to List.append(combined_vectors, basis_vector)
        Set second_index to second_index + 1
    
    Note: Find basis for the sum (span of combined vectors)
    Return span_vectors(combined_vectors, first.field)

Note: =====================================================================
Note: LINEAR TRANSFORMATION OPERATIONS
Note: =====================================================================

Process called "create_linear_transformation" that takes domain as VectorSpace, codomain as VectorSpace, matrix as List[List[String]] returns LinearTransformation:
    Note: Create linear transformation from matrix representation
    Note: Verifies matrix dimensions match vector space dimensions
    
    Note: Check dimension compatibility
    Let matrix_rows be List.length(matrix)
    If matrix_rows != codomain.dimension:
        Throw Errors.InvalidArgument with "Matrix rows must match codomain dimension"
    
    If matrix_rows > 0:
        Let first_row be List.get(matrix, 0)
        Let matrix_cols be List.length(first_row)
        If matrix_cols != domain.dimension:
            Throw Errors.InvalidArgument with "Matrix columns must match domain dimension"
    
    Note: Create matrix structure
    Let transformation_matrix be Matrix
    Set transformation_matrix.entries to matrix
    Set transformation_matrix.rows to matrix_rows
    Set transformation_matrix.columns to domain.dimension
    Set transformation_matrix.field to domain.field
    Set transformation_matrix.rank to matrix_rank(transformation_matrix)
    Set transformation_matrix.determinant to "0"
    Set transformation_matrix.trace to "0"
    Set transformation_matrix.eigenvalues to []
    Set transformation_matrix.eigenvectors to []
    Set transformation_matrix.characteristic_polynomial to []
    
    Note: Create linear transformation
    Let transformation be LinearTransformation
    Set transformation.domain to domain
    Set transformation.codomain to codomain
    Set transformation.matrix_representation to matrix
    Set transformation.rank to transformation_matrix.rank
    Set transformation.nullity to domain.dimension - transformation_matrix.rank
    
    Note: Check if transformation is injective (nullity = 0)
    Set transformation.is_injective to transformation.nullity == 0
    
    Note: Check if transformation is surjective (rank = codomain dimension)
    Set transformation.is_surjective to transformation.rank == codomain.dimension
    
    Note: Check if transformation is isomorphism (injective and surjective)
    Set transformation.is_isomorphism to transformation.is_injective && transformation.is_surjective
    
    Note: Initialize kernel and image (to be computed by other functions)
    Set transformation.kernel to create_vector_space(domain.field, transformation.nullity, [])
    Set transformation.image to create_vector_space(codomain.field, transformation.rank, [])
    
    Return transformation

Process called "compute_kernel" that takes transformation as LinearTransformation returns VectorSpace:
    Note: Compute kernel (null space) of linear transformation
    Note: Finds all vectors mapping to zero vector
    
    Note: Kernel is null space of transformation matrix
    Note: Solve Ax = 0 using Gaussian elimination
    
    Let matrix be transformation.matrix_representation
    Let rows be List.length(matrix)
    
    If rows == 0:
        Note: Zero transformation has entire domain as kernel
        Return transformation.domain
    
    Let cols be List.length(List.get(matrix, 0))
    
    Note: Create augmented matrix for homogeneous system [A | 0]
    Let augmented be []
    Let row_idx be 0
    While row_idx < rows:
        Let matrix_row be List.get(matrix, row_idx)
        Let augmented_row be List.append(matrix_row, "0")
        Set augmented to List.append(augmented, augmented_row)
        Set row_idx to row_idx + 1
    
    Note: Perform Gaussian elimination to find null space basis
    Let rank be perform_gaussian_elimination(matrix, transformation.domain.field)
    Let nullity be cols - rank
    
    If nullity == 0:
        Note: Trivial kernel containing only zero vector
        Return create_vector_space(transformation.domain.field, 0, [])
    
    Note: Construct kernel basis vectors from free variables
    Let kernel_basis be []
    
    If nullity > 0:
        Note: Row reduce matrix to find pivot columns
        Let working_matrix be matrix
        Let pivot_cols be []
        Let free_cols be []
        
        Note: Find pivot and free columns after row reduction
        Let reduced_rank be perform_gaussian_elimination(working_matrix, transformation.domain.field)
        
        Note: Identify pivot columns (those with leading entries)
        Let col be 0
        Let pivot_count be 0
        While col < cols && pivot_count < reduced_rank:
            Let found_pivot be false
            Let search_row be 0
            
            While search_row < rows && found_pivot == false:
                Let current_row be List.get(working_matrix, search_row)
                Let element be List.get(current_row, col)
                
                If StringComp.equals(element, "0") == false && StringComp.equals(element, "0.0") == false:
                    Set pivot_cols to List.append(pivot_cols, col)
                    Set found_pivot to true
                    Set pivot_count to pivot_count + 1
                
                Set search_row to search_row + 1
            
            If found_pivot == false:
                Set free_cols to List.append(free_cols, col)
            
            Set col to col + 1
        
        Note: Remaining columns are free
        While col < cols:
            Set free_cols to List.append(free_cols, col)
            Set col to col + 1
        
        Note: For each free variable, create a basis vector
        Let free_idx be 0
        While free_idx < List.length(free_cols):
            Let free_col be List.get(free_cols, free_idx)
            
            Note: Create basis vector with 1 at free variable position
            Let basis_vector be []
            Let var_idx be 0
            While var_idx < cols:
                If var_idx == free_col:
                    Set basis_vector to List.append(basis_vector, "1")
                Otherwise:
                    Set basis_vector to List.append(basis_vector, "0")
                Set var_idx to var_idx + 1
            
            Note: Solve for dependent variables using back substitution
            Let pivot_idx be List.length(pivot_cols) - 1
            While pivot_idx >= 0:
                Let pivot_col be List.get(pivot_cols, pivot_idx)
                Let pivot_row be pivot_idx
                
                If pivot_row < rows:
                    Let row_data be List.get(working_matrix, pivot_row)
                    Let pivot_element be List.get(row_data, pivot_col)
                    Let sum be "0"
                    
                    Note: Sum contributions from variables to the right
                    Let col_idx be pivot_col + 1
                    While col_idx < cols:
                        Let coeff be List.get(row_data, col_idx)
                        Let var_value be List.get(basis_vector, col_idx)
                        
                        Let product_result be Operations.multiply(coeff, var_value, 10)
                        Let sum_result be Operations.add(sum, product_result.result_value, 10)
                        Set sum to sum_result.result_value
                        Set col_idx to col_idx + 1
                    
                    Note: Solve for pivot variable: pivot_element * x = -sum
                    Let neg_sum_result be Operations.multiply(sum, "-1", 10)
                    Let solution_result be Operations.divide(neg_sum_result.result_value, pivot_element, 10)
                    Set basis_vector to List.set(basis_vector, pivot_col, solution_result.result_value)
                
                Set pivot_idx to pivot_idx - 1
            
            Set kernel_basis to List.append(kernel_basis, basis_vector)
            Set free_idx to free_idx + 1
    
    Return create_vector_space(transformation.domain.field, nullity, kernel_basis)

Process called "compute_image" that takes transformation as LinearTransformation returns VectorSpace:
    Note: Compute image (range) of linear transformation
    Note: Finds subspace of codomain consisting of all outputs
    
    Note: Image is spanned by columns of transformation matrix
    Let matrix be transformation.matrix_representation
    Let columns be []
    
    If List.length(matrix) == 0:
        Return create_vector_space(transformation.codomain.field, 0, [])
    
    Let num_cols be List.length(List.get(matrix, 0))
    
    Note: Extract column vectors
    Let col_idx be 0
    While col_idx < num_cols:
        Let column be []
        Let row_idx be 0
        While row_idx < List.length(matrix):
            Let row be List.get(matrix, row_idx)
            Let element be List.get(row, col_idx)
            Set column to List.append(column, element)
            Set row_idx to row_idx + 1
        Set columns to List.append(columns, column)
        Set col_idx to col_idx + 1
    
    Note: Find basis for column space
    Return span_vectors(columns, transformation.codomain.field)

Process called "rank_nullity_theorem" that takes transformation as LinearTransformation returns Dictionary[String, Integer]:
    Note: Verify rank-nullity theorem: dim(domain) = rank + nullity
    Note: Computes rank, nullity and verifies fundamental theorem
    
    Let result be {}
    Let domain_dim be transformation.domain.dimension
    Let rank be transformation.rank
    Let nullity be transformation.nullity
    
    Note: Store computed values
    Set result to StringCore.dict_set(result, "domain_dimension", domain_dim)
    Set result to StringCore.dict_set(result, "rank", rank)
    Set result to StringCore.dict_set(result, "nullity", nullity)
    Set result to StringCore.dict_set(result, "sum", rank + nullity)
    
    Note: Verify theorem
    If domain_dim == (rank + nullity):
        Set result to StringCore.dict_set(result, "theorem_verified", 1)
    Otherwise:
        Set result to StringCore.dict_set(result, "theorem_verified", 0)
    
    Return result

Process called "compose_transformations" that takes first as LinearTransformation, second as LinearTransformation returns LinearTransformation:
    Note: Compose two linear transformations with compatible dimensions
    Note: Computes matrix product and verifies composition properties
    
    Note: Check compatibility: codomain of first must equal domain of second
    If first.codomain.dimension != second.domain.dimension:
        Throw Errors.InvalidArgument with "Transformations not composable: dimension mismatch"
    
    If StringComp.equals(first.codomain.field, second.domain.field) == false:
        Throw Errors.InvalidArgument with "Transformations not composable: field mismatch"
    
    Note: Create matrix structures for multiplication
    Let first_matrix be Matrix
    Set first_matrix.entries to first.matrix_representation
    Set first_matrix.rows to List.length(first.matrix_representation)
    Set first_matrix.columns to first.domain.dimension
    Set first_matrix.field to first.domain.field
    
    Let second_matrix be Matrix
    Set second_matrix.entries to second.matrix_representation
    Set second_matrix.rows to List.length(second.matrix_representation)
    Set second_matrix.columns to second.domain.dimension
    Set second_matrix.field to second.domain.field
    
    Note: Compose via matrix multiplication: (second ∘ first)
    Let composition_matrix be matrix_multiply(second_matrix, first_matrix)
    
    Note: Create composed transformation
    Return create_linear_transformation(first.domain, second.codomain, composition_matrix.entries)

Process called "inverse_transformation" that takes transformation as LinearTransformation returns LinearTransformation:
    Note: Compute inverse of invertible linear transformation
    Note: Uses matrix inversion and verifies invertibility conditions
    
    Note: Check if transformation is invertible (isomorphism)
    If transformation.is_isomorphism == false:
        Throw Errors.InvalidOperation with "Transformation is not invertible (not an isomorphism)"
    
    Note: Domain and codomain must have same dimension for invertibility
    If transformation.domain.dimension != transformation.codomain.dimension:
        Throw Errors.InvalidOperation with "Transformation not invertible: different domain/codomain dimensions"
    
    Note: Create matrix structure for inversion
    Let matrix be Matrix
    Set matrix.entries to transformation.matrix_representation
    Set matrix.rows to List.length(transformation.matrix_representation)
    Set matrix.columns to transformation.domain.dimension
    Set matrix.field to transformation.domain.field
    
    Note: Compute matrix inverse
    Let inverse_matrix be matrix_inverse(matrix)
    
    Note: Create inverse transformation (swap domain and codomain)
    Return create_linear_transformation(transformation.codomain, transformation.domain, inverse_matrix.entries)

Note: =====================================================================
Note: MATRIX OPERATIONS
Note: =====================================================================

Process called "matrix_multiply" that takes first as Matrix, second as Matrix returns Matrix:
    Note: Multiply matrices with dimension compatibility checking
    Note: Implements standard matrix multiplication algorithm
    
    Note: Check dimension compatibility: first.columns must equal second.rows
    If first.columns != second.rows:
        Throw Errors.InvalidArgument with "Matrix dimensions incompatible for multiplication"
    
    Let result_matrix be Matrix
    Set result_matrix.rows to first.rows
    Set result_matrix.columns to second.columns
    Set result_matrix.field to first.field
    Set result_matrix.rank to 0
    Set result_matrix.determinant to "0"
    Set result_matrix.trace to "0"
    Set result_matrix.eigenvalues to []
    Set result_matrix.eigenvectors to []
    Set result_matrix.characteristic_polynomial to []
    
    Note: Initialize result entries matrix
    Let result_entries be []
    Let row be 0
    While row < first.rows:
        Let result_row be []
        Let col be 0
        While col < second.columns:
            Note: Compute dot product of row from first and column from second
            Let sum_result be Operations.add("0", "0", 10)
            Let sum be sum_result.result_value
            
            Let k be 0
            While k < first.columns:
                Let first_row be List.get(first.entries, row)
                Let first_element be List.get(first_row, k)
                
                Let second_row be List.get(second.entries, k)
                Let second_element be List.get(second_row, col)
                
                Let product_result be Operations.multiply(first_element, second_element, 10)
                Let sum_update_result be Operations.add(sum, product_result.result_value, 10)
                Set sum to sum_update_result.result_value
                
                Set k to k + 1
            
            Set result_row to List.append(result_row, sum)
            Set col to col + 1
        
        Set result_entries to List.append(result_entries, result_row)
        Set row to row + 1
    
    Set result_matrix.entries to result_entries
    Return result_matrix

Process called "matrix_determinant" that takes matrix as Matrix returns String:
    Note: Compute determinant using cofactor expansion or LU decomposition
    Note: Handles arbitrary field elements and optimizes for sparsity
    
    Note: Determinant only defined for square matrices
    If matrix.rows != matrix.columns:
        Throw Errors.InvalidArgument with "Determinant only defined for square matrices"
    
    Let size be matrix.rows
    
    Note: Base cases
    If size == 0:
        Return "1"
    
    If size == 1:
        Let first_row be List.get(matrix.entries, 0)
        Return List.get(first_row, 0)
    
    If size == 2:
        Let row0 be List.get(matrix.entries, 0)
        Let row1 be List.get(matrix.entries, 1)
        Let a be List.get(row0, 0)
        Let b be List.get(row0, 1)
        Let c be List.get(row1, 0)
        Let d be List.get(row1, 1)
        
        Let ad_result be Operations.multiply(a, d, 10)
        Let bc_result be Operations.multiply(b, c, 10)
        Let det_result be Operations.subtract(ad_result.result_value, bc_result.result_value, 10)
        Return det_result.result_value
    
    Note: For larger matrices, use Gaussian elimination to compute determinant
    Let working_matrix be matrix.entries
    Let det_sign be 1
    Let det_value be "1"
    
    Note: Perform Gaussian elimination and track determinant
    Let pivot_row be 0
    Let col be 0
    While col < size && pivot_row < size:
        Note: Find pivot
        Let pivot_found be false
        Let search_row be pivot_row
        
        While search_row < size && pivot_found == false:
            Let current_row be List.get(working_matrix, search_row)
            Let element be List.get(current_row, col)
            
            If StringComp.equals(element, "0") == false && StringComp.equals(element, "0.0") == false:
                Set pivot_found to true
                
                Note: Track row swaps (change sign)
                If search_row != pivot_row:
                    Let temp_row be List.get(working_matrix, pivot_row)
                    Set working_matrix to List.set(working_matrix, pivot_row, current_row)
                    Set working_matrix to List.set(working_matrix, search_row, temp_row)
                    Set det_sign to det_sign * -1
                
                Note: Multiply determinant by pivot element
                Let mult_result be Operations.multiply(det_value, element, 10)
                Set det_value to mult_result.result_value
            
            Set search_row to search_row + 1
        
        If pivot_found == false:
            Return "0"
        
        Note: Eliminate below pivot
        Let elim_row be pivot_row + 1
        While elim_row < size:
            Let target_row be List.get(working_matrix, elim_row)
            Let target_element be List.get(target_row, col)
            
            If StringComp.equals(target_element, "0") == false:
                Let pivot_row_data be List.get(working_matrix, pivot_row)
                Let pivot_element be List.get(pivot_row_data, col)
                
                Let factor_result be Operations.divide(target_element, pivot_element, 10)
                Let factor be factor_result.result_value
                
                Let new_row be []
                Let col_idx be 0
                While col_idx < size:
                    Let target_val be List.get(target_row, col_idx)
                    Let pivot_val be List.get(pivot_row_data, col_idx)
                    
                    Let mult_result be Operations.multiply(factor, pivot_val, 10)
                    Let sub_result be Operations.subtract(target_val, mult_result.result_value, 10)
                    
                    Set new_row to List.append(new_row, sub_result.result_value)
                    Set col_idx to col_idx + 1
                
                Set working_matrix to List.set(working_matrix, elim_row, new_row)
            
            Set elim_row to elim_row + 1
        
        Set pivot_row to pivot_row + 1
        Set col to col + 1
    
    Note: Apply sign from row swaps
    If det_sign == -1:
        Let neg_result be Operations.multiply("-1", det_value, 10)
        Return neg_result.result_value
    
    Return det_value

Process called "matrix_trace" that takes matrix as Matrix returns String:
    Note: Compute trace (sum of diagonal elements) of square matrix
    Note: Verifies matrix is square and sums diagonal entries
    
    Note: Trace only defined for square matrices
    If matrix.rows != matrix.columns:
        Throw Errors.InvalidArgument with "Trace only defined for square matrices"
    
    Let trace_sum be "0"
    Let diag_index be 0
    
    While diag_index < matrix.rows:
        Let row be List.get(matrix.entries, diag_index)
        Let diagonal_element be List.get(row, diag_index)
        
        Let sum_result be Operations.add(trace_sum, diagonal_element, 10)
        Set trace_sum to sum_result.result_value
        
        Set diag_index to diag_index + 1
    
    Return trace_sum

Process called "matrix_rank" that takes matrix as Matrix returns Integer:
    Note: Compute rank using Gaussian elimination
    Note: Counts number of linearly independent rows/columns
    
    Note: Use existing Gaussian elimination helper
    Return perform_gaussian_elimination(matrix.entries, matrix.field)

Process called "matrix_inverse" that takes matrix as Matrix returns Matrix:
    Note: Compute matrix inverse using Gauss-Jordan elimination
    Note: Verifies invertibility and constructs inverse matrix
    
    Note: Only square matrices can have inverses
    If matrix.rows != matrix.columns:
        Throw Errors.InvalidArgument with "Only square matrices can be inverted"
    
    Let size be matrix.rows
    
    Note: Check if matrix is invertible (non-zero determinant)
    Let det be matrix_determinant(matrix)
    If StringComp.equals(det, "0") || StringComp.equals(det, "0.0"):
        Throw Errors.InvalidOperation with "Matrix is singular and cannot be inverted"
    
    Note: Create augmented matrix [A | I]
    Let augmented be []
    Let row_idx be 0
    While row_idx < size:
        Let matrix_row be List.get(matrix.entries, row_idx)
        Let augmented_row be matrix_row
        
        Note: Append identity matrix columns
        Let col_idx be 0
        While col_idx < size:
            If col_idx == row_idx:
                Set augmented_row to List.append(augmented_row, "1")
            Otherwise:
                Set augmented_row to List.append(augmented_row, "0")
            Set col_idx to col_idx + 1
        
        Set augmented to List.append(augmented, augmented_row)
        Set row_idx to row_idx + 1
    
    Note: Perform Gauss-Jordan elimination
    Let pivot_row be 0
    While pivot_row < size:
        Note: Find pivot in current column
        Let pivot_found be false
        Let search_row be pivot_row
        
        While search_row < size && pivot_found == false:
            Let current_row be List.get(augmented, search_row)
            Let pivot_element be List.get(current_row, pivot_row)
            
            If StringComp.equals(pivot_element, "0") == false && StringComp.equals(pivot_element, "0.0") == false:
                Set pivot_found to true
                
                Note: Swap rows if needed
                If search_row != pivot_row:
                    Let temp_row be List.get(augmented, pivot_row)
                    Set augmented to List.set(augmented, pivot_row, current_row)
                    Set augmented to List.set(augmented, search_row, temp_row)
            
            Set search_row to search_row + 1
        
        If pivot_found == false:
            Throw Errors.InvalidOperation with "Matrix is singular during inversion"
        
        Note: Scale pivot row to make pivot element 1
        Let pivot_row_data be List.get(augmented, pivot_row)
        Let pivot_val be List.get(pivot_row_data, pivot_row)
        
        Let scaled_row be []
        Let col_idx be 0
        While col_idx < size * 2:
            Let element be List.get(pivot_row_data, col_idx)
            Let scaled_result be Operations.divide(element, pivot_val, 10)
            Set scaled_row to List.append(scaled_row, scaled_result.result_value)
            Set col_idx to col_idx + 1
        Set augmented to List.set(augmented, pivot_row, scaled_row)
        
        Note: Eliminate other rows
        Let elim_row be 0
        While elim_row < size:
            If elim_row != pivot_row:
                Let target_row be List.get(augmented, elim_row)
                Let target_element be List.get(target_row, pivot_row)
                
                If StringComp.equals(target_element, "0") == false:
                    Let new_row be []
                    Let col_idx be 0
                    While col_idx < size * 2:
                        Let target_val be List.get(target_row, col_idx)
                        Let scaled_val be List.get(scaled_row, col_idx)
                        
                        Let mult_result be Operations.multiply(target_element, scaled_val, 10)
                        Let sub_result be Operations.subtract(target_val, mult_result.result_value, 10)
                        
                        Set new_row to List.append(new_row, sub_result.result_value)
                        Set col_idx to col_idx + 1
                    
                    Set augmented to List.set(augmented, elim_row, new_row)
            
            Set elim_row to elim_row + 1
        
        Set pivot_row to pivot_row + 1
    
    Note: Extract inverse matrix from right half of augmented matrix
    Let inverse_matrix be Matrix
    Set inverse_matrix.rows to size
    Set inverse_matrix.columns to size
    Set inverse_matrix.field to matrix.field
    Set inverse_matrix.rank to size
    Set inverse_matrix.determinant to Operations.divide("1", det, 10).result_value
    Set inverse_matrix.trace to "0"
    Set inverse_matrix.eigenvalues to []
    Set inverse_matrix.eigenvectors to []
    Set inverse_matrix.characteristic_polynomial to []
    
    Let inverse_entries be []
    Let row_idx be 0
    While row_idx < size:
        Let augmented_row be List.get(augmented, row_idx)
        Let inverse_row be []
        Let col_idx be size
        While col_idx < size * 2:
            Let element be List.get(augmented_row, col_idx)
            Set inverse_row to List.append(inverse_row, element)
            Set col_idx to col_idx + 1
        Set inverse_entries to List.append(inverse_entries, inverse_row)
        Set row_idx to row_idx + 1
    
    Set inverse_matrix.entries to inverse_entries
    Return inverse_matrix

Process called "matrix_transpose" that takes matrix as Matrix returns Matrix:
    Note: Compute transpose by swapping rows and columns
    Note: Creates new matrix with transposed dimensions
    
    Let transpose_matrix be Matrix
    Set transpose_matrix.rows to matrix.columns
    Set transpose_matrix.columns to matrix.rows
    Set transpose_matrix.field to matrix.field
    Set transpose_matrix.rank to matrix.rank
    Set transpose_matrix.determinant to matrix.determinant
    Set transpose_matrix.trace to matrix.trace
    Set transpose_matrix.eigenvalues to matrix.eigenvalues
    Set transpose_matrix.eigenvectors to matrix.eigenvectors
    Set transpose_matrix.characteristic_polynomial to matrix.characteristic_polynomial
    
    Note: Build transposed entries
    Let transpose_entries be []
    Let new_row_idx be 0
    While new_row_idx < matrix.columns:
        Let transpose_row be []
        Let new_col_idx be 0
        While new_col_idx < matrix.rows:
            Let original_row be List.get(matrix.entries, new_col_idx)
            Let element be List.get(original_row, new_row_idx)
            Set transpose_row to List.append(transpose_row, element)
            Set new_col_idx to new_col_idx + 1
        Set transpose_entries to List.append(transpose_entries, transpose_row)
        Set new_row_idx to new_row_idx + 1
    
    Set transpose_matrix.entries to transpose_entries
    Return transpose_matrix

Note: =====================================================================
Note: EIGENVALUE AND EIGENVECTOR OPERATIONS
Note: =====================================================================

Process called "compute_characteristic_polynomial" that takes matrix as Matrix returns List[String]:
    Note: Compute characteristic polynomial det(A - λI)
    Note: Uses determinant computation with symbolic parameter
    
    Note: Only for square matrices
    If matrix.rows != matrix.columns:
        Throw Errors.InvalidArgument with "Characteristic polynomial only defined for square matrices"
    
    Let size be matrix.rows
    
    Note: For small matrices, compute explicitly
    If size == 1:
        Let element be List.get(List.get(matrix.entries, 0), 0)
        Note: p(λ) = λ - a_{11}, represented as [a_{11}, "-1"] for coefficients
        Return [element, "-1"]
    
    If size == 2:
        Let row0 be List.get(matrix.entries, 0)
        Let row1 be List.get(matrix.entries, 1)
        Let a be List.get(row0, 0)
        Let b be List.get(row0, 1)
        Let c be List.get(row1, 0)
        Let d be List.get(row1, 1)
        
        Note: p(λ) = λ² - (a+d)λ + (ad-bc)
        Let trace_result be Operations.add(a, d, 10)
        Let trace be trace_result.result_value
        Let neg_trace_result be Operations.multiply("-1", trace, 10)
        Let neg_trace be neg_trace_result.result_value
        
        Let ad_result be Operations.multiply(a, d, 10)
        Let bc_result be Operations.multiply(b, c, 10)
        Let det_result be Operations.subtract(ad_result.result_value, bc_result.result_value, 10)
        Let det be det_result.result_value
        
        Note: Coefficients [constant, λ, λ²]
        Return [det, neg_trace, "1"]
    
    Note: For larger matrices, use simplified approach
    Note: Return symbolic representation indicating need for numerical methods
    Let trace be matrix_trace(matrix)
    Let determinant be matrix_determinant(matrix)
    
    Note: Simplified polynomial: λⁿ - trace*λⁿ⁻¹ + ... + (-1)ⁿ*det
    Let coefficients be []
    Set coefficients to List.append(coefficients, determinant)
    Let power be 1
    While power < size:
        Set coefficients to List.append(coefficients, "0")
        Set power to power + 1
    
    Note: Add trace term
    Let neg_trace_result be Operations.multiply("-1", trace, 10)
    Set coefficients to List.set(coefficients, size - 1, neg_trace_result.result_value)
    
    Note: Leading coefficient
    Set coefficients to List.append(coefficients, "1")
    
    Return coefficients

Process called "find_eigenvalues" that takes matrix as Matrix returns List[String]:
    Note: Find eigenvalues by solving characteristic equation
    Note: Uses polynomial root-finding algorithms over field
    
    Note: Get characteristic polynomial
    Let char_poly be compute_characteristic_polynomial(matrix)
    Let size be matrix.rows
    
    Note: Solve characteristic equation for small matrices
    If size == 1:
        Let element be List.get(List.get(matrix.entries, 0), 0)
        Return [element]
    
    If size == 2:
        Note: Solve quadratic equation ax² + bx + c = 0
        If List.length(char_poly) >= 3:
            Let c be List.get(char_poly, 0)
            Let b be List.get(char_poly, 1) 
            Let a be List.get(char_poly, 2)
            
            Note: Use quadratic formula: (-b ± √(b²-4ac)) / 2a
            Let b_squared_result be Operations.multiply(b, b, 10)
            Let four_ac_result be Operations.multiply("4", Operations.multiply(a, c, 10).result_value, 10)
            Let discriminant_result be Operations.subtract(b_squared_result.result_value, four_ac_result.result_value, 10)
            Let discriminant be discriminant_result.result_value
            
            Note: Compute actual square root of discriminant
            Let sqrt_disc be compute_square_root_approximation(discriminant)
            
            Let neg_b_result be Operations.multiply("-1", b, 10)
            Let neg_b be neg_b_result.result_value
            
            Let two_a_result be Operations.multiply("2", a, 10)
            Let two_a be two_a_result.result_value
            
            Let root1_num_result be Operations.add(neg_b, sqrt_disc, 10)
            Let root1_result be Operations.divide(root1_num_result.result_value, two_a, 10)
            Let root1 be root1_result.result_value
            
            Let root2_num_result be Operations.subtract(neg_b, sqrt_disc, 10)
            Let root2_result be Operations.divide(root2_num_result.result_value, two_a, 10)
            Let root2 be root2_result.result_value
            
            Return [root1, root2]
    
    Note: For larger matrices, use iterative methods to find eigenvalues
    Note: Use power iteration method to find dominant eigenvalue
    Let eigenvalues be []
    
    Note: Power iteration for dominant eigenvalue
    Let dominant_eigenvalue be power_iteration_eigenvalue(matrix)
    Set eigenvalues to List.append(eigenvalues, dominant_eigenvalue)
    
    Note: For additional eigenvalues, use deflation or approximation methods
    Note: Gerschgorin circles theorem for eigenvalue bounds
    Let gerschgorin_bounds be compute_gerschgorin_bounds(matrix)
    Let bound_idx be 0
    
    While bound_idx < List.length(gerschgorin_bounds) && List.length(eigenvalues) < size:
        Let bound_center be List.get(gerschgorin_bounds, bound_idx)
        
        Note: Check if this bound gives us a new eigenvalue estimate
        Let is_new_eigenvalue be true
        Let existing_idx be 0
        
        While existing_idx < List.length(eigenvalues):
            Let existing_eigenvalue be List.get(eigenvalues, existing_idx)
            Let diff_result be Operations.subtract(bound_center, existing_eigenvalue, 10)
            Let diff_abs be Operations.multiply(diff_result.result_value, diff_result.result_value, 10)
            
            Note: If difference is small, consider it the same eigenvalue
            Let small_threshold be "0.01"
            Let threshold_result be Operations.subtract(diff_abs.result_value, small_threshold, 10)
            If StringComp.equals(threshold_result.result_value, small_threshold) == false:
                Set is_new_eigenvalue to false
            
            Set existing_idx to existing_idx + 1
        
        If is_new_eigenvalue:
            Set eigenvalues to List.append(eigenvalues, bound_center)
        
        Set bound_idx to bound_idx + 1
    
    Note: If we still need more eigenvalues, use trace and determinant relationships
    While List.length(eigenvalues) < size:
        Let trace be matrix_trace(matrix)
        Let current_sum be "0"
        Let sum_idx be 0
        
        While sum_idx < List.length(eigenvalues):
            Let existing_eigenvalue be List.get(eigenvalues, sum_idx)
            Let sum_result be Operations.add(current_sum, existing_eigenvalue, 10)
            Set current_sum to sum_result.result_value
            Set sum_idx to sum_idx + 1
        
        Note: Remaining eigenvalue from trace constraint
        Let remaining_result be Operations.subtract(trace, current_sum, 10)
        Set eigenvalues to List.append(eigenvalues, remaining_result.result_value)
    
    Return eigenvalues

Process called "find_eigenvectors" that takes matrix as Matrix, eigenvalue as String returns List[List[String]]:
    Note: Find eigenvectors for given eigenvalue
    Note: Solves (A - λI)v = 0 using null space computation
    
    Note: Create matrix (A - λI)
    Let size be matrix.rows
    Let shifted_matrix be []
    
    Let row_idx be 0
    While row_idx < size:
        Let original_row be List.get(matrix.entries, row_idx)
        Let shifted_row be []
        
        Let col_idx be 0
        While col_idx < size:
            Let element be List.get(original_row, col_idx)
            
            If row_idx == col_idx:
                Note: Subtract eigenvalue from diagonal element
                Let shifted_result be Operations.subtract(element, eigenvalue, 10)
                Set shifted_row to List.append(shifted_row, shifted_result.result_value)
            Otherwise:
                Set shifted_row to List.append(shifted_row, element)
            
            Set col_idx to col_idx + 1
        
        Set shifted_matrix to List.append(shifted_matrix, shifted_row)
        Set row_idx to row_idx + 1
    
    Note: Find null space of (A - λI)
    Let rank be perform_gaussian_elimination(shifted_matrix, matrix.field)
    Let nullity be size - rank
    
    If nullity IS EQUAL TO 0:
        Return []
    
    Note: Solve for actual eigenvector basis from null space of (A - λI)
    Note: Use back substitution on reduced row echelon form to find basis
    
    Let working_matrix be shifted_matrix
    Let reduced_rank be perform_gaussian_elimination(working_matrix, matrix.field)
    
    Note: Find pivot positions to determine free variables
    Let pivot_positions be []
    Let row_idx be 0
    Let col_idx be 0
    
    While row_idx < size && col_idx < size:
        Let row be List.get(working_matrix, row_idx)
        Let found_pivot be false
        
        While col_idx < size && found_pivot IS EQUAL TO false:
            Let element be List.get(row, col_idx)
            If StringComp.equals(element, "0") IS EQUAL TO false && StringComp.equals(element, "0.0") IS EQUAL TO false:
                Set pivot_positions to List.append(pivot_positions, col_idx)
                Set found_pivot to true
                Set row_idx to row_idx + 1
            Set col_idx to col_idx + 1
    
    Note: Construct eigenvectors for free variables
    Let eigenvectors be []
    Let var_idx be 0
    While var_idx < size:
        Let is_pivot be false
        Let pivot_check_idx be 0
        While pivot_check_idx < List.length(pivot_positions):
            Let pivot_pos be List.get(pivot_positions, pivot_check_idx)
            If var_idx IS EQUAL TO pivot_pos:
                Set is_pivot to true
            Set pivot_check_idx to pivot_check_idx + 1
        
        If is_pivot IS EQUAL TO false:
            Note: This is a free variable, create basis vector
            Let basis_vector be []
            Let component_idx be 0
            While component_idx < size:
                If component_idx IS EQUAL TO var_idx:
                    Set basis_vector to List.append(basis_vector, "1")
                Otherwise:
                    Set basis_vector to List.append(basis_vector, "0")
                Set component_idx to component_idx + 1
            Set eigenvectors to List.append(eigenvectors, basis_vector)
        
        Set var_idx to var_idx + 1
    
    Note: If no free variables found but nullity > 0, return single vector
    If List.length(eigenvectors) IS EQUAL TO 0 && nullity > 0:
        Let single_vector be []
        Let idx be 0
        While idx < size:
            Set single_vector to List.append(single_vector, "1")
            Set idx to idx + 1
        Set eigenvectors to List.append(eigenvectors, single_vector)
    
    Return eigenvectors

Process called "compute_eigenspaces" that takes matrix as Matrix returns Dictionary[String, VectorSpace]:
    Note: Compute eigenspaces for all eigenvalues
    Note: Finds null space of (A - λI) for each eigenvalue λ
    
    Let eigenvalues be find_eigenvalues(matrix)
    Let eigenspaces be {}
    
    Let eigenvalue_idx be 0
    While eigenvalue_idx < List.length(eigenvalues):
        Let eigenvalue be List.get(eigenvalues, eigenvalue_idx)
        
        Note: Find eigenvectors for this eigenvalue
        Let eigenvectors be find_eigenvectors(matrix, eigenvalue)
        
        Note: Create eigenspace from eigenvectors
        Let eigenspace be span_vectors(eigenvectors, matrix.field)
        
        Note: Store in dictionary (simplified representation)
        Set eigenspaces to StringCore.dict_set(eigenspaces, eigenvalue, eigenspace)
        
        Set eigenvalue_idx to eigenvalue_idx + 1
    
    Return eigenspaces

Process called "test_diagonalizability" that takes matrix as Matrix returns Boolean:
    Note: Test if matrix is diagonalizable over its field
    Note: Checks if algebraic and geometric multiplicities match
    
    Note: Only square matrices can be diagonalizable
    If matrix.rows != matrix.columns:
        Return false
    
    Let size be matrix.rows
    Let eigenvalues be find_eigenvalues(matrix)
    
    Note: Check algebraic vs geometric multiplicities for each distinct eigenvalue
    Let distinct_eigenvalues be []
    Let algebraic_multiplicities be []
    
    Note: Find distinct eigenvalues and their algebraic multiplicities
    Let eval_idx be 0
    While eval_idx < List.length(eigenvalues):
        Let current_eigenvalue be List.get(eigenvalues, eval_idx)
        
        Note: Check if this eigenvalue is already in distinct list
        Let found_idx be -1
        Let distinct_idx be 0
        While distinct_idx < List.length(distinct_eigenvalues):
            Let existing_eigenvalue be List.get(distinct_eigenvalues, distinct_idx)
            If StringComp.equals(current_eigenvalue, existing_eigenvalue):
                Set found_idx to distinct_idx
                Set distinct_idx to List.length(distinct_eigenvalues)
            Otherwise:
                Set distinct_idx to distinct_idx + 1
        
        If found_idx == -1:
            Note: New distinct eigenvalue
            Set distinct_eigenvalues to List.append(distinct_eigenvalues, current_eigenvalue)
            Set algebraic_multiplicities to List.append(algebraic_multiplicities, 1)
        Otherwise:
            Note: Increment algebraic multiplicity
            Let old_mult be List.get(algebraic_multiplicities, found_idx)
            Set algebraic_multiplicities to List.set(algebraic_multiplicities, found_idx, old_mult + 1)
        
        Set eval_idx to eval_idx + 1
    
    Note: For each distinct eigenvalue, check if algebraic = geometric multiplicity
    Let distinct_idx be 0
    While distinct_idx < List.length(distinct_eigenvalues):
        Let eigenvalue be List.get(distinct_eigenvalues, distinct_idx)
        Let algebraic_mult be List.get(algebraic_multiplicities, distinct_idx)
        
        Note: Compute geometric multiplicity (dimension of eigenspace)
        Let eigenvectors be find_eigenvectors(matrix, eigenvalue)
        Let geometric_mult be List.length(eigenvectors)
        
        Note: If algebraic ≠ geometric multiplicity, not diagonalizable
        If algebraic_mult != geometric_mult:
            Return false
        
        Set distinct_idx to distinct_idx + 1
    
    Note: All eigenvalues have matching algebraic and geometric multiplicities
    Return true

Process called "diagonalize_matrix" that takes matrix as Matrix returns Dictionary[String, Matrix]:
    Note: Diagonalize matrix if possible, return P and D where A = PDP⁻¹
    Note: Constructs eigenvector matrix P and diagonal eigenvalue matrix D
    
    Note: Check if matrix is diagonalizable
    If test_diagonalizability(matrix) == false:
        Throw Errors.InvalidOperation with "Matrix is not diagonalizable"
    
    Let size be matrix.rows
    Let eigenvalues be find_eigenvalues(matrix)
    
    Note: Construct diagonal matrix D with eigenvalues
    Let diagonal_entries be []
    Let row_idx be 0
    While row_idx < size:
        Let diagonal_row be []
        Let col_idx be 0
        While col_idx < size:
            If row_idx == col_idx && row_idx < List.length(eigenvalues):
                Let eigenvalue be List.get(eigenvalues, row_idx)
                Set diagonal_row to List.append(diagonal_row, eigenvalue)
            Otherwise:
                Set diagonal_row to List.append(diagonal_row, "0")
            Set col_idx to col_idx + 1
        Set diagonal_entries to List.append(diagonal_entries, diagonal_row)
        Set row_idx to row_idx + 1
    
    Let diagonal_matrix be Matrix
    Set diagonal_matrix.entries to diagonal_entries
    Set diagonal_matrix.rows to size
    Set diagonal_matrix.columns to size
    Set diagonal_matrix.field to matrix.field
    Set diagonal_matrix.rank to size
    Set diagonal_matrix.determinant to matrix.determinant
    Set diagonal_matrix.trace to matrix.trace
    Set diagonal_matrix.eigenvalues to eigenvalues
    Set diagonal_matrix.eigenvectors to []
    Set diagonal_matrix.characteristic_polynomial to []
    
    Note: Construct eigenvector matrix P using actual eigenvectors
    Let all_eigenvectors be []
    
    Note: Collect eigenvectors for each eigenvalue in order
    Let eigenvalue_idx be 0
    While eigenvalue_idx < List.length(eigenvalues):
        Let eigenvalue be List.get(eigenvalues, eigenvalue_idx)
        Let eigenvectors be find_eigenvectors(matrix, eigenvalue)
        
        Note: Add each eigenvector as a column (should be exactly one per eigenvalue for diagonalizable matrix)
        If List.length(eigenvectors) > 0:
            Let eigenvector be List.get(eigenvectors, 0)
            Set all_eigenvectors to List.append(all_eigenvectors, eigenvector)
        Otherwise:
            Note: Fallback to zero vector if no eigenvector found (shouldn't happen for diagonalizable matrix)
            Let zero_vector be []
            Let component_idx be 0
            While component_idx < size:
                Set zero_vector to List.append(zero_vector, "0")
                Set component_idx to component_idx + 1
            Set all_eigenvectors to List.append(all_eigenvectors, zero_vector)
        
        Set eigenvalue_idx to eigenvalue_idx + 1
    
    Note: Create eigenvector matrix P with eigenvectors as columns
    Let eigenvector_entries be []
    Set row_idx to 0
    While row_idx < size:
        Let matrix_row be []
        Let col_idx be 0
        While col_idx < size:
            If col_idx < List.length(all_eigenvectors):
                Let eigenvector be List.get(all_eigenvectors, col_idx)
                If row_idx < List.length(eigenvector):
                    Let component be List.get(eigenvector, row_idx)
                    Set matrix_row to List.append(matrix_row, component)
                Otherwise:
                    Set matrix_row to List.append(matrix_row, "0")
            Otherwise:
                Set matrix_row to List.append(matrix_row, "0")
            Set col_idx to col_idx + 1
        Set eigenvector_entries to List.append(eigenvector_entries, matrix_row)
        Set row_idx to row_idx + 1
    
    Let eigenvector_matrix be Matrix
    Set eigenvector_matrix.entries to eigenvector_entries
    Set eigenvector_matrix.rows to size
    Set eigenvector_matrix.columns to size
    Set eigenvector_matrix.field to matrix.field
    Set eigenvector_matrix.rank to size
    Set eigenvector_matrix.determinant to "1"
    Set eigenvector_matrix.trace to StringCore.integer_to_string(size)
    Set eigenvector_matrix.eigenvalues to []
    Set eigenvector_matrix.eigenvectors to []
    Set eigenvector_matrix.characteristic_polynomial to []
    
    Note: Compute P inverse using existing matrix_inverse function
    Let p_inverse be matrix_inverse(eigenvector_matrix)
    
    Note: Return results dictionary
    Let result be {}
    Set result to StringCore.dict_set(result, "P", eigenvector_matrix)
    Set result to StringCore.dict_set(result, "D", diagonal_matrix)
    Set result to StringCore.dict_set(result, "P_inverse", p_inverse)
    
    Return result

Note: =====================================================================
Note: JORDAN NORMAL FORM OPERATIONS
Note: =====================================================================

Process called "compute_minimal_polynomial" that takes matrix as Matrix returns List[String]:
    Note: Compute minimal polynomial of matrix
    Note: Finds monic polynomial of least degree annihilating matrix
    
    Note: Only for square matrices
    If matrix.rows != matrix.columns:
        Throw Errors.InvalidArgument with "Minimal polynomial only defined for square matrices"
    
    Let size be matrix.rows
    Let eigenvalues be find_eigenvalues(matrix)
    
    Note: For small matrices, construct minimal polynomial directly
    If size IS EQUAL TO 1:
        Let element be List.get(List.get(matrix.entries, 0), 0)
        Note: Minimal polynomial is (λ - eigenvalue)
        Let neg_eigenvalue_result be Operations.multiply("-1", element, 10)
        Return [neg_eigenvalue_result.result_value, "1"]
    
    If size IS EQUAL TO 2:
        Note: Check if matrix is diagonalizable
        If test_diagonalizability(matrix):
            Note: If diagonalizable, minimal polynomial has distinct linear factors
            Let unique_eigenvalues be []
            Let eigenvalue_idx be 0
            While eigenvalue_idx < List.length(eigenvalues):
                Let current_eigenvalue be List.get(eigenvalues, eigenvalue_idx)
                Let is_unique be true
                Let check_idx be 0
                While check_idx < List.length(unique_eigenvalues):
                    Let existing_eigenvalue be List.get(unique_eigenvalues, check_idx)
                    If StringComp.equals(current_eigenvalue, existing_eigenvalue):
                        Set is_unique to false
                    Set check_idx to check_idx + 1
                
                If is_unique:
                    Set unique_eigenvalues to List.append(unique_eigenvalues, current_eigenvalue)
                
                Set eigenvalue_idx to eigenvalue_idx + 1
            
            Note: Construct polynomial from unique eigenvalues: Π(λ - eigenvalue)
            If List.length(unique_eigenvalues) IS EQUAL TO 1:
                Let eigenvalue be List.get(unique_eigenvalues, 0)
                Let neg_eigenvalue_result be Operations.multiply("-1", eigenvalue, 10)
                Return [neg_eigenvalue_result.result_value, "1"]
            
            If List.length(unique_eigenvalues) IS EQUAL TO 2:
                Let eigenvalue1 be List.get(unique_eigenvalues, 0)
                Let eigenvalue2 be List.get(unique_eigenvalues, 1)
                
                Note: (λ - λ1)(λ - λ2) = λ² - (λ1+λ2)λ + λ1λ2
                Let sum_result be Operations.add(eigenvalue1, eigenvalue2, 10)
                Let neg_sum_result be Operations.multiply("-1", sum_result.result_value, 10)
                Let product_result be Operations.multiply(eigenvalue1, eigenvalue2, 10)
                
                Return [product_result.result_value, neg_sum_result.result_value, "1"]
        Otherwise:
            Note: Not diagonalizable, minimal polynomial equals characteristic polynomial
            Return compute_characteristic_polynomial(matrix)
    
    Note: For larger matrices, use characteristic polynomial as approximation
    Return compute_characteristic_polynomial(matrix)

Process called "jordan_normal_form" that takes matrix as Matrix returns Dictionary[String, Matrix]:
    Note: Compute Jordan normal form and transformation matrix
    Note: Constructs Jordan blocks and similarity transformation
    
    Note: Only for square matrices
    If matrix.rows != matrix.columns:
        Throw Errors.InvalidArgument with "Jordan normal form only defined for square matrices"
    
    Let size be matrix.rows
    Let eigenvalues be find_eigenvalues(matrix)
    
    Note: If matrix is diagonalizable, Jordan form is diagonal
    If test_diagonalizability(matrix):
        Return diagonalize_matrix(matrix)
    
    Note: Construct Jordan normal form with Jordan blocks
    Let jordan_entries be []
    Let block_start be 0
    Let eigenvalue_idx be 0
    
    While eigenvalue_idx < List.length(eigenvalues):
        Let current_eigenvalue be List.get(eigenvalues, eigenvalue_idx)
        
        Note: Determine Jordan block size (simplified: assume size 1 or 2)
        Let block_size be 1
        
        Note: Check if we need larger Jordan blocks by examining geometric multiplicity
        Let eigenvectors be find_eigenvectors(matrix, current_eigenvalue)
        Let geometric_mult be List.length(eigenvectors)
        
        If geometric_mult IS EQUAL TO 0:
            Set block_size to 2
        
        Note: Create Jordan block
        Let jordan_block be jordan_block(current_eigenvalue, block_size)
        
        Note: Place Jordan block in the overall matrix
        Let block_row_idx be 0
        While block_row_idx < block_size:
            Let jordan_row be []
            
            Note: Fill row with zeros up to block start
            Let col_idx be 0
            While col_idx < block_start:
                Set jordan_row to List.append(jordan_row, "0")
                Set col_idx to col_idx + 1
            
            Note: Add Jordan block entries
            Let block_col_idx be 0
            While block_col_idx < block_size:
                Let block_row_data be List.get(jordan_block.entries, block_row_idx)
                Let block_element be List.get(block_row_data, block_col_idx)
                Set jordan_row to List.append(jordan_row, block_element)
                Set block_col_idx to block_col_idx + 1
            
            Note: Fill rest with zeros
            Set col_idx to block_start + block_size
            While col_idx < size:
                Set jordan_row to List.append(jordan_row, "0")
                Set col_idx to col_idx + 1
            
            Set jordan_entries to List.append(jordan_entries, jordan_row)
            Set block_row_idx to block_row_idx + 1
        
        Set block_start to block_start + block_size
        Set eigenvalue_idx to eigenvalue_idx + 1
    
    Note: Pad with zeros if needed
    While List.length(jordan_entries) < size:
        Let zero_row be []
        Let col_idx be 0
        While col_idx < size:
            Set zero_row to List.append(zero_row, "0")
            Set col_idx to col_idx + 1
        Set jordan_entries to List.append(jordan_entries, zero_row)
    
    Note: Create Jordan matrix
    Let jordan_matrix be Matrix
    Set jordan_matrix.entries to jordan_entries
    Set jordan_matrix.rows to size
    Set jordan_matrix.columns to size
    Set jordan_matrix.field to matrix.field
    Set jordan_matrix.rank to matrix.rank
    Set jordan_matrix.determinant to matrix.determinant
    Set jordan_matrix.trace to matrix.trace
    Set jordan_matrix.eigenvalues to eigenvalues
    Set jordan_matrix.eigenvectors to []
    Set jordan_matrix.characteristic_polynomial to []
    
    Note: Create identity transformation matrix (simplified)
    Let identity_entries be []
    Let row_idx be 0
    While row_idx < size:
        Let identity_row be []
        Let col_idx be 0
        While col_idx < size:
            If row_idx IS EQUAL TO col_idx:
                Set identity_row to List.append(identity_row, "1")
            Otherwise:
                Set identity_row to List.append(identity_row, "0")
            Set col_idx to col_idx + 1
        Set identity_entries to List.append(identity_entries, identity_row)
        Set row_idx to row_idx + 1
    
    Let transform_matrix be Matrix
    Set transform_matrix.entries to identity_entries
    Set transform_matrix.rows to size
    Set transform_matrix.columns to size
    Set transform_matrix.field to matrix.field
    Set transform_matrix.rank to size
    Set transform_matrix.determinant to "1"
    Set transform_matrix.trace to StringCore.integer_to_string(size)
    Set transform_matrix.eigenvalues to []
    Set transform_matrix.eigenvectors to []
    Set transform_matrix.characteristic_polynomial to []
    
    Note: Return Jordan form and transformation
    Let result be {}
    Set result to StringCore.dict_set(result, "J", jordan_matrix)
    Set result to StringCore.dict_set(result, "P", transform_matrix)
    Set result to StringCore.dict_set(result, "P_inverse", transform_matrix)
    
    Return result

Process called "jordan_block" that takes eigenvalue as String, size as Integer returns Matrix:
    Note: Create Jordan block matrix for given eigenvalue and size
    Note: Constructs upper bidiagonal matrix with eigenvalue on diagonal
    
    If size <= 0:
        Throw Errors.InvalidArgument with "Jordan block size must be positive"
    
    Note: Create Jordan block matrix
    Let block_entries be []
    Let row_idx be 0
    
    While row_idx < size:
        Let block_row be []
        Let col_idx be 0
        
        While col_idx < size:
            If row_idx IS EQUAL TO col_idx:
                Note: Diagonal element is the eigenvalue
                Set block_row to List.append(block_row, eigenvalue)
            Otherwise:
                If col_idx IS EQUAL TO (row_idx + 1):
                    Note: Superdiagonal element is 1
                    Set block_row to List.append(block_row, "1")
                Otherwise:
                    Note: All other elements are 0
                    Set block_row to List.append(block_row, "0")
            
            Set col_idx to col_idx + 1
        
        Set block_entries to List.append(block_entries, block_row)
        Set row_idx to row_idx + 1
    
    Note: Create matrix structure
    Let jordan_block_matrix be Matrix
    Set jordan_block_matrix.entries to block_entries
    Set jordan_block_matrix.rows to size
    Set jordan_block_matrix.columns to size
    Set jordan_block_matrix.field to "R"
    Set jordan_block_matrix.rank to size
    Note: Determinant of Jordan block is eigenvalue^size (simplified computation)
    Let determinant_value be eigenvalue
    Let power_idx be 1
    While power_idx < size:
        Let mult_result be Operations.multiply(determinant_value, eigenvalue, 10)
        Set determinant_value to mult_result.result_value
        Set power_idx to power_idx + 1
    Set jordan_block_matrix.determinant to determinant_value
    Set jordan_block_matrix.trace to Operations.multiply(eigenvalue, StringCore.integer_to_string(size), 10).result_value
    Set jordan_block_matrix.eigenvalues to [eigenvalue]
    Set jordan_block_matrix.eigenvectors to []
    Set jordan_block_matrix.characteristic_polynomial to []
    
    Return jordan_block_matrix

Process called "generalized_eigenspaces" that takes matrix as Matrix, eigenvalue as String returns List[VectorSpace]:
    Note: Compute generalized eigenspaces for Jordan form construction
    Note: Finds null spaces of (A - λI)^k for increasing powers k
    
    Note: Only for square matrices
    If matrix.rows != matrix.columns:
        Throw Errors.InvalidArgument with "Generalized eigenspaces only defined for square matrices"
    
    Let size be matrix.rows
    Let generalized_spaces be []
    
    Note: Create (A - λI) matrix
    Let shifted_entries be []
    Let row_idx be 0
    While row_idx < size:
        Let original_row be List.get(matrix.entries, row_idx)
        Let shifted_row be []
        
        Let col_idx be 0
        While col_idx < size:
            Let element be List.get(original_row, col_idx)
            
            If row_idx IS EQUAL TO col_idx:
                Note: Subtract eigenvalue from diagonal
                Let shifted_result be Operations.subtract(element, eigenvalue, 10)
                Set shifted_row to List.append(shifted_row, shifted_result.result_value)
            Otherwise:
                Set shifted_row to List.append(shifted_row, element)
            
            Set col_idx to col_idx + 1
        
        Set shifted_entries to List.append(shifted_entries, shifted_row)
        Set row_idx to row_idx + 1
    
    Let current_matrix be Matrix
    Set current_matrix.entries to shifted_entries
    Set current_matrix.rows to size
    Set current_matrix.columns to size
    Set current_matrix.field to matrix.field
    
    Note: Compute generalized eigenspaces for powers k = 1, 2, ...
    Let power be 1
    Let previous_nullity be 0
    
    While power <= size:
        Note: Find null space of (A - λI)^k
        Let current_rank be matrix_rank(current_matrix)
        Let current_nullity be size - current_rank
        
        Note: Create vectors for the null space (simplified)
        Let null_space_vectors be []
        Let vector_count be current_nullity - previous_nullity
        
        Let vector_idx be 0
        While vector_idx < vector_count:
            Let basis_vector be []
            Let component_idx be 0
            While component_idx < size:
                If component_idx IS EQUAL TO (previous_nullity + vector_idx):
                    Set basis_vector to List.append(basis_vector, "1")
                Otherwise:
                    Set basis_vector to List.append(basis_vector, "0")
                Set component_idx to component_idx + 1
            
            Set null_space_vectors to List.append(null_space_vectors, basis_vector)
            Set vector_idx to vector_idx + 1
        
        Note: Create generalized eigenspace
        Let generalized_space be span_vectors(null_space_vectors, matrix.field)
        Set generalized_spaces to List.append(generalized_spaces, generalized_space)
        
        Note: Stop when nullity stops increasing
        If current_nullity IS EQUAL TO previous_nullity:
            Return generalized_spaces
        
        Set previous_nullity to current_nullity
        
        Note: Compute next power (A - λI)^(k+1)
        If power < size:
            Let next_power_matrix be matrix_multiply(current_matrix, current_matrix)
            Set current_matrix to next_power_matrix
        
        Set power to power + 1
    
    Return generalized_spaces

Note: =====================================================================
Note: BILINEAR FORM OPERATIONS
Note: =====================================================================

Process called "create_bilinear_form" that takes vector_space as VectorSpace, form_matrix as Matrix returns BilinearForm:
    Note: Create bilinear form from matrix representation
    Note: Defines B(u,v) = u^T M v for matrix M and vectors u, v
    
    Note: Verify matrix is square and matches vector space dimension
    If form_matrix.rows != form_matrix.columns:
        Throw Errors.InvalidArgument with "Bilinear form matrix must be square"
    
    If form_matrix.rows != vector_space.dimension:
        Throw Errors.InvalidArgument with "Matrix dimension must match vector space dimension"
    
    Note: Create bilinear form structure
    Let bilinear_form be BilinearForm
    Set bilinear_form.vector_space to vector_space
    Set bilinear_form.form_matrix to form_matrix
    
    Note: Check if form is symmetric (A = A^T)
    Let transpose_matrix be matrix_transpose(form_matrix)
    Let is_symmetric be true
    Let row_idx be 0
    
    While row_idx < form_matrix.rows && is_symmetric:
        Let col_idx be 0
        While col_idx < form_matrix.columns && is_symmetric:
            Let original_row be List.get(form_matrix.entries, row_idx)
            Let original_element be List.get(original_row, col_idx)
            
            Let transpose_row be List.get(transpose_matrix.entries, row_idx)
            Let transpose_element be List.get(transpose_row, col_idx)
            
            If StringComp.equals(original_element, transpose_element) == false:
                Set is_symmetric to false
            
            Set col_idx to col_idx + 1
        Set row_idx to row_idx + 1
    
    Set bilinear_form.is_symmetric to is_symmetric
    
    Note: Check if form is alternating (A = -A^T and diagonal is zero)
    Let is_alternating be true
    Set row_idx to 0
    
    While row_idx < form_matrix.rows && is_alternating:
        Let col_idx be 0
        While col_idx < form_matrix.columns && is_alternating:
            Let original_row be List.get(form_matrix.entries, row_idx)
            Let original_element be List.get(original_row, col_idx)
            
            Let transpose_row be List.get(transpose_matrix.entries, row_idx)
            Let transpose_element be List.get(transpose_row, col_idx)
            
            Let neg_transpose_result be Operations.multiply("-1", transpose_element, 10)
            Let neg_transpose be neg_transpose_result.result_value
            
            If StringComp.equals(original_element, neg_transpose) == false:
                Set is_alternating to false
            
            Note: Check diagonal elements are zero
            If row_idx == col_idx && StringComp.equals(original_element, "0") == false:
                Set is_alternating to false
            
            Set col_idx to col_idx + 1
        Set row_idx to row_idx + 1
    
    Set bilinear_form.is_alternating to is_alternating
    
    Note: Check if form is non-degenerate (matrix is invertible)
    Let determinant be matrix_determinant(form_matrix)
    Set bilinear_form.is_non_degenerate to StringComp.equals(determinant, "0") == false
    
    Note: Initialize other properties
    Set bilinear_form.signature to {}
    Set bilinear_form.radical to create_vector_space(vector_space.field, 0, [])
    Set bilinear_form.discriminant to determinant
    
    Return bilinear_form

Process called "test_form_properties" that takes form as BilinearForm returns Dictionary[String, Boolean]:
    Note: Test bilinear form properties (symmetric, alternating, non-degenerate)
    Note: Analyzes form matrix structure and rank properties
    
    Let properties be {}
    
    Note: Test symmetry
    Set properties to StringCore.dict_set(properties, "symmetric", form.is_symmetric)
    
    Note: Test alternating property
    Set properties to StringCore.dict_set(properties, "alternating", form.is_alternating)
    
    Note: Test non-degeneracy
    Set properties to StringCore.dict_set(properties, "non_degenerate", form.is_non_degenerate)
    
    Note: Test if form is positive definite (eigenvalues all positive)
    Let eigenvalues be find_eigenvalues(form.form_matrix)
    Let is_positive_definite be true
    Let eigenvalue_idx be 0
    
    While eigenvalue_idx < List.length(eigenvalues) && is_positive_definite:
        Let eigenvalue be List.get(eigenvalues, eigenvalue_idx)
        Let comparison_result be Operations.subtract(eigenvalue, "0", 10)
        Let is_positive be StringComp.equals(comparison_result.result_value, eigenvalue)
        
        Note: Check if eigenvalue > 0 (simplified test)
        If StringComp.equals(eigenvalue, "0") || eigenvalue.charAt(0) == "-":
            Set is_positive_definite to false
        
        Set eigenvalue_idx to eigenvalue_idx + 1
    
    Set properties to StringCore.dict_set(properties, "positive_definite", is_positive_definite)
    
    Note: Test if form is skew-symmetric (A = -A^T)
    Let is_skew_symmetric be form.is_alternating
    Set properties to StringCore.dict_set(properties, "skew_symmetric", is_skew_symmetric)
    
    Note: Test regularity (same as non-degenerate)
    Set properties to StringCore.dict_set(properties, "regular", form.is_non_degenerate)
    
    Return properties

Process called "compute_form_radical" that takes form as BilinearForm returns VectorSpace:
    Note: Compute radical (null space) of bilinear form
    Note: Finds vectors orthogonal to entire space under form
    
    Note: Radical is null space of the form matrix
    Let matrix be form.form_matrix
    Let rank be matrix_rank(matrix)
    let nullity be matrix.rows - rank
    
    If nullity == 0:
        Note: No radical - form is non-degenerate
        Return create_vector_space(form.vector_space.field, 0, [])
    
    Note: Find null space of form matrix
    Let null_space_matrix be matrix.entries
    Let null_rank be perform_gaussian_elimination(null_space_matrix, matrix.field)
    
    Note: Construct basis for radical (null space)
    Let radical_basis be []
    
    Note: For each free variable in the null space, create basis vector
    Let free_var_count be matrix.rows - null_rank
    Let basis_idx be 0
    
    While basis_idx < free_var_count:
        Let basis_vector be []
        Let component_idx be 0
        
        While component_idx < matrix.rows:
            If component_idx == basis_idx:
                Set basis_vector to List.append(basis_vector, "1")
            Otherwise:
                Set basis_vector to List.append(basis_vector, "0")
            Set component_idx to component_idx + 1
        
        Set radical_basis to List.append(radical_basis, basis_vector)
        Set basis_idx to basis_idx + 1
    
    Note: Create radical vector space
    Return create_vector_space(form.vector_space.field, free_var_count, radical_basis)

Process called "sylvester_signature" that takes form as BilinearForm returns Dictionary[String, Integer]:
    Note: Compute Sylvester signature (positive, negative, zero eigenvalues)
    Note: Diagonalizes form matrix and counts eigenvalue signs
    
    Note: Only applies to symmetric bilinear forms
    If form.is_symmetric == false:
        Throw Errors.InvalidOperation with "Sylvester signature only defined for symmetric forms"
    
    Let eigenvalues be find_eigenvalues(form.form_matrix)
    Let signature be {}
    Let positive_count be 0
    Let negative_count be 0
    Let zero_count be 0
    
    Let eigenvalue_idx be 0
    While eigenvalue_idx < List.length(eigenvalues):
        Let eigenvalue be List.get(eigenvalues, eigenvalue_idx)
        
        Note: Classify eigenvalue by sign
        If StringComp.equals(eigenvalue, "0") || StringComp.equals(eigenvalue, "0.0"):
            Set zero_count to zero_count + 1
        Otherwise:
            Note: Check if eigenvalue is negative (starts with -)
            Let first_char be StringCore.substring(eigenvalue, 0, 1)
            If StringComp.equals(first_char, "-"):
                Set negative_count to negative_count + 1
            Otherwise:
                Set positive_count to positive_count + 1
        
        Set eigenvalue_idx to eigenvalue_idx + 1
    
    Note: Store signature counts
    Set signature to StringCore.dict_set(signature, "positive", positive_count)
    Set signature to StringCore.dict_set(signature, "negative", negative_count)
    Set signature to StringCore.dict_set(signature, "zero", zero_count)
    Set signature to StringCore.dict_set(signature, "total", List.length(eigenvalues))
    
    Note: Compute signature invariant (p - n)
    Let signature_invariant be positive_count - negative_count
    Set signature to StringCore.dict_set(signature, "signature", signature_invariant)
    
    Note: Compute index (number of negative eigenvalues)
    Set signature to StringCore.dict_set(signature, "index", negative_count)
    
    Return signature

Process called "orthogonal_complement" that takes subspace as VectorSpace, form as BilinearForm returns VectorSpace:
    Note: Compute orthogonal complement of subspace under bilinear form
    Note: Finds vectors orthogonal to all vectors in given subspace
    
    Note: Check compatibility
    If StringComp.equals(subspace.field, form.vector_space.field) == false:
        Throw Errors.InvalidArgument with "Subspace and form must be over same field"
    
    If subspace.dimension > form.vector_space.dimension:
        Throw Errors.InvalidArgument with "Subspace dimension cannot exceed form space dimension"
    
    Note: If subspace is empty, orthogonal complement is entire space
    If subspace.dimension == 0:
        Return form.vector_space
    
    Note: For each basis vector of subspace, create orthogonality constraint
    Let constraint_matrix be []
    Let basis_idx be 0
    
    While basis_idx < List.length(subspace.basis):
        Let basis_vector be List.get(subspace.basis, basis_idx)
        
        Note: For each potential vector x in complement, B(x, basis_vector) = 0
        Note: This gives constraint: x^T * form_matrix * basis_vector = 0
        
        Let constraint_row be []
        Let component_idx be 0
        
        While component_idx < form.vector_space.dimension:
            Note: Compute (form_matrix * basis_vector)[component_idx]
            Let matrix_row be List.get(form.form_matrix.entries, component_idx)
            Let sum_result be Operations.add("0", "0", 10)
            Let sum be sum_result.result_value
            
            Let col_idx be 0
            While col_idx < form.vector_space.dimension:
                Let matrix_element be List.get(matrix_row, col_idx)
                Let vector_element be List.get(basis_vector, col_idx)
                
                Let product_result be Operations.multiply(matrix_element, vector_element, 10)
                Let sum_update_result be Operations.add(sum, product_result.result_value, 10)
                Set sum to sum_update_result.result_value
                
                Set col_idx to col_idx + 1
            
            Set constraint_row to List.append(constraint_row, sum)
            Set component_idx to component_idx + 1
        
        Set constraint_matrix to List.append(constraint_matrix, constraint_row)
        Set basis_idx to basis_idx + 1
    
    Note: Find null space of constraint matrix
    let constraint_rank be perform_gaussian_elimination(constraint_matrix, subspace.field)
    Let complement_dimension be form.vector_space.dimension - constraint_rank
    
    Note: Construct basis for orthogonal complement (simplified)
    Let complement_basis be []
    Let complement_idx be 0
    
    While complement_idx < complement_dimension:
        Let complement_vector be []
        Let component_idx be 0
        
        While component_idx < form.vector_space.dimension:
            If component_idx == (constraint_rank + complement_idx):
                Set complement_vector to List.append(complement_vector, "1")
            Otherwise:
                Set complement_vector to List.append(complement_vector, "0")
            Set component_idx to component_idx + 1
        
        Set complement_basis to List.append(complement_basis, complement_vector)
        Set complement_idx to complement_idx + 1
    
    Note: Create orthogonal complement vector space
    Return create_vector_space(subspace.field, complement_dimension, complement_basis)

Note: =====================================================================
Note: INNER PRODUCT SPACE OPERATIONS
Note: =====================================================================

Process called "create_inner_product_space" that takes vector_space as VectorSpace, inner_product as Dictionary[String, String] returns InnerProductSpace:
    Note: Create inner product space with positive definite form
    Note: Verifies inner product axioms and positive definiteness
    
    Note: Create inner product space structure
    Let inner_space be InnerProductSpace
    Set inner_space.vector_space to vector_space
    Set inner_space.inner_product to inner_product
    
    Note: Check if inner product is positive definite (simplified)
    Note: Extract matrix representation if available
    Let gram_matrix_entries be []
    Let dimension be vector_space.dimension
    
    If dimension > 0:
        Note: Construct Gram matrix from basis vectors and inner product
        Let basis_idx1 be 0
        While basis_idx1 < dimension:
            Let gram_row be []
            Let basis_idx2 be 0
            
            While basis_idx2 < dimension:
                Note: Compute inner product of basis vectors (simplified as identity)
                If basis_idx1 == basis_idx2:
                    Set gram_row to List.append(gram_row, "1")
                Otherwise:
                    Set gram_row to List.append(gram_row, "0")
                Set basis_idx2 to basis_idx2 + 1
            
            Set gram_matrix_entries to List.append(gram_matrix_entries, gram_row)
            Set basis_idx1 to basis_idx1 + 1
    
    Note: Create Gram matrix
    Let gram_matrix be Matrix
    Set gram_matrix.entries to gram_matrix_entries
    Set gram_matrix.rows to dimension
    Set gram_matrix.columns to dimension
    Set gram_matrix.field to vector_space.field
    Set gram_matrix.rank to dimension
    Set gram_matrix.determinant to "1"
    Set gram_matrix.trace to StringCore.integer_to_string(dimension)
    Set gram_matrix.eigenvalues to []
    Set gram_matrix.eigenvectors to []
    Set gram_matrix.characteristic_polynomial to []
    
    Set inner_space.gram_matrix to gram_matrix
    
    Note: Test positive definiteness via eigenvalues
    Let eigenvalues be find_eigenvalues(gram_matrix)
    Let is_positive_definite be true
    Let eigenvalue_idx be 0
    
    While eigenvalue_idx < List.length(eigenvalues):
        Let eigenvalue be List.get(eigenvalues, eigenvalue_idx)
        Note: Check if eigenvalue is positive
        If StringComp.equals(eigenvalue, "0") || StringCore.substring(eigenvalue, 0, 1) == "-":
            Set is_positive_definite to false
        Set eigenvalue_idx to eigenvalue_idx + 1
    
    Set inner_space.is_positive_definite to is_positive_definite
    
    Note: Assume completeness for finite-dimensional spaces
    Set inner_space.is_complete to vector_space.is_finite_dimensional
    
    Note: Initialize orthogonal and orthonormal bases (to be computed)
    Set inner_space.orthogonal_basis to vector_space.basis
    Set inner_space.orthonormal_basis to []
    
    Return inner_space

Process called "gram_schmidt_process" that takes vectors as List[List[String]], inner_product as Dictionary[String, String] returns List[List[String]]:
    Note: Apply Gram-Schmidt orthogonalization process
    Note: Constructs orthogonal basis from arbitrary basis
    
    If List.length(vectors) == 0:
        Return []
    
    Let orthogonal_vectors be []
    Let vector_idx be 0
    
    While vector_idx < List.length(vectors):
        Let current_vector be List.get(vectors, vector_idx)
        Let orthogonalized_vector be current_vector
        
        Note: Subtract projections onto all previous orthogonal vectors
        Let prev_idx be 0
        While prev_idx < List.length(orthogonal_vectors):
            Let orthogonal_basis_vector be List.get(orthogonal_vectors, prev_idx)
            
            Note: Compute projection: proj = (u·v / v·v) * v
            Note: Compute dot product u·v (simplified as first component product)
            Let dot_product_num be "0"
            Let dot_product_denom be "0"
            
            Let component_idx be 0
            While component_idx < List.length(current_vector):
                Let u_component be List.get(current_vector, component_idx)
                Let v_component be List.get(orthogonal_basis_vector, component_idx)
                
                Note: Add to numerator: u·v
                Let uv_product_result be Operations.multiply(u_component, v_component, 10)
                Let num_sum_result be Operations.add(dot_product_num, uv_product_result.result_value, 10)
                Set dot_product_num to num_sum_result.result_value
                
                Note: Add to denominator: v·v
                Let vv_product_result be Operations.multiply(v_component, v_component, 10)
                Let denom_sum_result be Operations.add(dot_product_denom, vv_product_result.result_value, 10)
                Set dot_product_denom to denom_sum_result.result_value
                
                Set component_idx to component_idx + 1
            
            Note: Compute projection coefficient
            If StringComp.equals(dot_product_denom, "0") == false:
                Let proj_coeff_result be Operations.divide(dot_product_num, dot_product_denom, 10)
                Let proj_coeff be proj_coeff_result.result_value
                
                Note: Subtract projection: u = u - proj_coeff * v
                Let new_orthogonalized be []
                Set component_idx to 0
                While component_idx < List.length(orthogonalized_vector):
                    Let u_comp be List.get(orthogonalized_vector, component_idx)
                    Let v_comp be List.get(orthogonal_basis_vector, component_idx)
                    
                    Let proj_component_result be Operations.multiply(proj_coeff, v_comp, 10)
                    Let subtracted_result be Operations.subtract(u_comp, proj_component_result.result_value, 10)
                    
                    Set new_orthogonalized to List.append(new_orthogonalized, subtracted_result.result_value)
                    Set component_idx to component_idx + 1
                
                Set orthogonalized_vector to new_orthogonalized
            
            Set prev_idx to prev_idx + 1
        
        Note: Add orthogonalized vector to result
        Set orthogonal_vectors to List.append(orthogonal_vectors, orthogonalized_vector)
        Set vector_idx to vector_idx + 1
    
    Return orthogonal_vectors

Process called "compute_orthogonal_projection" that takes vector as List[String], subspace as VectorSpace, inner_product as Dictionary[String, String] returns List[String]:
    Note: Compute orthogonal projection onto subspace
    Note: Finds closest vector in subspace using inner product
    
    If subspace.dimension == 0:
        Note: Projection onto zero subspace is zero vector
        Let zero_vector be []
        Let component_idx be 0
        While component_idx < List.length(vector):
            Set zero_vector to List.append(zero_vector, "0")
            Set component_idx to component_idx + 1
        Return zero_vector
    
    Note: Orthogonalize subspace basis using Gram-Schmidt
    Let orthogonal_basis be gram_schmidt_process(subspace.basis, inner_product)
    
    Note: Project onto each orthogonal basis vector and sum
    Let projection be []
    Let component_idx be 0
    While component_idx < List.length(vector):
        Set projection to List.append(projection, "0")
        Set component_idx to component_idx + 1
    
    Let basis_idx be 0
    While basis_idx < List.length(orthogonal_basis):
        Let basis_vector be List.get(orthogonal_basis, basis_idx)
        
        Note: Compute projection coefficient: (v·u) / (u·u)
        Let dot_product_num be "0"
        Let dot_product_denom be "0"
        
        Set component_idx to 0
        While component_idx < List.length(vector):
            Let v_component be List.get(vector, component_idx)
            Let u_component be List.get(basis_vector, component_idx)
            
            Note: Numerator: v·u
            Let vu_product_result be Operations.multiply(v_component, u_component, 10)
            Let num_sum_result be Operations.add(dot_product_num, vu_product_result.result_value, 10)
            Set dot_product_num to num_sum_result.result_value
            
            Note: Denominator: u·u
            Let uu_product_result be Operations.multiply(u_component, u_component, 10)
            Let denom_sum_result be Operations.add(dot_product_denom, uu_product_result.result_value, 10)
            Set dot_product_denom to denom_sum_result.result_value
            
            Set component_idx to component_idx + 1
        
        Note: Add projection component
        If StringComp.equals(dot_product_denom, "0") == false:
            Let proj_coeff_result be Operations.divide(dot_product_num, dot_product_denom, 10)
            Let proj_coeff be proj_coeff_result.result_value
            
            Set component_idx to 0
            While component_idx < List.length(vector):
                Let current_proj_comp be List.get(projection, component_idx)
                Let basis_comp be List.get(basis_vector, component_idx)
                
                Let scaled_component_result be Operations.multiply(proj_coeff, basis_comp, 10)
                Let updated_proj_result be Operations.add(current_proj_comp, scaled_component_result.result_value, 10)
                
                Set projection to List.set(projection, component_idx, updated_proj_result.result_value)
                Set component_idx to component_idx + 1
        
        Set basis_idx to basis_idx + 1
    
    Return projection

Process called "qr_decomposition" that takes matrix as Matrix returns Dictionary[String, Matrix]:
    Note: Compute QR decomposition A = QR with orthogonal Q
    Note: Uses Gram-Schmidt or Householder reflections
    
    Let rows be matrix.rows
    Let cols be matrix.columns
    
    Note: Extract column vectors from matrix A
    Let column_vectors be []
    Let col_idx be 0
    
    While col_idx < cols:
        Let column be []
        Let row_idx be 0
        While row_idx < rows:
            Let matrix_row be List.get(matrix.entries, row_idx)
            Let element be List.get(matrix_row, col_idx)
            Set column to List.append(column, element)
            Set row_idx to row_idx + 1
        Set column_vectors to List.append(column_vectors, column)
        Set col_idx to col_idx + 1
    
    Note: Apply Gram-Schmidt to get orthogonal vectors (Q)
    Let empty_inner_product be {}
    Let orthogonal_columns be gram_schmidt_process(column_vectors, empty_inner_product)
    
    Note: Normalize orthogonal vectors to get orthonormal Q
    Let q_columns be []
    Let q_col_idx be 0
    
    While q_col_idx < List.length(orthogonal_columns):
        Let orthogonal_vector be List.get(orthogonal_columns, q_col_idx)
        
        Note: Compute vector norm
        Let norm_squared be "0"
        Let component_idx be 0
        While component_idx < List.length(orthogonal_vector):
            Let component be List.get(orthogonal_vector, component_idx)
            Let squared_result be Operations.multiply(component, component, 10)
            Let sum_result be Operations.add(norm_squared, squared_result.result_value, 10)
            Set norm_squared to sum_result.result_value
            Set component_idx to component_idx + 1
        
        Note: Normalize vector by dividing by its norm
        Let normalized_vector be []
        If StringComp.equals(norm_squared, "0") == false:
            Note: Compute norm as sqrt(norm_squared) using iterative approximation
            Let norm be compute_square_root_approximation(norm_squared)
            
            Set component_idx to 0
            While component_idx < List.length(orthogonal_vector):
                Let component be List.get(orthogonal_vector, component_idx)
                Note: Divide by actual norm, not norm_squared
                Let normalized_result be Operations.divide(component, norm, 10)
                Set normalized_vector to List.append(normalized_vector, normalized_result.result_value)
                Set component_idx to component_idx + 1
        Otherwise:
            Set normalized_vector to orthogonal_vector
        
        Set q_columns to List.append(q_columns, normalized_vector)
        Set q_col_idx to q_col_idx + 1
    
    Note: Construct Q matrix from orthonormal columns
    Let q_entries be []
    Let row_idx be 0
    While row_idx < rows:
        Let q_row be []
        Set col_idx to 0
        While col_idx < List.length(q_columns):
            Let q_column be List.get(q_columns, col_idx)
            Let element be List.get(q_column, row_idx)
            Set q_row to List.append(q_row, element)
            Set col_idx to col_idx + 1
        Set q_entries to List.append(q_entries, q_row)
        Set row_idx to row_idx + 1
    
    Let q_matrix be Matrix
    Set q_matrix.entries to q_entries
    Set q_matrix.rows to rows
    Set q_matrix.columns to List.length(q_columns)
    Set q_matrix.field to matrix.field
    Set q_matrix.rank to List.length(q_columns)
    Set q_matrix.determinant to "1"
    Set q_matrix.trace to StringCore.integer_to_string(List.length(q_columns))
    Set q_matrix.eigenvalues to []
    Set q_matrix.eigenvectors to []
    Set q_matrix.characteristic_polynomial to []
    
    Note: Compute R = Q^T * A
    Let q_transpose be matrix_transpose(q_matrix)
    Let r_matrix be matrix_multiply(q_transpose, matrix)
    
    Note: Return QR decomposition
    Let result be {}
    Set result to StringCore.dict_set(result, "Q", q_matrix)
    Set result to StringCore.dict_set(result, "R", r_matrix)
    
    Return result

Process called "spectral_theorem" that takes matrix as Matrix, inner_product as Dictionary[String, String] returns Dictionary[String, Matrix]:
    Note: Apply spectral theorem for symmetric matrices
    Note: Diagonalizes symmetric matrix with orthogonal eigenvectors
    
    Note: Verify matrix is symmetric and square
    If matrix.rows != matrix.columns:
        Throw Errors.InvalidArgument with "Spectral theorem requires square matrix"
    
    Let transpose_matrix be matrix_transpose(matrix)
    Let is_symmetric be true
    Let row_idx be 0
    
    While row_idx < matrix.rows && is_symmetric:
        Let col_idx be 0
        While col_idx < matrix.columns && is_symmetric:
            Let original_row be List.get(matrix.entries, row_idx)
            Let original_element be List.get(original_row, col_idx)
            
            Let transpose_row be List.get(transpose_matrix.entries, row_idx)
            Let transpose_element be List.get(transpose_row, col_idx)
            
            If StringComp.equals(original_element, transpose_element) == false:
                Set is_symmetric to false
            
            Set col_idx to col_idx + 1
        Set row_idx to row_idx + 1
    
    If is_symmetric == false:
        Throw Errors.InvalidArgument with "Spectral theorem requires symmetric matrix"
    
    Note: For symmetric matrices, use diagonalization
    If test_diagonalizability(matrix):
        Let diagonalization be diagonalize_matrix(matrix)
        
        Note: Extract eigenvector matrix P and eigenvalue matrix D
        Let p_matrix be StringCore.dict_get(diagonalization, "P")
        Let d_matrix be StringCore.dict_get(diagonalization, "D")
        
        Note: Orthogonalize eigenvectors using Gram-Schmidt
        Let eigenvector_columns be []
        Set col_idx to 0
        
        While col_idx < p_matrix.columns:
            Let column be []
            Set row_idx to 0
            While row_idx < p_matrix.rows:
                Let matrix_row be List.get(p_matrix.entries, row_idx)
                Let element be List.get(matrix_row, col_idx)
                Set column to List.append(column, element)
                Set row_idx to row_idx + 1
            Set eigenvector_columns to List.append(eigenvector_columns, column)
            Set col_idx to col_idx + 1
        
        Let orthogonal_eigenvectors be gram_schmidt_process(eigenvector_columns, inner_product)
        
        Note: Construct orthogonal matrix from orthogonalized eigenvectors
        Let orthogonal_entries be []
        Set row_idx to 0
        While row_idx < p_matrix.rows:
            Let orthogonal_row be []
            Set col_idx to 0
            While col_idx < List.length(orthogonal_eigenvectors):
                Let eigenvector be List.get(orthogonal_eigenvectors, col_idx)
                Let element be List.get(eigenvector, row_idx)
                Set orthogonal_row to List.append(orthogonal_row, element)
                Set col_idx to col_idx + 1
            Set orthogonal_entries to List.append(orthogonal_entries, orthogonal_row)
            Set row_idx to row_idx + 1
        
        Let orthogonal_matrix be Matrix
        Set orthogonal_matrix.entries to orthogonal_entries
        Set orthogonal_matrix.rows to p_matrix.rows
        Set orthogonal_matrix.columns to p_matrix.columns
        Set orthogonal_matrix.field to matrix.field
        Set orthogonal_matrix.rank to p_matrix.rank
        Set orthogonal_matrix.determinant to "1"
        Set orthogonal_matrix.trace to p_matrix.trace
        Set orthogonal_matrix.eigenvalues to []
        Set orthogonal_matrix.eigenvectors to []
        Set orthogonal_matrix.characteristic_polynomial to []
        
        Note: Return spectral decomposition
        Let spectral_result be {}
        Set spectral_result to StringCore.dict_set(spectral_result, "Q", orthogonal_matrix)
        Set spectral_result to StringCore.dict_set(spectral_result, "Lambda", d_matrix)
        Set spectral_result to StringCore.dict_set(spectral_result, "Q_transpose", matrix_transpose(orthogonal_matrix))
        
        Return spectral_result
    Otherwise:
        Throw Errors.InvalidOperation with "Matrix is not diagonalizable"

Note: =====================================================================
Note: ADVANCED LINEAR ALGEBRA OPERATIONS
Note: =====================================================================

Process called "tensor_product_spaces" that takes first as VectorSpace, second as VectorSpace returns VectorSpace:
    Note: Compute tensor product of vector spaces
    Note: Constructs space of bilinear maps and universal property
    
    Note: Check field compatibility
    If StringComp.equals(first.field, second.field) == false:
        Throw Errors.InvalidArgument with "Vector spaces must be over same field"
    
    Note: Tensor product dimension is product of dimensions
    Let tensor_dimension be first.dimension * second.dimension
    
    Note: Construct tensor product basis from Kronecker products
    Let tensor_basis be []
    Let first_basis_idx be 0
    
    While first_basis_idx < List.length(first.basis):
        Let first_basis_vector be List.get(first.basis, first_basis_idx)
        Let second_basis_idx be 0
        
        While second_basis_idx < List.length(second.basis):
            Let second_basis_vector be List.get(second.basis, second_basis_idx)
            
            Note: Compute tensor product of basis vectors
            Let tensor_product_vector be []
            Let first_component_idx be 0
            
            While first_component_idx < List.length(first_basis_vector):
                Let first_component be List.get(first_basis_vector, first_component_idx)
                Let second_component_idx be 0
                
                While second_component_idx < List.length(second_basis_vector):
                    Let second_component be List.get(second_basis_vector, second_component_idx)
                    
                    Note: Tensor product component: a_i * b_j
                    Let product_result be Operations.multiply(first_component, second_component, 10)
                    Set tensor_product_vector to List.append(tensor_product_vector, product_result.result_value)
                    
                    Set second_component_idx to second_component_idx + 1
                Set first_component_idx to first_component_idx + 1
            
            Set tensor_basis to List.append(tensor_basis, tensor_product_vector)
            Set second_basis_idx to second_basis_idx + 1
        Set first_basis_idx to first_basis_idx + 1
    
    Note: Create tensor product vector space
    Return create_vector_space(first.field, tensor_dimension, tensor_basis)

Process called "exterior_algebra" that takes vector_space as VectorSpace returns Dictionary[Integer, VectorSpace]:
    Note: Construct exterior algebra (alternating tensors)
    Note: Builds graded algebra of antisymmetric multilinear forms
    
    Let exterior_algebra be {}
    Let dimension be vector_space.dimension
    
    Note: Λ^0(V) = field (1-dimensional)
    Let zero_grade_basis be [["1"]]
    Let zero_grade_space be create_vector_space(vector_space.field, 1, zero_grade_basis)
    Set exterior_algebra to StringCore.dict_set(exterior_algebra, 0, zero_grade_space)
    
    Note: Λ^1(V) = V itself
    Set exterior_algebra to StringCore.dict_set(exterior_algebra, 1, vector_space)
    
    Note: Higher grades Λ^k(V) for k = 2, 3, ..., dim(V)
    Let grade be 2
    While grade <= dimension:
        Note: Compute binomial coefficient C(n,k) for dimension of Λ^k(V)
        Let binomial_dimension be compute_binomial_coefficient(dimension, grade)
        
        Note: Construct basis for Λ^k(V) from k-element subsets
        Let exterior_basis be []
        
        Note: Generate all k-combinations of basis vectors (simplified)
        If grade == 2 && dimension >= 2:
            Let i be 0
            While i < dimension - 1:
                Let j be i + 1
                While j < dimension:
                    Note: Create wedge product e_i ∧ e_j
                    Let wedge_product be []
                    Let component_idx be 0
                    
                    While component_idx < binomial_dimension:
                        If component_idx == (i * dimension + j - i * (i + 1) / 2):
                            Set wedge_product to List.append(wedge_product, "1")
                        Otherwise:
                            Set wedge_product to List.append(wedge_product, "0")
                        Set component_idx to component_idx + 1
                    
                    Set exterior_basis to List.append(exterior_basis, wedge_product)
                    Set j to j + 1
                Set i to i + 1
        
        Note: Create exterior power space
        Let exterior_space be create_vector_space(vector_space.field, binomial_dimension, exterior_basis)
        Set exterior_algebra to StringCore.dict_set(exterior_algebra, grade, exterior_space)
        
        Set grade to grade + 1
    
    Return exterior_algebra

Process called "symmetric_algebra" that takes vector_space as VectorSpace returns Dictionary[Integer, VectorSpace]:
    Note: Construct symmetric algebra (symmetric tensors)
    Note: Builds graded algebra of symmetric multilinear forms
    
    Let symmetric_algebra be {}
    Let dimension be vector_space.dimension
    
    Note: S^0(V) = field (1-dimensional)
    Let zero_grade_basis be [["1"]]
    Let zero_grade_space be create_vector_space(vector_space.field, 1, zero_grade_basis)
    Set symmetric_algebra to StringCore.dict_set(symmetric_algebra, 0, zero_grade_space)
    
    Note: S^1(V) = V itself
    Set symmetric_algebra to StringCore.dict_set(symmetric_algebra, 1, vector_space)
    
    Note: Higher grades S^k(V) for k = 2, 3, ...
    Let grade be 2
    While grade <= 4:
        Note: Dimension of S^k(V) is C(n+k-1, k)
        Let symmetric_dimension be compute_symmetric_dimension(dimension, grade)
        
        Note: Construct basis for S^k(V) from symmetric products
        Let symmetric_basis be []
        
        Note: Generate symmetric products (simplified for grade 2)
        If grade == 2:
            Let i be 0
            While i < dimension:
                Let j be i
                While j < dimension:
                    Note: Create symmetric product e_i * e_j
                    Let symmetric_product be []
                    Let component_idx be 0
                    
                    While component_idx < symmetric_dimension:
                        If component_idx == compute_symmetric_index(i, j, dimension):
                            Set symmetric_product to List.append(symmetric_product, "1")
                        Otherwise:
                            Set symmetric_product to List.append(symmetric_product, "0")
                        Set component_idx to component_idx + 1
                    
                    Set symmetric_basis to List.append(symmetric_basis, symmetric_product)
                    Set j to j + 1
                Set i to i + 1
        
        Note: Create symmetric power space
        Let symmetric_space be create_vector_space(vector_space.field, symmetric_dimension, symmetric_basis)
        Set symmetric_algebra to StringCore.dict_set(symmetric_algebra, grade, symmetric_space)
        
        Set grade to grade + 1
    
    Return symmetric_algebra

Process called "dual_space" that takes vector_space as VectorSpace returns VectorSpace:
    Note: Construct dual space of linear functionals
    Note: Creates space of linear maps to base field
    
    Note: Dual space has same dimension as original space
    Let dual_dimension be vector_space.dimension
    
    Note: Construct dual basis {f_1, f_2, ..., f_n} where f_i(e_j) = δ_ij
    Let dual_basis be []
    Let dual_basis_idx be 0
    
    While dual_basis_idx < dual_dimension:
        Note: Create dual basis vector f_i
        Let dual_functional be []
        Let component_idx be 0
        
        While component_idx < dual_dimension:
            If component_idx == dual_basis_idx:
                Set dual_functional to List.append(dual_functional, "1")
            Otherwise:
                Set dual_functional to List.append(dual_functional, "0")
            Set component_idx to component_idx + 1
        
        Set dual_basis to List.append(dual_basis, dual_functional)
        Set dual_basis_idx to dual_basis_idx + 1
    
    Note: Create dual vector space V*
    Let dual_space be create_vector_space(vector_space.field, dual_dimension, dual_basis)
    
    Note: Store reference to original space
    Set dual_space.dual_space to {"original": vector_space}
    
    Return dual_space

Process called "canonical_forms" that takes matrix as Matrix returns Dictionary[String, Matrix]:
    Note: Compute various canonical forms (rational, Jordan, Smith normal)
    Note: Provides standard representatives for similarity classes
    
    Let canonical_forms be {}
    
    Note: Jordan canonical form
    If test_diagonalizability(matrix):
        Let jordan_result be diagonalize_matrix(matrix)
        Set canonical_forms to StringCore.dict_set(canonical_forms, "jordan", StringCore.dict_get(jordan_result, "D"))
    Otherwise:
        Let jordan_result be jordan_normal_form(matrix)
        Set canonical_forms to StringCore.dict_set(canonical_forms, "jordan", StringCore.dict_get(jordan_result, "J"))
    
    Note: Rational canonical form (simplified as Jordan form)
    Set canonical_forms to StringCore.dict_set(canonical_forms, "rational", StringCore.dict_get(canonical_forms, "jordan"))
    
    Note: Smith normal form (for integer matrices, simplified)
    Let smith_form be matrix
    If matrix.rows == matrix.columns:
        Note: For square matrices, use diagonal form with gcd entries
        Let diagonal_entries be []
        Let diag_idx be 0
        
        While diag_idx < matrix.rows:
            Let diagonal_row be []
            Let col_idx be 0
            
            While col_idx < matrix.columns:
                If diag_idx == col_idx:
                    Note: Simplified: use "1" for diagonal entries
                    Set diagonal_row to List.append(diagonal_row, "1")
                Otherwise:
                    Set diagonal_row to List.append(diagonal_row, "0")
                Set col_idx to col_idx + 1
            
            Set diagonal_entries to List.append(diagonal_entries, diagonal_row)
            Set diag_idx to diag_idx + 1
        
        Set smith_form.entries to diagonal_entries
    
    Set canonical_forms to StringCore.dict_set(canonical_forms, "smith", smith_form)
    
    Note: Frobenius canonical form (companion matrix form)
    Let char_poly be compute_characteristic_polynomial(matrix)
    Let frobenius_size be matrix.rows
    Let frobenius_entries be []
    
    Let row_idx be 0
    While row_idx < frobenius_size:
        Let frobenius_row be []
        Let col_idx be 0
        
        While col_idx < frobenius_size:
            If row_idx == frobenius_size - 1:
                Note: Last row contains negated coefficients
                If col_idx < List.length(char_poly):
                    Let coeff be List.get(char_poly, col_idx)
                    Let neg_coeff_result be Operations.multiply("-1", coeff, 10)
                    Set frobenius_row to List.append(frobenius_row, neg_coeff_result.result_value)
                Otherwise:
                    Set frobenius_row to List.append(frobenius_row, "0")
            Otherwise:
                If col_idx == row_idx + 1:
                    Set frobenius_row to List.append(frobenius_row, "1")
                Otherwise:
                    Set frobenius_row to List.append(frobenius_row, "0")
            
            Set col_idx to col_idx + 1
        
        Set frobenius_entries to List.append(frobenius_entries, frobenius_row)
        Set row_idx to row_idx + 1
    
    Let frobenius_form be Matrix
    Set frobenius_form.entries to frobenius_entries
    Set frobenius_form.rows to frobenius_size
    Set frobenius_form.columns to frobenius_size
    Set frobenius_form.field to matrix.field
    Set frobenius_form.rank to matrix.rank
    Set frobenius_form.determinant to matrix.determinant
    Set frobenius_form.trace to matrix.trace
    Set frobenius_form.eigenvalues to matrix.eigenvalues
    Set frobenius_form.eigenvectors to []
    Set frobenius_form.characteristic_polynomial to char_poly
    
    Set canonical_forms to StringCore.dict_set(canonical_forms, "frobenius", frobenius_form)
    
    Return canonical_forms

Process called "matrix_exponential" that takes matrix as Matrix returns Matrix:
    Note: Compute matrix exponential using series expansion
    Note: Computes e^A using Jordan form or series methods
    
    Note: Only for square matrices
    If matrix.rows != matrix.columns:
        Throw Errors.InvalidArgument with "Matrix exponential only defined for square matrices"
    
    Let size be matrix.rows
    
    Note: For small matrices, use direct series computation
    If size == 1:
        Let element be List.get(List.get(matrix.entries, 0), 0)
        Note: e^a approximated as 1 + a (first-order approximation)
        Let exp_result be Operations.add("1", element, 10)
        Let exp_entries be [[exp_result.result_value]]
        
        Let exp_matrix be Matrix
        Set exp_matrix.entries to exp_entries
        Set exp_matrix.rows to 1
        Set exp_matrix.columns to 1
        Set exp_matrix.field to matrix.field
        Set exp_matrix.rank to 1
        Set exp_matrix.determinant to exp_result.result_value
        Set exp_matrix.trace to exp_result.result_value
        Set exp_matrix.eigenvalues to [exp_result.result_value]
        Set exp_matrix.eigenvectors to []
        Set exp_matrix.characteristic_polynomial to []
        
        Return exp_matrix
    
    Note: For larger matrices, use series expansion e^A = I + A + A^2/2! + A^3/3! + ...
    Note: Initialize result as identity matrix I
    Let result_entries be []
    Set row_idx to 0
    While row_idx < size:
        Let identity_row be []
        Set col_idx to 0
        While col_idx < size:
            If row_idx == col_idx:
                Set identity_row to List.append(identity_row, "1")
            Otherwise:
                Set identity_row to List.append(identity_row, "0")
            Set col_idx to col_idx + 1
        Set result_entries to List.append(result_entries, identity_row)
        Set row_idx to row_idx + 1
    
    Note: Compute series terms: A^k/k! for k = 1, 2, 3, ...
    Let current_power_matrix be matrix
    Let factorial be 1
    Let term_count be 1
    
    Note: Add terms up to A^4/4! for reasonable approximation
    While term_count <= 4:
        Set factorial to factorial * term_count
        
        Note: Add A^k/k! to result
        Set row_idx to 0
        While row_idx < size:
            Set col_idx to 0
            While col_idx < size:
                Let result_row be List.get(result_entries, row_idx)
                Let current_result be List.get(result_row, col_idx)
                
                Let power_row be List.get(current_power_matrix.entries, row_idx)
                Let power_element be List.get(power_row, col_idx)
                
                Note: Divide by factorial
                Let factorial_str be StringCore.integer_to_string(factorial)
                Let term_result be Operations.divide(power_element, factorial_str, 10)
                
                Note: Add to running sum
                Let sum_result be Operations.add(current_result, term_result.result_value, 10)
                Set result_row to List.set(result_row, col_idx, sum_result.result_value)
                
                Set col_idx to col_idx + 1
            Set row_idx to row_idx + 1
        
        Note: Compute next power A^(k+1) = A^k * A
        If term_count < 4:
            Set current_power_matrix to matrix_multiply(current_power_matrix, matrix)
        
        Set term_count to term_count + 1
    
    Note: Create final result matrix
    Let result_matrix be Matrix
    Set result_matrix.entries to result_entries
    Set result_matrix.rows to size
    Set result_matrix.columns to size
    Set result_matrix.field to matrix.field
    Set result_matrix.rank to size
    Set result_matrix.determinant to matrix_determinant(result_matrix)
    Set result_matrix.trace to matrix_trace(result_matrix)
    Set result_matrix.eigenvalues to []
    Set result_matrix.eigenvectors to []
    Set result_matrix.characteristic_polynomial to []
    
    Return result_matrix

Note: =====================================================================
Note: HELPER FUNCTIONS FOR LINEAR ALGEBRA OPERATIONS
Note: =====================================================================

Process called "perform_gaussian_elimination" that takes matrix as List[List[String]], field as String returns Integer:
    Note: Perform Gaussian elimination and return rank of matrix
    Note: Used internally by linear independence tests and rank computations
    
    Let rows be List.length(matrix)
    If rows == 0:
        Return 0
    
    Let cols be List.length(List.get(matrix, 0))
    Let working_matrix be matrix
    Let rank be 0
    Let pivot_row be 0
    
    Let col be 0
    While col < cols && pivot_row < rows:
        Note: Find pivot element in current column
        Let pivot_found be false
        Let search_row be pivot_row
        
        While search_row < rows && pivot_found == false:
            Let current_row be List.get(working_matrix, search_row)
            Let element be List.get(current_row, col)
            
            Note: Check if element is non-zero (not "0" or "0.0")
            If StringComp.equals(element, "0") == false && StringComp.equals(element, "0.0") == false:
                Set pivot_found to true
                
                Note: Swap rows if needed
                If search_row != pivot_row:
                    Let temp_row be List.get(working_matrix, pivot_row)
                    Set working_matrix to List.set(working_matrix, pivot_row, current_row)
                    Set working_matrix to List.set(working_matrix, search_row, temp_row)
            
            Set search_row to search_row + 1
        
        If pivot_found:
            Set rank to rank + 1
            
            Note: Eliminate below pivot
            Let elim_row be pivot_row + 1
            While elim_row < rows:
                Let target_row be List.get(working_matrix, elim_row)
                Let target_element be List.get(target_row, col)
                
                Note: Skip if already zero
                If StringComp.equals(target_element, "0") == false && StringComp.equals(target_element, "0.0") == false:
                    Let pivot_row_data be List.get(working_matrix, pivot_row)
                    Let pivot_element be List.get(pivot_row_data, col)
                    
                    Note: Calculate elimination factor
                    Let factor_result be Operations.divide(target_element, pivot_element, 10)
                    Let factor be factor_result.result_value
                    
                    Note: Perform row elimination
                    Let new_row be []
                    Let col_idx be 0
                    While col_idx < cols:
                        Let target_val be List.get(target_row, col_idx)
                        Let pivot_val be List.get(pivot_row_data, col_idx)
                        
                        Let mult_result be Operations.multiply(factor, pivot_val, 10)
                        Let sub_result be Operations.subtract(target_val, mult_result.result_value, 10)
                        
                        Set new_row to List.append(new_row, sub_result.result_value)
                        Set col_idx to col_idx + 1
                    
                    Set working_matrix to List.set(working_matrix, elim_row, new_row)
                
                Set elim_row to elim_row + 1
            
            Set pivot_row to pivot_row + 1
        
        Set col to col + 1
    
    Return rank

Process called "find_intersection_basis" that takes first_basis as List[List[String]], second_basis as List[List[String]], field as String returns List[List[String]]:
    Note: Find basis for intersection of two vector spaces
    Note: Constructs system of equations and solves for intersection
    
    If List.length(first_basis) == 0 || List.length(second_basis) == 0:
        Return []
    
    Note: Get dimensions and check for trivial cases
    Let first_dim be List.length(first_basis)
    Let second_dim be List.length(second_basis)
    
    If first_dim == 0 || second_dim == 0:
        Return []
    
    Note: Get vector dimension (assume all vectors have same length)
    Let vector_dim be List.length(List.get(first_basis, 0))
    
    Note: Create combined matrix [A | B] where intersection is ker([A^T, -B^T])
    Note: We need vectors x such that Ax = Bx, i.e., (A-B)x = 0
    
    Note: Build coefficient matrix for intersection computation
    Let coeff_matrix be []
    
    Note: Add equations from first basis: for each v in second_basis, require v^T * first_basis[i] = 0
    Let first_idx be 0
    While first_idx < first_dim:
        Let first_vector be List.get(first_basis, first_idx)
        
        Note: Create constraint row: this vector must be orthogonal to complement
        Let constraint_row be []
        Let component_idx be 0
        
        While component_idx < vector_dim:
            Let component be List.get(first_vector, component_idx)
            Set constraint_row to List.append(constraint_row, component)
            Set component_idx to component_idx + 1
        
        Set coeff_matrix to List.append(coeff_matrix, constraint_row)
        Set first_idx to first_idx + 1
    
    Note: Add equations from second basis: similar orthogonality constraints
    Let second_idx be 0
    While second_idx < second_dim:
        Let second_vector be List.get(second_basis, second_idx)
        
        Let constraint_row be []
        Let component_idx be 0
        
        While component_idx < vector_dim:
            Let component be List.get(second_vector, component_idx)
            Set constraint_row to List.append(constraint_row, component)
            Set component_idx to component_idx + 1
        
        Set coeff_matrix to List.append(coeff_matrix, constraint_row)
        Set second_idx to second_idx + 1
    
    Note: Find null space of coefficient matrix using Gaussian elimination
    Let matrix_rank be perform_gaussian_elimination(coeff_matrix, field)
    Let total_constraints be first_dim + second_dim
    Let intersection_dimension be vector_dim - matrix_rank
    
    If intersection_dimension <= 0:
        Return []
    
    Note: Construct intersection basis from null space
    Let intersection_basis be []
    
    Note: Create standard basis vectors for free variables in null space
    Let free_var_idx be 0
    While free_var_idx < intersection_dimension:
        Let basis_vector be []
        Let component_idx be 0
        
        While component_idx < vector_dim:
            If component_idx == (matrix_rank + free_var_idx):
                Set basis_vector to List.append(basis_vector, "1")
            Otherwise:
                Set basis_vector to List.append(basis_vector, "0")
            Set component_idx to component_idx + 1
        
        Note: Verify this vector is actually in both spans by testing membership
        Let is_in_first_span be test_vector_membership(basis_vector, first_basis, field)
        Let is_in_second_span be test_vector_membership(basis_vector, second_basis, field)
        
        If is_in_first_span && is_in_second_span:
            Set intersection_basis to List.append(intersection_basis, basis_vector)
        
        Set free_var_idx to free_var_idx + 1
    
    Return intersection_basis

Process called "compute_binomial_coefficient" that takes n as Integer, k as Integer returns Integer:
    Note: Compute binomial coefficient C(n,k) = n! / (k!(n-k)!)
    
    If k > n || k < 0:
        Return 0
    
    If k == 0 || k == n:
        Return 1
    
    Note: Use iterative computation to avoid large factorials
    Let result be 1
    Let i be 0
    
    While i < k:
        Set result to result * (n - i) / (i + 1)
        Set i to i + 1
    
    Return result

Process called "compute_symmetric_dimension" that takes n as Integer, k as Integer returns Integer:
    Note: Compute dimension of symmetric power S^k(V) = C(n+k-1, k)
    
    Return compute_binomial_coefficient(n + k - 1, k)

Process called "compute_symmetric_index" that takes i as Integer, j as Integer, dimension as Integer returns Integer:
    Note: Compute index for symmetric product in lexicographic ordering
    
    Note: Simplified index computation for symmetric products
    If i <= j:
        Return i * dimension + j - (i * (i + 1)) / 2
    Otherwise:
        Return j * dimension + i - (j * (j + 1)) / 2

Process called "test_vector_membership" that takes vector as List[String], basis as List[List[String]], field as String returns Boolean:
    Note: Test if vector is in the span of the given basis
    Note: Solves the system: basis * coefficients = vector
    
    If List.length(basis) == 0:
        Note: Check if vector is zero vector
        Let component_idx be 0
        While component_idx < List.length(vector):
            Let component be List.get(vector, component_idx)
            If StringComp.equals(component, "0") == false && StringComp.equals(component, "0.0") == false:
                Return false
            Set component_idx to component_idx + 1
        Return true
    
    Let basis_size be List.length(basis)
    Let vector_dim be List.length(vector)
    
    Note: Create augmented matrix [basis^T | vector] for solving linear system
    Let augmented_matrix be []
    Let row_idx be 0
    
    While row_idx < vector_dim:
        Let augmented_row be []
        
        Note: Add components from each basis vector
        Let basis_idx be 0
        While basis_idx < basis_size:
            Let basis_vector be List.get(basis, basis_idx)
            Let basis_component be List.get(basis_vector, row_idx)
            Set augmented_row to List.append(augmented_row, basis_component)
            Set basis_idx to basis_idx + 1
        
        Note: Add corresponding vector component
        Let vector_component be List.get(vector, row_idx)
        Set augmented_row to List.append(augmented_row, vector_component)
        
        Set augmented_matrix to List.append(augmented_matrix, augmented_row)
        Set row_idx to row_idx + 1
    
    Note: Perform Gaussian elimination on augmented matrix
    Let original_rank be perform_gaussian_elimination(transpose_basis_matrix(basis), field)
    Let augmented_rank be perform_gaussian_elimination(augmented_matrix, field)
    
    Note: Vector is in span if rank doesn't increase when augmented
    Return original_rank == augmented_rank

Process called "transpose_basis_matrix" that takes basis as List[List[String]] returns List[List[String]]:
    Note: Transpose basis matrix where each basis vector is a column
    
    If List.length(basis) == 0:
        Return []
    
    Let vector_dim be List.length(List.get(basis, 0))
    Let basis_size be List.length(basis)
    Let transposed_matrix be []
    
    Let row_idx be 0
    While row_idx < vector_dim:
        Let transposed_row be []
        Let col_idx be 0
        
        While col_idx < basis_size:
            Let basis_vector be List.get(basis, col_idx)
            Let element be List.get(basis_vector, row_idx)
            Set transposed_row to List.append(transposed_row, element)
            Set col_idx to col_idx + 1
        
        Set transposed_matrix to List.append(transposed_matrix, transposed_row)
        Set row_idx to row_idx + 1
    
    Return transposed_matrix

Process called "compute_square_root_approximation" that takes number as String returns String:
    Note: Compute square root using Newton's method approximation
    Note: Uses iterative formula: x_{n+1} = (x_n + number/x_n) / 2
    
    Note: Handle special cases
    If StringComp.equals(number, "0") || StringComp.equals(number, "0.0"):
        Return "0"
    
    If StringComp.equals(number, "1") || StringComp.equals(number, "1.0"):
        Return "1"
    
    Note: Initial guess (use number/2 as starting approximation)
    Let two_result be Operations.add("1", "1", 10)
    Let initial_guess_result be Operations.divide(number, two_result.result_value, 10)
    Let current_approximation be initial_guess_result.result_value
    
    Note: Perform Newton's method iterations
    Let iteration be 0
    While iteration < 5:
        Note: Compute number / current_approximation
        Let quotient_result be Operations.divide(number, current_approximation, 10)
        Let quotient be quotient_result.result_value
        
        Note: Add current_approximation + quotient
        Let sum_result be Operations.add(current_approximation, quotient, 10)
        Let sum be sum_result.result_value
        
        Note: Divide by 2 to get next approximation
        Let next_approx_result be Operations.divide(sum, "2", 10)
        Set current_approximation to next_approx_result.result_value
        
        Set iteration to iteration + 1
    
    Return current_approximation

Process called "power_iteration_eigenvalue" that takes matrix as Matrix returns String:
    Note: Use power iteration to find dominant eigenvalue
    Note: Iterates vector multiplication to converge to dominant eigenvector
    
    Let dimension be matrix.rows
    If dimension == 0:
        Return "0"
    
    Note: Initialize random vector (simplified as [1, 1, ..., 1])
    Let current_vector be []
    Let component_idx be 0
    While component_idx < dimension:
        Set current_vector to List.append(current_vector, "1")
        Set component_idx to component_idx + 1
    
    Note: Perform power iteration
    Let iteration be 0
    Let eigenvalue_estimate be "0"
    
    While iteration < 10:
        Note: Multiply matrix by current vector
        Let new_vector be []
        Let row_idx be 0
        
        While row_idx < dimension:
            Let matrix_row be List.get(matrix.entries, row_idx)
            Let dot_product be "0"
            Let col_idx be 0
            
            While col_idx < dimension:
                Let matrix_element be List.get(matrix_row, col_idx)
                Let vector_element be List.get(current_vector, col_idx)
                Let product_result be Operations.multiply(matrix_element, vector_element, 10)
                Let sum_result be Operations.add(dot_product, product_result.result_value, 10)
                Set dot_product to sum_result.result_value
                Set col_idx to col_idx + 1
            
            Set new_vector to List.append(new_vector, dot_product)
            Set row_idx to row_idx + 1
        
        Note: Calculate eigenvalue estimate (Rayleigh quotient approximation)
        If List.length(new_vector) > 0:
            Let first_old be List.get(current_vector, 0)
            Let first_new be List.get(new_vector, 0)
            
            If StringComp.equals(first_old, "0") == false:
                Let ratio_result be Operations.divide(first_new, first_old, 10)
                Set eigenvalue_estimate to ratio_result.result_value
            
        Note: Normalize new vector (simplified: just use as-is)
        Set current_vector to new_vector
        Set iteration to iteration + 1
    
    Return eigenvalue_estimate

Process called "compute_gerschgorin_bounds" that takes matrix as Matrix returns List[String]:
    Note: Compute Gerschgorin circle centers for eigenvalue bounds
    Note: Each diagonal element ± sum of off-diagonal elements gives eigenvalue bounds
    
    Let dimension be matrix.rows
    Let bounds be []
    
    If dimension == 0:
        Return bounds
    
    Let row_idx be 0
    While row_idx < dimension:
        Let matrix_row be List.get(matrix.entries, row_idx)
        
        Note: Get diagonal element (center of Gerschgorin circle)
        Let diagonal_element be List.get(matrix_row, row_idx)
        
        Note: Calculate radius (sum of absolute values of off-diagonal elements)
        Let radius be "0"
        Let col_idx be 0
        
        While col_idx < dimension:
            If col_idx != row_idx:
                Let off_diagonal_element be List.get(matrix_row, col_idx)
                
                Note: Add absolute value to radius
                Let abs_element be off_diagonal_element
                If StringCore.substring(off_diagonal_element, 0, 1) == "-":
                    Set abs_element to StringCore.substring(off_diagonal_element, 1, StringCore.length(off_diagonal_element) - 1)
                
                Let radius_sum_result be Operations.add(radius, abs_element, 10)
                Set radius to radius_sum_result.result_value
            
            Set col_idx to col_idx + 1
        
        Note: Store bound as "center±radius" format
        Let bound_description be StringCore.concat(diagonal_element, "±")
        Set bound_description to StringCore.concat(bound_description, radius)
        Set bounds to List.append(bounds, bound_description)
        
        Set row_idx to row_idx + 1
    
    Return bounds
    Otherwise:
        Note: Test if second basis vectors are in first span  
        Let intersection be []
        Let test_index be 0
        While test_index < List.length(second_basis):
            Let test_vector be List.get(second_basis, test_index)
            Note: For simplicity, add to intersection (real implementation would test membership)
            Set intersection to List.append(intersection, test_vector)
            Set test_index to test_index + 1
        
        Note: Find linear independent subset
        Return find_basis(intersection, field)

