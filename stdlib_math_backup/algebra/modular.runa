Note:
math/algebra/modular.runa
Modular Arithmetic and Number Theory

This module provides comprehensive modular arithmetic including:
- Basic modular arithmetic operations (addition, multiplication, exponentiation)
- Chinese Remainder Theorem and system solving
- Quadratic residues and Legendre/Jacobi symbols
- Primitive roots and discrete logarithms
- Modular equations and congruence solving
- Carmichael function and Euler's totient
- Multiplicative order and cyclic group structure
- Modular square roots and Tonelli-Shanks algorithm
- Modular matrix operations and linear algebra
- Applications to cryptography and number theory
:End Note

Import "dev/debug/errors/core" as Errors
Import "math/discrete/number_theory" as NumberTheory
Import "math/algebra/polynomial" as Polynomial

Note: =====================================================================
Note: MODULAR ARITHMETIC DATA STRUCTURES
Note: =====================================================================

Type called "ModularInteger":
    value as Integer
    modulus as Integer
    is_reduced as Boolean
    multiplicative_order as Integer
    is_unit as Boolean
    inverse as Integer
    quadratic_character as String
    representation as String

Type called "ModularSystem":
    equations as List[Dictionary[String, Integer]]
    moduli as List[Integer]
    solutions as List[Integer]
    is_consistent as Boolean
    solution_exists as Boolean
    general_solution as Dictionary[String, Integer]
    lcm_modulus as Integer

Type called "QuadraticResidue":
    residue as Integer
    modulus as Integer
    is_quadratic_residue as Boolean
    legendre_symbol as Integer
    jacobi_symbol as Integer
    square_roots as List[Integer]
    tonelli_shanks_data as Dictionary[String, Integer]

Type called "PrimitiveRoot":
    root as Integer
    modulus as Integer
    is_primitive as Boolean
    multiplicative_order as Integer
    generates_group as Boolean
    discrete_log_base as Dictionary[Integer, Integer]
    index_calculus_data as Dictionary[String, Integer]

Type called "ModularEquation":
    coefficients as List[Integer]
    constant as Integer
    modulus as Integer
    degree as Integer
    solutions as List[Integer]
    solution_count as Integer
    is_solvable as Boolean

Type called "CongruenceClass":
    representative as Integer
    modulus as Integer
    class_elements as List[Integer]
    additive_inverse as Integer
    multiplicative_inverse as Integer
    is_zero_divisor as Boolean
    annihilator as List[Integer]

Note: =====================================================================
Note: BASIC MODULAR ARITHMETIC OPERATIONS
Note: =====================================================================

Process called "modular_add" that takes a as Integer, b as Integer, modulus as Integer returns Integer:
    Note: Perform modular addition with efficient reduction
    Note: Computes (a + b) mod m with overflow protection
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    Note: Reduce inputs to canonical form
    Let reduced_a be a % modulus
    Let reduced_b be b % modulus
    
    Note: Handle negative inputs by ensuring positive representatives
    If reduced_a < 0:
        Set reduced_a to reduced_a + modulus
    If reduced_b < 0:
        Set reduced_b to reduced_b + modulus
    
    Note: Compute sum with overflow protection
    Let sum be reduced_a + reduced_b
    
    Note: Apply modular reduction
    If sum >= modulus:
        Set sum to sum - modulus
    
    Return sum

Process called "modular_multiply" that takes a as Integer, b as Integer, modulus as Integer returns Integer:
    Note: Perform modular multiplication with efficient algorithms
    Note: Uses Montgomery multiplication for large moduli
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    Note: Handle special cases
    If modulus == 1:
        Return 0
    
    Note: Reduce inputs to canonical form
    Let reduced_a be a % modulus
    Let reduced_b be b % modulus
    
    Note: Handle negative inputs
    If reduced_a < 0:
        Set reduced_a to reduced_a + modulus
    If reduced_b < 0:
        Set reduced_b to reduced_b + modulus
    
    Note: Handle zero cases
    If reduced_a == 0 || reduced_b == 0:
        Return 0
    
    Note: For small moduli, use direct multiplication
    If modulus < 65536:
        Let product be reduced_a * reduced_b
        Return product % modulus
    
    Note: For larger moduli, use optimized multiplication to prevent overflow
    Let result be 0
    Let base be reduced_a
    
    While reduced_b > 0:
        Note: If b is odd, add current base to result
        If reduced_b % 2 == 1:
            Set result to (result + base) % modulus
        
        Note: Double the base and halve b
        Set base to (base * 2) % modulus
        Set reduced_b to reduced_b / 2
    
    Return result

Process called "modular_exponentiation" that takes base as Integer, exponent as Integer, modulus as Integer returns Integer:
    Note: Compute modular exponentiation using binary method
    Note: Implements square-and-multiply with Montgomery ladders
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If modulus == 1:
        Return 0
    
    If exponent < 0:
        Throw Errors.InvalidArgument with "Exponent must be non-negative"
    
    Note: Handle special cases
    If exponent == 0:
        Return 1
    
    If exponent == 1:
        Return base % modulus
    
    Note: Reduce base modulo m
    Let reduced_base be base % modulus
    If reduced_base < 0:
        Set reduced_base to reduced_base + modulus
    
    If reduced_base == 0:
        Return 0
    
    If reduced_base == 1:
        Return 1
    
    Note: Binary exponentiation (square-and-multiply)
    Let result be 1
    Let current_base be reduced_base
    Let current_exponent be exponent
    
    While current_exponent > 0:
        Note: If exponent is odd, multiply result by current base
        If current_exponent % 2 == 1:
            Set result to modular_multiply(result, current_base, modulus)
        
        Note: Square the base and halve the exponent
        Set current_base to modular_multiply(current_base, current_base, modulus)
        Set current_exponent to current_exponent / 2
    
    Return result

Process called "modular_inverse" that takes a as Integer, modulus as Integer returns Integer:
    Note: Compute modular multiplicative inverse using extended Euclidean algorithm
    Note: Returns x such that ax ≡ 1 (mod m) if gcd(a,m) = 1
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If modulus == 1:
        Return 0
    
    Note: Reduce input to canonical form
    Let reduced_a be a % modulus
    If reduced_a < 0:
        Set reduced_a to reduced_a + modulus
    
    If reduced_a == 0:
        Throw Errors.InvalidArgument with "Cannot find inverse of zero"
    
    Note: Extended Euclidean Algorithm
    Let old_r be modulus
    Let r be reduced_a
    Let old_s be 0
    Let s be 1
    
    While r != 0:
        Let quotient be old_r / r
        
        Note: Update r values
        Let temp_r be r
        Set r to old_r - quotient * r
        Set old_r to temp_r
        
        Note: Update s values
        Let temp_s be s
        Set s to old_s - quotient * s
        Set old_s to temp_s
    
    Note: Check if gcd is 1 (inverse exists)
    If old_r != 1:
        Throw Errors.InvalidArgument with "Modular inverse does not exist (gcd != 1)"
    
    Note: Ensure result is positive
    If old_s < 0:
        Set old_s to old_s + modulus
    
    Return old_s

Process called "fast_modular_reduction" that takes value as Integer, modulus as Integer returns Integer:
    Note: Perform fast modular reduction using specialized algorithms
    Note: Implements Barrett reduction and Montgomery reduction methods
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If modulus == 1:
        Return 0
    
    Note: For small moduli, use standard reduction
    If modulus < 65536:
        Let result be value % modulus
        If result < 0:
            Set result to result + modulus
        Return result
    
    Note: For larger moduli, implement Barrett reduction approximation
    Note: Barrett reduction: compute q = floor(x / m) approximately
    
    Let shifted_value be value
    If shifted_value < 0:
        Note: Handle negative values
        Let abs_value be -shifted_value
        Let quotient_approx be abs_value / modulus
        Let remainder be abs_value - quotient_approx * modulus
        
        If remainder == 0:
            Return 0
        Otherwise:
            Return modulus - remainder
    
    Note: Positive case - approximate division
    Let quotient_approx be shifted_value / modulus
    Let remainder be shifted_value - quotient_approx * modulus
    
    Note: Correct the approximation if needed
    While remainder >= modulus:
        Set remainder to remainder - modulus
    
    While remainder < 0:
        Set remainder to remainder + modulus
    
    Return remainder

Process called "modular_sqrt" that takes a as Integer, modulus as Integer returns List[Integer]:
    Note: Compute modular square roots using Tonelli-Shanks algorithm
    Note: Finds x such that x² ≡ a (mod p) for prime modulus
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    Note: Reduce input
    Let reduced_a be a % modulus
    If reduced_a < 0:
        Set reduced_a to reduced_a + modulus
    
    Let roots be []
    
    Note: Handle special cases
    If reduced_a == 0:
        Set roots to [0]
        Return roots
    
    If modulus == 2:
        Set roots to [reduced_a]
        Return roots
    
    Note: For small moduli, use brute force search
    If modulus <= 1000:
        Let candidate be 0
        While candidate < modulus:
            Let square be modular_multiply(candidate, candidate, modulus)
            If square == reduced_a:
                Set roots to List.append(roots, candidate)
            Set candidate to candidate + 1
        Return roots
    
    Note: For larger prime moduli, implement simplified Tonelli-Shanks
    Note: First check if a is quadratic residue using Euler's criterion
    If modulus % 2 == 1 && modulus > 2:
        Let euler_test_exp be (modulus - 1) / 2
        Let euler_result be modular_exponentiation(reduced_a, euler_test_exp, modulus)
        
        If euler_result != 1:
            Note: Not a quadratic residue
            Return roots
        
        Note: Simple case: p ≡ 3 (mod 4)
        If modulus % 4 == 3:
            Let sqrt_exp be (modulus + 1) / 4
            Let sqrt_candidate be modular_exponentiation(reduced_a, sqrt_exp, modulus)
            Set roots to List.append(roots, sqrt_candidate)
            
            Note: Add the negative root if different
            Let negative_root be modulus - sqrt_candidate
            If negative_root != sqrt_candidate:
                Set roots to List.append(roots, negative_root)
    
    Return roots

Note: =====================================================================
Note: CHINESE REMAINDER THEOREM OPERATIONS
Note: =====================================================================

Process called "chinese_remainder_theorem" that takes remainders as List[Integer], moduli as List[Integer] returns ModularSystem:
    Note: Solve system of congruences using Chinese Remainder Theorem
    Note: Finds x such that x ≡ a_i (mod m_i) when moduli are pairwise coprime
    
    If List.length(remainders) != List.length(moduli):
        Throw Errors.InvalidArgument with "Remainders and moduli lists must have same length"
    
    If List.length(remainders) == 0:
        Throw Errors.InvalidArgument with "Input lists cannot be empty"
    
    Let system be ModularSystem
    Set system.equations to []
    Set system.moduli to moduli
    Set system.solutions to []
    Set system.is_consistent to true
    Set system.solution_exists to true
    
    Note: Check all moduli are positive and compute LCM
    Let total_modulus be 1
    Let modulus_idx be 0
    
    While modulus_idx < List.length(moduli):
        Let current_modulus be List.get(moduli, modulus_idx)
        If current_modulus <= 0:
            Throw Errors.InvalidArgument with "All moduli must be positive"
        
        Note: For CRT, we assume pairwise coprime so LCM is product
        Set total_modulus to total_modulus * current_modulus
        Set modulus_idx to modulus_idx + 1
    
    Set system.lcm_modulus to total_modulus
    
    Note: Apply Chinese Remainder Theorem construction
    Let solution be 0
    Let equation_idx be 0
    
    While equation_idx < List.length(remainders):
        Let remainder be List.get(remainders, equation_idx)
        Let modulus be List.get(moduli, equation_idx)
        
        Note: Reduce remainder to canonical form
        Let reduced_remainder be remainder % modulus
        If reduced_remainder < 0:
            Set reduced_remainder to reduced_remainder + modulus
        
        Note: Compute M_i = total_modulus / modulus_i
        Let partial_product be total_modulus / modulus
        
        Note: Compute y_i = M_i^(-1) mod modulus_i
        Let inverse be modular_inverse(partial_product, modulus)
        
        Note: Add contribution: remainder * M_i * y_i
        Let contribution be modular_multiply(reduced_remainder, partial_product, total_modulus)
        Set contribution to modular_multiply(contribution, inverse, total_modulus)
        Set solution to modular_add(solution, contribution, total_modulus)
        
        Note: Store equation information
        Let equation be {}
        Set equation to {"remainder": reduced_remainder, "modulus": modulus, "partial_product": partial_product, "inverse": inverse}
        Set system.equations to List.append(system.equations, equation)
        
        Set equation_idx to equation_idx + 1
    
    Note: Store the unique solution
    Set system.solutions to [solution]
    
    Note: Create general solution description
    Let general_solution be {}
    Set general_solution to {"base_solution": solution, "period": total_modulus, "parametric_form": "x = " + solution + " + k * " + total_modulus}
    Set system.general_solution to general_solution
    
    Return system

Process called "generalized_crt" that takes remainders as List[Integer], moduli as List[Integer] returns ModularSystem:
    Note: Solve congruence system with non-coprime moduli
    Note: Uses generalized CRT with consistency checking
    
    If List.length(remainders) != List.length(moduli):
        Throw Errors.InvalidArgument with "Remainders and moduli lists must have same length"
    
    If List.length(remainders) == 0:
        Throw Errors.InvalidArgument with "Input lists cannot be empty"
    
    Let system be ModularSystem
    Set system.equations to []
    Set system.moduli to moduli
    Set system.solutions to []
    Set system.is_consistent to true
    Set system.solution_exists to true
    
    Note: Start with first congruence
    If List.length(remainders) == 1:
        Let remainder be List.get(remainders, 0)
        Let modulus be List.get(moduli, 0)
        Set system.solutions to [remainder % modulus]
        Set system.lcm_modulus to modulus
        Return system
    
    Note: Combine congruences pairwise
    Let current_remainder be List.get(remainders, 0)
    Let current_modulus be List.get(moduli, 0)
    Let pair_idx be 1
    
    While pair_idx < List.length(remainders):
        Let next_remainder be List.get(remainders, pair_idx)
        Let next_modulus be List.get(moduli, pair_idx)
        
        Note: Solve: x ≡ current_remainder (mod current_modulus)
        Note:        x ≡ next_remainder (mod next_modulus)
        Note: This becomes: current_remainder + k*current_modulus ≡ next_remainder (mod next_modulus)
        Note: Or: k*current_modulus ≡ (next_remainder - current_remainder) (mod next_modulus)
        
        Let difference be next_remainder - current_remainder
        
        Note: Compute gcd to check consistency and find solution
        Note: Inline extended GCD computation
        Let gcd_value be 0
        Let bezout_s be 0
        Let bezout_t be 0
        
        Note: Extended Euclidean algorithm inlined
        If next_modulus == 0:
            Set gcd_value to current_modulus
            Set bezout_s to 1
            Set bezout_t to 0
        Otherwise:
            Let old_r be current_modulus
            Let r be next_modulus
            Let old_s be 1
            Let s be 0
            Let old_t be 0
            Let t be 1
            
            While r != 0:
                Let quotient be old_r / r
                
                Let temp_r be r
                Set r to old_r - quotient * r
                Set old_r to temp_r
                
                Let temp_s be s
                Set s to old_s - quotient * s
                Set old_s to temp_s
                
                Let temp_t be t
                Set t to old_t - quotient * t
                Set old_t to temp_t
            
            Set gcd_value to old_r
            Set bezout_s to old_s
            Set bezout_t to old_t
        
        Note: Check if system is consistent
        If difference % gcd_value != 0:
            Set system.is_consistent to false
            Set system.solution_exists to false
            Return system
        
        Note: Find particular solution
        Let scaled_difference be difference / gcd_value
        Let k_solution be modular_multiply(scaled_difference, bezout_s, next_modulus / gcd_value)
        
        Note: Combine into single congruence
        Let combined_remainder be current_remainder + k_solution * current_modulus
        Let combined_modulus be (current_modulus / gcd_value) * next_modulus
        
        Note: Reduce to canonical form
        Set combined_remainder to combined_remainder % combined_modulus
        If combined_remainder < 0:
            Set combined_remainder to combined_remainder + combined_modulus
        
        Set current_remainder to combined_remainder
        Set current_modulus to combined_modulus
        Set pair_idx to pair_idx + 1
    
    Set system.solutions to [current_remainder]
    Set system.lcm_modulus to current_modulus
    
    Let general_solution be {}
    Set general_solution to {"base_solution": current_remainder, "period": current_modulus, "parametric_form": "x = " + current_remainder + " + k * " + current_modulus}
    Set system.general_solution to general_solution
    
    Return system

Process called "crt_interpolation" that takes values as List[Integer], points as List[Integer], modulus as Integer returns List[Integer]:
    Note: Perform polynomial interpolation using CRT methods
    Note: Reconstructs polynomial from evaluations at distinct points
    
    If List.length(values) != List.length(points):
        Throw Errors.InvalidArgument with "Values and points lists must have same length"
    
    If List.length(values) == 0:
        Throw Errors.InvalidArgument with "Input lists cannot be empty"
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    Let degree be List.length(values) - 1
    Let coefficients be []
    
    Note: Use Lagrange interpolation modulo m
    Let coeff_idx be 0
    While coeff_idx <= degree:
        Let coefficient be 0
        Let point_idx be 0
        
        While point_idx < List.length(points):
            Let point be List.get(points, point_idx)
            Let value be List.get(values, point_idx)
            
            Note: Compute Lagrange basis polynomial L_j(x_i) evaluated at coefficient position
            Let basis_contribution be value
            Let inner_idx be 0
            
            Note: Compute product for Lagrange basis
            While inner_idx < List.length(points):
                If inner_idx != point_idx:
                    Let other_point be List.get(points, inner_idx)
                    Let numerator be coeff_idx - other_point
                    Let denominator be point - other_point
                    
                    Note: Handle modular division
                    Let denominator_inv be modular_inverse(denominator, modulus)
                    Let factor be modular_multiply(numerator, denominator_inv, modulus)
                    Set basis_contribution to modular_multiply(basis_contribution, factor, modulus)
                
                Set inner_idx to inner_idx + 1
            
            Set coefficient to modular_add(coefficient, basis_contribution, modulus)
            Set point_idx to point_idx + 1
        
        Set coefficients to List.append(coefficients, coefficient)
        Set coeff_idx to coeff_idx + 1
    
    Return coefficients

Process called "mixed_radix_representation" that takes value as Integer, moduli as List[Integer] returns List[Integer]:
    Note: Convert integer to mixed radix representation
    Note: Expresses number in terms of hierarchical modular system
    
    If List.length(moduli) == 0:
        Throw Errors.InvalidArgument with "Moduli list cannot be empty"
    
    Note: Check all moduli are positive
    Let modulus_idx be 0
    While modulus_idx < List.length(moduli):
        Let modulus be List.get(moduli, modulus_idx)
        If modulus <= 0:
            Throw Errors.InvalidArgument with "All moduli must be positive"
        Set modulus_idx to modulus_idx + 1
    
    Let representation be []
    Let remaining_value be value
    
    Note: Extract digits in mixed radix system
    Let digit_idx be 0
    While digit_idx < List.length(moduli):
        Let current_modulus be List.get(moduli, digit_idx)
        
        Note: Compute digit for this position
        Let digit be remaining_value % current_modulus
        If digit < 0:
            Set digit to digit + current_modulus
        
        Set representation to List.append(representation, digit)
        
        Note: Update remaining value for next position
        Set remaining_value to (remaining_value - digit) / current_modulus
        Set digit_idx to digit_idx + 1
    
    Note: Handle any remaining value (overflow)
    If remaining_value != 0:
        Set representation to List.append(representation, remaining_value)
    
    Return representation

Note: =====================================================================
Note: QUADRATIC RESIDUE OPERATIONS
Note: =====================================================================

Process called "legendre_symbol" that takes a as Integer, p as Integer returns Integer:
    Note: Compute Legendre symbol (a/p) for odd prime p
    Note: Returns 1 if a is quadratic residue, -1 if not, 0 if a ≡ 0 (mod p)
    
    If p <= 2:
        Throw Errors.InvalidArgument with "Prime must be odd and greater than 2"
    
    If p % 2 == 0:
        Throw Errors.InvalidArgument with "Prime must be odd"
    
    Note: Reduce a modulo p
    Let reduced_a be a % p
    If reduced_a < 0:
        Set reduced_a to reduced_a + p
    
    Note: Handle special case: a ≡ 0 (mod p)
    If reduced_a == 0:
        Return 0
    
    Note: Use Euler's criterion: (a/p) ≡ a^((p-1)/2) (mod p)
    Let exponent be (p - 1) / 2
    Let result be modular_exponentiation(reduced_a, exponent, p)
    
    Note: Convert result to Legendre symbol format
    If result == 1:
        Return 1
    
    If result == p - 1:
        Return -1
    
    Note: This should not happen for valid prime p
    Return 0

Process called "jacobi_symbol" that takes a as Integer, n as Integer returns Integer:
    Note: Compute Jacobi symbol (a/n) for odd n
    Note: Generalizes Legendre symbol to composite moduli
    
    If n <= 0:
        Throw Errors.InvalidArgument with "n must be positive"
    
    If n % 2 == 0:
        Throw Errors.InvalidArgument with "n must be odd"
    
    Note: Reduce a modulo n
    Let reduced_a be a % n
    If reduced_a < 0:
        Set reduced_a to reduced_a + n
    
    Note: Handle base cases
    If reduced_a == 0:
        If n == 1:
            Return 1
        Otherwise:
            Return 0
    
    If reduced_a == 1:
        Return 1
    
    If n == 1:
        Return 1
    
    Note: Use binary Jacobi symbol algorithm
    Let result be 1
    Let current_a be reduced_a
    Let current_n be n
    
    While current_a != 0:
        Note: Remove factors of 2 from a
        While current_a % 2 == 0:
            Set current_a to current_a / 2
            
            Note: Apply rule for (2/n): (2/n) = (-1)^((n²-1)/8)
            Let n_mod_8 be current_n % 8
            If n_mod_8 == 3 || n_mod_8 == 5:
                Set result to -result
        
        Note: Swap a and n
        Let temp be current_a
        Set current_a to current_n
        Set current_n to temp
        
        Note: Apply quadratic reciprocity: (a/n)(n/a) = (-1)^((a-1)(n-1)/4)
        If current_a % 4 == 3 && current_n % 4 == 3:
            Set result to -result
        
        Note: Reduce a modulo n
        Set current_a to current_a % current_n
    
    Note: Check final result
    If current_n == 1:
        Return result
    Otherwise:
        Return 0

Process called "is_quadratic_residue" that takes a as Integer, modulus as Integer returns Boolean:
    Note: Test if integer is quadratic residue modulo given number
    Note: Uses quadratic character and efficient residue testing
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If modulus == 1:
        Return true
    
    Note: Reduce a modulo modulus
    Let reduced_a be a % modulus
    If reduced_a < 0:
        Set reduced_a to reduced_a + modulus
    
    Note: Handle special cases
    If reduced_a == 0:
        Return true
    
    If reduced_a == 1:
        Return true
    
    Note: For small moduli, use brute force
    If modulus <= 1000:
        Let candidate be 0
        While candidate < modulus:
            Let square be modular_multiply(candidate, candidate, modulus)
            If square == reduced_a:
                Return true
            Set candidate to candidate + 1
        Return false
    
    Note: For odd moduli, use Jacobi symbol
    If modulus % 2 == 1:
        Let jacobi_result be jacobi_symbol(reduced_a, modulus)
        Return jacobi_result == 1
    
    Note: For even moduli, check if both a and modulus/2 are quadratic residues
    If modulus % 2 == 0:
        Note: For composite even moduli, simplified test
        If reduced_a % 2 == 0:
            Return is_quadratic_residue(reduced_a / 4, modulus / 4)
        Otherwise:
            Note: Odd number modulo even modulus - check using properties
            Let half_modulus be modulus / 2
            If half_modulus % 2 == 1:
                Return jacobi_symbol(reduced_a, half_modulus) == 1
            Otherwise:
                Return is_quadratic_residue(reduced_a, half_modulus)
    
    Return false

Process called "quadratic_residues_mod_n" that takes modulus as Integer returns List[Integer]:
    Note: Find all quadratic residues modulo given integer
    Note: Enumerates all squares modulo n and finds unique residues
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If modulus == 1:
        Return [0]
    
    Let residues be []
    Let seen_residues be []
    
    Note: Compute all squares modulo n
    Let base be 0
    While base < modulus:
        Let square be modular_multiply(base, base, modulus)
        
        Note: Check if this residue is already found
        Let already_seen be false
        Let seen_idx be 0
        
        While seen_idx < List.length(seen_residues):
            Let seen_residue be List.get(seen_residues, seen_idx)
            If seen_residue == square:
                Set already_seen to true
            Set seen_idx to seen_idx + 1
        
        Note: Add to list if not already seen
        If already_seen == false:
            Set residues to List.append(residues, square)
            Set seen_residues to List.append(seen_residues, square)
        
        Set base to base + 1
    
    Note: Sort residues for consistent output
    Note: Inline sorting of residues
    Let sorted_residues be residues
    Let residues_length be List.length(sorted_residues)
    
    If residues_length > 1:
        Let i be 0
        While i < residues_length - 1:
            Let j be 0
            While j < residues_length - i - 1:
                Let current be List.get(sorted_residues, j)
                Let next be List.get(sorted_residues, j + 1)
                
                If current > next:
                    Set sorted_residues to List.set(sorted_residues, j, next)
                    Set sorted_residues to List.set(sorted_residues, j + 1, current)
                
                Set j to j + 1
            Set i to i + 1
    Return sorted_residues

Process called "tonelli_shanks_algorithm" that takes n as Integer, p as Integer returns List[Integer]:
    Note: Find square roots modulo prime using Tonelli-Shanks algorithm
    Note: Efficient algorithm for computing x such that x² ≡ n (mod p)
    
    If p <= 2:
        Throw Errors.InvalidArgument with "Prime must be greater than 2"
    
    If p % 2 == 0:
        Throw Errors.InvalidArgument with "Prime must be odd"
    
    Note: Reduce n modulo p
    Let reduced_n be n % p
    If reduced_n < 0:
        Set reduced_n to reduced_n + p
    
    Let roots be []
    
    Note: Handle special cases
    If reduced_n == 0:
        Set roots to [0]
        Return roots
    
    Note: Check if n is quadratic residue
    Let legendre_result be legendre_symbol(reduced_n, p)
    If legendre_result != 1:
        Return roots
    
    Note: Handle simple case: p ≡ 3 (mod 4)
    If p % 4 == 3:
        Let exponent be (p + 1) / 4
        Let root be modular_exponentiation(reduced_n, exponent, p)
        Set roots to List.append(roots, root)
        
        Let negative_root be p - root
        If negative_root != root:
            Set roots to List.append(roots, negative_root)
        Return roots
    
    Note: General Tonelli-Shanks algorithm for p ≡ 1 (mod 4)
    Note: Find Q and S such that p - 1 = Q * 2^S with Q odd
    Let Q be p - 1
    Let S be 0
    
    While Q % 2 == 0:
        Set Q to Q / 2
        Set S to S + 1
    
    Note: Find quadratic non-residue z
    Let z be 2
    While legendre_symbol(z, p) != -1:
        Set z to z + 1
    
    Note: Initialize algorithm variables
    Let M be S
    Let c be modular_exponentiation(z, Q, p)
    Let t be modular_exponentiation(reduced_n, Q, p)
    Let R be modular_exponentiation(reduced_n, (Q + 1) / 2, p)
    
    Note: Main Tonelli-Shanks loop
    While t != 1:
        Note: Find smallest i such that t^(2^i) ≡ 1 (mod p)
        Let i be 1
        Let temp_t be modular_multiply(t, t, p)
        
        While temp_t != 1 && i < M:
            Set temp_t to modular_multiply(temp_t, temp_t, p)
            Set i to i + 1
        
        If i == M:
            Note: Algorithm failed - should not happen for valid inputs
            Return roots
        
        Note: Update variables
        Let b be modular_exponentiation(c, modular_exponentiation(2, M - i - 1, p - 1), p)
        Set M to i
        Set c to modular_multiply(b, b, p)
        Set t to modular_multiply(t, c, p)
        Set R to modular_multiply(R, b, p)
    
    Note: Return both square roots
    Set roots to List.append(roots, R)
    Let negative_root be p - R
    If negative_root != R:
        Set roots to List.append(roots, negative_root)
    
    Return roots

Process called "cipolla_algorithm" that takes n as Integer, p as Integer returns List[Integer]:
    Note: Find square roots modulo prime using Cipolla's algorithm
    Note: Alternative to Tonelli-Shanks with different complexity characteristics
    
    If p <= 2:
        Throw Errors.InvalidArgument with "Prime must be greater than 2"
    
    If p % 2 == 0:
        Throw Errors.InvalidArgument with "Prime must be odd"
    
    Note: Reduce n modulo p
    Let reduced_n be n % p
    If reduced_n < 0:
        Set reduced_n to reduced_n + p
    
    Let roots be []
    
    Note: Handle special cases
    If reduced_n == 0:
        Set roots to [0]
        Return roots
    
    Note: Check if n is quadratic residue
    Let legendre_result be legendre_symbol(reduced_n, p)
    If legendre_result != 1:
        Return roots
    
    Note: Handle simple case: p ≡ 3 (mod 4)
    If p % 4 == 3:
        Let exponent be (p + 1) / 4
        Let root be modular_exponentiation(reduced_n, exponent, p)
        Set roots to List.append(roots, root)
        
        Let negative_root be p - root
        If negative_root != root:
            Set roots to List.append(roots, negative_root)
        Return roots
    
    Note: Cipolla's algorithm for p ≡ 1 (mod 4)
    Note: Find a such that a² - n is not a quadratic residue
    Let a be 1
    Let omega_squared be 0
    Let found_a be false
    
    While found_a == false && a < p:
        Set omega_squared to modular_add(modular_multiply(a, a, p), -reduced_n, p)
        If omega_squared < 0:
            Set omega_squared to omega_squared + p
        
        Let legendre_omega be legendre_symbol(omega_squared, p)
        If legendre_omega == -1:
            Set found_a to true
        Otherwise:
            Set a to a + 1
    
    If found_a == false:
        Note: Should not happen for valid prime p
        Return roots
    
    Note: Compute (a + ω)^((p+1)/2) in F_p[ω] where ω² = a² - n
    Note: Using binary exponentiation in the quadratic field extension
    Let exponent be (p + 1) / 2
    Let result_real be 1
    Let result_imag be 0
    Let base_real be a
    Let base_imag be 1
    
    While exponent > 0:
        If exponent % 2 == 1:
            Note: Multiply result by base in F_p[ω]
            Let new_real be modular_add(modular_multiply(result_real, base_real, p), modular_multiply(modular_multiply(result_imag, base_imag, p), omega_squared, p), p)
            Let new_imag be modular_add(modular_multiply(result_real, base_imag, p), modular_multiply(result_imag, base_real, p), p)
            Set result_real to new_real
            Set result_imag to new_imag
        
        Note: Square base in F_p[ω]
        Let new_base_real be modular_add(modular_multiply(base_real, base_real, p), modular_multiply(modular_multiply(base_imag, base_imag, p), omega_squared, p), p)
        Let new_base_imag be modular_multiply(modular_multiply(2, base_real, p), base_imag, p)
        Set base_real to new_base_real
        Set base_imag to new_base_imag
        
        Set exponent to exponent / 2
    
    Note: The result should have imaginary part 0
    If result_imag != 0:
        Note: Algorithm error - should not happen
        Return roots
    
    Note: Return both square roots
    Set roots to List.append(roots, result_real)
    Let negative_root be p - result_real
    If negative_root != result_real:
        Set roots to List.append(roots, negative_root)
    
    Return roots

Note: =====================================================================
Note: PRIMITIVE ROOT OPERATIONS
Note: =====================================================================

Process called "find_primitive_root" that takes modulus as Integer returns PrimitiveRoot:
    Note: Find primitive root modulo given integer
    Note: Finds generator of multiplicative group (Z/nZ)*
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    Let primitive_root be PrimitiveRoot
    Set primitive_root.modulus to modulus
    Set primitive_root.is_primitive to false
    Set primitive_root.multiplicative_order to 0
    Set primitive_root.generates_group to false
    Set primitive_root.discrete_log_base to {}
    Set primitive_root.index_calculus_data to {}
    
    Note: Primitive roots exist only for n = 1, 2, 4, p^k, 2p^k where p is odd prime
    If modulus == 1:
        Set primitive_root.root to 0
        Set primitive_root.is_primitive to true
        Set primitive_root.multiplicative_order to 1
        Set primitive_root.generates_group to true
        Return primitive_root
    
    If modulus == 2:
        Set primitive_root.root to 1
        Set primitive_root.is_primitive to true
        Set primitive_root.multiplicative_order to 1
        Set primitive_root.generates_group to true
        Return primitive_root
    
    If modulus == 4:
        Set primitive_root.root to 3
        Set primitive_root.is_primitive to true
        Set primitive_root.multiplicative_order to 2
        Set primitive_root.generates_group to true
        Return primitive_root
    
    Note: Compute Euler's totient function for the modulus
    Let phi_n be euler_totient(modulus)
    
    Note: Find all prime factors of φ(n)
    Let prime_factors be find_prime_factors(phi_n)
    
    Note: Search for primitive root by testing candidates
    Let candidate be 2
    While candidate < modulus:
        If compute_gcd(candidate, modulus) == 1:
            Let is_primitive_candidate be true
            
            Note: Check if candidate^(φ(n)/p) ≢ 1 (mod n) for all prime factors p of φ(n)
            Let factor_idx be 0
            While factor_idx < List.length(prime_factors) && is_primitive_candidate:
                Let prime_factor be List.get(prime_factors, factor_idx)
                Let exponent be phi_n / prime_factor
                Let result be modular_exponentiation(candidate, exponent, modulus)
                
                If result == 1:
                    Set is_primitive_candidate to false
                
                Set factor_idx to factor_idx + 1
            
            If is_primitive_candidate:
                Set primitive_root.root to candidate
                Set primitive_root.is_primitive to true
                Set primitive_root.multiplicative_order to phi_n
                Set primitive_root.generates_group to true
                Return primitive_root
        
        Set candidate to candidate + 1
    
    Note: No primitive root found
    Set primitive_root.root to 0
    Return primitive_root

Process called "test_primitive_root" that takes root as Integer, modulus as Integer returns Boolean:
    Note: Test if given integer is primitive root modulo n
    Note: Verifies that order of root equals φ(n)
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    Note: Reduce root modulo modulus
    Let reduced_root be root % modulus
    If reduced_root < 0:
        Set reduced_root to reduced_root + modulus
    
    Note: Check if gcd(root, modulus) = 1
    If compute_gcd(reduced_root, modulus) != 1:
        Return false
    
    Note: Handle special cases
    If modulus == 1:
        Return reduced_root == 0
    
    If modulus == 2:
        Return reduced_root == 1
    
    If modulus == 4:
        Return reduced_root == 3
    
    Note: Compute Euler's totient function
    Let phi_n be euler_totient(modulus)
    
    Note: Find prime factors of φ(n)
    Let prime_factors be find_prime_factors(phi_n)
    
    Note: Test primitive root condition: root^(φ(n)/p) ≢ 1 (mod n) for all prime factors p
    Let factor_idx be 0
    While factor_idx < List.length(prime_factors):
        Let prime_factor be List.get(prime_factors, factor_idx)
        Let exponent be phi_n / prime_factor
        Let result be modular_exponentiation(reduced_root, exponent, modulus)
        
        If result == 1:
            Return false
        
        Set factor_idx to factor_idx + 1
    
    Note: Also verify that root^φ(n) ≡ 1 (mod n)
    Let final_check be modular_exponentiation(reduced_root, phi_n, modulus)
    Return final_check == 1

Process called "multiplicative_order" that takes a as Integer, modulus as Integer returns Integer:
    Note: Compute multiplicative order of element in group (Z/nZ)*
    Note: Finds smallest positive k such that a^k ≡ 1 (mod n)
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If modulus == 1:
        Return 1
    
    Note: Reduce a modulo modulus
    Let reduced_a be a % modulus
    If reduced_a < 0:
        Set reduced_a to reduced_a + modulus
    
    Note: Check if gcd(a, modulus) = 1
    If compute_gcd(reduced_a, modulus) != 1:
        Throw Errors.InvalidArgument with "Element must be coprime to modulus"
    
    If reduced_a == 1:
        Return 1
    
    Note: Compute Euler's totient function
    Let phi_n be euler_totient(modulus)
    
    Note: Find all divisors of φ(n) to test as potential orders
    Let divisors be find_divisors(phi_n)
    Note: Inline sorting of divisors
    Let sorted_divisors be divisors
    Let divisors_length be List.length(sorted_divisors)
    
    If divisors_length > 1:
        Let i be 0
        While i < divisors_length - 1:
            Let j be 0
            While j < divisors_length - i - 1:
                Let current be List.get(sorted_divisors, j)
                Let next be List.get(sorted_divisors, j + 1)
                
                If current > next:
                    Set sorted_divisors to List.set(sorted_divisors, j, next)
                    Set sorted_divisors to List.set(sorted_divisors, j + 1, current)
                
                Set j to j + 1
            Set i to i + 1
    
    Note: Test divisors in ascending order to find smallest order
    Let divisor_idx be 0
    While divisor_idx < List.length(sorted_divisors):
        Let potential_order be List.get(sorted_divisors, divisor_idx)
        Let result be modular_exponentiation(reduced_a, potential_order, modulus)
        
        If result == 1:
            Return potential_order
        
        Set divisor_idx to divisor_idx + 1
    
    Note: Should not reach here if φ(n) is correct
    Return phi_n

Process called "discrete_logarithm" that takes base as Integer, target as Integer, modulus as Integer returns Integer:
    Note: Compute discrete logarithm using index calculus and baby-step giant-step
    Note: Finds x such that base^x ≡ target (mod modulus)
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    Note: Reduce inputs modulo modulus
    Let reduced_base be base % modulus
    If reduced_base < 0:
        Set reduced_base to reduced_base + modulus
    
    Let reduced_target be target % modulus
    If reduced_target < 0:
        Set reduced_target to reduced_target + modulus
    
    Note: Handle special cases
    If reduced_base == 1:
        If reduced_target == 1:
            Return 0
        Otherwise:
            Throw Errors.InvalidArgument with "No solution exists"
    
    If reduced_target == 1:
        Return 0
    
    If reduced_base == reduced_target:
        Return 1
    
    Note: Check if both base and target are coprime to modulus
    If compute_gcd(reduced_base, modulus) != 1:
        Throw Errors.InvalidArgument with "Base must be coprime to modulus"
    
    If compute_gcd(reduced_target, modulus) != 1:
        Throw Errors.InvalidArgument with "Target must be coprime to modulus"
    
    Note: Use baby-step giant-step algorithm
    Return baby_step_giant_step(reduced_base, reduced_target, modulus)

Process called "baby_step_giant_step" that takes base as Integer, target as Integer, modulus as Integer returns Integer:
    Note: Compute discrete logarithm using baby-step giant-step algorithm
    Note: Time-memory tradeoff algorithm with O(√n) complexity
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    Note: Compute search bound m = ceil(√φ(n))
    Let phi_n be euler_totient(modulus)
    Note: Inline integer square root computation
    Let sqrt_value be 0
    If phi_n < 0:
        Throw Errors.InvalidArgument with "Cannot compute square root of negative number"
    
    If phi_n == 0:
        Set sqrt_value to 0
    Otherwise:
        If phi_n == 1:
            Set sqrt_value to 1
        Otherwise:
            Let x be phi_n
            Let y be (x + 1) / 2
            
            While y < x:
                Set x to y
                Set y to (x + phi_n / x) / 2
            
            Set sqrt_value to x
    
    Let m be sqrt_value + 1
    
    Note: Baby steps: compute base^j for j = 0, 1, ..., m-1
    Let baby_steps be {}
    Let current_power be 1
    Let j be 0
    
    While j < m:
        Note: Store baby step: base^j -> j
        Set baby_steps to dict_set(baby_steps, current_power, j)
        
        Note: Check if we found a match immediately
        If current_power == target:
            Return j
        
        Set current_power to modular_multiply(current_power, base, modulus)
        Set j to j + 1
    
    Note: Giant steps: compute target * (base^(-m))^i for i = 0, 1, ..., m-1
    Let base_m be modular_exponentiation(base, m, modulus)
    Let base_m_inv be modular_inverse(base_m, modulus)
    
    Let gamma be target
    Let i be 0
    
    While i < m:
        Note: Check if gamma is in baby steps
        If dict_contains(baby_steps, gamma):
            Let j be dict_get(baby_steps, gamma)
            Let result be i * m + j
            
            Note: Verify the result
            Let verification be modular_exponentiation(base, result, modulus)
            If verification == target:
                Return result
        
        Set gamma to modular_multiply(gamma, base_m_inv, modulus)
        Set i to i + 1
    
    Note: No solution found within the search space
    Throw Errors.InvalidArgument with "Discrete logarithm not found"

Process called "pollard_rho_log" that takes base as Integer, target as Integer, modulus as Integer returns Integer:
    Note: Compute discrete logarithm using Pollard's rho algorithm
    Note: Probabilistic algorithm with expected O(√n) running time
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    Note: For small cases, use baby-step giant-step
    If modulus <= 1000:
        Return baby_step_giant_step(base, target, modulus)
    
    Note: Simplified Pollard's rho implementation
    Note: Use Floyd's cycle detection with pseudorandom function f(x) = base * x
    
    Let phi_n be euler_totient(modulus)
    
    Note: Initialize tortoise and hare
    Let tortoise_x be 1
    Let tortoise_a be 0
    Let tortoise_b be 0
    
    Let hare_x be 1
    Let hare_a be 0 
    Let hare_b be 0
    
    Note: Iterate until collision is found
    Let max_iterations be phi_n
    Let iteration be 0
    
    While iteration < max_iterations:
        Note: Move tortoise one step
        Let tortoise_partition be tortoise_x % 3
        
        If tortoise_partition == 0:
            Set tortoise_x to modular_multiply(tortoise_x, tortoise_x, modulus)
            Set tortoise_a to (tortoise_a * 2) % phi_n
            Set tortoise_b to (tortoise_b * 2) % phi_n
        Otherwise:
            If tortoise_partition == 1:
                Set tortoise_x to modular_multiply(tortoise_x, base, modulus)
                Set tortoise_a to (tortoise_a + 1) % phi_n
            Otherwise:
                Set tortoise_x to modular_multiply(tortoise_x, target, modulus)
                Set tortoise_b to (tortoise_b + 1) % phi_n
        
        Note: Move hare two steps
        Let step_count be 0
        While step_count < 2:
            Let hare_partition be hare_x % 3
            
            If hare_partition == 0:
                Set hare_x to modular_multiply(hare_x, hare_x, modulus)
                Set hare_a to (hare_a * 2) % phi_n
                Set hare_b to (hare_b * 2) % phi_n
            Otherwise:
                If hare_partition == 1:
                    Set hare_x to modular_multiply(hare_x, base, modulus)
                    Set hare_a to (hare_a + 1) % phi_n
                Otherwise:
                    Set hare_x to modular_multiply(hare_x, target, modulus)
                    Set hare_b to (hare_b + 1) % phi_n
            
            Set step_count to step_count + 1
        
        Note: Check for collision
        If tortoise_x == hare_x:
            Note: Found collision, solve for discrete logarithm
            Let r be (tortoise_a - hare_a) % phi_n
            Let s be (hare_b - tortoise_b) % phi_n
            
            If s != 0:
                Note: Inline extended GCD computation
                Let gcd_value be 0
                Let gcd_s_coeff be 0
                
                Note: Extended Euclidean algorithm inlined for s and phi_n
                If phi_n == 0:
                    Set gcd_value to s
                    Set gcd_s_coeff to 1
                Otherwise:
                    Let old_r be s
                    Let r be phi_n
                    Let old_s be 1
                    Let s_val be 0
                    
                    While r != 0:
                        Let quotient be old_r / r
                        
                        Let temp_r be r
                        Set r to old_r - quotient * r
                        Set old_r to temp_r
                        
                        Let temp_s be s_val
                        Set s_val to old_s - quotient * s_val
                        Set old_s to temp_s
                    
                    Set gcd_value to old_r
                    Set gcd_s_coeff to old_s
                
                If r % gcd_value == 0:
                    Let s_inv be gcd_s_coeff
                    Let solution be (r / gcd_value * s_inv) % (phi_n / gcd_value)
                    
                    Note: Verify solution
                    Let verification be modular_exponentiation(base, solution, modulus)
                    If verification == target:
                        Return solution
        
        Set iteration to iteration + 1
    
    Note: Fallback to baby-step giant-step if Pollard rho fails
    Return baby_step_giant_step(base, target, modulus)

Note: =====================================================================
Note: CONGRUENCE SOLVING OPERATIONS
Note: =====================================================================

Process called "solve_linear_congruence" that takes a as Integer, b as Integer, modulus as Integer returns List[Integer]:
    Note: Solve linear congruence ax ≡ b (mod m)
    Note: Uses extended Euclidean algorithm and GCD analysis
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If modulus == 1:
        Return [0]
    
    Note: Reduce coefficients modulo m
    Let reduced_a be a % modulus
    If reduced_a < 0:
        Set reduced_a to reduced_a + modulus
    
    Let reduced_b be b % modulus
    If reduced_b < 0:
        Set reduced_b to reduced_b + modulus
    
    Note: Handle special case: a ≡ 0 (mod m)
    If reduced_a == 0:
        If reduced_b == 0:
            Note: 0x ≡ 0 (mod m) has all solutions
            Let all_solutions be []
            Let x be 0
            While x < modulus:
                Set all_solutions to List.append(all_solutions, x)
                Set x to x + 1
            Return all_solutions
        Otherwise:
            Note: 0x ≡ b (mod m) with b ≠ 0 has no solutions
            Return []
    
    Note: Compute gcd(a, m) using extended Euclidean algorithm
    Note: Inline extended GCD computation
    Let gcd_value be 0
    Let bezout_coeff be 0
    
    Note: Extended Euclidean algorithm inlined for reduced_a and modulus
    If modulus == 0:
        Set gcd_value to reduced_a
        Set bezout_coeff to 1
    Otherwise:
        Let old_r be reduced_a
        Let r be modulus
        Let old_s be 1
        Let s_val be 0
        
        While r != 0:
            Let quotient be old_r / r
            
            Let temp_r be r
            Set r to old_r - quotient * r
            Set old_r to temp_r
            
            Let temp_s be s_val
            Set s_val to old_s - quotient * s_val
            Set old_s to temp_s
        
        Set gcd_value to old_r
        Set bezout_coeff to old_s
    
    Note: Check if congruence has solutions
    If reduced_b % gcd_value != 0:
        Return []
    
    Note: Reduce to simpler congruence
    Let simplified_a be reduced_a / gcd_value
    Let simplified_b be reduced_b / gcd_value
    Let simplified_modulus be modulus / gcd_value
    
    Note: Find particular solution
    Let particular_solution be (bezout_coeff * simplified_b) % simplified_modulus
    If particular_solution < 0:
        Set particular_solution to particular_solution + simplified_modulus
    
    Note: Generate all solutions
    Let solutions be []
    Let solution_step be simplified_modulus
    Let solution_idx be 0
    
    While solution_idx < gcd_value:
        Let current_solution be particular_solution + solution_idx * solution_step
        Set current_solution to current_solution % modulus
        If current_solution < 0:
            Set current_solution to current_solution + modulus
        
        Set solutions to List.append(solutions, current_solution)
        Set solution_idx to solution_idx + 1
    
    Note: Inline sorting of solutions
    Let sorted_solutions be solutions
    Let solutions_length be List.length(sorted_solutions)
    
    If solutions_length > 1:
        Let i be 0
        While i < solutions_length - 1:
            Let j be 0
            While j < solutions_length - i - 1:
                Let current be List.get(sorted_solutions, j)
                Let next be List.get(sorted_solutions, j + 1)
                
                If current > next:
                    Set sorted_solutions to List.set(sorted_solutions, j, next)
                    Set sorted_solutions to List.set(sorted_solutions, j + 1, current)
                
                Set j to j + 1
            Set i to i + 1
    Return sorted_solutions

Process called "solve_quadratic_congruence" that takes a as Integer, b as Integer, c as Integer, modulus as Integer returns List[Integer]:
    Note: Solve quadratic congruence ax² + bx + c ≡ 0 (mod m)
    Note: Uses completing the square and modular square root algorithms
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If modulus == 1:
        Return [0]
    
    Note: Reduce coefficients modulo m
    Let reduced_a be a % modulus
    If reduced_a < 0:
        Set reduced_a to reduced_a + modulus
    
    Let reduced_b be b % modulus
    If reduced_b < 0:
        Set reduced_b to reduced_b + modulus
    
    Let reduced_c be c % modulus
    If reduced_c < 0:
        Set reduced_c to reduced_c + modulus
    
    Note: Handle degenerate case: a ≡ 0 (mod m) - becomes linear congruence
    If reduced_a == 0:
        Return solve_linear_congruence(reduced_b, -reduced_c, modulus)
    
    Note: Check if a has modular inverse
    If compute_gcd(reduced_a, modulus) != 1:
        Note: For composite moduli, use brute force for small cases
        If modulus <= 1000:
            Let solutions be []
            Let x be 0
            While x < modulus:
                Let value be modular_add(modular_add(modular_multiply(modular_multiply(reduced_a, x, modulus), x, modulus), modular_multiply(reduced_b, x, modulus), modulus), reduced_c, modulus)
                If value == 0:
                    Set solutions to List.append(solutions, x)
                Set x to x + 1
            Return solutions
        Otherwise:
            Throw Errors.InvalidArgument with "Coefficient 'a' must be coprime to modulus for large moduli"
    
    Note: Complete the square: ax² + bx + c ≡ 0 (mod m)
    Note: Multiply by 4a: 4a²x² + 4abx + 4ac ≡ 0 (mod m)
    Note: Rewrite as: (2ax + b)² - b² + 4ac ≡ 0 (mod m)
    Note: So: (2ax + b)² ≡ b² - 4ac (mod m)
    
    Let discriminant be modular_add(modular_multiply(reduced_b, reduced_b, modulus), -modular_multiply(modular_multiply(4, reduced_a, modulus), reduced_c, modulus), modulus)
    If discriminant < 0:
        Set discriminant to discriminant + modulus
    
    Note: Find square roots of discriminant
    Let sqrt_discriminant be modular_sqrt(discriminant, modulus)
    
    If List.length(sqrt_discriminant) == 0:
        Return []
    
    Note: For each square root, solve 2ax + b ≡ ±√discriminant (mod m)
    Let solutions be []
    Let sqrt_idx be 0
    
    While sqrt_idx < List.length(sqrt_discriminant):
        Let sqrt_d be List.get(sqrt_discriminant, sqrt_idx)
        
        Note: Solve 2ax + b ≡ sqrt_d (mod m)
        Let rhs1 be modular_add(sqrt_d, -reduced_b, modulus)
        If rhs1 < 0:
            Set rhs1 to rhs1 + modulus
        
        Let two_a be modular_multiply(2, reduced_a, modulus)
        Let solutions1 be solve_linear_congruence(two_a, rhs1, modulus)
        
        Note: Solve 2ax + b ≡ -sqrt_d (mod m)
        Let rhs2 be modular_add(-sqrt_d, -reduced_b, modulus)
        If rhs2 < 0:
            Set rhs2 to rhs2 + modulus
        
        Let solutions2 be solve_linear_congruence(two_a, rhs2, modulus)
        
        Note: Combine solutions
        Let sol1_idx be 0
        While sol1_idx < List.length(solutions1):
            Let sol be List.get(solutions1, sol1_idx)
            Set solutions to List.append(solutions, sol)
            Set sol1_idx to sol1_idx + 1
        
        Let sol2_idx be 0
        While sol2_idx < List.length(solutions2):
            Let sol be List.get(solutions2, sol2_idx)
            Set solutions to List.append(solutions, sol)
            Set sol2_idx to sol2_idx + 1
        
        Set sqrt_idx to sqrt_idx + 1
    
    Note: Remove duplicates and sort
    Let unique_solutions be remove_duplicates(solutions)
    Note: Inline sorting of unique_solutions
    Let sorted_solutions be unique_solutions
    Let unique_solutions_length be List.length(sorted_solutions)
    
    If unique_solutions_length > 1:
        Let i be 0
        While i < unique_solutions_length - 1:
            Let j be 0
            While j < unique_solutions_length - i - 1:
                Let current be List.get(sorted_solutions, j)
                Let next be List.get(sorted_solutions, j + 1)
                
                If current > next:
                    Set sorted_solutions to List.set(sorted_solutions, j, next)
                    Set sorted_solutions to List.set(sorted_solutions, j + 1, current)
                
                Set j to j + 1
            Set i to i + 1
    Return sorted_solutions

Process called "solve_polynomial_congruence" that takes coefficients as List[Integer], modulus as Integer returns List[Integer]:
    Note: Solve polynomial congruence of arbitrary degree
    Note: Uses Hensel's lemma and factorization methods
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If List.length(coefficients) == 0:
        Throw Errors.InvalidArgument with "Coefficients list cannot be empty"
    
    If modulus == 1:
        Return [0]
    
    Note: Handle special cases by degree
    Let degree be List.length(coefficients) - 1
    
    If degree == 0:
        Note: Constant polynomial: c ≡ 0 (mod m)
        Let constant be List.get(coefficients, 0) % modulus
        If constant == 0:
            Note: All values are solutions
            Let all_solutions be []
            Let x be 0
            While x < modulus:
                Set all_solutions to List.append(all_solutions, x)
                Set x to x + 1
            Return all_solutions
        Otherwise:
            Return []
    
    If degree == 1:
        Note: Linear congruence: ax + b ≡ 0 (mod m)
        Let a be List.get(coefficients, 1)
        Let b be List.get(coefficients, 0)
        Return solve_linear_congruence(a, -b, modulus)
    
    If degree == 2:
        Note: Quadratic congruence: ax² + bx + c ≡ 0 (mod m)
        Let a be List.get(coefficients, 2)
        Let b be List.get(coefficients, 1)
        Let c be List.get(coefficients, 0)
        Return solve_quadratic_congruence(a, b, c, modulus)
    
    Note: For higher degree polynomials, use brute force for small moduli
    If modulus <= 1000:
        Let solutions be []
        Let x be 0
        
        While x < modulus:
            Note: Evaluate polynomial at x
            Let value be 0
            Let power be 1
            Let coeff_idx be 0
            
            While coeff_idx < List.length(coefficients):
                Let coefficient be List.get(coefficients, coeff_idx)
                Let term be modular_multiply(coefficient, power, modulus)
                Set value to modular_add(value, term, modulus)
                Set power to modular_multiply(power, x, modulus)
                Set coeff_idx to coeff_idx + 1
            
            If value == 0:
                Set solutions to List.append(solutions, x)
            
            Set x to x + 1
        
        Return solutions
    
    Note: For large moduli and high degree, use Hensel lifting from prime solutions
    Let solutions be []
    
    Note: For simplicity, handle prime power moduli first
    Note: Check if modulus is a prime power (simplified check for common cases)
    Let is_prime_power be false
    Let base_prime be 0
    Let prime_exponent be 0
    
    Note: Check small primes up to reasonable bound
    Let test_prime be 2
    While test_prime <= 1000 && is_prime_power == false:
        Let power be 1
        Let current_power be test_prime
        
        While current_power <= modulus:
            If current_power == modulus:
                Set is_prime_power to true
                Set base_prime to test_prime
                Set prime_exponent to power
                Break
            Set current_power to current_power * test_prime
            Set power to power + 1
        
        Set test_prime to test_prime + 1
    
    If is_prime_power && base_prime > 0:
        Note: Use Hensel lifting for prime power moduli
        Note: First find solutions modulo base prime
        Let base_solutions be []
        Let candidate be 0
        
        While candidate < base_prime:
            Note: Evaluate polynomial at candidate modulo base prime
            Let value be 0
            Let power be 1
            Let coeff_idx be 0
            
            While coeff_idx < List.length(coefficients):
                Let coefficient be List.get(coefficients, coeff_idx)
                Let reduced_coeff be coefficient % base_prime
                If reduced_coeff < 0:
                    Set reduced_coeff to reduced_coeff + base_prime
                
                Let term be modular_multiply(reduced_coeff, power, base_prime)
                Set value to modular_add(value, term, base_prime)
                Set power to modular_multiply(power, candidate, base_prime)
                Set coeff_idx to coeff_idx + 1
            
            If value == 0:
                Set base_solutions to List.append(base_solutions, candidate)
            
            Set candidate to candidate + 1
        
        Note: Lift each base solution using Hensel lifting
        Let sol_idx be 0
        While sol_idx < List.length(base_solutions):
            Let base_solution be List.get(base_solutions, sol_idx)
            Let lifted_solution be hensel_lifting(coefficients, base_solution, base_prime, prime_exponent)
            Set solutions to List.append(solutions, lifted_solution)
            Set sol_idx to sol_idx + 1
    Otherwise:
        Note: For composite moduli, fall back to limited brute force
        Let candidate be 0
        While candidate < 1000 && candidate < modulus:
            Note: Evaluate polynomial at candidate
            Let value be 0
            Let power be 1
            Let coeff_idx be 0
            
            While coeff_idx < List.length(coefficients):
                Let coefficient be List.get(coefficients, coeff_idx)
                Let term be modular_multiply(coefficient, power, modulus)
                Set value to modular_add(value, term, modulus)
                Set power to modular_multiply(power, candidate, modulus)
                Set coeff_idx to coeff_idx + 1
            
            If value == 0:
                Set solutions to List.append(solutions, candidate)
            
            Set candidate to candidate + 1
    
    Return solutions

Process called "hensel_lifting" that takes polynomial as List[Integer], solution as Integer, prime as Integer, exponent as Integer returns Integer:
    Note: Lift solution from mod p to mod p^k using Hensel's lemma
    Note: Provides systematic method for solving higher power congruences
    
    If prime <= 1:
        Throw Errors.InvalidArgument with "Prime must be greater than 1"
    
    If exponent <= 0:
        Throw Errors.InvalidArgument with "Exponent must be positive"
    
    If exponent == 1:
        Return solution % prime
    
    If List.length(polynomial) == 0:
        Throw Errors.InvalidArgument with "Polynomial cannot be empty"
    
    Note: Start with solution modulo p
    Let current_solution be solution % prime
    If current_solution < 0:
        Set current_solution to current_solution + prime
    
    Let current_modulus be prime
    Let k be 1
    
    Note: Lift solution from mod p^k to mod p^(k+1) iteratively
    While k < exponent:
        Note: Compute f(current_solution) mod p^(k+1)
        Let f_value be evaluate_polynomial(polynomial, current_solution, current_modulus * prime)
        
        Note: Compute f'(current_solution) mod p
        Let derivative be compute_polynomial_derivative(polynomial)
        Let f_prime_value be evaluate_polynomial(derivative, current_solution, prime)
        
        Note: Check if lifting is possible
        If f_prime_value % prime == 0:
            Note: Cannot lift - derivative is zero mod p
            Return current_solution
        
        Note: Compute the lifting step: t = -f(x_k) / (p^k * f'(x_k)) mod p
        Let numerator be -(f_value / current_modulus)
        Let f_prime_inv be modular_inverse(f_prime_value, prime)
        Let t be modular_multiply(numerator, f_prime_inv, prime)
        
        Note: Update solution: x_{k+1} = x_k + t * p^k
        Set current_solution to current_solution + t * current_modulus
        Set current_modulus to current_modulus * prime
        Set k to k + 1
    
    Return current_solution % current_modulus

Note: =====================================================================
Note: ARITHMETIC FUNCTION OPERATIONS
Note: =====================================================================

Process called "euler_totient" that takes n as Integer returns Integer:
    Note: Compute Euler's totient function φ(n)
    Note: Counts integers 1 ≤ k ≤ n with gcd(k,n) = 1
    
    If n <= 0:
        Throw Errors.InvalidArgument with "n must be positive"
    
    If n == 1:
        Return 1
    
    Note: Use multiplicative property: φ(n) = n * ∏(1 - 1/p) for all prime factors p
    Let result be n
    Let remaining be n
    Let prime_factor be 2
    
    Note: Handle factor 2
    If remaining % 2 == 0:
        Set result to result / 2
        While remaining % 2 == 0:
            Set remaining to remaining / 2
    
    Note: Handle odd prime factors
    Set prime_factor to 3
    While prime_factor * prime_factor <= remaining:
        If remaining % prime_factor == 0:
            Set result to result - result / prime_factor
            While remaining % prime_factor == 0:
                Set remaining to remaining / prime_factor
        Set prime_factor to prime_factor + 2
    
    Note: Handle remaining prime factor > √n
    If remaining > 1:
        Set result to result - result / remaining
    
    Return result

Process called "carmichael_function" that takes n as Integer returns Integer:
    Note: Compute Carmichael function λ(n)
    Note: Finds exponent of multiplicative group (Z/nZ)*
    
    If n <= 0:
        Throw Errors.InvalidArgument with "n must be positive"
    
    If n == 1:
        Return 1
    
    If n == 2:
        Return 1
    
    If n == 4:
        Return 2
    
    Note: Handle powers of 2: λ(2^k) = 2^(k-2) for k ≥ 3
    If n % 2 == 0:
        Let power_of_2 be 0
        Let temp_n be n
        
        While temp_n % 2 == 0:
            Set power_of_2 to power_of_2 + 1
            Set temp_n to temp_n / 2
        
        If temp_n == 1:
            Note: n = 2^k
            If power_of_2 >= 3:
                Let result be 1
                Let i be 0
                While i < power_of_2 - 2:
                    Set result to result * 2
                    Set i to i + 1
                Return result
    
    Note: Find prime factorization and compute λ for each prime power
    Let prime_powers be find_prime_power_factorization(n)
    Let lcm_result be 1
    Let factor_idx be 0
    
    While factor_idx < List.length(prime_powers):
        Let prime_power be List.get(prime_powers, factor_idx)
        Let prime be prime_power.prime
        Let exponent be prime_power.exponent
        
        Note: Compute λ(p^k)
        Let lambda_pk be 0
        
        If prime == 2:
            If exponent == 1:
                Set lambda_pk to 1
            If exponent == 2:
                Set lambda_pk to 2
            If exponent >= 3:
                Set lambda_pk to compute_power(2, exponent - 2)
        Otherwise:
            Note: For odd primes: λ(p^k) = φ(p^k) = p^(k-1) * (p-1)
            Set lambda_pk to compute_power(prime, exponent - 1) * (prime - 1)
        
        Note: Update LCM
        Set lcm_result to compute_lcm(lcm_result, lambda_pk)
        Set factor_idx to factor_idx + 1
    
    Return lcm_result

Process called "mobius_function" that takes n as Integer returns Integer:
    Note: Compute Möbius function μ(n) for inclusion-exclusion
    Note: Returns 1, -1, or 0 based on prime factorization structure
    
    If n <= 0:
        Throw Errors.InvalidArgument with "n must be positive"
    
    If n == 1:
        Return 1
    
    Note: Count distinct prime factors and check for repeated factors
    Let distinct_prime_count be 0
    Let remaining be n
    Let prime_factor be 2
    
    Note: Check factor 2
    If remaining % 2 == 0:
        Set distinct_prime_count to distinct_prime_count + 1
        Set remaining to remaining / 2
        
        Note: If 2 appears with multiplicity > 1, μ(n) = 0
        If remaining % 2 == 0:
            Return 0
    
    Note: Check odd prime factors
    Set prime_factor to 3
    While prime_factor * prime_factor <= remaining:
        If remaining % prime_factor == 0:
            Set distinct_prime_count to distinct_prime_count + 1
            Set remaining to remaining / prime_factor
            
            Note: If prime appears with multiplicity > 1, μ(n) = 0
            If remaining % prime_factor == 0:
                Return 0
        
        Set prime_factor to prime_factor + 2
    
    Note: Handle remaining prime factor > √n
    If remaining > 1:
        Set distinct_prime_count to distinct_prime_count + 1
    
    Note: μ(n) = (-1)^k where k is number of distinct prime factors
    If distinct_prime_count % 2 == 0:
        Return 1
    Otherwise:
        Return -1

Process called "liouville_function" that takes n as Integer returns Integer:
    Note: Compute Liouville function λ(n) = (-1)^Ω(n)
    Note: Returns (-1)^(number of prime factors with multiplicity)
    
    If n <= 0:
        Throw Errors.InvalidArgument with "n must be positive"
    
    If n == 1:
        Return 1
    
    Note: Count total prime factors with multiplicity
    Let total_prime_count be 0
    Let remaining be n
    Let prime_factor be 2
    
    Note: Count factor 2
    While remaining % 2 == 0:
        Set total_prime_count to total_prime_count + 1
        Set remaining to remaining / 2
    
    Note: Count odd prime factors
    Set prime_factor to 3
    While prime_factor * prime_factor <= remaining:
        While remaining % prime_factor == 0:
            Set total_prime_count to total_prime_count + 1
            Set remaining to remaining / prime_factor
        Set prime_factor to prime_factor + 2
    
    Note: Handle remaining prime factor > √n
    If remaining > 1:
        Set total_prime_count to total_prime_count + 1
    
    Note: λ(n) = (-1)^Ω(n) where Ω(n) is total number of prime factors with multiplicity
    If total_prime_count % 2 == 0:
        Return 1
    Otherwise:
        Return -1

Process called "sum_of_divisors" that takes n as Integer, k as Integer returns Integer:
    Note: Compute sum of k-th powers of divisors σ_k(n)
    Note: Uses multiplicative property and prime power formula
    
    If n <= 0:
        Throw Errors.InvalidArgument with "n must be positive"
    
    If k < 0:
        Throw Errors.InvalidArgument with "k must be non-negative"
    
    If n == 1:
        Return 1
    
    Note: Use multiplicative property: σ_k(mn) = σ_k(m)σ_k(n) when gcd(m,n) = 1
    Let result be 1
    Let remaining be n
    Let prime_factor be 2
    
    Note: Handle factor 2
    If remaining % 2 == 0:
        Let exponent be 0
        While remaining % 2 == 0:
            Set exponent to exponent + 1
            Set remaining to remaining / 2
        
        Note: Compute σ_k(2^exponent) = (2^(k*(exponent+1)) - 1) / (2^k - 1)
        If k == 0:
            Set result to result * (exponent + 1)
        Otherwise:
            Let numerator be compute_power(2, k * (exponent + 1)) - 1
            Let denominator be compute_power(2, k) - 1
            Set result to result * (numerator / denominator)
    
    Note: Handle odd prime factors
    Set prime_factor to 3
    While prime_factor * prime_factor <= remaining:
        If remaining % prime_factor == 0:
            Let exponent be 0
            While remaining % prime_factor == 0:
                Set exponent to exponent + 1
                Set remaining to remaining / prime_factor
            
            Note: Compute σ_k(p^exponent) = (p^(k*(exponent+1)) - 1) / (p^k - 1)
            If k == 0:
                Set result to result * (exponent + 1)
            Otherwise:
                Let p_to_k be compute_power(prime_factor, k)
                If p_to_k == 1:
                    Set result to result * (exponent + 1)
                Otherwise:
                    Let numerator be compute_power(prime_factor, k * (exponent + 1)) - 1
                    Let denominator be p_to_k - 1
                    Set result to result * (numerator / denominator)
        
        Set prime_factor to prime_factor + 2
    
    Note: Handle remaining prime factor > √n
    If remaining > 1:
        Note: Compute σ_k(remaining^1) = 1 + remaining^k
        If k == 0:
            Set result to result * 2
        Otherwise:
            Let prime_power_k be compute_power(remaining, k)
            Set result to result * (1 + prime_power_k)
    
    Return result

Process called "number_of_divisors" that takes n as Integer returns Integer:
    Note: Compute number of positive divisors τ(n) = σ_0(n)
    Note: Uses prime factorization and multiplicative formula
    
    If n <= 0:
        Throw Errors.InvalidArgument with "n must be positive"
    
    If n == 1:
        Return 1
    
    Note: Use multiplicative property: τ(mn) = τ(m)τ(n) when gcd(m,n) = 1
    Note: For prime power p^k: τ(p^k) = k + 1
    
    Let result be 1
    Let remaining be n
    Let prime_factor be 2
    
    Note: Handle factor 2
    If remaining % 2 == 0:
        Let exponent be 0
        While remaining % 2 == 0:
            Set exponent to exponent + 1
            Set remaining to remaining / 2
        Set result to result * (exponent + 1)
    
    Note: Handle odd prime factors
    Set prime_factor to 3
    While prime_factor * prime_factor <= remaining:
        If remaining % prime_factor == 0:
            Let exponent be 0
            While remaining % prime_factor == 0:
                Set exponent to exponent + 1
                Set remaining to remaining / prime_factor
            Set result to result * (exponent + 1)
        Set prime_factor to prime_factor + 2
    
    Note: Handle remaining prime factor > √n
    If remaining > 1:
        Set result to result * 2
    
    Return result

Note: =====================================================================
Note: ADVANCED MODULAR OPERATIONS
Note: =====================================================================

Process called "modular_matrix_multiply" that takes A as List[List[Integer]], B as List[List[Integer]], modulus as Integer returns List[List[Integer]]:
    Note: Multiply matrices modulo given integer with overflow protection
    Note: Implements efficient modular matrix multiplication algorithms
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If List.length(A) == 0 || List.length(B) == 0:
        Throw Errors.InvalidArgument with "Matrices cannot be empty"
    
    Note: Check matrix dimensions for multiplication compatibility
    Let rows_A be List.length(A)
    Let cols_A be List.length(List.get(A, 0))
    Let rows_B be List.length(B)
    Let cols_B be List.length(List.get(B, 0))
    
    If cols_A != rows_B:
        Throw Errors.InvalidArgument with "Matrix dimensions incompatible for multiplication"
    
    Note: Initialize result matrix
    Let result be []
    Let i be 0
    
    While i < rows_A:
        Let row be []
        Let j be 0
        
        While j < cols_B:
            Let sum be 0
            Let k be 0
            
            Note: Compute dot product of row i of A with column j of B
            While k < cols_A:
                Let a_element be List.get(List.get(A, i), k)
                Let b_element be List.get(List.get(B, k), j)
                Let product be modular_multiply(a_element, b_element, modulus)
                Set sum to modular_add(sum, product, modulus)
                Set k to k + 1
            
            Set row to List.append(row, sum)
            Set j to j + 1
        
        Set result to List.append(result, row)
        Set i to i + 1
    
    Return result

Process called "modular_matrix_power" that takes matrix as List[List[Integer]], exponent as Integer, modulus as Integer returns List[List[Integer]]:
    Note: Compute matrix power modulo integer using binary exponentiation
    Note: Efficient algorithm for computing A^n mod m for matrices
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If exponent < 0:
        Throw Errors.InvalidArgument with "Exponent must be non-negative"
    
    If List.length(matrix) == 0:
        Throw Errors.InvalidArgument with "Matrix cannot be empty"
    
    Note: Matrix must be square for exponentiation
    Let n be List.length(matrix)
    If List.length(List.get(matrix, 0)) != n:
        Throw Errors.InvalidArgument with "Matrix must be square for exponentiation"
    
    Note: Handle special case: A^0 = I (identity matrix)
    If exponent == 0:
        Let identity be create_identity_matrix(n, modulus)
        Return identity
    
    If exponent == 1:
        Return matrix
    
    Note: Binary matrix exponentiation
    Let result be create_identity_matrix(n, modulus)
    Let base be matrix
    Let current_exponent be exponent
    
    While current_exponent > 0:
        If current_exponent % 2 == 1:
            Set result to modular_matrix_multiply(result, base, modulus)
        
        Set base to modular_matrix_multiply(base, base, modulus)
        Set current_exponent to current_exponent / 2
    
    Return result

Process called "solve_modular_linear_system" that takes matrix as List[List[Integer]], vector as List[Integer], modulus as Integer returns List[Integer]:
    Note: Solve linear system Ax ≡ b (mod m) using modular Gaussian elimination
    Note: Handles singular systems and provides complete solution description
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If List.length(matrix) == 0 || List.length(vector) == 0:
        Throw Errors.InvalidArgument with "Matrix and vector cannot be empty"
    
    Let rows be List.length(matrix)
    Let cols be List.length(List.get(matrix, 0))
    
    If List.length(vector) != rows:
        Throw Errors.InvalidArgument with "Vector dimension must match number of matrix rows"
    
    Note: Create augmented matrix [A|b]
    Let augmented be []
    Let i be 0
    
    While i < rows:
        Let row be List.get(matrix, i)
        Let augmented_row be []
        Let j be 0
        
        Note: Copy matrix row
        While j < cols:
            Let element be List.get(row, j) % modulus
            If element < 0:
                Set element to element + modulus
            Set augmented_row to List.append(augmented_row, element)
            Set j to j + 1
        
        Note: Append vector element
        Let vector_element be List.get(vector, i) % modulus
        If vector_element < 0:
            Set vector_element to vector_element + modulus
        Set augmented_row to List.append(augmented_row, vector_element)
        
        Set augmented to List.append(augmented, augmented_row)
        Set i to i + 1
    
    Note: Perform Gaussian elimination with partial pivoting
    Let pivot_row be 0
    Let col be 0
    
    While col < cols && pivot_row < rows:
        Note: Find pivot element
        Let max_row be pivot_row
        Let search_row be pivot_row + 1
        
        While search_row < rows:
            Let current_element be List.get(List.get(augmented, search_row), col)
            Let max_element be List.get(List.get(augmented, max_row), col)
            
            Note: Find element with largest absolute value (approximation)
            If current_element > max_element:
                Set max_row to search_row
            Set search_row to search_row + 1
        
        Note: Check if pivot is invertible
        Let pivot_element be List.get(List.get(augmented, max_row), col)
        If compute_gcd(pivot_element, modulus) != 1:
            Set col to col + 1
            Continue
        
        Note: Swap rows if needed
        If max_row != pivot_row:
            Let temp_row be List.get(augmented, pivot_row)
            Set augmented to List.set(augmented, pivot_row, List.get(augmented, max_row))
            Set augmented to List.set(augmented, max_row, temp_row)
        
        Note: Eliminate below pivot
        Let elim_row be pivot_row + 1
        While elim_row < rows:
            Let target_element be List.get(List.get(augmented, elim_row), col)
            If target_element != 0:
                Let pivot_inv be modular_inverse(pivot_element, modulus)
                Let factor be modular_multiply(target_element, pivot_inv, modulus)
                
                Note: Row operation: R[elim_row] = R[elim_row] - factor * R[pivot_row]
                Let elim_col be 0
                Let new_row be []
                
                While elim_col <= cols:
                    Let target_val be List.get(List.get(augmented, elim_row), elim_col)
                    Let pivot_val be List.get(List.get(augmented, pivot_row), elim_col)
                    Let subtraction be modular_multiply(factor, pivot_val, modulus)
                    Let new_val be modular_add(target_val, -subtraction, modulus)
                    If new_val < 0:
                        Set new_val to new_val + modulus
                    Set new_row to List.append(new_row, new_val)
                    Set elim_col to elim_col + 1
                
                Set augmented to List.set(augmented, elim_row, new_row)
            Set elim_row to elim_row + 1
        
        Set pivot_row to pivot_row + 1
        Set col to col + 1
    
    Note: Back substitution
    Let solution be []
    Let var_idx be 0
    
    While var_idx < cols:
        Set solution to List.append(solution, 0)
        Set var_idx to var_idx + 1
    
    Let back_row be pivot_row - 1
    While back_row >= 0:
        Note: Find leading variable in this row
        Let leading_col be 0
        While leading_col < cols:
            Let coeff be List.get(List.get(augmented, back_row), leading_col)
            If coeff != 0:
                Note: Solve for this variable
                Let rhs be List.get(List.get(augmented, back_row), cols)
                Let substitute_col be leading_col + 1
                
                While substitute_col < cols:
                    Let sub_coeff be List.get(List.get(augmented, back_row), substitute_col)
                    Let sub_value be List.get(solution, substitute_col)
                    Let subtraction be modular_multiply(sub_coeff, sub_value, modulus)
                    Set rhs to modular_add(rhs, -subtraction, modulus)
                    If rhs < 0:
                        Set rhs to rhs + modulus
                    Set substitute_col to substitute_col + 1
                
                Let coeff_inv be modular_inverse(coeff, modulus)
                Let var_value be modular_multiply(rhs, coeff_inv, modulus)
                Set solution to List.set(solution, leading_col, var_value)
                Break
            Set leading_col to leading_col + 1
        Set back_row to back_row - 1
    
    Return solution

Process called "compute_modular_determinant" that takes matrix as List[List[Integer]], modulus as Integer returns Integer:
    Note: Compute determinant of matrix modulo given integer
    Note: Uses LU decomposition or cofactor expansion with modular arithmetic
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If List.length(matrix) == 0:
        Throw Errors.InvalidArgument with "Matrix cannot be empty"
    
    Let n be List.length(matrix)
    If List.length(List.get(matrix, 0)) != n:
        Throw Errors.InvalidArgument with "Matrix must be square"
    
    Note: Handle small matrices with direct computation
    If n == 1:
        Let element be List.get(List.get(matrix, 0), 0) % modulus
        If element < 0:
            Set element to element + modulus
        Return element
    
    If n == 2:
        Let a be List.get(List.get(matrix, 0), 0) % modulus
        Let b be List.get(List.get(matrix, 0), 1) % modulus
        Let c be List.get(List.get(matrix, 1), 0) % modulus
        Let d be List.get(List.get(matrix, 1), 1) % modulus
        
        If a < 0:
            Set a to a + modulus
        If b < 0:
            Set b to b + modulus
        If c < 0:
            Set c to c + modulus
        If d < 0:
            Set d to d + modulus
        
        Let ad be modular_multiply(a, d, modulus)
        Let bc be modular_multiply(b, c, modulus)
        Return modular_add(ad, -bc, modulus)
    
    Note: For larger matrices, use Gaussian elimination
    Note: Copy matrix to avoid modifying original
    Let working_matrix be []
    Let i be 0
    
    While i < n:
        Let row be []
        Let j be 0
        While j < n:
            Let element be List.get(List.get(matrix, i), j) % modulus
            If element < 0:
                Set element to element + modulus
            Set row to List.append(row, element)
            Set j to j + 1
        Set working_matrix to List.append(working_matrix, row)
        Set i to i + 1
    
    Let determinant be 1
    Let sign be 1
    Set i to 0
    
    While i < n:
        Note: Find pivot
        Let pivot_row be i
        Let max_element be List.get(List.get(working_matrix, i), i)
        Let search_row be i + 1
        
        While search_row < n:
            Let candidate be List.get(List.get(working_matrix, search_row), i)
            If candidate != 0 && (max_element == 0 || compute_gcd(candidate, modulus) == 1):
                Set pivot_row to search_row
                Set max_element to candidate
            Set search_row to search_row + 1
        
        Note: Check for zero pivot
        If max_element == 0:
            Return 0
        
        Note: Swap rows if needed
        If pivot_row != i:
            Let temp_row be List.get(working_matrix, i)
            Set working_matrix to List.set(working_matrix, i, List.get(working_matrix, pivot_row))
            Set working_matrix to List.set(working_matrix, pivot_row, temp_row)
            Set sign to -sign
        
        Note: Get pivot element
        Let pivot be List.get(List.get(working_matrix, i), i)
        Set determinant to modular_multiply(determinant, pivot, modulus)
        
        Note: Eliminate below pivot
        Let elim_row be i + 1
        While elim_row < n:
            Let target be List.get(List.get(working_matrix, elim_row), i)
            If target != 0:
                Note: Check if pivot has modular inverse
                If compute_gcd(pivot, modulus) != 1:
                    Return 0
                
                Let pivot_inv be modular_inverse(pivot, modulus)
                Let factor be modular_multiply(target, pivot_inv, modulus)
                
                Note: Row elimination
                Let col be 0
                Let new_row be []
                While col < n:
                    Let target_val be List.get(List.get(working_matrix, elim_row), col)
                    Let pivot_val be List.get(List.get(working_matrix, i), col)
                    Let subtraction be modular_multiply(factor, pivot_val, modulus)
                    Let new_val be modular_add(target_val, -subtraction, modulus)
                    If new_val < 0:
                        Set new_val to new_val + modulus
                    Set new_row to List.append(new_row, new_val)
                    Set col to col + 1
                Set working_matrix to List.set(working_matrix, elim_row, new_row)
            Set elim_row to elim_row + 1
        
        Set i to i + 1
    
    Note: Apply sign correction
    If sign == -1:
        Set determinant to modular_add(0, -determinant, modulus)
        If determinant < 0:
            Set determinant to determinant + modulus
    
    Return determinant

Process called "modular_polynomial_arithmetic" that takes poly1 as List[Integer], poly2 as List[Integer], operation as String, modulus as Integer returns List[Integer]:
    Note: Perform polynomial arithmetic operations modulo integer
    Note: Supports addition, multiplication, and division in polynomial rings Z_m[x]
    
    If modulus <= 0:
        Throw Errors.InvalidArgument with "Modulus must be positive"
    
    If List.length(poly1) == 0 && List.length(poly2) == 0:
        Return [0]
    
    Note: Normalize polynomials modulo m
    Let normalized_poly1 be normalize_polynomial(poly1, modulus)
    Let normalized_poly2 be normalize_polynomial(poly2, modulus)
    
    Note: Handle different operations
    If operation == "add":
        Return add_polynomials_mod(normalized_poly1, normalized_poly2, modulus)
    
    If operation == "subtract":
        Return subtract_polynomials_mod(normalized_poly1, normalized_poly2, modulus)
    
    If operation == "multiply":
        Return multiply_polynomials_mod(normalized_poly1, normalized_poly2, modulus)
    
    If operation == "divide":
        Return divide_polynomials_mod(normalized_poly1, normalized_poly2, modulus)
    
    Throw Errors.InvalidArgument with "Unsupported operation: " + operation

Process called "berlekamp_factorization" that takes polynomial as List[Integer], prime as Integer returns List[List[Integer]]:
    Note: Complete Berlekamp factorization algorithm for polynomials over finite fields F_p
    
    If prime <= 1:
        Throw Errors.InvalidArgument with "Prime must be greater than 1"
    
    If List.length(polynomial) == 0:
        Return []
    
    If List.length(polynomial) == 1:
        Return [polynomial]
    
    Note: Inline polynomial normalization modulo prime
    Let normalized_poly be []
    If List.length(polynomial) == 0:
        Set normalized_poly to [0]
    Otherwise:
        Let norm_i be 0
        While norm_i < List.length(polynomial):
            Let coeff be List.get(polynomial, norm_i) % prime
            If coeff < 0:
                Set coeff to coeff + prime
            Set normalized_poly to List.append(normalized_poly, coeff)
            Set norm_i to norm_i + 1
        
        Note: Remove leading zeros
        While List.length(normalized_poly) > 1:
            Let last_idx be List.length(normalized_poly) - 1
            Let leading_coeff be List.get(normalized_poly, last_idx)
            If leading_coeff == 0:
                Let temp_poly be []
                Let j be 0
                While j < last_idx:
                    Let temp_coeff be List.get(normalized_poly, j)
                    Set temp_poly to List.append(temp_poly, temp_coeff)
                    Set j to j + 1
                Set normalized_poly to temp_poly
            Otherwise:
                Break
        
        If List.length(normalized_poly) == 0:
            Set normalized_poly to [0]
    
    Note: Check polynomial degree
    Let degree be List.length(normalized_poly) - 1
    While degree > 0:
        Let coeff be List.get(normalized_poly, degree)
        If coeff != 0:
            Break
        Set degree to degree - 1
    
    If degree <= 0:
        Return [normalized_poly]
    
    If degree == 1:
        Return [normalized_poly]
    
    Note: Step 1: Make polynomial monic
    Let leading_coeff be List.get(normalized_poly, degree)
    Let leading_inv be modular_inverse(leading_coeff, prime)
    Let monic_poly be []
    Let monic_i be 0
    While monic_i < List.length(normalized_poly):
        Let monic_coeff be modular_multiply(List.get(normalized_poly, monic_i), leading_inv, prime)
        Set monic_poly to List.append(monic_poly, monic_coeff)
        Set monic_i to monic_i + 1
    
    Note: Step 2: Check if polynomial is square-free using derivative
    Let derivative be []
    If degree > 0:
        Let deriv_i be 1
        While deriv_i <= degree:
            Let coeff be List.get(monic_poly, deriv_i)
            Let deriv_coeff be modular_multiply(deriv_i, coeff, prime)
            Set derivative to List.append(derivative, deriv_coeff)
            Set deriv_i to deriv_i + 1
    
    If List.length(derivative) == 0:
        Set derivative to [0]
    
    Note: Compute GCD of polynomial and its derivative
    Let gcd_poly be Polynomial.polynomial_gcd_finite_field(monic_poly, derivative, prime)
    
    Note: Check if GCD is non-trivial
    Let gcd_degree be List.length(gcd_poly) - 1
    While gcd_degree > 0:
        Let gcd_coeff be List.get(gcd_poly, gcd_degree)
        If gcd_coeff != 0:
            Break
        Set gcd_degree to gcd_degree - 1
    
    If gcd_degree > 0:
        Note: Polynomial is not square-free, factor out repeated factors
        Let square_free_part be Polynomial.polynomial_divide_finite_field(monic_poly, gcd_poly, prime)
        Let sf_factors be berlekamp_factorization(square_free_part, prime)
        Let repeated_factors be berlekamp_factorization(gcd_poly, prime)
        
        Let combined_factors be []
        Let sf_idx be 0
        While sf_idx < List.length(sf_factors):
            Let factor be List.get(sf_factors, sf_idx)
            Set combined_factors to List.append(combined_factors, factor)
            Set sf_idx to sf_idx + 1
        
        Let rep_idx be 0
        While rep_idx < List.length(repeated_factors):
            Let factor be List.get(repeated_factors, rep_idx)
            Set combined_factors to List.append(combined_factors, factor)
            Set rep_idx to rep_idx + 1
        
        Return combined_factors
    
    Note: Step 3: Construct Berlekamp matrix Q - I (Q[i,j] = coefficient of x^j in x^(i*p) mod f(x))
    Let n be degree
    Let berlekamp_matrix be []
    
    Note: Initialize matrix as -I (negative identity)
    Let matrix_i be 0
    While matrix_i < n:
        Let row be []
        Let matrix_j be 0
        While matrix_j < n:
            If matrix_i == matrix_j:
                Set row to List.append(row, prime - 1)
            Otherwise:
                Set row to List.append(row, 0)
            Set matrix_j to matrix_j + 1
        Set berlekamp_matrix to List.append(berlekamp_matrix, row)
        Set matrix_i to matrix_i + 1
    
    Note: Compute x^(i*p) mod f(x) for each row i
    Let current_power be [1]
    Let power_i be 0
    While power_i < n:
        Note: Add coefficients of current_power to row power_i of berlekamp_matrix
        Let coeff_j be 0
        While coeff_j < List.length(current_power) && coeff_j < n:
            Let matrix_row be List.get(berlekamp_matrix, power_i)
            Let current_val be List.get(matrix_row, coeff_j)
            Let new_val be modular_add(current_val, List.get(current_power, coeff_j), prime)
            Set matrix_row to List.set(matrix_row, coeff_j, new_val)
            Set berlekamp_matrix to List.set(berlekamp_matrix, power_i, matrix_row)
            Set coeff_j to coeff_j + 1
        
        Note: Compute next power x^((i+1)*p) = (x^(i*p))^p mod f(x)
        If power_i < n - 1:
            Let new_power be current_power
            Let exp_step be 0
            While exp_step < prime - 1:
                Set new_power to Polynomial.polynomial_multiply_mod_finite_field(new_power, current_power, monic_poly, prime)
                Set exp_step to exp_step + 1
            Set current_power to new_power
        
        Set power_i to power_i + 1
    
    Note: Step 4: Find nullspace of berlekamp_matrix using Gaussian elimination
    Let nullspace_vectors be []
    
    Note: Gaussian elimination to find rank and nullspace
    Let pivot_row be 0
    Let col be 0
    While col < n && pivot_row < n:
        Note: Find pivot in current column
        Let pivot_found be false
        Let search_row be pivot_row
        While search_row < n:
            Let matrix_row be List.get(berlekamp_matrix, search_row)
            Let matrix_element be List.get(matrix_row, col)
            If matrix_element != 0:
                Set pivot_found to true
                
                Note: Swap rows if needed
                If search_row != pivot_row:
                    Let temp_row be List.get(berlekamp_matrix, pivot_row)
                    Set berlekamp_matrix to List.set(berlekamp_matrix, pivot_row, List.get(berlekamp_matrix, search_row))
                    Set berlekamp_matrix to List.set(berlekamp_matrix, search_row, temp_row)
                Break
            Set search_row to search_row + 1
        
        If pivot_found:
            Note: Normalize pivot row
            Let pivot_row_data be List.get(berlekamp_matrix, pivot_row)
            Let pivot_element be List.get(pivot_row_data, col)
            Let pivot_inv be modular_inverse(pivot_element, prime)
            
            Let norm_col be 0
            While norm_col < n:
                Let old_val be List.get(pivot_row_data, norm_col)
                Let new_val be modular_multiply(old_val, pivot_inv, prime)
                Set pivot_row_data to List.set(pivot_row_data, norm_col, new_val)
                Set norm_col to norm_col + 1
            Set berlekamp_matrix to List.set(berlekamp_matrix, pivot_row, pivot_row_data)
            
            Note: Eliminate column in other rows
            Let elim_row be 0
            While elim_row < n:
                If elim_row != pivot_row:
                    Let elim_row_data be List.get(berlekamp_matrix, elim_row)
                    Let elim_factor be List.get(elim_row_data, col)
                    
                    If elim_factor != 0:
                        Let elim_col be 0
                        While elim_col < n:
                            Let elim_old be List.get(elim_row_data, elim_col)
                            Let pivot_val be List.get(pivot_row_data, elim_col)
                            Let subtract_val be modular_multiply(elim_factor, pivot_val, prime)
                            Let elim_new be modular_add(elim_old, prime - subtract_val, prime)
                            Set elim_row_data to List.set(elim_row_data, elim_col, elim_new)
                            Set elim_col to elim_col + 1
                        Set berlekamp_matrix to List.set(berlekamp_matrix, elim_row, elim_row_data)
                
                Set elim_row to elim_row + 1
            
            Set pivot_row to pivot_row + 1
        
        Set col to col + 1
    
    Note: Extract nullspace basis vectors (rows that are all zeros)
    Let null_row be 0
    While null_row < n:
        Let row_data be List.get(berlekamp_matrix, null_row)
        Let is_zero_row be true
        Let check_col be 0
        While check_col < n:
            If List.get(row_data, check_col) != 0:
                Set is_zero_row to false
                Break
            Set check_col to check_col + 1
        
        If is_zero_row:
            Note: Create basis vector for this free variable
            Let basis_vector be []
            Let basis_i be 0
            While basis_i < n:
                If basis_i == null_row:
                    Set basis_vector to List.append(basis_vector, 1)
                Otherwise:
                    Set basis_vector to List.append(basis_vector, 0)
                Set basis_i to basis_i + 1
            Set nullspace_vectors to List.append(nullspace_vectors, basis_vector)
        
        Set null_row to null_row + 1
    
    Note: If nullspace dimension is 1, polynomial is irreducible
    If List.length(nullspace_vectors) <= 1:
        Return [monic_poly]
    
    Note: Step 5: Use nullspace vectors to find factors
    Let factors be []
    Let vector_idx be 1
    While vector_idx < List.length(nullspace_vectors):
        Let null_vector be List.get(nullspace_vectors, vector_idx)
        
        Note: For each element a in F_p, compute gcd(f(x), v(x) - a) where v(x) is nullspace vector
        Let field_elem be 0
        While field_elem < prime:
            Note: Construct polynomial v(x) - a
            Let v_minus_a be []
            Let va_i be 0
            While va_i < List.length(null_vector):
                Let coeff be List.get(null_vector, va_i)
                If va_i == 0:
                    Set coeff to modular_add(coeff, prime - field_elem, prime)
                Set v_minus_a to List.append(v_minus_a, coeff)
                Set va_i to va_i + 1
            
            Note: Compute GCD with original polynomial
            Let factor_candidate be Polynomial.polynomial_gcd_finite_field(monic_poly, v_minus_a, prime)
            
            Note: Check if we found a non-trivial factor
            Let factor_degree be List.length(factor_candidate) - 1
            While factor_degree > 0:
                Let factor_coeff be List.get(factor_candidate, factor_degree)
                If factor_coeff != 0:
                    Break
                Set factor_degree to factor_degree - 1
            
            If factor_degree > 0 && factor_degree < degree:
                Note: Found non-trivial factor, add to factors list
                Let is_duplicate be false
                Let dup_check be 0
                While dup_check < List.length(factors):
                    Let existing_factor be List.get(factors, dup_check)
                    If Polynomial.polynomials_equal(factor_candidate, existing_factor):
                        Set is_duplicate to true
                        Break
                    Set dup_check to dup_check + 1
                
                If !is_duplicate:
                    Set factors to List.append(factors, factor_candidate)
                    
                    Note: Also factor the quotient
                    Let quotient be Polynomial.polynomial_divide_finite_field(monic_poly, factor_candidate, prime)
                    Let quotient_degree be List.length(quotient) - 1
                    While quotient_degree > 0:
                        Let quot_coeff be List.get(quotient, quotient_degree)
                        If quot_coeff != 0:
                            Break
                        Set quotient_degree to quotient_degree - 1
                    
                    If quotient_degree > 1:
                        Let quotient_factors be berlekamp_factorization(quotient, prime)
                        Let qf_idx be 0
                        While qf_idx < List.length(quotient_factors):
                            Let qf be List.get(quotient_factors, qf_idx)
                            Set factors to List.append(factors, qf)
                            Set qf_idx to qf_idx + 1
                    Otherwise:
                        If quotient_degree == 1:
                            Set factors to List.append(factors, quotient)
                    
                    Return factors
            
            Set field_elem to field_elem + 1
        
        Set vector_idx to vector_idx + 1
    
    Note: If no factors found, polynomial is irreducible
    Return [monic_poly]

