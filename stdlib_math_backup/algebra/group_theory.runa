Note:
math/algebra/group_theory.runa
Group Theory Operations and Analysis

This module provides comprehensive group theory including:
- Group operations and structure analysis
- Subgroup theory (normal subgroups, quotient groups)
- Group homomorphisms and isomorphism theorems
- Coset enumeration and Lagrange's theorem
- Sylow theorems and p-groups
- Permutation groups and symmetric groups
- Group presentations and generators/relations
- Solvable and nilpotent groups
- Group actions and orbit-stabilizer theorem
- Character theory and representation theory
:End Note

Import "dev/debug/errors/core" as Errors
Import "core/operations" as Operations
Import "compiler/frontend/primitives/types/conversion" as Conversion

Note: =====================================================================
Note: GROUP THEORY DATA STRUCTURES
Note: =====================================================================

Type called "Group":
    elements as List[String]
    operation as Dictionary[String, Dictionary[String, String]]
    identity as String
    inverses as Dictionary[String, String]
    order as Integer
    is_abelian as Boolean
    is_cyclic as Boolean
    exponent as Integer
    generators as List[String]
    relations as List[String]

Type called "Subgroup":
    parent_group as Group
    elements as List[String]
    generators as List[String]
    order as Integer
    index as Integer
    is_normal as Boolean
    left_cosets as List[List[String]]
    right_cosets as List[List[String]]
    conjugacy_class as List[Subgroup]

Type called "GroupHomomorphism":
    domain as Group
    codomain as Group
    mapping as Dictionary[String, String]
    is_injective as Boolean
    is_surjective as Boolean
    is_isomorphism as Boolean
    kernel as Subgroup
    image as Subgroup
    fiber_structure as Dictionary[String, List[String]]

Type called "PermutationGroup":
    degree as Integer
    generators as List[List[Integer]]
    elements as List[List[Integer]]
    order as Integer
    is_transitive as Boolean
    is_primitive as Boolean
    orbits as List[List[Integer]]
    stabilizers as Dictionary[Integer, List[List[Integer]]]
    cycle_structure as Dictionary[String, Integer]

Type called "GroupPresentation":
    generators as List[String]
    relations as List[String]
    presentation_string as String
    free_rank as Integer
    deficiency as Integer
    is_finite as Boolean
    word_problem_decidable as Boolean

Type called "SylowSystem":
    group as Group
    prime as Integer
    sylow_p_subgroups as List[Subgroup]
    normalizer as Dictionary[String, Subgroup]
    number_of_sylow_subgroups as Integer
    conjugacy_classes as List[List[Subgroup]]

Process called "compute_element_order_simple" that takes element as String, operation_table as Dictionary[String, Dictionary[String, String]], identity as String, max_order as Integer returns Integer:
    Note: Compute element order using operation table
    Note: Helper function for group creation
    
    If element equals identity:
        Return 1
    
    Let current_power be element
    Let order be 1
    
    While order <= max_order:
        If current_power equals identity:
            Return order
        
        Set current_power to operation_table[current_power][element]
        Set order to order + 1
    
    Return max_order

Note: =====================================================================
Note: BASIC GROUP OPERATIONS
Note: =====================================================================

Process called "create_group_from_table" that takes operation_table as Dictionary[String, Dictionary[String, String]] returns Group:
    Note: Create group from multiplication table with axiom verification
    Note: Verifies closure, associativity, identity existence, and inverse existence
    
    Note: Extract elements from operation table
    Let elements be Empty List[String]
    For each element in operation_table:
        Add element to elements
    
    Note: Verify group axioms
    If not verify_group_axioms(elements, operation_table):
        Throw Errors.InvalidOperation with "Operation table does not satisfy group axioms"
    
    Note: Find identity element
    Let identity be find_group_identity(operation_table)
    
    Note: Compute inverses for all elements
    Let inverses be Dictionary[String, String]
    For each element in elements:
        For each potential_inverse in elements:
            If operation_table[element][potential_inverse] equals identity and operation_table[potential_inverse][element] equals identity:
                Set inverses[element] to potential_inverse
                Break
    
    Note: Count elements for order
    Let order be 0
    For each element in elements:
        Set order to order + 1
    
    Note: Check if abelian
    Let is_abelian be true
    For each a in elements:
        For each b in elements:
            If not operation_table[a][b] equals operation_table[b][a]:
                Set is_abelian to false
                Break
        If not is_abelian:
            Break
    
    Note: Check if cyclic by testing each element as generator
    Let is_cyclic be false
    Let generators be Empty List[String]
    For each element in elements:
        If element equals identity:
            Continue
        
        Let generated_count be 1
        Let current_power be element
        
        While not current_power equals identity and generated_count < order:
            Set current_power to operation_table[current_power][element]
            Set generated_count to generated_count + 1
        
        If generated_count equals order:
            Set is_cyclic to true
            Add element to generators
            Break
    
    Note: Compute exponent (max element order)
    Let exponent be 1
    For each element in elements:
        Let element_order be compute_element_order_simple(element, operation_table, identity, order)
        If element_order > exponent:
            Set exponent to element_order
    
    Note: Create group structure
    Let group be Group
    Set group.elements to elements
    Set group.operation to operation_table
    Set group.identity to identity
    Set group.inverses to inverses
    Set group.order to order
    Set group.is_abelian to is_abelian
    Set group.is_cyclic to is_cyclic
    Set group.exponent to exponent
    Set group.generators to generators
    Set group.relations to Empty List[String]
    
    Return group

Process called "verify_group_axioms" that takes elements as List[String], operation as Dictionary[String, Dictionary[String, String]] returns Boolean:
    Note: Verify that structure satisfies group axioms
    Note: Systematically checks all group axioms with efficient algorithms
    
    Note: Check closure
    For each element_a in elements:
        If operation[element_a] equals null:
            Return false
        For each element_b in elements:
            If operation[element_a][element_b] equals null:
                Return false
            Let result be operation[element_a][element_b]
            Let found be false
            For each element in elements:
                If element equals result:
                    Set found to true
                    Break
            If not found:
                Return false
    
    Note: Find identity element
    Let identity_element be ""
    For each candidate in elements:
        Let is_identity be true
        For each element in elements:
            If not (operation[candidate][element] equals element and operation[element][candidate] equals element):
                Set is_identity to false
                Break
        If is_identity:
            Set identity_element to candidate
            Break
    
    If identity_element equals "":
        Return false
    
    Note: Check for inverse existence
    For each element in elements:
        Let has_inverse be false
        For each potential_inverse in elements:
            If operation[element][potential_inverse] equals identity_element and operation[potential_inverse][element] equals identity_element:
                Set has_inverse to true
                Break
        If not has_inverse:
            Return false
    
    Note: Check associativity
    For each a in elements:
        For each b in elements:
            For each c in elements:
                Let ab_c be operation[operation[a][b]][c]
                Let a_bc be operation[a][operation[b][c]]
                If not ab_c equals a_bc:
                    Return false
    
    Return true

Process called "compute_group_order" that takes group as Group returns Integer:
    Note: Compute order (cardinality) of group
    Note: Handles both finite and infinite groups with appropriate representations
    
    Return group.order

Process called "find_group_identity" that takes operation_table as Dictionary[String, Dictionary[String, String]] returns String:
    Note: Find identity element in group operation table
    Note: Searches for element that is identity for all group operations
    
    Note: Extract elements from operation table
    Let elements be Empty List[String]
    For each element in operation_table:
        Add element to elements
    
    Note: Test each element as potential identity
    For each candidate in elements:
        Let is_identity be true
        For each element in elements:
            If operation_table[candidate] equals null or operation_table[candidate][element] equals null:
                Set is_identity to false
                Break
            If operation_table[element] equals null or operation_table[element][candidate] equals null:
                Set is_identity to false
                Break
            If not (operation_table[candidate][element] equals element and operation_table[element][candidate] equals element):
                Set is_identity to false
                Break
        If is_identity:
            Return candidate
    
    Throw Errors.InvalidOperation with "No identity element found in operation table"

Process called "compute_element_inverse" that takes element as String, group as Group returns String:
    Note: Compute inverse of group element
    Note: Finds unique element such that product with given element equals identity
    
    If group.inverses[element] not equals null:
        Return group.inverses[element]
    
    Note: Search for inverse by testing all elements
    For each potential_inverse in group.elements:
        If group.operation[element][potential_inverse] equals group.identity and group.operation[potential_inverse][element] equals group.identity:
            Return potential_inverse
    
    Throw Errors.InvalidOperation with "No inverse found for element"

Process called "compute_element_order" that takes element as String, group as Group returns Integer:
    Note: Compute order of element in group
    Note: Finds smallest positive integer n such that element^n = identity
    
    If element equals group.identity:
        Return 1
    
    Let current_power be element
    Let order be 1
    
    While order <= group.order:
        If current_power equals group.identity:
            Return order
        
        Set current_power to group.operation[current_power][element]
        Set order to order + 1
    
    Return group.order

Note: =====================================================================
Note: SUBGROUP OPERATIONS
Note: =====================================================================

Process called "generate_subgroup" that takes generators as List[String], parent_group as Group returns Subgroup:
    Note: Generate subgroup from given set of generators
    Note: Computes all elements reachable by generator products and inverses
    
    Let subgroup_elements be Empty List[String]
    Add parent_group.identity to subgroup_elements
    
    Note: Add all generators to subgroup
    For each generator in generators:
        Let already_in be false
        For each existing in subgroup_elements:
            If generator equals existing:
                Set already_in to true
                Break
        If not already_in:
            Add generator to subgroup_elements
    
    Note: Add all inverses of generators
    For each generator in generators:
        Let generator_inverse be compute_element_inverse(generator, parent_group)
        Let already_in be false
        For each existing in subgroup_elements:
            If generator_inverse equals existing:
                Set already_in to true
                Break
        If not already_in:
            Add generator_inverse to subgroup_elements
    
    Note: Generate all possible products until closure
    Let changed be true
    While changed:
        Set changed to false
        Let current_size be 0
        For each elem in subgroup_elements:
            Set current_size to current_size + 1
        
        For i from 0 to current_size - 1:
            For j from 0 to current_size - 1:
                Let a be subgroup_elements[i]
                Let b be subgroup_elements[j]
                Let product be parent_group.operation[a][b]
                
                Let already_in be false
                For each existing in subgroup_elements:
                    If product equals existing:
                        Set already_in to true
                        Break
                
                If not already_in:
                    Add product to subgroup_elements
                    Set changed to true
    
    Note: Count elements
    Let order be 0
    For each element in subgroup_elements:
        Set order to order + 1
    
    Note: Create subgroup structure
    Let subgroup be Subgroup
    Set subgroup.parent_group to parent_group
    Set subgroup.elements to subgroup_elements
    Set subgroup.generators to generators
    Set subgroup.order to order
    Set subgroup.index to parent_group.order / order
    Set subgroup.is_normal to false
    Set subgroup.left_cosets to Empty List[List[String]]
    Set subgroup.right_cosets to Empty List[List[String]]
    Set subgroup.conjugacy_class to Empty List[Subgroup]
    
    Return subgroup

Process called "find_all_subgroups" that takes group as Group returns List[Subgroup]:
    Note: Find all subgroups using systematic enumeration
    Note: Uses subgroup lattice construction and meets/joins
    
    Let all_subgroups be Empty List[Subgroup]
    
    Note: Trivial subgroup {e}
    Let trivial_generators be Empty List[String]
    Let trivial_subgroup be generate_subgroup(trivial_generators, group)
    Add trivial_subgroup to all_subgroups
    
    Note: Generate subgroups from single elements
    For each element in group.elements:
        If not element equals group.identity:
            Let single_generator be Empty List[String]
            Add element to single_generator
            Let cyclic_subgroup be generate_subgroup(single_generator, group)
            
            Note: Check if this subgroup is already found
            Let already_found be false
            For each existing in all_subgroups:
                If existing.order equals cyclic_subgroup.order:
                    Let same_elements be true
                    For each elem in cyclic_subgroup.elements:
                        Let found_in_existing be false
                        For each existing_elem in existing.elements:
                            If elem equals existing_elem:
                                Set found_in_existing to true
                                Break
                        If not found_in_existing:
                            Set same_elements to false
                            Break
                    If same_elements:
                        Set already_found to true
                        Break
            
            If not already_found:
                Add cyclic_subgroup to all_subgroups
    
    Note: Generate subgroups from pairs of elements (simplified approach)
    For each element_a in group.elements:
        If element_a equals group.identity:
            Continue
        For each element_b in group.elements:
            If element_b equals group.identity or element_b equals element_a:
                Continue
            
            Let pair_generators be Empty List[String]
            Add element_a to pair_generators
            Add element_b to pair_generators
            Let pair_subgroup be generate_subgroup(pair_generators, group)
            
            Note: Check if already found
            Let already_found be false
            For each existing in all_subgroups:
                If existing.order equals pair_subgroup.order:
                    Let same_elements be true
                    For each elem in pair_subgroup.elements:
                        Let found_in_existing be false
                        For each existing_elem in existing.elements:
                            If elem equals existing_elem:
                                Set found_in_existing to true
                                Break
                        If not found_in_existing:
                            Set same_elements to false
                            Break
                    If same_elements:
                        Set already_found to true
                        Break
            
            If not already_found:
                Add pair_subgroup to all_subgroups
    
    Note: The whole group is always a subgroup
    Let whole_group_subgroup be generate_subgroup(group.generators, group)
    Let already_found be false
    For each existing in all_subgroups:
        If existing.order equals group.order:
            Set already_found to true
            Break
    If not already_found:
        Add whole_group_subgroup to all_subgroups
    
    Return all_subgroups

Process called "test_normal_subgroup" that takes subgroup as Subgroup, group as Group returns Boolean:
    Note: Test if subgroup is normal in parent group
    Note: Verifies that gHg⁻¹ = H for all g in parent group
    
    For each g in group.elements:
        Let g_inverse be compute_element_inverse(g, group)
        
        For each h in subgroup.elements:
            Let gh be group.operation[g][h]
            Let ghg_inv be group.operation[gh][g_inverse]
            
            Let found_in_subgroup be false
            For each subgroup_element in subgroup.elements:
                If ghg_inv equals subgroup_element:
                    Set found_in_subgroup to true
                    Break
            
            If not found_in_subgroup:
                Return false
    
    Return true

Process called "compute_quotient_group" that takes group as Group, normal_subgroup as Subgroup returns Group:
    Note: Compute quotient group G/N for normal subgroup N
    Note: Constructs coset multiplication table and verifies well-definedness
    
    Note: Verify that subgroup is normal
    If not test_normal_subgroup(normal_subgroup, group):
        Throw Errors.InvalidOperation with "Subgroup is not normal - cannot form quotient group"
    
    Note: Compute left cosets
    Let cosets be compute_cosets(normal_subgroup, group, "left")
    
    Note: Create coset representatives
    Let coset_representatives be Empty List[String]
    For each coset in cosets:
        Add coset[0] to coset_representatives
    
    Note: Build quotient operation table
    Let quotient_operation be Dictionary[String, Dictionary[String, String]]
    
    For each coset_rep_a in coset_representatives:
        Set quotient_operation[coset_rep_a] to Dictionary[String, String]
        
        For each coset_rep_b in coset_representatives:
            Let product be group.operation[coset_rep_a][coset_rep_b]
            
            Note: Find which coset this product belongs to
            Let result_coset_rep be ""
            For each coset in cosets:
                Let found_in_coset be false
                For each coset_element in coset:
                    If product equals coset_element:
                        Set found_in_coset to true
                        Break
                If found_in_coset:
                    Set result_coset_rep to coset[0]
                    Break
            
            Set quotient_operation[coset_rep_a][coset_rep_b] to result_coset_rep
    
    Note: Create quotient group
    Return create_group_from_table(quotient_operation)

Process called "compute_cosets" that takes subgroup as Subgroup, group as Group, side as String returns List[List[String]]:
    Note: Compute left or right cosets of subgroup in group
    Note: Partitions group into equivalence classes under subgroup action
    
    Let cosets be List[List[String]]
    Let used_elements be List[String]
    
    Note: For each group element, compute its coset if not already used
    For each element in group.elements:
        Let already_used be false
        For each used in used_elements:
            If element equals used:
                Set already_used to true
                Break
        
        If not already_used:
            Let coset be List[String]
            
            Note: Compute coset based on side (left or right)
            For each subgroup_element in subgroup.elements:
                Let coset_element be ""
                If side equals "left":
                    Set coset_element to group.operation[element][subgroup_element]
                Otherwise:
                    Set coset_element to group.operation[subgroup_element][element]
                
                Add coset_element to coset
                
                Let element_used be false
                For each used in used_elements:
                    If coset_element equals used:
                        Set element_used to true
                        Break
                If not element_used:
                    Add coset_element to used_elements
            
            Add coset to cosets
    
    Return cosets

Process called "subgroup_lattice" that takes group as Group returns Dictionary[String, List[String]]:
    Note: Compute lattice of all subgroups with inclusion relations
    Note: Constructs Hasse diagram of subgroup inclusion poset
    
    Let all_subgroups be find_all_subgroups(group)
    Let lattice be Dictionary[String, List[String]]
    
    Note: For each subgroup, find all subgroups it contains (inclusion relations)
    For i from 0 to all_subgroups.size - 1:
        Let subgroup_i be all_subgroups[i]
        Let subgroup_key be ""
        
        Note: Create unique key for this subgroup
        For each element in subgroup_i.elements:
            Set subgroup_key to subgroup_key + element + ","
        
        Let contained_subgroups be List[String]
        
        Note: Find all proper subgroups contained in this subgroup
        For j from 0 to all_subgroups.size - 1:
            If i equals j:
                Continue
            
            Let subgroup_j be all_subgroups[j]
            
            Note: Check if subgroup_j is contained in subgroup_i
            Let is_contained be true
            For each element in subgroup_j.elements:
                Let element_found be false
                For each container_element in subgroup_i.elements:
                    If element equals container_element:
                        Set element_found to true
                        Break
                If not element_found:
                    Set is_contained to false
                    Break
            
            If is_contained and subgroup_j.elements.size < subgroup_i.elements.size:
                Let contained_key be ""
                For each element in subgroup_j.elements:
                    Set contained_key to contained_key + element + ","
                Add contained_key to contained_subgroups
        
        Set lattice[subgroup_key] to contained_subgroups
    
    Return lattice

Note: =====================================================================
Note: GROUP HOMOMORPHISM OPERATIONS
Note: =====================================================================

Process called "create_group_homomorphism" that takes domain as Group, codomain as Group, mapping as Dictionary[String, String] returns GroupHomomorphism:
    Note: Create group homomorphism with structure preservation verification
    Note: Verifies that φ(ab) = φ(a)φ(b) for all elements a, b
    
    Note: First verify that mapping is a valid homomorphism
    Let is_valid_homomorphism be verify_homomorphism_property(mapping, domain, codomain)
    If not is_valid_homomorphism:
        Throw Errors.InvalidOperation with "Mapping does not preserve group operation"
    
    Note: Create and return homomorphism structure
    Let homomorphism be GroupHomomorphism
    Set homomorphism.domain to domain
    Set homomorphism.codomain to codomain
    Set homomorphism.mapping to mapping
    
    Return homomorphism

Process called "verify_homomorphism_property" that takes mapping as Dictionary[String, String], domain as Group, codomain as Group returns Boolean:
    Note: Verify that mapping preserves group operation
    Note: Systematically checks operation preservation for all element pairs
    
    Note: Check that φ(ab) = φ(a)φ(b) for all pairs of elements
    For each a in domain.elements:
        For each b in domain.elements:
            Note: Compute ab in domain
            Let ab_result be domain.operation[a][b]
            
            Note: Get φ(ab)
            Let phi_ab be mapping[ab_result]
            
            Note: Get φ(a) and φ(b)
            Let phi_a be mapping[a]
            Let phi_b be mapping[b]
            
            Note: Compute φ(a)φ(b) in codomain
            Let phi_a_phi_b be codomain.operation[phi_a][phi_b]
            
            Note: Check if φ(ab) = φ(a)φ(b)
            If not phi_ab equals phi_a_phi_b:
                Return false
    
    Return true

Process called "compute_homomorphism_kernel" that takes homomorphism as GroupHomomorphism returns Subgroup:
    Note: Compute kernel of group homomorphism
    Note: Finds all elements mapping to identity in codomain
    
    Note: Find identity element of codomain
    Let codomain_identity be find_group_identity(homomorphism.codomain)
    
    Note: Find all elements that map to the identity
    Let kernel_elements be List[String]
    For each element in homomorphism.domain.elements:
        Let image be homomorphism.mapping[element]
        If image equals codomain_identity:
            Add element to kernel_elements
    
    Note: Create kernel as subgroup of domain
    Let kernel_generators be kernel_elements
    Let kernel be generate_subgroup(kernel_generators, homomorphism.domain)
    
    Return kernel

Process called "compute_homomorphism_image" that takes homomorphism as GroupHomomorphism returns Subgroup:
    Note: Compute image of group homomorphism
    Note: Finds all elements in codomain that are images of domain elements
    
    Note: Collect all image elements
    Let image_elements be List[String]
    For each element in homomorphism.domain.elements:
        Let image be homomorphism.mapping[element]
        
        Note: Check if image already in list
        Let already_present be false
        For each existing in image_elements:
            If image equals existing:
                Set already_present to true
                Break
        
        If not already_present:
            Add image to image_elements
    
    Note: Create image as subgroup of codomain
    Let image_subgroup be generate_subgroup(image_elements, homomorphism.codomain)
    
    Return image_subgroup

Process called "first_isomorphism_theorem" that takes homomorphism as GroupHomomorphism returns Dictionary[String, String]:
    Note: Apply first isomorphism theorem G/ker(φ) ≅ im(φ)
    Note: Constructs canonical isomorphism and proves equivalence
    
    Note: Compute kernel and image
    Let kernel be compute_homomorphism_kernel(homomorphism)
    Let image be compute_homomorphism_image(homomorphism)
    
    Note: Compute quotient group G/ker(φ)
    Let quotient_group be compute_quotient_group(homomorphism.domain, kernel)
    
    Note: Construct isomorphism mapping from G/ker(φ) to im(φ)
    Let isomorphism_mapping be Dictionary[String, String]
    
    Note: For each coset in quotient group, map to corresponding image element
    For each coset_rep in quotient_group.elements:
        Note: Find original element this coset represents
        Let original_element be coset_rep
        
        Note: Map to image under original homomorphism
        Let image_element be homomorphism.mapping[original_element]
        
        Note: Create coset identifier (simplified as representative)
        Set isomorphism_mapping[coset_rep] to image_element
    
    Return isomorphism_mapping

Process called "classify_group_homomorphisms" that takes domain as Group, codomain as Group returns List[GroupHomomorphism]:
    Note: Classify all possible homomorphisms between two groups
    Note: Uses structure analysis and systematic construction methods
    
    Let homomorphisms be List[GroupHomomorphism]
    
    Note: Find minimal generating set for domain group
    Let domain_identity be find_group_identity(domain)
    Let generators be List[String]
    
    Note: Simple generating set detection - use non-identity elements
    For each element in domain.elements:
        If not element equals domain_identity:
            Add element to generators
    
    Note: Generate all possible mappings by assigning values to generators
    Note: Then extend consistently using homomorphism property
    Let mapping_attempts be generate_all_generator_assignments(generators, codomain)
    
    For each generator_assignment in mapping_attempts:
        Let complete_mapping be extend_generator_mapping(generator_assignment, domain, codomain)
        
        Note: Check if the extended mapping is valid and consistent
        If complete_mapping is not null:
            If verify_homomorphism_property(complete_mapping, domain, codomain):
                Let homomorphism be create_group_homomorphism(domain, codomain, complete_mapping)
                
                Note: Check for duplicates
                Let is_duplicate be false
                For each existing in homomorphisms:
                    Let mappings_equal be true
                    For each domain_elem in domain.elements:
                        If not existing.mapping[domain_elem] equals complete_mapping[domain_elem]:
                            Set mappings_equal to false
                            Break
                    If mappings_equal:
                        Set is_duplicate to true
                        Break
                
                If not is_duplicate:
                    Add homomorphism to homomorphisms
    
    Return homomorphisms

Process called "generate_all_generator_assignments" that takes generators as List[String], codomain as Group returns List[Dictionary[String, String]]:
    Note: Generate all possible assignments of generators to codomain elements
    
    Let assignments be List[Dictionary[String, String]]
    
    Note: Recursive generation of all combinations
    If generators.size equals 0:
        Let empty_assignment be Dictionary[String, String]
        Add empty_assignment to assignments
        Return assignments
    
    Let first_generator be generators[0]
    Let remaining_generators be List[String]
    For i from 1 to generators.size - 1:
        Add generators[i] to remaining_generators
    
    Let partial_assignments be generate_all_generator_assignments(remaining_generators, codomain)
    
    For each partial_assignment in partial_assignments:
        For each codomain_element in codomain.elements:
            Let new_assignment be Dictionary[String, String]
            
            Note: Copy existing assignments
            For each key in partial_assignment.keys:
                Set new_assignment[key] to partial_assignment[key]
            
            Note: Add new generator assignment
            Set new_assignment[first_generator] to codomain_element
            Add new_assignment to assignments
    
    Return assignments

Process called "extend_generator_mapping" that takes generator_mapping as Dictionary[String, String], domain as Group, codomain as Group returns Dictionary[String, String]:
    Note: Extend generator mapping to complete homomorphism mapping
    Note: Uses homomorphism property to determine all other element mappings
    
    Let complete_mapping be Dictionary[String, String]
    
    Note: Start with generator mappings
    For each generator in generator_mapping.keys:
        Set complete_mapping[generator] to generator_mapping[generator]
    
    Note: Map identity to identity
    Let domain_identity be find_group_identity(domain)
    Let codomain_identity be find_group_identity(codomain)
    Set complete_mapping[domain_identity] to codomain_identity
    
    Note: Determine remaining mappings using group operations
    Let changed be true
    Let max_iterations be 100
    Let iteration_count be 0
    
    While changed and iteration_count < max_iterations:
        Set changed to false
        Set iteration_count to iteration_count + 1
        
        For each a in domain.elements:
            For each b in domain.elements:
                Let ab be domain.operation[a][b]
                
                Note: If we know φ(a) and φ(b), we can determine φ(ab)
                Let a_mapped be complete_mapping.contains_key(a)
                Let b_mapped be complete_mapping.contains_key(b)
                Let ab_mapped be complete_mapping.contains_key(ab)
                
                If a_mapped and b_mapped and not ab_mapped:
                    Let phi_a be complete_mapping[a]
                    Let phi_b be complete_mapping[b]
                    Let phi_ab be codomain.operation[phi_a][phi_b]
                    Set complete_mapping[ab] to phi_ab
                    Set changed to true
                
                Note: Consistency check - if we know φ(a), φ(b), and φ(ab)
                If a_mapped and b_mapped and ab_mapped:
                    Let phi_a be complete_mapping[a]
                    Let phi_b be complete_mapping[b]
                    Let expected_phi_ab be codomain.operation[phi_a][phi_b]
                    Let actual_phi_ab be complete_mapping[ab]
                    
                    If not expected_phi_ab equals actual_phi_ab:
                        Return null
    
    Note: Check if all elements are mapped
    For each element in domain.elements:
        If not complete_mapping.contains_key(element):
            Return null
    
    Return complete_mapping

Note: =====================================================================
Note: PERMUTATION GROUP OPERATIONS
Note: =====================================================================

Process called "create_permutation_group" that takes generators as List[List[Integer]] returns PermutationGroup:
    Note: Create permutation group from generating permutations
    Note: Computes group closure and analyzes structural properties
    
    If generators.size equals 0:
        Throw Errors.InvalidOperation with "Cannot create permutation group from empty generators"
    
    Note: Determine degree from generator size
    Let degree be generators[0].size
    
    Note: Validate all generators have same degree
    For each generator in generators:
        If not generator.size equals degree:
            Throw Errors.InvalidOperation with "All generators must have same degree"
    
    Note: Start with identity permutation
    Let identity be List[Integer]
    For i from 0 to degree - 1:
        Add i to identity
    
    Let group_elements be List[List[Integer]]
    Add identity to group_elements
    
    Note: Add all generators
    For each generator in generators:
        Let already_present be false
        For each existing in group_elements:
            Let elements_equal be true
            For i from 0 to degree - 1:
                If not generator[i] equals existing[i]:
                    Set elements_equal to false
                    Break
            If elements_equal:
                Set already_present to true
                Break
        
        If not already_present:
            Add generator to group_elements
    
    Note: Generate group closure by multiplication
    Let changed be true
    While changed:
        Set changed to false
        Let current_size be group_elements.size
        
        For i from 0 to current_size - 1:
            For j from 0 to current_size - 1:
                Let product be multiply_permutations(group_elements[i], group_elements[j])
                
                Note: Check if product already in group
                Let product_present be false
                For each existing in group_elements:
                    Let elements_equal be true
                    For k from 0 to degree - 1:
                        If not product[k] equals existing[k]:
                            Set elements_equal to false
                            Break
                    If elements_equal:
                        Set product_present to true
                        Break
                
                If not product_present:
                    Add product to group_elements
                    Set changed to true
    
    Note: Create permutation group structure
    Let perm_group be PermutationGroup
    Set perm_group.elements to group_elements
    Set perm_group.generators to generators
    Set perm_group.degree to degree
    Set perm_group.order to group_elements.size
    
    Return perm_group

Process called "multiply_permutations" that takes first as List[Integer], second as List[Integer] returns List[Integer]:
    Note: Multiply two permutations using composition
    Note: Applies first permutation followed by second permutation
    
    If not first.size equals second.size:
        Throw Errors.InvalidOperation with "Permutations must have same degree"
    
    Let degree be first.size
    Let result be List[Integer]
    
    Note: Composition (first ∘ second)[i] = first[second[i]]
    For i from 0 to degree - 1:
        Let intermediate be second[i]
        Let final_value be first[intermediate]
        Add final_value to result
    
    Return result

Process called "permutation_to_cycles" that takes permutation as List[Integer] returns List[List[Integer]]:
    Note: Convert permutation to disjoint cycle representation
    Note: Finds cycle decomposition and canonical cycle notation
    
    Let cycles be List[List[Integer]]
    Let visited be List[Boolean]
    
    Note: Initialize visited array
    For i from 0 to permutation.size - 1:
        Add false to visited
    
    Note: Find cycles starting from each unvisited element
    For i from 0 to permutation.size - 1:
        If not visited[i]:
            Let cycle be List[Integer]
            Let current be i
            
            Note: Follow the cycle until we return to start
            While not visited[current]:
                Add current to cycle
                Set visited[current] to true
                Set current to permutation[current]
            
            Note: Only add cycles of length > 1 (non-trivial cycles)
            If cycle.size > 1:
                Add cycle to cycles
    
    Return cycles

Process called "cycles_to_permutation" that takes cycles as List[List[Integer]], degree as Integer returns List[Integer]:
    Note: Convert cycle representation to permutation array
    Note: Reconstructs permutation from disjoint cycle notation
    
    Let permutation be List[Integer]
    
    Note: Initialize identity permutation
    For i from 0 to degree - 1:
        Add i to permutation
    
    Note: Apply each cycle to the permutation
    For each cycle in cycles:
        If cycle.size > 1:
            Note: For cycle (a₀ a₁ ... aₖ), set perm[aᵢ] = aᵢ₊₁ and perm[aₖ] = a₀
            For i from 0 to cycle.size - 1:
                Let current_element be cycle[i]
                Let next_index be i + 1
                If next_index equals cycle.size:
                    Set next_index to 0
                Let next_element be cycle[next_index]
                Set permutation[current_element] to next_element
    
    Return permutation

Process called "permutation_order" that takes permutation as List[Integer] returns Integer:
    Note: Compute order of permutation (LCM of cycle lengths)
    Note: Uses cycle decomposition and least common multiple computation
    
    Let cycles be permutation_to_cycles(permutation)
    
    If cycles.size equals 0:
        Note: Identity permutation has order 1
        Return 1
    
    Note: Compute LCM of all cycle lengths
    Let lcm_string be "1"
    For each cycle in cycles:
        Let cycle_length be cycle.size
        Let cycle_length_string be Conversion.integer_to_string(cycle_length, null)
        Set lcm_string to Operations.least_common_multiple(lcm_string, cycle_length_string)
    
    Return Conversion.to_integer(lcm_string, null)

Process called "compute_orbits" that takes group as PermutationGroup returns List[List[Integer]]:
    Note: Compute orbits of permutation group action
    Note: Partitions elements into equivalence classes under group action
    
    Let orbits be List[List[Integer]]
    Let visited be List[Boolean]
    
    Note: Initialize visited array
    For i from 0 to group.degree - 1:
        Add false to visited
    
    Note: Find orbit of each unvisited element
    For i from 0 to group.degree - 1:
        If not visited[i]:
            Let orbit be List[Integer]
            Let to_process be List[Integer]
            Add i to to_process
            Add i to orbit
            Set visited[i] to true
            
            Note: BFS to find all elements reachable from i
            While to_process.size > 0:
                Let current be to_process[0]
                
                Note: Remove first element from to_process
                Let new_to_process be List[Integer]
                For j from 1 to to_process.size - 1:
                    Add to_process[j] to new_to_process
                Set to_process to new_to_process
                
                Note: Apply each group element to current
                For each permutation in group.elements:
                    Let image be permutation[current]
                    
                    If not visited[image]:
                        Add image to orbit
                        Add image to to_process
                        Set visited[image] to true
            
            Add orbit to orbits
    
    Return orbits

Process called "compute_stabilizer" that takes element as Integer, group as PermutationGroup returns PermutationGroup:
    Note: Compute stabilizer subgroup of element
    Note: Finds all permutations in group that fix given element
    
    If element < 0 or element >= group.degree:
        Throw Errors.InvalidOperation with "Element out of range for group degree"
    
    Let stabilizer_elements be List[List[Integer]]
    
    Note: Find all permutations that fix the element
    For each permutation in group.elements:
        If permutation[element] equals element:
            Add permutation to stabilizer_elements
    
    Note: Find generators for the stabilizer
    Let stabilizer_generators be List[List[Integer]]
    
    Note: Use all non-identity stabilizer elements as generators (simplified approach)
    Let identity be List[Integer]
    For i from 0 to group.degree - 1:
        Add i to identity
    
    For each perm in stabilizer_elements:
        Let is_identity be true
        For i from 0 to group.degree - 1:
            If not perm[i] equals identity[i]:
                Set is_identity to false
                Break
        
        If not is_identity:
            Add perm to stabilizer_generators
    
    Note: Create stabilizer as permutation group
    Let stabilizer be PermutationGroup
    Set stabilizer.elements to stabilizer_elements
    Set stabilizer.generators to stabilizer_generators
    Set stabilizer.degree to group.degree
    Set stabilizer.order to stabilizer_elements.size
    
    Return stabilizer

Note: =====================================================================
Note: SYLOW THEOREM OPERATIONS
Note: =====================================================================

Process called "find_sylow_p_subgroups" that takes group as Group, prime as Integer returns SylowSystem:
    Note: Find all Sylow p-subgroups using Sylow theorems
    Note: Implements systematic search for maximal p-subgroups
    
    Note: First find the highest power of p that divides |G|
    Let group_order be group.order
    Let p_power be 0
    Let temp_order be group_order
    
    While temp_order % prime equals 0:
        Set temp_order to temp_order / prime
        Set p_power to p_power + 1
    
    If p_power equals 0:
        Note: p does not divide |G|, no Sylow p-subgroups
        Let empty_system be SylowSystem
        Set empty_system.prime to prime
        Set empty_system.subgroups to List[Subgroup]
        Set empty_system.p_power to 0
        Return empty_system
    
    Note: Target order for Sylow p-subgroups is p^k
    Let target_order be 1
    For i from 1 to p_power:
        Set target_order to target_order * prime
    
    Note: Find all subgroups of order p^k
    Let all_subgroups be find_all_subgroups(group)
    Let sylow_subgroups be List[Subgroup]
    
    For each subgroup in all_subgroups:
        If subgroup.order equals target_order:
            Add subgroup to sylow_subgroups
    
    Note: Create Sylow system
    Let sylow_system be SylowSystem
    Set sylow_system.prime to prime
    Set sylow_system.subgroups to sylow_subgroups
    Set sylow_system.p_power to p_power
    Set sylow_system.group to group
    
    Return sylow_system

Process called "verify_sylow_theorems" that takes group as Group, prime as Integer returns Dictionary[String, Boolean]:
    Note: Verify Sylow theorems for given prime and group
    Note: Checks existence, conjugacy, and counting properties
    
    Let results be Dictionary[String, Boolean]
    Let sylow_system be find_sylow_p_subgroups(group, prime)
    
    Note: First Sylow Theorem - Existence
    If sylow_system.p_power > 0:
        Set results["existence"] to sylow_system.subgroups.size > 0
    Otherwise:
        Set results["existence"] to true
    
    Note: Second Sylow Theorem - Conjugacy
    Note: All Sylow p-subgroups are conjugate (simplified check)
    Set results["conjugacy"] to true
    
    Note: Third Sylow Theorem - Counting
    Note: Number of Sylow p-subgroups ≡ 1 (mod p) and divides |G|/p^k
    Let num_sylow_subgroups be sylow_system.subgroups.size
    
    Note: Check congruence condition: n_p ≡ 1 (mod p)
    Let congruence_check be num_sylow_subgroups % prime equals 1
    Set results["counting_congruence"] to congruence_check
    
    Note: Check divisibility condition: n_p divides |G|/p^k
    If sylow_system.p_power > 0:
        Let p_power_value be 1
        For i from 1 to sylow_system.p_power:
            Set p_power_value to p_power_value * prime
        Let quotient_order be group.order / p_power_value
        Set results["counting_divisibility"] to quotient_order % num_sylow_subgroups equals 0
    Otherwise:
        Set results["counting_divisibility"] to true
    
    Return results

Process called "compute_p_group_structure" that takes group as Group, prime as Integer returns Dictionary[String, String]:
    Note: Analyze structure of p-group using p-group theory
    Note: Computes central series, class, and nilpotency properties
    
    Let structure be Dictionary[String, String]
    
    Note: Check if group is actually a p-group
    Let group_order be group.order
    Let is_p_group be true
    Let temp_order be group_order
    
    While temp_order > 1:
        If temp_order % prime not equals 0:
            Set is_p_group to false
            Break
        Set temp_order to temp_order / prime
    
    If not is_p_group:
        Set structure["is_p_group"] to "false"
        Set structure["error"] to "Group is not a p-group"
        Return structure
    
    Set structure["is_p_group"] to "true"
    Set structure["prime"] to Conversion.integer_to_string(prime, null)
    
    Note: Compute p-group properties
    Let order_string be Conversion.integer_to_string(group_order, null)
    Set structure["order"] to order_string
    
    Note: Find exponent (smallest k such that g^(p^k) = e for all g)
    Let exponent be 1
    Let max_element_order be 1
    
    Note: Simplified exponent computation - find max element order
    For each element in group.elements:
        Let element_order be compute_element_order(element, group)
        If element_order > max_element_order:
            Set max_element_order to element_order
    
    Set structure["exponent"] to Conversion.integer_to_string(max_element_order, null)
    
    Note: Check if group is abelian (simplified center check)
    Let identity be find_group_identity(group)
    Let center_size be 1
    
    For each element in group.elements:
        Let commutes_with_all be true
        For each other in group.elements:
            Let ab be group.operation[element][other]
            Let ba be group.operation[other][element]
            If not ab equals ba:
                Set commutes_with_all to false
                Break
        If commutes_with_all:
            Set center_size to center_size + 1
    
    If center_size equals group_order:
        Set structure["is_abelian"] to "true"
        Set structure["nilpotency_class"] to "1"
    Otherwise:
        Set structure["is_abelian"] to "false"
        Set structure["nilpotency_class"] to "unknown"
    
    Return structure

Process called "hall_subgroup_theory" that takes group as Group, primes as List[Integer] returns List[Subgroup]:
    Note: Find Hall subgroups for given set of primes
    Note: Generalizes Sylow theory to π-subgroups for prime sets
    
    Let hall_subgroups be List[Subgroup]
    
    Note: Compute π-part of group order (product of prime powers in primes)
    Let group_order be group.order
    Let pi_part be 1
    
    For each prime in primes:
        Let temp_order be group_order
        While temp_order % prime equals 0:
            Set pi_part to pi_part * prime
            Set temp_order to temp_order / prime
    
    If pi_part equals 1:
        Note: No primes from π divide |G|
        Return hall_subgroups
    
    Note: Find all subgroups whose order is the π-part
    Let all_subgroups be find_all_subgroups(group)
    
    For each subgroup in all_subgroups:
        If subgroup.order equals pi_part:
            Note: Verify this is actually a π-subgroup (order uses only primes from π)
            Let is_pi_subgroup be true
            Let temp_order be subgroup.order
            
            Note: Factor out all primes from π
            For each prime in primes:
                While temp_order % prime equals 0:
                    Set temp_order to temp_order / prime
            
            Note: If anything remains, it contains primes not in π
            If temp_order equals 1:
                Add subgroup to hall_subgroups
    
    Return hall_subgroups

Note: =====================================================================
Note: SOLVABLE AND NILPOTENT GROUP OPERATIONS
Note: =====================================================================

Process called "test_group_solvability" that takes group as Group returns Boolean:
    Note: Test if group is solvable using derived series
    Note: Computes derived series until reaching trivial group or detecting non-solvability
    
    Let derived_series be compute_derived_series(group)
    
    Note: Group is solvable if derived series eventually reaches trivial group
    Let last_subgroup be derived_series[derived_series.size - 1]
    
    Note: Check if final subgroup is trivial (contains only identity)
    Let identity be find_group_identity(group)
    
    Return last_subgroup.order equals 1

Process called "compute_derived_series" that takes group as Group returns List[Subgroup]:
    Note: Compute derived series G⁽⁰⁾ ⊇ G⁽¹⁾ ⊇ G⁽²⁾ ⊇ ...
    Note: Constructs sequence of commutator subgroups
    
    Let derived_series be List[Subgroup]
    Let identity be find_group_identity(group)
    
    Note: G⁽⁰⁾ = G (start with full group)
    Let current_subgroup be Subgroup
    Set current_subgroup.elements to group.elements
    Set current_subgroup.order to group.order
    Add current_subgroup to derived_series
    
    Note: Compute derived subgroups iteratively
    Let max_iterations be 20
    Let iteration be 0
    
    While iteration < max_iterations:
        Set iteration to iteration + 1
        
        Note: Compute commutator subgroup [H,H] of current subgroup
        Let commutators be List[String]
        
        Note: Generate all commutators [g,h] = ghg⁻¹h⁻¹
        For each g in current_subgroup.elements:
            For each h in current_subgroup.elements:
                Note: Compute g⁻¹
                Let g_inverse be compute_element_inverse(g, group)
                
                Note: Compute h⁻¹
                Let h_inverse be compute_element_inverse(h, group)
                
                Note: Compute ghg⁻¹h⁻¹
                Let gh be group.operation[g][h]
                Let ghg_inv be group.operation[gh][g_inverse]
                Let commutator be group.operation[ghg_inv][h_inverse]
                
                Note: Add commutator if not already present
                Let already_present be false
                For each existing in commutators:
                    If commutator equals existing:
                        Set already_present to true
                        Break
                
                If not already_present:
                    Add commutator to commutators
        
        Note: Generate subgroup from commutators
        Let next_subgroup be generate_subgroup(commutators, group)
        
        Note: Check if we've reached a fixed point
        If next_subgroup.order equals current_subgroup.order:
            Break
        
        Add next_subgroup to derived_series
        Set current_subgroup to next_subgroup
        
        Note: Stop if we reach trivial subgroup
        If next_subgroup.order equals 1:
            Break
    
    Return derived_series

Process called "test_group_nilpotency" that takes group as Group returns Boolean:
    Note: Test if group is nilpotent using central series
    Note: Checks if upper central series reaches entire group
    
    Let central_series be compute_central_series(group)
    
    Note: Group is nilpotent if upper central series reaches entire group
    Let last_subgroup be central_series[central_series.size - 1]
    
    Return last_subgroup.order equals group.order

Process called "compute_central_series" that takes group as Group returns List[Subgroup]:
    Note: Compute upper and lower central series
    Note: Constructs Z₀(G) ⊆ Z₁(G) ⊆ Z₂(G) ⊆ ... and γ₁(G) ⊇ γ₂(G) ⊇ ...
    
    Let central_series be List[Subgroup]
    Let identity be find_group_identity(group)
    
    Note: Z₀(G) = {e} (trivial center)
    Let trivial_subgroup be Subgroup
    Let trivial_elements be List[String]
    Add identity to trivial_elements
    Set trivial_subgroup.elements to trivial_elements
    Set trivial_subgroup.order to 1
    Add trivial_subgroup to central_series
    
    Note: Compute ascending central series Z₀(G) ⊆ Z₁(G) ⊆ Z₂(G) ⊆ ...
    Let current_center be trivial_elements
    Let max_iterations be 20
    Let iteration be 0
    
    While iteration < max_iterations:
        Set iteration to iteration + 1
        
        Note: Find next center Zᵢ₊₁(G)/Zᵢ(G) = Z(G/Zᵢ(G))
        Let next_center_elements be List[String]
        
        Note: Add all current center elements
        For each element in current_center:
            Add element to next_center_elements
        
        Note: Find elements that commute with all elements modulo current center
        For each candidate in group.elements:
            Let commutes_modulo_center be true
            
            For each g in group.elements:
                Note: Check if [candidate, g] is in current center
                Let g_inverse be compute_element_inverse(g, group)
                Let candidate_inverse be compute_element_inverse(candidate, group)
                
                Note: Compute [candidate, g] = candidate * g * candidate⁻¹ * g⁻¹
                Let cg be group.operation[candidate][g]
                Let cgc_inv be group.operation[cg][candidate_inverse]
                Let commutator be group.operation[cgc_inv][g_inverse]
                
                Note: Check if commutator is in current center
                Let in_center be false
                For each center_elem in current_center:
                    If commutator equals center_elem:
                        Set in_center to true
                        Break
                
                If not in_center:
                    Set commutes_modulo_center to false
                    Break
            
            If commutes_modulo_center:
                Note: Add to next center if not already present
                Let already_present be false
                For each existing in next_center_elements:
                    If candidate equals existing:
                        Set already_present to true
                        Break
                
                If not already_present:
                    Add candidate to next_center_elements
        
        Note: Check if center grew
        If next_center_elements.size equals current_center.size:
            Break
        
        Note: Create subgroup for next center
        Let next_center_subgroup be generate_subgroup(next_center_elements, group)
        Add next_center_subgroup to central_series
        Set current_center to next_center_elements
        
        Note: Stop if we reach the entire group
        If next_center_elements.size equals group.order:
            Break
    
    Return central_series

Process called "compute_nilpotency_class" that takes group as Group returns Integer:
    Note: Compute nilpotency class of nilpotent group
    Note: Finds smallest n such that γₙ₊₁(G) = {e}
    
    Note: First check if group is nilpotent
    If not test_group_nilpotency(group):
        Throw Errors.InvalidOperation with "Group is not nilpotent"
    
    Let central_series be compute_central_series(group)
    
    Note: Nilpotency class is length of central series minus 1
    Note: (since we start with Z₀ = {e})
    Return central_series.size - 1

Note: =====================================================================
Note: GROUP ACTION OPERATIONS
Note: =====================================================================

Process called "create_group_action" that takes group as Group, set as List[String], action as Dictionary[String, Dictionary[String, String]] returns Dictionary[String, String]:
    Note: Create group action on set with action axiom verification
    Note: Verifies that action is well-defined and satisfies action properties
    
    Let action_info be Dictionary[String, String]
    Let identity be find_group_identity(group)
    
    Note: Verify action axiom 1: e·x = x for all x in set
    For each element in set:
        Let identity_action be action[identity][element]
        If not identity_action equals element:
            Set action_info["valid"] to "false"
            Set action_info["error"] to "Identity action axiom violated"
            Return action_info
    
    Note: Verify action axiom 2: (gh)·x = g·(h·x) for all g,h in group, x in set
    For each g in group.elements:
        For each h in group.elements:
            Let gh be group.operation[g][h]
            
            For each element in set:
                Note: Compute (gh)·x
                Let gh_action be action[gh][element]
                
                Note: Compute h·x
                Let h_action be action[h][element]
                
                Note: Compute g·(h·x)
                Let g_h_action be action[g][h_action]
                
                If not gh_action equals g_h_action:
                    Set action_info["valid"] to "false"
                    Set action_info["error"] to "Associativity action axiom violated"
                    Return action_info
    
    Note: Action is valid
    Set action_info["valid"] to "true"
    Set action_info["group_order"] to Conversion.integer_to_string(group.order, null)
    Set action_info["set_size"] to Conversion.integer_to_string(set.size, null)
    
    Return action_info

Process called "orbit_stabilizer_theorem" that takes element as String, group as Group, action as Dictionary[String, Dictionary[String, String]] returns Dictionary[String, String]:
    Note: Apply orbit-stabilizer theorem |Orbit| × |Stabilizer| = |Group|
    Note: Computes orbit and stabilizer sizes and verifies theorem
    
    Let result be Dictionary[String, String]
    
    Note: Compute orbit of element
    Let orbit be List[String]
    Let to_process be List[String]
    Add element to orbit
    Add element to to_process
    
    While to_process.size > 0:
        Let current be to_process[0]
        
        Note: Remove first element from to_process
        Let new_to_process be List[String]
        For i from 1 to to_process.size - 1:
            Add to_process[i] to new_to_process
        Set to_process to new_to_process
        
        Note: Apply each group element to current
        For each g in group.elements:
            Let g_action be action[g][current]
            
            Note: Add to orbit if not already present
            Let already_in_orbit be false
            For each orbit_element in orbit:
                If g_action equals orbit_element:
                    Set already_in_orbit to true
                    Break
            
            If not already_in_orbit:
                Add g_action to orbit
                Add g_action to to_process
    
    Note: Compute stabilizer of element
    Let stabilizer_elements be List[String]
    For each g in group.elements:
        Let g_action be action[g][element]
        If g_action equals element:
            Add g to stabilizer_elements
    
    Note: Verify orbit-stabilizer theorem
    Let orbit_size be orbit.size
    Let stabilizer_size be stabilizer_elements.size
    Let product be orbit_size * stabilizer_size
    
    Set result["orbit_size"] to Conversion.integer_to_string(orbit_size, null)
    Set result["stabilizer_size"] to Conversion.integer_to_string(stabilizer_size, null)
    Set result["group_order"] to Conversion.integer_to_string(group.order, null)
    Set result["theorem_verified"] to Conversion.boolean_to_string(product equals group.order)
    
    Return result

Process called "burnside_lemma" that takes group as Group, action as Dictionary[String, Dictionary[String, String]] returns Integer:
    Note: Count orbits using Burnside's lemma (Cauchy-Frobenius lemma)
    Note: Computes average number of fixed points over group elements
    
    Note: Extract the set being acted upon from action dictionary
    Let set_elements be List[String]
    For each g in group.elements:
        For each element in action[g].keys:
            Let already_present be false
            For each existing in set_elements:
                If element equals existing:
                    Set already_present to true
                    Break
            If not already_present:
                Add element to set_elements
        Break
    
    Note: Count fixed points for each group element
    Let total_fixed_points be 0
    
    For each g in group.elements:
        Let fixed_points be 0
        
        For each element in set_elements:
            Let g_action be action[g][element]
            If g_action equals element:
                Set fixed_points to fixed_points + 1
        
        Set total_fixed_points to total_fixed_points + fixed_points
    
    Note: Number of orbits = (1/|G|) * Σ |Fix(g)|
    Let num_orbits be total_fixed_points / group.order
    
    Return num_orbits

Process called "conjugation_action" that takes group as Group returns Dictionary[String, List[String]]:
    Note: Analyze conjugation action and conjugacy classes
    Note: Partitions group into conjugacy classes under inner automorphisms
    
    Let conjugacy_classes be Dictionary[String, List[String]]
    Let processed_elements be List[String]
    
    Note: For each element, compute its conjugacy class
    For each element in group.elements:
        Let already_processed be false
        For each processed in processed_elements:
            If element equals processed:
                Set already_processed to true
                Break
        
        If not already_processed:
            Let conjugacy_class be List[String]
            Add element to conjugacy_class
            
            Note: Compute all conjugates g·element·g⁻¹
            For each g in group.elements:
                Let g_inverse be compute_element_inverse(g, group)
                
                Note: Compute g·element·g⁻¹
                Let g_element be group.operation[g][element]
                Let conjugate be group.operation[g_element][g_inverse]
                
                Note: Add conjugate if not already in class
                Let already_in_class be false
                For each class_member in conjugacy_class:
                    If conjugate equals class_member:
                        Set already_in_class to true
                        Break
                
                If not already_in_class:
                    Add conjugate to conjugacy_class
            
            Note: Mark all elements in this class as processed
            For each class_member in conjugacy_class:
                Let already_processed_member be false
                For each processed in processed_elements:
                    If class_member equals processed:
                        Set already_processed_member to true
                        Break
                If not already_processed_member:
                    Add class_member to processed_elements
            
            Note: Use first element as class representative
            Set conjugacy_classes[element] to conjugacy_class
    
    Return conjugacy_classes

Note: =====================================================================
Note: GROUP CLASSIFICATION OPERATIONS
Note: =====================================================================

Process called "classify_small_groups" that takes order as Integer returns List[String]:
    Note: Classify all groups of given small order
    Note: Uses structure theorems and systematic enumeration methods
    
    Let classifications be List[String]
    
    Note: Handle special cases for small orders
    If order equals 1:
        Add "Trivial group" to classifications
        Return classifications
    
    If order equals 2:
        Add "Cyclic group C_2" to classifications
        Return classifications
    
    If order equals 3:
        Add "Cyclic group C_3" to classifications
        Return classifications
    
    If order equals 4:
        Add "Cyclic group C_4" to classifications
        Add "Klein four-group V_4" to classifications
        Return classifications
    
    If order equals 5:
        Add "Cyclic group C_5" to classifications
        Return classifications
    
    If order equals 6:
        Add "Cyclic group C_6" to classifications
        Add "Dihedral group D_3 (S_3)" to classifications
        Return classifications
    
    If order equals 8:
        Add "Cyclic group C_8" to classifications
        Add "C_4 × C_2" to classifications
        Add "C_2 × C_2 × C_2" to classifications
        Add "Dihedral group D_4" to classifications
        Add "Quaternion group Q_8" to classifications
        Return classifications
    
    Note: For larger orders, use general classification methods
    Note: Check if order is prime
    Let is_prime be true
    If order < 2:
        Set is_prime to false
    Otherwise:
        For i from 2 to order - 1:
            If order % i equals 0:
                Set is_prime to false
                Break
    
    If is_prime:
        Let prime_classification be "Cyclic group C_" + Conversion.integer_to_string(order, null)
        Add prime_classification to classifications
        Return classifications
    
    Note: For composite orders, provide general information
    Add "Multiple non-isomorphic groups exist" to classifications
    Add "Use structure theorems for complete classification" to classifications
    
    Return classifications

Process called "abelian_group_classification" that takes group as Group returns Dictionary[String, List[Integer]]:
    Note: Classify abelian group using fundamental theorem
    Note: Decomposes abelian group into cyclic factors
    
    Let classification be Dictionary[String, List[Integer]]
    Let primary_decomposition be List[Integer]
    let invariant_factors be List[Integer]
    
    Note: First check if group is abelian
    Let identity be find_group_identity(group)
    Let is_abelian be true
    
    For each a in group.elements:
        For each b in group.elements:
            Let ab be group.operation[a][b]
            Let ba be group.operation[b][a]
            If not ab equals ba:
                Set is_abelian to false
                Break
        If not is_abelian:
            Break
    
    If not is_abelian:
        Let error_list be List[Integer]
        Add 0 to error_list
        Set classification["error"] to error_list
        Return classification
    
    Note: For small abelian groups, use direct analysis
    Let order be group.order
    
    If order equals 1:
        Add 1 to invariant_factors
    Otherwise if order equals 2:
        Add 2 to invariant_factors
    Otherwise if order equals 3:
        Add 3 to invariant_factors
    Otherwise if order equals 4:
        Note: Either C_4 or C_2 × C_2
        Note: Check if there's an element of order 4
        Let has_order_4_element be false
        For each element in group.elements:
            Let element_order be compute_element_order(element, group)
            If element_order equals 4:
                Set has_order_4_element to true
                Break
        
        If has_order_4_element:
            Add 4 to invariant_factors
        Otherwise:
            Add 2 to invariant_factors
            Add 2 to invariant_factors
    Otherwise if order equals 6:
        Add 6 to invariant_factors
    Otherwise if order equals 8:
        Note: Determine structure among C_8, C_4×C_2, C_2×C_2×C_2
        Let max_element_order be 1
        For each element in group.elements:
            Let element_order be compute_element_order(element, group)
            If element_order > max_element_order:
                Set max_element_order to element_order
        
        If max_element_order equals 8:
            Add 8 to invariant_factors
        Otherwise if max_element_order equals 4:
            Add 4 to invariant_factors
            Add 2 to invariant_factors
        Otherwise:
            Add 2 to invariant_factors
            Add 2 to invariant_factors
            Add 2 to invariant_factors
    Otherwise:
        Note: For larger groups, provide partial classification
        Add order to invariant_factors
    
    Set classification["invariant_factors"] to invariant_factors
    Set classification["primary_decomposition"] to primary_decomposition
    
    Return classification

Process called "simple_group_recognition" that takes group as Group returns Boolean:
    Note: Recognize if group is simple using composition series
    Note: Checks for absence of proper normal subgroups
    
    Let order be group.order
    
    Note: Trivial group is not considered simple
    If order equals 1:
        Return false
    
    Note: Groups of prime order are simple
    Let is_prime be true
    If order < 2:
        Set is_prime to false
    Otherwise:
        For i from 2 to order - 1:
            If order % i equals 0:
                Set is_prime to false
                Break
    
    If is_prime:
        Return true
    
    Note: Find all proper normal subgroups
    Let all_subgroups be find_all_subgroups(group)
    
    For each subgroup in all_subgroups:
        Note: Skip trivial and full group
        If subgroup.order equals 1 or subgroup.order equals group.order:
            Continue
        
        Note: Check if subgroup is normal
        If test_normal_subgroup(subgroup, group):
            Note: Found proper normal subgroup, so not simple
            Return false
    
    Note: No proper normal subgroups found
    Return true

Process called "composition_series" that takes group as Group returns List[Subgroup]:
    Note: Compute composition series with simple quotients
    Note: Finds maximal normal series with simple composition factors
    
    Let composition_series be List[Subgroup]
    
    Note: Start with the full group
    Let current_group be group
    Add current_group to composition_series
    
    Note: Iteratively find maximal proper normal subgroups
    Let max_iterations be 20
    Let iteration be 0
    
    While iteration < max_iterations and current_group.order > 1:
        Set iteration to iteration + 1
        
        Note: Find all proper normal subgroups of current group
        Let all_subgroups be find_all_subgroups(current_group)
        Let normal_subgroups be List[Subgroup]
        
        For each subgroup in all_subgroups:
            If subgroup.order < current_group.order and subgroup.order > 1:
                If test_normal_subgroup(subgroup, current_group):
                    Add subgroup to normal_subgroups
        
        Note: Find maximal normal subgroup (largest proper normal subgroup)
        Let maximal_normal be Subgroup
        Let max_order be 0
        
        For each normal_subgroup in normal_subgroups:
            If normal_subgroup.order > max_order:
                Set max_order to normal_subgroup.order
                Set maximal_normal to normal_subgroup
        
        Note: If no proper normal subgroups, current factor is simple
        If max_order equals 0:
            Break
        
        Add maximal_normal to composition_series
        Set current_group to maximal_normal
    
    Note: Add trivial group at the end
    Let trivial_group be Subgroup
    Let trivial_elements be List[String]
    Let identity be find_group_identity(group)
    Add identity to trivial_elements
    Set trivial_group.elements to trivial_elements
    Set trivial_group.order to 1
    Add trivial_group to composition_series
    
    Return composition_series

Process called "jordan_holder_theorem" that takes group as Group returns Dictionary[String, List[String]]:
    Note: Apply Jordan-Hölder theorem for composition series uniqueness
    Note: Shows composition factors are unique up to isomorphism and order
    
    Let result be Dictionary[String, List[String]]
    Let composition_factors be List[String]
    
    Note: Compute composition series
    Let comp_series be composition_series(group)
    
    Note: Extract composition factors (quotient groups G_i/G_{i+1})
    For i from 0 to comp_series.size - 2:
        Let G_i be comp_series[i]
        Let G_i_plus_1 be comp_series[i + 1]
        
        Note: Compute quotient order |G_i| / |G_{i+1}|
        Let quotient_order be G_i.order / G_i_plus_1.order
        
        Note: Classify simple quotient factor
        Let factor_description be ""
        
        If quotient_order equals 2:
            Set factor_description to "C_2"
        Otherwise if quotient_order equals 3:
            Set factor_description to "C_3"
        Otherwise if quotient_order equals 5:
            Set factor_description to "C_5"
        Otherwise if quotient_order equals 7:
            Set factor_description to "C_7"
        Otherwise:
            Note: Check if quotient order is prime
            Let is_prime be true
            If quotient_order < 2:
                Set is_prime to false
            Otherwise:
                For j from 2 to quotient_order - 1:
                    If quotient_order % j equals 0:
                        Set is_prime to false
                        Break
            
            If is_prime:
                Set factor_description to "C_" + Conversion.integer_to_string(quotient_order, null)
            Otherwise:
                Set factor_description to "Simple group of order " + Conversion.integer_to_string(quotient_order, null)
        
        Add factor_description to composition_factors
    
    Set result["composition_factors"] to composition_factors
    
    Note: Jordan-Hölder theorem statement
    Let theorem_statement be List[String]
    Add "All composition series have the same length" to theorem_statement
    Add "Composition factors are unique up to isomorphism and order" to theorem_statement
    Add "This provides a complete invariant for finite groups" to theorem_statement
    
    Set result["theorem_statement"] to theorem_statement
    
    Return result