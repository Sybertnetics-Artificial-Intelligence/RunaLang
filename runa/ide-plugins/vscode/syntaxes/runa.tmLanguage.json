{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Runa",
  "scopeName": "source.runa",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#types"
    },
    {
      "include": "#annotations"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.runa",
          "match": "#.*$"
        },
        {
          "name": "comment.block.runa",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": {
              "name": "punctuation.definition.comment.runa"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.runa",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.runa",
              "match": "\\\\."
            },
            {
              "name": "constant.other.placeholder.runa",
              "match": "\\{[^}]*\\}"
            }
          ]
        },
        {
          "name": "string.quoted.single.runa",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.runa",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.runa",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.runa",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.runa",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.runa",
          "match": "\\b0[oO][0-7]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.runa",
          "match": "\\b(if|else|for|while|do|break|continue|return|match|case|when|try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.declaration.runa",
          "match": "\\b(let|define|function|process|module|import|export|from|as)\\b"
        },
        {
          "name": "keyword.operator.logical.runa",
          "match": "\\b(and|or|not|is|in)\\b"
        },
        {
          "name": "keyword.other.runa",
          "match": "\\b(async|await|send|receive|atomic|lock|unlock|delete|own|shared|borrowed|end)\\b"
        },
        {
          "name": "constant.language.runa",
          "match": "\\b(true|false|null|undefined)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.runa",
          "match": "=|\\+=|-=|\\*=|/=|%=|\\^="
        },
        {
          "name": "keyword.operator.arithmetic.runa",
          "match": "\\+|-|\\*|/|%|\\^"
        },
        {
          "name": "keyword.operator.comparison.runa",
          "match": "==|!=|<|<=|>|>=|<>"
        },
        {
          "name": "keyword.operator.logical.runa",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.runa",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.other.runa",
          "match": "\\?|:|\\.|->|=>"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.runa",
          "match": "\\b(function|define)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.runa"
            },
            "2": {
              "name": "entity.name.function.runa"
            }
          }
        },
        {
          "name": "support.function.builtin.runa",
          "match": "\\b(print|input|length|type|convert|parse|format|range|enumerate|zip|map|filter|reduce|sort|reverse|split|join|replace|contains|starts_with|ends_with|uppercase|lowercase|trim)\\b"
        },
        {
          "name": "entity.name.function.call.runa",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.declaration.runa",
          "match": "\\b(let)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.runa"
            },
            "2": {
              "name": "variable.other.declaration.runa"
            }
          }
        },
        {
          "name": "variable.other.runa",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.runa",
          "match": "\\b(number|string|boolean|list|dictionary|function|any|void)\\b"
        },
        {
          "name": "storage.type.advanced.runa",
          "match": "\\b(optional|union|intersection)\\b"
        },
        {
          "name": "storage.type.user.runa",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.modifier.annotation.runa",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*",
          "captures": {
            "0": {
              "name": "storage.modifier.annotation.runa"
            }
          }
        }
      ]
    }
  }
}