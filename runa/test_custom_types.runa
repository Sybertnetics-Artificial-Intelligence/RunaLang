Display "Testing Custom Types and Enums:"

Type called "User":
    name as String
    age as Integer
    email as String
    is active as Boolean

Type called "Product":
    title as String
    price as Float
    category as String
    in stock as Boolean

Enum called "UserStatus":
    Active
    Inactive
    Suspended
    Pending

Enum called "OrderStatus":
    Draft
    Submitted
    Processing
    Shipped
    Delivered
    Cancelled

Enum called "Priority":
    Low
    Medium
    High
    Critical

Display "Type definitions created successfully!"

Display "Custom types and enums allow for:"
Display "- Structured data with named fields"
Display "- Type safety and validation"
Display "- Clear enumeration of possible values"
Display "- Better code organization and readability"

Display "Examples of usage:"
Display "Let user be User with name as \"Alice\", age as 25, email as \"alice@example.com\", is active as true"
Display "Let status be UserStatus Active"
Display "Let order status be OrderStatus Processing"

Display "Custom types test completed!"