"""
Advanced Runa test for enhanced bootstrap runner validation
"""

# Test complex collections
Let instructions be list containing "LOAD", "ADD", "STORE", "RETURN"
Let i be 2
Let prev_instruction be instructions at index i minus 1

Display "Array indexing test - previous instruction:" followed by prev_instruction

# Test nested dictionary access
Let vm_config be dictionary with:
    optimization_levels as dictionary with:
        0 as "basic"
        1 as "intermediate" 
        2 as "advanced"
    hot_threshold as 10

Let optimization_level be 1
Let optimization_name be vm_config at key "optimization_levels" at key optimization_level

Display "Dictionary access test - optimization:" followed by optimization_name

# Test for-each with index
For each instruction with index idx in instructions:
    Display "Instruction" followed by idx followed by ":" followed by instruction

Display "Advanced bootstrap validation complete!" 