    confidence_score as Float
    execution_time as Integer
    resource_usage as ResourceUsage
    warnings as List[VerificationWarning]
    evidence as List[VerificationEvidence]
    recommendations as List[String]
    created_at as DateTime.DateTime
    verifier_info as VerifierInfo

Type called "VerificationOutcome":
