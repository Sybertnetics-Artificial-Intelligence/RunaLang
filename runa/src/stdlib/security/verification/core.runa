    target as VerificationTarget
    properties as List[VerificationProperty]
    constraints as List[VerificationConstraint]
    proof_requirements as ProofRequirements
    priority as String
    deadline as Optional[DateTime.DateTime]
    requester as String
    context as VerificationContext
    created_at as DateTime.DateTime
    status as VerificationStatus

Type called "VerificationTarget":
    target_id as String
    target_type as String
