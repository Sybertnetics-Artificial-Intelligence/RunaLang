    status as JobStatus
    start_time as DateTime.DateTime
    end_time as Optional[DateTime.DateTime]
    timeout as Integer
    priority as JobPriority
    result as Optional[ProverResult]
    error_info as Optional[ErrorInfo]
    resource_usage as ResourceUsage
    checkpoints as List[JobCheckpoint]

Type called "JobStatus":
    QUEUED
    TRANSLATING
    SUBMITTED
    RUNNING
    COMPLETED
    FAILED
    TIMEOUT
    CANCELLED
    PAUSED
    RESUMED

Type called "JobPriority":
    CRITICAL
    HIGH
    NORMAL
    LOW
    BACKGROUND

Type called "TranslatedInput":
    translation_id as String
    original_format as String
    target_format as String
