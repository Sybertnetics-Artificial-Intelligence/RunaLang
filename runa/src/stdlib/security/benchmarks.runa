Process called "find_benchmark_by_id" that takes suite as BenchmarkSuite and benchmark_id as String returns Optional[SecurityBenchmark]:
    For each benchmark in suite.benchmarks:
        If benchmark.benchmark_id is equal to benchmark_id:
            Return benchmark
    Return None

Process called "clear_benchmark_results" that takes suite as BenchmarkSuite:
    Set suite.results to list containing
    Set suite.statistics to create_empty_benchmark_statistics()

Process called "update_benchmark_statistics" that takes suite as BenchmarkSuite and result as BenchmarkResult:
    If result.status is equal to Passed:
        Set suite.statistics.passed_benchmarks to suite.statistics.passed_benchmarks + 1
    Otherwise:
        Set suite.statistics.failed_benchmarks to suite.statistics.failed_benchmarks + 1
    Set suite.statistics.average_performance_score to calculate_average_performance_score with results as suite.results

Process called "validate_benchmark_result" that takes result as BenchmarkResult and threshold as PerformanceThreshold returns Boolean:
    Return result.throughput >= threshold.min_throughput and
        result.latency_stats.mean_ms <= threshold.max_latency_ms and
        result.resource_usage.peak_memory_mb <= threshold.max_memory_mb and
        result.success_rate >= threshold.min_success_rate

Process called "calculate_mean" that takes values as List[Float] returns Float:
    If Collections.List.is_empty with lst as values:
        Return 0.0
    Let sum be 0.0
    For each value in values:
        Set sum to sum + value
    Return sum / Collections.List.length with lst as values

Process called "calculate_percentile" that takes values as List[Float] and percentile as Float returns Float:
    Let sorted_values be Collections.List.sort with lst as values
    Let count be Collections.List.length with lst as sorted_values
    If count is equal to 0:
        Return 0.0
    Let index be Math.floor with value as (percentile / 100.0) * (count - 1)
    Let int_index be Math.to_int with value as index
    If int_index >= count - 1:
        Return sorted_values at index (count - 1)
    Return sorted_values at index int_index

Process called "calculate_standard_deviation" that takes values as List[Float] and mean as Float returns Float:
    If Collections.List.is_empty with lst as values:
        Return 0.0
    Let variance_sum be 0.0
    For each value in values:
        Let difference be value - mean
        Set variance_sum to variance_sum + (difference * difference)
    Let variance be variance_sum / Collections.List.length with lst as values
    Return Math.sqrt with value as variance

Process called "calculate_average_performance_score" that takes results as List[BenchmarkResult] returns Float:
    If Collections.List.is_empty with lst as results:
        Return 0.0
    Let sum_score be 0.0
    For each result in results:
        Set sum_score to sum_score + result.performance_score
    Return sum_score / Collections.List.length with lst as results

