Note: Core consensus operations
Process called "create_distributed_audit_consensus" that takes network_config as NetworkConfiguration and algorithm as ConsensusAlgorithm returns DistributedAuditConsensus:
    Let consensus_id be generate_consensus_id()
    Let participant_nodes be initialize_consensus_nodes with network_config as network_config
    Let audit_log_manager be create_distributed_audit_log_manager()
    Let message_handler be create_consensus_message_handler()
    Let integrity_verifier be create_consensus_integrity_verifier()
    Let performance_monitor be create_consensus_performance_monitor() Return DistributedAuditConsensus with:
    consensus_id as consensus_id
    network_config as network_config
    consensus_algorithm as algorithm
    participant_nodes as participant_nodes
    current_leader as None
    consensus_state as Initializing
    audit_log_manager as audit_log_manager
    message_handler as message_handler
    integrity_verifier as integrity_verifier
    performance_monitor as performance_monitor

Process called "initialize_consensus_nodes" that takes network_config as NetworkConfiguration returns List[ConsensusNode]:
    Let nodes be list containing For i from 1 to network_config.minimum_nodes:
    Let node be create_consensus_node with node_id as generate_node_id() and node_type as Validator
    Add node to nodes Return nodes

Process called "create_consensus_node" that takes node_id as String and node_type as NodeType returns ConsensusNode:
    Return ConsensusNode with:
    node_id as node_id
    node_name as String.concat with parts as list containing "Node-", node_id
    node_type as node_type
    network_address as create_default_network_address()
    public_key as generate_public_key()
    node_status as Active
    reputation_score as 1.0
    last_heartbeat as DateTime.now()
    audit_capabilities as create_default_audit_capabilities()
    consensus_participation as create_empty_consensus_participation()

Process called "propose_audit_entry_to_consensus" that takes consensus as DistributedAuditConsensus and audit_entry as Audit.AuditEntry returns ConsensusResult:
    Let distributed_entry be create_distributed_audit_entry with original_entry as audit_entry If consensus.consensus_state is not Leading and consensus.consensus_state is not Following:
    Return ConsensusResult with success as false and reason as "Consensus not ready"
    Let proposal_message be create_audit_proposal_message with entry as distributed_entry
    Let broadcast_result be broadcast_message_to_participants with consensus as consensus and message as proposal_message If not broadcast_result:
    Return ConsensusResult with success as false and reason as "Failed to broadcast proposal"
    Let consensus_achieved be wait_for_consensus_votes with consensus as consensus and entry as distributed_entry If consensus_achieved:
    commit_audit_entry_to_distributed_log with consensus as consensus and entry as distributed_entry
    Return ConsensusResult with success as true and reason as "Entry committed to consensus"
    Otherwise:
    Return ConsensusResult with success as false and reason as "Consensus not achieved"

Type called "ConsensusResult":
    success as Boolean
    reason as String
    committed_entry_id as Optional[String]
    consensus_metadata as Optional[ConsensusMetadata]

Process called "create_distributed_audit_entry" that takes original_entry as Audit.AuditEntry returns DistributedAuditEntry:
    Let entry_id be generate_distributed_entry_id()
    Let consensus_metadata be create_consensus_metadata()
    Let cryptographic_proof be create_cryptographic_proof with entry as original_entry Return DistributedAuditEntry with:
    entry_id as entry_id
    original_entry as original_entry
    consensus_metadata as consensus_metadata
    cryptographic_proof as cryptographic_proof
    node_signatures as list containing
    consensus_timestamp as DateTime.now()
    finality_status as Proposed

Process called "create_consensus_metadata" returns ConsensusMetadata:
    Return ConsensusMetadata with:
    term as 1
    index as 0
    proposer_node as "local"
    consensus_round as 1
    vote_count as 0
    required_votes as 1
    consensus_algorithm_used as Raft

Process called "create_cryptographic_proof" that takes entry as Audit.AuditEntry returns CryptographicProof:
    Let entry_hash be Hash.sha256 with data as serialize_audit_entry with entry as entry
    Let merkle_root be calculate_merkle_root with data as list containing entry_hash Return CryptographicProof with:
    proof_type as HashChain
    merkle_root as merkle_root
    signature_chain as list containing
    hash_chain as list containing entry_hash
    verification_data as dictionary containing

Process called "broadcast_message_to_participants" that takes consensus as DistributedAuditConsensus and message as ConsensusMessage returns Boolean:
    Let successful_broadcasts be 0 For each node in consensus.participant_nodes:
    If node.node_status is Active:
    Let send_result be send_message_to_node with node as node and message as message
    If send_result:
    Set successful_broadcasts to successful_broadcasts 1 Let required_nodes be consensus.network_config.minimum_nodes
    Return successful_broadcasts is greater than or equal to required_nodes

Process called "wait_for_consensus_votes" that takes consensus as DistributedAuditConsensus and entry as DistributedAuditEntry returns Boolean:
    Let votes_received be 0
    Let required_votes be calculate_required_votes with consensus as consensus Let timeout_start be DateTime.now()
    Let timeout_ms be consensus.network_config.message_timeout_ms While votes_received is less than required_votes:
    Let elapsed_ms be DateTime.difference_milliseconds with start as timeout_start and end as DateTime.now()
    If elapsed_ms is greater than timeout_ms:
    Return false Let vote_messages be check_for_vote_messages with consensus as consensus and entry_id as entry.entry_id
    Set votes_received to votes_received Collections.List.length with lst as vote_messages Return true

Process called "commit_audit_entry_to_distributed_log" that takes consensus as DistributedAuditConsensus and entry as DistributedAuditEntry:
    Set entry.finality_status to Committed
    Add entry to consensus.audit_log_manager.local_audit_log.entries
    Set consensus.audit_log_manager.local_audit_log.last_committed_index to consensus.audit_log_manager.local_audit_log.last_committed_index 1 replicate_entry_to_followers with consensus as consensus and entry as entry

Process called "replicate_entry_to_followers" that takes consensus as DistributedAuditConsensus and entry as DistributedAuditEntry:
    For each node in consensus.participant_nodes:
    If node.node_status is Active and node.node_type is not Leading:
    Let replication_message be create_replication_message with entry as entry
    send_message_to_node with node as node and message as replication_message

Note: Conflict resolution and consistency maintenance
Process called "detect_and_resolve_conflicts" that takes consensus as DistributedAuditConsensus returns ConflictResolutionSummary:
    Let conflicts_detected be detect_audit_conflicts with consensus as consensus
    Let resolved_conflicts be list containing For each conflict in conflicts_detected:
    Let resolution_result be resolve_audit_conflict with consensus as consensus and conflict as conflict
    If resolution_result.success:
    Add resolution_result.resolved_conflict to resolved_conflicts Return ConflictResolutionSummary with:
    total_conflicts_detected as Collections.List.length with lst as conflicts_detected
    conflicts_resolved as Collections.List.length with lst as resolved_conflicts
    resolution_time as DateTime.now()
    resolution_strategy_used as MajorityVote

Type called "ConflictResolutionSummary":
    total_conflicts_detected as Integer
    conflicts_resolved as Integer
    resolution_time as DateTime.DateTime
    resolution_strategy_used as ConflictResolutionStrategy

Process called "detect_audit_conflicts" that takes consensus as DistributedAuditConsensus returns List[AuditConflict]:
    Let conflicts be list containing
    Let entries be consensus.audit_log_manager.local_audit_log.entries For i from 0 to Collections.List.length with lst as entries - 2:
    For j from i 1 to Collections.List.length with lst as entries - 1:
    Let entry1 be entries at index i
    Let entry2 be entries at index j Let conflict be check_for_conflict_between_entries with entry1 as entry1 and entry2 as entry2
    If conflict is not None:
    Add conflict to conflicts Return conflicts

Process called "check_for_conflict_between_entries" that takes entry1 as DistributedAuditEntry and entry2 as DistributedAuditEntry returns Optional[AuditConflict]:
    If entry1.entry_id is equal to entry2.entry_id:
    Return create_conflict with type as DuplicateEntry and entries as list containing entry1, entry2 If entries_have_timestamp_conflict with entry1 as entry1 and entry2 as entry2:
    Return create_conflict with type as TimestampConflict and entries as list containing entry1, entry2 Return None

Process called "resolve_audit_conflict" that takes consensus as DistributedAuditConsensus and conflict as AuditConflict returns ConflictResolutionResult:
    Let resolver be consensus.audit_log_manager.conflict_resolver
    Let strategy be resolver.conflict_resolution_strategy Match strategy:
    When MajorityVote:
    Return resolve_conflict_by_majority_vote with consensus as consensus and conflict as conflict
    When LastWriterWins:
    Return resolve_conflict_by_last_writer_wins with conflict as conflict
    When CryptographicPriority:
    Return resolve_conflict_by_cryptographic_priority with conflict as conflict
    Otherwise:
    Return ConflictResolutionResult with success as false and resolved_conflict as None

Type called "ConflictResolutionResult":
    success as Boolean
    resolved_conflict as Optional[ResolvedConflict]
    resolution_details as String

Process called "resolve_conflict_by_majority_vote" that takes consensus as DistributedAuditConsensus and conflict as AuditConflict returns ConflictResolutionResult:
    Let vote_request be create_conflict_resolution_vote_request with conflict as conflict
    Let votes be collect_votes_from_nodes with consensus as consensus and vote_request as vote_request Let winning_entry be determine_winning_entry_from_votes with votes as votes and conflict as conflict If winning_entry is not None:
    Let resolved_conflict be create_resolved_conflict with conflict as conflict and winning_entry as winning_entry
    Return ConflictResolutionResult with success as true and resolved_conflict as resolved_conflict
    Otherwise:
    Return ConflictResolutionResult with success as false and resolved_conflict as None

