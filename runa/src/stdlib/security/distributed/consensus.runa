Process called "resolve_conflict_by_last_writer_wins" that takes conflict as AuditConflict returns ConflictResolutionResult:
    Let latest_entry be find_latest_entry with entries as conflict.conflicting_entries
    Let resolved_conflict be create_resolved_conflict with conflict as conflict and winning_entry as latest_entry Return ConflictResolutionResult with:
    success as true
    resolved_conflict as resolved_conflict
    resolution_details as "Resolved using last writer wins strategy"

Process called "resolve_conflict_by_cryptographic_priority" that takes conflict as AuditConflict returns ConflictResolutionResult:
    Let highest_priority_entry be find_highest_cryptographic_priority_entry with entries as conflict.conflicting_entries
    Let resolved_conflict be create_resolved_conflict with conflict as conflict and winning_entry as highest_priority_entry Return ConflictResolutionResult with:
    success as true
    resolved_conflict as resolved_conflict
    resolution_details as "Resolved using cryptographic priority"

Process called "find_latest_entry" that takes entries as List[DistributedAuditEntry] returns DistributedAuditEntry:
    If Collections.List.is_empty with lst as entries:
    Return entries at index 0 Let latest_entry be entries at index 0
    For each entry in entries:
    If DateTime.is_after with time1 as entry.consensus_timestamp and time2 as latest_entry.consensus_timestamp:
    Set latest_entry to entry Return latest_entry

Process called "find_highest_cryptographic_priority_entry" that takes entries as List[DistributedAuditEntry] returns DistributedAuditEntry:
    If Collections.List.is_empty with lst as entries:
    Return entries at index 0 Return entries at index 0

Process called "create_resolved_conflict" that takes conflict as AuditConflict and winning_entry as DistributedAuditEntry returns ResolvedConflict:
    Let rejected_entries be list containing
    For each entry in conflict.conflicting_entries:
    If entry.entry_id is not equal to winning_entry.entry_id:
    Add entry to rejected_entries Return ResolvedConflict with:
    conflict_id as conflict.conflict_id
    resolution_strategy_used as MajorityVote
    winning_entry as winning_entry
    rejected_entries as rejected_entries
    resolution_time as DateTime.now()
    confidence_score as 0.95

