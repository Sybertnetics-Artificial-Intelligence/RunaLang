    geo_restrictions as Optional[GeoRestriction]
    ai_analysis_required as Boolean
    constitutional_check_required as Boolean
    created_at as DateTime.DateTime
    last_matched as Optional[DateTime.DateTime]
    match_count as Integer
    effectiveness_score as Float

Type called "RuleCondition":
    condition_id as String
    condition_type as ConditionType
    field as String
    operator as ConditionOperator
    value as String
    case_sensitive as Boolean
    regex_enabled as Boolean
    ai_enhanced as Boolean
    negate as Boolean

Type ConditionType is:
    | SOURCE_IP
    | DESTINATION_IP
    | SOURCE_PORT
    | DESTINATION_PORT
    | PROTOCOL
    | HTTP_METHOD
    | HTTP_HEADER
    | HTTP_BODY
    | URL_PATH
    | USER_AGENT
    | CONTENT_TYPE
    | PAYLOAD_SIZE
    | REQUEST_RATE
    | AI_CONTENT_CLASSIFICATION
    | AI_INTENT_ANALYSIS
    | CONSTITUTIONAL_COMPLIANCE
    | THREAT_SCORE
    | BEHAVIORAL_PATTERN

Type ConditionOperator is:
    | EQUALS
    | NOT_EQUALS
    | CONTAINS
    | NOT_CONTAINS
    | STARTS_WITH
    | ENDS_WITH
    | MATCHES_REGEX
    | IN_RANGE
    | GREATER_THAN
    | LESS_THAN
    | IP_IN_SUBNET
    | GEO_IN_REGION
    | AI_CLASSIFIED_AS
    | THREAT_LEVEL_ABOVE

