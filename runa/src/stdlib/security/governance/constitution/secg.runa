Note: Utility and helper functions
Process called "generate_unique_id" that takes prefix as String returns String:
    Let timestamp be DateTime.now_milliseconds()
    Let random_part be Math.random_int with min as 1000 and max as 9999
    Return String.concat with parts as list containing prefix, "-", timestamp, "-", random_part

Process called "create_universal_applicability" returns ApplicabilityRule:
    Return ApplicabilityRule with:
    rule_id as generate_unique_id with prefix as "APPL"
    condition as ApplicabilityCondition with condition_type as TechnicalCondition and parameters as dictionary containing and evaluation_logic as "always_true" and context_requirements as list containing
    exceptions as list containing
    override_authority as list containing "ConstitutionalCouncil"

Process called "create_contextual_applicability" returns ApplicabilityRule:
    Return ApplicabilityRule with:
    rule_id as generate_unique_id with prefix as "APPL"
    condition as ApplicabilityCondition with condition_type as RiskLevelCondition and parameters as dictionary containing "min_risk_level": "medium" and evaluation_logic as "risk_based" and context_requirements as list containing "high-stakes-decisions"
    exceptions as list containing
    override_authority as list containing "EthicsCommittee"

Process called "create_legal_reference" that takes jurisdiction as String and law_type as LawType and citation as String and description as String returns LegalReference:
    Return LegalReference with:
    jurisdiction as jurisdiction
    law_type as law_type
    citation as citation
    description as description
    compliance_level as Mandatory

