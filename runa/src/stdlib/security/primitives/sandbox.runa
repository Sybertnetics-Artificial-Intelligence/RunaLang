Note: High-level sandbox management API
Process called "create_default_sandbox_config" that takes isolation_level as IsolationLevel returns SandboxConfig:
    Let resource_limits be create_default_resource_limits with level as isolation_level
    Let allowed_caps be get_default_capabilities with level as isolation_level
    Let fs_config be create_default_fs_config with level as isolation_level
    Let net_config be create_default_network_config with level as isolation_level Return SandboxConfig with:
    isolation_level as isolation_level
    resource_limits as resource_limits
    allowed_capabilities as allowed_caps
    denied_capabilities as list containing
    file_system_config as fs_config
    network_config as net_config
    security_policies as list containing
    monitoring_enabled as true
    auto_destroy as false
    max_runtime as None

Process called "create_default_resource_limits" that takes level as IsolationLevel returns ResourceLimits:
    Match level:
    When Minimal:
    Return create_minimal_resource_limits()
    When Standard:
    Return create_standard_resource_limits()
    When Strict:
    Return create_strict_resource_limits()
    When Maximum:
    Return create_maximum_resource_limits()
    Otherwise:
    Return create_standard_resource_limits()

Process called "create_standard_resource_limits" returns ResourceLimits:
    Return ResourceLimits with:
    cpu_limit as CPULimit with max_cpu_percent as 50.0 and cpu_cores as None and priority as 0 and scheduling_policy as Normal
    memory_limit as MemoryLimit with max_memory_bytes as 536870912 and max_swap_bytes as 1073741824 and memory_pressure_threshold as 0.8 and oom_kill_disable as false
    disk_limit as DiskLimit with max_disk_usage as 2147483648 and max_inodes as 10000 and allowed_paths as list containing "/" and denied_paths as list containing and read_rate_limit as None and write_rate_limit as None
    network_limit as NetworkLimit with max_bandwidth_in as None and max_bandwidth_out as None and max_connections as 100 and allowed_ports as list containing and denied_ports as list containing and allowed_hosts as list containing and denied_hosts as list containing
    file_descriptor_limit as 1024
    process_limit as 50
    thread_limit as 200
    execution_time_limit as None

Process called "get_default_capabilities" that takes level as IsolationLevel returns List[Capability]:
    Match level:
    When Minimal:
    Return list containing
    When Standard:
    Return list containing CHOWN, DAC_OVERRIDE, FOWNER, FSETID, KILL, SETGID, SETUID
    When Strict:
    Return list containing KILL, SETGID, SETUID
    When Maximum:
    Return list containing
    Otherwise:
    Return list containing CHOWN, DAC_OVERRIDE, FOWNER, FSETID, KILL, SETGID, SETUID

Process called "create_default_fs_config" that takes level as IsolationLevel returns FileSystemConfig:
    Return FileSystemConfig with:
    root_directory as "/var/lib/runa-sandbox"
    overlay_mounts as list containing
    bind_mounts as list containing
    tmpfs_mounts as list containing
    read_only_paths as list containing "/usr", "/lib", "/lib64"
    hidden_paths as list containing "/proc/kcore", "/proc/keys"
    device_access as create_default_device_access with level as level

Process called "create_default_network_config" returns NetworkConfig:
    Return NetworkConfig with:
    virtual_interfaces as list containing
    routing_rules as list containing
    firewall_rules as list containing
    dns_config as DNSConfig with nameservers as list containing "8.8.8.8", "8.8.4.4" and search_domains as list containing and options as dictionary containing
    proxy_config as None

Process called "create_default_device_access" that takes level as IsolationLevel returns DeviceAccess:
    Return DeviceAccess with:
    allowed_devices as list containing
    denied_devices as list containing
    device_cgroup_rules as list containing

Note: Additional helper functions
Process called "create_minimal_resource_limits" returns ResourceLimits:
    Return create_standard_resource_limits()

Process called "create_strict_resource_limits" returns ResourceLimits:
    Let standard_limits be create_standard_resource_limits() Set standard_limits.cpu_limit.max_cpu_percent to 25.0
    Set standard_limits.memory_limit.max_memory_bytes to 268435456
    Set standard_limits.process_limit to 20
    Set standard_limits.thread_limit to 50 Return standard_limits

Process called "create_maximum_resource_limits" returns ResourceLimits:
    Let standard_limits be create_standard_resource_limits() Set standard_limits.cpu_limit.max_cpu_percent to 10.0
    Set standard_limits.memory_limit.max_memory_bytes to 134217728
    Set standard_limits.process_limit to 10
    Set standard_limits.thread_limit to 20 Return standard_limits