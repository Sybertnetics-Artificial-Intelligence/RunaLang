Process called "quote_csv_field" that takes field as String returns String:
    If String.contains with str as field and substring as "," or String.contains with str as field and substring as "\"":
    Let escaped_field be String.replace with str as field and old as "\"" and new as "\"\""
    Return String.concat with parts as list containing "\"", escaped_field, "\""
    Return field

Process called "calculate_syslog_priority" that takes severity as SeverityLevel returns Integer:
    Match severity:
    When Critical:
    Return 130
    When High:
    Return 131
    When Medium:
    Return 132
    When Low:
    Return 133
    When Informational:
    Return 134
    Otherwise:
    Return 134

