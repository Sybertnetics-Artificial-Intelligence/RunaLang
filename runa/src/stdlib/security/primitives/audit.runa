Note:
Runa Security Library: Audit and Compliance Module

Production-ready audit trail system surpassing enterprise security frameworks.
Provides comprehensive logging, compliance tracking, and forensic analysis
capabilities exceeding those found in Java's security framework, .NET's
auditing, and Python's logging libraries.

Features:
- Tamper-proof audit trails with cryptographic integrity
- Real-time compliance monitoring and violation detection
- High-performance structured logging with minimal overhead
- Advanced forensic analysis and query capabilities
- Multi-format export (SIEM, JSON, XML, regulatory formats)
- Automatic PII detection and redaction
- Distributed audit log aggregation and correlation
- Performance metrics and system health monitoring
:End Note

Import "crypto/hash" as Hash
Import "crypto/signatures" as Signatures
Import "datetime" as DateTime
Import "collections" as Collections
Import "string" as String
Import "math/core" as Math

Note: Core audit data structures
Type called "AuditEntry":
    entry_id as String
    timestamp as DateTime.DateTime
    event_type as EventType
    severity as SeverityLevel
    actor as Actor
    target as Target
    action as String
    result as ActionResult
    context as AuditContext
    metadata as Dictionary[String, Any]
    checksum as String

Type EventType is:
    | Authentication
    | Authorization
    | DataAccess
    | DataModification
    | SystemChange
    | SecurityViolation
    | ComplianceEvent
    | PerformanceEvent
    | ErrorEvent
    | CustomEvent

Type SeverityLevel is:
    | Critical
    | High
    | Medium
    | Low
    | Informational

Type called "Actor":
    actor_id as String
    actor_type as ActorType
    name as String
    roles as List[String]
    session_id as Optional[String]
    source_ip as Optional[String]
    user_agent as Optional[String]

Type ActorType is:
    | Human
    | System
    | Service
    | Anonymous
    | Automated

Type called "Target":
    target_id as String
    target_type as TargetType
    name as String
    classification as ClassificationLevel
    owner as String
    location as String

Type TargetType is:
    | File
    | Database
    | Service
    | Configuration
    | Secret
    | Network
    | Process

Type ClassificationLevel is:
    | Unclassified
    | Internal
    | Confidential
    | Restricted
    | TopSecret

Type ActionResult is:
    | Success
    | Failure
    | Partial
    | Blocked
    | Timeout

Type called "AuditContext":
    request_id as String
    correlation_id as String
    process_id as Integer
    thread_id as Integer
    environment as String
    application as String
    version as String

Type called "AuditLogger":
    logger_id as String
    config as AuditConfig
    storage as AuditStorage
    filters as List[AuditFilter]
    formatters as List[AuditFormatter]
    handlers as List[AuditHandler]
    metrics as AuditMetrics
    integrity_provider as IntegrityProvider

Type called "AuditConfig":
    retention_days as Integer
    max_file_size as Integer
    compression_enabled as Boolean
    encryption_enabled as Boolean
    real_time_monitoring as Boolean
    performance_tracking as Boolean
    pii_redaction_enabled as Boolean
    tamper_detection as Boolean

Type called "AuditStorage":
    storage_type as StorageType
    connection_string as String
    encryption_key as Optional[String]
    backup_enabled as Boolean
    replication_enabled as Boolean

Type StorageType is:
    | FileSystem
    | Database
    | CloudStorage
    | MessageQueue
    | SIEM

Type called "AuditFilter":
    filter_id as String
    filter_type as FilterType
    criteria as FilterCriteria
    enabled as Boolean

Type FilterType is:
    | IncludeFilter
    | ExcludeFilter
    | SeverityFilter
    | ActorFilter
    | TargetFilter

Type called "FilterCriteria":
    field as String
    operator as FilterOperator
    value as Any
    case_sensitive as Boolean

Type FilterOperator is:
    | Equals
    | NotEquals
    | Contains
    | StartsWith
    | EndsWith
    | GreaterThan
    | LessThan
    | InList
    | Matches

Type called "AuditFormatter":
    formatter_id as String
    format_type as FormatType
    template as String
    include_fields as List[String]
    exclude_fields as List[String]

Type FormatType is:
    | JSON
    | XML
    | CSV
    | Syslog
    | CEF
    | LEEF
    | Custom

Type called "AuditHandler":
    handler_id as String
    handler_type as HandlerType
    destination as String
    batch_size as Integer
    flush_interval as Integer
    retry_policy as RetryPolicy

Type HandlerType is:
    | FileHandler
    | DatabaseHandler
    | NetworkHandler
    | SyslogHandler
    | EmailHandler
    | WebhookHandler

Type called "RetryPolicy":
    max_retries as Integer
    initial_delay as Integer
    backoff_multiplier as Float
    max_delay as Integer

Type called "AuditMetrics":
    total_events as Integer
    events_per_second as Float
    storage_usage as Integer
    errors_count as Integer
    last_flush_time as DateTime.DateTime
    performance_stats as PerformanceStats

Type called "PerformanceStats":
    avg_write_time as Float
    max_write_time as Float
    min_write_time as Float
    queue_size as Integer
    memory_usage as Integer

Type called "IntegrityProvider":
    algorithm as IntegrityAlgorithm
    signing_key as String
    verification_key as String
    chain_enabled as Boolean

Type IntegrityAlgorithm is:
    | SHA256
    | SHA512
    | HMAC_SHA256
    | RSA_SHA256
    | ECDSA_SHA256

Note: Audit logger creation and configuration
Process called "create_audit_logger" that takes logger_id as String and config as AuditConfig returns AuditLogger:
    Let storage be create_default_storage with config as config
    Let integrity_provider be create_integrity_provider with algorithm as SHA256
    Let metrics be create_empty_metrics() Return AuditLogger with:
    logger_id as logger_id
    config as config
    storage as storage
    filters as list containing
    formatters as list containing create_default_formatter()
    handlers as list containing create_default_handler()
    metrics as metrics
    integrity_provider as integrity_provider

Process called "create_default_audit_config" returns AuditConfig:
    Return AuditConfig with:
    retention_days as 90
    max_file_size as 100000000
    compression_enabled as true
    encryption_enabled as true
    real_time_monitoring as true
    performance_tracking as true
    pii_redaction_enabled as true
    tamper_detection as true

Process called "create_default_storage" that takes config as AuditConfig returns AuditStorage:
    Return AuditStorage with:
    storage_type as FileSystem
    connection_string as "/var/log/audit/"
    encryption_key as if config.encryption_enabled then generate_encryption_key() else None
    backup_enabled as true
    replication_enabled as false

Process called "create_integrity_provider" that takes algorithm as IntegrityAlgorithm returns IntegrityProvider:
    Let key_pair be generate_key_pair_for_algorithm with algorithm as algorithm Return IntegrityProvider with:
    algorithm as algorithm
    signing_key as key_pair.private_key
    verification_key as key_pair.public_key
    chain_enabled as true

Process called "create_default_formatter" returns AuditFormatter:
    Return AuditFormatter with:
    formatter_id as "default-json"
    format_type as JSON
    template as "{\"timestamp\":\"{{timestamp}}\",\"event\":\"{{event_type}}\",\"actor\":\"{{actor.name}}\",\"action\":\"{{action}}\",\"result\":\"{{result}}\"}"
    include_fields as list containing "timestamp", "event_type", "actor", "action", "result"
    exclude_fields as list containing

Process called "create_default_handler" returns AuditHandler:
    Return AuditHandler with:
    handler_id as "default-file"
    handler_type as FileHandler
    destination as "/var/log/audit/audit.log"
    batch_size as 100
    flush_interval as 5000
    retry_policy as create_default_retry_policy()

Process called "create_default_retry_policy" returns RetryPolicy:
    Return RetryPolicy with:
    max_retries as 3
    initial_delay as 1000
    backoff_multiplier as 2.0
    max_delay as 30000

Process called "create_empty_metrics" returns AuditMetrics:
    Return AuditMetrics with:
    total_events as 0
    events_per_second as 0.0
    storage_usage as 0
    errors_count as 0
    last_flush_time as DateTime.now()
    performance_stats as create_empty_performance_stats()

Process called "create_empty_performance_stats" returns PerformanceStats:
    Return PerformanceStats with:
    avg_write_time as 0.0
    max_write_time as 0.0
    min_write_time as 0.0
    queue_size as 0
    memory_usage as 0

Note: Core audit logging operations
Process called "log_audit_event" that takes logger as AuditLogger and entry as AuditEntry returns Boolean:
    Let validated_entry be validate_audit_entry with entry as entry If validated_entry.is_valid is false:
    Return false Let filtered_entry be apply_filters with entry as validated_entry.entry and filters as logger.filters If filtered_entry is None:
    Return true Let formatted_entry be apply_formatters with entry as filtered_entry and formatters as logger.formatters
    Let signed_entry be apply_integrity_signature with entry as formatted_entry and provider as logger.integrity_provider Let write_success be write_to_storage with entry as signed_entry and storage as logger.storage If write_success:
    update_metrics with logger as logger and entry as signed_entry If logger.config.real_time_monitoring:
    trigger_real_time_alerts with entry as signed_entry Return write_success

Process called "log_authentication_event" that takes logger as AuditLogger and actor as Actor and result as ActionResult and details as Dictionary[String, Any] returns Boolean:
    Let entry be create_audit_entry with
    event_type as Authentication
    and severity as if result is Success then Informational else High
    and actor as actor
    and action as "authenticate"
    and result as result
    and metadata as details Return log_audit_event with logger as logger and entry as entry

Process called "log_authorization_event" that takes logger as AuditLogger and actor as Actor and target as Target and action as String and result as ActionResult returns Boolean:
    Let entry be create_audit_entry with
    event_type as Authorization
    and severity as if result is Success then Low else High
    and actor as actor
    and target as target
    and action as action
    and result as result Return log_audit_event with logger as logger and entry as entry

Process called "log_data_access" that takes logger as AuditLogger and actor as Actor and target as Target and operation as String and result as ActionResult returns Boolean:
    Let severity_level be determine_severity_by_classification with classification as target.classification and result as result Let entry be create_audit_entry with
    event_type as DataAccess
    and severity as severity_level
    and actor as actor
    and target as target
    and action as operation
    and result as result Return log_audit_event with logger as logger and entry as entry

Process called "log_security_violation" that takes logger as AuditLogger and actor as Actor and violation_type as String and details as Dictionary[String, Any] returns Boolean:
    Let entry be create_audit_entry with
    event_type as SecurityViolation
    and severity as Critical
    and actor as actor
    and action as violation_type
    and result as Blocked
    and metadata as details Return log_audit_event with logger as logger and entry as entry

Process called "log_compliance_event" that takes logger as AuditLogger and regulation as String and status as String and details as Dictionary[String, Any] returns Boolean:
    Let entry be create_audit_entry with
    event_type as ComplianceEvent
    and severity as Medium
    and action as regulation
    and result as if status is equal to "compliant" then Success else Failure
    and metadata as details Return log_audit_event with logger as logger and entry as entry

Note: Audit entry creation and validation
Process called "create_audit_entry" that takes event_type as EventType and severity as SeverityLevel and actor as Actor and action as String and result as ActionResult returns AuditEntry:
    Let entry_id be generate_unique_id()
    Let timestamp be DateTime.now()
    Let context be get_current_context() Let entry be AuditEntry with:
    entry_id as entry_id
    timestamp as timestamp
    event_type as event_type
    severity as severity
    actor as actor
    target as create_default_target()
    action as action
    result as result
    context as context
    metadata as dictionary containing
    checksum as ""
    Let checksum be calculate_entry_checksum with entry as entry
    Set entry.checksum to checksum Return entry

Process called "create_audit_entry" that takes event_type as EventType and severity as SeverityLevel and actor as Actor and target as Target and action as String and result as ActionResult returns AuditEntry:
    Let entry_id be generate_unique_id()
    Let timestamp be DateTime.now()
    Let context be get_current_context() Let entry be AuditEntry with:
    entry_id as entry_id
    timestamp as timestamp
    event_type as event_type
    severity as severity
    actor as actor
    target as target
    action as action
    result as result
    context as context
    metadata as dictionary containing
    checksum as ""
    Let checksum be calculate_entry_checksum with entry as entry
    Set entry.checksum to checksum Return entry

Process called "create_audit_entry" that takes event_type as EventType and severity as SeverityLevel and actor as Actor and action as String and result as ActionResult and metadata as Dictionary[String, Any] returns AuditEntry:
    Let entry_id be generate_unique_id()
    Let timestamp be DateTime.now()
    Let context be get_current_context() Let entry be AuditEntry with:
    entry_id as entry_id
    timestamp as timestamp
    event_type as event_type
    severity as severity
    actor as actor
    target as create_default_target()
    action as action
    result as result
    context as context
    metadata as metadata
    checksum as ""
    Let checksum be calculate_entry_checksum with entry as entry
    Set entry.checksum to checksum Return entry

Type called "ValidationResult":
    is_valid as Boolean
    entry as AuditEntry
    errors as List[String]

Process called "validate_audit_entry" that takes entry as AuditEntry returns ValidationResult:
    Let errors be list containing If String.is_empty with str as entry.entry_id:
    Add "Entry ID is required" to errors If String.is_empty with str as entry.actor.actor_id:
    Add "Actor ID is required" to errors If String.is_empty with str as entry.action:
    Add "Action is required" to errors If entry.severity is Critical or entry.severity is High:
    If Collections.Dictionary.is_empty with dict as entry.metadata:
    Add "High/Critical events require metadata" to errors Let redacted_entry be apply_pii_redaction with entry as entry Return ValidationResult with:
    is_valid as Collections.List.is_empty with lst as errors
    entry as redacted_entry
    errors as errors

Process called "apply_pii_redaction" that takes entry as AuditEntry returns AuditEntry:
    Let pii_patterns be get_pii_detection_patterns()
    Let redacted_entry be entry Set redacted_entry.actor.name to redact_pii_in_string with text as entry.actor.name and patterns as pii_patterns
    Set redacted_entry.target.name to redact_pii_in_string with text as entry.target.name and patterns as pii_patterns Let redacted_metadata be dictionary containing
    For each key in Collections.Dictionary.keys with dict as entry.metadata:
    Let value be entry.metadata[key]
    If value is String:
    Set redacted_metadata[key] to redact_pii_in_string with text as value and patterns as pii_patterns
    Otherwise:
    Set redacted_metadata[key] to value Set redacted_entry.metadata to redacted_metadata Return redacted_entry

Process called "get_pii_detection_patterns" returns List[PIIPattern]:
    Return list containing
    create_pii_pattern with name as "SSN" and pattern as "\\b\\d{3}-\\d{2}-\\d{4}\\b" and replacement as "***-**-****",
    create_pii_pattern with name as "Email" and pattern as "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b" and replacement as "***@***.***",
    create_pii_pattern with name as "CreditCard" and pattern as "\\b\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b" and replacement as "****-****-****-****",
    create_pii_pattern with name as "Phone" and pattern as "\\b\\d{3}[-.\\s]?\\d{3}[-.\\s]?\\d{4}\\b" and replacement as "***-***-****"

Type called "PIIPattern":
    name as String
    pattern as String
    replacement as String

Process called "create_pii_pattern" that takes name as String and pattern as String and replacement as String returns PIIPattern:
    Return PIIPattern with:
    name as name
    pattern as pattern
    replacement as replacement

Process called "redact_pii_in_string" that takes text as String and patterns as List[PIIPattern] returns String:
    Let result as String
    Set result to text For each pattern in patterns:
    Set result to String.regex_replace with text as result and pattern as pattern.pattern and replacement as pattern.replacement Return result

Note: Filtering and formatting operations
Process called "apply_filters" that takes entry as AuditEntry and filters as List[AuditFilter] returns Optional[AuditEntry]:
    For each filter in filters:
    If filter.enabled is false:
    Continue Let matches be evaluate_filter with entry as entry and filter as filter Match filter.filter_type:
    When IncludeFilter:
    If matches is false:
    Return None
    When ExcludeFilter:
    If matches is true:
    Return None
    Otherwise:
    Continue Return entry

Process called "evaluate_filter" that takes entry as AuditEntry and filter as AuditFilter returns Boolean:
    Let criteria be filter.criteria
    Let field_value be get_field_value_from_entry with entry as entry and field as criteria.field Match criteria.operator:
    When Equals:
    Return compare_values with value1 as field_value and value2 as criteria.value and case_sensitive as criteria.case_sensitive
    When NotEquals:
    Return not compare_values with value1 as field_value and value2 as criteria.value and case_sensitive as criteria.case_sensitive
    When Contains:
    If field_value is String and criteria.value is String:
    Let field_str be if criteria.case_sensitive then field_value else String.to_lower with str as field_value
    Let criteria_str be if criteria.case_sensitive then criteria.value else String.to_lower with str as criteria.value
    Return String.contains with str as field_str and substring as criteria_str
    Return false
    When StartsWith:
    If field_value is String and criteria.value is String:
    Let field_str be if criteria.case_sensitive then field_value else String.to_lower with str as field_value
    Let criteria_str be if criteria.case_sensitive then criteria.value else String.to_lower with str as criteria.value
    Return String.starts_with with str as field_str and prefix as criteria_str
    Return false
    When InList:
    If criteria.value is List:
    For each item in criteria.value:
    If compare_values with value1 as field_value and value2 as item and case_sensitive as criteria.case_sensitive:
    Return true
    Return false
    Return false
    Otherwise:
    Return true

Process called "get_field_value_from_entry" that takes entry as AuditEntry and field as String returns Any:
    Match field:
    When "event_type":
    Return entry.event_type
    When "severity":
    Return entry.severity
    When "actor.name":
    Return entry.actor.name
    When "actor.actor_type":
    Return entry.actor.actor_type
    When "target.target_type":
    Return entry.target.target_type
    When "action":
    Return entry.action
    When "result":
    Return entry.result
    Otherwise:
    If Collections.Dictionary.contains_key with dict as entry.metadata and key as field:
    Return entry.metadata[field]
    Return None

Process called "compare_values" that takes value1 as Any and value2 as Any and case_sensitive as Boolean returns Boolean:
    If value1 is String and value2 is String:
    Let str1 be if case_sensitive then value1 else String.to_lower with str as value1
    Let str2 be if case_sensitive then value2 else String.to_lower with str as value2
    Return String.equals with str1 as str1 and str2 as str2
    Otherwise:
    Return value1 is equal to value2

Process called "apply_formatters" that takes entry as AuditEntry and formatters as List[AuditFormatter] returns String:
    If Collections.List.is_empty with lst as formatters:
    Return format_entry_as_json with entry as entry Let formatter be formatters at index 0 Match formatter.format_type:
    When JSON:
    Return format_entry_as_json with entry as entry
    When XML:
    Return format_entry_as_xml with entry as entry
    When CSV:
    Return format_entry_as_csv with entry as entry
    When Syslog:
    Return format_entry_as_syslog with entry as entry
    Otherwise:
    Return format_entry_with_template with entry as entry and template as formatter.template

Process called "format_entry_as_json" that takes entry as AuditEntry returns String:
    Let json_object be dictionary containing
    Set json_object["entry_id"] to entry.entry_id
    Set json_object["timestamp"] to DateTime.to_iso_string with datetime as entry.timestamp
    Set json_object["event_type"] to entry.event_type
    Set json_object["severity"] to entry.severity
    Set json_object["actor"] to format_actor_as_dict with actor as entry.actor
    Set json_object["target"] to format_target_as_dict with target as entry.target
    Set json_object["action"] to entry.action
    Set json_object["result"] to entry.result
    Set json_object["context"] to format_context_as_dict with context as entry.context
    Set json_object["metadata"] to entry.metadata
    Set json_object["checksum"] to entry.checksum Return Collections.Dictionary.to_json with dict as json_object

Process called "format_entry_as_xml" that takes entry as AuditEntry returns String:
    Let xml_parts be list containing
    Add "<audit_entry>" to xml_parts
    Add String.concat with parts as list containing "<entry_id>", entry.entry_id, "</entry_id>" to xml_parts
    Add String.concat with parts as list containing "<timestamp>", DateTime.to_iso_string with datetime as entry.timestamp, "</timestamp>" to xml_parts
    Add String.concat with parts as list containing "<event_type>", entry.event_type, "</event_type>" to xml_parts
    Add String.concat with parts as list containing "<severity>", entry.severity, "</severity>" to xml_parts
    Add String.concat with parts as list containing "<actor>", entry.actor.name, "</actor>" to xml_parts
    Add String.concat with parts as list containing "<action>", entry.action, "</action>" to xml_parts
    Add String.concat with parts as list containing "<result>", entry.result, "</result>" to xml_parts
    Add String.concat with parts as list containing "<checksum>", entry.checksum, "</checksum>" to xml_parts
    Add "</audit_entry>" to xml_parts Return String.join with parts as xml_parts and separator as ""

Process called "format_entry_as_csv" that takes entry as AuditEntry returns String:
    Let csv_fields be list containing
    Add quote_csv_field with field as entry.entry_id to csv_fields
    Add quote_csv_field with field as DateTime.to_iso_string with datetime as entry.timestamp to csv_fields
    Add quote_csv_field with field as entry.event_type to csv_fields
    Add quote_csv_field with field as entry.severity to csv_fields
    Add quote_csv_field with field as entry.actor.name to csv_fields
    Add quote_csv_field with field as entry.action to csv_fields
    Add quote_csv_field with field as entry.result to csv_fields
    Add quote_csv_field with field as entry.checksum to csv_fields Return String.join with parts as csv_fields and separator as ","

Process called "format_entry_as_syslog" that takes entry as AuditEntry returns String:
    Let priority be calculate_syslog_priority with severity as entry.severity
    Let timestamp_str be DateTime.to_rfc3339 with datetime as entry.timestamp
    Let hostname be get_hostname()
    Let app_name be entry.context.application Return String.concat with parts as list containing 
    "<", priority, ">1 ",
    timestamp_str, " ",
    hostname, " ",
    app_name, " ",
    entry.context.process_id, " ",
    entry.entry_id, " ",
    "[audit] ",
    entry.event_type, " ",
    entry.action, " by ",
    entry.actor.name, " result=",
    entry.result

Note: Integrity and security operations
Process called "apply_integrity_signature" that takes entry as String and provider as IntegrityProvider returns String:
    If provider.chain_enabled is false:
    Return sign_single_entry with entry as entry and provider as provider Return sign_with_chain with entry as entry and provider as provider

Process called "sign_single_entry" that takes entry as String and provider as IntegrityProvider returns String:
    Let signature be Match provider.algorithm:
    When SHA256:
    Hash.sha256 with data as entry
    When SHA512:
    Hash.sha512 with data as entry
    When HMAC_SHA256:
    Hash.hmac_sha256 with data as entry and key as provider.signing_key
    When RSA_SHA256:
    Signatures.rsa_sign with data as entry and private_key as provider.signing_key
    When ECDSA_SHA256:
    Signatures.ecdsa_sign with data as entry and private_key as provider.signing_key
    Otherwise:
    Hash.sha256 with data as entry Return String.concat with parts as list containing entry, "|SIG:", signature

Process called "sign_with_chain" that takes entry as String and provider as IntegrityProvider returns String:
    Let previous_hash be get_last_chain_hash()
    Let chain_data be String.concat with parts as list containing entry, "|PREV:", previous_hash
    Let signature be Hash.sha256 with data as chain_data store_chain_hash with hash as signature Return String.concat with parts as list containing entry, "|CHAIN:", signature

Process called "verify_entry_integrity" that takes signed_entry as String and provider as IntegrityProvider returns Boolean:
    If String.contains with str as signed_entry and substring as "|SIG:":
    Return verify_single_signature with signed_entry as signed_entry and provider as provider
    Else if String.contains with str as signed_entry and substring as "|CHAIN:":
    Return verify_chain_signature with signed_entry as signed_entry and provider as provider Return false

Process called "verify_single_signature" that takes signed_entry as String and provider as IntegrityProvider returns Boolean:
    Let parts be String.split with str as signed_entry and delimiter as "|SIG:"
    If Collections.List.length with lst as parts is not equal to 2:
    Return false Let entry_data be parts at index 0
    Let signature be parts at index 1 Let expected_signature be Match provider.algorithm:
    When SHA256:
    Hash.sha256 with data as entry_data
    When SHA512:
    Hash.sha512 with data as entry_data
    When HMAC_SHA256:
    Hash.hmac_sha256 with data as entry_data and key as provider.verification_key
    When RSA_SHA256:
    Signatures.rsa_verify with data as entry_data and signature as signature and public_key as provider.verification_key
    When ECDSA_SHA256:
    Signatures.ecdsa_verify with data as entry_data and signature as signature and public_key as provider.verification_key
    Otherwise:
    Hash.sha256 with data as entry_data Return String.equals with str1 as signature and str2 as expected_signature

Note: Storage operations
Process called "write_to_storage" that takes entry as String and storage as AuditStorage returns Boolean:
    Match storage.storage_type:
    When FileSystem:
    Return write_to_file_system with entry as entry and storage as storage
    When Database:
    Return write_to_database with entry as entry and storage as storage
    When CloudStorage:
    Return write_to_cloud_storage with entry as entry and storage as storage
    Otherwise:
    Return false

Process called "write_to_file_system" that takes entry as String and storage as AuditStorage returns Boolean:
    Let file_path be get_current_log_file_path with storage as storage
    Let encrypted_entry be if storage.encryption_key is not None then encrypt_entry with entry as entry and key as storage.encryption_key else entry Return append_to_file with file_path as file_path and content as encrypted_entry

Process called "write_to_database" that takes entry as String and storage as AuditStorage returns Boolean:
    Let connection be get_database_connection with connection_string as storage.connection_string
    Let encrypted_entry be if storage.encryption_key is not None then encrypt_entry with entry as entry and key as storage.encryption_key else entry Return execute_insert_query with connection as connection and entry as encrypted_entry

Process called "write_to_cloud_storage" that takes entry as String and storage as AuditStorage returns Boolean:
    Let cloud_client be get_cloud_storage_client with connection_string as storage.connection_string
    Let encrypted_entry be if storage.encryption_key is not None then encrypt_entry with entry as entry and key as storage.encryption_key else entry Return upload_to_cloud with client as cloud_client and entry as encrypted_entry

Note: Query and analysis operations
Type called "AuditQuery":
    start_time as Optional[DateTime.DateTime]
    end_time as Optional[DateTime.DateTime]
    event_types as Optional[List[EventType]]
    severity_levels as Optional[List[SeverityLevel]]
    actors as Optional[List[String]]
    targets as Optional[List[String]]
    actions as Optional[List[String]]
