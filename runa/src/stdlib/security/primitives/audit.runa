Note: Utility and helper functions
Process called "generate_unique_id" returns String:
    Let timestamp be DateTime.now_milliseconds()
    Let random_part be Math.random_int with min as 1000 and max as 9999
    Return String.concat with parts as list containing "AUD-", timestamp, "-", random_part

Process called "get_current_context" returns AuditContext:
    Return AuditContext with:
    request_id as generate_correlation_id()
    correlation_id as generate_correlation_id()
    process_id as get_current_process_id()
    thread_id as get_current_thread_id()
    environment as get_environment_name()
    application as get_application_name()
    version as get_application_version()

Process called "create_default_target" returns Target:
    Return Target with:
    target_id as "unknown"
    target_type as Service
    name as "system"
    classification as Internal
    owner as "system"
    location as "localhost"

Process called "determine_severity_by_classification" that takes classification as ClassificationLevel and result as ActionResult returns SeverityLevel:
    Match classification:
    When TopSecret:
    Return if result is Success then Medium else Critical
    When Restricted:
    Return if result is Success then Low else High
    When Confidential:
    Return if result is Success then Low else Medium
    Otherwise:
    Return Informational

Process called "calculate_entry_checksum" that takes entry as AuditEntry returns String:
    Let checksum_data be String.concat with parts as list containing
    entry.entry_id,
    DateTime.to_iso_string with datetime as entry.timestamp,
    entry.event_type,
    entry.severity,
    entry.actor.actor_id,
    entry.action,
    entry.result Return Hash.sha256 with data as checksum_data

Process called "format_actor_as_dict" that takes actor as Actor returns Dictionary[String, Any]:
    Let actor_dict be dictionary containing
    Set actor_dict["actor_id"] to actor.actor_id
    Set actor_dict["actor_type"] to actor.actor_type
    Set actor_dict["name"] to actor.name
    Set actor_dict["roles"] to actor.roles
    Set actor_dict["session_id"] to actor.session_id
    Set actor_dict["source_ip"] to actor.source_ip
    Return actor_dict

Process called "format_target_as_dict" that takes target as Target returns Dictionary[String, Any]:
    Let target_dict be dictionary containing
    Set target_dict["target_id"] to target.target_id
    Set target_dict["target_type"] to target.target_type
    Set target_dict["name"] to target.name
    Set target_dict["classification"] to target.classification
    Set target_dict["owner"] to target.owner
    Set target_dict["location"] to target.location
    Return target_dict

Process called "format_context_as_dict" that takes context as AuditContext returns Dictionary[String, Any]:
    Let context_dict be dictionary containing
    Set context_dict["request_id"] to context.request_id
    Set context_dict["correlation_id"] to context.correlation_id
    Set context_dict["process_id"] to context.process_id
    Set context_dict["thread_id"] to context.thread_id
    Set context_dict["environment"] to context.environment
    Set context_dict["application"] to context.application
    Set context_dict["version"] to context.version
    Return context_dict

Process called "update_metrics" that takes logger as AuditLogger and entry as String:
    Set logger.metrics.total_events to logger.metrics.total_events 1
    Set logger.metrics.last_flush_time to DateTime.now() Let current_time be DateTime.now_milliseconds()
    Let time_window be 60000
    Let events_in_window be count_events_in_time_window with logger as logger and window_ms as time_window
    Set logger.metrics.events_per_second to events_in_window divided by 60.0

