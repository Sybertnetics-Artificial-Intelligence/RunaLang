Process called "format_entry_with_template" that takes entry as AuditEntry and template as String returns String:
    Let result be template
    Set result to String.replace with str as result and old as "{{timestamp}}" and new as DateTime.to_iso_string with datetime as entry.timestamp
    Set result to String.replace with str as result and old as "{{event_type}}" and new as entry.event_type
    Set result to String.replace with str as result and old as "{{actor.name}}" and new as entry.actor.name
    Set result to String.replace with str as result and old as "{{action}}" and new as entry.action
    Set result to String.replace with str as result and old as "{{result}}" and new as entry.result
    Return result

