    offset as Optional[Integer]

Type called "QueryResult":
    entries as List[AuditEntry]
    total_count as Integer
    execution_time as Float
    query_hash as String

Process called "query_audit_logs" that takes logger as AuditLogger and query as AuditQuery returns QueryResult:
    Let start_time be DateTime.now_milliseconds()
    Let query_hash be generate_query_hash with query as query Let entries be execute_query with storage as logger.storage and query as query
    Let filtered_entries be apply_post_query_filters with entries as entries and query as query Let end_time be DateTime.now_milliseconds()
    Let execution_time be end_time - start_time Return QueryResult with:
    entries as filtered_entries
    total_count as Collections.List.length with lst as filtered_entries
    execution_time as execution_time
    query_hash as query_hash

Process called "search_audit_logs" that takes logger as AuditLogger and search_term as String and field as String returns List[AuditEntry]:
    Let query be AuditQuery with:
    start_time as None
    end_time as None
    event_types as None
    severity_levels as None
    actors as None
    targets as None
    actions as None
    results as None
    limit as 1000
    offset as None Let result be query_audit_logs with logger as logger and query as query Let matching_entries be list containing
    For each entry in result.entries:
    Let field_value be get_field_value_from_entry with entry as entry and field as field
    If field_value is String and String.contains with str as String.to_lower with str as field_value and substring as String.to_lower with str as search_term:
    Add entry to matching_entries Return matching_entries

Process called "generate_compliance_report" that takes logger as AuditLogger and regulation as String and start_date as DateTime.DateTime and end_date as DateTime.DateTime returns ComplianceReport:
    Let query be AuditQuery with:
    start_time as start_date
    end_time as end_date
    event_types as None
    severity_levels as None
    actors as None
    targets as None
    actions as None
    results as None
    limit as None
    offset as None Let result be query_audit_logs with logger as logger and query as query
    Let compliance_data be analyze_compliance with entries as result.entries and regulation as regulation Return create_compliance_report with data as compliance_data and regulation as regulation and period_start as start_date and period_end as end_date

