Note: Core permission management operations
Process called "create_permission_manager" that takes config as PermissionConfig returns PermissionManager:
    Let policy_engine be create_policy_engine with cache_enabled as config.cache_enabled
    Let role_manager be create_role_manager with inheritance_enabled as config.inheritance_enabled
    Let permission_cache be create_permission_cache with ttl_seconds as config.cache_ttl_seconds Return PermissionManager with:
    manager_id as generate_unique_id with prefix as "PM"
    policy_engine as policy_engine
    role_manager as role_manager
    permission_cache as permission_cache
    audit_logger as None
    configuration as config

Process called "create_default_permission_config" returns PermissionConfig:
    Return PermissionConfig with:
    cache_enabled as true
    cache_ttl_seconds as 300
    audit_enabled as true
    performance_monitoring as true
    strict_mode as true
    default_deny as true
    inheritance_enabled as true
    temporal_policies_enabled as true

Process called "check_access" that takes manager as PermissionManager and request as AccessRequest returns AccessDecision:
    Let start_time be DateTime.now_milliseconds()
    Let decision_id be generate_unique_id with prefix as "AD" Note: Check cache first
    If manager.configuration.cache_enabled:
    Let cache_key be generate_cache_key with request as request
    Let cached_decision be get_cached_decision with cache as manager.permission_cache and key as cache_key If cached_decision is not None:
    Return cached_decision Note: Evaluate access request
    Let decision be evaluate_access_request with manager as manager and request as request
    Set decision.decision_id to decision_id
    Set decision.decision_time to DateTime.now()
    Set decision.evaluation_time to DateTime.now_milliseconds() minus start_time Note: Cache the decision
    If manager.configuration.cache_enabled:
    cache_decision with cache as manager.permission_cache and decision as decision Note: Log the decision if auditing is enabled
    If manager.configuration.audit_enabled and manager.audit_logger is not None:
    log_access_decision with logger as manager.audit_logger and decision as decision Return decision

Process called "evaluate_access_request" that takes manager as PermissionManager and request as AccessRequest returns AccessDecision:
    Let matched_policies be list containing
    Let matched_roles be list containing
    Let evaluated_permissions be list containing
    Let obligations be list containing Note: Evaluate direct permissions
    Let direct_result be evaluate_direct_permissions with subject as request.subject and resource as request.resource and action as request.action If direct_result.result is Allowed:
    Return create_access_decision with result as Allowed and reason as "Direct permission granted" and matched_policies as matched_policies and matched_roles as matched_roles and evaluated_permissions as evaluated_permissions and obligations as obligations Note: Evaluate role-based permissions
    Let role_result be evaluate_role_permissions with manager as manager and request as request
    Add role_result.matched_roles to matched_roles
    Add role_result.evaluated_permissions to evaluated_permissions If role_result.result is Allowed:
    Return create_access_decision with result as Allowed and reason as "Role-based permission granted" and matched_policies as matched_policies and matched_roles as matched_roles and evaluated_permissions as evaluated_permissions and obligations as obligations Note: Evaluate policy-based permissions
    Let policy_result be evaluate_policies with engine as manager.policy_engine and request as request
    Add policy_result.matched_policies to matched_policies
    Add policy_result.obligations to obligations If policy_result.result is Allowed:
    Return create_access_decision with result as Allowed and reason as "Policy-based permission granted" and matched_policies as matched_policies and matched_roles as matched_roles and evaluated_permissions as evaluated_permissions and obligations as obligations Note: Default deny if configured
    If manager.configuration.default_deny:
    Return create_access_decision with result as Denied and reason as "Default deny - no matching permissions" and matched_policies as matched_policies and matched_roles as matched_roles and evaluated_permissions as evaluated_permissions and obligations as obligations Return create_access_decision with result as NotApplicable and reason as "No applicable permissions found" and matched_policies as matched_policies and matched_roles as matched_roles and evaluated_permissions as evaluated_permissions and obligations as obligations

Process called "evaluate_direct_permissions" that takes subject as Subject and resource as Resource and action as Action returns PermissionEvaluationResult:
    For each permission in subject.direct_permissions:
    If permission.resource_type is equal to resource.resource_type or permission.resource_type is equal to "*":
    Let action_matches be check_action_match with permission_actions as permission.actions and requested_action as action If action_matches:
    Let constraints_satisfied be evaluate_constraints with constraints as permission.constraints and resource as resource If constraints_satisfied:
    Return PermissionEvaluationResult with result as Allowed and matched_permissions as list containing permission.permission_id Return PermissionEvaluationResult with result as Denied and matched_permissions as list containing

Type called "PermissionEvaluationResult":
    result as AccessResult
    matched_permissions as List[String]
    matched_roles as List[String]
    matched_policies as List[String]
    obligations as List[Obligation]

Process called "evaluate_role_permissions" that takes manager as PermissionManager and request as AccessRequest returns PermissionEvaluationResult:
    Let matched_roles be list containing
    Let evaluated_permissions be list containing For each role_id in request.subject.roles:
    If Collections.Dictionary.contains_key with dict as manager.role_manager.roles and key as role_id:
    Let role be manager.role_manager.roles[role_id]
    Add role_id to matched_roles Note: Check role constraints first
    Let role_constraints_satisfied be evaluate_constraints with constraints as role.constraints and resource as request.resource If role_constraints_satisfied:
    Note: Check if role has expired
    If role.expires_at is not None and DateTime.is_after with datetime1 as DateTime.now() and datetime2 as role.expires_at:
    Continue Note: Evaluate role permissions
    For each permission in role.permissions:
    If permission.resource_type is equal to request.resource.resource_type or permission.resource_type is equal to "*":
    Let action_matches be check_action_match with permission_actions as permission.actions and requested_action as request.action If action_matches:
    Let permission_constraints_satisfied be evaluate_constraints with constraints as permission.constraints and resource as request.resource If permission_constraints_satisfied:
    Add permission.permission_id to evaluated_permissions
    Return PermissionEvaluationResult with result as Allowed and matched_permissions as evaluated_permissions and matched_roles as matched_roles and matched_policies as list containing and obligations as list containing Note: Check inherited permissions from parent roles
    If manager.configuration.inheritance_enabled:
    Let inherited_result be evaluate_inherited_permissions with manager as manager and subject as request.subject and resource as request.resource and action as request.action If inherited_result.result is Allowed:
    Add inherited_result.matched_roles to matched_roles
    Add inherited_result.matched_permissions to evaluated_permissions
    Return PermissionEvaluationResult with result as Allowed and matched_permissions as evaluated_permissions and matched_roles as matched_roles and matched_policies as list containing and obligations as list containing Return PermissionEvaluationResult with result as Denied and matched_permissions as evaluated_permissions and matched_roles as matched_roles and matched_policies as list containing and obligations as list containing

Process called "evaluate_policies" that takes engine as PolicyEngine and request as AccessRequest returns PermissionEvaluationResult:
    Let matched_policies be list containing
    Let obligations be list containing
    Let allow_policies be list containing
    Let deny_policies be list containing Note: Collect applicable policies
    For each policy_id in Collections.Dictionary.keys with dict as engine.policies:
    Let policy be engine.policies[policy_id] If policy.is_active:
    Let policy_applies be evaluate_policy_conditions with policy as policy and request as request If policy_applies:
    Add policy_id to matched_policies Match policy.effect:
    When Allow:
    Add policy to allow_policies
    When Deny:
    Add policy to deny_policies
    When Conditional:
    Note: Handle conditional policies based on rules
    Let conditional_result be evaluate_conditional_policy with policy as policy and request as request
    If conditional_result.allow:
    Add policy to allow_policies
    Otherwise:
    Add policy to deny_policies Note: Deny policies take precedence
    If not Collections.List.is_empty with lst as deny_policies:
    For each policy in deny_policies:
    Add create_policy_obligation with policy as policy to obligations Return PermissionEvaluationResult with result as Denied and matched_permissions as list containing and matched_roles as list containing and matched_policies as matched_policies and obligations as obligations Note: Check allow policies
    If not Collections.List.is_empty with lst as allow_policies:
    For each policy in allow_policies:
    Add create_policy_obligation with policy as policy to obligations Return PermissionEvaluationResult with result as Allowed and matched_permissions as list containing and matched_roles as list containing and matched_policies as matched_policies and obligations as obligations Return PermissionEvaluationResult with result as NotApplicable and matched_permissions as list containing and matched_roles as list containing and matched_policies as matched_policies and obligations as list containing

