Note: Constraint and condition evaluation
Process called "evaluate_constraints" that takes constraints as List[Constraint] and resource as Resource returns Boolean:
    For each constraint in constraints:
    Let constraint_satisfied be evaluate_single_constraint with constraint as constraint and resource as resource If constraint_satisfied is false:
    Return false Return true

Process called "evaluate_single_constraint" that takes constraint as Constraint and resource as Resource returns Boolean:
    Match constraint.constraint_type:
    When TimeConstraint:
    Return evaluate_time_constraint with constraint as constraint
    When LocationConstraint:
    Return evaluate_location_constraint with constraint as constraint and resource as resource
    When AttributeConstraint:
    Return evaluate_attribute_constraint with constraint as constraint and resource as resource
    When ResourceConstraint:
    Return evaluate_resource_constraint with constraint as constraint and resource as resource
    Otherwise:
    Return true

Process called "evaluate_time_constraint" that takes constraint as Constraint returns Boolean:
    Let current_time be DateTime.now() Match constraint.operator:
    When GreaterThan:
    If constraint.value is DateTime.DateTime:
    Return DateTime.is_after with datetime1 as current_time and datetime2 as constraint.value
    When LessThan:
    If constraint.value is DateTime.DateTime:
    Return DateTime.is_before with datetime1 as current_time and datetime2 as constraint.value
    Otherwise:
    Return true Return true

Process called "evaluate_location_constraint" that takes constraint as Constraint and resource as Resource returns Boolean:
    Note: Simplified location constraint evaluation
    Return true

Process called "evaluate_attribute_constraint" that takes constraint as Constraint and resource as Resource returns Boolean:
    If Collections.Dictionary.contains_key with dict as resource.attributes and key as constraint.field:
    Let attribute_value be resource.attributes[constraint.field]
    Return evaluate_constraint_comparison with value1 as attribute_value and operator as constraint.operator and value2 as constraint.value Return false

Process called "evaluate_resource_constraint" that takes constraint as Constraint and resource as Resource returns Boolean:
    Match constraint.field:
    When "classification":
    Return evaluate_constraint_comparison with value1 as resource.classification and operator as constraint.operator and value2 as constraint.value
    When "owner":
    Return evaluate_constraint_comparison with value1 as resource.owner and operator as constraint.operator and value2 as constraint.value
    When "resource_type":
    Return evaluate_constraint_comparison with value1 as resource.resource_type and operator as constraint.operator and value2 as constraint.value
    Otherwise:
    Return true

Process called "evaluate_constraint_comparison" that takes value1 as Any and operator as ComparisonOperator and value2 as Any returns Boolean:
    Match operator:
    When Equals:
    Return value1 is equal to value2
    When NotEquals:
    Return value1 is not equal to value2
    When Contains:
    If value1 is String and value2 is String:
    Return String.contains with str as value1 and substring as value2
    Return false
    When StartsWith:
    If value1 is String and value2 is String:
    Return String.starts_with with str as value1 and prefix as value2
    Return false
    When InList:
    If value2 is List:
    Return Collections.List.contains with lst as value2 and item as value1
    Return false
    Otherwise:
    Return false

Process called "evaluate_policy_conditions" that takes policy as Policy and request as AccessRequest returns Boolean:
    For each condition in policy.conditions:
    Let condition_satisfied be evaluate_policy_condition with condition as condition and request as request If condition_satisfied is false:
    Return false Return true

Process called "evaluate_policy_condition" that takes condition as PolicyCondition and request as AccessRequest returns Boolean:
    Let field_value be get_field_value_from_request with request as request and field as condition.field
    Return evaluate_constraint_comparison with value1 as field_value and operator as condition.operator and value2 as condition.value

Process called "get_field_value_from_request" that takes request as AccessRequest and field as String returns Any:
    Match field:
    When "subject.subject_type":
    Return request.subject.subject_type
    When "subject.name":
    Return request.subject.name
    When "resource.resource_type":
    Return request.resource.resource_type
    When "resource.classification":
    Return request.resource.classification
    When "action.verb":
    Return request.action.verb
    When "context.environment":
    Return request.context.environment
    Otherwise:
    If String.starts_with with str as field and prefix as "subject.attributes.":
    Let attribute_key be String.substring with str as field and start as 19
    If Collections.Dictionary.contains_key with dict as request.subject.attributes and key as attribute_key:
    Return request.subject.attributes[attribute_key] If String.starts_with with str as field and prefix as "resource.attributes.":
    Let attribute_key be String.substring with str as field and start as 20
    If Collections.Dictionary.contains_key with dict as request.resource.attributes and key as attribute_key:
    Return request.resource.attributes[attribute_key] Return None

Note: Caching operations
Process called "create_permission_cache" that takes ttl_seconds as Integer returns PermissionCache:
    Return PermissionCache with:
    cache_id as generate_unique_id with prefix as "CACHE"
    cache_type as InMemory
    entries as dictionary containing
    max_size as 10000
    ttl_seconds as ttl_seconds
    hit_rate as 0.0
    miss_rate as 0.0

Process called "generate_cache_key" that takes request as AccessRequest returns String:
    Let key_parts be list containing
    Add request.subject.subject_id to key_parts
    Add request.resource.resource_id to key_parts
    Add request.action.action_id to key_parts Let key_string be String.join with parts as key_parts and separator as ":"
    Return Hash.sha256 with data as key_string

Process called "get_cached_decision" that takes cache as PermissionCache and key as String returns Optional[AccessDecision]:
    If Collections.Dictionary.contains_key with dict as cache.entries and key as key:
    Let entry be cache.entries[key] If DateTime.is_before with datetime1 as DateTime.now() and datetime2 as entry.expires_at:
    Set entry.access_count to entry.access_count 1
    Set entry.last_accessed to DateTime.now()
    update_cache_hit_rate with cache as cache
    Return entry.value
    Otherwise:
    Collections.Dictionary.remove with dict as cache.entries and key as key update_cache_miss_rate with cache as cache
    Return None

Process called "cache_decision" that takes cache as PermissionCache and decision as AccessDecision:
    If Collections.Dictionary.size with dict as cache.entries is greater than or equal to cache.max_size:
    evict_oldest_cache_entry with cache as cache Let cache_key be generate_cache_key with request as decision.request
    Let expires_at be DateTime.add_seconds with datetime as DateTime.now() and seconds as cache.ttl_seconds Let cache_entry be CacheEntry with:
    key as cache_key
    value as decision
    created_at as DateTime.now()
    expires_at as expires_at
    access_count as 1
    last_accessed as DateTime.now() Set cache.entries[cache_key] to cache_entry

Process called "evict_oldest_cache_entry" that takes cache as PermissionCache:
    Let oldest_key be None
    Let oldest_time be DateTime.now() For each key in Collections.Dictionary.keys with dict as cache.entries:
    Let entry be cache.entries[key]
    If DateTime.is_before with datetime1 as entry.last_accessed and datetime2 as oldest_time:
    Set oldest_key to key
    Set oldest_time to entry.last_accessed If oldest_key is not None:
    Collections.Dictionary.remove with dict as cache.entries and key as oldest_key

Note: Utility and helper functions
Process called "check_action_match" that takes permission_actions as List[Action] and requested_action as Action returns Boolean:
    For each action in permission_actions:
    If action.action_id is equal to requested_action.action_id or action.verb is equal to requested_action.verb:
    Return true Return false

Process called "evaluate_inherited_permissions" that takes manager as PermissionManager and subject as Subject and resource as Resource and action as Action returns PermissionEvaluationResult:
    Let matched_roles be list containing
    Let matched_permissions be list containing For each role_id in subject.roles:
    If Collections.Dictionary.contains_key with dict as manager.role_manager.roles and key as role_id:
    Let role be manager.role_manager.roles[role_id]
    Let inherited_result be check_role_inheritance with manager as manager and role as role and resource as resource and action as action If inherited_result.result is Allowed:
    Add role_id to matched_roles
    Add inherited_result.matched_permissions to matched_permissions
    Return PermissionEvaluationResult with result as Allowed and matched_permissions as matched_permissions and matched_roles as matched_roles and matched_policies as list containing and obligations as list containing Return PermissionEvaluationResult with result as Denied and matched_permissions as matched_permissions and matched_roles as matched_roles and matched_policies as list containing and obligations as list containing

Process called "check_role_inheritance" that takes manager as PermissionManager and role as Role and resource as Resource and action as Action returns PermissionEvaluationResult:
    Note: Check parent roles for inherited permissions
    For each parent_role_id in role.parent_roles:
    If Collections.Dictionary.contains_key with dict as manager.role_manager.roles and key as parent_role_id:
    Let parent_role be manager.role_manager.roles[parent_role_id] For each permission in parent_role.permissions:
    If permission.resource_type is equal to resource.resource_type or permission.resource_type is equal to "*":
    Let action_matches be check_action_match with permission_actions as permission.actions and requested_action as action If action_matches:
    Let constraints_satisfied be evaluate_constraints with constraints as permission.constraints and resource as resource If constraints_satisfied:
    Return PermissionEvaluationResult with result as Allowed and matched_permissions as list containing permission.permission_id and matched_roles as list containing parent_role_id and matched_policies as list containing and obligations as list containing Note: Recursively check parent's parents
    Let recursive_result be check_role_inheritance with manager as manager and role as parent_role and resource as resource and action as action If recursive_result.result is Allowed:
    Return recursive_result Return PermissionEvaluationResult with result as Denied and matched_permissions as list containing and matched_roles as list containing and matched_policies as list containing and obligations as list containing

Process called "evaluate_conditional_policy" that takes policy as Policy and request as AccessRequest returns ConditionalResult:
    Let allow_count be 0
    Let total_rules be Collections.List.length with lst as policy.rules For each rule in policy.rules:
    Let rule_result be evaluate_policy_rule with rule as rule and request as request If rule_result.result is Allowed:
    Set allow_count to allow_count 1 Note: Simple majority rule for conditional policies
    Let allow_threshold be total_rules divided by 2 Return ConditionalResult with allow as (allow_count is greater than allow_threshold)

Type called "ConditionalResult":
    allow as Boolean

Process called "evaluate_policy_rule" that takes rule as PolicyRule and request as AccessRequest returns PermissionEvaluationResult:
    Note: Check if rule applies to this request
    Let subject_matches be Collections.List.is_empty with lst as rule.subjects or Collections.List.contains with lst as rule.subjects and item as request.subject.subject_id
    Let resource_matches be Collections.List.is_empty with lst as rule.resources or Collections.List.contains with lst as rule.resources and item as request.resource.resource_id
    Let action_matches be Collections.List.is_empty with lst as rule.actions or check_action_match with permission_actions as rule.actions and requested_action as request.action If subject_matches and resource_matches and action_matches:
    Let conditions_satisfied be evaluate_rule_conditions with conditions as rule.conditions and request as request If conditions_satisfied:
    Return PermissionEvaluationResult with result as rule.effect and matched_permissions as list containing and matched_roles as list containing and matched_policies as list containing rule.rule_id and obligations as list containing Return PermissionEvaluationResult with result as NotApplicable and matched_permissions as list containing and matched_roles as list containing and matched_policies as list containing and obligations as list containing

Process called "evaluate_rule_conditions" that takes conditions as List[PolicyCondition] and request as AccessRequest returns Boolean:
    For each condition in conditions:
    Let condition_satisfied be evaluate_policy_condition with condition as condition and request as request If condition_satisfied is false:
    Return false Return true

