Note: Advanced permission features
Process called "check_temporal_access" that takes manager as PermissionManager and request as AccessRequest and start_time as DateTime.DateTime and end_time as DateTime.DateTime returns AccessDecision:
    If not manager.configuration.temporal_policies_enabled:
    Return check_access with manager as manager and request as request Let current_time be DateTime.now() If DateTime.is_before with datetime1 as current_time and datetime2 as start_time or DateTime.is_after with datetime1 as current_time and datetime2 as end_time:
    Return create_access_decision with result as Denied and reason as "Access denied - outside allowed time window" and matched_policies as list containing and matched_roles as list containing and evaluated_permissions as list containing and obligations as list containing Return check_access with manager as manager and request as request

Process called "delegate_permission" that takes manager as PermissionManager and delegator as Subject and delegatee as Subject and permissions as List[Permission] and expiry as DateTime.DateTime returns Boolean:
    For each permission in permissions:
    Let delegated_permission be create_delegated_permission with original_permission as permission and delegator as delegator and delegatee as delegatee and expiry as expiry
    Add delegated_permission to delegatee.direct_permissions Return true

Process called "create_delegated_permission" that takes original_permission as Permission and delegator as Subject and delegatee as Subject and expiry as DateTime.DateTime returns Permission:
    Let delegated_permission be Permission with:
    permission_id as generate_unique_id with prefix as "DELEG"
    name as String.concat with parts as list containing "Delegated: ", original_permission.name
    description as String.concat with parts as list containing "Delegated from ", delegator.name, " to ", delegatee.name
    resource_type as original_permission.resource_type
    actions as original_permission.actions
    constraints as original_permission.constraints
    metadata as dictionary containing Set delegated_permission.metadata["delegated"] to true
    Set delegated_permission.metadata["delegator"] to delegator.subject_id
    Set delegated_permission.metadata["expires_at"] to DateTime.to_iso_string with datetime as expiry Return delegated_permission

Process called "impersonate_subject" that takes manager as PermissionManager and impersonator as Subject and target_subject as Subject and request as AccessRequest returns AccessDecision:
    Note: Check if impersonator has impersonation rights
    Let impersonation_permission be check_impersonation_permission with manager as manager and impersonator as impersonator and target as target_subject If impersonation_permission is false:
    Return create_access_decision with result as Denied and reason as "Impersonation not allowed" and matched_policies as list containing and matched_roles as list containing and evaluated_permissions as list containing and obligations as list containing Note: Create modified request with target subject
    Let impersonated_request be AccessRequest with:
    request_id as request.request_id
    subject as target_subject
    resource as request.resource
    action as request.action
    context as request.context
    timestamp as request.timestamp Return check_access with manager as manager and request as impersonated_request

Process called "check_impersonation_permission" that takes manager as PermissionManager and impersonator as Subject and target as Subject returns Boolean:
    Note: Check if impersonator has the special impersonation permission
    For each permission in impersonator.direct_permissions:
    If permission.name is equal to "impersonate" and permission.resource_type is equal to "subject":
    Return true Note: Check role-based impersonation permissions
    For each role_id in impersonator.roles:
    If Collections.Dictionary.contains_key with dict as manager.role_manager.roles and key as role_id:
    Let role be manager.role_manager.roles[role_id] For each permission in role.permissions:
    If permission.name is equal to "impersonate" and permission.resource_type is equal to "subject":
    Return true Return false

Process called "bulk_permission_check" that takes manager as PermissionManager and requests as List[AccessRequest] returns List[AccessDecision]:
    Let decisions be list containing For each request in requests:
    Let decision be check_access with manager as manager and request as request
    Add decision to decisions Return decisions

Process called "get_effective_permissions" that takes manager as PermissionManager and subject as Subject returns List[Permission]:
    Let effective_permissions be list containing Note: Add direct permissions
    For each permission in subject.direct_permissions:
    Add permission to effective_permissions Note: Add role-based permissions
    For each role_id in subject.roles:
    If Collections.Dictionary.contains_key with dict as manager.role_manager.roles and key as role_id:
    Let role be manager.role_manager.roles[role_id] For each permission in role.permissions:
    Add permission to effective_permissions Note: Add inherited permissions if inheritance is enabled
    If manager.configuration.inheritance_enabled:
    Let inherited_permissions be get_inherited_permissions_from_role with manager as manager and role as role
    For each inherited_permission in inherited_permissions:
    Add inherited_permission to effective_permissions Return remove_duplicate_permissions with permissions as effective_permissions

Process called "get_inherited_permissions_from_role" that takes manager as PermissionManager and role as Role returns List[Permission]:
    Let inherited_permissions be list containing For each parent_role_id in role.parent_roles:
    If Collections.Dictionary.contains_key with dict as manager.role_manager.roles and key as parent_role_id:
    Let parent_role be manager.role_manager.roles[parent_role_id] For each permission in parent_role.permissions:
    Add permission to inherited_permissions Note: Recursively get permissions from parent's parents
    Let recursive_permissions be get_inherited_permissions_from_role with manager as manager and role as parent_role
    For each recursive_permission in recursive_permissions:
    Add recursive_permission to inherited_permissions Return inherited_permissions

Process called "remove_duplicate_permissions" that takes permissions as List[Permission] returns List[Permission]:
    Let unique_permissions be list containing
    Let seen_permission_ids be Collections.Set.create_empty() For each permission in permissions:
    If not Collections.Set.contains with set as seen_permission_ids and item as permission.permission_id:
    Collections.Set.add with set as seen_permission_ids and item as permission.permission_id
    Add permission to unique_permissions Return unique_permissions