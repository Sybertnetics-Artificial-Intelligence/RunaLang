Process called "get_cached_policy_result" that takes cache as PolicyCache and key as String returns Optional[PolicyCacheEntry]:
    If Collections.Dictionary.contains_key with dict as cache.entries and key as key:
    Let entry be cache.entries[key] If DateTime.is_before with datetime1 as DateTime.now() and datetime2 as entry.expires_at:
    Set entry.hit_count to entry.hit_count 1
    Return entry
    Otherwise:
    Collections.Dictionary.remove with dict as cache.entries and key as key Return None

Process called "cache_policy_result" that takes cache as PolicyCache and key as String and result as AccessDecision_:
    Let expires_at be DateTime.add_seconds with datetime as DateTime.now() and seconds as cache.ttl_seconds Let entry be PolicyCacheEntry with:
    key as key
    result as result
    created_at as DateTime.now()
    expires_at as expires_at
    hit_count as 1 Set cache.entries[key] to entry

