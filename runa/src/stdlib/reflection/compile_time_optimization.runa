Process called "estimate_memory_savings" that takes candidate as OptimizationCandidate returns Float:
    Return candidate.potential_improvement multiplied by 0.1

Process called "estimate_startup_reduction" that takes candidate as OptimizationCandidate returns Float:
    Return candidate.potential_improvement multiplied by 0.05

Process called "filter_high_impact_candidates" that takes candidates as List[OptimizationCandidate] returns List[OptimizationCandidate]:
    Let high_impact be list containing
    For each candidate in candidates:
    If candidate.potential_improvement is greater than 0.3:
    Add candidate to high_impact
    Return high_impact

Process called "create_recommendation_for_candidate" that takes candidate as OptimizationCandidate returns OptimizationRecommendation:
    Return OptimizationRecommendation with:
    recommendation_id as generate_optimizer_id()
    optimization_type as candidate.optimization_type
    target_sites as list containing candidate.site_id
    expected_benefit as candidate.potential_improvement
    implementation_effort as convert_complexity_to_effort with complexity as candidate.implementation_complexity
    compatibility_risk as candidate.risk_assessment
    description as generate_recommendation_description with candidate as candidate

Process called "convert_complexity_to_effort" that takes complexity as ComplexityLevel returns EffortLevel:
    Match complexity:
    When Trivial:
    Return Minimal
    When Simple:
    Return Low
    When Moderate:
    Return Medium
    When Complex:
    Return High
    When VeryComplex:
    Return Extensive
    Otherwise:
    Return Medium

Process called "generate_recommendation_description" that takes candidate as OptimizationCandidate returns String:
    Return String.concat with parts as list containing "Apply ", candidate.optimization_type, " optimization for improved performance"

Process called "create_generic_transformation" that takes candidate as OptimizationCandidate returns CodeTransformation:
