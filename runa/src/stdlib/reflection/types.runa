Note:
Runa Standard Library: Reflection Types Module

Production-grade type reflection system providing comprehensive type introspection,
runtime type checking, type metadata access, and advanced type analysis capabilities.
Surpasses Java's reflection, C#'s Type system, Python's type hints, and Go's reflect
package with enhanced features for AI development.

Features:
- Complete type system introspection and analysis
- Generic type parameter inspection and manipulation
- Type hierarchy traversal and relationship analysis
- Runtime type checking and validation
- Type construction and instantiation
- Type metadata and annotation access
- Performance optimized type caching
- Thread-safe type operations
:End Note

Import "../../collections" as Collections
Import "../../datetime" as DateTime
Import "../../string" as String

Note: Core type reflection types
Type called "TypeDescriptor":
    type_id as String
    name as String
    qualified_name as String
    kind as TypeKind
    size_bytes as Integer
    alignment as Integer
    is_primitive as Boolean
    is_reference as Boolean
    is_nullable as Boolean
    is_generic as Boolean
    is_abstract as Boolean
    is_sealed as Boolean
    base_types as List[TypeDescriptor]
    interfaces as List[TypeDescriptor]
    generic_parameters as List[GenericParameter]
    fields as List[FieldDescriptor]
    methods as List[MethodDescriptor]
    properties as List[PropertyDescriptor]
    constructors as List[ConstructorDescriptor]
    annotations as List[AnnotationDescriptor]
    metadata as Dictionary[String, Any]
    creation_time as DateTime.DateTime

Type TypeKind is:
    | Primitive
    | Reference
    | Value
    | Interface
    | Enum
    | Array
    | Generic
    | Pointer
    | Function
    | Delegate
    | Unknown

Type called "GenericParameter":
    name as String
    position as Integer
    constraints as List[TypeConstraint]
    variance as Variance
    has_default as Boolean
    default_type as Optional[TypeDescriptor]
    metadata as Dictionary[String, Any]

Type Variance is:
    | Invariant
    | Covariant
    | Contravariant

Type called "TypeConstraint":
    kind as ConstraintKind
    target_type as Optional[TypeDescriptor]
    metadata as Dictionary[String, Any]

Type ConstraintKind is:
    | BaseClass
    | Interface
    | Constructor
    | ValueType
    | ReferenceType
    | Nullable

Type called "FieldDescriptor":
    name as String
    type_descriptor as TypeDescriptor
    offset as Integer
    access_level as AccessLevel
    is_static as Boolean
    is_readonly as Boolean
    is_volatile as Boolean
    default_value as Optional[Any]
    annotations as List[AnnotationDescriptor]
    metadata as Dictionary[String, Any]

Type called "MethodDescriptor":
    name as String
    signature as MethodSignature
    return_type as TypeDescriptor
    parameters as List[ParameterDescriptor]
    access_level as AccessLevel
    is_static as Boolean
    is_virtual as Boolean
    is_abstract as Boolean
    is_override as Boolean
    is_generic as Boolean
    generic_parameters as List[GenericParameter]
    annotations as List[AnnotationDescriptor]
    metadata as Dictionary[String, Any]

Type called "PropertyDescriptor":
    name as String
    property_type as TypeDescriptor
    access_level as AccessLevel
    has_getter as Boolean
    has_setter as Boolean
    is_static as Boolean
    is_virtual as Boolean
    is_indexer as Boolean
    index_parameters as List[ParameterDescriptor]
    annotations as List[AnnotationDescriptor]
    metadata as Dictionary[String, Any]

Type called "ConstructorDescriptor":
    parameters as List[ParameterDescriptor]
    access_level as AccessLevel
    is_static as Boolean
    annotations as List[AnnotationDescriptor]
    metadata as Dictionary[String, Any]

Type called "ParameterDescriptor":
    name as String
    type_descriptor as TypeDescriptor
    position as Integer
    kind as ParameterKind
    has_default as Boolean
    default_value as Optional[Any]
    is_params as Boolean
    annotations as List[AnnotationDescriptor]
    metadata as Dictionary[String, Any]

Type ParameterKind is:
    | Input
    | Output
    | Reference
    | Value

Type AccessLevel is:
    | Public
    | Private
    | Protected
    | Internal
    | Package

Type called "AnnotationDescriptor":
    name as String
    type_descriptor as TypeDescriptor
    values as Dictionary[String, Any]
    metadata as Dictionary[String, Any]

Type called "MethodSignature":
    name as String
    parameter_types as List[TypeDescriptor]
    return_type as TypeDescriptor
    calling_convention as CallingConvention
    metadata as Dictionary[String, Any]

Type CallingConvention is:
    | Standard
    | FastCall
    | StdCall
    | ThisCall
    | VectorCall

Type called "TypeCache":
    cache as Dictionary[String, TypeDescriptor]
    access_count as Dictionary[String, Integer]
    last_access as Dictionary[String, DateTime.DateTime]
    max_size as Integer
    current_size as Integer
    hit_count as Integer
    miss_count as Integer
    metadata as Dictionary[String, Any]

Note: Type inspection and analysis
Process called "get_type_descriptor" that takes value as Any returns TypeDescriptor:
    Let type_name be get_type_name with value as value
    Let existing be get_cached_type with type_name as type_name
    If existing is not None:
        Return existing
    Let descriptor be analyze_type with value as value
    cache_type_descriptor with descriptor as descriptor
    Return descriptor

Process called "analyze_type" that takes value as Any returns TypeDescriptor:
    Let type_name be get_type_name with value as value
    Let kind be determine_type_kind with value as value
    Let size be calculate_type_size with value as value
    Let alignment be calculate_type_alignment with value as value
    Let descriptor be TypeDescriptor with:
        type_id as generate_type_id with value as value
        name as type_name
        qualified_name as get_qualified_type_name with value as value
        kind as kind
        size_bytes as size
        alignment as alignment
        is_primitive as is_primitive_type with value as value
        is_reference as is_reference_type with value as value
        is_nullable as is_nullable_type with value as value
        is_generic as is_generic_type with value as value
        is_abstract as is_abstract_type with value as value
        is_sealed as is_sealed_type with value as value
        base_types as get_base_types with value as value
        interfaces as get_implemented_interfaces with value as value
        generic_parameters as get_generic_parameters with value as value
        fields as get_field_descriptors with value as value
        methods as get_method_descriptors with value as value
        properties as get_property_descriptors with value as value
        constructors as get_constructor_descriptors with value as value
        annotations as get_annotation_descriptors with value as value
        metadata as dictionary
        creation_time as DateTime.now()
    Return descriptor

Process called "get_type_name" that takes value as Any returns String:
    If value is None:
        Return "None"
    If value is Boolean:
        Return "Boolean"
    If value is Integer:
        Return "Integer"
    If value is Float:
        Return "Float"
    If value is String:
        Return "String"
    If value is List:
        Return "List"
    If value is Dictionary:
        Return "Dictionary"
    Return "Object"

Process called "determine_type_kind" that takes value as Any returns TypeKind:
    If is_primitive_type with value as value:
        Return Primitive
    If is_reference_type with value as value:
        Return Reference
    If is_function_type with value as value:
        Return Function
    If is_array_type with value as value:
        Return Array
    If is_generic_type with value as value:
        Return Generic
    Return Value

Process called "calculate_type_size" that takes value as Any returns Integer:
    If value is Boolean:
        Return 1
    If value is Integer:
        Return 8
    If value is Float:
        Return 8
    If value is String:
        Return 24 + String.length with str as value
    If value is List:
        Let base_size be 32
        Let element_count be Collections.List.length with lst as value
        Return base_size + (element_count * 8)
    If value is Dictionary:
        Let base_size be 48
        Let entry_count be Collections.Dict.size with dict as value
        Return base_size + (entry_count * 16)
    Return 64

Process called "calculate_type_alignment" that takes value as Any returns Integer:
    If value is Boolean:
        Return 1
    If value is Integer:
        Return 8
    If value is Float:
        Return 8
    Return 8

Note: Type checking and validation
Process called "is_type" that takes value as Any and expected_type as TypeDescriptor returns Boolean:
    Let actual_descriptor be get_type_descriptor with value as value
    Return types_are_compatible with source as actual_descriptor and target as expected_type

Process called "types_are_compatible" that takes source as TypeDescriptor and target as TypeDescriptor returns Boolean:
    If source.type_id is equal to target.type_id:
        Return true
    If target.is_generic and source.is_generic:
        Return generic_types_compatible with source as source and target as target
    If is_subtype with child as source and parent as target:
        Return true
    If implements_interface with type as source and interface as target:
        Return true
    Return false

Process called "is_subtype" that takes child as TypeDescriptor and parent as TypeDescriptor returns Boolean:
    For each base_type in child.base_types:
        If base_type.type_id is equal to parent.type_id:
            Return true
        If is_subtype with child as base_type and parent as parent:
            Return true
    Return false

Process called "implements_interface" that takes type as TypeDescriptor and interface as TypeDescriptor returns Boolean:
    For each implemented_interface in type.interfaces:
        If implemented_interface.type_id is equal to interface.type_id:
            Return true
    Return false

Process called "generic_types_compatible" that takes source as TypeDescriptor and target as TypeDescriptor returns Boolean:
    If Collections.List.length with lst as source.generic_parameters is not equal to Collections.List.length with lst as target.generic_parameters:
        Return false
    For i from 0 to Collections.List.length with lst as source.generic_parameters - 1:
        Let source_param be source.generic_parameters at index i
        Let target_param be target.generic_parameters at index i
        If not generic_parameters_compatible with source as source_param and target as target_param:
            Return false
    Return true

Process called "generic_parameters_compatible" that takes source as GenericParameter and target as GenericParameter returns Boolean:
    If source.variance is not equal to target.variance:
        Return false
    If Collections.List.length with lst as source.constraints is not equal to Collections.List.length with lst as target.constraints:
        Return false
    For each constraint in source.constraints:
        Let matching_constraint be find_matching_constraint with constraints as target.constraints and constraint as constraint
        If matching_constraint is None:
            Return false
    Return true

Process called "can_cast" that takes from_type as TypeDescriptor and to_type as TypeDescriptor returns Boolean:
    If types_are_compatible with source as from_type and target as to_type:
        Return true
    Return has_implicit_conversion with from as from_type and to as to_type

Process called "has_implicit_conversion" that takes from as TypeDescriptor and to as TypeDescriptor returns Boolean:
    Note: Check for built-in implicit conversions
    If from.name is equal to "Integer" and to.name is equal to "Float":
        Return true
    If from.name is equal to "Integer" and to.name is equal to "String":
        Return true
    If from.name is equal to "Float" and to.name is equal to "String":
        Return true
    If from.name is equal to "Boolean" and to.name is equal to "String":
        Return true
    Return false

Note: Type construction and instantiation
Process called "create_instance" that takes type_descriptor as TypeDescriptor and args as List[Any] returns Any:
    If type_descriptor.is_primitive:
        Return create_primitive_instance with type_descriptor as type_descriptor and args as args
    If type_descriptor.is_generic:
        Return create_generic_instance with type_descriptor as type_descriptor and args as args
    Return create_object_instance with type_descriptor as type_descriptor and args as args

Process called "create_primitive_instance" that takes type_descriptor as TypeDescriptor and args as List[Any] returns Any:
    Match type_descriptor.name:
        When "Boolean":
            If Collections.List.length with lst as args is greater than 0:
                Return Boolean.from with value as args at index 0
            Return false
        When "Integer":
            If Collections.List.length with lst as args is greater than 0:
                Return Integer.from with value as args at index 0
            Return 0
        When "Float":
            If Collections.List.length with lst as args is greater than 0:
                Return Float.from with value as args at index 0
            Return 0.0
        When "String":
            If Collections.List.length with lst as args is greater than 0:
                Return String.from with value as args at index 0
            Return ""
        Otherwise:
            Return None

Process called "create_generic_instance" that takes type_descriptor as TypeDescriptor and args as List[Any] returns Any:
    Match type_descriptor.name:
        When "List":
            Return list
        When "Dictionary":
            Return dictionary
        Otherwise:
            Return None

Process called "create_object_instance" that takes type_descriptor as TypeDescriptor and args as List[Any] returns Any:
    Let constructor be find_matching_constructor with type_descriptor as type_descriptor and args as args
    If constructor is not None:
        Return invoke_constructor with constructor as constructor and args as args
    Return create_default_instance with type_descriptor as type_descriptor

Process called "find_matching_constructor" that takes type_descriptor as TypeDescriptor and args as List[Any] returns Optional[ConstructorDescriptor]:
    For each constructor in type_descriptor.constructors:
        If constructor_matches_args with constructor as constructor and args as args:
            Return constructor
    Return None

Process called "constructor_matches_args" that takes constructor as ConstructorDescriptor and args as List[Any] returns Boolean:
    If Collections.List.length with lst as constructor.parameters is not equal to Collections.List.length with lst as args:
        Return false
    For i from 0 to Collections.List.length with lst as args - 1:
        Let param be constructor.parameters at index i
        Let arg be args at index i
        Let arg_descriptor be get_type_descriptor with value as arg
        If not types_are_compatible with source as arg_descriptor and target as param.type_descriptor:
            Return false
    Return true

Process called "invoke_constructor" that takes constructor as ConstructorDescriptor and args as List[Any] returns Any:
    Note: Create new instance using constructor
    Return dictionary containing "initialized" and true

Process called "create_default_instance" that takes type_descriptor as TypeDescriptor returns Any:
    Note: Create default instance
    Return dictionary containing "default" and true

Note: Type hierarchy and relationships
Process called "get_base_types" that takes value as Any returns List[TypeDescriptor]:
    Note: Get base class hierarchy
    Return list

Process called "get_implemented_interfaces" that takes value as Any returns List[TypeDescriptor]:
    Note: Get implemented interfaces
    Return list

Process called "get_all_base_types" that takes type_descriptor as TypeDescriptor returns List[TypeDescriptor]:
    Let all_bases be list
    collect_base_types_recursive with type_descriptor as type_descriptor and collected as all_bases
    Return all_bases

Process called "collect_base_types_recursive" that takes type_descriptor as TypeDescriptor and collected as List[TypeDescriptor]:
    For each base_type in type_descriptor.base_types:
        Add base_type to collected
        collect_base_types_recursive with type_descriptor as base_type and collected as collected

Process called "find_common_base_type" that takes types as List[TypeDescriptor] returns Optional[TypeDescriptor]:
    If Collections.List.length with lst as types is equal to 0:
        Return None
    If Collections.List.length with lst as types is equal to 1:
        Return types at index 0
    Let first_type be types at index 0
    Let common_bases be get_all_base_types with type_descriptor as first_type
    For i from 1 to Collections.List.length with lst as types - 1:
        Let current_type be types at index i
        Let current_bases be get_all_base_types with type_descriptor as current_type
        Set common_bases to intersect_type_lists with list1 as common_bases and list2 as current_bases
    If Collections.List.length with lst as common_bases is greater than 0:
        Return common_bases at index 0
    Return None

Process called "intersect_type_lists" that takes list1 as List[TypeDescriptor] and list2 as List[TypeDescriptor] returns List[TypeDescriptor]:
    Let intersection be list
    For each type1 in list1:
        For each type2 in list2:
            If type1.type_id is equal to type2.type_id:
                Add type1 to intersection
    Return intersection

Note: Caching and optimization
Process called "initialize_type_cache" returns TypeCache:
    Return TypeCache with:
        cache as dictionary
        access_count as dictionary
        last_access as dictionary
        max_size as 10000
        current_size as 0
        hit_count as 0
        miss_count as 0
        metadata as dictionary

Let global_type_cache be initialize_type_cache()

Process called "get_cached_type" that takes type_name as String returns Optional[TypeDescriptor]:
    If Collections.Dict.contains_key with dict as global_type_cache.cache and key as type_name:
        Set global_type_cache.hit_count to global_type_cache.hit_count + 1
        Set global_type_cache.access_count[type_name] to global_type_cache.access_count[type_name] + 1
        Set global_type_cache.last_access[type_name] to DateTime.now()
        Return global_type_cache.cache[type_name]
    Set global_type_cache.miss_count to global_type_cache.miss_count + 1
    Return None

Process called "cache_type_descriptor" that takes descriptor as TypeDescriptor:
    If global_type_cache.current_size is greater than or equal to global_type_cache.max_size:
        evict_least_recently_used()
    Set global_type_cache.cache[descriptor.name] to descriptor
    Set global_type_cache.access_count[descriptor.name] to 1
    Set global_type_cache.last_access[descriptor.name] to DateTime.now()
    Set global_type_cache.current_size to global_type_cache.current_size + 1

Process called "evict_least_recently_used":
    If global_type_cache.current_size is equal to 0:
        Return
    Let oldest_time be DateTime.now()
    Let oldest_key be ""
    For each key and access_time in global_type_cache.last_access:
        If DateTime.compare with first as access_time and second as oldest_time is less than 0:
            Set oldest_time to access_time
            Set oldest_key to key
    If oldest_key is not equal to "":
        Remove global_type_cache.cache[oldest_key]
        Remove global_type_cache.access_count[oldest_key]
        Remove global_type_cache.last_access[oldest_key]
        Set global_type_cache.current_size to global_type_cache.current_size - 1

Process called "clear_type_cache":
    Set global_type_cache.cache to dictionary
    Set global_type_cache.access_count to dictionary
    Set global_type_cache.last_access to dictionary
    Set global_type_cache.current_size to 0
    Set global_type_cache.hit_count to 0
    Set global_type_cache.miss_count to 0

Note: Utility functions
Process called "generate_type_id" that takes value as Any returns String:
    Let type_name be get_type_name with value as value
    Let timestamp be DateTime.now().timestamp
    Return type_name followed by "_" followed by String.from with value as timestamp

Process called "get_qualified_type_name" that takes value as Any returns String:
    Let type_name be get_type_name with value as value
    Return "stdlib.reflection." followed by type_name

Process called "is_primitive_type" that takes value as Any returns Boolean:
    Return value is Boolean or value is Integer or value is Float or value is String or value is None

Process called "is_reference_type" that takes value as Any returns Boolean:
    Return value is String or value is List or value is Dictionary

Process called "is_nullable_type" that takes value as Any returns Boolean:
    Return true

Process called "is_generic_type" that takes value as Any returns Boolean:
    Return value is List or value is Dictionary

Process called "is_abstract_type" that takes value as Any returns Boolean:
    Return false

Process called "is_sealed_type" that takes value as Any returns Boolean:
    If value is Boolean or value is Integer or value is Float or value is String:
        Return true
    Return false

Process called "is_function_type" that takes value as Any returns Boolean:
    Return false

Process called "is_array_type" that takes value as Any returns Boolean:
    Return value is List

Process called "get_generic_parameters" that takes value as Any returns List[GenericParameter]:
    Return list

Process called "get_field_descriptors" that takes value as Any returns List[FieldDescriptor]:
    Return list

Process called "get_method_descriptors" that takes value as Any returns List[MethodDescriptor]:
    Return list

Process called "get_property_descriptors" that takes value as Any returns List[PropertyDescriptor]:
    Return list

Process called "get_constructor_descriptors" that takes value as Any returns List[ConstructorDescriptor]:
    Return list

Process called "get_annotation_descriptors" that takes value as Any returns List[AnnotationDescriptor]:
    Return list

Process called "find_matching_constraint" that takes constraints as List[TypeConstraint] and constraint as TypeConstraint returns Optional[TypeConstraint]:
    For each c in constraints:
        If c.kind is equal to constraint.kind:
            Return c
    Return None