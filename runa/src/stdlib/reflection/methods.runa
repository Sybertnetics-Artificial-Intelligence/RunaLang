Note:
Runa Standard Library: Reflection Methods Module

Production-grade method reflection system providing comprehensive method introspection,
dynamic invocation, parameter inspection, and advanced method analysis capabilities.
Surpasses Java's Method reflection, C#'s MethodInfo, Python's inspect module, and
JavaScript's function introspection with enhanced features for AI development.

Features:
- Complete method signature analysis and introspection
- Dynamic method invocation with type safety
- Parameter and return type inspection
- Method overload resolution and dispatch
- Generic method instantiation and analysis
- Performance optimized method caching
- Method interception and proxying
- Async method detection and handling
:End Note

Import "../../collections" as Collections
Import "../../datetime" as DateTime
Import "../../string" as String
Import "reflection/types" as Types
Import "reflection/attributes" as Attributes

Note: Core method reflection types
Type called "MethodDescriptor":
    name as String
    qualified_name as String
    declaring_type as Types.TypeDescriptor
    return_type as Types.TypeDescriptor
    parameters as List[ParameterDescriptor]
    generic_parameters as List[Types.GenericParameter]
    access_level as Types.AccessLevel
    method_kind as MethodKind
    calling_convention as Types.CallingConvention
    is_static as Boolean
    is_virtual as Boolean
    is_abstract as Boolean
    is_override as Boolean
    is_async as Boolean
    is_generic as Boolean
    is_extension as Boolean
    is_operator as Boolean
    body_location as Optional[MethodBody]
    attributes as Attributes.AttributeCollection
    metadata as Dictionary[String, Any]
    creation_time as DateTime.DateTime

Type MethodKind is:
    | Regular
    | Constructor
    | Destructor
    | Property
    | Event
    | Operator
    | Conversion
    | Iterator
    | Lambda
    | Delegate

Type called "ParameterDescriptor":
    name as String
    position as Integer
    parameter_type as Types.TypeDescriptor
    kind as ParameterKind
    direction as ParameterDirection
    has_default as Boolean
    default_value as Optional[Any]
    is_params as Boolean
    is_optional as Boolean
    attributes as Attributes.AttributeCollection
    metadata as Dictionary[String, Any]

Type ParameterKind is:
    | Value
    | Reference
    | Output
    | Pointer
    | Array
    | Generic

Type ParameterDirection is:
    | In
    | Out
    | InOut
    | Return

Type called "MethodBody":
    source_location as Types.SourceLocation
    bytecode as Optional[List[Integer]]
    il_code as Optional[String]
    native_address as Optional[Integer]
    metadata as Dictionary[String, Any]

Type called "MethodSignature":
    name as String
    parameter_types as List[Types.TypeDescriptor]
    return_type as Types.TypeDescriptor
    generic_arity as Integer
    hash_code as Integer
    metadata as Dictionary[String, Any]

Type called "MethodInvocation":
    method as MethodDescriptor
    target as Optional[Any]
    arguments as List[Any]
    result as Optional[Any]
    exception as Optional[Exception]
    start_time as DateTime.DateTime
    end_time as Optional[DateTime.DateTime]
    execution_time as Optional[Integer]
    metadata as Dictionary[String, Any]

Type called "MethodCache":
    methods as Dictionary[String, MethodDescriptor]
    signatures as Dictionary[String, MethodSignature]
    overload_groups as Dictionary[String, List[MethodDescriptor]]
    access_count as Dictionary[String, Integer]
    last_access as Dictionary[String, DateTime.DateTime]
    max_size as Integer
    current_size as Integer
    hit_count as Integer
    miss_count as Integer
    metadata as Dictionary[String, Any]

Type called "OverloadResolver":
    candidate_methods as List[MethodDescriptor]
    argument_types as List[Types.TypeDescriptor]
    resolution_strategy as ResolutionStrategy
    exact_matches as List[MethodDescriptor]
    compatible_matches as List[MethodDescriptor]
    conversion_matches as List[MethodDescriptor]
    metadata as Dictionary[String, Any]

Type ResolutionStrategy is:
    | ExactMatch
    | BestMatch
    | FirstMatch
    | AllMatches

Note: Method discovery and inspection
Process called "get_methods" that takes target as Any returns List[MethodDescriptor]:
    Let type_descriptor be Types.get_type_descriptor with value as target
    Let methods be list
    collect_instance_methods with type_descriptor as type_descriptor and methods as methods
    collect_static_methods with type_descriptor as type_descriptor and methods as methods
    collect_inherited_methods with type_descriptor as type_descriptor and methods as methods
    Return methods

Process called "get_method" that takes target as Any and method_name as String returns Optional[MethodDescriptor]:
    Let methods be get_methods with target as target
    For each method in methods:
        If method.name is equal to method_name:
            Return method
    Return None

Process called "get_methods_by_signature" that takes target as Any and signature as MethodSignature returns List[MethodDescriptor]:
    Let methods be get_methods with target as target
    Let matching_methods be list
    For each method in methods:
        If signatures_match with method_sig as create_signature_from_method with method as method and target_sig as signature:
            Add method to matching_methods
    Return matching_methods

Process called "get_overloads" that takes target as Any and method_name as String returns List[MethodDescriptor]:
    Let methods be get_methods with target as target
    Let overloads be list
    For each method in methods:
        If method.name is equal to method_name:
            Add method to overloads
    Return overloads

Process called "find_method" that takes target as Any and method_name as String and parameter_types as List[Types.TypeDescriptor] returns Optional[MethodDescriptor]:
    Let overloads be get_overloads with target as target and method_name as method_name
    Let resolver be create_overload_resolver with candidates as overloads and argument_types as parameter_types
    Let resolved_method be resolve_best_overload with resolver as resolver
    Return resolved_method

Note: Method signature analysis
Process called "create_method_signature" that takes name as String and parameter_types as List[Types.TypeDescriptor] and return_type as Types.TypeDescriptor returns MethodSignature:
    Let hash_value be calculate_signature_hash with name as name and parameter_types as parameter_types and return_type as return_type
    Return MethodSignature with:
        name as name
        parameter_types as parameter_types
        return_type as return_type
        generic_arity as count_generic_parameters with parameter_types as parameter_types
        hash_code as hash_value
        metadata as dictionary

Process called "create_signature_from_method" that takes method as MethodDescriptor returns MethodSignature:
    Let parameter_types be list
    For each param in method.parameters:
        Add param.parameter_type to parameter_types
    Return create_method_signature with name as method.name and parameter_types as parameter_types and return_type as method.return_type

Process called "signatures_match" that takes method_sig as MethodSignature and target_sig as MethodSignature returns Boolean:
    If method_sig.name is not equal to target_sig.name:
        Return false
    If Collections.List.length with lst as method_sig.parameter_types is not equal to Collections.List.length with lst as target_sig.parameter_types:
        Return false
    For i from 0 to Collections.List.length with lst as method_sig.parameter_types - 1:
        Let method_param_type be method_sig.parameter_types at index i
        Let target_param_type be target_sig.parameter_types at index i
        If not Types.types_are_compatible with source as method_param_type and target as target_param_type:
            Return false
    Return Types.types_are_compatible with source as method_sig.return_type and target as target_sig.return_type

Process called "calculate_signature_hash" that takes name as String and parameter_types as List[Types.TypeDescriptor] and return_type as Types.TypeDescriptor returns Integer:
    Let hash_value be String.hash with str as name
    For each param_type in parameter_types:
        Let param_hash be String.hash with str as param_type.type_id
        Set hash_value to hash_value XOR param_hash
    Let return_hash be String.hash with str as return_type.type_id
    Set hash_value to hash_value XOR return_hash
    Return hash_value

Note: Dynamic method invocation
Process called "invoke" that takes method as MethodDescriptor and target as Optional[Any] and arguments as List[Any] returns Any:
    Let invocation be create_invocation with method as method and target as target and arguments as arguments
    If not validate_invocation with invocation as invocation:
        Set invocation.exception to Exception with message as "Invalid method invocation"
        Set invocation.end_time to DateTime.now()
        Return None
    Set invocation.start_time to DateTime.now()
    Let result be execute_method_invocation with invocation as invocation
    Set invocation.result to result
    Set invocation.end_time to DateTime.now()
    Set invocation.execution_time to DateTime.milliseconds_between with start as invocation.start_time and end as invocation.end_time
    Return result

Process called "invoke_static" that takes method as MethodDescriptor and arguments as List[Any] returns Any:
    If not method.is_static:
        Return None
    Return invoke with method as method and target as None and arguments as arguments

Process called "invoke_generic" that takes method as MethodDescriptor and type_arguments as List[Types.TypeDescriptor] and target as Optional[Any] and arguments as List[Any] returns Any:
    If not method.is_generic:
        Return None
    Let instantiated_method be instantiate_generic_method with method as method and type_arguments as type_arguments
    Return invoke with method as instantiated_method and target as target and arguments as arguments

Process called "create_invocation" that takes method as MethodDescriptor and target as Optional[Any] and arguments as List[Any] returns MethodInvocation:
    Return MethodInvocation with:
        method as method
        target as target
        arguments as arguments
        result as None
        exception as None
        start_time as DateTime.now()
        end_time as None
        execution_time as None
        metadata as dictionary

Process called "validate_invocation" that takes invocation as MethodInvocation returns Boolean:
    If invocation.method.is_static and invocation.target is not None:
        Return false
    If not invocation.method.is_static and invocation.target is None:
        Return false
    If Collections.List.length with lst as invocation.arguments is not equal to Collections.List.length with lst as invocation.method.parameters:
        Return false
    For i from 0 to Collections.List.length with lst as invocation.arguments - 1:
        Let argument be invocation.arguments at index i
        Let parameter be invocation.method.parameters at index i
        Let argument_type be Types.get_type_descriptor with value as argument
        If not Types.types_are_compatible with source as argument_type and target as parameter.parameter_type:
            Return false
    Return true

Process called "execute_method_invocation" that takes invocation as MethodInvocation returns Any:
    Match invocation.method.method_kind:
        When Regular:
            Return execute_regular_method with invocation as invocation
        When Constructor:
            Return execute_constructor_method with invocation as invocation
        When Property:
            Return execute_property_method with invocation as invocation
        When Operator:
            Return execute_operator_method with invocation as invocation
        Otherwise:
            Return None

Note: Overload resolution
Process called "create_overload_resolver" that takes candidates as List[MethodDescriptor] and argument_types as List[Types.TypeDescriptor] returns OverloadResolver:
    Return OverloadResolver with:
        candidate_methods as candidates
        argument_types as argument_types
        resolution_strategy as BestMatch
        exact_matches as list
        compatible_matches as list
        conversion_matches as list
        metadata as dictionary

Process called "resolve_best_overload" that takes resolver as OverloadResolver returns Optional[MethodDescriptor]:
    categorize_overloads with resolver as resolver
    Match resolver.resolution_strategy:
        When ExactMatch:
            If Collections.List.length with lst as resolver.exact_matches is greater than 0:
                Return resolver.exact_matches at index 0
            Return None
        When BestMatch:
            Return find_best_match with resolver as resolver
        When FirstMatch:
            Return find_first_match with resolver as resolver
        When AllMatches:
            Return None
        Otherwise:
            Return None

Process called "categorize_overloads" that takes resolver as OverloadResolver:
    For each method in resolver.candidate_methods:
        Let match_quality be evaluate_parameter_match with method as method and argument_types as resolver.argument_types
        Match match_quality:
            When ExactMatch:
                Add method to resolver.exact_matches
            When Compatible:
                Add method to resolver.compatible_matches
            When ConversionRequired:
                Add method to resolver.conversion_matches
            Otherwise:
                Continue

Process called "evaluate_parameter_match" that takes method as MethodDescriptor and argument_types as List[Types.TypeDescriptor] returns MatchQuality:
    If Collections.List.length with lst as method.parameters is not equal to Collections.List.length with lst as argument_types:
        Return NoMatch
    Let has_exact_match be true
    Let has_compatible_match be true
    For i from 0 to Collections.List.length with lst as argument_types - 1:
        Let arg_type be argument_types at index i
        Let param_type be method.parameters at index i
        If Types.types_are_compatible with source as arg_type and target as param_type.parameter_type:
            If arg_type.type_id is not equal to param_type.parameter_type.type_id:
                Set has_exact_match to false
        Otherwise:
            Set has_exact_match to false
            If not Types.can_cast with from_type as arg_type and to_type as param_type.parameter_type:
                Set has_compatible_match to false
    If has_exact_match:
        Return ExactMatch
    If has_compatible_match:
        Return Compatible
    Return ConversionRequired

Type MatchQuality is:
    | ExactMatch
    | Compatible
    | ConversionRequired
    | NoMatch

Process called "find_best_match" that takes resolver as OverloadResolver returns Optional[MethodDescriptor]:
    If Collections.List.length with lst as resolver.exact_matches is greater than 0:
        Return resolver.exact_matches at index 0
    If Collections.List.length with lst as resolver.compatible_matches is greater than 0:
        Return resolver.compatible_matches at index 0
    If Collections.List.length with lst as resolver.conversion_matches is greater than 0:
        Return resolver.conversion_matches at index 0
    Return None

Process called "find_first_match" that takes resolver as OverloadResolver returns Optional[MethodDescriptor]:
    If Collections.List.length with lst as resolver.candidate_methods is greater than 0:
        Return resolver.candidate_methods at index 0
    Return None

Note: Generic method handling
Process called "instantiate_generic_method" that takes method as MethodDescriptor and type_arguments as List[Types.TypeDescriptor] returns MethodDescriptor:
    If not method.is_generic:
        Return method
    Let instantiated_parameters be list
    For each param in method.parameters:
        Let instantiated_param_type be substitute_generic_parameters with type_descriptor as param.parameter_type and type_arguments as type_arguments
        Let instantiated_param be ParameterDescriptor with:
            name as param.name
            position as param.position
            parameter_type as instantiated_param_type
            kind as param.kind
            direction as param.direction
            has_default as param.has_default
            default_value as param.default_value
            is_params as param.is_params
            is_optional as param.is_optional
            attributes as param.attributes
            metadata as param.metadata
        Add instantiated_param to instantiated_parameters
    Let instantiated_return_type be substitute_generic_parameters with type_descriptor as method.return_type and type_arguments as type_arguments
    Return MethodDescriptor with:
        name as method.name
        qualified_name as method.qualified_name
        declaring_type as method.declaring_type
        return_type as instantiated_return_type
        parameters as instantiated_parameters
        generic_parameters as list
        access_level as method.access_level
        method_kind as method.method_kind
        calling_convention as method.calling_convention
        is_static as method.is_static
        is_virtual as method.is_virtual
        is_abstract as method.is_abstract
        is_override as method.is_override
        is_async as method.is_async
        is_generic as false
        is_extension as method.is_extension
        is_operator as method.is_operator
        body_location as method.body_location
        attributes as method.attributes
        metadata as method.metadata
        creation_time as method.creation_time

Process called "substitute_generic_parameters" that takes type_descriptor as Types.TypeDescriptor and type_arguments as List[Types.TypeDescriptor] returns Types.TypeDescriptor:
    If not type_descriptor.is_generic:
        Return type_descriptor
    Note: In a real implementation, this would perform actual generic substitution
    Return type_descriptor

Note: Method caching
Let global_method_cache be initialize_method_cache()

Process called "initialize_method_cache" returns MethodCache:
    Return MethodCache with:
        methods as dictionary
        signatures as dictionary
        overload_groups as dictionary
        access_count as dictionary
        last_access as dictionary
        max_size as 5000
        current_size as 0
        hit_count as 0
        miss_count as 0
        metadata as dictionary

Process called "get_cached_method" that takes method_key as String returns Optional[MethodDescriptor]:
    If Collections.Dict.contains_key with dict as global_method_cache.methods and key as method_key:
        Set global_method_cache.hit_count to global_method_cache.hit_count + 1
        Set global_method_cache.access_count[method_key] to global_method_cache.access_count[method_key] + 1
        Set global_method_cache.last_access[method_key] to DateTime.now()
        Return global_method_cache.methods[method_key]
    Set global_method_cache.miss_count to global_method_cache.miss_count + 1
    Return None

Process called "cache_method" that takes method as MethodDescriptor:
    Let method_key be generate_method_key with method as method
    If global_method_cache.current_size is greater than or equal to global_method_cache.max_size:
        evict_least_used_method()
    Set global_method_cache.methods[method_key] to method
    Set global_method_cache.access_count[method_key] to 1
    Set global_method_cache.last_access[method_key] to DateTime.now()
    Set global_method_cache.current_size to global_method_cache.current_size + 1

Process called "evict_least_used_method":
    If global_method_cache.current_size is equal to 0:
        Return
    Let least_used_key be ""
    Let least_access_count be 1000000
    For each key and access_count in global_method_cache.access_count:
        If access_count is less than least_access_count:
            Set least_access_count to access_count
            Set least_used_key to key
    If least_used_key is not equal to "":
        Remove global_method_cache.methods[least_used_key]
        Remove global_method_cache.access_count[least_used_key]
        Remove global_method_cache.last_access[least_used_key]
        Set global_method_cache.current_size to global_method_cache.current_size - 1

Process called "clear_method_cache":
    Set global_method_cache.methods to dictionary
    Set global_method_cache.signatures to dictionary
    Set global_method_cache.overload_groups to dictionary
    Set global_method_cache.access_count to dictionary
    Set global_method_cache.last_access to dictionary
    Set global_method_cache.current_size to 0
    Set global_method_cache.hit_count to 0
    Set global_method_cache.miss_count to 0

Note: Utility functions
Process called "collect_instance_methods" that takes type_descriptor as Types.TypeDescriptor and methods as List[MethodDescriptor]:
    Note: Collect instance methods from type
    Return

Process called "collect_static_methods" that takes type_descriptor as Types.TypeDescriptor and methods as List[MethodDescriptor]:
    Note: Collect static methods from type
    Return

Process called "collect_inherited_methods" that takes type_descriptor as Types.TypeDescriptor and methods as List[MethodDescriptor]:
    Note: Collect inherited methods from base types
    Return

Process called "execute_regular_method" that takes invocation as MethodInvocation returns Any:
    Note: Execute regular method
    Return "method_result"

Process called "execute_constructor_method" that takes invocation as MethodInvocation returns Any:
    Note: Execute constructor method
    Return invocation.target

Process called "execute_property_method" that takes invocation as MethodInvocation returns Any:
    Note: Execute property getter/setter
    Return "property_value"

Process called "execute_operator_method" that takes invocation as MethodInvocation returns Any:
    Note: Execute operator method
    Return "operator_result"

Process called "count_generic_parameters" that takes parameter_types as List[Types.TypeDescriptor] returns Integer:
    Let count be 0
    For each param_type in parameter_types:
        If param_type.is_generic:
            Set count to count + 1
    Return count

Process called "generate_method_key" that takes method as MethodDescriptor returns String:
    Let signature be create_signature_from_method with method as method
    Return method.declaring_type.type_id followed by "." followed by method.name followed by "_" followed by String.from with value as signature.hash_code

Note: Method analysis and inspection
Process called "analyze_method_complexity" that takes method as MethodDescriptor returns Dictionary[String, Any]:
    Let analysis be dictionary
    Set analysis["parameter_count"] to Collections.List.length with lst as method.parameters
    Set analysis["is_generic"] to method.is_generic
    Set analysis["is_async"] to method.is_async
    Set analysis["is_virtual"] to method.is_virtual
    Set analysis["complexity_score"] to calculate_method_complexity_score with method as method
    Return analysis

Process called "calculate_method_complexity_score" that takes method as MethodDescriptor returns Integer:
    Let score be 1
    Set score to score + Collections.List.length with lst as method.parameters
    If method.is_generic:
        Set score to score + 2
    If method.is_virtual:
        Set score to score + 1
    If method.is_async:
        Set score to score + 2
    Return score

Process called "get_method_dependencies" that takes method as MethodDescriptor returns List[Types.TypeDescriptor]:
    Let dependencies be list
    Add method.return_type to dependencies
    For each param in method.parameters:
        Add param.parameter_type to dependencies
    Return dependencies