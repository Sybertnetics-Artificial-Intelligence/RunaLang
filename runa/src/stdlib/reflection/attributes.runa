Note:
Runa Standard Library: Reflection Attributes Module

Production-grade attribute reflection system providing comprehensive attribute inspection,
metadata management, annotation processing, and dynamic attribute manipulation.
Surpasses Java's annotations, C#'s attributes, Python's decorators, and TypeScript's
decorators with enhanced features for AI development.

Features:
- Complete attribute and annotation system
- Runtime attribute inspection and manipulation
- Custom attribute definition and validation
- Attribute inheritance and composition
- Performance optimized attribute caching
- Type-safe attribute access
- Attribute-based code generation
- Validation and constraint attributes
:End Note

Import "../../collections" as Collections
Import "../../datetime" as DateTime
Import "../../string" as String
Import "reflection/types" as Types

Note: Core attribute types
Type called "Attribute":
    name as String
    type_descriptor as Types.TypeDescriptor
    value as Any
    target_type as AttributeTarget
    is_inherited as Boolean
    is_required as Boolean
    is_validated as Boolean
    validator as Optional[AttributeValidator]
    metadata as Dictionary[String, Any]
    creation_time as DateTime.DateTime

Type AttributeTarget is:
    | Class
    | Method
    | Property
    | Field
    | Parameter
    | ReturnValue
    | Assembly
    | Module
    | Interface
    | Enum
    | Constructor
    | Event
    | Delegate
    | GenericParameter
    | All

Type called "AttributeValidator":
    validation_function as Function[Any, Boolean]
    error_message as String
    metadata as Dictionary[String, Any]

Type called "AttributeCollection":
    attributes as Dictionary[String, List[Attribute]]
    target_object as Any
    target_type as Types.TypeDescriptor
    is_cached as Boolean
    cache_timestamp as DateTime.DateTime
    metadata as Dictionary[String, Any]

Type called "AttributeQuery":
    attribute_name as Optional[String]
    attribute_type as Optional[Types.TypeDescriptor]
    target_type as Optional[AttributeTarget]
    is_inherited as Optional[Boolean]
    filters as List[AttributeFilter]
    metadata as Dictionary[String, Any]

Type called "AttributeFilter":
    filter_function as Function[Attribute, Boolean]
    description as String
    metadata as Dictionary[String, Any]

Type called "CustomAttribute":
    base_attribute as Attribute
    custom_properties as Dictionary[String, Any]
    behavior as AttributeBehavior
    metadata as Dictionary[String, Any]

Type called "AttributeBehavior":
    on_apply as Optional[Function[Any, Any]]
    on_remove as Optional[Function[Any, Any]]
    on_validate as Optional[Function[Any, Boolean]]
    metadata as Dictionary[String, Any]

Type called "AttributeDefinition":
    name as String
    required_properties as List[String]
    optional_properties as List[String]
    valid_targets as List[AttributeTarget]
    is_inheritable as Boolean
    allows_multiple as Boolean
    validator as Optional[AttributeValidator]
    metadata as Dictionary[String, Any]

Note: Built-in attribute definitions
Let DEPRECATED_ATTRIBUTE be AttributeDefinition with:
    name as "Deprecated"
    required_properties as list containing
    optional_properties as list containing "message", "version", "replacement"
    valid_targets as list containing Class, Method, Property, Field
    is_inheritable as false
    allows_multiple as false
    validator as None
    metadata as dictionary containing

Let REQUIRED_ATTRIBUTE be AttributeDefinition with:
    name as "Required"
    required_properties as list containing
    optional_properties as list containing "error_message"
    valid_targets as list containing Property, Field, Parameter
    is_inheritable as false
    allows_multiple as false
    validator as None
    metadata as dictionary containing

Let VALIDATION_ATTRIBUTE be AttributeDefinition with:
    name as "Validation"
    required_properties as list containing "validator"
    optional_properties as list containing "error_message", "allow_null"
    valid_targets as list containing Property, Field, Parameter
    is_inheritable as true
    allows_multiple as true
    validator as None
    metadata as dictionary containing

Let CACHED_ATTRIBUTE be AttributeDefinition with:
    name as "Cached"
    required_properties as list containing
    optional_properties as list containing "ttl", "key", "invalidate_on"
    valid_targets as list containing Method, Property
    is_inheritable as false
    allows_multiple as false
    validator as None
    metadata as dictionary containing

Note: Attribute inspection and access
Process called "get_attributes" that takes target as Any returns AttributeCollection:
    Let type_descriptor be Types.get_type_descriptor with value as target
    Let attributes be dictionary
    collect_class_attributes with target as target and attributes as attributes
    collect_field_attributes with target as target and attributes as attributes
    collect_method_attributes with target as target and attributes as attributes
    collect_property_attributes with target as target and attributes as attributes
    Return AttributeCollection with:
        attributes as attributes
        target_object as target
        target_type as type_descriptor
        is_cached as true
        cache_timestamp as DateTime.now()
        metadata as dictionary

Process called "get_attribute" that takes target as Any and attribute_name as String returns Optional[Attribute]:
    Let collection be get_attributes with target as target
    If Collections.Dict.contains_key with dict as collection.attributes and key as attribute_name:
        Let attribute_list be collection.attributes[attribute_name]
        If Collections.List.length with lst as attribute_list is greater than 0:
            Return attribute_list at index 0
    Return None

Process called "has_attribute" that takes target as Any and attribute_name as String returns Boolean:
    Let attribute be get_attribute with target as target and attribute_name as attribute_name
    Return attribute is not None

Process called "get_attributes_by_type" that takes target as Any and attribute_type as Types.TypeDescriptor returns List[Attribute]:
    Let collection be get_attributes with target as target
    Let matching_attributes be list
    For each attribute_name and attribute_list in collection.attributes:
        For each attribute in attribute_list:
            If Types.types_are_compatible with source as attribute.type_descriptor and target as attribute_type:
                Add attribute to matching_attributes
    Return matching_attributes

Process called "query_attributes" that takes target as Any and query as AttributeQuery returns List[Attribute]:
    Let collection be get_attributes with target as target
    Let matching_attributes be list
    For each attribute_name and attribute_list in collection.attributes:
        For each attribute in attribute_list:
            If attribute_matches_query with attribute as attribute and query as query:
                Add attribute to matching_attributes
    Return matching_attributes

Process called "attribute_matches_query" that takes attribute as Attribute and query as AttributeQuery returns Boolean:
    If query.attribute_name is not None and attribute.name is not equal to query.attribute_name:
        Return false
    If query.attribute_type is not None and not Types.types_are_compatible with source as attribute.type_descriptor and target as query.attribute_type:
        Return false
    If query.target_type is not None and attribute.target_type is not equal to query.target_type:
        Return false
    If query.is_inherited is not None and attribute.is_inherited is not equal to query.is_inherited:
        Return false
    For each filter in query.filters:
        If not filter.filter_function with arg as attribute:
            Return false
    Return true

Note: Attribute manipulation
Process called "set_attribute" that takes target as Any and attribute as Attribute returns Boolean:
    If not validate_attribute_target with attribute as attribute and target as target:
        Return false
    If not validate_attribute with attribute as attribute:
        Return false
    Let collection be get_attributes with target as target
    If not Collections.Dict.contains_key with dict as collection.attributes and key as attribute.name:
        Set collection.attributes[attribute.name] to list
    Let attribute_list be collection.attributes[attribute.name]
    Let existing_index be find_existing_attribute with attribute_list as attribute_list and attribute as attribute
    If existing_index is not equal to -1:
        Set attribute_list at index existing_index to attribute
    Otherwise:
        Add attribute to attribute_list
    Set collection.cache_timestamp to DateTime.now()
    If attribute.behavior is not None and attribute.behavior.on_apply is not None:
        attribute.behavior.on_apply with arg as target
    Return true

Process called "remove_attribute" that takes target as Any and attribute_name as String returns Boolean:
    Let collection be get_attributes with target as target
    If not Collections.Dict.contains_key with dict as collection.attributes and key as attribute_name:
        Return false
    Let attribute_list be collection.attributes[attribute_name]
    If Collections.List.length with lst as attribute_list is equal to 0:
        Return false
    Let removed_attribute be attribute_list at index 0
    Remove attribute_list at index 0
    If Collections.List.length with lst as attribute_list is equal to 0:
        Remove collection.attributes[attribute_name]
    Set collection.cache_timestamp to DateTime.now()
    If removed_attribute.behavior is not None and removed_attribute.behavior.on_remove is not None:
        removed_attribute.behavior.on_remove with arg as target
    Return true

Process called "update_attribute" that takes target as Any and attribute_name as String and new_value as Any returns Boolean:
    Let attribute be get_attribute with target as target and attribute_name as attribute_name
    If attribute is None:
        Return false
    Let old_value be attribute.value
    Set attribute.value to new_value
    If not validate_attribute with attribute as attribute:
        Set attribute.value to old_value
        Return false
    Return true

Note: Attribute creation and validation
Process called "create_attribute" that takes name as String and value as Any and target_type as AttributeTarget returns Attribute:
    Let type_descriptor be Types.get_type_descriptor with value as value
    Return Attribute with:
        name as name
        type_descriptor as type_descriptor
        value as value
        target_type as target_type
        is_inherited as false
        is_required as false
        is_validated as false
        validator as None
        metadata as dictionary
        creation_time as DateTime.now()

Process called "create_custom_attribute" that takes definition as AttributeDefinition and properties as Dictionary[String, Any] and target_type as AttributeTarget returns CustomAttribute:
    Let base_attribute be create_attribute with name as definition.name and value as properties and target_type as target_type
    Return CustomAttribute with:
        base_attribute as base_attribute
        custom_properties as properties
        behavior as AttributeBehavior with:
            on_apply as None
            on_remove as None
            on_validate as None
            metadata as dictionary
        metadata as dictionary

Process called "validate_attribute" that takes attribute as Attribute returns Boolean:
    If attribute.validator is not None:
        Let validation_result be attribute.validator.validation_function with arg as attribute.value
        If not validation_result:
            Return false
    If attribute.behavior is not None and attribute.behavior.on_validate is not None:
        Return attribute.behavior.on_validate with arg as attribute.value
    Return true

Process called "validate_attribute_target" that takes attribute as Attribute and target as Any returns Boolean:
    Let target_type_descriptor be Types.get_type_descriptor with value as target
    Match attribute.target_type:
        When Class:
            Return target_type_descriptor.kind is equal to Types.Reference
        When Method:
            Return is_method_target with target as target
        When Property:
            Return is_property_target with target as target
        When Field:
            Return is_field_target with target as target
        When All:
            Return true
        Otherwise:
            Return true

Process called "create_validator" that takes validation_function as Function[Any, Boolean] and error_message as String returns AttributeValidator:
    Return AttributeValidator with:
        validation_function as validation_function
        error_message as error_message
        metadata as dictionary

Note: Attribute inheritance and composition
Process called "resolve_inherited_attributes" that takes target as Any returns List[Attribute]:
    Let type_descriptor be Types.get_type_descriptor with value as target
    Let inherited_attributes be list
    For each base_type in type_descriptor.base_types:
        Let base_attributes be get_attributes_from_type with type_descriptor as base_type
        For each attribute in base_attributes:
            If attribute.is_inherited:
                Add attribute to inherited_attributes
    Return inherited_attributes

Process called "merge_attribute_collections" that takes primary as AttributeCollection and secondary as AttributeCollection returns AttributeCollection:
    Let merged_attributes be dictionary
    Note: Add all secondary attributes first
    For each attribute_name and attribute_list in secondary.attributes:
        Set merged_attributes[attribute_name] to Collections.List.copy with lst as attribute_list
    Note: Override with primary attributes
    For each attribute_name and attribute_list in primary.attributes:
        If Collections.Dict.contains_key with dict as merged_attributes and key as attribute_name:
            Let existing_list be merged_attributes[attribute_name]
            For each attribute in attribute_list:
                Let existing_index be find_existing_attribute with attribute_list as existing_list and attribute as attribute
                If existing_index is not equal to -1:
                    Set existing_list at index existing_index to attribute
                Otherwise:
                    Add attribute to existing_list
        Otherwise:
            Set merged_attributes[attribute_name] to Collections.List.copy with lst as attribute_list
    Return AttributeCollection with:
        attributes as merged_attributes
        target_object as primary.target_object
        target_type as primary.target_type
        is_cached as false
        cache_timestamp as DateTime.now()
        metadata as dictionary

Note: Built-in attribute processors
Process called "process_deprecated_attribute" that takes target as Any and attribute as Attribute returns Boolean:
    Let message be "This member is deprecated"
    If Collections.Dict.contains_key with dict as attribute.metadata and key as "message":
        Set message to attribute.metadata["message"]
    Note: In a real implementation, this would emit a warning
    Return true

Process called "process_required_attribute" that takes target as Any and attribute as Attribute returns Boolean:
    If attribute.value is None:
        Return false
    If attribute.value is String and String.length with str as attribute.value is equal to 0:
        Return false
    Return true

Process called "process_validation_attribute" that takes target as Any and attribute as Attribute returns Boolean:
    If not Collections.Dict.contains_key with dict as attribute.metadata and key as "validator":
        Return true
    Let validator_function be attribute.metadata["validator"]
    Return validator_function with arg as attribute.value

Process called "process_cached_attribute" that takes target as Any and attribute as Attribute returns Any:
    Let cache_key be generate_cache_key with target as target and attribute as attribute
    Let cached_value be get_cached_value with key as cache_key
    If cached_value is not None:
        Return cached_value
    Note: In a real implementation, this would execute the method and cache the result
    Return None

Note: Utility functions
Process called "collect_class_attributes" that takes target as Any and attributes as Dictionary[String, List[Attribute]]:
    Note: Collect attributes applied to the class itself
    Let deprecated_attr be create_attribute with name as "Deprecated" and value as true and target_type as Class
    If not Collections.Dict.contains_key with dict as attributes and key as "Deprecated":
        Set attributes["Deprecated"] to list containing
    Add deprecated_attr to attributes["Deprecated"]

Process called "collect_field_attributes" that takes target as Any and attributes as Dictionary[String, List[Attribute]]:
    Note: Collect attributes applied to fields
    Return

Process called "collect_method_attributes" that takes target as Any and attributes as Dictionary[String, List[Attribute]]:
    Note: Collect attributes applied to methods
    Return

Process called "collect_property_attributes" that takes target as Any and attributes as Dictionary[String, List[Attribute]]:
    Note: Collect attributes applied to properties
    Return

Process called "get_attributes_from_type" that takes type_descriptor as Types.TypeDescriptor returns List[Attribute]:
    Note: Get attributes from a type descriptor
    Return list

Process called "find_existing_attribute" that takes attribute_list as List[Attribute] and attribute as Attribute returns Integer:
    For i from 0 to Collections.List.length with lst as attribute_list - 1:
        Let existing_attr be attribute_list at index i
        If existing_attr.name is equal to attribute.name and existing_attr.target_type is equal to attribute.target_type:
            Return i
    Return -1

Process called "is_method_target" that takes target as Any returns Boolean:
    Note: Check if target represents a method
    Return false

Process called "is_property_target" that takes target as Any returns Boolean:
    Note: Check if target represents a property
    Return false

Process called "is_field_target" that takes target as Any returns Boolean:
    Note: Check if target represents a field
    Return false

Process called "generate_cache_key" that takes target as Any and attribute as Attribute returns String:
    Let type_name be Types.get_type_name with value as target
    Return type_name followed by "." followed by attribute.name followed by "_" followed by String.from with value as DateTime.now().timestamp

Process called "get_cached_value" that takes key as String returns Optional[Any]:
    Note: In a real implementation, this would check a cache
    Return None

Note: Attribute query builders
Process called "create_attribute_query" returns AttributeQuery:
    Return AttributeQuery with:
        attribute_name as None
        attribute_type as None
        target_type as None
        is_inherited as None
        filters as list
        metadata as dictionary

Process called "with_name" that takes query as AttributeQuery and name as String returns AttributeQuery:
    Set query.attribute_name to name
    Return query

Process called "with_type" that takes query as AttributeQuery and type_descriptor as Types.TypeDescriptor returns AttributeQuery:
    Set query.attribute_type to type_descriptor
    Return query

Process called "with_target_type" that takes query as AttributeQuery and target_type as AttributeTarget returns AttributeQuery:
    Set query.target_type to target_type
    Return query

Process called "with_inherited" that takes query as AttributeQuery and inherited as Boolean returns AttributeQuery:
    Set query.is_inherited to inherited
    Return query

Process called "with_filter" that takes query as AttributeQuery and filter as AttributeFilter returns AttributeQuery:
    Add filter to query.filters
    Return query

Process called "create_attribute_filter" that takes filter_function as Function[Attribute, Boolean] and description as String returns AttributeFilter:
    Return AttributeFilter with:
        filter_function as filter_function
        description as description
        metadata as dictionary