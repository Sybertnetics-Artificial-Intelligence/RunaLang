Note:
Runa Scientific Computing: Advanced I/O Operations

Comprehensive data I/O operations for scientific computing, supporting multiple
formats and providing high-performance reading/writing capabilities.

Features:
- CSV with advanced parsing (custom delimiters, quote handling, type inference)
- JSON with scientific data extensions (complex numbers, arrays)
- Binary formats (NumPy .npy, .npz archives)
- Text formats with flexible parsing
- Memory-mapped file access for large datasets
- Streaming I/O for processing data larger than memory
- Compression support (gzip, bz2, lzma)
- Metadata preservation and schema validation
- Cross-platform path handling and encoding detection
:End Note

Import "scientific/core/ndarray" as NDArray
Import "collections" as Collections
Import "string" as String
Import "io/file" as FileIO
Import "compress/gzip" as GZip

Type called "DataFile":
    file_path as String
    format as DataFormat
    encoding as String
    compression as Optional[CompressionType]
    metadata as Dictionary[String, Any]
    schema as Optional[DataSchema]
    size_bytes as Integer
    last_modified as Integer
    checksum as Optional[String]

Type DataFormat is:
    | CSV
    | JSON
    | Binary
    | Text
    | HDF5
    | NetCDF
    | Parquet
    | Excel

Type CompressionType is:
    | None_
    | GZip_
    | BZ2
    | LZMA
    | ZIP

Type called "DataSchema":
    column_names as List[String]
    column_types as List[DataType]
    nullable_columns as List[Boolean]
    constraints as List[ColumnConstraint]
    primary_key as Optional[List[String]]
    foreign_keys as List[ForeignKey]
    metadata as Dictionary[String, Any]

Type DataType is:
    | Integer32
    | Integer64
    | Float32
    | Float64
    | Complex64
    | Complex128
    | String_
    | Boolean_
    | DateTime
    | Category

Type called "ColumnConstraint":
    column as String
    constraint_type as ConstraintType
    value as Any

Type ConstraintType is:
    | NotNull
    | Unique
    | MinValue
    | MaxValue
    | Range
    | Pattern

Type called "ForeignKey":
    columns as List[String]
    reference_table as String
    reference_columns as List[String]

Type called "CSVOptions":
    delimiter as String
    quote_char as String
    escape_char as Optional[String]
    line_terminator as String
    skip_initial_space as Boolean
    has_header as Boolean
    infer_types as Boolean
    na_values as List[String]
    date_format as Optional[String]
    decimal as String
    thousands as Optional[String]
    encoding as String
    chunk_size as Optional[Integer]

Type called "JSONOptions":
    indent as Optional[Integer]
    ensure_ascii as Boolean
    sort_keys as Boolean
    compact as Boolean
    handle_complex as Boolean
    handle_ndarray as Boolean
    precision as Optional[Integer]

Type called "StreamReader":
    file_handle as Any
    buffer_size as Integer
    current_position as Integer
    total_size as Optional[Integer]
    encoding as String
    compression as Optional[CompressionType]
    chunk_iterator as Optional[Any]

Type called "StreamWriter":
    file_handle as Any
    buffer_size as Integer
    bytes_written as Integer
    compression as Optional[CompressionType]
    flush_threshold as Integer
    auto_flush as Boolean

Note: CSV I/O operations
Process called "read_csv" that takes file_path as String and options as Optional[CSVOptions] returns NDArray.NDArray:
    Let csv_opts be options or create_default_csv_options()
    Let file_handle be FileIO.open with path as file_path and mode as "r" and encoding as csv_opts.encoding Let data_rows be list containing
    Let header be None
    Let line_number be 0 Note: Read file line by line
    Let current_line be FileIO.readline with handle as file_handle
    While current_line is not empty:
    Set line_number to line_number 1 If line_number is equal to 1 and csv_opts.has_header:
    Set header to parse_csv_line with line as current_line and options as csv_opts
    Otherwise:
    Let parsed_row be parse_csv_line with line as current_line and options as csv_opts
    Add parsed_row to data_rows Set current_line to FileIO.readline with handle as file_handle FileIO.close with handle as file_handle Note: Convert to NDArray
    Return convert_rows_to_ndarray with rows as data_rows and header as header and options as csv_opts

Process called "write_csv" that takes data as NDArray.NDArray and file_path as String and options as Optional[CSVOptions] returns Boolean:
    Let csv_opts be options or create_default_csv_options()
    Let file_handle be FileIO.open with path as file_path and mode as "w" and encoding as csv_opts.encoding Note: Write header if specified
    If csv_opts.has_header:
    Let header_line be create_header_line with data as data and options as csv_opts
    FileIO.write with handle as file_handle and content as header_line
    FileIO.write with handle as file_handle and content as csv_opts.line_terminator Note: Write data rows
    For i from 0 to data.shape at index 0 - 1:
    Let row_data be extract_row with array as data and row_index as i
    Let csv_line be format_csv_line with row as row_data and options as csv_opts
    FileIO.write with handle as file_handle and content as csv_line
    FileIO.write with handle as file_handle and content as csv_opts.line_terminator FileIO.close with handle as file_handle
    Return true

Process called "parse_csv_line" that takes line as String and options as CSVOptions returns List[String]:
    Let fields be list containing
    Let current_field be ""
    Let in_quotes be false
    Let i be 0 While i is less than String.length with str as line:
    Let char be String.char_at with str as line and index as i If char is equal to options.quote_char:
    Set in_quotes to not in_quotes
    Otherwise if char is equal to options.delimiter and not in_quotes:
    Let trimmed_field be if options.skip_initial_space then String.trim with str as current_field else current_field
    Add trimmed_field to fields
    Set current_field to ""
    Otherwise:
    Set current_field to current_field followed by char Set i to i 1 Note: Add last field
    Let trimmed_field be if options.skip_initial_space then String.trim with str as current_field else current_field
    Add trimmed_field to fields Return fields

Note: JSON I/O operations
Process called "read_json" that takes file_path as String and options as Optional[JSONOptions] returns Dictionary[String, Any]:
    Let json_opts be options or create_default_json_options()
    Let file_content be FileIO.read_all with path as file_path Let parsed_data be parse_json_string with content as file_content and options as json_opts
    Return parsed_data

Process called "write_json" that takes data as Dictionary[String, Any] and file_path as String and options as Optional[JSONOptions] returns Boolean:
    Let json_opts be options or create_default_json_options()
    Let json_string be serialize_to_json with data as data and options as json_opts Return FileIO.write_all with path as file_path and content as json_string

Process called "serialize_to_json" that takes data as Any and options as JSONOptions returns String:
    Match data:
    When data is Dictionary:
    Return serialize_dict_to_json with dict as data and options as options
    When data is List:
    Return serialize_list_to_json with list as data and options as options
    When data is NDArray.NDArray and options.handle_ndarray:
    Return serialize_ndarray_to_json with array as data and options as options
    When data is String:
    Return quote_json_string with str as String.from with value as data
    When data is Integer or Float:
    Return String.from with value as data
    When data is Boolean:
    Return if data then "true" else "false"
    Otherwise:
    Return "null"

Note: Binary I/O operations
Process called "read_binary" that takes file_path as String and format as Optional[String] returns NDArray.NDArray:
    Let binary_format be format or "numpy"
    Match binary_format:
    When "numpy":
    Return read_numpy_binary with file_path as file_path
    When "raw":
    Return read_raw_binary with file_path as file_path
    Otherwise:
    Return read_numpy_binary with file_path as file_path

Process called "write_binary" that takes data as NDArray.NDArray and file_path as String and format as Optional[String] returns Boolean:
    Let binary_format be format or "numpy"
    Match binary_format:
    When "numpy":
    Return write_numpy_binary with data as data and file_path as file_path
    When "raw":
    Return write_raw_binary with data as data and file_path as file_path
    Otherwise:
    Return write_numpy_binary with data as data and file_path as file_path

Process called "read_numpy_binary" that takes file_path as String returns NDArray.NDArray:
    Note: Read NumPy .npy format (simplified)
    Let file_handle be FileIO.open_binary with path as file_path and mode as "rb" Note: Read magic number and version
    Let magic be FileIO.read_bytes with handle as file_handle and count as 6
    Let version be FileIO.read_bytes with handle as file_handle and count as 2 Note: Read header length
    Let header_len_bytes be FileIO.read_bytes with handle as file_handle and count as 2
    Let header_len be bytes_to_uint16 with bytes as header_len_bytes Note: Read header dictionary
    Let header_bytes be FileIO.read_bytes with handle as file_handle and count as header_len
    Let header_str be String.from_bytes with bytes as header_bytes
    Let header_dict be parse_numpy_header with header as header_str Note: Read data
    Let data_bytes be FileIO.read_remaining with handle as file_handle
    FileIO.close with handle as file_handle Let array be parse_numpy_data with bytes as data_bytes and header as header_dict
    Return array

Process called "write_numpy_binary" that takes data as NDArray.NDArray and file_path as String returns Boolean:
    Note: Write NumPy .npy format (simplified)
    Let file_handle be FileIO.open_binary with path as file_path and mode as "wb" Note: Write magic number and version
    Let magic be create_numpy_magic()
    Let version be create_numpy_version()
    FileIO.write_bytes with handle as file_handle and data as magic
    FileIO.write_bytes with handle as file_handle and data as version Note: Create and write header
    Let header_dict be create_numpy_header with array as data
    Let header_str be serialize_numpy_header with header as header_dict
    Let header_bytes be String.to_bytes with str as header_str Let header_len be Collections.List.length with lst as header_bytes
    Let header_len_bytes be uint16_to_bytes with value as header_len
    FileIO.write_bytes with handle as file_handle and data as header_len_bytes
    FileIO.write_bytes with handle as file_handle and data as header_bytes Note: Write data
    Let data_bytes be ndarray_to_bytes with array as data
    FileIO.write_bytes with handle as file_handle and data as data_bytes FileIO.close with handle as file_handle
    Return true

Note: Stream processing
Process called "create_stream_reader" that takes file_path as String and buffer_size as Optional[Integer] returns StreamReader:
    Let buf_size be buffer_size or 8192
    Let file_handle be FileIO.open with path as file_path and mode as "r"
    Let total_size be FileIO.get_file_size with path as file_path Return StreamReader with:
    file_handle as file_handle
    buffer_size as buf_size
    current_position as 0
    total_size as total_size
    encoding as "utf-8"
    compression as None
    chunk_iterator as None

Process called "read_chunk" that takes reader as StreamReader returns Optional[String]:
    Let chunk be FileIO.read with handle as reader.file_handle and count as reader.buffer_size If String.length with str as chunk is greater than 0:
    Set reader.current_position to reader.current_position String.length with str as chunk
    Return chunk Return None

Process called "create_csv_chunk_reader" that takes file_path as String and chunk_size as Integer and options as Optional[CSVOptions] returns StreamReader:
    Let csv_opts be options or create_default_csv_options()
    Let reader be create_stream_reader with file_path as file_path and buffer_size as chunk_size Note: Skip header if specified
    If csv_opts.has_header:
    Let header_line be read_chunk with reader as reader Return reader

Process called "read_csv_chunk" that takes reader as StreamReader and options as CSVOptions returns Optional[NDArray.NDArray]:
    Let chunk_lines be list containing
    Let lines_read be 0 While lines_read is less than options.chunk_size or 1000:
    Let chunk be read_chunk with reader as reader
    If chunk is None:
    Break Let lines be String.split with str as chunk and delimiter as options.line_terminator
    For each line in lines:
    If String.length with str as String.trim with str as line is greater than 0:
    Add line to chunk_lines
    Set lines_read to lines_read 1 If Collections.List.length with lst as chunk_lines is equal to 0:
    Return None Let parsed_rows be list containing
    For each line in chunk_lines:
    Let row be parse_csv_line with line as line and options as options
    Add row to parsed_rows Return convert_rows_to_ndarray with rows as parsed_rows and header as None and options as options

Note: Compression support
Process called "read_compressed_file" that takes file_path as String and compression as CompressionType returns String:
    Match compression:
    When GZip_:
    Return GZip.decompress_file with path as file_path
    When BZ2:
    Return decompress_bz2_file with path as file_path
    When LZMA:
    Return decompress_lzma_file with path as file_path
    Otherwise:
    Return FileIO.read_all with path as file_path

Process called "write_compressed_file" that takes content as String and file_path as String and compression as CompressionType returns Boolean:
    Match compression:
    When GZip_:
    Return GZip.compress_to_file with content as content and path as file_path
    When BZ2:
    Return compress_to_bz2_file with content as content and path as file_path
    When LZMA:
    Return compress_to_lzma_file with content as content and path as file_path
    Otherwise:
    Return FileIO.write_all with path as file_path and content as content

Note: Data type inference
Process called "infer_column_types" that takes data as List[List[String]] returns List[DataType]:
    Let n_cols be if Collections.List.length with lst as data is greater than 0 then Collections.List.length with lst as data at index 0 else 0
    Let column_types be list containing For col from 0 to n_cols - 1:
    Let column_values be list containing
    For each row in data:
    If col is less than Collections.List.length with lst as row:
    Add row at index col to column_values Let inferred_type be infer_column_type with values as column_values
    Add inferred_type to column_types Return column_types

Process called "infer_column_type" that takes values as List[String] returns DataType:
    Let all_integers be true
    Let all_floats be true
    Let all_booleans be true
    Let all_dates be true For each value in values:
    Let trimmed be String.trim with str as value If String.length with str as trimmed is greater than 0:
    If not is_integer_string with str as trimmed:
    Set all_integers to false If not is_float_string with str as trimmed:
    Set all_floats to false If not is_boolean_string with str as trimmed:
    Set all_booleans to false If not is_date_string with str as trimmed:
    Set all_dates to false If all_integers:
    Return Integer64 If all_floats:
    Return Float64 If all_booleans:
    Return Boolean_ If all_dates:
    Return DateTime Return String_

Note: Utility functions
Process called "create_default_csv_options" returns CSVOptions:
    Return CSVOptions with:
    delimiter as ","
    quote_char as "\""
    escape_char as None
    line_terminator as "\n"
    skip_initial_space as false
    has_header as true
    infer_types as true
    na_values as list containing "NA", "NULL", "", "N/A", "null"
    date_format as None
    decimal as "."
    thousands as None
    encoding as "utf-8"
    chunk_size as None

Process called "create_default_json_options" returns JSONOptions:
    Return JSONOptions with:
    indent as None
    ensure_ascii as false
    sort_keys as false
    compact as false
    handle_complex as true
    handle_ndarray as true
    precision as None

Process called "convert_rows_to_ndarray" that takes rows as List[List[String]] and header as Optional[List[String]] and options as CSVOptions returns NDArray.NDArray:
    If Collections.List.length with lst as rows is equal to 0:
    Return NDArray.zeros with shape as list containing 0, 0 Let n_rows be Collections.List.length with lst as rows
    Let n_cols be Collections.List.length with lst as rows at index 0 Note: Infer types if requested
    Let column_types be if options.infer_types then infer_column_types with data as rows else create_string_types with count as n_cols Note: Convert data
    Let data_array be NDArray.zeros with shape as list containing n_rows, n_cols For i from 0 to n_rows - 1:
    For j from 0 to n_cols - 1:
    Let cell_value be if j is less than Collections.List.length with lst as rows at index i then rows at index i at index j else ""
    Let converted_value be convert_string_to_type with str as cell_value and target_type as column_types at index j and na_values as options.na_values
    Set data_array.data at index (i multiplied by n_cols j) to converted_value Return data_array

Process called "convert_string_to_type" that takes str as String and target_type as DataType and na_values as List[String] returns Any:
    Let trimmed be String.trim with str as str Note: Check for NA values
    For each na_value in na_values:
    If trimmed is equal to na_value:
    Return None Match target_type:
    When Integer64:
    Return parse_integer with str as trimmed
    When Float64:
    Return parse_float with str as trimmed
    When Boolean_:
    Return parse_boolean with str as trimmed
    When DateTime:
    Return parse_datetime with str as trimmed
    Otherwise:
    Return trimmed

Process called "format_csv_line" that takes row as NDArray.NDArray and options as CSVOptions returns String:
    Let fields be list containing For i from 0 to row.size - 1:
    Let value be String.from with value as row.data at index i
    Let formatted_field be format_csv_field with value as value and options as options
    Add formatted_field to fields Return String.join with lst as fields and separator as options.delimiter

Process called "format_csv_field" that takes value as String and options as CSVOptions returns String:
    Let needs_quoting be String.contains with str as value and substring as options.delimiter or String.contains with str as value and substring as options.quote_char or String.contains with str as value and substring as options.line_terminator If needs_quoting:
    Let escaped_value be String.replace with str as value and old as options.quote_char and new as options.quote_char followed by options.quote_char
    Return options.quote_char followed by escaped_value followed by options.quote_char Return value

Process called "extract_row" that takes array as NDArray.NDArray and row_index as Integer returns NDArray.NDArray:
    Let n_cols be array.shape at index 1
    Let row_data be NDArray.zeros with shape as list containing n_cols For j from 0 to n_cols - 1:
    Set row_data.data at index j to array.data at index (row_index multiplied by n_cols j) Return row_data

Process called "create_header_line" that takes data as NDArray.NDArray and options as CSVOptions returns String:
    Let n_cols be data.shape at index 1
    Let headers be list containing For i from 0 to n_cols - 1:
    Let header_name be "Column" followed by String.from with value as (i 1)
    Add header_name to headers Return String.join with lst as headers and separator as options.delimiter

Process called "parse_json_string" that takes content as String and options as JSONOptions returns Dictionary[String, Any]:
    Note: Simplified JSON parser
    Return dictionary containing

Process called "serialize_dict_to_json" that takes dict as Dictionary[String, Any] and options as JSONOptions returns String:
    Note: Simplified JSON serialization
    Return "{}"

Process called "serialize_list_to_json" that takes list as List[Any] and options as JSONOptions returns String:
    Note: Simplified JSON serialization
    Return "[]"

Process called "serialize_ndarray_to_json" that takes array as NDArray.NDArray and options as JSONOptions returns String:
    Note: Serialize NDArray as JSON array
    Return "[]"

Process called "quote_json_string" that takes str as String returns String:
    Return "\"" followed by str followed by "\""

Process called "read_raw_binary" that takes file_path as String returns NDArray.NDArray:
    Note: Read binary data as float64 array
    Return NDArray.zeros with shape as list containing 0

Process called "write_raw_binary" that takes data as NDArray.NDArray and file_path as String returns Boolean:
    Note: Write binary data
    Return true

Process called "bytes_to_uint16" that takes bytes as List[Integer] returns Integer:
    Note: Convert 2 bytes to uint16 (little endian)
    Return 0

Process called "uint16_to_bytes" that takes value as Integer returns List[Integer]:
    Note: Convert uint16 to 2 bytes (little endian)
    Return list containing 0, 0

Process called "parse_numpy_header" that takes header as String returns Dictionary[String, Any]:
    Note: Parse NumPy header dictionary
    Return dictionary containing

Process called "create_numpy_header" that takes array as NDArray.NDArray returns Dictionary[String, Any]:
    Note: Create NumPy header dictionary
    Return dictionary containing

Process called "serialize_numpy_header" that takes header as Dictionary[String, Any] returns String:
    Note: Serialize NumPy header to string
    Return ""

Process called "parse_numpy_data" that takes bytes as List[Integer] and header as Dictionary[String, Any] returns NDArray.NDArray:
    Note: Parse binary data according to NumPy header
    Return NDArray.zeros with shape as list containing 0

Process called "ndarray_to_bytes" that takes array as NDArray.NDArray returns List[Integer]:
    Note: Convert NDArray to binary bytes
    Return list containing

Process called "create_numpy_magic" returns List[Integer]:
    Note: NumPy magic number
    Return list containing 147, 78, 85, 77, 80, 89

Process called "create_numpy_version" returns List[Integer]:
    Note: NumPy version
    Return list containing 1, 0

Process called "decompress_bz2_file" that takes path as String returns String:
    Note: Decompress BZ2 file
    Return ""

Process called "decompress_lzma_file" that takes path as String returns String:
    Note: Decompress LZMA file
    Return ""

Process called "compress_to_bz2_file" that takes content as String and path as String returns Boolean:
    Note: Compress to BZ2 file
    Return true

Process called "compress_to_lzma_file" that takes content as String and path as String returns Boolean:
    Note: Compress to LZMA file
    Return true

Process called "create_string_types" that takes count as Integer returns List[DataType]:
    Let types be list containing
    For i from 0 to count - 1:
    Add String_ to types
    Return types

Process called "is_integer_string" that takes str as String returns Boolean:
    Note: Check if string represents an integer
    Return true

Process called "is_float_string" that takes str as String returns Boolean:
    Note: Check if string represents a float
    Return true

Process called "is_boolean_string" that takes str as String returns Boolean:
    Let lower_str be String.to_lower with str as str
    Return lower_str is equal to "true" or lower_str is equal to "false" or lower_str is equal to "1" or lower_str is equal to "0"

Process called "is_date_string" that takes str as String returns Boolean:
    Note: Check if string represents a date
    Return false

Process called "parse_integer" that takes str as String returns Integer:
    Note: Parse string to integer
    Return 0

Process called "parse_float" that takes str as String returns Float:
    Note: Parse string to float
    Return 0.0

Process called "parse_boolean" that takes str as String returns Boolean:
    Let lower_str be String.to_lower with str as str
    Return lower_str is equal to "true" or lower_str is equal to "1"

Process called "parse_datetime" that takes str as String returns Integer:
    Note: Parse string to datetime timestamp
    Return 0