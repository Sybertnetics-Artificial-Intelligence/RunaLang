Note:
Runa Scientific Computing: HDF5 I/O Operations

Comprehensive HDF5 (Hierarchical Data Format version 5) support for scientific
computing, providing high-performance storage for large datasets with metadata.

Features:
- Hierarchical data organization (groups, datasets, attributes)
- Chunked storage for efficient access patterns
- Compression support (gzip, szip, lzf)
- Parallel I/O for distributed computing
- Memory-mapped access for large datasets
- Complex data types (compound, variable-length)
- Dimension scales and coordinate systems
- Dataset linking and references
- Advanced indexing and slicing
- Metadata preservation and schema validation
:End Note

Import "scientific/core/ndarray" as NDArray
Import "scientific/io/core" as IOCore
Import "../../collections" as Collections
Import "../../string" as String
Import "io/file" as FileIO

Type called "HDF5File":
    file_path as String
    mode as AccessMode
    file_handle as Any
    root_group as HDF5Group
    metadata as Dictionary[String, Any]
    version as String
    driver as String
    chunk_cache_size as Integer
    rdcc_nbytes as Integer
    rdcc_nslots as Integer

Type AccessMode is:
    | ReadOnly
    | ReadWrite | Create
    | Append

Type called "HDF5Group":
    name as String
    path as String
    parent as Optional[HDF5Group]
    subgroups as Dictionary[String, HDF5Group]
    datasets as Dictionary[String, HDF5Dataset]
    attributes as Dictionary[String, HDF5Attribute]
    creation_time as Integer
    modification_time as Integer

Type called "HDF5Dataset":
    name as String
    path as String
    parent_group as HDF5Group
    shape as List[Integer]
    dtype as HDF5DataType
    chunks as Optional[List[Integer]]
    compression as Optional[CompressionInfo]
    fillvalue as Optional[Any]
    maxshape as Optional[List[Integer]]
    attributes as Dictionary[String, HDF5Attribute]
    creation_time as Integer
    storage_size as Integer

Type called "HDF5Attribute":
    name as String
    value as Any
    dtype as HDF5DataType
    shape as List[Integer]

Type called "HDF5DataType":
    type_class as TypeClass
    byte_order as ByteOrder
    size as Integer
    precision as Optional[Integer]
    offset as Optional[Integer]
    pad as Optional[PaddingType]
    sign as Optional[SignType]
    mantissa_bits as Optional[Integer]
    exponent_bits as Optional[Integer]

Type TypeClass is:
    | Integer_
    | Float_
    | String_
    | Bitfield
    | Opaque
    | Compound
    | Reference
    | Enum
    | VarLength
    | Array

Type ByteOrder is:
    | LittleEndian
    | BigEndian
    | Native

Type PaddingType is:
    | Zero
    | One
    | Background

Type SignType is:
    | TwosComplement
    | Unsigned

Type called "CompressionInfo":
    algorithm as CompressionAlgorithm
    level as Integer
    shuffle as Boolean
    fletcher32 as Boolean
    scaleoffset as Optional[Integer]

Type CompressionAlgorithm is:
    | None_
    | Gzip
    | Szip
    | LZF
    | Blosc

Type called "ChunkInfo":
    chunk_dims as List[Integer]
    chunk_size_bytes as Integer
    total_chunks as Integer
    cache_policy as ChunkCachePolicy

Type ChunkCachePolicy is:
    | LRU
    | MRU
    | Random

Type called "HDF5Selection":
    hyperslab as Optional[Hyperslab]
    point_selection as Optional[List[List[Integer]]]
    selection_type as SelectionType

Type SelectionType is:
    | All
    | None_
    | Hyperslab_
    | Points

Type called "Hyperslab":
    start as List[Integer]
    count as List[Integer]
    stride as Optional[List[Integer]]
    block as Optional[List[Integer]]

Note: File operations
Process called "open_hdf5" that takes file_path as String and mode as AccessMode returns HDF5File:
    Let file_handle be open_hdf5_native with path as file_path and mode as mode
    Let root_group be create_root_group with file_handle as file_handle Return HDF5File with:
    file_path as file_path
    mode as mode
    file_handle as file_handle
    root_group as root_group
    metadata as read_file_metadata with handle as file_handle
    version as get_hdf5_version with handle as file_handle
    driver as get_file_driver with handle as file_handle
    chunk_cache_size as 1048576
    rdcc_nbytes as 1048576
    rdcc_nslots as 521

Process called "close_hdf5" that takes file as HDF5File returns Boolean:
    Return close_hdf5_native with handle as file.file_handle

Process called "flush_hdf5" that takes file as HDF5File returns Boolean:
    Return flush_hdf5_native with handle as file.file_handle

Note: Group operations
Process called "create_group" that takes parent as HDF5Group and name as String returns HDF5Group:
    Let group_handle be create_group_native with parent_handle as get_group_handle with group as parent and name as name Let new_group be HDF5Group with:
    name as name
    path as parent.path followed by "/" followed by name
    parent as parent
    subgroups as dictionary containing
    datasets as dictionary containing
    attributes as dictionary containing
    creation_time as get_current_timestamp()
    modification_time as get_current_timestamp() Set parent.subgroups[name] to new_group
    Return new_group

Process called "get_group" that takes parent as HDF5Group and path as String returns Optional[HDF5Group]:
    If String.starts_with with str as path and prefix as "/":
    Note: Absolute path - start from root
    Return traverse_path_from_root with root as get_root_group with group as parent and path as path
    Otherwise:
    Note: Relative path
    Return traverse_relative_path with parent as parent and path as path

Process called "list_groups" that takes group as HDF5Group returns List[String]:
    Let group_names be list containing
    For each group_name in Collections.Dict.keys with dict as group.subgroups:
    Add group_name to group_names
    Return group_names

Process called "delete_group" that takes parent as HDF5Group and name as String returns Boolean:
    If Collections.Dict.contains_key with dict as parent.subgroups and key as name:
    Let group_to_delete be parent.subgroups[name]
    Let result be delete_group_native with group_handle as get_group_handle with group as group_to_delete
    Collections.Dict.remove with dict as parent.subgroups and key as name
    Return result
    Return false

Note: Dataset operations
Process called "create_dataset" that takes parent as HDF5Group and name as String and data as NDArray.NDArray and options as Optional[DatasetOptions] returns HDF5Dataset:
    Let opts be options or create_default_dataset_options()
    Let dataset_handle be create_dataset_native with parent_handle as get_group_handle with group as parent and name as name and data as data and options as opts Let new_dataset be HDF5Dataset with:
    name as name
    path as parent.path followed by "/" followed by name
    parent_group as parent
    shape as data.shape
    dtype as infer_hdf5_dtype with ndarray as data
    chunks as opts.chunks
    compression as opts.compression
    fillvalue as opts.fillvalue
    maxshape as opts.maxshape
    attributes as dictionary containing
    creation_time as get_current_timestamp()
    storage_size as calculate_storage_size with data as data and options as opts Set parent.datasets[name] to new_dataset
    Return new_dataset

Process called "read_dataset" that takes dataset as HDF5Dataset and selection as Optional[HDF5Selection] returns NDArray.NDArray:
    Let sel be selection or create_all_selection()
    Let dataset_handle be get_dataset_handle with dataset as dataset Let data be read_dataset_native with handle as dataset_handle and selection as sel
    Return data

Process called "write_dataset" that takes dataset as HDF5Dataset and data as NDArray.NDArray and selection as Optional[HDF5Selection] returns Boolean:
    Let sel be selection or create_all_selection()
    Let dataset_handle be get_dataset_handle with dataset as dataset Return write_dataset_native with handle as dataset_handle and data as data and selection as sel

Process called "resize_dataset" that takes dataset as HDF5Dataset and new_shape as List[Integer] returns Boolean:
    Note: Check if dataset is resizable
    If dataset.maxshape is None:
    Return false Let max_shape be dataset.maxshape or dataset.shape
    For i from 0 to Collections.List.length with lst as new_shape - 1:
    Let new_dim be new_shape at index i
    Let max_dim be max_shape at index i
    If max_dim is not equal to -1 and new_dim is greater than max_dim:
    Return false Let dataset_handle be get_dataset_handle with dataset as dataset
    Let result be resize_dataset_native with handle as dataset_handle and shape as new_shape If result:
    Set dataset.shape to new_shape Return result

Process called "list_datasets" that takes group as HDF5Group returns List[String]:
    Let dataset_names be list containing
    For each dataset_name in Collections.Dict.keys with dict as group.datasets:
    Add dataset_name to dataset_names
    Return dataset_names

Note: Attribute operations
Process called "create_attribute" that takes parent as Any and name as String and value as Any returns HDF5Attribute:
    Let attr_dtype be infer_attribute_dtype with value as value
    Let attr_shape be infer_attribute_shape with value as value Let new_attribute be HDF5Attribute with:
    name as name
    value as value
    dtype as attr_dtype
    shape as attr_shape Note: Add to parent's attribute dictionary
    Match parent:
    When parent is HDF5Group:
    Set parent.attributes[name] to new_attribute
    When parent is HDF5Dataset:
    Set parent.attributes[name] to new_attribute Let parent_handle be get_parent_handle with parent as parent
    create_attribute_native with parent_handle as parent_handle and name as name and value as value Return new_attribute

Process called "read_attribute" that takes parent as Any and name as String returns Optional[Any]:
    Match parent:
    When parent is HDF5Group:
    If Collections.Dict.contains_key with dict as parent.attributes and key as name:
    Return parent.attributes[name].value
    When parent is HDF5Dataset:
    If Collections.Dict.contains_key with dict as parent.attributes and key as name:
    Return parent.attributes[name].value
    Return None

Process called "list_attributes" that takes parent as Any returns List[String]:
    Let attr_names be list containing Match parent:
    When parent is HDF5Group:
    For each attr_name in Collections.Dict.keys with dict as parent.attributes:
    Add attr_name to attr_names
    When parent is HDF5Dataset:
    For each attr_name in Collections.Dict.keys with dict as parent.attributes:
    Add attr_name to attr_names Return attr_names

Note: Advanced operations
Process called "create_chunked_dataset" that takes parent as HDF5Group and name as String and shape as List[Integer] and dtype as HDF5DataType and chunk_shape as List[Integer] returns HDF5Dataset:
    Let chunks be chunk_shape
    Let compression be CompressionInfo with:
    algorithm as Gzip
    level as 6
    shuffle as true
    fletcher32 as false
    scaleoffset as None Let options be DatasetOptions with:
    chunks as chunks
    compression as compression
    fillvalue as None
    maxshape as None
    track_times as true
    shuffle as true
    fletcher32 as false
    scaleoffset as None Note: Create empty dataset with specified shape and chunks
    Let empty_data be NDArray.zeros with shape as shape
    Return create_dataset with parent as parent and name as name and data as empty_data and options as options

Process called "create_virtual_dataset" that takes parent as HDF5Group and name as String and mapping as List[VirtualMapping] returns HDF5Dataset:
    Note: Create virtual dataset that maps to other files/datasets
    Let dataset_handle be create_virtual_dataset_native with parent_handle as get_group_handle with group as parent and name as name and mapping as mapping Let virtual_dataset be HDF5Dataset with:
    name as name
    path as parent.path followed by "/" followed by name
    parent_group as parent
    shape as calculate_virtual_shape with mapping as mapping
    dtype as infer_virtual_dtype with mapping as mapping
    chunks as None
    compression as None
    fillvalue as None
    maxshape as None
    attributes as dictionary containing
    creation_time as get_current_timestamp()
    storage_size as 0 Set parent.datasets[name] to virtual_dataset
    Return virtual_dataset

Process called "create_external_link" that takes parent as HDF5Group and name as String and target_file as String and target_path as String returns Boolean:
    Let parent_handle be get_group_handle with group as parent
    Return create_external_link_native with parent_handle as parent_handle and name as name and target_file as target_file and target_path as target_path

Process called "create_soft_link" that takes parent as HDF5Group and name as String and target_path as String returns Boolean:
    Let parent_handle be get_group_handle with group as parent
    Return create_soft_link_native with parent_handle as parent_handle and name as name and target_path as target_path

Note: Selection and indexing
Process called "create_hyperslab_selection" that takes start as List[Integer] and count as List[Integer] and stride as Optional[List[Integer]] and block as Optional[List[Integer]] returns HDF5Selection:
    Let hyperslab be Hyperslab with:
    start as start
    count as count
    stride as stride
    block as block Return HDF5Selection with:
    hyperslab as hyperslab
    point_selection as None
    selection_type as Hyperslab_

Process called "create_point_selection" that takes points as List[List[Integer]] returns HDF5Selection:
    Return HDF5Selection with:
    hyperslab as None
    point_selection as points
    selection_type as Points

Process called "select_hyperslab" that takes dataset as HDF5Dataset and start as List[Integer] and count as List[Integer] and stride as Optional[List[Integer]] and block as Optional[List[Integer]] returns NDArray.NDArray:
    Let selection be create_hyperslab_selection with start as start and count as count and stride as stride and block as block
    Return read_dataset with dataset as dataset and selection as selection

Process called "select_points" that takes dataset as HDF5Dataset and points as List[List[Integer]] returns NDArray.NDArray:
    Let selection be create_point_selection with points as points
    Return read_dataset with dataset as dataset and selection as selection

Note: Utilities and helpers
Type called "DatasetOptions":
    chunks as Optional[List[Integer]]
    compression as Optional[CompressionInfo]
    fillvalue as Optional[Any]
    maxshape as Optional[List[Integer]]
    track_times as Boolean
    shuffle as Boolean
    fletcher32 as Boolean
    scaleoffset as Optional[Integer]

Type called "VirtualMapping":
    virtual_selection as HDF5Selection
    source_file as String
    source_dataset as String
    source_selection as HDF5Selection

Process called "create_default_dataset_options" returns DatasetOptions:
    Return DatasetOptions with:
    chunks as None
    compression as None
    fillvalue as None
    maxshape as None
    track_times as true
    shuffle as false
    fletcher32 as false
    scaleoffset as None

Process called "infer_hdf5_dtype" that takes ndarray as NDArray.NDArray returns HDF5DataType:
    Match ndarray.dtype:
    When NDArray.Float32:
    Return create_float_dtype with size as 4
    When NDArray.Float64:
    Return create_float_dtype with size as 8
    When NDArray.Int32:
    Return create_integer_dtype with size as 4 and signed as true
    When NDArray.Int64:
    Return create_integer_dtype with size as 8 and signed as true
    Otherwise:
    Return create_float_dtype with size as 8

Process called "create_float_dtype" that takes size as Integer returns HDF5DataType:
    Return HDF5DataType with:
    type_class as Float_
    byte_order as Native
    size as size
    precision as size multiplied by 8
    offset as None
    pad as None
    sign as None
    mantissa_bits as if size is equal to 4 then 23 else 52
    exponent_bits as if size is equal to 4 then 8 else 11

Process called "create_integer_dtype" that takes size as Integer and signed as Boolean returns HDF5DataType:
    Return HDF5DataType with:
    type_class as Integer_
    byte_order as Native
    size as size
    precision as size multiplied by 8
    offset as None
    pad as None
    sign as if signed then TwosComplement else Unsigned
    mantissa_bits as None
    exponent_bits as None

Process called "infer_attribute_dtype" that takes value as Any returns HDF5DataType:
    Note: Simplified attribute type inference
    Return create_float_dtype with size as 8

Process called "infer_attribute_shape" that takes value as Any returns List[Integer]:
    Match value:
    When value is List:
    Return list containing Collections.List.length with lst as value
    Otherwise:
    Return list containing

Process called "create_all_selection" returns HDF5Selection:
    Return HDF5Selection with:
    hyperslab as None
    point_selection as None
    selection_type as All

Process called "calculate_storage_size" that takes data as NDArray.NDArray and options as DatasetOptions returns Integer:
    Let element_size be get_element_size with dtype as data.dtype
    Let total_elements be NDArray.calculate_size with shape as data.shape
    Let base_size be total_elements multiplied by element_size Note: Adjust for compression
    If options.compression is not None:
    Return Integer.from with value as Float.from with value as base_size multiplied by 0.7 Return base_size

Process called "get_element_size" that takes dtype as NDArray.DataType returns Integer:
    Match dtype:
    When NDArray.Float32:
    Return 4
    When NDArray.Float64:
    Return 8
    When NDArray.Int32:
    Return 4
    When NDArray.Int64:
    Return 8
    Otherwise:
    Return 8

Note: Native HDF5 operations (simplified implementations)
Process called "open_hdf5_native" that takes path as String and mode as AccessMode returns Any:
    Note: Open HDF5 file using native library
    Return FileIO.open with path as path and mode as "r"

Process called "close_hdf5_native" that takes handle as Any returns Boolean:
    FileIO.close with handle as handle
    Return true

Process called "flush_hdf5_native" that takes handle as Any returns Boolean:
    Return true

Process called "create_root_group" that takes file_handle as Any returns HDF5Group:
    Return HDF5Group with:
    name as "/"
    path as "/"
    parent as None
    subgroups as dictionary containing
    datasets as dictionary containing
    attributes as dictionary containing
    creation_time as get_current_timestamp()
    modification_time as get_current_timestamp()

Process called "read_file_metadata" that takes handle as Any returns Dictionary[String, Any]:
    Return dictionary containing

Process called "get_hdf5_version" that takes handle as Any returns String:
    Return "1.12.0"

Process called "get_file_driver" that takes handle as Any returns String:
    Return "sec2"

Process called "create_group_native" that takes parent_handle as Any and name as String returns Any:
    Return parent_handle

Process called "get_group_handle" that takes group as HDF5Group returns Any:
    Return group

Process called "traverse_path_from_root" that takes root as HDF5Group and path as String returns Optional[HDF5Group]:
    Return root

Process called "traverse_relative_path" that takes parent as HDF5Group and path as String returns Optional[HDF5Group]:
    Return parent

Process called "get_root_group" that takes group as HDF5Group returns HDF5Group:
    Let current be group
    While current.parent is not None:
    Set current to current.parent or current
    Return current

Process called "delete_group_native" that takes group_handle as Any returns Boolean:
    Return true

Process called "create_dataset_native" that takes parent_handle as Any and name as String and data as NDArray.NDArray and options as DatasetOptions returns Any:
    Return parent_handle

Process called "get_dataset_handle" that takes dataset as HDF5Dataset returns Any:
    Return dataset

Process called "read_dataset_native" that takes handle as Any and selection as HDF5Selection returns NDArray.NDArray:
    Return NDArray.zeros with shape as list containing 0

Process called "write_dataset_native" that takes handle as Any and data as NDArray.NDArray and selection as HDF5Selection returns Boolean:
    Return true

Process called "resize_dataset_native" that takes handle as Any and shape as List[Integer] returns Boolean:
    Return true

Process called "get_parent_handle" that takes parent as Any returns Any:
    Return parent

Process called "create_attribute_native" that takes parent_handle as Any and name as String and value as Any returns Boolean:
    Return true

Process called "create_virtual_dataset_native" that takes parent_handle as Any and name as String and mapping as List[VirtualMapping] returns Any:
    Return parent_handle

Process called "calculate_virtual_shape" that takes mapping as List[VirtualMapping] returns List[Integer]:
    Return list containing 0

Process called "infer_virtual_dtype" that takes mapping as List[VirtualMapping] returns HDF5DataType:
    Return create_float_dtype with size as 8

Process called "create_external_link_native" that takes parent_handle as Any and name as String and target_file as String and target_path as String returns Boolean:
    Return true

Process called "create_soft_link_native" that takes parent_handle as Any and name as String and target_path as String returns Boolean:
    Return true

Process called "get_current_timestamp" returns Integer:
    Return 0