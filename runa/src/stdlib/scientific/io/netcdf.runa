Note:
Runa Scientific Computing: NetCDF I/O Operations

Comprehensive NetCDF (Network Common Data Form) support for scientific data,
particularly focusing on multidimensional arrays with metadata and coordinate systems.

Features:
- NetCDF classic and enhanced (NetCDF-4) formats
- Multidimensional variables with named dimensions
- Coordinate variables and dimension scales
- Global and variable attributes with rich metadata
- Groups and hierarchical data organization
- Compression and chunking for large datasets
- Time handling with CF conventions
- Geographic coordinate systems and projections
- Quality flags and data masking
- Parallel I/O for distributed computing
:End Note

Import "scientific/core/ndarray" as NDArray
Import "scientific/io/core" as IOCore
Import "../../collections" as Collections
Import "../../string" as String
Import "../../datetime" as DateTime

Type called "NetCDFFile":
    file_path as String
    mode as NetCDFMode
    format as NetCDFFormat
    file_handle as Any
    root_group as NetCDFGroup
    global_attributes as Dictionary[String, NetCDFAttribute]
    conventions as String
    history as List[String]
    creation_time as Integer
    last_modified as Integer

Type NetCDFMode is:
    | ReadOnly
    | ReadWrite
    | Create
    | Append

Type NetCDFFormat is:
    | Classic
    | Classic64
    | NetCDF4
    | NetCDF4Classic

Type called "NetCDFGroup":
    name as String
    path as String
    parent as Optional[NetCDFGroup]
    subgroups as Dictionary[String, NetCDFGroup]
    dimensions as Dictionary[String, NetCDFDimension]
    variables as Dictionary[String, NetCDFVariable]
    attributes as Dictionary[String, NetCDFAttribute]

Type called "NetCDFDimension":
    name as String
    size as Optional[Integer]
    is_unlimited as Boolean
    coordinate_variable as Optional[NetCDFVariable]

Type called "NetCDFVariable":
    name as String
    dimensions as List[String]
    shape as List[Integer]
    dtype as NetCDFDataType
    attributes as Dictionary[String, NetCDFAttribute]
    chunking as Optional[List[Integer]]
    compression as Optional[NetCDFCompression]
    fillvalue as Optional[Any]
    scale_factor as Optional[Float]
    add_offset as Optional[Float]
    missing_values as List[Any]
    valid_range as Optional[ValidRange]
    units as Optional[String]
    long_name as Optional[String]
    standard_name as Optional[String]

Type called "NetCDFAttribute":
    name as String
    value as Any
    dtype as NetCDFDataType

Type NetCDFDataType is:
    | Int8
    | UInt8
    | Int16
    | UInt16
    | Int32
    | UInt32
    | Int64
    | UInt64
    | Float32
    | Float64
    | Char
    | String_
    | Compound
    | VarLength
    | Enum
    | Opaque

Type called "NetCDFCompression":
    algorithm as CompressionAlgorithm
    level as Integer
    shuffle as Boolean
    fletcher32 as Boolean
    blosc_codec as Optional[String]

Type CompressionAlgorithm is:
    | None_
    | Zlib
    | Szip
    | Blosc

Type called "ValidRange":
    min_value as Any
    max_value as Any

Type called "CoordinateSystem":
    spatial_dims as List[String]
    temporal_dim as Optional[String]
    projection as Optional[ProjectionInfo]
    coordinate_variables as Dictionary[String, NetCDFVariable]

Type called "ProjectionInfo":
    name as String
    parameters as Dictionary[String, Float]
    false_easting as Float
    false_northing as Float
    central_meridian as Float
    standard_parallel as List[Float]

Type called "CFConventions":
    version as String
    coordinate_variables as List[String]
    auxiliary_coordinates as List[String]
