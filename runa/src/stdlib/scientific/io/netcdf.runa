    bounds as Dictionary[String, String]
    climatology as Dictionary[String, String]

Note: File operations
Process called "open_netcdf" that takes file_path as String and mode as NetCDFMode and format as Optional[NetCDFFormat] returns NetCDFFile:
    Let nc_format be format or NetCDF4
    Let file_handle be open_netcdf_native with path as file_path and mode as mode and format as nc_format
    Let root_group be create_netcdf_root_group with handle as file_handle
    Let global_attrs be read_global_attributes with handle as file_handle Return NetCDFFile with:
    file_path as file_path
    mode as mode
    format as nc_format
    file_handle as file_handle
    root_group as root_group
    global_attributes as global_attrs
    conventions as get_conventions_string with attributes as global_attrs
    history as get_history_list with attributes as global_attrs
    creation_time as get_current_timestamp()
    last_modified as get_current_timestamp()

Process called "close_netcdf" that takes file as NetCDFFile returns Boolean:
    Return close_netcdf_native with handle as file.file_handle

Process called "sync_netcdf" that takes file as NetCDFFile returns Boolean:
    Note: Synchronize changes to disk
    Return sync_netcdf_native with handle as file.file_handle

Note: Group operations
Process called "create_netcdf_group" that takes parent as NetCDFGroup and name as String returns NetCDFGroup:
    Let group_handle be create_group_netcdf_native with parent_handle as get_netcdf_group_handle with group as parent and name as name Let new_group be NetCDFGroup with:
    name as name
    path as if parent.path is equal to "/" then "/" followed by name else parent.path followed by "/" followed by name
    parent as parent
    subgroups as dictionary containing
    dimensions as dictionary containing
    variables as dictionary containing
    attributes as dictionary containing Set parent.subgroups[name] to new_group
    Return new_group

Process called "list_netcdf_groups" that takes group as NetCDFGroup returns List[String]:
    Return Collections.Dict.keys with dict as group.subgroups

Note: Dimension operations
Process called "create_dimension" that takes group as NetCDFGroup and name as String and size as Optional[Integer] returns NetCDFDimension:
    Let dim_size be size
    Let is_unlimited be size is None Let group_handle be get_netcdf_group_handle with group as group
    create_dimension_native with group_handle as group_handle and name as name and size as dim_size Let new_dimension be NetCDFDimension with:
    name as name
    size as dim_size
    is_unlimited as is_unlimited
    coordinate_variable as None Set group.dimensions[name] to new_dimension
    Return new_dimension

Process called "get_dimension" that takes group as NetCDFGroup and name as String returns Optional[NetCDFDimension]:
    If Collections.Dict.contains_key with dict as group.dimensions and key as name:
    Return group.dimensions[name]
    Return None

Process called "list_dimensions" that takes group as NetCDFGroup returns List[String]:
    Return Collections.Dict.keys with dict as group.dimensions

Process called "get_dimension_size" that takes group as NetCDFGroup and name as String returns Optional[Integer]:
    Let dimension be get_dimension with group as group and name as name
    If dimension is not None:
    Return dimension.size
    Return None

Note: Variable operations
Process called "create_variable" that takes group as NetCDFGroup and name as String and dimensions as List[String] and dtype as NetCDFDataType and options as Optional[VariableOptions] returns NetCDFVariable:
    Let var_opts be options or create_default_variable_options()
    Let group_handle be get_netcdf_group_handle with group as group Note: Calculate shape from dimensions
    Let shape be list containing
    For each dim_name in dimensions:
    Let dimension be get_dimension with group as group and name as dim_name
    If dimension is not None and dimension.size is not None:
    Add dimension.size to shape
    Otherwise:
    Add 0 to shape create_variable_native with group_handle as group_handle and name as name and dimensions as dimensions and dtype as dtype and options as var_opts Let new_variable be NetCDFVariable with:
    name as name
    dimensions as dimensions
    shape as shape
    dtype as dtype
    attributes as dictionary containing
    chunking as var_opts.chunking
    compression as var_opts.compression
    fillvalue as var_opts.fillvalue
    scale_factor as None
    add_offset as None
    missing_values as list containing
    valid_range as None
    units as None
    long_name as None
    standard_name as None Set group.variables[name] to new_variable
    Return new_variable

Process called "read_variable" that takes variable as NetCDFVariable and indices as Optional[List[SliceIndex]] returns NDArray.NDArray:
    Let var_handle be get_netcdf_variable_handle with variable as variable
    Let selection be indices or create_full_selection with shape as variable.shape Let raw_data be read_variable_native with handle as var_handle and indices as selection Note: Apply scale_factor and add_offset if present
    Let processed_data be apply_scale_and_offset with data as raw_data and variable as variable Note: Handle missing values and fill values
    Let masked_data be apply_missing_value_mask with data as processed_data and variable as variable Return masked_data

Process called "write_variable" that takes variable as NetCDFVariable and data as NDArray.NDArray and indices as Optional[List[SliceIndex]] returns Boolean:
    Let var_handle be get_netcdf_variable_handle with variable as variable
    Let selection be indices or create_full_selection with shape as variable.shape Note: Apply inverse scaling if scale_factor/add_offset are present
    Let processed_data be apply_inverse_scaling with data as data and variable as variable Return write_variable_native with handle as var_handle and data as processed_data and indices as selection

Process called "list_variables" that takes group as NetCDFGroup returns List[String]:
    Return Collections.Dict.keys with dict as group.variables

Process called "get_variable" that takes group as NetCDFGroup and name as String returns Optional[NetCDFVariable]:
    If Collections.Dict.contains_key with dict as group.variables and key as name:
    Return group.variables[name]
    Return None

Note: Attribute operations
Process called "create_global_attribute" that takes file as NetCDFFile and name as String and value as Any returns NetCDFAttribute:
    Let attr_dtype be infer_netcdf_attribute_type with value as value
    let file_handle be file.file_handle create_global_attribute_native with handle as file_handle and name as name and value as value Let new_attribute be NetCDFAttribute with:
    name as name
    value as value
    dtype as attr_dtype Set file.global_attributes[name] to new_attribute
    Return new_attribute

Process called "create_variable_attribute" that takes variable as NetCDFVariable and name as String and value as Any returns NetCDFAttribute:
    Let attr_dtype be infer_netcdf_attribute_type with value as value
    Let var_handle be get_netcdf_variable_handle with variable as variable create_variable_attribute_native with handle as var_handle and name as name and value as value Let new_attribute be NetCDFAttribute with:
    name as name
    value as value
    dtype as attr_dtype Set variable.attributes[name] to new_attribute
    Return new_attribute

Process called "read_global_attribute" that takes file as NetCDFFile and name as String returns Optional[Any]:
    If Collections.Dict.contains_key with dict as file.global_attributes and key as name:
    Return file.global_attributes[name].value
    Return None

Process called "read_variable_attribute" that takes variable as NetCDFVariable and name as String returns Optional[Any]:
    If Collections.Dict.contains_key with dict as variable.attributes and key as name:
    Return variable.attributes[name].value
    Return None

Note: CF Conventions support
Process called "create_coordinate_variable" that takes group as NetCDFGroup and dimension_name as String and coordinates as NDArray.NDArray and units as String returns NetCDFVariable:
    Let coord_var be create_variable with group as group and name as dimension_name and dimensions as list containing dimension_name and dtype as infer_netcdf_dtype with array as coordinates and options as None Note: Write coordinate data
    write_variable with variable as coord_var and data as coordinates and indices as None Note: Add standard attributes
    create_variable_attribute with variable as coord_var and name as "units" and value as units
    create_variable_attribute with variable as coord_var and name as "axis" and value as infer_axis_from_name with name as dimension_name Note: Link to dimension
    Let dimension be get_dimension with group as group and name as dimension_name
    If dimension is not None:
    Set dimension.coordinate_variable to coord_var Return coord_var

Process called "create_time_variable" that takes group as NetCDFGroup and dimension_name as String and times as NDArray.NDArray and time_units as String and calendar as Optional[String] returns NetCDFVariable:
    Let time_var be create_coordinate_variable with group as group and dimension_name as dimension_name and coordinates as times and units as time_units Note: Add time-specific attributes
    create_variable_attribute with variable as time_var and name as "standard_name" and value as "time"
    create_variable_attribute with variable as time_var and name as "long_name" and value as "time"
    Let cal be calendar or "gregorian"
    create_variable_attribute with variable as time_var and name as "calendar" and value as cal Return time_var

Process called "add_bounds_variable" that takes group as NetCDFGroup and coord_var as NetCDFVariable and bounds_data as NDArray.NDArray returns NetCDFVariable:
    Let bounds_name be coord_var.name followed by "_bounds"
    Let bounds_dim_name be "bounds_dim" Note: Create bounds dimension if it doesn't exist
    If get_dimension with group as group and name as bounds_dim_name is None:
    create_dimension with group as group and name as bounds_dim_name and size as 2 Let bounds_dims be list containing coord_var.dimensions at index 0, bounds_dim_name
    Let bounds_var be create_variable with group as group and name as bounds_name and dimensions as bounds_dims and dtype as coord_var.dtype and options as None Note: Write bounds data
    write_variable with variable as bounds_var and data as bounds_data and indices as None Note: Add bounds attribute to coordinate variable
    create_variable_attribute with variable as coord_var and name as "bounds" and value as bounds_name Return bounds_var

Note: Geographic coordinate systems
Process called "add_crs_variable" that takes group as NetCDFGroup and crs_name as String and projection as ProjectionInfo returns NetCDFVariable:
    Note: Create a scalar CRS variable
    Let crs_var be create_variable with group as group and name as crs_name and dimensions as list containing and dtype as Int32 and options as None Note: Write dummy value
    Let dummy_data be NDArray.create_scalar with value as 1 and dtype as NDArray.Int32
    write_variable with variable as crs_var and data as dummy_data and indices as None Note: Add projection parameters as attributes
    create_variable_attribute with variable as crs_var and name as "grid_mapping_name" and value as projection.name
    create_variable_attribute with variable as crs_var and name as "false_easting" and value as projection.false_easting
    create_variable_attribute with variable as crs_var and name as "false_northing" and value as projection.false_northing
    create_variable_attribute with variable as crs_var and name as "longitude_of_central_meridian" and value as projection.central_meridian For each param_name in Collections.Dict.keys with dict as projection.parameters:
    create_variable_attribute with variable as crs_var and name as param_name and value as projection.parameters[param_name] Return crs_var

Process called "add_grid_mapping_attribute" that takes variable as NetCDFVariable and crs_name as String returns NetCDFAttribute:
    Return create_variable_attribute with variable as variable and name as "grid_mapping" and value as crs_name

Note: Data quality and masking
Process called "set_fill_value" that takes variable as NetCDFVariable and fill_value as Any returns NetCDFAttribute:
    Set variable.fillvalue to fill_value
    Return create_variable_attribute with variable as variable and name as "_FillValue" and value as fill_value

Process called "set_missing_value" that takes variable as NetCDFVariable and missing_value as Any returns NetCDFAttribute:
    Add missing_value to variable.missing_values
    Return create_variable_attribute with variable as variable and name as "missing_value" and value as missing_value

Process called "set_valid_range" that takes variable as NetCDFVariable and min_value as Any and max_value as Any returns List[NetCDFAttribute]:
    Set variable.valid_range to ValidRange with min_value as min_value and max_value as max_value Let min_attr be create_variable_attribute with variable as variable and name as "valid_min" and value as min_value
    Let max_attr be create_variable_attribute with variable as variable and name as "valid_max" and value as max_value Return list containing min_attr, max_attr

Process called "set_scale_and_offset" that takes variable as NetCDFVariable and scale_factor as Float and add_offset as Float returns List[NetCDFAttribute]:
    Set variable.scale_factor to scale_factor
    Set variable.add_offset to add_offset Let scale_attr be create_variable_attribute with variable as variable and name as "scale_factor" and value as scale_factor
    Let offset_attr be create_variable_attribute with variable as variable and name as "add_offset" and value as add_offset Return list containing scale_attr, offset_attr

Note: Utility functions and types
Type called "VariableOptions":
    chunking as Optional[List[Integer]]
    compression as Optional[NetCDFCompression]
    fillvalue as Optional[Any]
    shuffle as Boolean
    fletcher32 as Boolean
    endian as Optional[String]

Type called "SliceIndex":
    start as Optional[Integer]
    stop as Optional[Integer]
    step as Optional[Integer]

Process called "create_default_variable_options" returns VariableOptions:
    Return VariableOptions with:
    chunking as None
    compression as None
    fillvalue as None
    shuffle as false
    fletcher32 as false
    endian as None

Process called "infer_netcdf_dtype" that takes array as NDArray.NDArray returns NetCDFDataType:
    Match array.dtype:
    When NDArray.Float32:
    Return Float32
    When NDArray.Float64:
    Return Float64
    When NDArray.Int32:
    Return Int32
    When NDArray.Int64:
    Return Int64
    Otherwise:
    Return Float64

Process called "infer_netcdf_attribute_type" that takes value as Any returns NetCDFDataType:
    Match value:
    When value is Float:
    Return Float64
    When value is Integer:
    Return Int64
    When value is String:
    Return String_
    When value is List:
    Note: Infer from first element
    If Collections.List.length with lst as value is greater than 0:
    Return infer_netcdf_attribute_type with value as value at index 0
    Return String_
    Otherwise:
    Return String_

Process called "apply_scale_and_offset" that takes data as NDArray.NDArray and variable as NetCDFVariable returns NDArray.NDArray:
    Let result be NDArray.copy_array with arr as data If variable.scale_factor is not None:
    For i from 0 to result.size - 1:
    Set result.data at index i to result.data at index i multiplied by variable.scale_factor or 1.0 If variable.add_offset is not None:
    For i from 0 to result.size - 1:
    Set result.data at index i to result.data at index i variable.add_offset or 0.0 Return result

Process called "apply_inverse_scaling" that takes data as NDArray.NDArray and variable as NetCDFVariable returns NDArray.NDArray:
    Let result be NDArray.copy_array with arr as data If variable.add_offset is not None:
    For i from 0 to result.size - 1:
    Set result.data at index i to result.data at index i - variable.add_offset or 0.0 If variable.scale_factor is not None:
    For i from 0 to result.size - 1:
    Set result.data at index i to result.data at index i divided by variable.scale_factor or 1.0 Return result

Process called "apply_missing_value_mask" that takes data as NDArray.NDArray and variable as NetCDFVariable returns NDArray.NDArray:
    Note: Replace fill values and missing values with NaN or appropriate sentinel
    Let result be NDArray.copy_array with arr as data For i from 0 to result.size - 1:
    Let value be result.data at index i Note: Check fill value
    If variable.fillvalue is not None and value is equal to variable.fillvalue:
    Set result.data at index i to create_missing_value_sentinel() Note: Check missing values
    For each missing_val in variable.missing_values:
    If value is equal to missing_val:
    Set result.data at index i to create_missing_value_sentinel() Return result

Process called "create_full_selection" that takes shape as List[Integer] returns List[SliceIndex]:
    Let selection be list containing
    For each dim_size in shape:
    Let slice be SliceIndex with:
    start as 0
    stop as dim_size
    step as 1
    Add slice to selection
    Return selection

Process called "infer_axis_from_name" that takes name as String returns String:
    Let lower_name be String.to_lower with str as name If String.contains with str as lower_name and substring as "lat":
    Return "Y"
    If String.contains with str as lower_name and substring as "lon":
    Return "X"
    If String.contains with str as lower_name and substring as "time":
    Return "T"
    If String.contains with str as lower_name and substring as "depth" or String.contains with str as lower_name and substring as "level":
    Return "Z"
    Return "X"

Process called "get_conventions_string" that takes attributes as Dictionary[String, NetCDFAttribute] returns String:
    If Collections.Dict.contains_key with dict as attributes and key as "Conventions":
    Let conventions_attr be attributes["Conventions"]
    Return String.from with value as conventions_attr.value
    Return "CF-1.8"

Process called "get_history_list" that takes attributes as Dictionary[String, NetCDFAttribute] returns List[String]:
    If Collections.Dict.contains_key with dict as attributes and key as "history":
    Let history_attr be attributes["history"]
    Let history_str be String.from with value as history_attr.value
    Return String.split with str as history_str and delimiter as "\n"
    Return list containing

Process called "create_missing_value_sentinel" returns Float:
    Note: Return NaN or appropriate missing value sentinel
    Return Float.nan

Process called "get_current_timestamp" returns Integer:
    Note: Get current Unix timestamp
    Return 0

Note: Native NetCDF operations (simplified implementations)
Process called "open_netcdf_native" that takes path as String and mode as NetCDFMode and format as NetCDFFormat returns Any:
    Note: Open NetCDF file using native library
    Return path

Process called "close_netcdf_native" that takes handle as Any returns Boolean:
    Return true

Process called "sync_netcdf_native" that takes handle as Any returns Boolean:
    Return true

Process called "create_netcdf_root_group" that takes handle as Any returns NetCDFGroup:
    Return NetCDFGroup with:
    name as "/"
    path as "/"
    parent as None
    subgroups as dictionary containing
    dimensions as dictionary containing
    variables as dictionary containing
    attributes as dictionary containing

Process called "read_global_attributes" that takes handle as Any returns Dictionary[String, NetCDFAttribute]:
    Return dictionary containing

Process called "create_group_netcdf_native" that takes parent_handle as Any and name as String returns Any:
    Return parent_handle

Process called "get_netcdf_group_handle" that takes group as NetCDFGroup returns Any:
    Return group

Process called "create_dimension_native" that takes group_handle as Any and name as String and size as Optional[Integer] returns Boolean:
    Return true

Process called "create_variable_native" that takes group_handle as Any and name as String and dimensions as List[String] and dtype as NetCDFDataType and options as VariableOptions returns Any:
    Return group_handle

Process called "get_netcdf_variable_handle" that takes variable as NetCDFVariable returns Any:
    Return variable

Process called "read_variable_native" that takes handle as Any and indices as List[SliceIndex] returns NDArray.NDArray:
    Return NDArray.zeros with shape as list containing 0

Process called "write_variable_native" that takes handle as Any and data as NDArray.NDArray and indices as List[SliceIndex] returns Boolean:
    Return true

Process called "create_global_attribute_native" that takes handle as Any and name as String and value as Any returns Boolean:
    Return true

Process called "create_variable_attribute_native" that takes handle as Any and name as String and value as Any returns Boolean:
    Return true