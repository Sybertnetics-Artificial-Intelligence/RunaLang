    Return

Process called "get_tool_icon" that takes type as ToolType returns String:
    Match type:
        When ZoomTool:
            Return "zoom_in"
        When PanTool:
            Return "pan_tool"
        When SelectTool:
            Return "select"
        When ResetTool:
            Return "refresh"
        When SaveTool:
            Return "save"
        Otherwise:
            Return "tool"

Process called "get_tool_tooltip" that takes type as ToolType returns String:
    Match type:
        When ZoomTool:
            Return "Zoom"
        When PanTool:
            Return "Pan"
        When SelectTool:
            Return "Select"
        When ResetTool:
            Return "Reset View"
        When SaveTool:
            Return "Save Figure"
        Otherwise:
            Return "Tool"

Process called "get_tool_shortcut" that takes type as ToolType returns Optional[String]:
    Match type:
        When ZoomTool:
            Return "z"
        When PanTool:
            Return "p"
        When SelectTool:
            Return "s"
        When ResetTool:
            Return "r"
        When SaveTool:
            Return "Ctrl+S"
        Otherwise:
            Return None

Process called "create_tool_callback" that takes type as ToolType returns Function[Any, Any]:
    Return function that takes event as Any returns Any:
        Match type:
            When ZoomTool:
                activate_zoom_tool with event as event
            When PanTool:
                activate_pan_tool with event as event
            When SelectTool:
                activate_select_tool with event as event
            When ResetTool:
                reset_view with event as event
            When SaveTool:
                save_figure with event as event
            Otherwise:
                handle_generic_tool with event as event

