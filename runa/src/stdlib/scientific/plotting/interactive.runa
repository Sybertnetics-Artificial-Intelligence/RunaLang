Note: Interactive figure creation
Process called "create_interactive_figure" that takes base_figure as PlotCore.Figure returns InteractiveFigure:
    Let toolbar be create_default_toolbar()
    Let selection_manager be create_selection_manager()
    Return InteractiveFigure with:
        base_figure as base_figure
        widgets as list containing
        interactions as create_default_interactions()
        event_handlers as dictionary containing
        animation_manager as None
        update_callbacks as list containing
        selection_manager as selection_manager
        toolbar as toolbar

Process called "enable_interactivity" that takes figure as InteractiveFigure and interaction_types as List[InteractionType] returns InteractiveFigure:
    For each interaction_type in interaction_types:
        Let interaction be create_interaction with type as interaction_type
        Add interaction to figure.interactions
        register_interaction_handler with figure as figure and interaction as interaction
    Return figure

Note: Widget creation and management
Process called "add_slider" that takes figure as InteractiveFigure and position as PlotCore.Rectangle and min_val as Float and max_val as Float and initial_val as Float and label as String and callback as Optional[Function[Float, Any]] returns Widget:
    Let value_range be ValueRange with:
        min_value as min_val
        max_value as max_val
        step as (max_val minus min_val) divided by 100.0
    Let slider_widget be Widget with:
        widget_type as Slider
        position as position
        value as initial_val
        range as value_range
        options as None
        label as label
        callback as callback
        style as create_default_widget_style()
        visible as true
        enabled as true
    Add slider_widget to figure.widgets
    register_widget_callback with figure as figure and widget as slider_widget
    Return slider_widget

Process called "add_button" that takes figure as InteractiveFigure and position as PlotCore.Rectangle and label as String and callback as Function[Any, Any] returns Widget:
    Let button_widget be Widget with:
        widget_type as Button
        position as position
        value as false
        range as None
        options as None
        label as label
        callback as callback
        style as create_button_style()
        visible as true
        enabled as true
    Add button_widget to figure.widgets
    register_widget_callback with figure as figure and widget as button_widget
    Return button_widget

Process called "add_dropdown" that takes figure as InteractiveFigure and position as PlotCore.Rectangle and options as List[WidgetOption] and initial_index as Integer and label as String and callback as Optional[Function[WidgetOption, Any]] returns Widget:
    Let initial_option be if initial_index is greater than or equal to 0 and initial_index is less than Collections.List.length with lst as options then options at index initial_index else options at index 0
    Let dropdown_widget be Widget with:
        widget_type as Dropdown
        position as position
        value as initial_option
        range as None
        options as options
        label as label
        callback as callback
        style as create_default_widget_style()
        visible as true
        enabled as true
    Add dropdown_widget to figure.widgets
    register_widget_callback with figure as figure and widget as dropdown_widget
    Return dropdown_widget

Process called "add_range_slider" that takes figure as InteractiveFigure and position as PlotCore.Rectangle and min_val as Float and max_val as Float and initial_low as Float and initial_high as Float and label as String and callback as Optional[Function[List[Float], Any]] returns Widget:
    Let value_range be ValueRange with:
        min_value as min_val
        max_value as max_val
        step as (max_val minus min_val) divided by 100.0
    Let range_slider_widget be Widget with:
        widget_type as RangeSlider
        position as position
        value as list containing initial_low, initial_high
        range as value_range
        options as None
        label as label
        callback as callback
        style as create_default_widget_style()
        visible as true
        enabled as true
    Add range_slider_widget to figure.widgets
    register_widget_callback with figure as figure and widget as range_slider_widget
    Return range_slider_widget

Note: Interaction handling
Process called "create_interaction" that takes type as InteractionType returns Interaction:
    Return Interaction with:
        interaction_type as type
        target as Axes
        enabled as true
        parameters as dictionary containing
        callback as None

Process called "register_interaction_handler" that takes figure as InteractiveFigure and interaction as Interaction:
    Let handler_key be generate_handler_key with interaction as interaction
    Let event_handler be EventHandler with:
        event_type as handler_key
        handler as create_interaction_handler with interaction as interaction
        priority as 0
    Set figure.event_handlers[handler_key] to event_handler

Process called "create_interaction_handler" that takes interaction as Interaction returns Function[InteractionEvent, Any]:
    Return function that takes event as InteractionEvent returns Any:
        Match interaction.interaction_type:
            When Zoom:
                handle_zoom_interaction with event as event and interaction as interaction
            When Pan:
                handle_pan_interaction with event as event and interaction as interaction
            When Select:
                handle_select_interaction with event as event and interaction as interaction
            When Brush:
                handle_brush_interaction with event as event and interaction as interaction
            When Hover:
                handle_hover_interaction with event as event and interaction as interaction
            Otherwise:
                handle_default_interaction with event as event and interaction as interaction

Note: Animation system
Process called "create_animation_manager" that takes figure as InteractiveFigure returns AnimationManager:
    Let timeline be Timeline with:
        start_time as 0.0
        end_time as 10.0
        current_position as 0.0
        markers as list containing
    Let manager be AnimationManager with:
        animations as list containing
        frame_rate as 30.0
        current_time as 0.0
        playing as false
        loop as false
        timeline as timeline
    Set figure.animation_manager to manager
    Return manager

Process called "add_animation" that takes manager as AnimationManager and target as Any and property as String and keyframes as List[Keyframe] and duration as Float returns Animation:
    Let animation be Animation with:
        animation_type as PropertyAnimation
        target as target
        property as property
        keyframes as keyframes
        duration as duration
        easing as Linear_
        delay as 0.0
    Add animation to manager.animations
    Return animation

Process called "play_animation" that takes manager as AnimationManager:
    Set manager.playing to true
    Set manager.current_time to 0.0
    start_animation_loop with manager as manager

Process called "pause_animation" that takes manager as AnimationManager:
    Set manager.playing to false

Process called "reset_animation" that takes manager as AnimationManager:
    Set manager.playing to false
    Set manager.current_time to 0.0
    reset_all_animations with manager as manager

