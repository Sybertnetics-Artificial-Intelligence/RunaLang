        tooltip as get_tool_tooltip with type as type
        keyboard_shortcut as get_tool_shortcut with type as type
        enabled as true
        callback as create_tool_callback with type as type

Process called "create_selection_manager" returns SelectionManager:
    Return SelectionManager with:
        current_selection as create_empty_selection()
        selection_history as list containing
        multi_select as false
        selection_mode as Replace

Process called "create_empty_selection" returns Selection:
    Return Selection with:
        selected_items as list containing
        selection_bounds as None
        selection_indices as list containing
        metadata as dictionary containing

Process called "create_default_widget_style" returns WidgetStyle:
    Return WidgetStyle with:
        font as PlotCore.create_default_font()
        background_color as PlotCore.create_color with red as 0.9 and green as 0.9 and blue as 0.9 and alpha as 1.0
        border_color as PlotCore.create_color with red as 0.5 and green as 0.5 and blue as 0.5 and alpha as 1.0
        text_color as PlotCore.create_black_color()
        hover_color as PlotCore.create_color with red as 0.8 and green as 0.8 and blue as 1.0 and alpha as 1.0
        disabled_color as PlotCore.create_color with red as 0.7 and green as 0.7 and blue as 0.7 and alpha as 1.0

Process called "create_button_style" returns WidgetStyle:
    Return WidgetStyle with:
        font as PlotCore.create_default_font()
        background_color as PlotCore.create_color with red as 0.2 and green as 0.6 and blue as 1.0 and alpha as 1.0
        border_color as PlotCore.create_color with red as 0.1 and green as 0.4 and blue as 0.8 and alpha as 1.0
        text_color as PlotCore.create_white_color()
        hover_color as PlotCore.create_color with red as 0.3 and green as 0.7 and blue as 1.0 and alpha as 1.0
        disabled_color as PlotCore.create_color with red as 0.5 and green as 0.5 and blue as 0.5 and alpha as 1.0

Process called "create_brush_style" returns BrushStyle:
    Return BrushStyle with:
        border_color as PlotCore.create_color with red as 0.0 and green as 0.0 and blue as 1.0 and alpha as 1.0
        fill_color as PlotCore.create_color with red as 0.0 and green as 0.0 and blue as 1.0 and alpha as 0.2
        line_width as 1.0
        alpha as 0.7

Process called "create_default_toolbar_style" returns ToolbarStyle:
    Return ToolbarStyle with:
        background_color as PlotCore.create_color with red as 0.95 and green as 0.95 and blue as 0.95 and alpha as 1.0
        button_size as 32.0
        spacing as 4.0
        border_radius as 4.0

Process called "create_circular_buffer" that takes size as Integer returns CircularBuffer:
    Return CircularBuffer with:
        data as NDArray.zeros with shape as list containing size, 2
        capacity as size
        size as 0
        head as 0
        tail as 0

