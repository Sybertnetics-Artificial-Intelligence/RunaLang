    Return StreamingPlot with:
        figure as figure
        subplot as subplot
        data_buffer as create_circular_buffer with size as buffer_size
        update_rate as 30.0
        auto_scale as true
        time_window as 60.0
        artists as list containing

Type called "StreamingPlot":
    figure as InteractiveFigure
    subplot as PlotCore.Subplot
    data_buffer as CircularBuffer
    update_rate as Float
    auto_scale as Boolean
    time_window as Float
    artists as List[PlotCore.Artist]

Type called "CircularBuffer":
    data as NDArray.NDArray
    capacity as Integer
    size as Integer
