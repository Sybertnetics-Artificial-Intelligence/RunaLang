    scientific_notation as false

Process called "create_default_locator" returns TickLocator:
    Note: Return default tick locator
    Return TickLocator with:
    max_ticks as 10
    min_ticks as 2

Type called "TickFormatter":
    format_string as String
    scientific_notation as Boolean

Type called "TickLocator":
    max_ticks as Integer
    min_ticks as Integer

Process called "create_default_font" returns Font:
    Return Font with:
