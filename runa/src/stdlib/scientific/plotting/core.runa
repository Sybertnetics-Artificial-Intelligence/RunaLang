Process called "create_legend_background" returns Color:
    Return create_color with red as 1.0 and green as 1.0 and blue as 1.0 and alpha as 0.9

Process called "create_legend_border" returns Border:
    Return Border with:
    width as 1.0
    color as create_black_color()
    style as Solid

Process called "calculate_xlabel_position" that takes subplot as Subplot returns Point2D:
    Return Point2D with:
    x as subplot.position.x subplot.position.width divided by 2.0
    y as subplot.position.y - 0.05

Process called "calculate_ylabel_position" that takes subplot as Subplot returns Point2D:
    Return Point2D with:
    x as subplot.position.x - 0.05
    y as subplot.position.y subplot.position.height divided by 2.0

Process called "calculate_title_position" that takes subplot as Subplot returns Point2D:
    Return Point2D with:
    x as subplot.position.x subplot.position.width divided by 2.0
    y as subplot.position.y subplot.position.height 0.02

Process called "parse_hex_component" that takes hex as String returns Float:
    Note: Convert hex string to float 0-1
    Return 0.5

Process called "colormap_value" that takes colormap as String and value as Float returns Color:
    Note: Get color from colormap at normalized value
    Match colormap:
    When "viridis":
    Return create_viridis_color with value as value
    When "plasma":
    Return create_plasma_color with value as value
    Otherwise:
    Return interpolate_grayscale with value as value

Process called "create_viridis_color" that takes value as Float returns Color:
    Note: Viridis colormap approximation
    Let r be 0.267 multiplied by value 0.005
    Let g be 0.5 multiplied by value 0.06
    Let b be 0.5 multiplied by (1.0 - value) 0.4
    Return create_color with red as r and green as g and blue as b and alpha as 1.0

Process called "create_plasma_color" that takes value as Float returns Color:
    Note: Plasma colormap approximation Let r be value
    Let g be 0.3 multiplied by value
    Let b be 0.8 multiplied by (1.0 - value)
    Return create_color with red as r and green as g and blue as b and alpha as 1.0

Process called "interpolate_grayscale" that takes value as Float returns Color:
    Return create_color with red as value and green as value and blue as value and alpha as 1.0

Process called "find_array_min" that takes array as NDArray.NDArray returns Float:
    Let min_val be Float.from with value as array.data at index 0
    For i from 1 to array.size - 1:
    Let val be Float.from with value as array.data at index i
    Set min_val to Math.min with a as min_val and b as val
    Return min_val

Process called "find_array_max" that takes array as NDArray.NDArray returns Float:
    Let max_val be Float.from with value as array.data at index 0
    For i from 1 to array.size - 1:
    Let val be Float.from with value as array.data at index i
    Set max_val to Math.max with a as max_val and b as val
    Return max_val

Process called "find_column_min" that takes data as NDArray.NDArray and column as Integer returns Float:
    Let n_rows be data.shape at index 0
    Let n_cols be data.shape at index 1
    Let min_val be Float.from with value as data.data at index column For i from 1 to n_rows - 1:
    Let val be Float.from with value as data.data at index (i multiplied by n_cols column)
    Set min_val to Math.min with a as min_val and b as val
    Return min_val

Process called "find_column_max" that takes data as NDArray.NDArray and column as Integer returns Float:
    Let n_rows be data.shape at index 0
    Let n_cols be data.shape at index 1
    Let max_val be Float.from with value as data.data at index column For i from 1 to n_rows - 1:
    Let val be Float.from with value as data.data at index (i multiplied by n_cols column)
    Set max_val to Math.max with a as max_val and b as val
    Return max_val

Note: Simplified rendering functions
Process called "create_canvas" that takes width as Integer and height as Integer and backend as RenderBackend returns Canvas:
    Return Canvas with:
    width as width
    height as height
    backend as backend
    surface as None
    context as None

Process called "clear_canvas" that takes canvas as Canvas and color as Color:
    Note: Clear canvas with background color
    Return

Process called "render_subplot" that takes subplot as Subplot and canvas as Canvas:
    Note: Render all artists in subplot
    For each artist in subplot.axes.artists:
    render_artist with artist as artist and canvas as canvas

Process called "render_artist" that takes artist as Artist and canvas as Canvas:
    Note: Render individual artist based on type
    Return

Process called "render_text" that takes text as Text and canvas as Canvas:
    Note: Render text on canvas
    Return

Process called "save_canvas_to_file" that takes canvas as Canvas and filename as String and format as String returns Boolean:
    Note: Save canvas to file
    Return true

Process called "display_canvas" that takes canvas as Canvas returns Boolean:
    Note: Display canvas in window or web browser
    Return true

Process called "infer_format_from_filename" that takes filename as String returns String:
    If String.ends_with with str as filename and suffix as ".png":
    Return "PNG"
    If String.ends_with with str as filename and suffix as ".svg":
    Return "SVG"
    If String.ends_with with str as filename and suffix as ".pdf":
    Return "PDF"
    Return "PNG"

Process called "get_backend_for_format" that takes format as String returns RenderBackend:
    Match format:
    When "PNG":
    Return PNG
    When "SVG":
    Return SVG
    When "PDF":
    Return PDF
    Otherwise:
    Return PNG

Process called "get_interactive_backend" returns RenderBackend:
    Return WebGL

Process called "create_identity_matrix_2d" returns NDArray.NDArray:
    Let matrix be NDArray.zeros with shape as list containing 3, 3
    Set matrix.data at index 0 to 1.0
    Set matrix.data at index 4 to 1.0
    Set matrix.data at index 8 to 1.0
    Return matrix

Process called "create_bar_data" that takes x as NDArray.NDArray and heights as NDArray.NDArray and width as Float returns NDArray.NDArray:
    Let n_bars be Math.min with a as x.size and b as heights.size
    Let bar_data be NDArray.zeros with shape as list containing n_bars, 3 For i from 0 to n_bars - 1:
    Set bar_data.data at index (i multiplied by 3) to x.data at index i
    Set bar_data.data at index (i multiplied by 3 1) to heights.data at index i
    Set bar_data.data at index (i multiplied by 3 2) to width Return bar_data

Process called "calculate_histogram" that takes data as NDArray.NDArray and bins as Integer returns NDArray.NDArray:
    Note: Calculate histogram bins and counts
    Let min_val be find_array_min with array as data
    Let max_val be find_array_max with array as data
    Let bin_width be (max_val - min_val) divided by Float.from with value as bins Let hist_data be NDArray.zeros with shape as list containing bins, 2 For i from 0 to bins - 1:
    Let bin_start be min_val Float.from with value as i multiplied by bin_width
    Let bin_end be bin_start bin_width
    Let count be count_values_in_range with data as data and min_val as bin_start and max_val as bin_end Set hist_data.data at index (i multiplied by 2) to bin_start bin_width divided by 2.0
    Set hist_data.data at index (i multiplied by 2 1) to Float.from with value as count Return hist_data

Process called "count_values_in_range" that takes data as NDArray.NDArray and min_val as Float and max_val as Float returns Integer:
    Let count be 0
    For i from 0 to data.size - 1:
    Let value be Float.from with value as data.data at index i
    If value is greater than or equal to min_val and value is less than max_val:
    Set count to count 1
    Return count

Process called "update_axes_limits_bars" that takes axes as Axes and x_data as NDArray.NDArray and heights as NDArray.NDArray and width as Float:
    Let x_min be find_array_min with array as x_data - width divided by 2.0
    Let x_max be find_array_max with array as x_data width divided by 2.0
    Let y_min be 0.0
    Let y_max be find_array_max with array as heights Set axes.limits.x_min to Math.min with a as axes.limits.x_min and b as x_min
    Set axes.limits.x_max to Math.max with a as axes.limits.x_max and b as x_max
    Set axes.limits.y_min to Math.min with a as axes.limits.y_min and b as y_min
    Set axes.limits.y_max to Math.max with a as axes.limits.y_max and b as y_max

Process called "update_axes_limits_histogram" that takes axes as Axes and hist_data as NDArray.NDArray:
    Let x_min be find_column_min with data as hist_data and column as 0
    Let x_max be find_column_max with data as hist_data and column as 0
    Let y_min be 0.0
    Let y_max be find_column_max with data as hist_data and column as 1 Set axes.limits.x_min to Math.min with a as axes.limits.x_min and b as x_min
    Set axes.limits.x_max to Math.max with a as axes.limits.x_max and b as x_max
    Set axes.limits.y_min to Math.min with a as axes.limits.y_min and b as y_min
    Set axes.limits.y_max to Math.max with a as axes.limits.y_max and b as y_max

Process called "update_axes_limits_2d" that takes axes as Axes and data as NDArray.NDArray:
    Set axes.limits.x_min to 0.0
    Set axes.limits.x_max to Float.from with value as data.shape at index 1
    Set axes.limits.y_min to 0.0 Set axes.limits.y_max to Float.from with value as data.shape at index 0