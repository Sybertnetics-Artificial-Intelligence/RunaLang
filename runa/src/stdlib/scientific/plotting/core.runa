Note:
Runa Scientific Computing: Advanced Plotting Core

Comprehensive plotting infrastructure surpassing matplotlib and seaborn with
modern graphics pipeline, GPU acceleration, and advanced rendering capabilities.

Features:
- High-performance rendering with GPU acceleration
- Vector and raster graphics with SVG/PDF export
- Advanced color management and typography
- Multi-layered plotting system with compositing
- Animation and interactive visualization support
- Publication-quality output with precise measurements
- Customizable themes and styling system
- Memory-efficient handling of large datasets
- Multi-threaded rendering for complex scenes
- Cross-platform compatibility
:End Note

Import "scientific/core/ndarray" as NDArray
Import "collections" as Collections
Import "string" as String
Import "math/core" as Math

Type called "Figure":
    width as Float
    height as Float
    dpi as Float
    background_color as Color
    subplots as List[Subplot]
    layout as LayoutManager
    title as Optional[Text]
    metadata as Dictionary[String, Any]
    render_backend as RenderBackend
    canvas as Optional[Canvas]

Type called "Subplot":
    figure as Figure
    position as Rectangle
    axes as Axes
    title as Optional[Text]
    legend as Optional[Legend]
    annotations as List[Annotation]
    zorder as Integer

Type called "Axes":
    x_axis as Axis
    y_axis as Axis
    z_axis as Optional[Axis]
    projection as ProjectionType
    artists as List[Artist]
    limits as AxisLimits
    aspect_ratio as AspectRatio
    grid as Optional[Grid]
    background as Optional[Color]

Type ProjectionType is:
    | Cartesian
    | Polar
    | Geographic
    | ThreeD
    | LogLog
    | SemiLogX
    | SemiLogY

Type called "Axis":
    label as Optional[Text]
    scale as ScaleType
    limits as Optional[AxisRange]
    ticks as TickConfiguration
    spine as Spine
    formatter as TickFormatter
    locator as TickLocator

Type ScaleType is:
    | Linear
    | Log
    | Symlog
    | Logit
    | Function

