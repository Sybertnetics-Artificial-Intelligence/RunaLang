Note: Figure creation and management
Process called "create_figure" that takes width as Optional[Float] and height as Optional[Float] and dpi as Optional[Float] returns Figure:
    Let fig_width be width or 8.0
    Let fig_height be height or 6.0
    Let fig_dpi be dpi or 100.0 Let layout be LayoutManager with:
    layout_type as Single
    parameters as dictionary containing
    margins as create_default_margins()
    spacing as 0.1 Return Figure with:
    width as fig_width
    height as fig_height
    dpi as fig_dpi
    background_color as create_white_color()
    subplots as list containing
    layout as layout
    title as None
    metadata as dictionary containing
    render_backend as SVG
    canvas as None

Process called "add_subplot" that takes figure as Figure and rows as Integer and cols as Integer and index as Integer returns Subplot:
    Let subplot_width be figure.width divided by Float.from with value as cols
    Let subplot_height be figure.height divided by Float.from with value as rows Let row_index be (index - 1) divided by cols
    Let col_index be (index - 1) modulo cols Let x_pos be Float.from with value as col_index multiplied by subplot_width
    Let y_pos be Float.from with value as row_index multiplied by subplot_height Let position be Rectangle with:
    x as x_pos
    y as y_pos
    width as subplot_width
    height as subplot_height Let axes be create_default_axes() Let new_subplot be Subplot with:
    figure as figure
    position as position
    axes as axes
    title as None
    legend as None
    annotations as list containing
    zorder as Collections.List.length with lst as figure.subplots Add new_subplot to figure.subplots
    Return new_subplot

Process called "create_default_axes" returns Axes:
    Let x_axis be create_default_axis()
    Let y_axis be create_default_axis() Return Axes with:
    x_axis as x_axis
    y_axis as y_axis
    z_axis as None
    projection as Cartesian
    artists as list containing
    limits as create_auto_limits()
    aspect_ratio as Auto
    grid as None
    background as None

Process called "create_default_axis" returns Axis:
    Return Axis with:
    label as None
    scale as Linear
    limits as None
    ticks as create_default_tick_configuration()
    spine as create_default_spine()
    formatter as create_default_formatter()
    locator as create_default_locator()

Note: Drawing primitives
Process called "plot_line" that takes subplot as Subplot and x_data as NDArray.NDArray and y_data as NDArray.NDArray and style as Optional[Style] returns Artist:
    Let line_style be style or create_default_line_style() Note: Combine x and y data into single array
    Let plot_data be combine_xy_data with x as x_data and y as y_data Let line_artist be Artist with:
    artist_type as Line
    data as plot_data
    style as line_style
    transform as create_identity_transform()
    zorder as calculate_next_zorder with artists as subplot.axes.artists
    visible as true
    alpha as 1.0
    clip_box as None Add line_artist to subplot.axes.artists
    update_axes_limits with axes as subplot.axes and data as plot_data Return line_artist

Process called "scatter_plot" that takes subplot as Subplot and x_data as NDArray.NDArray and y_data as NDArray.NDArray and style as Optional[Style] returns Artist:
    Let scatter_style be style or create_default_scatter_style() Let plot_data be combine_xy_data with x as x_data and y as y_data Let scatter_artist be Artist with:
    artist_type as Scatter
    data as plot_data
    style as scatter_style
    transform as create_identity_transform()
    zorder as calculate_next_zorder with artists as subplot.axes.artists
    visible as true
    alpha as 1.0
    clip_box as None Add scatter_artist to subplot.axes.artists
    update_axes_limits with axes as subplot.axes and data as plot_data Return scatter_artist

Process called "bar_chart" that takes subplot as Subplot and x_data as NDArray.NDArray and heights as NDArray.NDArray and width as Optional[Float] and style as Optional[Style] returns Artist:
    Let bar_width be width or 0.8
    Let bar_style be style or create_default_bar_style() Note: Create bar data including width information
    Let bar_data be create_bar_data with x as x_data and heights as heights and width as bar_width Let bar_artist be Artist with:
    artist_type as Bar
    data as bar_data
    style as bar_style
    transform as create_identity_transform()
    zorder as calculate_next_zorder with artists as subplot.axes.artists
    visible as true
    alpha as 1.0
    clip_box as None Add bar_artist to subplot.axes.artists
    update_axes_limits_bars with axes as subplot.axes and x_data as x_data and heights as heights and width as bar_width Return bar_artist

Process called "histogram" that takes subplot as Subplot and data as NDArray.NDArray and bins as Optional[Integer] and style as Optional[Style] returns Artist:
    Let n_bins be bins or 30
    Let hist_style be style or create_default_histogram_style() Let hist_data be calculate_histogram with data as data and bins as n_bins Let hist_artist be Artist with:
    artist_type as Histogram
    data as hist_data
    style as hist_style
    transform as create_identity_transform()
    zorder as calculate_next_zorder with artists as subplot.axes.artists
    visible as true
    alpha as 0.7
    clip_box as None Add hist_artist to subplot.axes.artists
    update_axes_limits_histogram with axes as subplot.axes and hist_data as hist_data Return hist_artist

Process called "heatmap" that takes subplot as Subplot and data as NDArray.NDArray and colormap as Optional[String] and style as Optional[Style] returns Artist:
    Let cmap_name be colormap or "viridis"
    Let heatmap_style be style or create_default_heatmap_style() Note: Apply colormap to data
    Let colored_data be apply_colormap with data as data and colormap as cmap_name Let heatmap_artist be Artist with:
    artist_type as Heatmap
    data as colored_data
    style as heatmap_style
    transform as create_identity_transform()
    zorder as calculate_next_zorder with artists as subplot.axes.artists
    visible as true
    alpha as 1.0
    clip_box as None Add heatmap_artist to subplot.axes.artists
    update_axes_limits_2d with axes as subplot.axes and data as data Return heatmap_artist

Note: Styling and appearance
Process called "set_axis_labels" that takes subplot as Subplot and xlabel as Optional[String] and ylabel as Optional[String]:
    If xlabel is not None:
    Let x_label_text be Text with:
    content as xlabel
    position as calculate_xlabel_position with subplot as subplot
    font as create_default_font()
    color as create_black_color()
    alignment as Center
    rotation as 0.0
    Set subplot.axes.x_axis.label to x_label_text If ylabel is not None:
    Let y_label_text be Text with:
    content as ylabel
    position as calculate_ylabel_position with subplot as subplot
    font as create_default_font()
    color as create_black_color()
    alignment as Center
    rotation as 90.0
    Set subplot.axes.y_axis.label to y_label_text

Process called "set_title" that takes subplot as Subplot and title as String:
    Let title_text be Text with:
    content as title
    position as calculate_title_position with subplot as subplot
    font as create_title_font()
    color as create_black_color()
    alignment as Center
    rotation as 0.0
    Set subplot.title to title_text

Process called "set_axis_limits" that takes subplot as Subplot and xlim as Optional[AxisRange] and ylim as Optional[AxisRange]:
    If xlim is not None:
    Set subplot.axes.x_axis.limits to xlim
    Set subplot.axes.limits.x_min to xlim.min_value
    Set subplot.axes.limits.x_max to xlim.max_value If ylim is not None:
    Set subplot.axes.y_axis.limits to ylim
    Set subplot.axes.limits.y_min to ylim.min_value
    Set subplot.axes.limits.y_max to ylim.max_value

Process called "add_legend" that takes subplot as Subplot and labels as List[String] and position as Optional[LegendPosition] returns Legend:
    Let legend_pos be position or TopRight
    Let legend_entries be list containing Let n_artists be Math.min with a as Collections.List.length with lst as labels and b as Collections.List.length with lst as subplot.axes.artists For i from 0 to n_artists - 1:
    Let label be labels at index i
    Let artist be subplot.axes.artists at index i
    Let entry be LegendEntry with:
    label as label
    artist as artist
    handle as None
    Add entry to legend_entries Let new_legend be Legend with:
    entries as legend_entries
    position as legend_pos
    background as create_legend_background()
    border as create_legend_border()
    font as create_legend_font()
    spacing as 0.1 Set subplot.legend to new_legend
    Return new_legend

Process called "enable_grid" that takes subplot as Subplot and major as Optional[Boolean] and minor as Optional[Boolean]:
    Let show_major be major or true
    Let show_minor be minor or false Let major_grid be GridLines with:
    color as create_grid_color()
    line_width as 0.5
    line_style as Solid
    alpha as 0.3 Let minor_grid be if show_minor then GridLines with:
    color as create_grid_color()
    line_width as 0.25
    line_style as Dotted
    alpha as 0.2
    else None Set subplot.axes.grid to Grid with:
    major as major_grid
    minor as minor_grid
    visible as show_major

Note: Color management
Process called "create_color" that takes red as Float and green as Float and blue as Float and alpha as Optional[Float] returns Color:
    Let color_alpha be alpha or 1.0
    Return Color with:
    red as Math.max with a as 0.0 and b as Math.min with a as 1.0 and b as red
    green as Math.max with a as 0.0 and b as Math.min with a as 1.0 and b as green
    blue as Math.max with a as 0.0 and b as Math.min with a as 1.0 and b as blue
    alpha as Math.max with a as 0.0 and b as Math.min with a as 1.0 and b as color_alpha

Process called "create_color_from_hex" that takes hex_code as String returns Color:
    Note: Parse hex color code like "#FF0000"
    Let clean_hex be if String.starts_with with str as hex_code and prefix as "#" then String.substring with str as hex_code and start as 1 else hex_code Let red_val be parse_hex_component with hex as String.substring with str as clean_hex and start as 0 and length as 2
    Let green_val be parse_hex_component with hex as String.substring with str as clean_hex and start as 2 and length as 2
    Let blue_val be parse_hex_component with hex as String.substring with str as clean_hex and start as 4 and length as 2 Return create_color with red as red_val and green as green_val and blue as blue_val and alpha as 1.0

Process called "apply_colormap" that takes data as NDArray.NDArray and colormap as String returns NDArray.NDArray:
    Note: Apply colormap to normalize data values to colors
    Let min_val be find_array_min with array as data
    Let max_val be find_array_max with array as data
    Let range_val be max_val - min_val Let colored_data be NDArray.zeros with shape as list containing data.shape at index 0, data.shape at index 1, 3 For i from 0 to data.shape at index 0 - 1:
    For j from 0 to data.shape at index 1 - 1:
    Let value be Float.from with value as data.data at index (i multiplied by data.shape at index 1 j)
    Let normalized be if range_val is greater than 0.0 then (value - min_val) divided by range_val else 0.5
    Let color be colormap_value with colormap as colormap and value as normalized Set colored_data.data at index (i multiplied by data.shape at index 1 multiplied by 3 j multiplied by 3) to color.red
    Set colored_data.data at index (i multiplied by data.shape at index 1 multiplied by 3 j multiplied by 3 1) to color.green
    Set colored_data.data at index (i multiplied by data.shape at index 1 multiplied by 3 j multiplied by 3 2) to color.blue Return colored_data

Note: Rendering and output
Process called "render_figure" that takes figure as Figure and backend as Optional[RenderBackend] returns Canvas:
    Let render_backend be backend or figure.render_backend
    Let canvas be create_canvas with width as Integer.from with value as figure.width multiplied by figure.dpi and height as Integer.from with value as figure.height multiplied by figure.dpi and backend as render_backend Note: Clear canvas with background color
    clear_canvas with canvas as canvas and color as figure.background_color Note: Render each subplot
    For each subplot in figure.subplots:
    render_subplot with subplot as subplot and canvas as canvas Note: Render figure title if present
    If figure.title is not None:
    render_text with text as figure.title and canvas as canvas Set figure.canvas to canvas
    Return canvas

Process called "save_figure" that takes figure as Figure and filename as String and format as Optional[String] returns Boolean:
    Let output_format be format or infer_format_from_filename with filename as filename
    Let canvas be render_figure with figure as figure and backend as get_backend_for_format with format as output_format Return save_canvas_to_file with canvas as canvas and filename as filename and format as output_format

Process called "show_figure" that takes figure as Figure returns Boolean:
    Let canvas be render_figure with figure as figure and backend as get_interactive_backend()
    Return display_canvas with canvas as canvas

