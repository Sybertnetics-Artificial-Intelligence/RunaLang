Note:
Runa Scientific Computing: High-Level Chart Types

Comprehensive collection of ready-to-use chart types surpassing matplotlib, seaborn,
and plotly with intelligent defaults and publication-quality output.

Features:
- Statistical plots (violin, box, swarm, regression)
- Scientific plots (error bars, contour, 3D surface, polar)
- Financial charts (candlestick, OHLC, volume, Bollinger bands)
- Specialized visualizations (treemap, sankey, chord diagrams)
- Multi-panel layouts with automatic alignment
- Smart defaults with minimal configuration required
- Automatic statistical computations and annotations
- Professional color schemes and typography
- Export-ready formatting for papers and presentations
:End Note

Import "scientific/plotting/core" as PlotCore
Import "scientific/core/ndarray" as NDArray
Import "statistics/core" as Stats
Import "../../collections" as Collections
Import "math/core" as Math
Import "../../string" as String

Type called "StatisticalPlot":
    plot_type as StatPlotType
    data as NDArray.NDArray
    grouping as Optional[NDArray.NDArray]
    statistics as PlotStatistics
    confidence_intervals as List[ConfidenceInterval]
    annotations as List[StatAnnotation]
    subplot as PlotCore.Subplot

Type StatPlotType is:
    | BoxPlot
    | ViolinPlot
    | SwarmPlot
    | StripPlot
    | BarPlot
    | PointPlot
    | RegressionPlot
    | ResidualPlot
    | QQPlot

Type called "PlotStatistics":
    mean as Optional[Float]
    median as Optional[Float]
    std_dev as Optional[Float]
    quartiles as Optional[List[Float]]
    outliers as List[Float]
    correlation as Optional[Float]
    r_squared as Optional[Float]
    p_value as Optional[Float]

Type called "ConfidenceInterval":
    level as Float
    lower_bound as Float
    upper_bound as Float
    interval_type as IntervalType

Type IntervalType is:
    | Bootstrap
    | Parametric
    | Percentile

Type called "StatAnnotation":
    text as String
    position as PlotCore.Point2D
    p_value as Optional[Float]
    test_statistic as Optional[Float]
    significance_level as Float

Type called "ScientificPlot":
    plot_type as SciPlotType
    primary_data as NDArray.NDArray
    error_data as Optional[NDArray.NDArray]
    secondary_data as Optional[NDArray.NDArray]
    parameters as PlotParameters
    subplot as PlotCore.Subplot

Type SciPlotType is:
    | ErrorBarPlot
    | ContourPlot
    | Surface3D
    | PolarPlot
    | RadarChart
    | HeatmapWithDendrogram
    | PhasePlot
    | VectorField

Type called "PlotParameters":
    levels as Optional[List[Float]]
    colormap as String
    contour_labels as Boolean
    error_bar_caps as Boolean
    error_bar_width as Float
    surface_alpha as Float
    mesh_resolution as Integer

Type called "FinancialChart":
    chart_type as FinChartType
    price_data as PriceData
    volume_data as Optional[NDArray.NDArray]
    indicators as List[TechnicalIndicator]
    subplot as PlotCore.Subplot

Type FinChartType is:
    | Candlestick
    | OHLC
    | LineChart
    | VolumeChart
    | CombinedChart

Type called "PriceData":
    dates as NDArray.NDArray
    open_prices as NDArray.NDArray
    high_prices as NDArray.NDArray
    low_prices as NDArray.NDArray
    close_prices as NDArray.NDArray

Type called "TechnicalIndicator":
    indicator_type as IndicatorType
    parameters as Dictionary[String, Float]
    data as NDArray.NDArray
    style as PlotCore.Style

Type IndicatorType is:
    | MovingAverage
    | BollingerBands
    | RSI
    | MACD
    | Stochastic
    | Fibonacci

Type called "SpecializedChart":
    chart_type as SpecChartType
    data as NDArray.NDArray
    hierarchy as Optional[HierarchyData]
    flow_data as Optional[FlowData]
    network_data as Optional[NetworkData]
    subplot as PlotCore.Subplot

Type SpecChartType is:
    | Treemap
    | Sunburst
    | SankeyDiagram
    | ChordDiagram
    | NetworkGraph
    | ParallelCoordinates
    | AlluvialDiagram

Type called "HierarchyData":
    nodes as List[HierarchyNode]
    parent_child_map as Dictionary[String, List[String]]
    values as Dictionary[String, Float]

Type called "HierarchyNode":
    id as String
    label as String
    parent as Optional[String]
