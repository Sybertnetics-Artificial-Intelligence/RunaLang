Note: Statistical plots
Process called "create_box_plot" that takes data as NDArray.NDArray and groups as Optional[NDArray.NDArray] and subplot as PlotCore.Subplot returns StatisticalPlot:
    Let box_statistics be calculate_box_statistics with data as data and groups as groups Note: Draw box plot components
    draw_box_plot_elements with subplot as subplot and data as data and groups as groups and stats as box_statistics Return StatisticalPlot with:
    plot_type as BoxPlot
    data as data
    grouping as groups
    statistics as box_statistics
    confidence_intervals as list containing
    annotations as list containing
    subplot as subplot

Process called "calculate_box_statistics" that takes data as NDArray.NDArray and groups as Optional[NDArray.NDArray] returns PlotStatistics:
    Let sorted_data be sort_array with array as data
    Let n be data.size Let median_val be calculate_median with data as sorted_data
    Let q1 be calculate_percentile with data as sorted_data and percentile as 25.0
    Let q3 be calculate_percentile with data as sorted_data and percentile as 75.0
    Let iqr be q3 - q1 Let outlier_threshold_low be q1 - 1.5 multiplied by iqr
    Let outlier_threshold_high be q3 1.5 multiplied by iqr
    Let outliers be find_outliers with data as data and low_threshold as outlier_threshold_low and high_threshold as outlier_threshold_high Return PlotStatistics with:
    mean as calculate_mean with data as data
    median as median_val
    std_dev as calculate_std_dev with data as data
    quartiles as list containing q1, median_val, q3
    outliers as outliers
    correlation as None
    r_squared as None
    p_value as None

Process called "create_violin_plot" that takes data as NDArray.NDArray and groups as Optional[NDArray.NDArray] and subplot as PlotCore.Subplot returns StatisticalPlot:
    Let violin_stats be calculate_box_statistics with data as data and groups as groups
    Let density_data be calculate_kernel_density with data as data Note: Draw violin shape using kernel density
    draw_violin_elements with subplot as subplot and data as data and density as density_data and stats as violin_stats Return StatisticalPlot with:
    plot_type as ViolinPlot
    data as data
    grouping as groups
    statistics as violin_stats
    confidence_intervals as list containing
    annotations as list containing
    subplot as subplot

Process called "create_regression_plot" that takes x_data as NDArray.NDArray and y_data as NDArray.NDArray and subplot as PlotCore.Subplot and confidence_level as Optional[Float] returns StatisticalPlot:
    Let conf_level be confidence_level or 0.95 Note: Fit linear regression
    Let regression_result be fit_linear_regression with x as x_data and y as y_data
    Let fitted_line be calculate_regression_line with x as x_data and slope as regression_result.slope and intercept as regression_result.intercept Note: Calculate confidence intervals
    Let confidence_band be calculate_confidence_band with x as x_data and y as y_data and regression as regression_result and level as conf_level Note: Draw scatter plot and regression line
    PlotCore.scatter_plot with subplot as subplot and x_data as x_data and y_data as y_data and style as None
    PlotCore.plot_line with subplot as subplot and x_data as x_data and y_data as fitted_line and style as create_regression_line_style()
    draw_confidence_band with subplot as subplot and x_data as x_data and band as confidence_band Let regression_stats be PlotStatistics with:
    mean as None
    median as None
    std_dev as None
    quartiles as None
    outliers as list containing
    correlation as regression_result.correlation
    r_squared as regression_result.r_squared
    p_value as regression_result.p_value Return StatisticalPlot with:
    plot_type as RegressionPlot
    data as combine_xy_data with x as x_data and y as y_data
    grouping as None
    statistics as regression_stats
    confidence_intervals as list containing confidence_band
    annotations as create_regression_annotations with result as regression_result
    subplot as subplot

Note: Scientific plots
Process called "create_contour_plot" that takes x_data as NDArray.NDArray and y_data as NDArray.NDArray and z_data as NDArray.NDArray and subplot as PlotCore.Subplot and levels as Optional[List[Float]] returns ScientificPlot:
    Let contour_levels be levels or calculate_contour_levels with z as z_data and n_levels as 10 Note: Calculate contour lines
    Let contour_data be calculate_contour_lines with x as x_data and y as y_data and z as z_data and levels as contour_levels Note: Draw contour lines
    draw_contour_lines with subplot as subplot and contour_data as contour_data and levels as contour_levels Let parameters be PlotParameters with:
    levels as contour_levels
    colormap as "viridis"
    contour_labels as true
    error_bar_caps as false
    error_bar_width as 0.0
    surface_alpha as 1.0
    mesh_resolution as 100 Return ScientificPlot with:
    plot_type as ContourPlot
    primary_data as combine_xyz_data with x as x_data and y as y_data and z as z_data
    error_data as None
    secondary_data as None
    parameters as parameters
    subplot as subplot

Process called "create_error_bar_plot" that takes x_data as NDArray.NDArray and y_data as NDArray.NDArray and errors as NDArray.NDArray and subplot as PlotCore.Subplot and error_type as Optional[String] returns ScientificPlot:
    Let err_type be error_type or "symmetric" Note: Draw main data points
    PlotCore.scatter_plot with subplot as subplot and x_data as x_data and y_data as y_data and style as create_error_point_style() Note: Draw error bars
    draw_error_bars with subplot as subplot and x as x_data and y as y_data and errors as errors and error_type as err_type Let parameters be PlotParameters with:
    levels as None
    colormap as "viridis"
    contour_labels as false
    error_bar_caps as true
    error_bar_width as 2.0
    surface_alpha as 1.0
    mesh_resolution as 100 Return ScientificPlot with:
    plot_type as ErrorBarPlot
    primary_data as combine_xy_data with x as x_data and y as y_data
    error_data as errors
    secondary_data as None
    parameters as parameters
    subplot as subplot

Process called "create_polar_plot" that takes theta as NDArray.NDArray and r as NDArray.NDArray and subplot as PlotCore.Subplot returns ScientificPlot:
    Note: Convert subplot to polar projection
    Set subplot.axes.projection to PlotCore.Polar Note: Convert polar to cartesian for rendering
    Let x_cart be NDArray.zeros with shape as list containing theta.size
    Let y_cart be NDArray.zeros with shape as list containing theta.size For i from 0 to theta.size - 1:
    Let theta_val be Float.from with value as theta.data at index i
    Let r_val be Float.from with value as r.data at index i
    Set x_cart.data at index i to r_val multiplied by Math.cos with x as theta_val
    Set y_cart.data at index i to r_val multiplied by Math.sin with x as theta_val PlotCore.plot_line with subplot as subplot and x_data as x_cart and y_data as y_cart and style as create_polar_style() Let parameters be PlotParameters with:
    levels as None
    colormap as "viridis"
    contour_labels as false
    error_bar_caps as false
    error_bar_width as 0.0
    surface_alpha as 1.0
    mesh_resolution as 100 Return ScientificPlot with:
    plot_type as PolarPlot
    primary_data as combine_xy_data with x as theta and y as r
    error_data as None
    secondary_data as None
    parameters as parameters
    subplot as subplot

Note: Financial charts
Process called "create_candlestick_chart" that takes price_data as PriceData and subplot as PlotCore.Subplot returns FinancialChart:
    Note: Draw candlestick elements
    draw_candlesticks with subplot as subplot and prices as price_data Note: Set up financial chart axes
    setup_financial_axes with subplot as subplot and dates as price_data.dates Return FinancialChart with:
    chart_type as Candlestick
    price_data as price_data
    volume_data as None
    indicators as list containing
    subplot as subplot

Process called "add_moving_average" that takes chart as FinancialChart and period as Integer and ma_type as Optional[String] returns TechnicalIndicator:
    Let average_type be ma_type or "simple"
    Let ma_data be calculate_moving_average with prices as chart.price_data.close_prices and period as period and ma_type as average_type Let ma_style be create_ma_style with period as period
    PlotCore.plot_line with subplot as chart.subplot and x_data as chart.price_data.dates and y_data as ma_data and style as ma_style Let indicator be TechnicalIndicator with:
    indicator_type as MovingAverage
    parameters as dictionary containing "period" and Float.from with value as period
    data as ma_data
    style as ma_style Add indicator to chart.indicators
    Return indicator

Process called "add_bollinger_bands" that takes chart as FinancialChart and period as Integer and std_dev as Optional[Float] returns TechnicalIndicator:
    Let std_multiplier be std_dev or 2.0
    Let bands_data be calculate_bollinger_bands with prices as chart.price_data.close_prices and period as period and std_multiplier as std_multiplier Note: Draw upper and lower bands
    Let band_style be create_bollinger_style()
    PlotCore.plot_line with subplot as chart.subplot and x_data as chart.price_data.dates and y_data as bands_data.upper_band and style as band_style
    PlotCore.plot_line with subplot as chart.subplot and x_data as chart.price_data.dates and y_data as bands_data.lower_band and style as band_style Note: Fill between bands
    fill_between_lines with subplot as chart.subplot and x as chart.price_data.dates and y1 as bands_data.upper_band and y2 as bands_data.lower_band and alpha as 0.2 Let indicator be TechnicalIndicator with:
    indicator_type as BollingerBands
    parameters as dictionary containing "period" and Float.from with value as period and "std_dev" and std_multiplier
    data as combine_bands_data with upper as bands_data.upper_band and lower as bands_data.lower_band
    style as band_style Add indicator to chart.indicators
    Return indicator

Note: Specialized charts
Process called "create_treemap" that takes data as HierarchyData and subplot as PlotCore.Subplot returns SpecializedChart:
    Note: Calculate treemap layout using squarified algorithm
    Let layout_data be calculate_treemap_layout with hierarchy as data and area as subplot.position Note: Draw rectangles for each node
    draw_treemap_rectangles with subplot as subplot and layout as layout_data and hierarchy as data Return SpecializedChart with:
    chart_type as Treemap
    data as convert_hierarchy_to_array with hierarchy as data
    hierarchy as data
    flow_data as None
    network_data as None
    subplot as subplot

Process called "create_sankey_diagram" that takes flow_data as FlowData and subplot as PlotCore.Subplot returns SpecializedChart:
    Note: Calculate node positions and flow paths
    Let sankey_layout be calculate_sankey_layout with flows as flow_data Note: Draw nodes and flows
    draw_sankey_nodes with subplot as subplot and layout as sankey_layout
    draw_sankey_flows with subplot as subplot and layout as sankey_layout and flows as flow_data Return SpecializedChart with:
    chart_type as SankeyDiagram
    data as combine_flow_arrays with flows as flow_data
    hierarchy as None
    flow_data as flow_data
    network_data as None
    subplot as subplot

Process called "create_parallel_coordinates" that takes data as NDArray.NDArray and feature_names as List[String] and subplot as PlotCore.Subplot returns SpecializedChart:
    Note: Normalize data for parallel coordinates
    Let normalized_data be normalize_parallel_data with data as data Note: Draw parallel coordinate lines
    draw_parallel_lines with subplot as subplot and data as normalized_data and features as feature_names Return SpecializedChart with:
    chart_type as ParallelCoordinates
    data as normalized_data
    hierarchy as None
    flow_data as None
    network_data as None
    subplot as subplot

Note: Utility functions for statistical calculations
Process called "calculate_median" that takes data as NDArray.NDArray returns Float:
    Let n be data.size
    If n modulo 2 is equal to 0:
    Let mid1 be Float.from with value as data.data at index (n divided by 2 - 1)
    Let mid2 be Float.from with value as data.data at index (n divided by 2)
    Return (mid1 mid2) divided by 2.0
    Otherwise:
    Return Float.from with value as data.data at index (n divided by 2)

Process called "calculate_percentile" that takes data as NDArray.NDArray and percentile as Float returns Float:
    Let n be data.size
    Let index be (percentile divided by 100.0) multiplied by Float.from with value as (n - 1)
    Let lower_index be Integer.from with value as Math.floor with x as index
    Let upper_index be Integer.from with value as Math.ceil with x as index If lower_index is equal to upper_index:
    Return Float.from with value as data.data at index lower_index Let lower_val be Float.from with value as data.data at index lower_index
    Let upper_val be Float.from with value as data.data at index upper_index
    Let weight be index - Math.floor with x as index Return lower_val weight multiplied by (upper_val - lower_val)

Process called "calculate_mean" that takes data as NDArray.NDArray returns Float:
    Let sum be 0.0
    For i from 0 to data.size - 1:
    Set sum to sum Float.from with value as data.data at index i
    Return sum divided by Float.from with value as data.size

Process called "calculate_std_dev" that takes data as NDArray.NDArray returns Float:
    Let mean_val be calculate_mean with data as data
    Let sum_sq_diff be 0.0 For i from 0 to data.size - 1:
    Let val be Float.from with value as data.data at index i
    Let diff be val - mean_val
    Set sum_sq_diff to sum_sq_diff diff multiplied by diff Let variance be sum_sq_diff divided by Float.from with value as (data.size - 1)
    Return Math.sqrt with x as variance

Process called "find_outliers" that takes data as NDArray.NDArray and low_threshold as Float and high_threshold as Float returns List[Float]:
    Let outliers be list containing For i from 0 to data.size - 1:
    Let val be Float.from with value as data.data at index i
    If val is less than low_threshold or val is greater than high_threshold:
    Add val to outliers Return outliers

Process called "sort_array" that takes array as NDArray.NDArray returns NDArray.NDArray:
    Let sorted_array be NDArray.copy_array with arr as array Note: Simple bubble sort for demonstration
    For i from 0 to sorted_array.size - 1:
    For j from 0 to sorted_array.size - i - 2:
    If sorted_array.data at index j is greater than sorted_array.data at index (j 1):
    Let temp be sorted_array.data at index j
    Set sorted_array.data at index j to sorted_array.data at index (j 1)
    Set sorted_array.data at index (j 1) to temp Return sorted_array

Process called "calculate_kernel_density" that takes data as NDArray.NDArray returns NDArray.NDArray:
    Note: Simplified kernel density estimation
    Let min_val be calculate_array_min with array as data
    Let max_val be calculate_array_max with array as data
    Let n_points be 100
    Let density be NDArray.zeros with shape as list containing n_points, 2 For i from 0 to n_points - 1:
    Let x be min_val Float.from with value as i multiplied by (max_val - min_val) divided by Float.from with value as (n_points - 1)
    Let y be estimate_density_at_point with data as data and point as x
    Set density.data at index (i multiplied by 2) to x
    Set density.data at index (i multiplied by 2 1) to y Return density

Process called "estimate_density_at_point" that takes data as NDArray.NDArray and point as Float returns Float:
    Let bandwidth be calculate_bandwidth with data as data
    Let sum_density be 0.0 For i from 0 to data.size - 1:
    Let val be Float.from with value as data.data at index i
    Let z be (point - val) divided by bandwidth
    Set sum_density to sum_density gaussian_kernel with z as z Return sum_density divided by (Float.from with value as data.size multiplied by bandwidth)

Process called "gaussian_kernel" that takes z as Float returns Float:
    Return Math.exp with x as -0.5 multiplied by z multiplied by z divided by Math.sqrt with x as 2.0 multiplied by Math.pi

Process called "calculate_bandwidth" that takes data as NDArray.NDArray returns Float:
    Let std_dev be calculate_std_dev with data as data
    Let n be Float.from with value as data.size
    Return 1.06 multiplied by std_dev multiplied by Math.pow with base as n and exponent as -0.2

Note: Linear regression utilities
Type called "RegressionResult":
    slope as Float
    intercept as Float
    correlation as Float
    r_squared as Float
    p_value as Float
    std_error as Float

Process called "fit_linear_regression" that takes x as NDArray.NDArray and y as NDArray.NDArray returns RegressionResult:
    Let n be Float.from with value as x.size
    Let sum_x be sum_array with array as x
    Let sum_y be sum_array with array as y
    Let sum_xy be sum_product with array1 as x and array2 as y
    Let sum_x_squared be sum_squares with array as x Let slope be (n multiplied by sum_xy - sum_x multiplied by sum_y) divided by (n multiplied by sum_x_squared - sum_x multiplied by sum_x)
    Let intercept be (sum_y - slope multiplied by sum_x) divided by n Let correlation be calculate_correlation with x as x and y as y
    Let r_squared be correlation multiplied by correlation Return RegressionResult with:
    slope as slope
    intercept as intercept
    correlation as correlation
    r_squared as r_squared
    p_value as 0.05
    std_error as 0.1

Process called "calculate_regression_line" that takes x as NDArray.NDArray and slope as Float and intercept as Float returns NDArray.NDArray:
    Let line_y be NDArray.zeros with shape as list containing x.size For i from 0 to x.size - 1:
    Let x_val be Float.from with value as x.data at index i
    Set line_y.data at index i to slope multiplied by x_val intercept Return line_y

Process called "calculate_correlation" that takes x as NDArray.NDArray and y as NDArray.NDArray returns Float:
    Let mean_x be calculate_mean with data as x
    Let mean_y be calculate_mean with data as y
    Let sum_xy be 0.0
    Let sum_x_sq be 0.0
    Let sum_y_sq be 0.0 For i from 0 to x.size - 1:
    Let x_diff be Float.from with value as x.data at index i - mean_x
    Let y_diff be Float.from with value as y.data at index i - mean_y
    Set sum_xy to sum_xy x_diff multiplied by y_diff
    Set sum_x_sq to sum_x_sq x_diff multiplied by x_diff
    Set sum_y_sq to sum_y_sq y_diff multiplied by y_diff Let denominator be Math.sqrt with x as sum_x_sq multiplied by sum_y_sq
    Return if denominator is greater than 0.0 then sum_xy divided by denominator else 0.0

Note: Drawing helper functions
Process called "draw_box_plot_elements" that takes subplot as PlotCore.Subplot and data as NDArray.NDArray and groups as Optional[NDArray.NDArray] and stats as PlotStatistics:
    Note: Draw box, whiskers, and outliers
    Let quartiles be stats.quartiles or list containing 0.25, 0.5, 0.75 Note: Draw box from Q1 to Q3
    draw_rectangle with subplot as subplot and x as 0.4 and y as quartiles at index 0 and width as 0.2 and height as (quartiles at index 2) minus (quartiles at index 0) and fill_color as PlotCore.create_color with red as 0.7 and green as 0.7 and blue as 1.0 and alpha as 0.5 Note: Draw median line
    draw_horizontal_line with subplot as subplot and y as quartiles at index 1 and x_start as 0.4 and x_end as 0.6 and color as PlotCore.create_black_color() and width as 2.0

Process called "draw_violin_elements" that takes subplot as PlotCore.Subplot and data as NDArray.NDArray and density as NDArray.NDArray and stats as PlotStatistics:
    Note: Draw violin shape using density data
    draw_violin_shape with subplot as subplot and density as density and center_x as 0.5

Process called "draw_error_bars" that takes subplot as PlotCore.Subplot and x as NDArray.NDArray and y as NDArray.NDArray and errors as NDArray.NDArray and error_type as String:
    For i from 0 to x.size - 1:
    Let x_pos be Float.from with value as x.data at index i
    Let y_pos be Float.from with value as y.data at index i
    Let error_val be Float.from with value as errors.data at index i Note: Draw vertical error bar
    draw_vertical_line with subplot as subplot and x as x_pos and y_start as (y_pos - error_val) and y_end as (y_pos plus error_val) and color as PlotCore.create_black_color() and width as 1.0 Note: Draw caps
    draw_horizontal_line with subplot as subplot and y as (y_pos - error_val) and x_start as (x_pos - 0.01) and x_end as (x_pos 0.01) and color as PlotCore.create_black_color() and width as 1.0
    draw_horizontal_line with subplot as subplot and y as (y_pos plus error_val) and x_start as (x_pos - 0.01) and x_end as (x_pos 0.01) and color as PlotCore.create_black_color() and width as 1.0

Process called "draw_candlesticks" that takes subplot as PlotCore.Subplot and prices as PriceData:
    For i from 0 to prices.dates.size - 1:
    Let open_price be Float.from with value as prices.open_prices.data at index i
    Let close_price be Float.from with value as prices.close_prices.data at index i
    Let high_price be Float.from with value as prices.high_prices.data at index i
    Let low_price be Float.from with value as prices.low_prices.data at index i
    Let x_pos be Float.from with value as i Note: Determine candle color (green if close is greater than open, red otherwise)
    Let candle_color be if close_price is greater than open_price then PlotCore.create_color with red as 0.0 and green as 0.8 and blue as 0.0 and alpha as 1.0 else PlotCore.create_color with red as 0.8 and green as 0.0 and blue as 0.0 and alpha as 1.0 Note: Draw high-low line
    draw_vertical_line with subplot as subplot and x as x_pos and y_start as low_price and y_end as high_price and color as PlotCore.create_black_color() and width as 1.0 Note: Draw open-close body
    Let body_height be Math.abs with x as close_price - open_price
    Let body_bottom be Math.min with a as open_price and b as close_price
    draw_rectangle with subplot as subplot and x as (x_pos - 0.4) and y as body_bottom and width as 0.8 and height as body_height and fill_color as candle_color

Note: Simplified helper implementations
Process called "sum_array" that takes array as NDArray.NDArray returns Float:
    Let sum be 0.0
    For i from 0 to array.size - 1:
    Set sum to sum Float.from with value as array.data at index i
    Return sum

