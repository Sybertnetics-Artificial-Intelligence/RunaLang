Process called "start_profiling_session" that takes monitor as PerformanceMonitor returns ProfilingSession:
    Let session_id be generate_session_id()
    Let session be ProfilingSession with:
    session_id as session_id
    start_time as DateTime.now()
    end_time as None
    operations_profiled as list containing
    total_gpu_time_ms as 0.0
    total_cpu_time_ms as 0.0
    memory_peak_mb as 0.0 Add session to monitor.profiling_sessions
    Return session

Process called "end_profiling_session" that takes session as ProfilingSession returns PerformanceReport:
    Set session.end_time to DateTime.now() Let report be generate_performance_report with session as session
    Return report

Type called "PerformanceReport":
    report_id as String
    session_id as String
    generation_time as DateTime.DateTime
