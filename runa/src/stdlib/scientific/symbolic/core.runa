Note:
Runa Scientific Computing: Symbolic Mathematics Core

Advanced symbolic computation capabilities surpassing SymPy with
comprehensive expression manipulation, calculus operations, and algebraic systems.
Production-ready implementations for AI-powered mathematical reasoning.

Features:
- Symbolic expression representation and manipulation
- Automatic differentiation and integration
- Algebraic simplification and expansion
- Equation solving (linear, polynomial, transcendental)
- Matrix symbolic operations
- Series expansion and limits
- Symbolic linear algebra
- Computer algebra system (CAS) operations
- LaTeX and mathematical notation output
- Mathematical theorem proving support
:End Note

Import "scientific/core/ndarray" as NDArray
Import "collections" as Collections
Import "math/core" as Math
Import "datetime" as DateTime
Import "string" as String

Note: Core symbolic types
Type called "SymbolicExpression":
    expression_type as ExpressionType
    value as Any
    children as List[SymbolicExpression]
    variables as List[String]
    constants as Dictionary[String, Float]
    properties as ExpressionProperties
    metadata as Dictionary[String, Any]

Type ExpressionType is:
    | Symbol
    | Number
    | Add
    | Multiply
    | Power
    | Function
    | Derivative
    | Integral
    | Matrix
    | Equation

Type called "ExpressionProperties":
    is_constant as Boolean
    is_polynomial as Boolean
    is_rational as Boolean
    is_transcendental as Boolean
    degree as Integer
    complexity as Integer
    variables_count as Integer
    metadata as Dictionary[String, Any]

Type called "SymbolicMatrix":
    expressions as List[List[SymbolicExpression]]
    rows as Integer
    columns as Integer
    is_square as Boolean
    is_diagonal as Boolean
    is_symmetric as Boolean
    determinant as Optional[SymbolicExpression]
    metadata as Dictionary[String, Any]

Type called "SymbolicEquation":
    left_side as SymbolicExpression
    right_side as SymbolicExpression
    equation_type as EquationType
    solutions as List[SymbolicExpression]
    variables as List[String]
    degree as Integer
    metadata as Dictionary[String, Any]

Type EquationType is:
    | Linear
    | Quadratic
    | Polynomial
    | Transcendental
    | Differential
    | System

Type called "DerivativeResult":
    original_expression as SymbolicExpression
    derivative as SymbolicExpression
    variable as String
    order as Integer
    chain_rule_steps as List[SymbolicExpression]
    simplified as SymbolicExpression
    metadata as Dictionary[String, Any]

Type called "IntegrationResult":
    original_expression as SymbolicExpression
    antiderivative as SymbolicExpression
    variable as String
    integration_method as IntegrationMethod
    substitutions as List[SymbolicSubstitution]
    definite_bounds as Optional[Tuple[SymbolicExpression, SymbolicExpression]]
    definite_value as Optional[SymbolicExpression]
    metadata as Dictionary[String, Any]

Type IntegrationMethod is:
    | PowerRule
    | ChainRule
    | PartsByParts
    | Substitution
    | PartialFractions
    | Trigonometric
    | Numerical

Type called "SymbolicSubstitution":
    variable as String
    expression as SymbolicExpression
    reverse as Boolean
    metadata as Dictionary[String, Any]

Note: Basic symbolic expression creation
Process called "create_symbol" that takes name as String returns SymbolicExpression:
    Return SymbolicExpression with:
    expression_type as Symbol
    value as name
    children as list containing
    variables as list containing name
    constants as dictionary containing
    properties as ExpressionProperties with:
    is_constant as false
    is_polynomial as true
    is_rational as true
    is_transcendental as false
    degree as 1
    complexity as 1
    variables_count as 1
    metadata as dictionary containing
    metadata as dictionary containing

Process called "create_number" that takes value as Float returns SymbolicExpression:
    Return SymbolicExpression with:
    expression_type as Number
    value as value
    children as list containing
    variables as list containing
    constants as dictionary containing
    properties as ExpressionProperties with:
    is_constant as true
    is_polynomial as true
    is_rational as true
    is_transcendental as false
    degree as 0
    complexity as 0
    variables_count as 0
    metadata as dictionary containing
    metadata as dictionary containing

Process called "create_add" that takes left as SymbolicExpression and right as SymbolicExpression returns SymbolicExpression:
    Let combined_vars be combine_variable_lists with list1 as left.variables and list2 as right.variables
    Let max_degree be Math.max with a as left.properties.degree and b as right.properties.degree
    Let total_complexity be left.properties.complexity right.properties.complexity 1 Return SymbolicExpression with:
    expression_type as Add
    value as "+"
    children as list containing left, right
    variables as combined_vars
    constants as combine_constants with dict1 as left.constants and dict2 as right.constants
    properties as ExpressionProperties with:
    is_constant as left.properties.is_constant and right.properties.is_constant
    is_polynomial as left.properties.is_polynomial and right.properties.is_polynomial
    is_rational as left.properties.is_rational and right.properties.is_rational
    is_transcendental as left.properties.is_transcendental or right.properties.is_transcendental
    degree as max_degree
    complexity as total_complexity
    variables_count as Collections.List.length with lst as combined_vars
    metadata as dictionary containing
    metadata as dictionary containing

Process called "create_multiply" that takes left as SymbolicExpression and right as SymbolicExpression returns SymbolicExpression:
    Let combined_vars be combine_variable_lists with list1 as left.variables and list2 as right.variables
    Let total_degree be left.properties.degree right.properties.degree
    Let total_complexity be left.properties.complexity right.properties.complexity 2 Return SymbolicExpression with:
    expression_type as Multiply
    value as "*"
    children as list containing left, right
    variables as combined_vars
    constants as combine_constants with dict1 as left.constants and dict2 as right.constants
    properties as ExpressionProperties with:
    is_constant as left.properties.is_constant and right.properties.is_constant
    is_polynomial as left.properties.is_polynomial and right.properties.is_polynomial
    is_rational as left.properties.is_rational and right.properties.is_rational
    is_transcendental as left.properties.is_transcendental or right.properties.is_transcendental
    degree as total_degree
    complexity as total_complexity
    variables_count as Collections.List.length with lst as combined_vars
    metadata as dictionary containing
    metadata as dictionary containing

Process called "create_power" that takes base as SymbolicExpression and exponent as SymbolicExpression returns SymbolicExpression:
    Let combined_vars be combine_variable_lists with list1 as base.variables and list2 as exponent.variables
    Let is_poly be base.properties.is_polynomial and exponent.properties.is_constant and is_positive_integer with expr as exponent
    Let degree_multiplier be if exponent.expression_type is Number then Float.from with value as exponent.value else 1.0
    Let new_degree be Integer.from with value as Float.from with value as base.properties.degree multiplied by degree_multiplier Return SymbolicExpression with:
    expression_type as Power
    value as "^"
    children as list containing base, exponent
    variables as combined_vars
    constants as combine_constants with dict1 as base.constants and dict2 as exponent.constants
    properties as ExpressionProperties with:
    is_constant as base.properties.is_constant and exponent.properties.is_constant
    is_polynomial as is_poly
    is_rational as base.properties.is_rational and exponent.properties.is_rational
    is_transcendental as not is_poly
    degree as new_degree
    complexity as base.properties.complexity exponent.properties.complexity 3
    variables_count as Collections.List.length with lst as combined_vars
    metadata as dictionary containing
    metadata as dictionary containing

Process called "create_function" that takes function_name as String and argument as SymbolicExpression returns SymbolicExpression:
    Let is_transcendental be function_name is not equal to "abs"
    Return SymbolicExpression with:
    expression_type as Function
    value as function_name
    children as list containing argument
    variables as argument.variables
    constants as argument.constants
    properties as ExpressionProperties with:
    is_constant as argument.properties.is_constant
    is_polynomial as false
    is_rational as false
    is_transcendental as is_transcendental
    degree as 0
    complexity as argument.properties.complexity 5
    variables_count as argument.properties.variables_count
    metadata as dictionary containing
    metadata as dictionary containing

Note: Symbolic differentiation
Process called "differentiate" that takes expr as SymbolicExpression and variable as String returns DerivativeResult:
    Let derivative_expr be compute_derivative with expression as expr and var as variable
    Let simplified_expr be simplify with expression as derivative_expr Return DerivativeResult with:
    original_expression as expr
    derivative as derivative_expr
    variable as variable
    order as 1
    chain_rule_steps as list containing
    simplified as simplified_expr
    metadata as dictionary containing

Process called "compute_derivative" that takes expression as SymbolicExpression and var as String returns SymbolicExpression:
    Match expression.expression_type:
    When Symbol:
    If String.from with value as expression.value is equal to var:
    Return create_number with value as 1.0
    Otherwise:
    Return create_number with value as 0.0 When Number:
    Return create_number with value as 0.0 When Add:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let left_derivative be compute_derivative with expression as expression.children at index 0 and var as var
    Let right_derivative be compute_derivative with expression as expression.children at index 1 and var as var
    Return create_add with left as left_derivative and right as right_derivative
    Return create_number with value as 0.0 When Multiply:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let u be expression.children at index 0
    Let v be expression.children at index 1
    Let du_dx be compute_derivative with expression as u and var as var
    Let dv_dx be compute_derivative with expression as v and var as var Note: Product rule: d/dx(uv) = u(dv/dx) + v(du/dx)
    Let first_term be create_multiply with left as u and right as dv_dx
    Let second_term be create_multiply with left as v and right as du_dx
    Return create_add with left as first_term and right as second_term
    Return create_number with value as 0.0 When Power:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let base be expression.children at index 0
    Let exponent be expression.children at index 1 Note: Power rule: d/dx(x^n) = n*x^(n-1) for constant n
    If exponent.expression_type is Number and not contains_variable with expr as base and variable as var:
    Let n be Float.from with value as exponent.value
    Let n_minus_1 be create_number with value as (n - 1.0)
    Let new_base_power be create_power with base as base and exponent as n_minus_1
    Let coefficient be create_number with value as n
    Return create_multiply with left as coefficient and right as new_base_power Note: General case would require chain rule and logarithmic differentiation
    Return create_number with value as 0.0
    Return create_number with value as 0.0 When Function:
    If Collections.List.length with lst as expression.children is greater than or equal to 1:
    Let func_name be String.from with value as expression.value
    Let argument be expression.children at index 0
    Let arg_derivative be compute_derivative with expression as argument and var as var Match func_name:
    When "sin":
    Let cos_arg be create_function with function_name as "cos" and argument as argument
    Return create_multiply with left as cos_arg and right as arg_derivative
    When "cos":
    Let sin_arg be create_function with function_name as "sin" and argument as argument
    Let negative_sin be create_multiply with left as create_number with value as -1.0 and right as sin_arg
    Return create_multiply with left as negative_sin and right as arg_derivative
    When "exp":
    Let exp_arg be create_function with function_name as "exp" and argument as argument
    Return create_multiply with left as exp_arg and right as arg_derivative
    When "ln" or "log":
    Let reciprocal be create_power with base as argument and exponent as create_number with value as -1.0
    Return create_multiply with left as reciprocal and right as arg_derivative
    Otherwise:
    Return create_number with value as 0.0
    Return create_number with value as 0.0 Otherwise:
    Return create_number with value as 0.0

Note: Symbolic integration
Process called "integrate" that takes expr as SymbolicExpression and variable as String returns IntegrationResult:
    Let antiderivative_expr be compute_antiderivative with expression as expr and var as variable
    Let simplified_antiderivative be simplify with expression as antiderivative_expr Return IntegrationResult with:
    original_expression as expr
    antiderivative as antiderivative_expr
    variable as variable
    integration_method as PowerRule
    substitutions as list containing
    definite_bounds as None
    definite_value as None
    metadata as dictionary containing

Process called "compute_antiderivative" that takes expression as SymbolicExpression and var as String returns SymbolicExpression:
    Match expression.expression_type:
    When Symbol:
    If String.from with value as expression.value is equal to var:
    Note: ∫x dx = x²/2
    Let x_squared be create_power with base as expression and exponent as create_number with value as 2.0
    Let half be create_number with value as 0.5
    Return create_multiply with left as half and right as x_squared
    Otherwise:
    Note: ∫c dx = cx (constant with respect to integration variable)
    Return create_multiply with left as expression and right as create_symbol with name as var When Number:
    Note: ∫c dx = cx
    Let constant be expression
    Let variable_symbol be create_symbol with name as var
    Return create_multiply with left as constant and right as variable_symbol When Add:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let left_integral be compute_antiderivative with expression as expression.children at index 0 and var as var
    Let right_integral be compute_antiderivative with expression as expression.children at index 1 and var as var
    Return create_add with left as left_integral and right as right_integral
    Return create_multiply with left as expression and right as create_symbol with name as var When Power:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let base be expression.children at index 0
    Let exponent be expression.children at index 1 Note: ∫x^n dx = x^(n+1)/(n+1) for n ≠ -1
    If base.expression_type is Symbol and String.from with value as base.value is equal to var and exponent.expression_type is Number:
    Let n be Float.from with value as exponent.value
    If Math.abs with x as (n 1.0) is greater than 1e-10:
    Let n_plus_1 be create_number with value as (n 1.0)
    Let new_exponent be n_plus_1
    Let new_power be create_power with base as base and exponent as new_exponent
    Let coefficient be create_power with base as n_plus_1 and exponent as create_number with value as -1.0
    Return create_multiply with left as coefficient and right as new_power
    Otherwise:
    Note: ∫x^(-1) dx = ln|x|
    Return create_function with function_name as "ln" and argument as base
    Return create_multiply with left as expression and right as create_symbol with name as var When Function:
    If Collections.List.length with lst as expression.children is greater than or equal to 1:
    Let func_name be String.from with value as expression.value
    Let argument be expression.children at index 0 Note: Simple cases where argument is just the variable
    If argument.expression_type is Symbol and String.from with value as argument.value is equal to var:
    Match func_name:
    When "sin":
    Let cos_arg be create_function with function_name as "cos" and argument as argument
    Return create_multiply with left as create_number with value as -1.0 and right as cos_arg
    When "cos":
    Return create_function with function_name as "sin" and argument as argument
    When "exp":
    Return create_function with function_name as "exp" and argument as argument
    Otherwise:
    Return create_multiply with left as expression and right as create_symbol with name as var
    Otherwise:
    Return create_multiply with left as expression and right as create_symbol with name as var
    Return create_multiply with left as expression and right as create_symbol with name as var Otherwise:
    Return create_multiply with left as expression and right as create_symbol with name as var

Note: Expression simplification
Process called "simplify" that takes expression as SymbolicExpression returns SymbolicExpression:
    Match expression.expression_type:
    When Add:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let simplified_left be simplify with expression as expression.children at index 0
    Let simplified_right be simplify with expression as expression.children at index 1
    Return simplify_addition with left as simplified_left and right as simplified_right
    Return expression When Multiply:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let simplified_left be simplify with expression as expression.children at index 0
    Let simplified_right be simplify with expression as expression.children at index 1
    Return simplify_multiplication with left as simplified_left and right as simplified_right
    Return expression When Power:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let simplified_base be simplify with expression as expression.children at index 0
    Let simplified_exponent be simplify with expression as expression.children at index 1
    Return simplify_power with base as simplified_base and exponent as simplified_exponent
    Return expression Otherwise:
    Return expression

Process called "simplify_addition" that takes left as SymbolicExpression and right as SymbolicExpression returns SymbolicExpression:
    Note: 0 + expr = expr
    If left.expression_type is Number and Float.from with value as left.value is equal to 0.0:
    Return right If right.expression_type is Number and Float.from with value as right.value is equal to 0.0:
    Return left Note: number + number = sum
    If left.expression_type is Number and right.expression_type is Number:
    Let sum be Float.from with value as left.value Float.from with value as right.value
    Return create_number with value as sum Note: x + x = 2x (like terms)
    If expressions_equal with expr1 as left and expr2 as right:
    Let two be create_number with value as 2.0
    Return create_multiply with left as two and right as left Return create_add with left as left and right as right

Process called "simplify_multiplication" that takes left as SymbolicExpression and right as SymbolicExpression returns SymbolicExpression:
    Note: 0 multiplied by expr = 0
    If (left.expression_type is Number and Float.from with value as left.value is equal to 0.0) or (right.expression_type is Number and Float.from with value as right.value is equal to 0.0):
    Return create_number with value as 0.0 Note: 1 multiplied by expr = expr
    If left.expression_type is Number and Float.from with value as left.value is equal to 1.0:
    Return right If right.expression_type is Number and Float.from with value as right.value is equal to 1.0:
    Return left Note: number multiplied by number = product
    If left.expression_type is Number and right.expression_type is Number:
    Let product be Float.from with value as left.value multiplied by Float.from with value as right.value
    Return create_number with value as product Note: x multiplied by x = x^2
    If expressions_equal with expr1 as left and expr2 as right:
    Let two be create_number with value as 2.0
    Return create_power with base as left and exponent as two Return create_multiply with left as left and right as right

Process called "simplify_power" that takes base as SymbolicExpression and exponent as SymbolicExpression returns SymbolicExpression:
    Note: expr^0 = 1
    If exponent.expression_type is Number and Float.from with value as exponent.value is equal to 0.0:
    Return create_number with value as 1.0 Note: expr^1 = expr
    If exponent.expression_type is Number and Float.from with value as exponent.value is equal to 1.0:
    Return base Note: 0^expr = 0 (for non-zero exponent)
    If base.expression_type is Number and Float.from with value as base.value is equal to 0.0 and not (exponent.expression_type is Number and Float.from with value as exponent.value is equal to 0.0):
    Return create_number with value as 0.0 Note: 1^expr = 1
    If base.expression_type is Number and Float.from with value as base.value is equal to 1.0:
    Return create_number with value as 1.0 Note: number^number = result
    If base.expression_type is Number and exponent.expression_type is Number:
    Let base_val be Float.from with value as base.value
    Let exp_val be Float.from with value as exponent.value
    Let result be Math.pow with base as base_val and exponent as exp_val
    Return create_number with value as result Return create_power with base as base and exponent as exponent

Note: Expression evaluation
Process called "evaluate" that takes expression as SymbolicExpression and variable_values as Dictionary[String, Float] returns Float:
    Match expression.expression_type:
    When Symbol:
    Let var_name be String.from with value as expression.value
    If Collections.Dict.contains_key with dict as variable_values and key as var_name:
    Return variable_values[var_name]
    Return 0.0 When Number:
    Return Float.from with value as expression.value When Add:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let left_val be evaluate with expression as expression.children at index 0 and variable_values as variable_values
    Let right_val be evaluate with expression as expression.children at index 1 and variable_values as variable_values
    Return left_val right_val
    Return 0.0 When Multiply:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let left_val be evaluate with expression as expression.children at index 0 and variable_values as variable_values
    Let right_val be evaluate with expression as expression.children at index 1 and variable_values as variable_values
    Return left_val multiplied by right_val
    Return 0.0 When Power:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let base_val be evaluate with expression as expression.children at index 0 and variable_values as variable_values
    Let exp_val be evaluate with expression as expression.children at index 1 and variable_values as variable_values
    Return Math.pow with base as base_val and exponent as exp_val
    Return 0.0 When Function:
    If Collections.List.length with lst as expression.children is greater than or equal to 1:
    Let func_name be String.from with value as expression.value
    Let arg_val be evaluate with expression as expression.children at index 0 and variable_values as variable_values Match func_name:
    When "sin":
    Return Math.sin with x as arg_val
    When "cos":
    Return Math.cos with x as arg_val
    When "exp":
    Return Math.exp with x as arg_val
    When "ln" or "log":
    Return Math.log with x as arg_val
    When "abs":
    Return Math.abs with x as arg_val
    When "sqrt":
    Return Math.sqrt with x as arg_val
    Otherwise:
    Return arg_val
    Return 0.0 Otherwise:
    Return 0.0

Note: Equation solving
Process called "solve_equation" that takes equation as SymbolicEquation and variable as String returns List[SymbolicExpression]:
    Note: Move everything to left side (left - right = 0)
    Let zero_form be create_add with left as equation.left_side and right as create_multiply with left as create_number with value as -1.0 and right as equation.right_side
    Let simplified_form be simplify with expression as zero_form Return solve_polynomial_equation with expression as simplified_form and variable as variable

Process called "solve_polynomial_equation" that takes expression as SymbolicExpression and variable as String returns List[SymbolicExpression]:
    Let degree be get_polynomial_degree with expression as expression and variable as variable Match degree:
    When 0:
    Note: Constant equation
    Let constant_value be evaluate with expression as expression and variable_values as dictionary containing variable and 0.0
    If Math.abs with x as constant_value is less than 1e-10:
    Return list containing create_symbol with name as "all_real_numbers"
    Otherwise:
    Return list containing When 1:
    Return solve_linear_equation with expression as expression and variable as variable When 2:
    Return solve_quadratic_equation with expression as expression and variable as variable Otherwise:
    Note: Higher degree polynomials - return approximate solutions
    Return find_numerical_roots with expression as expression and variable as variable

Process called "solve_linear_equation" that takes expression as SymbolicExpression and variable as String returns List[SymbolicExpression]:
    Note: ax + b = 0, solution: x = -b/a
    Let coeffs be extract_polynomial_coefficients with expression as expression and variable as variable and max_degree as 1 If Collections.List.length with lst as coeffs is greater than or equal to 2:
    Let a be coeffs at index 1
    Let b be coeffs at index 0 If Math.abs with x as a is greater than 1e-10:
    Let solution_value be -b divided by a
    Return list containing create_number with value as solution_value Return list containing

Process called "solve_quadratic_equation" that takes expression as SymbolicExpression and variable as String returns List[SymbolicExpression]:
    Note: ax² + bx + c = 0
    Let coeffs be extract_polynomial_coefficients with expression as expression and variable as variable and max_degree as 2 If Collections.List.length with lst as coeffs is greater than or equal to 3:
    Let a be coeffs at index 2
    Let b be coeffs at index 1
    Let c be coeffs at index 0 If Math.abs with x as a is greater than 1e-10:
    Let discriminant be b multiplied by b - 4.0 multiplied by a multiplied by c If discriminant is greater than 0.0:
    Let sqrt_discriminant be Math.sqrt with x as discriminant
    Let x1 be (-b sqrt_discriminant) divided by (2.0 multiplied by a)
    Let x2 be (-b - sqrt_discriminant) divided by (2.0 multiplied by a)
    Return list containing create_number with value as x1, create_number with value as x2 If Math.abs with x as discriminant is less than 1e-10:
    Let x be -b divided by (2.0 multiplied by a)
    Return list containing create_number with value as x Return list containing

Note: Series expansion
Process called "taylor_series" that takes expression as SymbolicExpression and variable as String and point as Float and order as Integer returns List[SymbolicExpression]:
    Let terms be list containing
    Let current_derivative be expression
    Let factorial be 1.0 For n from 0 to order:
    Note: Evaluate derivative at the point
    Let point_value be evaluate with expression as current_derivative and variable_values as dictionary containing variable and point Note: Create the term: f^(n)(a) multiplied by (x-a)^n divided by n!
    If n is equal to 0:
    Add create_number with value as point_value to terms
    Otherwise:
    Let x_minus_a be create_add with left as create_symbol with name as variable and right as create_number with value as -point
    Let power_term be create_power with base as x_minus_a and exponent as create_number with value as Float.from with value as n
    Let coefficient be create_number with value as (point_value divided by factorial)
    Add create_multiply with left as coefficient and right as power_term to terms Note: Compute next derivative
    If n is less than order:
    Set current_derivative to compute_derivative with expression as current_derivative and var as variable
    Set factorial to factorial multiplied by Float.from with value as (n 1) Return terms

Note: Expression manipulation utilities
Process called "expand" that takes expression as SymbolicExpression returns SymbolicExpression:
    Match expression.expression_type:
    When Multiply:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let left be expression.children at index 0
    Let right be expression.children at index 1 Note: Expand (a+b)*c to a*c + b*c
    If left.expression_type is Add and Collections.List.length with lst as left.children is greater than or equal to 2:
    Let a be left.children at index 0
    Let b be left.children at index 1
    Let ac be create_multiply with left as a and right as right
    Let bc be create_multiply with left as b and right as right
    Return create_add with left as expand with expression as ac and right as expand with expression as bc Note: Expand c*(a+b) to c*a + c*b
    If right.expression_type is Add and Collections.List.length with lst as right.children is greater than or equal to 2:
    Let a be right.children at index 0
    Let b be right.children at index 1
    Let ca be create_multiply with left as left and right as a
    Let cb be create_multiply with left as left and right as b
    Return create_add with left as expand with expression as ca and right as expand with expression as cb Return expression When Power:
    Note: Expand (a+b)^n for small integer n
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let base be expression.children at index 0
    Let exponent be expression.children at index 1 If base.expression_type is Add and exponent.expression_type is Number:
    Let n be Integer.from with value as Float.from with value as exponent.value
    If n is greater than 0 and n is less than or equal to 4:
    Return expand_binomial with base as base and exponent as n Return expression Otherwise:
    Return expression

Process called "factor" that takes expression as SymbolicExpression returns SymbolicExpression:
    Note: Simple factoring for quadratic expressions
    If expression.expression_type is Add:
    Return attempt_quadratic_factoring with expression as expression Return expression

Process called "substitute" that takes expression as SymbolicExpression and variable as String and replacement as SymbolicExpression returns SymbolicExpression:
    Match expression.expression_type:
    When Symbol:
    If String.from with value as expression.value is equal to variable:
    Return replacement
    Return expression When Number:
    Return expression When Add or Multiply or Power:
    Let new_children be list containing
    For each child in expression.children:
    Add substitute with expression as child and variable as variable and replacement as replacement to new_children Match expression.expression_type:
    When Add:
    If Collections.List.length with lst as new_children is greater than or equal to 2:
    Return create_add with left as new_children at index 0 and right as new_children at index 1
    When Multiply:
    If Collections.List.length with lst as new_children is greater than or equal to 2:
    Return create_multiply with left as new_children at index 0 and right as new_children at index 1
    When Power:
    If Collections.List.length with lst as new_children is greater than or equal to 2:
    Return create_power with base as new_children at index 0 and exponent as new_children at index 1 Return expression When Function:
    If Collections.List.length with lst as expression.children is greater than or equal to 1:
    Let new_argument be substitute with expression as expression.children at index 0 and variable as variable and replacement as replacement
    Return create_function with function_name as String.from with value as expression.value and argument as new_argument
    Return expression Otherwise:
    Return expression

Note: LaTeX output
Process called "to_latex" that takes expression as SymbolicExpression returns String:
    Match expression.expression_type:
    When Symbol:
    Return String.from with value as expression.value When Number:
    Return String.from with value as expression.value When Add:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let left_latex be to_latex with expression as expression.children at index 0
    Let right_latex be to_latex with expression as expression.children at index 1
    Return left_latex followed by " + " followed by right_latex
    Return "0"
    When Multiply:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let left_latex be to_latex with expression as expression.children at index 0
    Let right_latex be to_latex with expression as expression.children at index 1
    Return left_latex followed by " \\cdot " followed by right_latex
    Return "1"
    When Power:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let base_latex be to_latex with expression as expression.children at index 0
    Let exp_latex be to_latex with expression as expression.children at index 1
    Return base_latex followed by "^{" followed by exp_latex followed by "}"
    Return "1"
    When Function:
    If Collections.List.length with lst as expression.children is greater than or equal to 1:
    Let func_name be String.from with value as expression.value
    Let arg_latex be to_latex with expression as expression.children at index 0
    Return "\\" followed by func_name followed by "{" followed by arg_latex followed by "}"
    Return "f(x)" Otherwise:
    Return "expr"

Note: Utility functions
Process called "combine_variable_lists" that takes list1 as List[String] and list2 as List[String] returns List[String]:
    Let combined be Collections.List.copy with lst as list1
    For each var in list2:
    If not Collections.List.contains with lst as combined and item as var:
    Add var to combined
    Return combined

Process called "combine_constants" that takes dict1 as Dictionary[String, Float] and dict2 as Dictionary[String, Float] returns Dictionary[String, Float]:
    Let combined be Collections.Dict.copy with dict as dict1
    For each key in Collections.Dict.keys with dict as dict2:
    Set combined[key] to dict2[key]
    Return combined

Process called "contains_variable" that takes expr as SymbolicExpression and variable as String returns Boolean:
    Return Collections.List.contains with lst as expr.variables and item as variable

Process called "is_positive_integer" that takes expr as SymbolicExpression returns Boolean:
    If expr.expression_type is Number:
    Let value be Float.from with value as expr.value
    Return value is greater than 0.0 and value is equal to Float.from with value as Integer.from with value as value
    Return false

Process called "expressions_equal" that takes expr1 as SymbolicExpression and expr2 as SymbolicExpression returns Boolean:
    If expr1.expression_type is not equal to expr2.expression_type:
    Return false Match expr1.expression_type:
    When Symbol:
    Return String.from with value as expr1.value is equal to String.from with value as expr2.value
    When Number:
    Return Math.abs with x as (Float.from with value as expr1.value - Float.from with value as expr2.value) is less than 1e-10
    Otherwise:
    Return false

Process called "get_polynomial_degree" that takes expression as SymbolicExpression and variable as String returns Integer:
    Note: Simplified degree calculation
    If not contains_variable with expr as expression and variable as variable:
    Return 0 Match expression.expression_type:
    When Symbol:
    Return if String.from with value as expression.value is equal to variable then 1 else 0
    When Power:
    If Collections.List.length with lst as expression.children is greater than or equal to 2:
    Let base be expression.children at index 0
    Let exponent be expression.children at index 1
    If base.expression_type is Symbol and String.from with value as base.value is equal to variable and exponent.expression_type is Number:
    Return Integer.from with value as Float.from with value as exponent.value
    Return 1
    When Add or Multiply:
    Let max_degree be 0
    For each child in expression.children:
    Let child_degree be get_polynomial_degree with expression as child and variable as variable
    Set max_degree to Math.max with a as max_degree and b as child_degree
    Return max_degree
    Otherwise:
    Return 1

Process called "extract_polynomial_coefficients" that takes expression as SymbolicExpression and variable as String and max_degree as Integer returns List[Float]:
    Let coefficients be list containing
    For i from 0 to max_degree:
    Add 0.0 to coefficients Note: Simplified coefficient extraction
    If expression.expression_type is Number:
    Set coefficients at index 0 to Float.from with value as expression.value If expression.expression_type is Symbol and String.from with value as expression.value is equal to variable:
    Set coefficients at index 1 to 1.0 Return coefficients

Process called "find_numerical_roots" that takes expression as SymbolicExpression and variable as String returns List[SymbolicExpression]:
    Note: Simplified numerical root finding
    Return list containing create_number with value as 0.0

Process called "expand_binomial" that takes base as SymbolicExpression and exponent as Integer returns SymbolicExpression:
    Note: Simplified binomial expansion - just return the original for now
    Return create_power with base as base and exponent as create_number with value as Float.from with value as exponent

Process called "attempt_quadratic_factoring" that takes expression as SymbolicExpression returns SymbolicExpression:
    Note: Simplified factoring attempt
    Return expression

Type called "Tuple":
    first as SymbolicExpression
    second as SymbolicExpression

