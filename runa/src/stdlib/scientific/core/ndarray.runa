    Return copy_array with arr as arr

Note: Advanced Indexing Operations

Process called "fancy_index" that takes arr as NDArray and indices as List[NDArray] returns NDArray:
    Note: Advanced indexing using integer arrays (fancy indexing)
    Let result_shape be calculate_fancy_index_shape with indices as indices
    Let result_size be calculate_size with shape as result_shape
    Let result_data be list containing
    If Collections.List.length with lst as indices is equal to 0:
        Return copy_array with arr as arr
    Note: Handle single dimension fancy indexing
    If Collections.List.length with lst as indices is equal to 1:
        Let index_arr be indices at index 0
        For each idx in index_arr.data:
            Let normalized_idx be normalize_index with index as idx and size as arr.shape at index 0
            Let flat_idx be normalized_idx multiplied by arr.strides at index 0
            Add arr.data at index flat_idx to result_data
    Otherwise:
        Note: Multi-dimensional fancy indexing
        Let num_indices be Math.min with a as Collections.List.length with lst as indices and b as arr.ndim
        For i from 0 to result_size - 1:
            Let multi_index be calculate_multi_index_from_flat with flat_index as i and shape as result_shape
            Let target_indices be list containing
            For j from 0 to num_indices - 1:
                Let idx_arr be indices at index j
                Let idx_flat be calculate_flat_index with arr as idx_arr and indices as multi_index
                Let actual_idx be idx_arr.data at index idx_flat
                Add actual_idx to target_indices
            Let flat_target be calculate_flat_index with arr as arr and indices as target_indices
            Add arr.data at index flat_target to result_data
    Return NDArray with:
        data as result_data
        shape as result_shape
        strides as calculate_strides with shape as result_shape
        dtype as arr.dtype
        ndim as Collections.List.length with lst as result_shape
        size as result_size
        itemsize as arr.itemsize
        flags as ArrayFlags with:
            writeable as true
            contiguous as true
            aligned as arr.flags.aligned
            owndata as true
            memory_layout as RowMajor
        metadata as dictionary containing

Process called "boolean_index" that takes arr as NDArray and mask as NDArray returns NDArray:
    Note: Boolean indexing using a boolean mask array
    If mask.dtype is not equal to Boolean:
        Return copy_array with arr as arr
    If mask.size is not equal to arr.size:
        Note: Broadcast mask if needed
        Return copy_array with arr as arr
    Let result_data be list containing
    Let true_count be 0
    Note: Count true values in mask
    For each mask_value in mask.data:
        If mask_value is equal to true:
            Set true_count to true_count plus 1
    Note: Extract values where mask is true
    For i from 0 to mask.size - 1:
        If mask.data at index i is equal to true:
            Add arr.data at index i to result_data
    Let result_shape be list containing true_count
    Return NDArray with:
        data as result_data
        shape as result_shape
        strides as calculate_strides with shape as result_shape
        dtype as arr.dtype
        ndim as 1
        size as true_count
        itemsize as arr.itemsize
        flags as ArrayFlags with:
            writeable as true
            contiguous as true
            aligned as arr.flags.aligned
            owndata as true
            memory_layout as RowMajor
        metadata as dictionary containing

Process called "mixed_index" that takes arr as NDArray and index_spec as List[Any] returns NDArray:
    Note: Mixed indexing with integers, slices, arrays, and boolean masks
    Let integer_indices be list containing
    Let array_indices be list containing
    Let boolean_masks be list containing
    Let slice_specs be list containing
    Note: Separate different index types
    For each spec in index_spec:
        If spec is Integer:
            Add spec to integer_indices
        Otherwise If spec is NDArray:
            If spec.dtype is equal to Boolean:
                Add spec to boolean_masks
            Otherwise:
                Add spec to array_indices
        Otherwise If spec is ArraySlice:
            Add spec to slice_specs
    Note: Apply indexing in order: slicing, then boolean, then fancy
    Let current_arr be arr
    If Collections.List.length with lst as slice_specs is greater than 0:
        Set current_arr to slice_array with arr as current_arr and slices as slice_specs
    If Collections.List.length with lst as boolean_masks is greater than 0:
        Let combined_mask be boolean_masks at index 0
        For i from 1 to Collections.List.length with lst as boolean_masks - 1:
            Set combined_mask to logical_and with a as combined_mask and b as boolean_masks at index i
        Set current_arr to boolean_index with arr as current_arr and mask as combined_mask
    If Collections.List.length with lst as array_indices is greater than 0:
        Set current_arr to fancy_index with arr as current_arr and indices as array_indices
    Return current_arr

Note: Enhanced 3D+ Transpose Operations

Process called "transpose_3d_plus" that takes arr as NDArray and axes as Optional[List[Integer]] returns NDArray:
    Note: Enhanced transpose with validation for 3D+ arrays
    If arr.ndim is less than 3:
        Return transpose with arr as arr and axes as axes
    Let perm_axes be axes or generate_reverse_axes with ndim as arr.ndim
    Note: Validate axes for 3D+ arrays
    If not validate_transpose_axes with axes as perm_axes and ndim as arr.ndim:
        Return copy_array with arr as arr
    Note: Optimize transpose for common 3D patterns
    If arr.ndim is equal to 3 and perm_axes is equal to [2, 1, 0]:
        Return optimized_3d_transpose with arr as arr
    Note: General N-dimensional transpose
    Let new_shape be list containing
    Let new_strides be list containing
    For each axis in perm_axes:
        Add arr.shape at index axis to new_shape
        Add arr.strides at index axis to new_strides
    Note: For 3D+ arrays, ensure proper memory layout
    Let memory_layout be if check_contiguous with shape as new_shape and strides as new_strides then RowMajor else arr.flags.memory_layout
    Return NDArray with:
        data as create_transposed_data with arr as arr and axes as perm_axes
        shape as new_shape
        strides as new_strides
        dtype as arr.dtype
        ndim as arr.ndim
        size as arr.size
        itemsize as arr.itemsize
        flags as ArrayFlags with:
            writeable as arr.flags.writeable
            contiguous as check_contiguous with shape as new_shape and strides as new_strides
            aligned as arr.flags.aligned
            owndata as true
            memory_layout as memory_layout
        metadata as arr.metadata

Note: Helper Functions for Advanced Indexing

Process called "calculate_fancy_index_shape" that takes indices as List[NDArray] returns List[Integer]:
    Note: Calculate result shape for fancy indexing
    If Collections.List.length with lst as indices is equal to 0:
        Return list containing 0
    Let first_index as NDArray be indices at index 0
    If Collections.List.length with lst as indices is equal to 1:
        Return first_index.shape
    Note: For multi-dimensional fancy indexing, result shape is broadcast shape
    Let result_shape be Collections.List.copy with lst as first_index.shape
    For i from 1 to Collections.List.length with lst as indices - 1:
        Let current_index as NDArray be indices at index i
        Set result_shape to broadcast_shapes with shape1 as result_shape and shape2 as current_index.shape
    Return result_shape

Process called "calculate_multi_index_from_flat" that takes flat_index as Integer and shape as List[Integer] returns List[Integer]:
    Note: Convert flat index to multi-dimensional indices
    Let result be list containing
    Let remaining_index be flat_index
    For i from Collections.List.length with lst as shape - 1 down to 0:
        Let dim_size be shape at index i
        Let index_in_dim be remaining_index modulo dim_size
        Add index_in_dim to beginning of result
        Set remaining_index to remaining_index divided by dim_size
    Return result

Process called "validate_transpose_axes" that takes axes as List[Integer] and ndim as Integer returns Boolean:
    Note: Validate transpose axes for N-dimensional arrays
    If Collections.List.length with lst as axes is not equal to ndim:
        Return false
    Let seen be list containing
    For each axis in axes:
        If axis is less than 0 or axis is greater than or equal to ndim:
            Return false
        If axis in seen:
            Return false
        Add axis to seen
    Return true

Process called "optimized_3d_transpose" that takes arr as NDArray returns NDArray:
    Note: Optimized transpose for 3D arrays with [2,1,0] permutation
    Let new_shape be [arr.shape at index 2, arr.shape at index 1, arr.shape at index 0]
    Let new_strides be [arr.strides at index 2, arr.strides at index 1, arr.strides at index 0]
    Let result_data be list containing
    Note: Optimized data reordering for common 3D transpose
    For z from 0 to arr.shape at index 2 - 1:
        For y from 0 to arr.shape at index 1 - 1:
            For x from 0 to arr.shape at index 0 - 1:
                Let old_index be x multiplied by arr.strides at index 0 plus y multiplied by arr.strides at index 1 plus z multiplied by arr.strides at index 2
                Add arr.data at index old_index to result_data
    Return NDArray with:
        data as result_data
        shape as new_shape
        strides as calculate_strides with shape as new_shape
        dtype as arr.dtype
        ndim as 3
        size as arr.size
        itemsize as arr.itemsize
        flags as ArrayFlags with:
            writeable as arr.flags.writeable
            contiguous as true
            aligned as arr.flags.aligned
            owndata as true
            memory_layout as RowMajor
        metadata as arr.metadata

Process called "create_transposed_data" that takes arr as NDArray and axes as List[Integer] returns List[Any]:
    Note: Create properly transposed data for N-dimensional arrays
    Let result_data be list containing
    Let total_elements be arr.size
    For flat_index from 0 to total_elements - 1:
        Let multi_index be calculate_multi_index_from_flat with flat_index as flat_index and shape as arr.shape
        Let new_multi_index be list containing
        Note: Reorder indices according to axes permutation
        For each axis in axes:
            Add multi_index at index axis to new_multi_index
        Let new_flat_index be calculate_flat_index_from_multi with multi_index as new_multi_index and shape as arr.shape and axes as axes
        Add arr.data at index flat_index to result_data
    Return result_data

Process called "calculate_flat_index_from_multi" that takes multi_index as List[Integer] and shape as List[Integer] and axes as List[Integer] returns Integer:
    Note: Calculate flat index from multi-dimensional index with axis permutation
    Let flat_index be 0
    Let stride be 1
    For i from Collections.List.length with lst as shape - 1 down to 0:
        Let axis_index be axes at index i
        Let coord be multi_index at index axis_index
        Set flat_index to flat_index plus coord multiplied by stride
        Set stride to stride multiplied by shape at index axis_index
    Return flat_index

Process called "broadcast_shapes" that takes shape1 as List[Integer] and shape2 as List[Integer] returns List[Integer]:
    Note: Compute broadcast shape for two arrays
    Let max_ndim be Math.max with a as Collections.List.length with lst as shape1 and b as Collections.List.length with lst as shape2
    Let result_shape be list containing
    For i from 0 to max_ndim - 1:
        Let dim1 be if i is less than Collections.List.length with lst as shape1 then shape1 at index (Collections.List.length with lst as shape1 - 1 - i) else 1
        Let dim2 be if i is less than Collections.List.length with lst as shape2 then shape2 at index (Collections.List.length with lst as shape2 - 1 - i) else 1
        Let broadcast_dim be if dim1 is equal to dim2 then dim1 else if dim1 is equal to 1 then dim2 else if dim2 is equal to 1 then dim1 else Math.max with a as dim1 and b as dim2
        Add broadcast_dim to beginning of result_shape
    Return result_shape

Process called "logical_and" that takes a as NDArray and b as NDArray returns NDArray:
    Note: Element-wise logical AND for boolean arrays
    If a.dtype is not equal to Boolean or b.dtype is not equal to Boolean:
        Return copy_array with arr as a
    Let result_shape be broadcast_shapes with shape1 as a.shape and shape2 as b.shape
    Let result_size be calculate_size with shape as result_shape
    Let result_data be list containing
    For i from 0 to result_size - 1:
        Let a_val be get_broadcast_value with arr as a and flat_index as i and target_shape as result_shape
        Let b_val be get_broadcast_value with arr as b and flat_index as i and target_shape as result_shape
        Let and_result be a_val and b_val
        Add and_result to result_data
    Return NDArray with:
        data as result_data
        shape as result_shape
        strides as calculate_strides with shape as result_shape
        dtype as Boolean
        ndim as Collections.List.length with lst as result_shape
        size as result_size
        itemsize as 1
        flags as ArrayFlags with:
            writeable as true
            contiguous as true
            aligned as true
            owndata as true
            memory_layout as RowMajor
        metadata as dictionary containing

Process called "get_broadcast_value" that takes arr as NDArray and flat_index as Integer and target_shape as List[Integer] returns Any:
    Note: Get value from array with broadcasting to target shape
    Let target_multi_index be calculate_multi_index_from_flat with flat_index as flat_index and shape as target_shape
    Let arr_multi_index be list containing
    Note: Map target indices to array indices with broadcasting
    Let offset be Collections.List.length with lst as target_shape - arr.ndim
    For i from 0 to arr.ndim - 1:
        Let target_idx be target_multi_index at index (offset plus i)
        Let arr_dim be arr.shape at index i
        Let broadcasted_idx be if arr_dim is equal to 1 then 0 else target_idx modulo arr_dim
        Add broadcasted_idx to arr_multi_index
    Let arr_flat_index be calculate_flat_index with arr as arr and indices as arr_multi_index
    Return arr.data at index arr_flat_index

Process called "vector_dot_product" that takes a as NDArray and b as NDArray returns NDArray:
    Let result_value be get_zero_value with dtype as a.dtype
    For i from 0 to a.size - 1:
        Let val_a be a.data at index i
        Let val_b be b.data at index i
        Set result_value to add_values with a as result_value and b as multiply_values with a as val_a and b as val_b and dtype as a.dtype and dtype as a.dtype
    Return create_array with data as list containing result_value and dtype as a.dtype and shape as list containing

Process called "matrix_multiply" that takes a as NDArray and b as NDArray returns NDArray:
    Note: Matrix multiplication for 2D arrays
    If a.ndim is not equal to 2 or b.ndim is not equal to 2:
        Return copy_array with arr as a
    Let m be a.shape at index 0
    Let k be a.shape at index 1
    Let n be b.shape at index 1
    If k is not equal to b.shape at index 0:
        Return copy_array with arr as a
    Let result_data be list containing
    For i from 0 to m - 1:
        For j from 0 to n - 1:
            Let sum_val be get_zero_value with dtype as a.dtype
            For l from 0 to k - 1:
                Let a_val be a.data at index (i multiplied by k plus l)
                Let b_val be b.data at index (l multiplied by n plus j)
                Let product be multiply_values with a as a_val and b as b_val and dtype as a.dtype
                Set sum_val to add_values with a as sum_val and b as product and dtype as a.dtype
            Add sum_val to result_data
    Return create_array with data as result_data and dtype as a.dtype and shape as list containing m, n

Process called "matrix_vector_multiply" that takes matrix as NDArray and vector as NDArray returns NDArray:
    Note: Matrix-vector multiplication
    If matrix.ndim is not equal to 2 or vector.ndim is not equal to 1:
        Return copy_array with arr as vector
    Let m be matrix.shape at index 0
    Let n be matrix.shape at index 1
    If n is not equal to vector.size:
        Return copy_array with arr as vector
    Let result_data be list containing
    For i from 0 to m - 1:
        Let sum_val be get_zero_value with dtype as matrix.dtype
        For j from 0 to n - 1:
            Let matrix_val be matrix.data at index (i multiplied by n plus j)
            Let vector_val be vector.data at index j
            Let product be multiply_values with a as matrix_val and b as vector_val and dtype as matrix.dtype
            Set sum_val to add_values with a as sum_val and b as product and dtype as matrix.dtype
        Add sum_val to result_data
    Return create_array with data as result_data and dtype as matrix.dtype and shape as list containing m

Process called "divide_values" that takes a as Any and b as Any and dtype as DataType returns Any:
    Match dtype:
        When Boolean:
            Return if Boolean.from with value as b then Boolean.from with value as a else false
        When Int8 or Int16 or Int32 or Int64 or UInt8 or UInt16 or UInt32 or UInt64:
            Let b_int be Integer.from with value as b
            Return if b_int is not equal to 0 then Integer.from with value as a divided by b_int else 0
        When Float32 or Float64:
            Let b_float be Float.from with value as b
            Return if b_float is not equal to 0.0 then Float.from with value as a divided by b_float else 0.0
        Otherwise:
            Return 0.0

Process called "max_values" that takes a as Any and b as Any and dtype as DataType returns Any:
    Match dtype:
        When Boolean:
            Return Boolean.from with value as a or Boolean.from with value as b
        When Int8 or Int16 or Int32 or Int64 or UInt8 or UInt16 or UInt32 or UInt64:
            Return Math.max with a as Integer.from with value as a and b as Integer.from with value as b
        When Float32 or Float64:
            Return Math.max with a as Float.from with value as a and b as Float.from with value as b
        Otherwise:
            Return Math.max with a as Float.from with value as a and b as Float.from with value as b

Process called "min_values" that takes a as Any and b as Any and dtype as DataType returns Any:
    Match dtype:
        When Boolean:
            Return Boolean.from with value as a and Boolean.from with value as b
        When Int8 or Int16 or Int32 or Int64 or UInt8 or UInt16 or UInt32 or UInt64:
            Return Math.min with a as Integer.from with value as a and b as Integer.from with value as b
        When Float32 or Float64:
            Return Math.min with a as Float.from with value as a and b as Float.from with value as b
        Otherwise:
            Return Math.min with a as Float.from with value as a and b as Float.from with value as b