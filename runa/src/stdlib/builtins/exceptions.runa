Note:
Runa Standard Library: Built-in Exception Types and Handling

Provides the complete exception hierarchy and error handling mechanisms as specified 
in the Runa language specification. All exception types follow the natural language 
syntax and are fully compatible with Try/Catch/Finally blocks.
:End Note

Type called "RunaException":
    message as String
    error_code as String
    stack_trace as List[String]
    cause as Optional[RunaException]
    timestamp as Integer

Type TypeError is RunaException with:
    expected_type as String
    actual_type as String
    variable_name as String

Type ValueError is RunaException with:
    invalid_value as Any
    valid_range as Optional[String]
    constraint_violated as String

Type IndexError is RunaException with:
    index as Integer
    collection_size as Integer
    collection_type as String

Type KeyError is RunaException with:
    missing_key as Any
    available_keys as List[Any]
    dictionary_name as String

Type AttributeError is RunaException with:
    object_type as String
    missing_attribute as String
    available_attributes as List[String]

Type RuntimeError is RunaException with:
    operation as String
    context as Dictionary[String, Any]
    recovery_suggestions as List[String]

Type MemoryError is RunaException with:
    requested_size as Integer
    available_memory as Integer
    memory_type as String

Type IOError is RunaException with:
    file_path as String
    operation as String
    system_error_code as Integer

Type NetworkError is RunaException with:
    endpoint as String
    operation as String
    status_code as Integer
    retry_count as Integer

Type TimeoutError is RunaException with:
    operation as String
    timeout_duration as Float
    elapsed_time as Float

Type ConcurrencyError is RunaException with:
    resource_name as String
    operation as String
    thread_id as String

Type ValidationError is RunaException with:
    field_name as String
    validation_rule as String
    provided_value as Any

Type SerializationError is RunaException with:
    object_type as String
    serialization_format as String
    serialization_stage as String

Type ParseError is RunaException with:
    input_text as String
    position as Integer
    expected_tokens as List[String]

Type ConfigurationError is RunaException with:
    configuration_key as String
    configuration_file as String
    suggested_value as String

Process called "create_exception" that takes exception_type as String and message as String returns RunaException:
    Let current_time be get_current_timestamp
    Let stack be get_current_stack_trace
    
    Return RunaException with:
        message as message
        error_code as exception_type
        stack_trace as stack
        cause as None
        timestamp as current_time

Process called "create_type_error" that takes expected as String and actual as String and variable as String returns TypeError:
    Let base_exception be create_exception with exception_type as "TypeError" and message as format_type_error_message with expected as expected and actual as actual and variable as variable
    
    Return TypeError with:
        message as base_exception["message"]
        error_code as base_exception["error_code"]
        stack_trace as base_exception["stack_trace"]
        cause as base_exception["cause"]
        timestamp as base_exception["timestamp"]
        expected_type as expected
        actual_type as actual
        variable_name as variable

Process called "create_value_error" that takes value as Any and constraint as String returns ValueError:
    Let message be format_value_error_message with value as value and constraint as constraint
    Let base_exception be create_exception with exception_type as "ValueError" and message as message
    
    Return ValueError with:
        message as base_exception["message"]
        error_code as base_exception["error_code"]
        stack_trace as base_exception["stack_trace"]
        cause as base_exception["cause"]
        timestamp as base_exception["timestamp"]
        invalid_value as value
        valid_range as None
        constraint_violated as constraint

Process called "create_index_error" that takes index as Integer and size as Integer and collection_type as String returns IndexError:
    Let message be format_index_error_message with index as index and size as size and collection_type as collection_type
    Let base_exception be create_exception with exception_type as "IndexError" and message as message
    
    Return IndexError with:
        message as base_exception["message"]
        error_code as base_exception["error_code"]
        stack_trace as base_exception["stack_trace"]
        cause as base_exception["cause"]
        timestamp as base_exception["timestamp"]
        index as index
        collection_size as size
        collection_type as collection_type

Process called "create_key_error" that takes key as Any and available_keys as List[Any] and dict_name as String returns KeyError:
    Let message be format_key_error_message with key as key and available_keys as available_keys and dict_name as dict_name
    Let base_exception be create_exception with exception_type as "KeyError" and message as message
    
    Return KeyError with:
        message as base_exception["message"]
        error_code as base_exception["error_code"]
        stack_trace as base_exception["stack_trace"]
        cause as base_exception["cause"]
        timestamp as base_exception["timestamp"]
        missing_key as key
        available_keys as available_keys
        dictionary_name as dict_name

Process called "create_runtime_error" that takes operation as String and context as Dictionary[String, Any] returns RuntimeError:
    Let message be format_runtime_error_message with operation as operation and context as context
    Let base_exception be create_exception with exception_type as "RuntimeError" and message as message
    
    Return RuntimeError with:
        message as base_exception["message"]
        error_code as base_exception["error_code"]
        stack_trace as base_exception["stack_trace"]
        cause as base_exception["cause"]
        timestamp as base_exception["timestamp"]
        operation as operation
        context as context
        recovery_suggestions as generate_recovery_suggestions with operation as operation

Process called "create_io_error" that takes file_path as String and operation as String and system_code as Integer returns IOError:
    Let message be format_io_error_message with file_path as file_path and operation as operation and system_code as system_code
    Let base_exception be create_exception with exception_type as "IOError" and message as message
    
    Return IOError with:
        message as base_exception["message"]
        error_code as base_exception["error_code"]
        stack_trace as base_exception["stack_trace"]
        cause as base_exception["cause"]
        timestamp as base_exception["timestamp"]
        file_path as file_path
        operation as operation
        system_error_code as system_code

Process called "chain_exception" that takes new_exception as RunaException and cause as RunaException returns RunaException:
    Set new_exception["cause"] to cause
    Return new_exception

Process called "get_exception_chain" that takes exception as RunaException returns List[RunaException]:
    Let chain be list containing exception
    Let current_cause be exception["cause"]
    
    While current_cause is not None:
        Add current_cause to chain
        Set current_cause to current_cause["cause"]
    
    Return chain

Process called "format_exception" that takes exception as RunaException returns String:
    Let formatted_message be exception["error_code"] with message ": " with message exception["message"]
    
    If exception["cause"] is not None:
        Let cause_formatted be format_exception with exception as exception["cause"]
        Set formatted_message to formatted_message with message "\nCaused by: " with message cause_formatted
    
    Return formatted_message

Process called "format_stack_trace" that takes exception as RunaException returns String:
    Let trace_lines be list containing "Stack trace:"
    
    For each frame in exception["stack_trace"]:
        Add "  at " with message frame to trace_lines
    
    Return join_strings with strings as trace_lines and separator as "\n"

Process called "is_recoverable_error" that takes exception as RunaException returns Boolean:
    Let recoverable_types be list containing "IOError", "NetworkError", "TimeoutError", "ValidationError"
    Return exception["error_code"] is in recoverable_types

Process called "get_error_severity" that takes exception as RunaException returns String:
    Let critical_types be list containing "MemoryError", "ConcurrencyError", "RuntimeError"
    Let warning_types be list containing "ValidationError", "ConfigurationError"
    
    If exception["error_code"] is in critical_types:
        Return "CRITICAL"
    Otherwise if exception["error_code"] is in warning_types:
        Return "WARNING"
    Otherwise:
        Return "ERROR"

Process called "suggest_error_resolution" that takes exception as RunaException returns List[String]:
    Match exception["error_code"]:
        When "TypeError":
            Return list containing "Check variable types match expected types", "Use explicit type annotations", "Verify function parameter types"
        When "ValueError":
            Return list containing "Validate input values before use", "Check value constraints and ranges", "Use proper value conversion functions"
        When "IndexError":
            Return list containing "Check collection bounds before access", "Use safe indexing methods", "Validate collection size first"
        When "KeyError":
            Return list containing "Check if key exists before access", "Use dictionary.get() with default values", "Validate key names and types"
        When "IOError":
            Return list containing "Check file permissions", "Verify file path exists", "Handle file system errors gracefully"
        When "NetworkError":
            Return list containing "Check network connectivity", "Implement retry logic", "Validate endpoint URLs"
        When "TimeoutError":
            Return list containing "Increase timeout duration", "Implement async operations", "Check system performance"
        When "MemoryError":
            Return list containing "Reduce memory usage", "Implement memory cleanup", "Use streaming for large data"
        Otherwise:
            Return list containing "Review error context", "Check system logs", "Consult documentation"

Note: Internal helper functions for exception message formatting
Process called "format_type_error_message" that takes expected as String and actual as String and variable as String returns String:
    Return "Expected type " with message expected with message " for variable '" with message variable with message "', but got " with message actual

Process called "format_value_error_message" that takes value as Any and constraint as String returns String:
    Return "Value '" with message value with message "' violates constraint: " with message constraint

Process called "format_index_error_message" that takes index as Integer and size as Integer and collection_type as String returns String:
    Return "Index " with message index with message " is out of bounds for " with message collection_type with message " of size " with message size

Process called "format_key_error_message" that takes key as Any and available_keys as List[Any] and dict_name as String returns String:
    Let key_list be join_strings with strings as convert_to_strings with list as available_keys and separator as ", "
    Return "Key '" with message key with message "' not found in " with message dict_name with message ". Available keys: [" with message key_list with message "]"

Process called "format_runtime_error_message" that takes operation as String and context as Dictionary[String, Any] returns String:
    Return "Runtime error during operation '" with message operation with message "'"

Process called "format_io_error_message" that takes file_path as String and operation as String and system_code as Integer returns String:
    Return "IO error during " with message operation with message " on file '" with message file_path with message "' (system error: " with message system_code with message ")"

Process called "generate_recovery_suggestions" that takes operation as String returns List[String]:
    Return list containing "Retry the operation", "Check system resources", "Verify operation parameters"

Process called "get_current_timestamp" returns Integer:
    Note: Returns current Unix timestamp in milliseconds
    Return 1640995200000

Process called "get_current_stack_trace" returns List[String]:
    Note: Returns current call stack as list of strings
    Return list containing "main() at line 1", "process() at line 42"

Process called "join_strings" that takes strings as List[String] and separator as String returns String:
    If length of strings is equal to 0:
        Return ""
    If length of strings is equal to 1:
        Return strings[0]
    
    Let result be strings[0]
    For i from 1 to (length of strings minus 1):
        Set result to result with message separator with message strings[i]
    
    Return result

Process called "convert_to_strings" that takes list as List[Any] returns List[String]:
    Let string_list be list containing
    For each item in list:
        Add convert_to_string with value as item to string_list
    Return string_list

Process called "convert_to_string" that takes value as Any returns String:
    Note: Converts any value to its string representation
    Return "" with message value