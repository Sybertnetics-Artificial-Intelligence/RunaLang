            "error" as result["error"]
    
    Let service_data be parse_json with json_string as result["output"]
    Return parse_service_info with service_data as service_data

Note: List deployments in a namespace
Process called "list_deployments" that takes namespace as Optional[String] returns List[KubernetesDeployment]:
    Let command be "get deployments -o json"
    If namespace is not null:
        Set command to "get deployments -n " with message namespace with message " -o json"
    Else:
        Set command to command with message " --all-namespaces"
    
    Let result be execute_kubectl_command with command as command
    If not result["success"]:
        Throw create_runtime_error with operation as "list_deployments" and context as dictionary with:
            "namespace" as namespace,
            "error" as result["error"]
    
    Let deployments_data be parse_json with json_string as result["output"]
    Let deployments be list containing
    
    If deployments_data contains key "items":
        For each deployment_item in deployments_data["items"]:
            Let deployment be parse_deployment_info with deployment_data as deployment_item
            Add deployment to deployments
    
    Return deployments

Note: Parse deployment information from Kubernetes API response
Process called "parse_deployment_info" that takes deployment_data as Dictionary[String, Any] returns KubernetesDeployment:
    Let metadata be deployment_data["metadata"]
    Let spec be deployment_data["spec"]
    Let status be deployment_data["status"]
    
    Let containers be list containing
    If spec contains key "template" and spec["template"] contains key "spec" and spec["template"]["spec"] contains key "containers":
        For each container in spec["template"]["spec"]["containers"]:
            Let container_info be dictionary with:
                "name" as container["name"],
                "image" as container["image"],
                "ports" as (container["ports"] if container contains key "ports" otherwise list containing),
                "env" as (container["env"] if container contains key "env" otherwise list containing),
                "resources" as (container["resources"] if container contains key "resources" otherwise dictionary containing)
            Add container_info to containers
    
    Return dictionary with:
        "name" as metadata["name"],
        "namespace" as metadata["namespace"],
        "replicas_desired" as spec["replicas"],
        "replicas_ready" as (status["readyReplicas"] if status contains key "readyReplicas" otherwise 0),
        "replicas_available" as (status["availableReplicas"] if status contains key "availableReplicas" otherwise 0),
        "containers" as containers,
        "strategy" as (spec["strategy"] if spec contains key "strategy" otherwise dictionary containing),
        "labels" as (metadata["labels"] if metadata contains key "labels" otherwise dictionary containing),
        "selector" as spec["selector"],
        "created_at" as parse_kubernetes_timestamp with timestamp as metadata["creationTimestamp"],
        "updated_at" as (parse_kubernetes_timestamp with timestamp as status["conditions"][-1]["lastUpdateTime"] if status contains key "conditions" and length of status["conditions"] is greater than 0 otherwise 0)

Note: Create a new deployment
Process called "create_deployment" that takes deployment_definition as Dictionary[String, Any] returns KubernetesDeployment:
    Let yaml_content be convert_to_yaml with data as deployment_definition
    Let temp_file be "/tmp/deployment_definition.yaml"
    
    Note: Write deployment definition to temporary file
    Let write_result be write_file with file_path as temp_file and content as yaml_content
    If not write_result:
        Throw create_runtime_error with operation as "create_deployment" and context as dictionary with:
            "error" as "Failed to write deployment definition file"
    
    Let command be "apply -f " with message temp_file
    Let result be execute_kubectl_command with command as command
    
    Note: Clean up temporary file
    Let cleanup_result be execute_command with command as "rm " with message temp_file
    
    If not result["success"]:
        Throw create_runtime_error with operation as "create_deployment" and context as dictionary with:
            "deployment_definition" as deployment_definition,
            "error" as result["error"]
    
    Note: Get the created deployment details
    Let deployment_name be deployment_definition["metadata"]["name"]
    Let namespace be deployment_definition["metadata"]["namespace"]
    Return get_deployment_details with deployment_name as deployment_name and namespace as namespace

Note: Get detailed deployment information
Process called "get_deployment_details" that takes deployment_name as String and namespace as String returns KubernetesDeployment:
    Let command be "get deployment " with message deployment_name with message " -n " with message namespace with message " -o json"
    Let result be execute_kubectl_command with command as command
    
    If not result["success"]:
        Throw create_runtime_error with operation as "get_deployment_details" and context as dictionary with:
            "deployment_name" as deployment_name,
            "namespace" as namespace,
            "error" as result["error"]
    
    Let deployment_data be parse_json with json_string as result["output"]
    Return parse_deployment_info with deployment_data as deployment_data

Note: Scale deployment
Process called "scale_deployment" that takes deployment_name as String and namespace as String and replicas as Integer returns Boolean:
    Let command be "scale deployment " with message deployment_name with message " -n " with message namespace with message " --replicas=" with message replicas
    Let result be execute_kubectl_command with command as command
    
    If not result["success"]:
        Throw create_runtime_error with operation as "scale_deployment" and context as dictionary with:
            "deployment_name" as deployment_name,
            "namespace" as namespace,
            "replicas" as replicas,
            "error" as result["error"]
    
    Return true

