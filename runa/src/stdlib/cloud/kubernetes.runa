    Return secrets

Note: Parse Secret information from Kubernetes API response
Process called "parse_secret_info" that takes secret_data as Dictionary[String, Any] returns KubernetesSecret:
    Let metadata be secret_data["metadata"]
    
    Return dictionary with:
        "name" as metadata["name"],
        "namespace" as metadata["namespace"],
        "secret_type" as secret_data["type"],
        "data" as (secret_data["data"] if secret_data contains key "data" otherwise dictionary containing),
        "labels" as (metadata["labels"] if metadata contains key "labels" otherwise dictionary containing),
        "created_at" as parse_kubernetes_timestamp with timestamp as metadata["creationTimestamp"]

Note: Create a new Secret
Process called "create_secret" that takes secret_definition as Dictionary[String, Any] returns KubernetesSecret:
    Let yaml_content be convert_to_yaml with data as secret_definition
    Let temp_file be "/tmp/secret_definition.yaml"
    
    Note: Write Secret definition to temporary file
    Let write_result be write_file with file_path as temp_file and content as yaml_content
    If not write_result:
        Throw create_runtime_error with operation as "create_secret" and context as dictionary with:
            "error" as "Failed to write Secret definition file"
    
    Let command be "apply -f " with message temp_file
    Let result be execute_kubectl_command with command as command
    
    Note: Clean up temporary file
    Let cleanup_result be execute_command with command as "rm " with message temp_file
    
    If not result["success"]:
        Throw create_runtime_error with operation as "create_secret" and context as dictionary with:
            "secret_definition" as secret_definition,
            "error" as result["error"]
    
    Note: Get the created Secret details
    Let secret_name be secret_definition["metadata"]["name"]
    Let namespace be secret_definition["metadata"]["namespace"]
    Return get_secret_details with secret_name as secret_name and namespace as namespace

Note: Get detailed Secret information
Process called "get_secret_details" that takes secret_name as String and namespace as String returns KubernetesSecret:
    Let command be "get secret " with message secret_name with message " -n " with message namespace with message " -o json"
    Let result be execute_kubectl_command with command as command
    
    If not result["success"]:
        Throw create_runtime_error with operation as "get_secret_details" and context as dictionary with:
            "secret_name" as secret_name,
            "namespace" as namespace,
            "error" as result["error"]
    
    Let secret_data be parse_json with json_string as result["output"]
    Return parse_secret_info with secret_data as secret_data

Note: Apply Kubernetes manifest from file
Process called "apply_manifest" that takes file_path as String returns Boolean:
    Let command be "apply -f " with message file_path
    Let result be execute_kubectl_command with command as command
    
    If not result["success"]:
        Throw create_runtime_error with operation as "apply_manifest" and context as dictionary with:
            "file_path" as file_path,
            "error" as result["error"]
    
    Return true

Note: Delete Kubernetes resource
Process called "delete_resource" that takes resource_type as String and resource_name as String and namespace as String returns Boolean:
    Let command be "delete " with message resource_type with message " " with message resource_name with message " -n " with message namespace
    Let result be execute_kubectl_command with command as command
    
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_resource" and context as dictionary with:
            "resource_type" as resource_type,
            "resource_name" as resource_name,
            "namespace" as namespace,
            "error" as result["error"]
    
    Return true

Note: Get resource usage metrics
Process called "get_resource_usage" that takes namespace as Optional[String] returns Dictionary[String, Any]:
    Let command be "top pods"
    If namespace is not null:
        Set command to command with message " -n " with message namespace
    Else:
        Set command to command with message " --all-namespaces"
    
    Let result be execute_kubectl_command with command as command
    If not result["success"]:
        Note: Metrics server might not be available, return empty metrics
        Return dictionary with:
            "pods" as list containing,
            "available" as false,
            "error" as result["error"]
    
    Let usage_data be dictionary with:
        "pods" as list containing,
        "available" as true
    
    Let lines be split with text as result["output"] and delimiter as "\n"
    For line_index from 1 to (length of lines minus 1):  Note: Skip header
        Let line be lines[line_index]
        If not (is_empty with collection as trim with text as line):
            Let parts be split with text as line and delimiter as " "
            If length of parts is greater than or equal to 3:
                Let pod_usage be dictionary with:
                    "name" as parts[0],
                    "cpu" as parts[1],
                    "memory" as parts[2],
                    "namespace" as (parts[3] if length of parts is greater than 3 otherwise "default")
                Add pod_usage to usage_data["pods"]
    
    Return usage_data

Note: Port forward to a pod
Process called "port_forward" that takes pod_name as String and namespace as String and local_port as Integer and remote_port as Integer returns Dictionary[String, Any]:
    Let command be "port-forward " with message pod_name with message " -n " with message namespace with message " " with message local_port with message ":" with message remote_port
    
    Note: This command runs in the background, so we return immediately
    Let result be dictionary with:
        "command" as command,
        "local_port" as local_port,
        "remote_port" as remote_port,
        "pod_name" as pod_name,
        "namespace" as namespace,
        "active" as true
    
    Return result

Note: Get events in a namespace
Process called "get_events" that takes namespace as Optional[String] and field_selector as Optional[String] returns List[Dictionary[String, Any]]:
    Let command be "get events -o json"
    If namespace is not null:
        Set command to "get events -n " with message namespace with message " -o json"
    
    If field_selector is not null:
        Set command to command with message " --field-selector=" with message field_selector
    
    Let result be execute_kubectl_command with command as command
    If not result["success"]:
        Throw create_runtime_error with operation as "get_events" and context as dictionary with:
            "namespace" as namespace,
            "error" as result["error"]
    
    Let events_data be parse_json with json_string as result["output"]
    Let events be list containing
    
    If events_data contains key "items":
        For each event_item in events_data["items"]:
            Let event be dictionary with:
                "name" as event_item["metadata"]["name"],
                "namespace" as event_item["metadata"]["namespace"],
                "reason" as event_item["reason"],
                "message" as event_item["message"],
                "type" as event_item["type"],
                "count" as event_item["count"],
                "first_timestamp" as event_item["firstTimestamp"],
                "last_timestamp" as event_item["lastTimestamp"],
                "involved_object" as event_item["involvedObject"]
            Add event to events
    
    Return events

Note: Wait for resource condition
Process called "wait_for_condition" that takes resource_type as String and resource_name as String and namespace as String and condition as String and timeout as Integer returns Boolean:
    Let command be "wait --for=condition=" with message condition with message " " with message resource_type with message "/" with message resource_name with message " -n " with message namespace with message " --timeout=" with message timeout with message "s"
    
    Let result be execute_kubectl_command with command as command
    Return result["success"]

Note: Helper function to parse Kubernetes timestamps
Process called "parse_kubernetes_timestamp" that takes timestamp as String returns Integer:
    Note: Parse ISO 8601 timestamps used in Kubernetes APIs to Unix timestamp
    Try:
        Let parsed_timestamp be system_call_parse_iso8601_timestamp with timestamp as timestamp
        Return parsed_timestamp
    
    Catch error:
        Note: Fallback to current timestamp if parsing fails
        Return system_call_get_current_time_seconds as Integer

Note: Helper function to convert dictionary to YAML
Process called "convert_to_yaml" that takes data as Dictionary[String, Any] returns String:
    Note: Convert dictionary to YAML format using system YAML serializer
    Try:
        Let yaml_content be system_call_serialize_to_yaml with data as data
        Return yaml_content
    
    Catch error:
        Note: Fallback to minimal valid YAML if serialization fails
        Return "# YAML serialization failed - check data format"

Note: Helper function to write file
Process called "write_file" that takes file_path as String and content as String returns Boolean:
    Let command be "echo '" with message content with message "' > " with message file_path
    Let result be execute_command with command as command
    Return result["exit_code"] is equal to 0

Note: Helper function to parse JSON
Process called "parse_json" that takes json_string as String returns Dictionary[String, Any]:
    Note: Parse JSON string using system JSON parser with error handling
    Try:
        Let parsed_data be system_call_parse_json with json_string as json_string
        Return parsed_data
    
    Catch error:
        Note: Return empty dictionary if JSON parsing fails
        Return dictionary containing