Note: Runa Kubernetes Management Module
Note: Provides comprehensive Kubernetes cluster and resource management functionality
Note: Following Runa specification patterns with natural language syntax

Note: Built-in functions are automatically available in Runa programs
Note: No imports required for built-ins like create_runtime_error, execute_command, etc.

Note: Kubernetes Pod type definition
Type called "KubernetesPod":
    name as String,
    namespace as String,
    status as String,
    phase as String,
    containers as List[Dictionary[String, Any]],
    node_name as Optional[String],
    pod_ip as Optional[String],
    labels as Dictionary[String, String],
    annotations as Dictionary[String, String],
    created_at as Integer,
    ready as Boolean,
    restarts as Integer

Note: Kubernetes Service type definition
Type called "KubernetesService":
    name as String,
    namespace as String,
    service_type as String,
    cluster_ip as String,
    external_ip as Optional[String],
    ports as List[Dictionary[String, Any]],
    selector as Dictionary[String, String],
    labels as Dictionary[String, String],
    created_at as Integer

Note: Kubernetes Deployment type definition
Type called "KubernetesDeployment":
    name as String,
    namespace as String,
    replicas_desired as Integer,
    replicas_ready as Integer,
    replicas_available as Integer,
    containers as List[Dictionary[String, Any]],
    strategy as Dictionary[String, Any],
    labels as Dictionary[String, String],
    selector as Dictionary[String, String],
    created_at as Integer,
    updated_at as Integer

Note: Kubernetes Node type definition
Type called "KubernetesNode":
    name as String,
    status as String,
    roles as List[String],
    age as String,
    version as String,
    internal_ip as String,
    external_ip as Optional[String],
    hostname as String,
    os_image as String,
    kernel_version as String,
    container_runtime as String,
    capacity as Dictionary[String, String],
    allocatable as Dictionary[String, String],
    conditions as List[Dictionary[String, Any]]

Note: Kubernetes ConfigMap type definition
Type called "KubernetesConfigMap":
    name as String,
    namespace as String,
    data as Dictionary[String, String],
    binary_data as Dictionary[String, String],
    labels as Dictionary[String, String],
    created_at as Integer

Note: Kubernetes Secret type definition
Type called "KubernetesSecret":
    name as String,
    namespace as String,
    secret_type as String,
    data as Dictionary[String, String],
    labels as Dictionary[String, String],
    created_at as Integer

Note: Execute kubectl command with error handling
Process called "execute_kubectl_command" that takes command as String returns Dictionary[String, Any]:
    Try:
        Let full_command be "kubectl " with message command
        Let result be execute_command with command as full_command
        
        If result["exit_code"] is not equal to 0:
            Throw create_runtime_error with operation as "kubectl_command" and context as dictionary with:
                "command" as command,
                "exit_code" as result["exit_code"],
                "error_output" as result["stderr"]
        
        Return dictionary with:
            "success" as true,
            "output" as result["stdout"],
            "command" as command
    
    Catch error:
        Return dictionary with:
            "success" as false,
            "error" as error["message"],
            "command" as command

Note: Get cluster information
Process called "get_cluster_info" returns Dictionary[String, Any]:
    Let command be "cluster-info"
    Let result be execute_kubectl_command with command as command
    
    If not result["success"]:
        Throw create_runtime_error with operation as "get_cluster_info" and context as dictionary with:
            "error" as result["error"]
    
    Return dictionary with:
        "info" as result["output"],
        "accessible" as true

Note: List all nodes in the cluster
Process called "list_nodes" returns List[KubernetesNode]:
    Let command be "get nodes -o json"
    Let result be execute_kubectl_command with command as command
    
    If not result["success"]:
        Throw create_runtime_error with operation as "list_nodes" and context as dictionary with:
            "error" as result["error"]
    
    Let nodes_data be parse_json with json_string as result["output"]
    Let nodes be list containing
    
    If nodes_data contains key "items":
        For each node_item in nodes_data["items"]:
            Let node be parse_node_info with node_data as node_item
            Add node to nodes
    
    Return nodes

Note: Parse node information from Kubernetes API response
Process called "parse_node_info" that takes node_data as Dictionary[String, Any] returns KubernetesNode:
    Let metadata be node_data["metadata"]
    Let status be node_data["status"]
    
    Let roles be list containing
    If metadata contains key "labels":
        For each key and value in metadata["labels"]:
            If contains with collection as key and item as "node-role.kubernetes.io":
                Let role be replace with text as key and old_substring as "node-role.kubernetes.io/" and new_substring as ""
                Add role to roles
    
    Let addresses be status["addresses"]
    Let internal_ip be ""
    Let external_ip be null
    Let hostname be ""
    
    For each address in addresses:
        If address["type"] is equal to "InternalIP":
            Set internal_ip to address["address"]
        If address["type"] is equal to "ExternalIP":
            Set external_ip to address["address"]
        If address["type"] is equal to "Hostname":
            Set hostname to address["address"]
    
    Return dictionary with:
        "name" as metadata["name"],
        "status" as (status["conditions"][-1]["type"] if length of status["conditions"] is greater than 0 otherwise "Unknown"),
        "roles" as roles,
        "age" as metadata["creationTimestamp"],
        "version" as status["nodeInfo"]["kubeletVersion"],
        "internal_ip" as internal_ip,
        "external_ip" as external_ip,
        "hostname" as hostname,
        "os_image" as status["nodeInfo"]["osImage"],
        "kernel_version" as status["nodeInfo"]["kernelVersion"],
        "container_runtime" as status["nodeInfo"]["containerRuntimeVersion"],
        "capacity" as status["capacity"],
        "allocatable" as status["allocatable"],
        "conditions" as status["conditions"]

Note: List pods in a namespace
Process called "list_pods" that takes namespace as Optional[String] returns List[KubernetesPod]:
    Let command be "get pods -o json"
    If namespace is not null:
        Set command to "get pods -n " with message namespace with message " -o json"
    Else:
        Set command to command with message " --all-namespaces"
    
    Let result be execute_kubectl_command with command as command
    If not result["success"]:
        Throw create_runtime_error with operation as "list_pods" and context as dictionary with:
            "namespace" as namespace,
            "error" as result["error"]
    
    Let pods_data be parse_json with json_string as result["output"]
    Let pods be list containing
    
    If pods_data contains key "items":
        For each pod_item in pods_data["items"]:
            Let pod be parse_pod_info with pod_data as pod_item
            Add pod to pods
    
    Return pods

Note: Parse pod information from Kubernetes API response
Process called "parse_pod_info" that takes pod_data as Dictionary[String, Any] returns KubernetesPod:
    Let metadata be pod_data["metadata"]
    Let status be pod_data["status"]
    Let spec be pod_data["spec"]
    
    Let containers be list containing
    For each container in spec["containers"]:
        Let container_info be dictionary with:
            "name" as container["name"],
            "image" as container["image"],
            "ports" as (container["ports"] if container contains key "ports" otherwise list containing),
            "env" as (container["env"] if container contains key "env" otherwise list containing),
            "resources" as (container["resources"] if container contains key "resources" otherwise dictionary containing)
        Add container_info to containers
    
    Let ready_count be 0
    Let restart_count be 0
    If status contains key "containerStatuses":
        For each container_status in status["containerStatuses"]:
            If container_status["ready"]:
                Set ready_count to ready_count plus 1
            Set restart_count to restart_count plus container_status["restartCount"]
    
    Return dictionary with:
        "name" as metadata["name"],
        "namespace" as metadata["namespace"],
        "status" as (status["phase"] if status contains key "phase" otherwise "Unknown"),
        "phase" as (status["phase"] if status contains key "phase" otherwise "Unknown"),
        "containers" as containers,
        "node_name" as (spec["nodeName"] if spec contains key "nodeName" otherwise null),
        "pod_ip" as (status["podIP"] if status contains key "podIP" otherwise null),
        "labels" as (metadata["labels"] if metadata contains key "labels" otherwise dictionary containing),
        "annotations" as (metadata["annotations"] if metadata contains key "annotations" otherwise dictionary containing),
        "created_at" as parse_kubernetes_timestamp with timestamp as metadata["creationTimestamp"],
        "ready" as (ready_count is equal to length of containers),
        "restarts" as restart_count

Note: Get detailed pod information
Process called "get_pod_details" that takes pod_name as String and namespace as String returns KubernetesPod:
    Let command be "get pod " with message pod_name with message " -n " with message namespace with message " -o json"
    Let result be execute_kubectl_command with command as command
    
    If not result["success"]:
        Throw create_runtime_error with operation as "get_pod_details" and context as dictionary with:
            "pod_name" as pod_name,
            "namespace" as namespace,
            "error" as result["error"]
    
    Let pod_data be parse_json with json_string as result["output"]
    Return parse_pod_info with pod_data as pod_data

Note: Create a new pod
Process called "create_pod" that takes pod_definition as Dictionary[String, Any] returns KubernetesPod:
    Let yaml_content be convert_to_yaml with data as pod_definition
    Let temp_file be "/tmp/pod_definition.yaml"
    
    Note: Write pod definition to temporary file
    Let write_result be write_file with file_path as temp_file and content as yaml_content
    If not write_result:
        Throw create_runtime_error with operation as "create_pod" and context as dictionary with:
            "error" as "Failed to write pod definition file"
    
    Let command be "apply -f " with message temp_file
    Let result be execute_kubectl_command with command as command
    
    Note: Clean up temporary file
    Let cleanup_result be execute_command with command as "rm " with message temp_file
    
    If not result["success"]:
        Throw create_runtime_error with operation as "create_pod" and context as dictionary with:
            "pod_definition" as pod_definition,
            "error" as result["error"]
    
    Note: Get the created pod details
    Let pod_name be pod_definition["metadata"]["name"]
    Let namespace be pod_definition["metadata"]["namespace"]
    Return get_pod_details with pod_name as pod_name and namespace as namespace

Note: Delete a pod
Process called "delete_pod" that takes pod_name as String and namespace as String and grace_period as Optional[Integer] returns Boolean:
    Let command be "delete pod " with message pod_name with message " -n " with message namespace
    If grace_period is not null:
        Set command to command with message " --grace-period=" with message grace_period
    
    Let result be execute_kubectl_command with command as command
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_pod" and context as dictionary with:
            "pod_name" as pod_name,
            "namespace" as namespace,
            "error" as result["error"]
    
    Return true

Note: Get pod logs
Process called "get_pod_logs" that takes pod_name as String and namespace as String and options as Dictionary[String, Any] returns String:
    Let command be "logs " with message pod_name with message " -n " with message namespace
    
    Note: Add container name if specified
    If options contains key "container":
        Set command to command with message " -c " with message options["container"]
    
    Note: Add follow option
    If options contains key "follow" and options["follow"]:
        Set command to command with message " -f"
    
    Note: Add tail option
    If options contains key "tail":
        Set command to command with message " --tail=" with message options["tail"]
    
    Note: Add since option
    If options contains key "since":
        Set command to command with message " --since=" with message options["since"]
    
    Note: Add previous option
    If options contains key "previous" and options["previous"]:
        Set command to command with message " --previous"
    
    Let result be execute_kubectl_command with command as command
    If not result["success"]:
        Throw create_runtime_error with operation as "get_pod_logs" and context as dictionary with:
            "pod_name" as pod_name,
            "namespace" as namespace,
            "error" as result["error"]
    
    Return result["output"]

Note: Execute command in pod
Process called "execute_in_pod" that takes pod_name as String and namespace as String and command as String and options as Dictionary[String, Any] returns String:
    Let exec_command be "exec " with message pod_name with message " -n " with message namespace
    
    Note: Add container name if specified
    If options contains key "container":
        Set exec_command to exec_command with message " -c " with message options["container"]
    
    Note: Add interactive and TTY flags
    If options contains key "interactive" and options["interactive"]:
        Set exec_command to exec_command with message " -i"
    If options contains key "tty" and options["tty"]:
        Set exec_command to exec_command with message " -t"
    
    Set exec_command to exec_command with message " -- " with message command
    
    Let result be execute_kubectl_command with command as exec_command
    If not result["success"]:
        Throw create_runtime_error with operation as "execute_in_pod" and context as dictionary with:
            "pod_name" as pod_name,
            "namespace" as namespace,
            "command" as command,
            "error" as result["error"]
    
    Return result["output"]

Note: List services in a namespace
Process called "list_services" that takes namespace as Optional[String] returns List[KubernetesService]:
    Let command be "get services -o json"
    If namespace is not null:
        Set command to "get services -n " with message namespace with message " -o json"
    Else:
        Set command to command with message " --all-namespaces"
    
    Let result be execute_kubectl_command with command as command
    If not result["success"]:
        Throw create_runtime_error with operation as "list_services" and context as dictionary with:
            "namespace" as namespace,
            "error" as result["error"]
    
    Let services_data be parse_json with json_string as result["output"]
    Let services be list containing
    
    If services_data contains key "items":
        For each service_item in services_data["items"]:
            Let service be parse_service_info with service_data as service_item
            Add service to services
    
    Return services

Note: Parse service information from Kubernetes API response
Process called "parse_service_info" that takes service_data as Dictionary[String, Any] returns KubernetesService:
    Let metadata be service_data["metadata"]
    Let spec be service_data["spec"]
    Let status be service_data["status"]
    
    Let ports be list containing
    If spec contains key "ports":
        For each port in spec["ports"]:
            Let port_info be dictionary with:
                "name" as (port["name"] if port contains key "name" otherwise ""),
                "protocol" as port["protocol"],
                "port" as port["port"],
                "target_port" as port["targetPort"],
                "node_port" as (port["nodePort"] if port contains key "nodePort" otherwise null)
            Add port_info to ports
    
    Let external_ip be null
    If status contains key "loadBalancer" and status["loadBalancer"] contains key "ingress":
        Let ingress_list be status["loadBalancer"]["ingress"]
        If length of ingress_list is greater than 0:
            If ingress_list[0] contains key "ip":
                Set external_ip to ingress_list[0]["ip"]
            If ingress_list[0] contains key "hostname":
                Set external_ip to ingress_list[0]["hostname"]
    
    Return dictionary with:
        "name" as metadata["name"],
        "namespace" as metadata["namespace"],
        "service_type" as spec["type"],
        "cluster_ip" as spec["clusterIP"],
        "external_ip" as external_ip,
        "ports" as ports,
        "selector" as (spec["selector"] if spec contains key "selector" otherwise dictionary containing),
        "labels" as (metadata["labels"] if metadata contains key "labels" otherwise dictionary containing),
        "created_at" as parse_kubernetes_timestamp with timestamp as metadata["creationTimestamp"]

Note: Create a new service
Process called "create_service" that takes service_definition as Dictionary[String, Any] returns KubernetesService:
    Let yaml_content be convert_to_yaml with data as service_definition
    Let temp_file be "/tmp/service_definition.yaml"
    
    Note: Write service definition to temporary file
    Let write_result be write_file with file_path as temp_file and content as yaml_content
    If not write_result:
        Throw create_runtime_error with operation as "create_service" and context as dictionary with:
            "error" as "Failed to write service definition file"
    
    Let command be "apply -f " with message temp_file
    Let result be execute_kubectl_command with command as command
    
    Note: Clean up temporary file
    Let cleanup_result be execute_command with command as "rm " with message temp_file
    
    If not result["success"]:
        Throw create_runtime_error with operation as "create_service" and context as dictionary with:
            "service_definition" as service_definition,
            "error" as result["error"]
    
    Note: Get the created service details
    Let service_name be service_definition["metadata"]["name"]
    Let namespace be service_definition["metadata"]["namespace"]
    Return get_service_details with service_name as service_name and namespace as namespace

Note: Get detailed service information
Process called "get_service_details" that takes service_name as String and namespace as String returns KubernetesService:
    Let command be "get service " with message service_name with message " -n " with message namespace with message " -o json"
    Let result be execute_kubectl_command with command as command
    
    If not result["success"]:
        Throw create_runtime_error with operation as "get_service_details" and context as dictionary with:
            "service_name" as service_name,
