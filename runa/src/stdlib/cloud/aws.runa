        "engine_version" as instance_data["EngineVersion"],
        "db_name" as (instance_data["DBName"] if instance_data contains key "DBName" otherwise null),
        "master_username" as instance_data["MasterUsername"],
        "allocated_storage" as instance_data["AllocatedStorage"],
        "storage_type" as instance_data["StorageType"],
        "storage_encrypted" as instance_data["StorageEncrypted"],
        "vpc_security_groups" as vpc_security_groups,
        "availability_zone" as instance_data["AvailabilityZone"],
        "multi_az" as instance_data["MultiAZ"],
        "publicly_accessible" as instance_data["PubliclyAccessible"],
        "endpoint" as endpoint_info,
        "db_instance_status" as instance_data["DBInstanceStatus"],
        "creation_time" as parse_aws_timestamp with timestamp as instance_data["InstanceCreateTime"],
        "tags" as dictionary containing

Note: Create RDS database instance
Process called "create_rds_instance" that takes db_instance_identifier as String and db_instance_class as String and engine as String and master_username as String and master_password as String and options as Dictionary[String, Any] returns AWSRDSInstance:
    Let parameters be list containing
    Add "--db-instance-identifier" to parameters
    Add db_instance_identifier to parameters
    Add "--db-instance-class" to parameters
    Add db_instance_class to parameters
    Add "--engine" to parameters
    Add engine to parameters
    Add "--master-username" to parameters
    Add master_username to parameters
    Add "--master-user-password" to parameters
    Add master_password to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Note: Add allocated storage
    Let allocated_storage be (options["allocated_storage"] if options contains key "allocated_storage" otherwise 20)
    Add "--allocated-storage" to parameters
    Add allocated_storage to parameters
    
    Note: Add database name if specified
    If options contains key "db_name":
        Add "--db-name" to parameters
        Add options["db_name"] to parameters
    
    Note: Add VPC security groups
    If options contains key "vpc_security_group_ids":
        For each sg_id in options["vpc_security_group_ids"]:
            Add "--vpc-security-group-ids" to parameters
            Add sg_id to parameters
    
    Note: Add storage type
    If options contains key "storage_type":
        Add "--storage-type" to parameters
        Add options["storage_type"] to parameters
    
    Note: Add multi-AZ option
    If options contains key "multi_az" and options["multi_az"]:
        Add "--multi-az" to parameters
    
    Note: Add publicly accessible option
    If options contains key "publicly_accessible":
        If options["publicly_accessible"]:
            Add "--publicly-accessible" to parameters
        Else:
            Add "--no-publicly-accessible" to parameters
    
    Let result be execute_aws_command with service as "rds" and command as "create-db-instance" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "create_rds_instance" and context as dictionary with:
            "db_instance_identifier" as db_instance_identifier,
            "error" as result["error"]
    
    Let instance_data be parse_json with json_string as result["output"]
    If instance_data contains key "DBInstance":
        Return parse_rds_instance_info with instance_data as instance_data["DBInstance"]
    
    Throw create_runtime_error with operation as "create_rds_instance" and context as dictionary with:
        "error" as "No database instance data returned"

Note: Delete RDS database instance
Process called "delete_rds_instance" that takes db_instance_identifier as String and skip_final_snapshot as Boolean returns Boolean:
    Let parameters be list containing
    Add "--db-instance-identifier" to parameters
    Add db_instance_identifier to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    If skip_final_snapshot:
        Add "--skip-final-snapshot" to parameters
    Else:
        Add "--final-db-snapshot-identifier" to parameters
        Add db_instance_identifier with message "-final-snapshot-" with message get_current_timestamp to parameters
    
    Let result be execute_aws_command with service as "rds" and command as "delete-db-instance" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_rds_instance" and context as dictionary with:
            "db_instance_identifier" as db_instance_identifier,
            "error" as result["error"]
    
    Return true

Note: Deploy CloudFormation stack
Process called "deploy_cloudformation_stack" that takes stack_name as String and template_body_or_url as String and parameters_list as List[Dictionary[String, String]] and options as Dictionary[String, Any] returns AWSCloudFormationStack:
    Let deploy_parameters be list containing
    Add "--stack-name" to deploy_parameters
    Add stack_name to deploy_parameters
    Add "--output" to deploy_parameters
    Add "json" to deploy_parameters
    
    Note: Add template body or URL
    If contains with collection as template_body_or_url and item as "http":
        Add "--template-url" to deploy_parameters
        Add template_body_or_url to deploy_parameters
    Else:
        Add "--template-body" to deploy_parameters
        Add "file://" with message template_body_or_url to deploy_parameters
    
    Note: Add parameters
    If length of parameters_list is greater than 0:
        Let params_string be ""
        Let first be true
        For each param in parameters_list:
            If not first:
                Set params_string to params_string with message " "
            Set params_string to params_string with message "ParameterKey=" with message param["key"] with message ",ParameterValue=" with message param["value"]
            Set first to false
        Add "--parameters" to deploy_parameters
        Add params_string to deploy_parameters
    
    Note: Add capabilities if specified
    If options contains key "capabilities":
        Add "--capabilities" to deploy_parameters
        For each capability in options["capabilities"]:
            Add capability to deploy_parameters
    
    Let result be execute_aws_command with service as "cloudformation" and command as "create-stack" and parameters as deploy_parameters
    If not result["success"]:
        Note: Try update-stack if create failed
        Set deploy_parameters[6] to "update-stack"  Note: Replace create-stack with update-stack
        Let update_result be execute_aws_command with service as "cloudformation" and command as "update-stack" and parameters as deploy_parameters
        If not update_result["success"]:
            Throw create_runtime_error with operation as "deploy_cloudformation_stack" and context as dictionary with:
                "stack_name" as stack_name,
                "create_error" as result["error"],
                "update_error" as update_result["error"]
        Set result to update_result
    
    Note: Wait for stack operation to complete
    Let wait_result be wait_for_cloudformation_stack with stack_name as stack_name and operation as "deploy"
    If not wait_result:
        Throw create_runtime_error with operation as "deploy_cloudformation_stack" and context as dictionary with:
            "stack_name" as stack_name,
            "error" as "Stack deployment did not complete successfully"
    
    Return get_cloudformation_stack_details with stack_name as stack_name

Note: Get CloudFormation stack details
Process called "get_cloudformation_stack_details" that takes stack_name as String returns AWSCloudFormationStack:
    Let parameters be list containing
    Add "--stack-name" to parameters
    Add stack_name to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_aws_command with service as "cloudformation" and command as "describe-stacks" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "get_cloudformation_stack_details" and context as dictionary with:
            "stack_name" as stack_name,
            "error" as result["error"]
    
    Let stacks_data be parse_json with json_string as result["output"]
    If stacks_data contains key "Stacks" and length of stacks_data["Stacks"] is greater than 0:
        Let stack_data be stacks_data["Stacks"][0]
        Return parse_cloudformation_stack_info with stack_data as stack_data
    
    Throw create_runtime_error with operation as "get_cloudformation_stack_details" and context as dictionary with:
        "stack_name" as stack_name,
        "error" as "Stack not found"

Note: Parse CloudFormation stack information from AWS API response
Process called "parse_cloudformation_stack_info" that takes stack_data as Dictionary[String, Any] returns AWSCloudFormationStack:
    Let parameters_list be list containing
    If stack_data contains key "Parameters":
        For each param in stack_data["Parameters"]:
            Let parameter_info be dictionary with:
                "key" as param["ParameterKey"],
                "value" as param["ParameterValue"]
            Add parameter_info to parameters_list
    
    Let outputs_list be list containing
    If stack_data contains key "Outputs":
        For each output in stack_data["Outputs"]:
            Let output_info be dictionary with:
                "key" as output["OutputKey"],
                "value" as output["OutputValue"],
                "description" as (output["Description"] if output contains key "Description" otherwise null)
            Add output_info to outputs_list
    
    Let tags_dict be dictionary containing
    If stack_data contains key "Tags":
        For each tag in stack_data["Tags"]:
            Set tags_dict[tag["Key"]] to tag["Value"]
    
    Return dictionary with:
        "stack_name" as stack_data["StackName"],
        "stack_id" as stack_data["StackId"],
        "stack_status" as stack_data["StackStatus"],
        "creation_time" as parse_aws_timestamp with timestamp as stack_data["CreationTime"],
        "last_updated_time" as (parse_aws_timestamp with timestamp as stack_data["LastUpdatedTime"] if stack_data contains key "LastUpdatedTime" otherwise null),
        "description" as (stack_data["Description"] if stack_data contains key "Description" otherwise null),
        "parameters" as parameters_list,
        "outputs" as outputs_list,
        "tags" as tags_dict,
        "capabilities" as (stack_data["Capabilities"] if stack_data contains key "Capabilities" otherwise list containing),
        "rollback_configuration" as (stack_data["RollbackConfiguration"] if stack_data contains key "RollbackConfiguration" otherwise null)

Note: Wait for CloudFormation stack operation to complete
Process called "wait_for_cloudformation_stack" that takes stack_name as String and operation as String returns Boolean:
    Let wait_condition be ""
    If operation is equal to "deploy":
        Set wait_condition to "stack-create-complete"
    Else if operation is equal to "update":
        Set wait_condition to "stack-update-complete"
    Else if operation is equal to "delete":
        Set wait_condition to "stack-delete-complete"
    Else:
        Set wait_condition to "stack-create-complete"
    
    Let parameters be list containing
    Add wait_condition to parameters
    Add "--stack-name" to parameters
    Add stack_name to parameters
    
    Let result be execute_aws_command with service as "cloudformation" and command as "wait" and parameters as parameters
    Return result["success"]

Note: Delete CloudFormation stack
Process called "delete_cloudformation_stack" that takes stack_name as String returns Boolean:
    Let parameters be list containing
    Add "--stack-name" to parameters
    Add stack_name to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_aws_command with service as "cloudformation" and command as "delete-stack" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_cloudformation_stack" and context as dictionary with:
            "stack_name" as stack_name,
            "error" as result["error"]
    
    Note: Wait for deletion to complete
    Let wait_result be wait_for_cloudformation_stack with stack_name as stack_name and operation as "delete"
    Return wait_result

Note: Helper function to parse AWS timestamps
Process called "parse_aws_timestamp" that takes timestamp as String returns Integer:
    Note: Parse ISO 8601 timestamps used in AWS APIs to Unix timestamp
    Try:
        Let parsed_timestamp be system_call_parse_iso8601_timestamp with timestamp as timestamp
        Return parsed_timestamp
    
    Catch error:
        Note: Fallback to current timestamp if parsing fails
        Return system_call_get_current_time_seconds as Integer

Note: Helper function to get current timestamp
Process called "get_current_timestamp" returns Integer:
    Let result be execute_command with command as "date +%s"
    Return to_integer with value as trim with text as result["stdout"]

Note: Helper function to read file content
Process called "read_file_content" that takes file_path as String returns String:
    Let result be execute_command with command as "cat " with message file_path
    If result["exit_code"] is equal to 0:
        Return result["stdout"]
    Return ""

Note: Helper function to parse JSON
Process called "parse_json" that takes json_string as String returns Dictionary[String, Any]:
    Note: Parse JSON string using system JSON parser with error handling
    Try:
        Let parsed_data be system_call_parse_json with json_string as json_string
        Return parsed_data
    
    Catch error:
        Note: Return empty dictionary if JSON parsing fails
        Return dictionary containing