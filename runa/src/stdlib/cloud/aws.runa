Note: List S3 buckets
Process called "list_s3_buckets" returns List[AWSS3Bucket]:
    Let parameters be list containing
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_aws_command with service as "s3api" and command as "list-buckets" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_s3_buckets" and context as dictionary with:
            "error" as result["error"]
    
    Let buckets_data be parse_json with json_string as result["output"]
    Let buckets be list containing
    
    If buckets_data contains key "Buckets":
        For each bucket_data in buckets_data["Buckets"]:
            Let bucket be dictionary with:
                "name" as bucket_data["Name"],
                "region" as "us-east-1",  Note: Default, can be updated with get-bucket-location
                "creation_date" as parse_aws_timestamp with timestamp as bucket_data["CreationDate"],
                "versioning_enabled" as false,
                "encryption_enabled" as false,
                "public_access_blocked" as false,
                "policy" as null,
                "website_configuration" as null,
                "cors_configuration" as null,
                "lifecycle_configuration" as null,
                "tags" as dictionary containing
            Add bucket to buckets
    
    Return buckets

Note: Create S3 bucket
Process called "create_s3_bucket" that takes bucket_name as String and region as Optional[String] returns AWSS3Bucket:
    Let parameters be list containing
    Add "--bucket" to parameters
    Add bucket_name to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    If region is not null and region is not equal to "us-east-1":
        Add "--create-bucket-configuration" to parameters
        Add "LocationConstraint=" with message region to parameters
        Add "--region" to parameters
        Add region to parameters
    
    Let result be execute_aws_command with service as "s3api" and command as "create-bucket" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "create_s3_bucket" and context as dictionary with:
            "bucket_name" as bucket_name,
            "region" as region,
            "error" as result["error"]
    
    Return dictionary with:
        "name" as bucket_name,
        "region" as (region if region is not null otherwise "us-east-1"),
        "creation_date" as get_current_timestamp,
        "versioning_enabled" as false,
        "encryption_enabled" as false,
        "public_access_blocked" as true,
        "policy" as null,
        "website_configuration" as null,
        "cors_configuration" as null,
        "lifecycle_configuration" as null,
        "tags" as dictionary containing

Note: Delete S3 bucket
Process called "delete_s3_bucket" that takes bucket_name as String and force as Boolean returns Boolean:
    Note: If force is true, delete all objects first
    If force:
        Let empty_result be empty_s3_bucket with bucket_name as bucket_name
        If not empty_result:
            Throw create_runtime_error with operation as "delete_s3_bucket" and context as dictionary with:
                "bucket_name" as bucket_name,
                "error" as "Failed to empty bucket before deletion"
    
    Let parameters be list containing
    Add "--bucket" to parameters
    Add bucket_name to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_aws_command with service as "s3api" and command as "delete-bucket" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_s3_bucket" and context as dictionary with:
            "bucket_name" as bucket_name,
            "error" as result["error"]
    
    Return true

Note: Empty S3 bucket (delete all objects)
Process called "empty_s3_bucket" that takes bucket_name as String returns Boolean:
    Let parameters be list containing
    Add bucket_name to parameters
    Add "--recursive" to parameters
    
    Let result be execute_aws_command with service as "s3" and command as "rm" and parameters as parameters
    Return result["success"]

Note: List objects in S3 bucket
Process called "list_s3_objects" that takes bucket_name as String and prefix as Optional[String] returns List[AWSS3Object]:
    Let parameters = list containing
    Add "--bucket" to parameters
    Add bucket_name to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    If prefix is not null:
        Add "--prefix" to parameters
        Add prefix to parameters
    
    Let result be execute_aws_command with service as "s3api" and command as "list-objects-v2" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_s3_objects" and context as dictionary with:
            "bucket_name" as bucket_name,
            "prefix" as prefix,
            "error" as result["error"]
    
    Let objects_data be parse_json with json_string as result["output"]
    Let objects be list containing
    
    If objects_data contains key "Contents":
        For each object_data in objects_data["Contents"]:
            Let s3_object be dictionary with:
                "key" as object_data["Key"],
                "bucket" as bucket_name,
                "size" as object_data["Size"],
                "last_modified" as parse_aws_timestamp with timestamp as object_data["LastModified"],
                "etag" as object_data["ETag"],
                "storage_class" as object_data["StorageClass"],
                "content_type" as null,
                "metadata" as dictionary containing,
                "server_side_encryption" as null,
                "version_id" as null
            Add s3_object to objects
    
    Return objects

Note: Upload file to S3
Process called "upload_to_s3" that takes local_file_path as String and bucket_name as String and s3_key as String and options as Dictionary[String, Any] returns AWSS3Object:
    Let parameters be list containing
    Add local_file_path to parameters
    Add "s3://" with message bucket_name with message "/" with message s3_key to parameters
    
    Note: Add metadata
    If options contains key "metadata":
        For each key and value in options["metadata"]:
            Add "--metadata" to parameters
            Add key with message "=" with message value to parameters
    
    Note: Add content type
    If options contains key "content_type":
        Add "--content-type" to parameters
        Add options["content_type"] to parameters
    
    Note: Add server-side encryption
    If options contains key "server_side_encryption":
        Add "--server-side-encryption" to parameters
        Add options["server_side_encryption"] to parameters
    
    Let result be execute_aws_command with service as "s3" and command as "cp" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "upload_to_s3" and context as dictionary with:
            "local_file_path" as local_file_path,
            "bucket_name" as bucket_name,
            "s3_key" as s3_key,
            "error" as result["error"]
    
    Note: Get object info after upload
    Let object_info be get_s3_object_details with bucket_name as bucket_name and s3_key as s3_key
    Return object_info

Note: Download file from S3
Process called "download_from_s3" that takes bucket_name as String and s3_key as String and local_file_path as String returns Boolean:
    Let parameters be list containing
    Add "s3://" with message bucket_name with message "/" with message s3_key to parameters
    Add local_file_path to parameters
    
    Let result be execute_aws_command with service as "s3" and command as "cp" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "download_from_s3" and context as dictionary with:
            "bucket_name" as bucket_name,
            "s3_key" as s3_key,
            "local_file_path" as local_file_path,
            "error" as result["error"]
    
    Return true

Note: Get S3 object details
Process called "get_s3_object_details" that takes bucket_name as String and s3_key as String returns AWSS3Object:
    Let parameters be list containing
    Add "--bucket" to parameters
    Add bucket_name to parameters
    Add "--key" to parameters
    Add s3_key to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_aws_command with service as "s3api" and command as "head-object" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "get_s3_object_details" and context as dictionary with:
            "bucket_name" as bucket_name,
            "s3_key" as s3_key,
            "error" as result["error"]
    
    Let object_data be parse_json with json_string as result["output"]
    
    Return dictionary with:
        "key" as s3_key,
        "bucket" as bucket_name,
        "size" as object_data["ContentLength"],
        "last_modified" as parse_aws_timestamp with timestamp as object_data["LastModified"],
        "etag" as object_data["ETag"],
        "storage_class" as (object_data["StorageClass"] if object_data contains key "StorageClass" otherwise "STANDARD"),
        "content_type" as (object_data["ContentType"] if object_data contains key "ContentType" otherwise null),
        "metadata" as (object_data["Metadata"] if object_data contains key "Metadata" otherwise dictionary containing),
        "server_side_encryption" as (object_data["ServerSideEncryption"] if object_data contains key "ServerSideEncryption" otherwise null),
        "version_id" as (object_data["VersionId"] if object_data contains key "VersionId" otherwise null)

Note: Delete S3 object
Process called "delete_s3_object" that takes bucket_name as String and s3_key as String returns Boolean:
    Let parameters be list containing
    Add "--bucket" to parameters
    Add bucket_name to parameters
    Add "--key" to parameters
    Add s3_key to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_aws_command with service as "s3api" and command as "delete-object" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_s3_object" and context as dictionary with:
            "bucket_name" as bucket_name,
            "s3_key" as s3_key,
            "error" as result["error"]
    
    Return true

Note: List Lambda functions
Process called "list_lambda_functions" returns List[AWSLambdaFunction]:
    Let parameters be list containing
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_aws_command with service as "lambda" and command as "list-functions" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_lambda_functions" and context as dictionary with:
            "error" as result["error"]
    
    Let functions_data be parse_json with json_string as result["output"]
    Let functions be list containing
    
    If functions_data contains key "Functions":
        For each function_data in functions_data["Functions"]:
            Let lambda_function be parse_lambda_function_info with function_data as function_data
            Add lambda_function to functions
    
    Return functions

Note: Parse Lambda function information from AWS API response
Process called "parse_lambda_function_info" that takes function_data as Dictionary[String, Any] returns AWSLambdaFunction:
    Let env_vars be dictionary containing
    If function_data contains key "Environment" and function_data["Environment"] contains key "Variables":
        Set env_vars to function_data["Environment"]["Variables"]
    
    Let layers be list containing
    If function_data contains key "Layers":
        For each layer in function_data["Layers"]:
            Add layer["Arn"] to layers
    
    Return dictionary with:
        "function_name" as function_data["FunctionName"],
        "function_arn" as function_data["FunctionArn"],
        "runtime" as function_data["Runtime"],
        "role" as function_data["Role"],
        "handler" as function_data["Handler"],
        "code_size" as function_data["CodeSize"],
        "memory_size" as function_data["MemorySize"],
        "timeout" as function_data["Timeout"],
        "last_modified" as parse_aws_timestamp with timestamp as function_data["LastModified"],
        "version" as function_data["Version"],
        "description" as (function_data["Description"] if function_data contains key "Description" otherwise null),
        "environment_variables" as env_vars,
        "vpc_config" as (function_data["VpcConfig"] if function_data contains key "VpcConfig" otherwise null),
        "layers" as layers,
        "tags" as dictionary containing

Note: Create Lambda function
Process called "create_lambda_function" that takes function_name as String and runtime as String and role as String and handler as String and zip_file_path as String and options as Dictionary[String, Any] returns AWSLambdaFunction:
    Let parameters be list containing
    Add "--function-name" to parameters
    Add function_name to parameters
    Add "--runtime" to parameters
    Add runtime to parameters
    Add "--role" to parameters
    Add role to parameters
    Add "--handler" to parameters
    Add handler to parameters
    Add "--zip-file" to parameters
    Add "fileb://" with message zip_file_path to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Note: Add description if specified
    If options contains key "description":
        Add "--description" to parameters
        Add options["description"] to parameters
    
    Note: Add memory size
    If options contains key "memory_size":
        Add "--memory-size" to parameters
        Add options["memory_size"] to parameters
    
    Note: Add timeout
    If options contains key "timeout":
        Add "--timeout" to parameters
        Add options["timeout"] to parameters
    
    Note: Add environment variables
    If options contains key "environment_variables":
        Let env_string be "Variables={"
        Let first be true
        For each key and value in options["environment_variables"]:
            If not first:
                Set env_string to env_string with message ","
            Set env_string to env_string with message key with message "=" with message value
            Set first to false
        Set env_string to env_string with message "}"
        Add "--environment" to parameters
        Add env_string to parameters
    
    Let result be execute_aws_command with service as "lambda" and command as "create-function" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "create_lambda_function" and context as dictionary with:
            "function_name" as function_name,
            "error" as result["error"]
    
    Let function_data be parse_json with json_string as result["output"]
    Return parse_lambda_function_info with function_data as function_data

Note: Invoke Lambda function
Process called "invoke_lambda_function" that takes function_name as String and payload as Optional[String] and invocation_type as Optional[String] returns Dictionary[String, Any]:
    Let parameters be list containing
    Add "--function-name" to parameters
    Add function_name to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Note: Add invocation type (synchronous, asynchronous, dry run)
    Let invoke_type be (invocation_type if invocation_type is not null otherwise "RequestResponse")
    Add "--invocation-type" to parameters
    Add invoke_type to parameters
    
    Note: Add payload if specified
    If payload is not null:
        Add "--payload" to parameters
        Add payload to parameters
    
    Note: Lambda invoke needs output file
    Let output_file be "/tmp/lambda_output.json"
    Add output_file to parameters
    
    Let result be execute_aws_command with service as "lambda" and command as "invoke" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "invoke_lambda_function" and context as dictionary with:
            "function_name" as function_name,
            "error" as result["error"]
    
    Note: Read output file and clean up
    Let output_content be read_file_content with file_path as output_file
    Let cleanup_result be execute_command with command as "rm -f " with message output_file
    
    Let invocation_data be parse_json with json_string as result["output"]
    
    Return dictionary with:
        "status_code" as (invocation_data["StatusCode"] if invocation_data contains key "StatusCode" otherwise 200),
        "executed_version" as (invocation_data["ExecutedVersion"] if invocation_data contains key "ExecutedVersion" otherwise "$LATEST"),
        "payload" as output_content,
        "log_result" as (invocation_data["LogResult"] if invocation_data contains key "LogResult" otherwise null),
        "function_error" as (invocation_data["FunctionError"] if invocation_data contains key "FunctionError" otherwise null)

