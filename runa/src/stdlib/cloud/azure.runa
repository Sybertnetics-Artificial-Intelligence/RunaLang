Note: Runa Azure (Microsoft Azure) Integration Module
Note: Provides comprehensive Microsoft Azure cloud services management functionality
Note: Following Runa specification patterns with natural language syntax

Note: Built-in functions are automatically available in Runa programs
Note: No imports required for built-ins like create_runtime_error, execute_command, etc.

Note: Azure Virtual Machine type definition
Type called "AzureVM":
    vm_id as String,
    name as String,
    resource_group as String,
    location as String,
    vm_size as String,
    os_type as String,
    os_disk as Dictionary[String, Any],
    network_profile as Dictionary[String, Any],
    power_state as String,
    provisioning_state as String,
    public_ip as Optional[String],
    private_ip as String,
    tags as Dictionary[String, String],
    availability_zone as Optional[String],
    created_time as Integer

Note: Azure Storage Account type definition
Type called "AzureStorageAccount":
    account_name as String,
    resource_group as String,
    location as String,
    account_type as String,
    account_kind as String,
    access_tier as String,
    provisioning_state as String,
    creation_time as Integer,
    primary_endpoints as Dictionary[String, String],
    encryption_enabled as Boolean,
    https_traffic_only as Boolean,
    tags as Dictionary[String, String]

Note: Azure Blob Container type definition
Type called "AzureBlobContainer":
    container_name as String,
    storage_account as String,
    resource_group as String,
    public_access as String,
    last_modified as Integer,
    etag as String,
    lease_status as String,
    lease_state as String,
    metadata as Dictionary[String, String]

Note: Azure Blob type definition
Type called "AzureBlob":
    blob_name as String,
    container_name as String,
    storage_account as String,
    blob_type as String,
    content_length as Integer,
    content_type as String,
    last_modified as Integer,
    etag as String,
    content_md5 as Optional[String],
    cache_control as Optional[String],
    content_encoding as Optional[String],
    content_language as Optional[String],
    metadata as Dictionary[String, String],
    tier as Optional[String]

Note: Azure SQL Database type definition
Type called "AzureSQLDatabase":
    database_name as String,
    server_name as String,
    resource_group as String,
    location as String,
    edition as String,
    service_tier as String,
    max_size_bytes as Integer,
    collation as String,
    creation_date as Integer,
    status as String,
    connection_policy as String,
    containment_type as String,
    tags as Dictionary[String, String]

Note: Azure Function App type definition
Type called "AzureFunctionApp":
    app_name as String,
