Note: List storage accounts
Process called "list_storage_accounts" that takes resource_group as Optional[String] returns List[AzureStorageAccount]:
    Let parameters be list containing
    Add "--output" to parameters
    Add "json" to parameters
    
    If resource_group is not null:
        Add "--resource-group" to parameters
        Add resource_group to parameters
    
    Let result be execute_azure_command with service as "storage" and command as "account list" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_storage_accounts" and context as dictionary with:
            "resource_group" as resource_group,
            "error" as result["error"]
    
    Let accounts_data be parse_json with json_string as result["output"]
    Let storage_accounts be list containing
    
    For each account_data in accounts_data:
        Let storage_account be dictionary with:
            "account_name" as account_data["name"],
            "resource_group" as account_data["resourceGroup"],
            "location" as account_data["location"],
            "account_type" as account_data["sku"]["name"],
            "account_kind" as account_data["kind"],
            "access_tier" as (account_data["accessTier"] if account_data contains key "accessTier" otherwise "Hot"),
            "provisioning_state" as account_data["provisioningState"],
            "creation_time" as parse_azure_timestamp with timestamp as account_data["creationTime"],
            "primary_endpoints" as account_data["primaryEndpoints"],
            "encryption_enabled" as account_data["encryption"]["services"]["blob"]["enabled"],
            "https_traffic_only" as account_data["supportsHttpsTrafficOnly"],
            "tags" as (account_data["tags"] if account_data contains key "tags" otherwise dictionary containing)
        Add storage_account to storage_accounts
    
    Return storage_accounts

Note: Create storage account
Process called "create_storage_account" that takes account_name as String and resource_group as String and location as String and options as Dictionary[String, Any] returns AzureStorageAccount:
    Let parameters be list containing
    Add "--name" to parameters
    Add account_name to parameters
    Add "--resource-group" to parameters
    Add resource_group to parameters
    Add "--location" to parameters
    Add location to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Note: Add SKU (storage type)
    Let sku be (options["sku"] if options contains key "sku" otherwise "Standard_LRS")
    Add "--sku" to parameters
    Add sku to parameters
    
    Note: Add kind
    Let kind be (options["kind"] if options contains key "kind" otherwise "StorageV2")
    Add "--kind" to parameters
    Add kind to parameters
    
    Note: Add access tier
    If options contains key "access_tier":
        Add "--access-tier" to parameters
        Add options["access_tier"] to parameters
    
    Note: Add HTTPS only
    If options contains key "https_only" and options["https_only"]:
        Add "--https-only" to parameters
        Add "true" to parameters
    
    Let result be execute_azure_command with service as "storage" and command as "account create" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "create_storage_account" and context as dictionary with:
            "account_name" as account_name,
            "resource_group" as resource_group,
            "error" as result["error"]
    
    Let account_data be parse_json with json_string as result["output"]
    Return dictionary with:
        "account_name" as account_data["name"],
        "resource_group" as account_data["resourceGroup"],
        "location" as account_data["location"],
        "account_type" as account_data["sku"]["name"],
        "account_kind" as account_data["kind"],
        "access_tier" as (account_data["accessTier"] if account_data contains key "accessTier" otherwise "Hot"),
        "provisioning_state" as account_data["provisioningState"],
        "creation_time" as parse_azure_timestamp with timestamp as account_data["creationTime"],
        "primary_endpoints" as account_data["primaryEndpoints"],
        "encryption_enabled" as account_data["encryption"]["services"]["blob"]["enabled"],
        "https_traffic_only" as account_data["supportsHttpsTrafficOnly"],
        "tags" as (account_data["tags"] if account_data contains key "tags" otherwise dictionary containing)

