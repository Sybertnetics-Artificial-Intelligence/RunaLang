    tags as Dictionary[String, String]

Note: Azure Resource Group type definition
Type called "AzureResourceGroup":
    name as String,
    location as String,
    provisioning_state as String,
    managed_by as Optional[String],
    tags as Dictionary[String, String],
    properties as Dictionary[String, Any]

Note: Execute Azure CLI command with error handling
Process called "execute_azure_command" that takes service as String and command as String and parameters as List[String] returns Dictionary[String, Any]:
    Try:
        Let full_command be "az " with message service with message " " with message command
        For each param in parameters:
            Set full_command to full_command with message " " with message param
        
        Let result be execute_command with command as full_command
        
        If result["exit_code"] is not equal to 0:
            Throw create_runtime_error with operation as "azure_command" and context as dictionary with:
                "service" as service,
                "command" as command,
                "parameters" as parameters,
                "exit_code" as result["exit_code"],
                "error_output" as result["stderr"]
        
        Return dictionary with:
            "success" as true,
            "output" as result["stdout"],
            "service" as service,
            "command" as command
    
    Catch error:
        Return dictionary with:
            "success" as false,
            "error" as error["message"],
            "service" as service,
            "command" as command

Note: Configure Azure CLI authentication
Process called "configure_azure_login" that takes subscription_id as Optional[String] returns Boolean:
    Let login_command be "az login"
    Let result be execute_command with command as login_command
    
    If result["exit_code"] is not equal to 0:
        Throw create_runtime_error with operation as "configure_azure_login" and context as dictionary with:
            "error" as result["stderr"]
    
    Note: Set subscription if provided
    If subscription_id is not null:
        Let subscription_command be "az account set --subscription " with message subscription_id
        Let sub_result be execute_command with command as subscription_command
        If sub_result["exit_code"] is not equal to 0:
            Throw create_runtime_error with operation as "configure_azure_login" and context as dictionary with:
                "subscription_id" as subscription_id,
                "error" as sub_result["stderr"]
    
    Return true

Note: List resource groups
Process called "list_resource_groups" returns List[AzureResourceGroup]:
    Let parameters be list containing
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_azure_command with service as "group" and command as "list" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_resource_groups" and context as dictionary with:
            "error" as result["error"]
    
    Let groups_data be parse_json with json_string as result["output"]
    Let resource_groups be list containing
    
    For each group_data in groups_data:
        Let resource_group be dictionary with:
            "name" as group_data["name"],
            "location" as group_data["location"],
            "provisioning_state" as group_data["properties"]["provisioningState"],
            "managed_by" as (group_data["managedBy"] if group_data contains key "managedBy" otherwise null),
            "tags" as (group_data["tags"] if group_data contains key "tags" otherwise dictionary containing),
            "properties" as group_data["properties"]
        Add resource_group to resource_groups
    
    Return resource_groups

Note: Create resource group
Process called "create_resource_group" that takes group_name as String and location as String and tags as Optional[Dictionary[String, String]] returns AzureResourceGroup:
    Let parameters be list containing
    Add "--name" to parameters
    Add group_name to parameters
    Add "--location" to parameters
    Add location to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Note: Add tags if provided
    If tags is not null:
        Let tags_string be ""
        Let first be true
        For each key and value in tags:
            If not first:
                Set tags_string to tags_string with message " "
            Set tags_string to tags_string with message key with message "=" with message value
            Set first to false
        Add "--tags" to parameters
        Add tags_string to parameters
    
    Let result be execute_azure_command with service as "group" and command as "create" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "create_resource_group" and context as dictionary with:
            "group_name" as group_name,
            "location" as location,
            "error" as result["error"]
    
    Let group_data be parse_json with json_string as result["output"]
    Return dictionary with:
        "name" as group_data["name"],
        "location" as group_data["location"],
        "provisioning_state" as group_data["properties"]["provisioningState"],
        "managed_by" as (group_data["managedBy"] if group_data contains key "managedBy" otherwise null),
        "tags" as (group_data["tags"] if group_data contains key "tags" otherwise dictionary containing),
        "properties" as group_data["properties"]

Note: Delete resource group
Process called "delete_resource_group" that takes group_name as String and no_wait as Boolean returns Boolean:
    Let parameters be list containing
    Add "--name" to parameters
    Add group_name to parameters
    Add "--yes" to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    If no_wait:
        Add "--no-wait" to parameters
    
    Let result be execute_azure_command with service as "group" and command as "delete" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_resource_group" and context as dictionary with:
            "group_name" as group_name,
            "error" as result["error"]
    
    Return true

Note: List virtual machines
Process called "list_virtual_machines" that takes resource_group as Optional[String] returns List[AzureVM]:
    Let parameters be list containing
    Add "--output" to parameters
    Add "json" to parameters
    
    If resource_group is not null:
        Add "--resource-group" to parameters
        Add resource_group to parameters
    
    Let result be execute_azure_command with service as "vm" and command as "list" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_virtual_machines" and context as dictionary with:
            "resource_group" as resource_group,
            "error" as result["error"]
    
    Let vms_data be parse_json with json_string as result["output"]
    Let virtual_machines be list containing
    
    For each vm_data in vms_data:
        Let vm be parse_vm_info with vm_data as vm_data
        Add vm to virtual_machines
    
    Return virtual_machines

Note: Parse virtual machine information from Azure API response
Process called "parse_vm_info" that takes vm_data as Dictionary[String, Any] returns AzureVM:
    Let network_profile be vm_data["networkProfile"]
    Let public_ip be null
    Let private_ip be ""
    
    Note: Extract IP addresses from network interfaces
    If network_profile contains key "networkInterfaces":
        For each nic in network_profile["networkInterfaces"]:
            Note: This would require additional API calls to get IP details
            Note: For now, set placeholder values
            Set private_ip to "10.0.0.1"
    
    Return dictionary with:
        "vm_id" as vm_data["vmId"],
        "name" as vm_data["name"],
        "resource_group" as vm_data["resourceGroup"],
        "location" as vm_data["location"],
        "vm_size" as vm_data["hardwareProfile"]["vmSize"],
        "os_type" as vm_data["storageProfile"]["osDisk"]["osType"],
        "os_disk" as vm_data["storageProfile"]["osDisk"],
        "network_profile" as network_profile,
        "power_state" as "Unknown",
        "provisioning_state" as vm_data["provisioningState"],
        "public_ip" as public_ip,
        "private_ip" as private_ip,
        "tags" as (vm_data["tags"] if vm_data contains key "tags" otherwise dictionary containing),
        "availability_zone" as (vm_data["zones"][0] if vm_data contains key "zones" and length of vm_data["zones"] is greater than 0 otherwise null),
        "created_time" as get_current_timestamp

Note: Create virtual machine
Process called "create_virtual_machine" that takes vm_name as String and resource_group as String and location as String and vm_size as String and image as String and options as Dictionary[String, Any] returns AzureVM:
    Let parameters be list containing
    Add "--name" to parameters
    Add vm_name to parameters
    Add "--resource-group" to parameters
    Add resource_group to parameters
    Add "--location" to parameters
    Add location to parameters
    Add "--size" to parameters
    Add vm_size to parameters
    Add "--image" to parameters
    Add image to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Note: Add authentication method
    If options contains key "admin_username":
        Add "--admin-username" to parameters
        Add options["admin_username"] to parameters
    
    If options contains key "admin_password":
        Add "--admin-password" to parameters
        Add options["admin_password"] to parameters
    
    If options contains key "ssh_key_values":
        Add "--ssh-key-values" to parameters
        For each key_value in options["ssh_key_values"]:
            Add key_value to parameters
    
    Note: Add network configuration
    If options contains key "vnet_name":
        Add "--vnet-name" to parameters
        Add options["vnet_name"] to parameters
    
    If options contains key "subnet":
        Add "--subnet" to parameters
        Add options["subnet"] to parameters
    
    If options contains key "public_ip":
        Add "--public-ip-address" to parameters
        Add options["public_ip"] to parameters
    
    Note: Add storage configuration
    If options contains key "os_disk_size":
        Add "--os-disk-size-gb" to parameters
        Add options["os_disk_size"] to parameters
    
    If options contains key "storage_sku":
        Add "--storage-sku" to parameters
        Add options["storage_sku"] to parameters
    
    Let result be execute_azure_command with service as "vm" and command as "create" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "create_virtual_machine" and context as dictionary with:
            "vm_name" as vm_name,
            "resource_group" as resource_group,
            "error" as result["error"]
    
    Let vm_data be parse_json with json_string as result["output"]
    Return parse_vm_info with vm_data as vm_data

Note: Start virtual machine
Process called "start_virtual_machine" that takes vm_name as String and resource_group as String returns Boolean:
