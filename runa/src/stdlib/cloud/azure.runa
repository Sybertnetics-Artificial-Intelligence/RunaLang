Note: List blob containers
Process called "list_blob_containers" that takes account_name as String returns List[AzureBlobContainer]:
    Let parameters be list containing
    Add "--account-name" to parameters
    Add account_name to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_azure_command with service as "storage" and command as "container list" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_blob_containers" and context as dictionary with:
            "account_name" as account_name,
            "error" as result["error"]
    
    Let containers_data be parse_json with json_string as result["output"]
    Let containers be list containing
    
    For each container_data in containers_data:
        Let container be dictionary with:
            "container_name" as container_data["name"],
            "storage_account" as account_name,
            "resource_group" as "unknown",
            "public_access" as (container_data["properties"]["publicAccess"] if container_data["properties"] contains key "publicAccess" otherwise "none"),
            "last_modified" as parse_azure_timestamp with timestamp as container_data["properties"]["lastModified"],
            "etag" as container_data["etag"],
            "lease_status" as container_data["properties"]["leaseStatus"],
            "lease_state" as container_data["properties"]["leaseState"],
            "metadata" as (container_data["metadata"] if container_data contains key "metadata" otherwise dictionary containing)
        Add container to containers
    
    Return containers

