Note: Stop virtual machine
Process called "stop_virtual_machine" that takes vm_name as String and resource_group as String and deallocate as Boolean returns Boolean:
    Let command_name be (if deallocate then "deallocate" else "stop")
    
    Let parameters be list containing
    Add "--name" to parameters
    Add vm_name to parameters
    Add "--resource-group" to parameters
    Add resource_group to parameters
    Add "--output" to parameters
    Add "json" to parameters
    
    Let result be execute_azure_command with service as "vm" and command as command_name and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "stop_virtual_machine" and context as dictionary with:
            "vm_name" as vm_name,
            "resource_group" as resource_group,
            "deallocate" as deallocate,
            "error" as result["error"]
    
    Return true

