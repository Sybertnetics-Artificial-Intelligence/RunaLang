        "cache_control" as (blob_data["properties"]["contentSettings"]["cacheControl"] if blob_data["properties"]["contentSettings"] contains key "cacheControl" otherwise null),
        "content_encoding" as (blob_data["properties"]["contentSettings"]["contentEncoding"] if blob_data["properties"]["contentSettings"] contains key "contentEncoding" otherwise null),
        "content_language" as (blob_data["properties"]["contentSettings"]["contentLanguage"] if blob_data["properties"]["contentSettings"] contains key "contentLanguage" otherwise null),
        "metadata" as (blob_data["metadata"] if blob_data contains key "metadata" otherwise dictionary containing),
        "tier" as (blob_data["properties"]["accessTier"] if blob_data["properties"] contains key "accessTier" otherwise null)

