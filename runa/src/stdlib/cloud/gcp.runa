Note: Delete Compute Engine instance
Process called "delete_compute_instance" that takes instance_name as String and zone as String returns Boolean:
    Let parameters be list containing
    Add instance_name to parameters
    Add "--zone=" with message zone to parameters
    Add "--quiet" to parameters
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "compute" and command as "instances delete" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_compute_instance" and context as dictionary with:
            "instance_name" as instance_name,
            "zone" as zone,
            "error" as result["error"]
    
    Return true

Note: List Cloud Storage buckets
Process called "list_storage_buckets" returns List[GCPBucket]:
    Let parameters be list containing
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "storage" and command as "buckets list" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_storage_buckets" and context as dictionary with:
            "error" as result["error"]
    
    Let buckets_data be parse_json with json_string as result["output"]
    Let buckets be list containing
    
    For each bucket_data in buckets_data:
        Let bucket be parse_storage_bucket_info with bucket_data as bucket_data
        Add bucket to buckets
    
    Return buckets

Note: Parse Cloud Storage bucket information from GCP API response
Process called "parse_storage_bucket_info" that takes bucket_data as Dictionary[String, Any] returns GCPBucket:
    Let labels_dict be dictionary containing
    If bucket_data contains key "labels":
        Set labels_dict to bucket_data["labels"]
    
    Let lifecycle_config be null
    If bucket_data contains key "lifecycle":
        Set lifecycle_config to bucket_data["lifecycle"]["rule"]
    
    Let cors_config be null
    If bucket_data contains key "cors":
        Set cors_config to bucket_data["cors"]
    
    Let website_config be null
    If bucket_data contains key "website":
        Set website_config to bucket_data["website"]
    
    Let retention_policy be null
    If bucket_data contains key "retentionPolicy":
        Set retention_policy to bucket_data["retentionPolicy"]
    
    Return dictionary with:
        "name" as bucket_data["name"],
        "location" as bucket_data["location"],
        "location_type" as bucket_data["locationType"],
        "storage_class" as bucket_data["storageClass"],
        "versioning_enabled" as (bucket_data["versioning"]["enabled"] if bucket_data contains key "versioning" otherwise false),
        "lifecycle_configuration" as lifecycle_config,
        "cors_configuration" as cors_config,
        "website_configuration" as website_config,
        "encryption" as (bucket_data["encryption"] if bucket_data contains key "encryption" otherwise dictionary containing),
        "iam_configuration" as (bucket_data["iamConfiguration"] if bucket_data contains key "iamConfiguration" otherwise dictionary containing),
        "retention_policy" as retention_policy,
        "creation_time" as parse_gcp_timestamp with timestamp as bucket_data["timeCreated"],
        "updated_time" as parse_gcp_timestamp with timestamp as bucket_data["updated"],
        "labels" as labels_dict

Note: Create Cloud Storage bucket
Process called "create_storage_bucket" that takes bucket_name as String and location as Optional[String] and storage_class as Optional[String] returns GCPBucket:
    Let parameters be list containing
    Add bucket_name to parameters
    Add "--format=json" to parameters
    
    Note: Add location
    If location is not null:
        Add "--location=" with message location to parameters
    
    Note: Add storage class
    If storage_class is not null:
        Add "--default-storage-class=" with message storage_class to parameters
    
    Let result be execute_gcp_command with service as "storage" and command as "buckets create" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "create_storage_bucket" and context as dictionary with:
            "bucket_name" as bucket_name,
            "location" as location,
            "error" as result["error"]
    
    Note: Get the created bucket details
    Return get_storage_bucket_details with bucket_name as bucket_name

Note: Get Cloud Storage bucket details
Process called "get_storage_bucket_details" that takes bucket_name as String returns GCPBucket:
    Let parameters be list containing
    Add bucket_name to parameters
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "storage" and command as "buckets describe" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "get_storage_bucket_details" and context as dictionary with:
            "bucket_name" as bucket_name,
            "error" as result["error"]
    
    Let bucket_data be parse_json with json_string as result["output"]
    Return parse_storage_bucket_info with bucket_data as bucket_data

Note: Delete Cloud Storage bucket
Process called "delete_storage_bucket" that takes bucket_name as String returns Boolean:
    Let parameters be list containing
    Add bucket_name to parameters
    Add "--quiet" to parameters
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "storage" and command as "buckets delete" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_storage_bucket" and context as dictionary with:
            "bucket_name" as bucket_name,
            "error" as result["error"]
    
    Return true

Note: List objects in Cloud Storage bucket
Process called "list_storage_objects" that takes bucket_name as String and prefix as Optional[String] returns List[GCPObject]:
    Let parameters be list containing
    Add "gs://" with message bucket_name with message "/" to parameters
    Add "--format=json" to parameters
    
    If prefix is not null:
        Set parameters[0] to "gs://" with message bucket_name with message "/" with message prefix with message "*"
    
    Let result be execute_gcp_command with service as "storage" and command as "objects list" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_storage_objects" and context as dictionary with:
            "bucket_name" as bucket_name,
            "prefix" as prefix,
            "error" as result["error"]
    
    Let objects_data be parse_json with json_string as result["output"]
    Let objects be list containing
    
    For each object_data in objects_data:
        Let storage_object be dictionary with:
            "name" as object_data["name"],
            "bucket" as bucket_name,
            "generation" as object_data["generation"],
            "metageneration" as object_data["metageneration"],
            "content_type" as object_data["contentType"],
            "size" as to_integer with value as object_data["size"],
            "md5_hash" as object_data["md5Hash"],
            "crc32c" as object_data["crc32c"],
            "etag" as object_data["etag"],
            "creation_time" as parse_gcp_timestamp with timestamp as object_data["timeCreated"],
            "updated_time" as parse_gcp_timestamp with timestamp as object_data["updated"],
            "storage_class" as object_data["storageClass"],
            "metadata" as (object_data["metadata"] if object_data contains key "metadata" otherwise dictionary containing),
            "cache_control" as (object_data["cacheControl"] if object_data contains key "cacheControl" otherwise null),
            "content_disposition" as (object_data["contentDisposition"] if object_data contains key "contentDisposition" otherwise null),
            "content_encoding" as (object_data["contentEncoding"] if object_data contains key "contentEncoding" otherwise null),
            "content_language" as (object_data["contentLanguage"] if object_data contains key "contentLanguage" otherwise null)
        Add storage_object to objects
    
    Return objects

Note: Upload object to Cloud Storage
Process called "upload_storage_object" that takes local_file_path as String and bucket_name as String and object_name as String and options as Dictionary[String, Any] returns GCPObject:
    Let parameters be list containing
    Add local_file_path to parameters
    Add "gs://" with message bucket_name with message "/" with message object_name to parameters
    Add "--format=json" to parameters
    
    Note: Add content type
    If options contains key "content_type":
        Add "--content-type=" with message options["content_type"] to parameters
    
    Note: Add cache control
    If options contains key "cache_control":
        Add "--cache-control=" with message options["cache_control"] to parameters
    
    Note: Add metadata
    If options contains key "metadata":
        For each key and value in options["metadata"]:
            Add "--custom-metadata=" with message key with message "=" with message value to parameters
    
    Let result be execute_gcp_command with service as "storage" and command as "objects cp" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "upload_storage_object" and context as dictionary with:
            "local_file_path" as local_file_path,
            "bucket_name" as bucket_name,
            "object_name" as object_name,
            "error" as result["error"]
    
    Note: Get the uploaded object details
    Return get_storage_object_details with bucket_name as bucket_name and object_name as object_name

Note: Download object from Cloud Storage
Process called "download_storage_object" that takes bucket_name as String and object_name as String and local_file_path as String returns Boolean:
    Let parameters be list containing
    Add "gs://" with message bucket_name with message "/" with message object_name to parameters
    Add local_file_path to parameters
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "storage" and command as "objects cp" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "download_storage_object" and context as dictionary with:
            "bucket_name" as bucket_name,
            "object_name" as object_name,
            "local_file_path" as local_file_path,
            "error" as result["error"]
    
    Return true

Note: Get Cloud Storage object details
Process called "get_storage_object_details" that takes bucket_name as String and object_name as String returns GCPObject:
    Let parameters be list containing
    Add "gs://" with message bucket_name with message "/" with message object_name to parameters
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "storage" and command as "objects describe" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "get_storage_object_details" and context as dictionary with:
            "bucket_name" as bucket_name,
            "object_name" as object_name,
            "error" as result["error"]
    
    Let object_data be parse_json with json_string as result["output"]
    
    Return dictionary with:
        "name" as object_data["name"],
        "bucket" as bucket_name,
        "generation" as object_data["generation"],
        "metageneration" as object_data["metageneration"],
        "content_type" as object_data["contentType"],
        "size" as to_integer with value as object_data["size"],
        "md5_hash" as object_data["md5Hash"],
        "crc32c" as object_data["crc32c"],
        "etag" as object_data["etag"],
        "creation_time" as parse_gcp_timestamp with timestamp as object_data["timeCreated"],
        "updated_time" as parse_gcp_timestamp with timestamp as object_data["updated"],
        "storage_class" as object_data["storageClass"],
        "metadata" as (object_data["metadata"] if object_data contains key "metadata" otherwise dictionary containing),
        "cache_control" as (object_data["cacheControl"] if object_data contains key "cacheControl" otherwise null),
        "content_disposition" as (object_data["contentDisposition"] if object_data contains key "contentDisposition" otherwise null),
        "content_encoding" as (object_data["contentEncoding"] if object_data contains key "contentEncoding" otherwise null),
        "content_language" as (object_data["contentLanguage"] if object_data contains key "contentLanguage" otherwise null)

Note: Delete Cloud Storage object
Process called "delete_storage_object" that takes bucket_name as String and object_name as String returns Boolean:
    Let parameters be list containing
    Add "gs://" with message bucket_name with message "/" with message object_name to parameters
    Add "--quiet" to parameters
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "storage" and command as "objects rm" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_storage_object" and context as dictionary with:
            "bucket_name" as bucket_name,
            "object_name" as object_name,
            "error" as result["error"]
    
    Return true

Note: List Cloud Functions
Process called "list_cloud_functions" that takes region as Optional[String] returns List[GCPCloudFunction]:
    Let parameters be list containing
    Add "--format=json" to parameters
    
    If region is not null:
        Add "--region=" with message region to parameters
    
    Let result be execute_gcp_command with service as "functions" and command as "list" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_cloud_functions" and context as dictionary with:
            "region" as region,
            "error" as result["error"]
    
    Let functions_data be parse_json with json_string as result["output"]
    Let functions be list containing
    
    For each function_data in functions_data:
        Let cloud_function be parse_cloud_function_info with function_data as function_data
        Add cloud_function to functions
    
    Return functions

Note: Parse Cloud Function information from GCP API response
Process called "parse_cloud_function_info" that takes function_data as Dictionary[String, Any] returns GCPCloudFunction:
    Let labels_dict be dictionary containing
    If function_data contains key "labels":
        Set labels_dict to function_data["labels"]
    
    Let env_vars be dictionary containing
    If function_data contains key "environmentVariables":
        Set env_vars to function_data["environmentVariables"]
    
    Return dictionary with:
        "name" as function_data["name"],
        "description" as (function_data["description"] if function_data contains key "description" otherwise ""),
        "source_archive_url" as (function_data["sourceArchive"] if function_data contains key "sourceArchive" otherwise null),
        "source_repository" as (function_data["sourceRepository"] if function_data contains key "sourceRepository" otherwise null),
        "source_upload_url" as (function_data["sourceUploadUrl"] if function_data contains key "sourceUploadUrl" otherwise null),
        "https_trigger" as (function_data["httpsTrigger"] if function_data contains key "httpsTrigger" otherwise null),
        "event_trigger" as (function_data["eventTrigger"] if function_data contains key "eventTrigger" otherwise null),
        "status" as function_data["status"],
        "entry_point" as function_data["entryPoint"],
        "runtime" as function_data["runtime"],
        "timeout" as function_data["timeout"],
        "available_memory_mb" as to_integer with value as function_data["availableMemoryMb"],
        "labels" as labels_dict,
        "environment_variables" as env_vars,
        "max_instances" as (to_integer with value as function_data["maxInstances"] if function_data contains key "maxInstances" otherwise 0),
        "vpc_connector" as (function_data["vpcConnector"] if function_data contains key "vpcConnector" otherwise null),
        "ingress_settings" as (function_data["ingressSettings"] if function_data contains key "ingressSettings" otherwise "ALLOW_ALL"),
        "service_account_email" as (function_data["serviceAccountEmail"] if function_data contains key "serviceAccountEmail" otherwise ""),
        "update_time" as parse_gcp_timestamp with timestamp as function_data["updateTime"],
        "version_id" as (function_data["versionId"] if function_data contains key "versionId" otherwise "1")

Note: Deploy Cloud Function
Process called "deploy_cloud_function" that takes function_name as String and region as String and runtime as String and trigger_type as String and source_path as String and options as Dictionary[String, Any] returns GCPCloudFunction:
    Let parameters be list containing
    Add function_name to parameters
    Add "--region=" with message region to parameters
    Add "--runtime=" with message runtime to parameters
    Add "--source=" with message source_path to parameters
    Add "--format=json" to parameters
    
    Note: Add trigger type
    If trigger_type is equal to "http":
        Add "--trigger-http" to parameters
    Else if trigger_type is equal to "pubsub":
        If options contains key "trigger_topic":
            Add "--trigger-topic=" with message options["trigger_topic"] to parameters
    Else if trigger_type is equal to "storage":
        If options contains key "trigger_bucket":
            Add "--trigger-bucket=" with message options["trigger_bucket"] to parameters
    
    Note: Add entry point
    If options contains key "entry_point":
        Add "--entry-point=" with message options["entry_point"] to parameters
    
    Note: Add memory
    If options contains key "memory":
        Add "--memory=" with message options["memory"] to parameters
    
    Note: Add timeout
    If options contains key "timeout":
        Add "--timeout=" with message options["timeout"] to parameters
    
    Note: Add environment variables
    If options contains key "env_vars":
        For each key and value in options["env_vars"]:
            Add "--set-env-vars=" with message key with message "=" with message value to parameters
    
    Note: Add service account
    If options contains key "service_account":
        Add "--service-account=" with message options["service_account"] to parameters
    
    Let result be execute_gcp_command with service as "functions" and command as "deploy" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "deploy_cloud_function" and context as dictionary with:
            "function_name" as function_name,
            "region" as region,
            "error" as result["error"]
    
    Note: Get the deployed function details
    Return get_cloud_function_details with function_name as function_name and region as region

Note: Get Cloud Function details
Process called "get_cloud_function_details" that takes function_name as String and region as String returns GCPCloudFunction:
    Let parameters be list containing
    Add function_name to parameters
    Add "--region=" with message region to parameters
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "functions" and command as "describe" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "get_cloud_function_details" and context as dictionary with:
            "function_name" as function_name,
            "region" as region,
            "error" as result["error"]
    
    Let function_data be parse_json with json_string as result["output"]
    Return parse_cloud_function_info with function_data as function_data

Note: Delete Cloud Function
Process called "delete_cloud_function" that takes function_name as String and region as String returns Boolean:
    Let parameters be list containing
    Add function_name to parameters
    Add "--region=" with message region to parameters
    Add "--quiet" to parameters
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "functions" and command as "delete" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "delete_cloud_function" and context as dictionary with:
            "function_name" as function_name,
            "region" as region,
            "error" as result["error"]
    
    Return true

Note: List Cloud SQL instances
Process called "list_sql_instances" returns List[GCPSQLInstance]:
    Let parameters be list containing
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "sql" and command as "instances list" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_sql_instances" and context as dictionary with:
            "error" as result["error"]
    
    Let instances_data be parse_json with json_string as result["output"]
    Let instances be list containing
    
    For each instance_data in instances_data:
        Let sql_instance be parse_sql_instance_info with instance_data as instance_data
        Add sql_instance to instances
    
    Return instances

Note: Parse Cloud SQL instance information from GCP API response
Process called "parse_sql_instance_info" that takes instance_data as Dictionary[String, Any] returns GCPSQLInstance:
    Let settings be instance_data["settings"]
    Let ip_addresses = list containing
    
    If instance_data contains key "ipAddresses":
        Set ip_addresses to instance_data["ipAddresses"]
    
    Return dictionary with:
        "name" as instance_data["name"],
        "database_version" as instance_data["databaseVersion"],
        "region" as instance_data["region"],
        "tier" as settings["tier"],
        "disk_size_gb" as to_integer with value as settings["dataDiskSizeGb"],
        "disk_type" as settings["dataDiskType"],
        "disk_autoresize" as settings["storageAutoResize"],
        "pricing_plan" as settings["pricingPlan"],
        "replication_type" as settings["replicationType"],
        "activation_policy" as settings["activationPolicy"],
        "authorized_gae_applications" as (settings["authorizedGaeApplications"] if settings contains key "authorizedGaeApplications" otherwise list containing),
        "authorized_networks" as (settings["ipConfiguration"]["authorizedNetworks"] if settings contains key "ipConfiguration" and settings["ipConfiguration"] contains key "authorizedNetworks" otherwise list containing),
        "backend_type" as instance_data["backendType"],
        "connection_name" as instance_data["connectionName"],
        "current_disk_size" as (to_integer with value as instance_data["currentDiskSize"] if instance_data contains key "currentDiskSize" otherwise null),
        "failover_replica" as (instance_data["failoverReplica"] if instance_data contains key "failoverReplica" otherwise null),
        "gce_zone" as instance_data["gceZone"],
        "instance_type" as instance_data["instanceType"],
        "ip_addresses" as ip_addresses,
        "ipv6_address" as (instance_data["ipv6Address"] if instance_data contains key "ipv6Address" otherwise null),
        "master_instance_name" as (instance_data["masterInstanceName"] if instance_data contains key "masterInstanceName" otherwise null),
        "max_disk_size" as (to_integer with value as instance_data["maxDiskSize"] if instance_data contains key "maxDiskSize" otherwise null),
        "on_premises_configuration" as (instance_data["onPremisesConfiguration"] if instance_data contains key "onPremisesConfiguration" otherwise null),
        "project" as instance_data["project"],
        "replica_names" as (instance_data["replicaNames"] if instance_data contains key "replicaNames" otherwise list containing),
        "self_link" as instance_data["selfLink"],
        "server_ca_cert" as instance_data["serverCaCert"],
        "service_account_email_address" as instance_data["serviceAccountEmailAddress"],
        "settings" as settings,
        "state" as instance_data["state"]

Note: Create Cloud SQL instance
Process called "create_sql_instance" that takes instance_name as String and database_version as String and tier as String and region as String and options as Dictionary[String, Any] returns GCPSQLInstance:
    Let parameters be list containing
    Add instance_name to parameters
    Add "--database-version=" with message database_version to parameters
    Add "--tier=" with message tier to parameters
    Add "--region=" with message region to parameters
    Add "--format=json" to parameters
    
    Note: Add root password
    If options contains key "root_password":
        Add "--root-password=" with message options["root_password"] to parameters
    
    Note: Add storage size
    If options contains key "storage_size":
        Add "--storage-size=" with message options["storage_size"] to parameters
    
    Note: Add storage type
    If options contains key "storage_type":
        Add "--storage-type=" with message options["storage_type"] to parameters
    
    Note: Add backup configuration
    If options contains key "backup_start_time":
        Add "--backup-start-time=" with message options["backup_start_time"] to parameters
    
    Note: Add maintenance window
    If options contains key "maintenance_release_channel":
        Add "--maintenance-release-channel=" with message options["maintenance_release_channel"] to parameters
    
    If options contains key "maintenance_window_day":
        Add "--maintenance-window-day=" with message options["maintenance_window_day"] to parameters
    
    If options contains key "maintenance_window_hour":
        Add "--maintenance-window-hour=" with message options["maintenance_window_hour"] to parameters
    
    Let result be execute_gcp_command with service as "sql" and command as "instances create" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "create_sql_instance" and context as dictionary with:
            "instance_name" as instance_name,
            "database_version" as database_version,
            "error" as result["error"]
    
    Note: Get the created instance details
    Return get_sql_instance_details with instance_name as instance_name

