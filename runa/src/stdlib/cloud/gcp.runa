Note: Deploy using Deployment Manager
Process called "deploy_deployment_manager" that takes deployment_name as String and config_file as String and properties as Optional[Dictionary[String, String]] returns Dictionary[String, Any]:
    Let parameters be list containing
    Add deployment_name to parameters
    Add "--config=" with message config_file to parameters
    Add "--format=json" to parameters
    
    Note: Add properties
    If properties is not null:
        For each key and value in properties:
            Add "--properties=" with message key with message ":" with message value to parameters
    
    Let result be execute_gcp_command with service as "deployment-manager" and command as "deployments create" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "deploy_deployment_manager" and context as dictionary with:
            "deployment_name" as deployment_name,
            "config_file" as config_file,
            "error" as result["error"]
    
    Let deployment_data be parse_json with json_string as result["output"]
    Return dictionary with:
        "deployment_name" as deployment_data["name"],
        "description" as (deployment_data["description"] if deployment_data contains key "description" otherwise ""),
        "fingerprint" as deployment_data["fingerprint"],
        "id" as deployment_data["id"],
        "insert_time" as deployment_data["insertTime"],
        "manifest" as deployment_data["manifest"],
        "operation" as deployment_data["operation"],
        "self_link" as deployment_data["selfLink"],
        "target" as deployment_data["target"]

