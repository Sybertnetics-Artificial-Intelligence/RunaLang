    feature_settings as Dictionary[String, Any]

Note: Execute gcloud command with error handling
Process called "execute_gcp_command" that takes service as String and command as String and parameters as List[String] returns Dictionary[String, Any]:
    Try:
        Let full_command be "gcloud " with message service with message " " with message command
        For each param in parameters:
            Set full_command to full_command with message " " with message param
        
        Let result be execute_command with command as full_command
        
        If result["exit_code"] is not equal to 0:
            Throw create_runtime_error with operation as "gcp_command" and context as dictionary with:
                "service" as service,
                "command" as command,
                "parameters" as parameters,
                "exit_code" as result["exit_code"],
                "error_output" as result["stderr"]
        
        Return dictionary with:
            "success" as true,
            "output" as result["stdout"],
            "service" as service,
            "command" as command
    
    Catch error:
        Return dictionary with:
            "success" as false,
            "error" as error["message"],
            "service" as service,
            "command" as command

Note: Configure GCP authentication and project
Process called "configure_gcp" that takes project_id as String and service_account_key as Optional[String] returns Boolean:
    Note: Set the project
    Let project_command be "gcloud config set project " with message project_id
    Let result be execute_command with command as project_command
    
    If result["exit_code"] is not equal to 0:
        Throw create_runtime_error with operation as "configure_gcp" and context as dictionary with:
            "project_id" as project_id,
            "error" as result["stderr"]
    
    Note: Authenticate with service account if provided
    If service_account_key is not null:
        Let auth_command be "gcloud auth activate-service-account --key-file=" with message service_account_key
        Let auth_result be execute_command with command as auth_command
        If auth_result["exit_code"] is not equal to 0:
            Throw create_runtime_error with operation as "configure_gcp" and context as dictionary with:
                "service_account_key" as service_account_key,
                "error" as auth_result["stderr"]
    
    Return true

Note: List Compute Engine instances
Process called "list_compute_instances" that takes zone as Optional[String] returns List[GCPInstance]:
    Let parameters be list containing
    Add "--format=json" to parameters
    
    If zone is not null:
        Add "--zones=" with message zone to parameters
    
    Let result be execute_gcp_command with service as "compute" and command as "instances list" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "list_compute_instances" and context as dictionary with:
            "zone" as zone,
            "error" as result["error"]
    
    Let instances_data be parse_json with json_string as result["output"]
    Let instances be list containing
    
    For each instance_data in instances_data:
        Let instance be parse_compute_instance_info with instance_data as instance_data
        Add instance to instances
    
    Return instances

Note: Parse Compute Engine instance information from GCP API response
Process called "parse_compute_instance_info" that takes instance_data as Dictionary[String, Any] returns GCPInstance:
    Let internal_ip be ""
    Let external_ip be null
    Let network_interfaces be list containing
    
    If instance_data contains key "networkInterfaces":
        For each ni in instance_data["networkInterfaces"]:
            Set internal_ip to ni["networkIP"]
            If ni contains key "accessConfigs":
                For each access_config in ni["accessConfigs"]:
                    If access_config contains key "natIP":
                        Set external_ip to access_config["natIP"]
            Add ni to network_interfaces
    
    Let disks_list be list containing
    If instance_data contains key "disks":
        For each disk in instance_data["disks"]:
            Add disk to disks_list
    
    Let metadata_dict be dictionary containing
    If instance_data contains key "metadata" and instance_data["metadata"] contains key "items":
        For each item in instance_data["metadata"]["items"]:
            Set metadata_dict[item["key"]] to item["value"]
    
    Let labels_dict be dictionary containing
    If instance_data contains key "labels":
        Set labels_dict to instance_data["labels"]
    
    Let service_accounts_list be list containing
    If instance_data contains key "serviceAccounts":
        For each sa in instance_data["serviceAccounts"]:
            Add sa to service_accounts_list
    
    Return dictionary with:
        "instance_id" as instance_data["id"],
        "name" as instance_data["name"],
        "zone" as extract_zone_from_url with zone_url as instance_data["zone"],
        "machine_type" as extract_machine_type_from_url with machine_type_url as instance_data["machineType"],
        "status" as instance_data["status"],
        "internal_ip" as internal_ip,
        "external_ip" as external_ip,
        "network_interfaces" as network_interfaces,
        "disks" as disks_list,
        "metadata" as metadata_dict,
        "labels" as labels_dict,
        "service_accounts" as service_accounts_list,
        "creation_timestamp" as parse_gcp_timestamp with timestamp as instance_data["creationTimestamp"],
        "last_start_timestamp" as (parse_gcp_timestamp with timestamp as instance_data["lastStartTimestamp"] if instance_data contains key "lastStartTimestamp" otherwise null),
        "can_ip_forward" as instance_data["canIpForward"],
        "scheduling" as instance_data["scheduling"]

Note: Create Compute Engine instance
Process called "create_compute_instance" that takes instance_name as String and zone as String and machine_type as String and image as String and options as Dictionary[String, Any] returns GCPInstance:
    Let parameters be list containing
    Add instance_name to parameters
    Add "--zone=" with message zone to parameters
    Add "--machine-type=" with message machine_type to parameters
    Add "--image=" with message image to parameters
    Add "--format=json" to parameters
    
    Note: Add boot disk size
    If options contains key "boot_disk_size":
        Add "--boot-disk-size=" with message options["boot_disk_size"] to parameters
    
    Note: Add boot disk type
    If options contains key "boot_disk_type":
        Add "--boot-disk-type=" with message options["boot_disk_type"] to parameters
    
    Note: Add network configuration
    If options contains key "subnet":
        Add "--subnet=" with message options["subnet"] to parameters
    
    If options contains key "no_external_ip" and options["no_external_ip"]:
        Add "--no-address" to parameters
    
    Note: Add service account
    If options contains key "service_account":
        Add "--service-account=" with message options["service_account"] to parameters
    
    Note: Add scopes
    If options contains key "scopes":
        Let scopes_string be join_list with list as options["scopes"] and separator as ","
        Add "--scopes=" with message scopes_string to parameters
    
    Note: Add labels
    If options contains key "labels":
        Let labels_list be list containing
        For each key and value in options["labels"]:
            Add key with message "=" with message value to labels_list
        Let labels_string be join_list with list as labels_list and separator as ","
        Add "--labels=" with message labels_string to parameters
    
    Note: Add metadata
    If options contains key "metadata":
        Let metadata_list be list containing
        For each key and value in options["metadata"]:
            Add key with message "=" with message value to metadata_list
        Let metadata_string be join_list with list as metadata_list and separator as ","
        Add "--metadata=" with message metadata_string to parameters
    
    Note: Add startup script
    If options contains key "startup_script":
        Add "--metadata-from-file=startup-script=" with message options["startup_script"] to parameters
    
    Let result be execute_gcp_command with service as "compute" and command as "instances create" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "create_compute_instance" and context as dictionary with:
            "instance_name" as instance_name,
            "zone" as zone,
            "error" as result["error"]
    
    Note: Get the created instance details
    Return get_compute_instance_details with instance_name as instance_name and zone as zone

Note: Get Compute Engine instance details
Process called "get_compute_instance_details" that takes instance_name as String and zone as String returns GCPInstance:
    Let parameters be list containing
    Add instance_name to parameters
    Add "--zone=" with message zone to parameters
    Add "--format=json" to parameters
    
    Let result be execute_gcp_command with service as "compute" and command as "instances describe" and parameters as parameters
    If not result["success"]:
        Throw create_runtime_error with operation as "get_compute_instance_details" and context as dictionary with:
            "instance_name" as instance_name,
            "zone" as zone,
            "error" as result["error"]
    
    Let instance_data be parse_json with json_string as result["output"]
    Return parse_compute_instance_info with instance_data as instance_data

Note: Start Compute Engine instance
Process called "start_compute_instance" that takes instance_name as String and zone as String returns Boolean:
    Let parameters be list containing
    Add instance_name to parameters
