Note:
Runa Standard Library: Telemetry

Production-grade telemetry system providing comprehensive observability,
distributed tracing, and performance monitoring capabilities.

Features:
- Distributed tracing with span management
- Performance metrics collection and analysis
- Event logging and correlation
- Resource utilization monitoring
- Integration with OpenTelemetry standards
- Automatic instrumentation and context propagation
:End Note

Import "metrics/collectors" as Collectors
Import "metrics/prometheus" as Prometheus
Import "metrics/statsd" as StatsD

Note: Core telemetry types and structures
Type called "TelemetryConfig":
    service_name as String
    service_version as String
    environment as String
    sample_rate as Float
    enable_metrics as Boolean
    enable_tracing as Boolean
    enable_logging as Boolean
    resource_labels as Dictionary[String, String]

Type called "Span":
    span_id as String
    trace_id as String
    parent_span_id as String
    operation_name as String
    start_time as Float
    end_time as Float
    duration as Float
    tags as Dictionary[String, String]
    logs as List[SpanLog]
    status as SpanStatus
    baggage as Dictionary[String, String]

Type SpanStatus is:
    | OK
    | Cancelled
    | Unknown
    | InvalidArgument
    | DeadlineExceeded
    | NotFound
    | AlreadyExists
    | PermissionDenied
    | ResourceExhausted
    | FailedPrecondition
    | Aborted
    | OutOfRange
    | Unimplemented
    | Internal
    | Unavailable
    | DataLoss

Type called "SpanLog":
    timestamp as Float
    level as String
    message as String
    fields as Dictionary[String, Any]

Type called "TelemetryContext":
    trace_id as String
    span_id as String
    baggage as Dictionary[String, String]
    correlation_id as String

Type called "MetricEvent":
    timestamp as Float
    name as String
    value as Float
    metric_type as String
    labels as Dictionary[String, String]
    context as TelemetryContext

Type called "TelemetryExporter":
    name as String
    endpoint as String
    headers as Dictionary[String, String]
    batch_size as Integer
    timeout as Float

Note: Global telemetry configuration and context
Let telemetry_config be TelemetryConfig with:
    service_name as "runa-application"
    service_version as "1.0.0"
    environment as "development"
    sample_rate as 1.0
    enable_metrics as true
    enable_tracing as true
    enable_logging as true
    resource_labels as dictionary

Let active_spans be Dictionary[String, Span]
Let span_stack be List[Span]
Let telemetry_exporters be List[TelemetryExporter]
Let global_baggage be Dictionary[String, String]

Note: Telemetry initialization and configuration
Process called "configure_telemetry" that takes config as TelemetryConfig:
    Set telemetry_config to config
    setup_resource_labels with config as config
    initialize_exporters with config as config

Process called "set_service_info" that takes name as String and version as String and environment as String:
    Set telemetry_config.service_name to name
    Set telemetry_config.service_version to version
    Set telemetry_config.environment to environment

Process called "add_resource_label" that takes key as String and value as String:
    Set telemetry_config.resource_labels[key] to value

Process called "setup_resource_labels" that takes config as TelemetryConfig:
    add_resource_label with key as "service.name" and value as config.service_name
    add_resource_label with key as "service.version" and value as config.service_version
    add_resource_label with key as "deployment.environment" and value as config.environment

Note: Span management and distributed tracing
Process called "start_span" that takes operation_name as String returns Span:
    Return start_span_with_parent with operation_name as operation_name and parent as get_active_span()

Process called "start_span_with_parent" that takes operation_name as String and parent as Optional[Span] returns Span:
    Let trace_id be generate_trace_id()
    Let parent_span_id be ""
    If parent is not None:
        Let parent_span be parent as Span
        Set trace_id to parent_span.trace_id
        Set parent_span_id to parent_span.span_id
    Let span be Span with:
        span_id as generate_span_id()
        trace_id as trace_id
        parent_span_id as parent_span_id
        operation_name as operation_name
        start_time as get_current_time()
        end_time as 0.0
        duration as 0.0
        tags as dictionary
        logs as list
        status as OK
        baggage as copy_baggage with baggage as global_baggage
    Set active_spans[span.span_id] to span
    Add span to span_stack
    Return span

Process called "finish_span" that takes span as Span:
    Set span.end_time to get_current_time()
    Set span.duration to span.end_time - span.start_time
    Remove active_spans[span.span_id]
    If List.length with lst as span_stack is greater than 0:
        Let last_span be List.last with lst as span_stack
        If last_span.span_id is equal to span.span_id:
            List.pop with lst as span_stack
    export_span with span as span

Process called "get_active_span" returns Optional[Span]:
    If List.length with lst as span_stack is greater than 0:
        Return Some(List.last with lst as span_stack)
    Return None

Process called "add_span_tag" that takes span as Span and key as String and value as String:
    Set span.tags[key] to value

Process called "add_span_log" that takes span as Span and level as String and message as String:
    add_span_log_with_fields with span as span and level as level and message as message and fields as dictionary

Process called "add_span_log_with_fields" that takes span as Span and level as String and message as String and fields as Dictionary[String, Any]:
    Let log_entry be SpanLog with:
        timestamp as get_current_time()
        level as level
        message as message
        fields as fields
    Add log_entry to span.logs

Process called "set_span_status" that takes span as Span and status as SpanStatus:
    Set span.status to status

Note: Context management and propagation
Process called "extract_context" that takes headers as Dictionary[String, String] returns TelemetryContext:
    Let trace_id be headers.get("x-trace-id", "")
    Let span_id be headers.get("x-span-id", "")
    Let correlation_id be headers.get("x-correlation-id", "")
    Let baggage_header be headers.get("baggage", "")
    Let baggage be parse_baggage with baggage_string as baggage_header
    Return TelemetryContext with:
        trace_id as trace_id
        span_id as span_id
        baggage as baggage
        correlation_id as correlation_id

Process called "inject_context" that takes context as TelemetryContext and headers as Dictionary[String, String]:
    Set headers["x-trace-id"] to context.trace_id
    Set headers["x-span-id"] to context.span_id
    Set headers["x-correlation-id"] to context.correlation_id
    Set headers["baggage"] to serialize_baggage with baggage as context.baggage

Process called "get_current_context" returns TelemetryContext:
    Let active_span_opt be get_active_span()
    If active_span_opt is not None:
        Let active_span be active_span_opt as Span
        Return TelemetryContext with:
            trace_id as active_span.trace_id
            span_id as active_span.span_id
            baggage as active_span.baggage
            correlation_id as generate_correlation_id()
    Return TelemetryContext with:
        trace_id as ""
        span_id as ""
        baggage as dictionary
        correlation_id as ""

Process called "set_baggage" that takes key as String and value as String:
    Set global_baggage[key] to value
    Let active_span_opt be get_active_span()
    If active_span_opt is not None:
        Let active_span be active_span_opt as Span
        Set active_span.baggage[key] to value

Process called "get_baggage" that takes key as String returns Optional[String]:
    If key is in global_baggage:
        Return Some(global_baggage[key])
    Return None

Note: Metric events and instrumentation
Process called "record_metric_event" that takes name as String and value as Float and metric_type as String:
    record_metric_event_with_labels with name as name and value as value and metric_type as metric_type and labels as dictionary

Process called "record_metric_event_with_labels" that takes name as String and value as Float and metric_type as String and labels as Dictionary[String, String]:
    Let context be get_current_context()
    Let event be MetricEvent with:
        timestamp as get_current_time()
        name as name
        value as value
        metric_type as metric_type
        labels as merge_labels with base_labels as telemetry_config.resource_labels and additional_labels as labels
        context as context
    export_metric_event with event as event

Process called "time_operation" that takes operation_name as String and operation as Process returns Any:
    Let span be start_span with operation_name as operation_name
    Let start_time be get_current_time()
    Try:
        Let result be operation()
        set_span_status with span as span and status as OK
        Return result
    Catch error:
        set_span_status with span as span and status as Internal
        add_span_log with span as span and level as "ERROR" and message as String.from with value as error
        Throw error
    Finally:
        Let end_time be get_current_time()
        Let duration be end_time - start_time
        add_span_tag with span as span and key as "duration_ms" and value as String.from with value as duration multiplied by 1000.0
        finish_span with span as span

Process called "instrument_function" that takes function_name as String and func as Process returns Process:
    Process called "instrumented_wrapper" that takes args as List[Any] returns Any:
        Return time_operation with operation_name as function_name and operation as lambda: func with args as args
    Return instrumented_wrapper

Note: Performance monitoring
Type called "PerformanceMetrics":
    cpu_usage as Float
    memory_usage as Integer
    heap_size as Integer
    gc_collections as Integer
    thread_count as Integer
    active_connections as Integer

Process called "collect_performance_metrics" returns PerformanceMetrics:
    Return PerformanceMetrics with:
        cpu_usage as get_cpu_usage()
        memory_usage as get_memory_usage()
        heap_size as get_heap_size()
        gc_collections as get_gc_collections()
        thread_count as get_thread_count()
        active_connections as get_active_connections()

Process called "start_performance_monitoring" that takes interval as Float:
    Let monitoring_task be create_performance_monitoring_task with interval as interval
    start_background_task with task as monitoring_task

Process called "create_performance_monitoring_task" that takes interval as Float returns Process:
    Process called "performance_monitoring_task":
        While true:
            Let metrics be collect_performance_metrics()
            record_metric_event with name as "system.cpu.usage" and value as metrics.cpu_usage and metric_type as "gauge"
            record_metric_event with name as "system.memory.usage" and value as Float.from with value as metrics.memory_usage and metric_type as "gauge"
            record_metric_event with name as "system.heap.size" and value as Float.from with value as metrics.heap_size and metric_type as "gauge"
            record_metric_event with name as "system.gc.collections" and value as Float.from with value as metrics.gc_collections and metric_type as "counter"
            record_metric_event with name as "system.threads.count" and value as Float.from with value as metrics.thread_count and metric_type as "gauge"
            record_metric_event with name as "system.connections.active" and value as Float.from with value as metrics.active_connections and metric_type as "gauge"
            sleep with seconds as interval
    Return performance_monitoring_task

Note: Export and integration
Process called "add_exporter" that takes exporter as TelemetryExporter:
    Add exporter to telemetry_exporters

Process called "export_span" that takes span as Span:
    If not telemetry_config.enable_tracing:
        Return
    For each exporter in telemetry_exporters:
        export_span_to_exporter with span as span and exporter as exporter

Process called "export_metric_event" that takes event as MetricEvent:
    If not telemetry_config.enable_metrics:
        Return
    Note: Export to integrated metrics systems
    Match event.metric_type:
        When "counter":
            Collectors.increment_counter_with_labels with collector_name as "telemetry" and metric_name as event.name and value as event.value and labels as event.labels
        When "gauge":
            Collectors.set_gauge_with_labels with collector_name as "telemetry" and metric_name as event.name and value as event.value and labels as event.labels
        When "histogram":
            Collectors.record_histogram_with_labels with collector_name as "telemetry" and metric_name as event.name and value as event.value and labels as event.labels

Process called "export_span_to_exporter" that takes span as Span and exporter as TelemetryExporter:
    Try:
    Let span_data be serialize_span with span as span
    send_to_exporter with data as span_data and exporter as exporter
    Catch error:
    add_span_log with span as span and level as "ERROR" and message as "Failed to export span: " followed by String.from with value as error

Process called "serialize_span" that takes span as Span returns String:
    Let span_json be dictionary with:
        "spanId" as span.span_id
        "traceId" as span.trace_id
        "parentSpanId" as span.parent_span_id
        "operationName" as span.operation_name
        "startTime" as span.start_time
        "endTime" as span.end_time
        "duration" as span.duration
        "tags" as span.tags
        "status" as span_status_to_string with status as span.status
    Return json_stringify with data as span_json

Note: Utility functions for trace and span ID generation
Process called "generate_trace_id" returns String:
    Return generate_hex_id with length as 32

Process called "generate_span_id" returns String:
    Return generate_hex_id with length as 16

Process called "generate_correlation_id" returns String:
    Return generate_hex_id with length as 16

Process called "generate_hex_id" that takes length as Integer returns String:
    Let hex_chars be "0123456789abcdef"
    Let result be ""
    For i from 0 to length - 1:
        Let random_index be get_random_int with max as 16
        Let char be String.char_at with str as hex_chars and index as random_index
        Set result to result followed by char
    Return result

Process called "copy_baggage" that takes baggage as Dictionary[String, String] returns Dictionary[String, String]:
    Let copied be dictionary
    For each key and value in baggage:
        Set copied[key] to value
    Return copied

Process called "parse_baggage" that takes baggage_string as String returns Dictionary[String, String]:
    Let baggage be dictionary
    Let pairs be String.split with str as baggage_string and separator as ","
    For each pair in pairs:
        Let trimmed_pair be String.trim with str as pair
        If String.length with str as trimmed_pair is greater than 0:
            Let key_value be String.split with str as trimmed_pair and separator as "="
            If List.length with lst as key_value is equal to 2:
                Let key be String.trim with str as List.get with lst as key_value and index as 0
                Let value be String.trim with str as List.get with lst as key_value and index as 1
                Set baggage[key] to value
    Return baggage

Process called "serialize_baggage" that takes baggage as Dictionary[String, String] returns String:
    Let baggage_pairs be list
    For each key and value in baggage:
        Add key followed by "=" followed by value to baggage_pairs
    Return String.join with parts as baggage_pairs and separator as ","

Process called "merge_labels" that takes base_labels as Dictionary[String, String] and additional_labels as Dictionary[String, String] returns Dictionary[String, String]:
    Let merged be dictionary
    For each key and value in base_labels:
        Set merged[key] to value
    For each key and value in additional_labels:
        Set merged[key] to value
    Return merged

Process called "span_status_to_string" that takes status as SpanStatus returns String:
    Match status:
        When OK:
            Return "OK"
        When Cancelled:
            Return "CANCELLED"
        When Unknown:
            Return "UNKNOWN"
        When InvalidArgument:
            Return "INVALID_ARGUMENT"
        When DeadlineExceeded:
            Return "DEADLINE_EXCEEDED"
        When NotFound:
            Return "NOT_FOUND"
        When AlreadyExists:
            Return "ALREADY_EXISTS"
        When PermissionDenied:
            Return "PERMISSION_DENIED"
        When ResourceExhausted:
            Return "RESOURCE_EXHAUSTED"
        When FailedPrecondition:
            Return "FAILED_PRECONDITION"
        When Aborted:
            Return "ABORTED"
        When OutOfRange:
            Return "OUT_OF_RANGE"
        When Unimplemented:
            Return "UNIMPLEMENTED"
        When Internal:
            Return "INTERNAL"
        When Unavailable:
            Return "UNAVAILABLE"
        When DataLoss:
            Return "DATA_LOSS"

Note: System metrics collection utilities
Process called "get_cpu_usage" returns Float:
    Note: Would return current CPU usage percentage
    Return 15.5

Process called "get_memory_usage" returns Integer:
    Note: Would return current memory usage in bytes
    Return 134217728

Process called "get_heap_size" returns Integer:
    Note: Would return current heap size in bytes
    Return 67108864

Process called "get_gc_collections" returns Integer:
    Note: Would return total GC collection count
    Return 42

Process called "get_thread_count" returns Integer:
    Note: Would return active thread count
    Return 8

Process called "get_active_connections" returns Integer:
    Note: Would return active network connection count
    Return 12

Process called "get_current_time" returns Float:
    Note: Would return high-precision timestamp
    Return 0.0

Process called "get_random_int" that takes max as Integer returns Integer:
    Note: Would return random integer from 0 to max-1
    Return 7

Process called "sleep" that takes seconds as Float:
    Note: Would pause execution for specified seconds
    pass

Process called "start_background_task" that takes task as Process:
    Note: Would start task in background thread
    pass

Process called "json_stringify" that takes data as Dictionary[String, Any] returns String:
    Note: Would serialize dictionary to JSON string
    Return "{}"

Process called "send_to_exporter" that takes data as String and exporter as TelemetryExporter:
    Note: Would send data to external telemetry system
    pass

Note: Initialize telemetry system
Process called "initialize_telemetry":
    configure_telemetry with config as telemetry_config
    Collectors.create_collector with name as "telemetry"
    start_performance_monitoring with interval as 30.0