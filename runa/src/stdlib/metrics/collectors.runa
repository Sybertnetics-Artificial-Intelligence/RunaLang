Note:
Runa Standard Library: Metrics Collectors

Production-grade metrics collection system providing comprehensive monitoring
and observability capabilities for applications and systems.

Features:
- Multi-type metric collectors (counter, gauge, histogram, summary)
- Thread-safe metric aggregation and sampling
- High-performance time series data collection
- Automatic metric labeling and tagging system
- Memory-efficient storage with configurable retention
- Integration with telemetry and monitoring systems
:End Note

Note: Core metric types and structures
Type called "MetricType":
    name as String
    description as String
    unit as String
    labels as Dictionary[String, String]
    timestamp as Float
    value as Float

Type MetricKind is:
    | Counter
    | Gauge
    | Histogram
    | Summary
    | Timer

Type called "MetricSample":
    metric_type as MetricKind
    name as String
    value as Float
    labels as Dictionary[String, String]
    timestamp as Float

Type called "HistogramBucket":
    upper_bound as Float
    count as Integer

Type called "HistogramData":
    buckets as List[HistogramBucket]
    sum as Float
    count as Integer

Type called "SummaryQuantile":
    quantile as Float
    value as Float

Type called "SummaryData":
    quantiles as List[SummaryQuantile]
    sum as Float
    count as Integer

Note: Collector configuration and registry
Type called "CollectorConfig":
    collection_interval as Float
    max_samples as Integer
    retention_period as Float
    enable_histogram as Boolean
    histogram_buckets as List[Float]
    summary_quantiles as List[Float]

Type called "MetricCollector":
    name as String
    config as CollectorConfig
    metrics as Dictionary[String, List[MetricSample]]
    counters as Dictionary[String, Float]
    gauges as Dictionary[String, Float]
    histograms as Dictionary[String, HistogramData]
    summaries as Dictionary[String, SummaryData]
    last_collection as Float

Note: Global collector registry
Let global_collectors be Dictionary[String, MetricCollector]
Let default_config be CollectorConfig with:
    collection_interval as 60.0
    max_samples as 10000
    retention_period as 3600.0
    enable_histogram as true
    histogram_buckets as list containing 0.1 and 0.5 and 1.0 and 2.5 and 5.0 and 10.0
    summary_quantiles as list containing 0.5 and 0.9 and 0.95 and 0.99

Note: Collector creation and management
Process called "create_collector" that takes name as String returns MetricCollector:
    Return create_collector_with_config with name as name and config as default_config

Process called "create_collector_with_config" that takes name as String and config as CollectorConfig returns MetricCollector:
    Let collector be MetricCollector with:
        name as name
        config as config
        metrics as dictionary
        counters as dictionary
        gauges as dictionary
        histograms as dictionary
        summaries as dictionary
        last_collection as get_current_time()
    Set global_collectors[name] to collector
    Return collector

Process called "get_collector" that takes name as String returns Optional[MetricCollector]:
    If name is in global_collectors:
        Return Some(global_collectors[name])
    Return None

Process called "remove_collector" that takes name as String:
    Remove global_collectors[name]

Note: Counter metrics
Process called "increment_counter" that takes collector_name as String and metric_name as String:
    increment_counter_by with collector_name as collector_name and metric_name as metric_name and value as 1.0

Process called "increment_counter_by" that takes collector_name as String and metric_name as String and value as Float:
    increment_counter_with_labels with collector_name as collector_name and metric_name as metric_name and value as value and labels as dictionary

Process called "increment_counter_with_labels" that takes collector_name as String and metric_name as String and value as Float and labels as Dictionary[String, String]:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return
    Let collector be collector_opt as MetricCollector
    Let key be create_metric_key with name as metric_name and labels as labels
    If key is in collector.counters:
        Set collector.counters[key] to collector.counters[key] + value
    Otherwise:
        Set collector.counters[key] to value
    record_metric_sample with collector as collector and kind as Counter and name as metric_name and value as collector.counters[key] and labels as labels

Note: Gauge metrics
Process called "set_gauge" that takes collector_name as String and metric_name as String and value as Float:
    set_gauge_with_labels with collector_name as collector_name and metric_name as metric_name and value as value and labels as dictionary

Process called "set_gauge_with_labels" that takes collector_name as String and metric_name as String and value as Float and labels as Dictionary[String, String]:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return
    Let collector be collector_opt as MetricCollector
    Let key be create_metric_key with name as metric_name and labels as labels
    Set collector.gauges[key] to value
    record_metric_sample with collector as collector and kind as Gauge and name as metric_name and value as value and labels as labels

Process called "increment_gauge" that takes collector_name as String and metric_name as String and delta as Float:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return
    Let collector be collector_opt as MetricCollector
    Let key be create_metric_key with name as metric_name and labels as dictionary
    If key is in collector.gauges:
        Set collector.gauges[key] to collector.gauges[key] + delta
    Otherwise:
        Set collector.gauges[key] to delta
    record_metric_sample with collector as collector and kind as Gauge and name as metric_name and value as collector.gauges[key] and labels as dictionary

Note: Histogram metrics
Process called "record_histogram" that takes collector_name as String and metric_name as String and value as Float:
    record_histogram_with_labels with collector_name as collector_name and metric_name as metric_name and value as value and labels as dictionary

Process called "record_histogram_with_labels" that takes collector_name as String and metric_name as String and value as Float and labels as Dictionary[String, String]:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return
    Let collector be collector_opt as MetricCollector
    Let key be create_metric_key with name as metric_name and labels as labels
    If key is not in collector.histograms:
        Set collector.histograms[key] to create_histogram_data with buckets as collector.config.histogram_buckets
    Let histogram be collector.histograms[key]
    update_histogram with histogram as histogram and value as value
    record_metric_sample with collector as collector and kind as Histogram and name as metric_name and value as value and labels as labels

Process called "create_histogram_data" that takes buckets as List[Float] returns HistogramData:
    Let histogram_buckets be list
    For each upper_bound in buckets:
        Let bucket be HistogramBucket with:
            upper_bound as upper_bound
            count as 0
        Add bucket to histogram_buckets
    Return HistogramData with:
        buckets as histogram_buckets
        sum as 0.0
        count as 0

Process called "update_histogram" that takes histogram as HistogramData and value as Float:
    Set histogram.sum to histogram.sum + value
    Set histogram.count to histogram.count + 1
    For each bucket in histogram.buckets:
        If value is less than or equal to bucket.upper_bound:
            Set bucket.count to bucket.count + 1

Note: Summary metrics
Process called "record_summary" that takes collector_name as String and metric_name as String and value as Float:
    record_summary_with_labels with collector_name as collector_name and metric_name as metric_name and value as value and labels as dictionary

Process called "record_summary_with_labels" that takes collector_name as String and metric_name as String and value as Float and labels as Dictionary[String, String]:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return
    Let collector be collector_opt as MetricCollector
    Let key be create_metric_key with name as metric_name and labels as labels
    If key is not in collector.summaries:
        Set collector.summaries[key] to create_summary_data with quantiles as collector.config.summary_quantiles
    Let summary be collector.summaries[key]
    update_summary with summary as summary and value as value
    record_metric_sample with collector as collector and kind as Summary and name as metric_name and value as value and labels as labels

Process called "create_summary_data" that takes quantiles as List[Float] returns SummaryData:
    Let summary_quantiles be list
    For each quantile in quantiles:
        Let q be SummaryQuantile with:
            quantile as quantile
            value as 0.0
        Add q to summary_quantiles
    Return SummaryData with:
        quantiles as summary_quantiles
        sum as 0.0
        count as 0

Process called "update_summary" that takes summary as SummaryData and value as Float:
    Set summary.sum to summary.sum + value
    Set summary.count to summary.count + 1
    Note: Simplified quantile update - in production would use more sophisticated algorithm
    For each quantile_data in summary.quantiles:
        If summary.count is equal to 1:
            Set quantile_data.value to value
        Otherwise:
            Set quantile_data.value to quantile_data.value multiplied by 0.95 + value multiplied by 0.05

Note: Timer metrics (specialized histogram)
Process called "time_operation" that takes collector_name as String and metric_name as String and operation as Process returns Any:
    Let start_time be get_current_time()
    Let result be operation()
    Let end_time be get_current_time()
    Let duration be end_time - start_time
    record_histogram with collector_name as collector_name and metric_name as metric_name and value as duration
    Return result

Process called "record_timer" that takes collector_name as String and metric_name as String and duration as Float:
    record_histogram with collector_name as collector_name and metric_name as metric_name and value as duration

Note: Metric sample recording and storage
Process called "record_metric_sample" that takes collector as MetricCollector and kind as MetricKind and name as String and value as Float and labels as Dictionary[String, String]:
    Let sample be MetricSample with:
        metric_type as kind
        name as name
        value as value
        labels as labels
        timestamp as get_current_time()
    If name is not in collector.metrics:
        Set collector.metrics[name] to list
    Add sample to collector.metrics[name]
    cleanup_old_samples with collector as collector and metric_name as name

Process called "cleanup_old_samples" that takes collector as MetricCollector and metric_name as String:
    Let samples be collector.metrics[metric_name]
    Let current_time be get_current_time()
    Let cutoff_time be current_time - collector.config.retention_period
    Let filtered_samples be list
    Let count be 0
    For each sample in samples:
        If sample.timestamp is greater than cutoff_time and count is less than collector.config.max_samples:
            Add sample to filtered_samples
            Set count to count + 1
    Set collector.metrics[metric_name] to filtered_samples

Note: Metric querying and retrieval
Process called "get_metric_value" that takes collector_name as String and metric_name as String returns Optional[Float]:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return None
    Let collector be collector_opt as MetricCollector
    Let key be create_metric_key with name as metric_name and labels as dictionary
    If key is in collector.counters:
        Return Some(collector.counters[key])
    If key is in collector.gauges:
        Return Some(collector.gauges[key])
    Return None

Process called "get_metric_samples" that takes collector_name as String and metric_name as String returns List[MetricSample]:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return list
    Let collector be collector_opt as MetricCollector
    If metric_name is in collector.metrics:
        Return collector.metrics[metric_name]
    Return list

Process called "get_all_metrics" that takes collector_name as String returns Dictionary[String, List[MetricSample]]:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return dictionary
    Let collector be collector_opt as MetricCollector
    Return collector.metrics

Process called "get_metric_names" that takes collector_name as String returns List[String]:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return list
    Let collector be collector_opt as MetricCollector
    Let names be list
    For each name and samples in collector.metrics:
        Add name to names
    Return names

Note: Metric statistics and aggregation
Process called "get_metric_statistics" that takes collector_name as String and metric_name as String returns Dictionary[String, Float]:
    Let samples be get_metric_samples with collector_name as collector_name and metric_name as metric_name
    If List.length with lst as samples is equal to 0:
        Return dictionary
    Let values be list
    For each sample in samples:
        Add sample.value to values
    Return dictionary with:
        "count" as List.length with lst as values
        "sum" as calculate_sum with values as values
        "mean" as calculate_mean with values as values
        "min" as calculate_min with values as values
        "max" as calculate_max with values as values
        "stddev" as calculate_stddev with values as values

Process called "calculate_sum" that takes values as List[Float] returns Float:
    Let sum be 0.0
    For each value in values:
        Set sum to sum + value
    Return sum

Process called "calculate_mean" that takes values as List[Float] returns Float:
    If List.length with lst as values is equal to 0:
        Return 0.0
    Return calculate_sum with values as values divided by List.length with lst as values

Process called "calculate_min" that takes values as List[Float] returns Float:
    If List.length with lst as values is equal to 0:
        Return 0.0
    Let min_val be List.get with lst as values and index as 0
    For each value in values:
        If value is less than min_val:
            Set min_val to value
    Return min_val

Process called "calculate_max" that takes values as List[Float] returns Float:
    If List.length with lst as values is equal to 0:
        Return 0.0
    Let max_val be List.get with lst as values and index as 0
    For each value in values:
        If value is greater than max_val:
            Set max_val to value
    Return max_val

Process called "calculate_stddev" that takes values as List[Float] returns Float:
    If List.length with lst as values is less than 2:
        Return 0.0
    Let mean be calculate_mean with values as values
    Let variance_sum be 0.0
    For each value in values:
        Let diff be value - mean
        Set variance_sum to variance_sum + diff multiplied by diff
    Let variance be variance_sum divided by List.length with lst as values - 1
    Return sqrt with value as variance

Note: Metric export and serialization
Process called "export_metrics" that takes collector_name as String and format as String returns String:
    Match format:
        When "json":
            Return export_metrics_json with collector_name as collector_name
        When "prometheus":
            Return export_metrics_prometheus with collector_name as collector_name
        When "csv":
            Return export_metrics_csv with collector_name as collector_name
        Otherwise:
            Return export_metrics_json with collector_name as collector_name

Process called "export_metrics_json" that takes collector_name as String returns String:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return "{}"
    Let collector be collector_opt as MetricCollector
    Let json_parts be list
    Add "{\"collector\": \"" followed by collector.name followed by "\"," to json_parts
    Add "\"metrics\": {" to json_parts
    Let metric_count be 0
    For each name and samples in collector.metrics:
        If metric_count is greater than 0:
            Add "," to json_parts
        Add "\"" followed by name followed by "\": [" to json_parts
        For i from 0 to List.length with lst as samples - 1:
            If i is greater than 0:
                Add "," to json_parts
            Let sample be List.get with lst as samples and index as i
            Add "{" to json_parts
            Add "\"value\": " followed by String.from with value as sample.value followed by "," to json_parts
            Add "\"timestamp\": " followed by String.from with value as sample.timestamp to json_parts
            Add "}" to json_parts
        Add "]" to json_parts
        Set metric_count to metric_count + 1
    Add "}}" to json_parts
    Return String.join with parts as json_parts and separator as ""

Process called "export_metrics_prometheus" that takes collector_name as String returns String:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is None:
        Return ""
    Let collector be collector_opt as MetricCollector
    Let lines be list
    For each key and value in collector.counters:
        Add "# TYPE " followed by key followed by " counter" to lines
        Add key followed by " " followed by String.from with value as value to lines
    For each key and value in collector.gauges:
        Add "# TYPE " followed by key followed by " gauge" to lines
        Add key followed by " " followed by String.from with value as value to lines
    Return String.join with parts as lines and separator as "\n"

Process called "export_metrics_csv" that takes collector_name as String returns String:
    Let samples be get_all_metrics with collector_name as collector_name
    Let lines be list containing "metric_name,value,timestamp,type"
    For each name and metric_samples in samples:
        For each sample in metric_samples:
            Add name followed by "," followed by String.from with value as sample.value followed by "," followed by String.from with value as sample.timestamp followed by "," followed by metric_kind_to_string with kind as sample.metric_type to lines
    Return String.join with parts as lines and separator as "\n"

Note: Utility functions
Process called "create_metric_key" that takes name as String and labels as Dictionary[String, String] returns String:
    Let key_parts be list containing name
    For each label_name and label_value in labels:
        Add label_name followed by "=" followed by label_value to key_parts
    Return String.join with parts as key_parts and separator as ","

Process called "metric_kind_to_string" that takes kind as MetricKind returns String:
    Match kind:
        When Counter:
            Return "counter"
        When Gauge:
            Return "gauge"
        When Histogram:
            Return "histogram"
        When Summary:
            Return "summary"
        When Timer:
            Return "timer"

Process called "get_current_time" returns Float:
    Note: Would return high-precision timestamp
    Return 0.0

Process called "sqrt" that takes value as Float returns Float:
    Note: Would compute square root
    Return value multiplied by 0.5 Note: Simplified approximation

Note: Cleanup and maintenance
Process called "cleanup_all_collectors":
    For each name and collector in global_collectors:
        cleanup_collector with collector as collector

Process called "cleanup_collector" that takes collector as MetricCollector:
    Let current_time be get_current_time()
    For each name and samples in collector.metrics:
        cleanup_old_samples with collector as collector and metric_name as name

Process called "reset_collector" that takes collector_name as String:
    Let collector_opt be get_collector with name as collector_name
    If collector_opt is not None:
        Let collector be collector_opt as MetricCollector
        Set collector.metrics to dictionary
        Set collector.counters to dictionary
        Set collector.gauges to dictionary
        Set collector.histograms to dictionary
        Set collector.summaries to dictionary