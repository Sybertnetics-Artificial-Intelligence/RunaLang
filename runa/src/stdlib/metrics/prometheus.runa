Note:
Runa Standard Library: Prometheus Metrics

Production-grade Prometheus protocol integration providing native support
for Prometheus metric collection, exposition, and remote write capabilities.

Features:
- Complete Prometheus metric format support
- HTTP endpoint exposition with /metrics endpoint
- Remote write protocol implementation
- Time series labeling and metadata management
- High-performance metric serialization
- Integration with collectors system for unified metrics
:End Note

Import "metrics/collectors" as Collectors
Import "http/server" as HttpServer
Import "http/client" as HttpClient

Note: Core Prometheus types and formats
Type PrometheusMetricType is:
    | Counter
    | Gauge
    | Histogram
    | Summary
    | Untyped

Type called "PrometheusMetric":
    name as String
    metric_type as PrometheusMetricType
    help as String
    labels as Dictionary[String, String]
    value as Float
    timestamp as Float

Type called "PrometheusHistogram":
    name as String
    help as String
    labels as Dictionary[String, String]
    buckets as List[PrometheusBucket]
    sum as Float
    count as Integer

Type called "PrometheusBucket":
    upper_bound as Float
    count as Integer
    cumulative_count as Integer

Type called "PrometheusSummary":
    name as String
    help as String
    labels as Dictionary[String, String] 
    quantiles as List[PrometheusQuantile]
    sum as Float
    count as Integer

Type called "PrometheusQuantile":
    quantile as Float
    value as Float

Type called "PrometheusRegistry":
    metrics as List[PrometheusMetric]
    histograms as List[PrometheusHistogram]
    summaries as List[PrometheusSummary]
    collectors as Dictionary[String, String]
    labels as Dictionary[String, String]

Note: Global Prometheus registry
Let prometheus_registry be PrometheusRegistry with:
    metrics as list
    histograms as list
    summaries as list
    collectors as dictionary
    labels as dictionary

Note: Metric registration and management
Process called "register_metric" that takes name as String and metric_type as PrometheusMetricType and help as String:
    Let metric be PrometheusMetric with:
        name as name
        metric_type as metric_type
        help as help
        labels as dictionary
        value as 0.0
        timestamp as get_current_time()
    Add metric to prometheus_registry.metrics

Process called "register_histogram" that takes name as String and help as String and buckets as List[Float]:
    Let histogram_buckets be list
    Let cumulative be 0
    For each upper_bound in buckets:
        Let bucket be PrometheusBucket with:
            upper_bound as upper_bound
            count as 0
            cumulative_count as cumulative
        Add bucket to histogram_buckets
    Let histogram be PrometheusHistogram with:
        name as name
        help as help
        labels as dictionary
        buckets as histogram_buckets
        sum as 0.0
        count as 0
    Add histogram to prometheus_registry.histograms

Process called "register_summary" that takes name as String and help as String and quantiles as List[Float]:
    Let summary_quantiles be list
    For each quantile in quantiles:
        Let q be PrometheusQuantile with:
            quantile as quantile
            value as 0.0
        Add q to summary_quantiles
    Let summary be PrometheusSummary with:
        name as name
        help as help
        labels as dictionary
        quantiles as summary_quantiles
        sum as 0.0
        count as 0
    Add summary to prometheus_registry.summaries

Note: Metric updating and collection
Process called "update_counter" that takes name as String and value as Float and labels as Dictionary[String, String]:
    For each metric in prometheus_registry.metrics:
        If metric.name is equal to name and metric.metric_type is equal to Counter:
            If labels_match with metric_labels as metric.labels and provided_labels as labels:
                Set metric.value to metric.value + value
                Set metric.timestamp to get_current_time()
                Return
    Note: Create new metric instance if not found
    Let new_metric be PrometheusMetric with:
        name as name
        metric_type as Counter
        help as "Counter metric"
        labels as labels
        value as value
        timestamp as get_current_time()
    Add new_metric to prometheus_registry.metrics

Process called "update_gauge" that takes name as String and value as Float and labels as Dictionary[String, String]:
    For each metric in prometheus_registry.metrics:
        If metric.name is equal to name and metric.metric_type is equal to Gauge:
            If labels_match with metric_labels as metric.labels and provided_labels as labels:
                Set metric.value to value
                Set metric.timestamp to get_current_time()
                Return
    Note: Create new metric instance if not found
    Let new_metric be PrometheusMetric with:
        name as name
        metric_type as Gauge
        help as "Gauge metric"
        labels as labels
        value as value
        timestamp as get_current_time()
    Add new_metric to prometheus_registry.metrics

Process called "update_histogram" that takes name as String and value as Float and labels as Dictionary[String, String]:
    For each histogram in prometheus_registry.histograms:
        If histogram.name is equal to name:
            If labels_match with metric_labels as histogram.labels and provided_labels as labels:
                Set histogram.sum to histogram.sum + value
                Set histogram.count to histogram.count + 1
                For each bucket in histogram.buckets:
                    If value is less than or equal to bucket.upper_bound:
                        Set bucket.count to bucket.count + 1
                        Set bucket.cumulative_count to bucket.cumulative_count + 1
                Return

Process called "update_summary" that takes name as String and value as Float and labels as Dictionary[String, String]:
    For each summary in prometheus_registry.summaries:
        If summary.name is equal to name:
            If labels_match with metric_labels as summary.labels and provided_labels as labels:
                Set summary.sum to summary.sum + value
                Set summary.count to summary.count + 1
                Note: Update quantiles using simplified approximation
                For each quantile in summary.quantiles:
                    Set quantile.value to quantile.value multiplied by 0.9 + value multiplied by 0.1
                Return

Note: Prometheus exposition format
Process called "export_metrics" returns String:
    Let output_lines be list
    Note: Export regular metrics
    For each metric in prometheus_registry.metrics:
        Add format_metric_help with metric as metric to output_lines
        Add format_metric_type with metric as metric to output_lines
        Add format_metric_sample with metric as metric to output_lines
    Note: Export histograms
    For each histogram in prometheus_registry.histograms:
        Add format_histogram with histogram as histogram to output_lines
    Note: Export summaries
    For each summary in prometheus_registry.summaries:
        Add format_summary with summary as summary to output_lines
    Return String.join with parts as output_lines and separator as "\n"

Process called "format_metric_help" that takes metric as PrometheusMetric returns String:
    Return "# HELP " followed by metric.name followed by " " followed by metric.help

Process called "format_metric_type" that takes metric as PrometheusMetric returns String:
    Let type_string be prometheus_type_to_string with metric_type as metric.metric_type
    Return "# TYPE " followed by metric.name followed by " " followed by type_string

Process called "format_metric_sample" that takes metric as PrometheusMetric returns String:
    Let labels_string be format_labels with labels as metric.labels
    Let timestamp_string be String.from with value as metric.timestamp
    If Dictionary.length with dict as metric.labels is greater than 0:
        Return metric.name followed by labels_string followed by " " followed by String.from with value as metric.value followed by " " followed by timestamp_string
    Otherwise:
        Return metric.name followed by " " followed by String.from with value as metric.value followed by " " followed by timestamp_string

Process called "format_histogram" that takes histogram as PrometheusHistogram returns String:
    Let lines be list
    Add "# HELP " followed by histogram.name followed by " " followed by histogram.help to lines
    Add "# TYPE " followed by histogram.name followed by " histogram" to lines
    Let labels_base be format_labels with labels as histogram.labels
    Note: Format histogram buckets
    For each bucket in histogram.buckets:
        Let bucket_labels be extend_labels with base_labels as histogram.labels and key as "le" and value as String.from with value as bucket.upper_bound
        Let bucket_labels_string be format_labels with labels as bucket_labels
        Add histogram.name followed by "_bucket" followed by bucket_labels_string followed by " " followed by String.from with value as bucket.cumulative_count to lines
    Note: Add sum and count
    Add histogram.name followed by "_sum" followed by labels_base followed by " " followed by String.from with value as histogram.sum to lines
    Add histogram.name followed by "_count" followed by labels_base followed by " " followed by String.from with value as histogram.count to lines
    Return String.join with parts as lines and separator as "\n"

Process called "format_summary" that takes summary as PrometheusSummary returns String:
    Let lines be list
    Add "# HELP " followed by summary.name followed by " " followed by summary.help to lines
    Add "# TYPE " followed by summary.name followed by " summary" to lines
    Let labels_base be format_labels with labels as summary.labels
    Note: Format summary quantiles
    For each quantile in summary.quantiles:
        Let quantile_labels be extend_labels with base_labels as summary.labels and key as "quantile" and value as String.from with value as quantile.quantile
        Let quantile_labels_string be format_labels with labels as quantile_labels
        Add summary.name followed by quantile_labels_string followed by " " followed by String.from with value as quantile.value to lines
    Note: Add sum and count
    Add summary.name followed by "_sum" followed by labels_base followed by " " followed by String.from with value as summary.sum to lines
    Add summary.name followed by "_count" followed by labels_base followed by " " followed by String.from with value as summary.count to lines
    Return String.join with parts as lines and separator as "\n"

Note: Label handling utilities
Process called "format_labels" that takes labels as Dictionary[String, String] returns String:
    If Dictionary.length with dict as labels is equal to 0:
        Return ""
    Let label_pairs be list
    For each key and value in labels:
        Add key followed by "=\"" followed by escape_label_value with value as value followed by "\"" to label_pairs
    Return "{" followed by String.join with parts as label_pairs and separator as "," followed by "}"

Process called "extend_labels" that takes base_labels as Dictionary[String, String] and key as String and value as String returns Dictionary[String, String]:
    Let extended_labels be dictionary
    For each label_key and label_value in base_labels:
        Set extended_labels[label_key] to label_value
    Set extended_labels[key] to value
    Return extended_labels

Process called "escape_label_value" that takes value as String returns String:
    Let result be String.replace with str as value and old_substr as "\\" and new_substr as "\\\\"
    Set result to String.replace with str as result and old_substr as "\"" and new_substr as "\\\""
    Set result to String.replace with str as result and old_substr as "\n" and new_substr as "\\n"
    Return result

Process called "labels_match" that takes metric_labels as Dictionary[String, String] and provided_labels as Dictionary[String, String] returns Boolean:
    If Dictionary.length with dict as metric_labels is not equal to Dictionary.length with dict as provided_labels:
        Return false
    For each key and value in metric_labels:
        If key is not in provided_labels:
            Return false
        If provided_labels[key] is not equal to value:
            Return false
    Return true

Note: HTTP exposition endpoint
Process called "start_metrics_server" that takes port as Integer:
    Let server be HttpServer.create_server with port as port
    HttpServer.add_route with server as server and method as "GET" and path as "/metrics" and handler as metrics_handler
    HttpServer.start with server as server

Process called "metrics_handler" that takes request as HttpServer.Request returns HttpServer.Response:
    Let metrics_content be export_metrics()
    Return HttpServer.Response with:
        status as 200
        headers as dictionary with "Content-Type" as "text/plain; version=0.0.4; charset=utf-8"
        body as metrics_content

Note: Remote write protocol support
Type called "RemoteWriteRequest":
    timeseries as List[TimeSeries]
    metadata as List[MetricMetadata]

Type called "TimeSeries":
    labels as List[LabelPair]
    samples as List[Sample]
    exemplars as List[Exemplar]

Type called "LabelPair":
    name as String
    value as String

Type called "Sample":
    value as Float
    timestamp as Integer

Type called "Exemplar":
    labels as List[LabelPair]
    value as Float
    timestamp as Integer

Type called "MetricMetadata":
    metric_family_name as String
    help as String
    unit as String
    metric_type as PrometheusMetricType

Process called "create_remote_write_request" returns RemoteWriteRequest:
    Let timeseries_list be list
    Let metadata_list be list
    Note: Convert metrics to timeseries
    For each metric in prometheus_registry.metrics:
        Let labels be convert_labels_to_pairs with labels as metric.labels
        Add LabelPair with name as "__name__" and value as metric.name to labels
        Let sample be Sample with:
            value as metric.value
            timestamp as Float.to_integer with value as metric.timestamp multiplied by 1000
        Let ts be TimeSeries with:
            labels as labels
            samples as list containing sample
            exemplars as list
        Add ts to timeseries_list
        Let metadata be MetricMetadata with:
            metric_family_name as metric.name
            help as metric.help
            unit as ""
            metric_type as metric.metric_type
        Add metadata to metadata_list
    Return RemoteWriteRequest with:
        timeseries as timeseries_list
        metadata as metadata_list

Process called "send_remote_write" that takes endpoint_url as String and request as RemoteWriteRequest returns Boolean:
    Let serialized_data be serialize_remote_write_request with request as request
    Let headers be dictionary with:
        "Content-Type" as "application/x-protobuf"
        "Content-Encoding" as "snappy"
        "X-Prometheus-Remote-Write-Version" as "0.1.0"
    Try:
        Let response be HttpClient.post with url as endpoint_url and body as serialized_data and headers as headers
        If response.status is equal to 200:
            Return true
        Otherwise:
            Return false
    Catch error:
        Return false

Process called "serialize_remote_write_request" that takes request as RemoteWriteRequest returns String:
    Note: This would normally use Protocol Buffers serialization
    Note: For now, return a simplified JSON representation
    Let json_parts be list
    Add "{\"timeseries\": [" to json_parts
    For i from 0 to List.length with lst as request.timeseries - 1:
        If i is greater than 0:
            Add "," to json_parts
        Let ts be List.get with lst as request.timeseries and index as i
        Add serialize_timeseries with timeseries as ts to json_parts
    Add "]}" to json_parts
    Return String.join with parts as json_parts and separator as ""

Process called "serialize_timeseries" that takes timeseries as TimeSeries returns String:
    Let labels_json be serialize_label_pairs with labels as timeseries.labels
    Let samples_json be serialize_samples with samples as timeseries.samples Return "{\"labels\": " followed by labels_json followed by ", \"samples\": " followed by samples_json followed by "}"

Process called "serialize_label_pairs" that takes labels as List[LabelPair] returns String:
    Let label_parts be list
    For each label in labels:
        Add "{\"name\": \"" followed by label.name followed by "\", \"value\": \"" followed by label.value followed by "\"}" to label_parts
    Return "[" followed by String.join with parts as label_parts and separator as "," followed by "]"

Process called "serialize_samples" that takes samples as List[Sample] returns String:
    Let sample_parts be list
    For each sample in samples:
        Add "{\"value\": " followed by String.from with value as sample.value followed by ", \"timestamp\": " followed by String.from with value as sample.timestamp followed by "}" to sample_parts
    Return "[" followed by String.join with parts as sample_parts and separator as "," followed by "]"

Note: Collectors integration
Process called "import_from_collectors" that takes collector_name as String:
    Let collector_metrics be Collectors.get_all_metrics with collector_name as collector_name
    For each metric_name and samples in collector_metrics:
        For each sample in samples:
            Match sample.metric_type:
                When Collectors.Counter:
                    update_counter with name as metric_name and value as sample.value and labels as sample.labels
                When Collectors.Gauge:
                    update_gauge with name as metric_name and value as sample.value and labels as sample.labels
                When Collectors.Histogram:
                    update_histogram with name as metric_name and value as sample.value and labels as sample.labels
                When Collectors.Summary:
                    update_summary with name as metric_name and value as sample.value and labels as sample.labels

Process called "sync_with_collectors":
    Let collector_names be list
    For each name and collector_id in prometheus_registry.collectors:
        Add name to collector_names
    For each collector_name in collector_names:
        import_from_collectors with collector_name as collector_name

Note: Utility functions
Process called "convert_labels_to_pairs" that takes labels as Dictionary[String, String] returns List[LabelPair]:
    Let pairs be list
    For each key and value in labels:
        Let pair be LabelPair with:
            name as key
            value as value
        Add pair to pairs
    Return pairs

Process called "prometheus_type_to_string" that takes metric_type as PrometheusMetricType returns String:
    Match metric_type:
        When Counter:
            Return "counter"
        When Gauge:
            Return "gauge"
        When Histogram:
            Return "histogram"
        When Summary:
            Return "summary"
        When Untyped:
            Return "untyped"

Process called "get_current_time" returns Float:
    Note: Would return high-precision timestamp
    Return 0.0

Process called "register_collector" that takes collector_name as String:
    Set prometheus_registry.collectors[collector_name] to collector_name

Process called "unregister_collector" that takes collector_name as String:
    Remove prometheus_registry.collectors[collector_name]

Process called "set_global_labels" that takes labels as Dictionary[String, String]:
    Set prometheus_registry.labels to labels

Process called "add_global_label" that takes key as String and value as String:
    Set prometheus_registry.labels[key] to value

Note: Health and status endpoints
Process called "add_health_endpoints" that takes server as HttpServer.Server:
    HttpServer.add_route with server as server and method as "GET" and path as "/health" and handler as health_handler
    HttpServer.add_route with server as server and method as "GET" and path as "/-/healthy" and handler as health_handler
    HttpServer.add_route with server as server and method as "GET" and path as "/-/ready" and handler as ready_handler

Process called "health_handler" that takes request as HttpServer.Request returns HttpServer.Response:
    Return HttpServer.Response with:
        status as 200
        headers as dictionary with "Content-Type" as "text/plain"
        body as "Prometheus metrics endpoint is healthy"

Process called "ready_handler" that takes request as HttpServer.Request returns HttpServer.Response:
    Let metric_count be List.length with lst as prometheus_registry.metrics
    If metric_count is greater than 0:
        Return HttpServer.Response with:
            status as 200
            headers as dictionary with "Content-Type" as "text/plain"
            body as "Prometheus metrics endpoint is ready"
    Otherwise:
        Return HttpServer.Response with:
            status as 503
            headers as dictionary with "Content-Type" as "text/plain"
            body as "Prometheus metrics endpoint is not ready - no metrics registered"

Note: Cleanup and maintenance
Process called "clear_metrics":
    Set prometheus_registry.metrics to list
    Set prometheus_registry.histograms to list
    Set prometheus_registry.summaries to list

Process called "get_metrics_count" returns Integer:
    Return List.length with lst as prometheus_registry.metrics + List.length with lst as prometheus_registry.histograms + List.length with lst as prometheus_registry.summaries