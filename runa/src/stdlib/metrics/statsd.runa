Note:
Runa Standard Library: StatsD Metrics

Production-grade StatsD protocol implementation providing native support
for StatsD metric collection, aggregation, and transmission.

Features:
- Complete StatsD protocol support (counters, gauges, timers, histograms, sets)
- UDP and TCP transport with automatic failover
- Client-side sampling and aggregation
- Batch transmission for high-throughput scenarios
- Integration with collectors system
- Thread-safe metric buffering and transmission
:End Note

Import "metrics/collectors" as Collectors
Import "net/udp" as UDP
Import "net/tcp" as TCP

Note: Core StatsD types and configuration
Type StatsDMetricType is:
    | Counter
    | Gauge
    | Timer
    | Histogram
    | Set

Type called "StatsDMetric":
    name as String
    metric_type as StatsDMetricType
    value as Float
    sample_rate as Float
    tags as Dictionary[String, String]
    timestamp as Float

Type called "StatsDConfig":
    host as String
    port as Integer
    protocol as String
    max_buffer_size as Integer
    flush_interval as Float
    sample_rate as Float
    prefix as String
    suffix as String
    tags as Dictionary[String, String]

Type called "StatsDClient":
    config as StatsDConfig
    buffer as List[String]
    connection as Any
    last_flush as Float
    metrics_sent as Integer
    metrics_dropped as Integer

Note: Global StatsD client
Let default_statsd_config be StatsDConfig with:
    host as "localhost"
    port as 8125
    protocol as "udp"
    max_buffer_size as 1000
    flush_interval as 1.0
    sample_rate as 1.0
    prefix as ""
    suffix as ""
    tags as dictionary

Let global_statsd_client be StatsDClient with:
    config as default_statsd_config
    buffer as list
    connection as None
    last_flush as get_current_time()
    metrics_sent as 0
    metrics_dropped as 0

Note: Client creation and configuration
Process called "create_client" that takes config as StatsDConfig returns StatsDClient:
    Return StatsDClient with:
        config as config
        buffer as list
        connection as None
        last_flush as get_current_time()
        metrics_sent as 0
        metrics_dropped as 0

Process called "create_default_client" returns StatsDClient:
    Return create_client with config as default_statsd_config

Process called "configure_client" that takes client as StatsDClient and host as String and port as Integer:
    Set client.config.host to host
    Set client.config.port to port
    close_connection with client as client

Process called "set_prefix" that takes client as StatsDClient and prefix as String:
    Set client.config.prefix to prefix

Process called "set_suffix" that takes client as StatsDClient and suffix as String:
    Set client.config.suffix to suffix

Process called "add_tag" that takes client as StatsDClient and key as String and value as String:
    Set client.config.tags[key] to value

Process called "set_sample_rate" that takes client as StatsDClient and sample_rate as Float:
    Set client.config.sample_rate to sample_rate

Note: Connection management
Process called "connect" that takes client as StatsDClient returns Boolean:
    If client.connection is not None:
        Return true
    Try:
        Match client.config.protocol:
            When "udp":
                Set client.connection to UDP.create_socket()
                UDP.connect with socket as client.connection and host as client.config.host and port as client.config.port
            When "tcp":
                Set client.connection to TCP.create_socket()
                TCP.connect with socket as client.connection and host as client.config.host and port as client.config.port
            Otherwise:
                Return false
        Return true
    Catch error:
        Set client.connection to None
        Return false

Process called "close_connection" that takes client as StatsDClient:
    If client.connection is not None:
        Match client.config.protocol:
            When "udp":
                UDP.close with socket as client.connection
            When "tcp":
                TCP.close with socket as client.connection
        Set client.connection to None

Process called "reconnect" that takes client as StatsDClient returns Boolean:
    close_connection with client as client
    Return connect with client as client

Note: Metric sending operations
Process called "counter" that takes client as StatsDClient and name as String and value as Float:
    counter_with_options with client as client and name as name and value as value and sample_rate as client.config.sample_rate and tags as dictionary

Process called "counter_with_options" that takes client as StatsDClient and name as String and value as Float and sample_rate as Float and tags as Dictionary[String, String]:
    If should_sample with rate as sample_rate:
        Let metric_line be format_counter with name as name and value as value and sample_rate as sample_rate and tags as tags and client as client
        send_metric with client as client and metric_line as metric_line

Process called "gauge" that takes client as StatsDClient and name as String and value as Float:
    gauge_with_options with client as client and name as name and value as value and tags as dictionary

Process called "gauge_with_options" that takes client as StatsDClient and name as String and value as Float and tags as Dictionary[String, String]:
    Let metric_line be format_gauge with name as name and value as value and tags as tags and client as client
    send_metric with client as client and metric_line as metric_line

Process called "increment" that takes client as StatsDClient and name as String:
    counter with client as client and name as name and value as 1.0

Process called "decrement" that takes client as StatsDClient and name as String:
    counter with client as client and name as name and value as -1.0

Process called "timer" that takes client as StatsDClient and name as String and value as Float:
    timer_with_options with client as client and name as name and value as value and tags as dictionary

Process called "timer_with_options" that takes client as StatsDClient and name as String and value as Float and tags as Dictionary[String, String]:
    Let metric_line be format_timer with name as name and value as value and tags as tags and client as client
    send_metric with client as client and metric_line as metric_line

Process called "histogram" that takes client as StatsDClient and name as String and value as Float:
    histogram_with_options with client as client and name as name and value as value and tags as dictionary

Process called "histogram_with_options" that takes client as StatsDClient and name as String and value as Float and tags as Dictionary[String, String]:
    Let metric_line be format_histogram with name as name and value as value and tags as tags and client as client
    send_metric with client as client and metric_line as metric_line

Process called "set_metric" that takes client as StatsDClient and name as String and value as String:
    set_metric_with_options with client as client and name as name and value as value and tags as dictionary

Process called "set_metric_with_options" that takes client as StatsDClient and name as String and value as String and tags as Dictionary[String, String]:
    Let metric_line be format_set with name as name and value as value and tags as tags and client as client
    send_metric with client as client and metric_line as metric_line

Note: Timing convenience functions
Process called "time_function" that takes client as StatsDClient and name as String and func as Process returns Any:
    Let start_time be get_current_time()
    Let result be func()
    Let end_time be get_current_time()
    Let duration be end_time - start_time multiplied by 1000.0
    Note: Convert to milliseconds
    timer with client as client and name as name and value as duration
    Return result

Process called "start_timer" that takes client as StatsDClient and name as String returns Float:
    Return get_current_time()

Process called "stop_timer" that takes client as StatsDClient and name as String and start_time as Float:
    Let end_time be get_current_time()
    Let duration be end_time - start_time multiplied by 1000.0
    timer with client as client and name as name and value as duration

Note: Metric formatting
Process called "format_counter" that takes name as String and value as Float and sample_rate as Float and tags as Dictionary[String, String] and client as StatsDClient returns String:
    Let metric_name be build_metric_name with name as name and client as client
    Let formatted_value be String.from with value as value
    Let tags_string be format_tags with tags as merge_tags with base_tags as client.config.tags and additional_tags as tags
    Let sample_string be format_sample_rate with rate as sample_rate
    Return metric_name followed by ":" followed by formatted_value followed by "|c" followed by sample_string followed by tags_string

Process called "format_gauge" that takes name as String and value as Float and tags as Dictionary[String, String] and client as StatsDClient returns String:
    Let metric_name be build_metric_name with name as name and client as client
    Let formatted_value be String.from with value as value
    Let tags_string be format_tags with tags as merge_tags with base_tags as client.config.tags and additional_tags as tags
    Return metric_name followed by ":" followed by formatted_value followed by "|g" followed by tags_string

Process called "format_timer" that takes name as String and value as Float and tags as Dictionary[String, String] and client as StatsDClient returns String:
    Let metric_name be build_metric_name with name as name and client as client
    Let formatted_value be String.from with value as value
    Let tags_string be format_tags with tags as merge_tags with base_tags as client.config.tags and additional_tags as tags
    Return metric_name followed by ":" followed by formatted_value followed by "|ms" followed by tags_string

Process called "format_histogram" that takes name as String and value as Float and tags as Dictionary[String, String] and client as StatsDClient returns String:
    Let metric_name be build_metric_name with name as name and client as client
    Let formatted_value be String.from with value as value
    Let tags_string be format_tags with tags as merge_tags with base_tags as client.config.tags and additional_tags as tags
    Return metric_name followed by ":" followed by formatted_value followed by "|h" followed by tags_string

Process called "format_set" that takes name as String and value as String and tags as Dictionary[String, String] and client as StatsDClient returns String:
    Let metric_name be build_metric_name with name as name and client as client
    Let tags_string be format_tags with tags as merge_tags with base_tags as client.config.tags and additional_tags as tags
    Return metric_name followed by ":" followed by value followed by "|s" followed by tags_string

Process called "build_metric_name" that takes name as String and client as StatsDClient returns String:
    Let metric_name be name
    If String.length with str as client.config.prefix is greater than 0:
        Set metric_name to client.config.prefix followed by "." followed by metric_name
    If String.length with str as client.config.suffix is greater than 0:
        Set metric_name to metric_name followed by "." followed by client.config.suffix
    Return metric_name

Process called "format_tags" that takes tags as Dictionary[String, String] returns String:
    If Dictionary.length with dict as tags is equal to 0:
        Return ""
    Let tag_pairs be list
    For each key and value in tags:
        Add key followed by ":" followed by value to tag_pairs
    Return "|#" followed by String.join with parts as tag_pairs and separator as ","

Process called "format_sample_rate" that takes rate as Float returns String:
    If rate is less than 1.0:
        Return "|@" followed by String.from with value as rate
    Return ""

Process called "merge_tags" that takes base_tags as Dictionary[String, String] and additional_tags as Dictionary[String, String] returns Dictionary[String, String]:
    Let merged be dictionary
    For each key and value in base_tags:
        Set merged[key] to value
    For each key and value in additional_tags:
        Set merged[key] to value
    Return merged

Note: Buffering and transmission
Process called "send_metric" that takes client as StatsDClient and metric_line as String:
    If List.length with lst as client.buffer is greater than or equal to client.config.max_buffer_size:
        flush_buffer with client as client
    Add metric_line to client.buffer
    Let current_time be get_current_time()
    If current_time - client.last_flush is greater than client.config.flush_interval:
        flush_buffer with client as client

Process called "flush_buffer" that takes client as StatsDClient:
    If List.length with lst as client.buffer is equal to 0:
        Return
    If not connect with client as client:
        Set client.metrics_dropped to client.metrics_dropped + List.length with lst as client.buffer
        Set client.buffer to list
        Return
    Let payload be String.join with parts as client.buffer and separator as "\n"
    Try:
        Match client.config.protocol:
            When "udp":
                UDP.send with socket as client.connection and data as payload
            When "tcp":
                TCP.send with socket as client.connection and data as payload
        Set client.metrics_sent to client.metrics_sent + List.length with lst as client.buffer
        Set client.buffer to list
        Set client.last_flush to get_current_time()
    Catch error:
        Set client.metrics_dropped to client.metrics_dropped + List.length with lst as client.buffer
        Set client.buffer to list
        close_connection with client as client

Process called "force_flush" that takes client as StatsDClient:
    flush_buffer with client as client

Note: Sampling utilities
Process called "should_sample" that takes rate as Float returns Boolean:
    If rate is greater than or equal to 1.0:
        Return true
    Let random_value be get_random_float()
    Return random_value is less than rate

Process called "get_random_float" returns Float:
    Note: Would return random float between 0.0 and 1.0
    Return 0.5

Note: Batch operations
Process called "batch_send" that takes client as StatsDClient and metrics as List[StatsDMetric]:
    For each metric in metrics:
        Match metric.metric_type:
            When Counter:
                counter_with_options with client as client and name as metric.name and value as metric.value and sample_rate as metric.sample_rate and tags as metric.tags
            When Gauge:
                gauge_with_options with client as client and name as metric.name and value as metric.value and tags as metric.tags
            When Timer:
                timer_with_options with client as client and name as metric.name and value as metric.value and tags as metric.tags
            When Histogram:
                histogram_with_options with client as client and name as metric.name and value as metric.value and tags as metric.tags
            When Set:
                set_metric_with_options with client as client and name as metric.name and value as String.from with value as metric.value and tags as metric.tags

Note: Collectors integration
Process called "import_from_collectors" that takes client as StatsDClient and collector_name as String:
    Let collector_metrics be Collectors.get_all_metrics with collector_name as collector_name
    For each metric_name and samples in collector_metrics:
        For each sample in samples:
            Match sample.metric_type:
                When Collectors.Counter:
                    counter_with_options with client as client and name as metric_name and value as sample.value and sample_rate as 1.0 and tags as sample.labels
                When Collectors.Gauge:
                    gauge_with_options with client as client and name as metric_name and value as sample.value and tags as sample.labels
                When Collectors.Histogram:
                    histogram_with_options with client as client and name as metric_name and value as sample.value and tags as sample.labels
                When Collectors.Timer:
                    timer_with_options with client as client and name as metric_name and value as sample.value and tags as sample.labels

Process called "setup_collectors_sync" that takes client as StatsDClient and collector_name as String and sync_interval as Float:
    Note: This would set up a background task to periodically sync with collectors
    Let sync_task be create_sync_task with client as client and collector_name as collector_name and interval as sync_interval
    start_background_task with task as sync_task

Process called "create_sync_task" that takes client as StatsDClient and collector_name as String and interval as Float returns Process:
    Process called "sync_task":
        While true:
            import_from_collectors with client as client and collector_name as collector_name
            sleep with seconds as interval
    Return sync_task

Note: Statistics and monitoring
Process called "get_client_stats" that takes client as StatsDClient returns Dictionary[String, Integer]:
    Return dictionary with:
        "metrics_sent" as client.metrics_sent
        "metrics_dropped" as client.metrics_dropped
        "buffer_size" as List.length with lst as client.buffer
        "connection_active" as if client.connection is not None then 1 else 0

Process called "reset_client_stats" that takes client as StatsDClient:
    Set client.metrics_sent to 0
    Set client.metrics_dropped to 0

Note: Global client convenience functions
Process called "global_counter" that takes name as String and value as Float:
    counter with client as global_statsd_client and name as name and value as value

Process called "global_gauge" that takes name as String and value as Float:
    gauge with client as global_statsd_client and name as name and value as value

Process called "global_increment" that takes name as String:
    increment with client as global_statsd_client and name as name

Process called "global_decrement" that takes name as String:
    decrement with client as global_statsd_client and name as name

Process called "global_timer" that takes name as String and value as Float:
    timer with client as global_statsd_client and name as name and value as value

Process called "global_time_function" that takes name as String and func as Process returns Any:
    Return time_function with client as global_statsd_client and name as name and func as func

Process called "configure_global_client" that takes host as String and port as Integer:
    configure_client with client as global_statsd_client and host as host and port as port

Process called "set_global_prefix" that takes prefix as String:
    set_prefix with client as global_statsd_client and prefix as prefix

Process called "add_global_tag" that takes key as String and value as String:
    add_tag with client as global_statsd_client and key as key and value as value

Note: Health check and diagnostics
Process called "health_check" that takes client as StatsDClient returns Boolean:
    Try:
        Let test_metric be "runa.statsd.health_check:" followed by String.from with value as get_current_time() followed by "|g"
        If not connect with client as client:
            Return false
        Match client.config.protocol:
            When "udp":
                UDP.send with socket as client.connection and data as test_metric
            When "tcp":
                TCP.send with socket as client.connection and data as test_metric
        Return true
    Catch error:
        Return false

Process called "get_current_time" returns Float:
    Note: Would return high-precision timestamp
    Return 0.0

Process called "sleep" that takes seconds as Float:
    Note: Would pause execution for specified seconds
    pass

Process called "start_background_task" that takes task as Process:
    Note: Would start task in background thread
    pass

Process called "cleanup_client" that takes client as StatsDClient:
    force_flush with client as client
    close_connection with client as client

Note: Initialize global client on module load
Process called "initialize_global_client":
    connect with client as global_statsd_client