Note: Enhanced Kotlin Interop Module for Runa
Note: Provides comprehensive Kotlin/JVM integration with coroutines and Android support
Note: Zero-copy data exchange, advanced type system bridging, and Kotlin Native compatibility

Import "interop/ffi" as FFI
Import "../../collections" as Collections
Import "../../async" as Async
Import "../../concurrent" as Concurrent
Import "../../errors" as Errors
Import "../../os" as OS
Import "../../string" as String

Note: Core Kotlin Runtime Types
Data Type KotlinRuntimeConfig:
    kotlin_version as KotlinVersion
    jvm_config as KotlinJVMConfig
    compiler_config as KotlinCompilerConfig
    coroutine_config as KotlinCoroutineConfig
    native_config as Optional[KotlinNativeConfig]
    android_config as Optional[KotlinAndroidConfig]

Data Type KotlinVersion:
    Case Kotlin1_8
    Case Kotlin1_9
    Case Kotlin2_0

Data Type KotlinJVMConfig:
    jvm_target as KotlinJVMTarget
    java_parameters as Boolean
    use_ir as Boolean
    include_runtime as Boolean
    no_stdlib as Boolean
    no_kotlin_stdlib as Boolean
    classpath as List[String]
    module_path as List[String]

Data Type KotlinJVMTarget:
    Case JVM_1_8
    Case JVM_11
    Case JVM_17
    Case JVM_21

Data Type KotlinCompilerConfig:
    language_version as KotlinVersion
    api_version as KotlinVersion
    progressive_mode as Boolean
    suppress_warnings as List[String]
    all_warnings_as_errors as Boolean
    no_warn as Boolean
    verbose as Boolean
    script_templates as List[String]

Data Type KotlinCoroutineConfig:
    context_dispatcher as KotlinDispatcher
    exception_handler as Optional[String]
    debug_probes as Boolean
    stacktrace_recovery as Boolean

Data Type KotlinDispatcher:
    Case Default
    Case Main
    Case IO
    Case Unconfined
    Case Custom with name as String

Data Type KotlinNativeConfig:
    target as KotlinNativeTarget
    optimization_mode as KotlinOptimizationMode
    debug_info as KotlinDebugInfo
    memory_model as KotlinMemoryModel

Data Type KotlinNativeTarget:
    Case LinuxX64
    Case MingwX64
    Case MacosX64
    Case MacosArm64
    Case IosX64
    Case IosArm64
    Case AndroidNativeArm64
    Case AndroidNativeX64

Data Type KotlinOptimizationMode:
    Case Debug
    Case Release

Data Type KotlinDebugInfo:
    Case Enable
    Case Disable

Data Type KotlinMemoryModel:
    Case Strict
    Case Relaxed

Data Type KotlinAndroidConfig:
    android_api_level as Integer
    build_tools_version as String
    proguard_enabled as Boolean
    dex_enabled as Boolean

Note: Enhanced Result Types
Data Type KotlinResult[T]:
    Case Success with value as T
    Case CompilationError with diagnostics as List[KotlinDiagnostic]
    Case RuntimeError with message as String and error_code as Integer
    Case ExecutionError with exception as KotlinException
    Case InteropError with details as String
    Case CoroutineError with error as KotlinCoroutineError

Data Type KotlinDiagnostic:
    severity as KotlinDiagnosticSeverity
    message as String
    source_file as String
    line as Integer
    column as Integer
    category as String

Data Type KotlinDiagnosticSeverity:
    Case Error
    Case Warning
    Case Info

Data Type KotlinException:
    exception_class as String
    message as String
    stack_trace as List[KotlinStackFrame]
    cause as Optional[KotlinException]
    suppressed as List[KotlinException]

Data Type KotlinStackFrame:
    class_name as String
    method_name as String
    file_name as String
    line_number as Integer
    is_native_method as Boolean

Data Type KotlinCoroutineError:
    error_type as KotlinCoroutineErrorType
    message as String
    coroutine_context as Dictionary[String, Any]

Data Type KotlinCoroutineErrorType:
    Case CancellationException
    Case TimeoutException
    Case CoroutineException
    Case DispatchException

Note: Kotlin Type System
Data Type KotlinType:
    name as String
    package_name as String
    is_nullable as Boolean
    type_parameters as List[KotlinTypeParameter]
    supertypes as List[String]
    annotations as List[KotlinAnnotation]
    kind as KotlinTypeKind

Data Type KotlinTypeKind:
    Case Class
    Case Interface
    Case Object
    Case Enum
    Case Annotation
    Case Sealed
    Case Data
    Case Inline
    Case Fun

Data Type KotlinTypeParameter:
    name as String
    variance as KotlinVariance
    bounds as List[String]

Data Type KotlinVariance:
    Case Invariant
    Case Covariant
    Case Contravariant

Data Type KotlinAnnotation:
    name as String
    arguments as Dictionary[String, Any]

Note: Kotlin Value System
Data Type KotlinValue:
    kotlin_type as KotlinType
    value as Any
    is_null as Boolean
    jvm_reference as Optional[Integer]

Data Type KotlinFunction:
    name as String
    parameters as List[KotlinParameter]
    return_type as KotlinType
    modifiers as List[KotlinModifier]
    annotations as List[KotlinAnnotation]
    is_suspend as Boolean
    is_inline as Boolean
    is_extension as Boolean

Data Type KotlinParameter:
    name as String
    type as KotlinType
    has_default as Boolean
    is_vararg as Boolean

Data Type KotlinModifier:
    Case Public
    Case Private
    Case Protected
    Case Internal
    Case Abstract
    Case Final
    Case Open
    Case Override
    Case Static
    Case Suspend
    Case Inline
    Case Crossinline
    Case Noinline

Note: Coroutine Management
Data Type KotlinCoroutine:
    coroutine_id as String
    context as KotlinCoroutineContext
    job as KotlinJob
    is_active as Boolean
    is_completed as Boolean
    is_cancelled as Boolean

Data Type KotlinCoroutineContext:
    dispatcher as KotlinDispatcher
    job as Optional[String]
    exception_handler as Optional[String]
    coroutine_name as Optional[String]

Data Type KotlinJob:
    job_id as String
    state as KotlinJobState
    children as List[String]
    parent as Optional[String]

Data Type KotlinJobState:
    Case New
    Case Active
    Case Completing
    Case Completed
    Case Cancelled
    Case Cancelling

Note: Core Runtime Operations
Process initialize_kotlin_runtime that takes config as KotlinRuntimeConfig returns KotlinResult[Integer]:
    Import "interop/ffi" as FFI
    Import "../../os" as OS
    Note: First, initialize JVM if using Kotlin/JVM
    Let jvm_result be initialize_kotlin_jvm(config.jvm_config)
    If jvm_result is not KotlinResult::Success:
    Return jvm_result
    Note: Load Kotlin runtime libraries
    Let kotlin_lib_path be locate_kotlin_runtime(config.kotlin_version)
    If kotlin_lib_path is Empty:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not found" and error_code 1001 Let kotlin_lib be FFI::load_library(kotlin_lib_path.value)
    If kotlin_lib is FFI::LibraryResult::LoadError:
    Return KotlinResult::RuntimeError with message "Failed to load Kotlin runtime library" and error_code 1002
    Note: Initialize Kotlin runtime
    Let init_func be FFI::get_symbol(kotlin_lib, "kotlin_runtime_initialize")
    If init_func is not Empty:
    Let init_result be FFI::call_function(init_func, [])
    If init_result.return_code is not equal to 0:
    Return KotlinResult::RuntimeError with message "Failed to initialize Kotlin runtime" and error_code init_result.return_code
    Note: Setup coroutine runtime if configured
    If config.coroutine_config.debug_probes:
    Let coroutine_result be setup_kotlin_coroutines(kotlin_lib, config.coroutine_config)
    If coroutine_result is not KotlinResult::Success:
    Return coroutine_result
    Note: Initialize Kotlin/Native if configured
    If config.native_config is not Empty:
    Let native_result be initialize_kotlin_native(kotlin_lib, config.native_config.value)
    If native_result is not KotlinResult::Success:
    Return native_result Set global_kotlin_runtime to kotlin_lib
    Set kotlin_runtime_initialized to True Return KotlinResult::Success with value kotlin_lib

Process initialize_kotlin_jvm that takes config as KotlinJVMConfig returns KotlinResult[Integer]:
Note: Use the Java interop to initialize JVM
    Import "interop/java" as Java Let java_config be Java::JavaRuntimeConfig with:
    version as map_kotlin_jvm_target(config.jvm_target),
    heap_size as 512,
    stack_size as 8,
    garbage_collector as Java::JavaGCType::G1GC,
    class_paths as config.classpath,
    module_paths as config.module_path,
    enable_preview as False,
    system_properties as new Dictionary,
    vm_arguments as new List,
    debug_config as Java::JavaDebugConfig with:
    enable_debug as False,
    debug_port as 5005,
    suspend as False,
    server_mode as True,
    security_config as Java::JavaSecurityConfig with:
    security_manager as Empty,
    policy_file as Empty,
    sandbox_mode as False,
    performance_config as Java::JavaPerformanceConfig with:
    jit_compiler as True,
    tiered_compilation as True,
    compressed_oops as True,
    escape_analysis as True Let java_result be Java::initialize_java_runtime(java_config)
    If java_result is not Java::JavaResult::Success:
    Return KotlinResult::RuntimeError with message "Failed to initialize JVM for Kotlin" and error_code 2001 Return KotlinResult::Success with value java_result.value

Process map_kotlin_jvm_target that takes target as KotlinJVMTarget returns Java::JavaVersion:
    Import "interop/java" as Java If target is KotlinJVMTarget::JVM_1_8:
    Return Java::JavaVersion::Java8
    Otherwise if target is KotlinJVMTarget::JVM_11:
    Return Java::JavaVersion::Java11
    Otherwise if target is KotlinJVMTarget::JVM_17:
    Return Java::JavaVersion::Java17
    Otherwise if target is KotlinJVMTarget::JVM_21:
    Return Java::JavaVersion::Java21
    Otherwise:
    Return Java::JavaVersion::Java17

Process locate_kotlin_runtime that takes version as KotlinVersion returns Optional[String]:
    Import "../../os" as OS
    Note: Check for Kotlin installation
    Let kotlin_home be OS::get_environment_variable("KOTLIN_HOME")
    If kotlin_home is not Empty and OS::directory_exists(kotlin_home + "/lib"):
    Return Some with value kotlin_home + "/lib/kotlin-stdlib.jar"
    Note: Common installation paths
    Let common_paths be new List containing
    "/opt/kotlin/lib",
    "/usr/local/kotlin/lib",
    OS::get_home_directory() + "/.kotlin/lib"
    For Each path in common_paths:
    Let stdlib_path be path + "/kotlin-stdlib.jar"
    If OS::file_exists(stdlib_path):
    Return Some with value stdlib_path
    Note: Try to find kotlin compiler in PATH and derive lib path
    Let kotlin_compiler be find_kotlin_compiler_in_path()
    If kotlin_compiler is not Empty:
    Let kotlin_bin_dir be OS::get_directory_name(kotlin_compiler.value)
    Let kotlin_home be OS::get_directory_name(kotlin_bin_dir)
    Let lib_path be kotlin_home + "/lib/kotlin-stdlib.jar"
    If OS::file_exists(lib_path):
    Return Some with value lib_path Return Empty

Process find_kotlin_compiler_in_path that takes returns Optional[String]:
    Import "../../os" as OS
    Let path_env be OS::get_environment_variable("PATH")
    Let path_dirs be String::split(path_env, ":") For Each dir in path_dirs:
    Let kotlinc_binary be dir + "/kotlinc"
    If OS::file_exists(kotlinc_binary):
    Return Some with value kotlinc_binary Return Empty

Note: Kotlin Compilation
Process compile_kotlin_source that takes source_code as String and config as KotlinCompilerConfig returns KotlinResult[KotlinCompiledModule]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 3001 Import "../../os" as OS
    Note: Create temporary source file
    Let temp_file be OS::get_temp_directory() + "/kotlin_temp_" + generate_unique_id() + ".kt"
    Let write_result be OS::write_file(temp_file, source_code)
    If not write_result:
    Return KotlinResult::CompilationError with diagnostics new List
    Note: Prepare compilation command
    Let kotlinc_path be find_kotlin_compiler_in_path()
    If kotlinc_path is Empty:
    Return KotlinResult::RuntimeError with message "Kotlin compiler not found" and error_code 3002 Let compile_cmd be prepare_kotlin_compilation_command(kotlinc_path.value, temp_file, config)
    Note: Execute compilation
    Let compile_result be OS::execute_command(compile_cmd)
    Note: Cleanup temporary file
    OS::delete_file(temp_file) If compile_result.exit_code is not equal to 0:
    Let diagnostics be parse_kotlin_diagnostics(compile_result.stderr)
    Return KotlinResult::CompilationError with diagnostics diagnostics
    Note: Create compiled module info
    Let module be KotlinCompiledModule with:
    name as "RunaKotlinModule",
    output_path as extract_output_path(compile_result.stdout),
    source_files as new List containing temp_file,
    dependencies as new List,
    kotlin_version as config.language_version Return KotlinResult::Success with value module

Data Type KotlinCompiledModule:
    name as String
    output_path as String
    source_files as List[String]
    dependencies as List[String]
    kotlin_version as KotlinVersion

Process prepare_kotlin_compilation_command that takes kotlinc as String and source_file as String and config as KotlinCompilerConfig returns String:
    Let cmd be kotlinc + " " + source_file
    Note: Language version
    Set cmd to cmd + " -language-version " + kotlin_version_string(config.language_version)
    Note: API version
    Set cmd to cmd + " -api-version " + kotlin_version_string(config.api_version)
    Note: Progressive mode
    If config.progressive_mode:
    Set cmd to cmd + " -progressive"
    Note: Warnings configuration
    If config.all_warnings_as_errors:
    Set cmd to cmd + " -Werror"
    If config.no_warn:
    Set cmd to cmd + " -nowarn"
    Note: Suppress specific warnings
    For Each warning in config.suppress_warnings:
    Set cmd to cmd + " -Xsuppress-warning=" + warning
    Note: Verbose output
    If config.verbose:
    Set cmd to cmd + " -verbose"
    Note: Output directory
    Let output_dir be OS::get_temp_directory() + "/kotlin_output"
    Set cmd to cmd + " -d " + output_dir Return cmd

Process kotlin_version_string that takes version as KotlinVersion returns String:
    If version is KotlinVersion::Kotlin1_8:
    Return "1.8"
    Otherwise if version is KotlinVersion::Kotlin1_9:
    Return "1.9"
    Otherwise if version is KotlinVersion::Kotlin2_0:
    Return "2.0"
    Otherwise:
    Return "1.9"

Process parse_kotlin_diagnostics that takes stderr_output as String returns List[KotlinDiagnostic]:
    Let diagnostics be new List
    Let lines be String::split(stderr_output, "\n") For Each line in lines:
    If String::contains(line, ": error:") or String::contains(line, ": warning:") or String::contains(line, ": info:"):
    Let diagnostic be parse_kotlin_diagnostic_line(line)
    If diagnostic is not Empty:
    Add diagnostic.value to diagnostics Return diagnostics

Process parse_kotlin_diagnostic_line that takes line as String returns Optional[KotlinDiagnostic]:
Note: Parse format: "file.kt:(line,column): severity: message"
    Let colon_pos be String::find_first(line, ":")
    If colon_pos is Empty:
    Return Empty Let file_part be String::substring(line, 0, colon_pos.value)
    Let rest be String::substring(line, colon_pos.value + 1)
    Note: Extract line and column
    If String::starts_with(rest, "(") and String::contains(rest, ")"):
    Let paren_end be String::find_first(rest, ")")
    If paren_end is not Empty:
    Let coords_part be String::substring(rest, 1, paren_end.value)
    Let coords be String::split(coords_part, ",") If coords.length is equal to 2:
    Let line_num be String::to_integer_safe(String::trim(coords[0]))
    Let col_num be String::to_integer_safe(String::trim(coords[1])) If line_num is not Empty and col_num is not Empty:
    Let severity_part be String::substring(rest, paren_end.value + 2)
    Let severity_and_message be String::split(severity_part, ": ", 2) If severity_and_message.length is equal to 2:
    Let severity be parse_kotlin_diagnostic_severity(String::trim(severity_and_message[0]))
    Let message be String::trim(severity_and_message[1]) Let diagnostic be KotlinDiagnostic with:
    severity as severity,
    message as message,
    source_file as file_part,
    line as line_num.value,
    column as col_num.value,
    category as ""
    Return Some with value diagnostic Return Empty

Process parse_kotlin_diagnostic_severity that takes severity_str as String returns KotlinDiagnosticSeverity:
    If severity_str is equal to "error":
    Return KotlinDiagnosticSeverity::Error
    Otherwise if severity_str is equal to "warning":
    Return KotlinDiagnosticSeverity::Warning
    Otherwise if severity_str is equal to "info":
    Return KotlinDiagnosticSeverity::Info
    Otherwise:
    Return KotlinDiagnosticSeverity::Error

Note: Kotlin Code Execution
Process execute_kotlin_main that takes module as KotlinCompiledModule and main_class as String and arguments as List[String] returns KotlinResult[String]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 4001 Import "interop/java" as Java
    Note: Load the compiled class
    Let class_result be Java::load_java_class(main_class)
    If class_result is not Java::JavaResult::Success:
    Return KotlinResult::ExecutionError with exception KotlinException with:
    exception_class as "ClassNotFoundException",
    message as "Main class not found: " + main_class,
    stack_trace as new List,
    cause as Empty,
    suppressed as new List
    Note: Execute main method
    Let main_result be Java::call_java_static_method(main_class, "main", new List containing arguments)
    If main_result is not Java::JavaResult::Success:
    Return convert_java_error_to_kotlin(main_result) Return KotlinResult::Success with value "Kotlin program executed successfully"

Note: Coroutine Management
Process setup_kotlin_coroutines that takes kotlin_lib as Integer and config as KotlinCoroutineConfig returns KotlinResult[Boolean]:
Note: Setup coroutine debug probes if enabled
    If config.debug_probes:
    Let debug_func be FFI::get_symbol(kotlin_lib, "kotlinx_coroutines_debug_install")
    If debug_func is not Empty:
    Let debug_result be FFI::call_function(debug_func, [])
    If debug_result.return_code is not equal to 0:
    Return KotlinResult::RuntimeError with message "Failed to setup coroutine debug probes" and error_code debug_result.return_code Return KotlinResult::Success with value True

Process create_kotlin_coroutine that takes coroutine_builder as String and block as String and context as KotlinCoroutineContext returns KotlinResult[KotlinCoroutine]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 4001
    Note: Create coroutine code
    Let coroutine_code be generate_coroutine_code(coroutine_builder, block, context)
    Note: Execute coroutine creation
    Let exec_result be execute_kotlin_expression(coroutine_code)
    If exec_result is not KotlinResult::Success:
    Return exec_result
    Note: Generate coroutine ID
    Let coroutine_id be generate_coroutine_id() Let job be KotlinJob with:
    job_id as generate_job_id(),
    state as KotlinJobState::Active,
    children as new List,
    parent as Empty Let coroutine be KotlinCoroutine with:
    coroutine_id as coroutine_id,
    context as context,
    job as job,
    is_active as True,
    is_completed as False,
    is_cancelled as False
    Note: Register coroutine for tracking
    register_kotlin_coroutine(coroutine_id, coroutine) Return KotlinResult::Success with value coroutine

Process generate_coroutine_code that takes builder as String and block as String and context as KotlinCoroutineContext returns String:
    Let dispatcher_code be kotlin_dispatcher_string(context.dispatcher)
    Let context_code be "Dispatchers." + dispatcher_code If context.coroutine_name is not Empty:
    Set context_code to context_code + " + CoroutineName(\"" + context.coroutine_name.value + "\")"
    Return builder + "(" + context_code + ") {\n" + block + "\n}"

Process kotlin_dispatcher_string that takes dispatcher as KotlinDispatcher returns String:
    If dispatcher is KotlinDispatcher::Default:
    Return "Default"
    Otherwise if dispatcher is KotlinDispatcher::Main:
    Return "Main"
    Otherwise if dispatcher is KotlinDispatcher::IO:
    Return "IO"
    Otherwise if dispatcher is KotlinDispatcher::Unconfined:
    Return "Unconfined"
    Otherwise if dispatcher is KotlinDispatcher::Custom:
    Return dispatcher.name
    Otherwise:
    Return "Default"

Process await_kotlin_coroutine that takes coroutine as KotlinCoroutine returns KotlinResult[Any]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 4001
    Note: Generate await code
    Let await_code be "runBlocking { coroutine_" + coroutine.coroutine_id + ".await() }"
    Note: Execute await
    Let result be execute_kotlin_expression(await_code)
    Return result

Process cancel_kotlin_coroutine that takes coroutine_id as String and reason as Optional[String] returns KotlinResult[Boolean]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 4001
    Note: Generate cancellation code
    Let cancel_code be "coroutine_" + coroutine_id + ".cancel()"
    If reason is not Empty:
    Set cancel_code to "coroutine_" + coroutine_id + ".cancel(\"" + reason.value + "\")"
    Note: Execute cancellation
    Let result be execute_kotlin_expression(cancel_code)
    If result is KotlinResult::Success:
Note: Update coroutine state
    update_kotlin_coroutine_state(coroutine_id, KotlinJobState::Cancelled)
    Return KotlinResult::Success with value True Return result

Note: Function and Method Calls
Process call_kotlin_function that takes function_name as String and arguments as List[KotlinValue] and type_arguments as List[String] returns KotlinResult[KotlinValue]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 4001
    Note: Generate function call code
    Let args_code be format_kotlin_arguments(arguments)
    Let type_args_code be If type_arguments.length is greater than 0 then "<" + String::join(type_arguments, ", ") + ">" else ""
    Let call_code be function_name + type_args_code + "(" + args_code + ")"
    Note: Execute function call
    Let result be execute_kotlin_expression(call_code)
    If result is not KotlinResult::Success:
    Return result
    Note: Convert result to KotlinValue
    Let kotlin_value be convert_to_kotlin_value(result.value)
    Return KotlinResult::Success with value kotlin_value

Process call_kotlin_method that takes object_instance as KotlinValue and method_name as String and arguments as List[KotlinValue] returns KotlinResult[KotlinValue]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 4001
    Note: Generate method call code
    Let args_code be format_kotlin_arguments(arguments)
    Let call_code be "instance." + method_name + "(" + args_code + ")"
    Note: Set the instance variable
    Let instance_result be set_kotlin_variable("instance", object_instance)
    If instance_result is not KotlinResult::Success:
    Return instance_result
    Note: Execute method call
    Let result be execute_kotlin_expression(call_code)
    If result is not KotlinResult::Success:
    Return result
    Note: Convert result to KotlinValue
    Let kotlin_value be convert_to_kotlin_value(result.value)
    Return KotlinResult::Success with value kotlin_value

Note: Variable and Property Management
Process set_kotlin_variable that takes name as String and value as KotlinValue returns KotlinResult[Boolean]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 4001 Let assignment_code be "val " + name + " = " + format_kotlin_value(value) Let result be execute_kotlin_expression(assignment_code)
    If result is KotlinResult::Success:
    Return KotlinResult::Success with value True
    Otherwise:
    Return result

Process get_kotlin_variable that takes name as String returns KotlinResult[KotlinValue]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 4001 Let result be execute_kotlin_expression(name)
    If result is not KotlinResult::Success:
    Return result Let kotlin_value be convert_to_kotlin_value(result.value)
    Return KotlinResult::Success with value kotlin_value

Note: Kotlin/Native Integration
Process initialize_kotlin_native that takes kotlin_lib as Integer and config as KotlinNativeConfig returns KotlinResult[Boolean]:
Note: Initialize Kotlin/Native runtime if applicable
    Let native_init_func be FFI::get_symbol(kotlin_lib, "kotlin_native_initialize")
    If native_init_func is not Empty:
    Let init_result be FFI::call_function(native_init_func, [
    kotlin_native_target_value(config.target),
    kotlin_optimization_value(config.optimization_mode),
    kotlin_memory_model_value(config.memory_model)
    ]) If init_result.return_code is not equal to 0:
    Return KotlinResult::RuntimeError with message "Failed to initialize Kotlin/Native" and error_code init_result.return_code Return KotlinResult::Success with value True

Process kotlin_native_target_value that takes target as KotlinNativeTarget returns Integer:
    If target is KotlinNativeTarget::LinuxX64:
    Return 1
    Otherwise if target is KotlinNativeTarget::MingwX64:
    Return 2
    Otherwise if target is KotlinNativeTarget::MacosX64:
    Return 3
    Otherwise if target is KotlinNativeTarget::MacosArm64:
    Return 4
    Otherwise if target is KotlinNativeTarget::IosX64:
    Return 5
    Otherwise if target is KotlinNativeTarget::IosArm64:
    Return 6
    Otherwise:
    Return 1

Process kotlin_optimization_value that takes mode as KotlinOptimizationMode returns Integer:
    If mode is KotlinOptimizationMode::Debug:
    Return 0
    Otherwise if mode is KotlinOptimizationMode::Release:
    Return 1
    Otherwise:
    Return 0

Process kotlin_memory_model_value that takes model as KotlinMemoryModel returns Integer:
    If model is KotlinMemoryModel::Strict:
    Return 0
    Otherwise if model is KotlinMemoryModel::Relaxed:
    Return 1
    Otherwise:
    Return 1

Note: Utility Functions
Process execute_kotlin_expression that takes expression as String returns KotlinResult[Any]:
Note: This would use the Kotlin scripting engine or REPL
Note: Use Kotlin scripting engine through JVM integration
    Import "interop/java" as Java If not kotlin_runtime_initialized:
    Return KotlinResult::RuntimeError with message "Kotlin runtime not initialized" and error_code 2001
    Note: Create Kotlin script wrapper
    Let script_code be create_kotlin_script_wrapper(expression)
    Note: Compile using Kotlin compiler
    Let compile_result be compile_kotlin_script(script_code)
    If compile_result is not KotlinResult::Success:
    Return compile_result
    Note: Execute compiled script
    Let execute_result be execute_kotlin_script(compile_result.value)
    If execute_result is not KotlinResult::Success:
    Return execute_result
    Note: Convert result back to Runa type
    Let kotlin_result be convert_kotlin_result_to_runa(execute_result.value)
    Return KotlinResult::Success with value kotlin_result

Process format_kotlin_arguments that takes arguments as List[KotlinValue] returns String:
    Let arg_strings be new List For Each arg in arguments:
    Add format_kotlin_value(arg) to arg_strings Return String::join(arg_strings, ", ")

Process format_kotlin_value that takes value as KotlinValue returns String:
    If value.is_null:
    Return "null"
    If value.kotlin_type.name is equal to "String":
    Return "\"" + String::from_any(value.value) + "\""
    Otherwise if value.kotlin_type.name is equal to "Int":
    Return String::from_integer(Integer::from_any(value.value))
    Otherwise if value.kotlin_type.name is equal to "Double":
    Return String::from_float(Float::from_any(value.value))
    Otherwise if value.kotlin_type.name is equal to "Boolean":
    Return If Boolean::from_any(value.value) then "true" else "false"
    Otherwise:
    Return String::from_any(value.value)

Process convert_to_kotlin_value that takes value as Any returns KotlinValue:
    Let kotlin_type be infer_kotlin_type(value) Return KotlinValue with:
    kotlin_type as kotlin_type,
    value as value,
    is_null as value is Empty,
    jvm_reference as Empty

Process infer_kotlin_type that takes value as Any returns KotlinType:
    Let type_name be "Any"
    If value is String:
    Set type_name to "String"
    Otherwise if value is Integer:
    Set type_name to "Int"
    Otherwise if value is Float:
    Set type_name to "Double"
    Otherwise if value is Boolean:
    Set type_name to "Boolean"
    Return KotlinType with:
    name as type_name,
    package_name as "kotlin",
    is_nullable as False,
    type_parameters as new List,
    supertypes as new List,
    annotations as new List,
    kind as KotlinTypeKind::Class

Process convert_java_error_to_kotlin that takes java_result as Any returns KotlinResult[Any]:
Note: Convert Java interop errors to Kotlin errors
    Return KotlinResult::ExecutionError with exception KotlinException with:
    exception_class as "RuntimeException",
    message as "Java execution error",
    stack_trace as new List,
    cause as Empty,
    suppressed as new List

Process generate_unique_id that takes returns String:
    Import "../../uuid" as UUID
    Return UUID::generate()

Process generate_coroutine_id that takes returns String:
    Import "../../uuid" as UUID
    Return "kotlin_coroutine_" + UUID::generate()

Process generate_job_id that takes returns String:
    Import "../../uuid" as UUID
    Return "kotlin_job_" + UUID::generate()

Process register_kotlin_coroutine that takes coroutine_id as String and coroutine as KotlinCoroutine returns Nothing:
    If global_kotlin_coroutines is Empty:
    Set global_kotlin_coroutines to new Dictionary
    Set global_kotlin_coroutines[coroutine_id] to coroutine

Process update_kotlin_coroutine_state that takes coroutine_id as String and new_state as KotlinJobState returns Nothing:
    If global_kotlin_coroutines is not Empty and Collections::contains_key(global_kotlin_coroutines, coroutine_id):
    Let coroutine be global_kotlin_coroutines[coroutine_id]
    Set coroutine.job.state to new_state If new_state is KotlinJobState::Completed:
    Set coroutine.is_completed to True
    Set coroutine.is_active to False
    Otherwise if new_state is KotlinJobState::Cancelled:
    Set coroutine.is_cancelled to True
    Set coroutine.is_active to False

Process extract_output_path that takes compiler_output as String returns String:
Note: Extract output path from compiler output
    Return OS::get_temp_directory() + "/kotlin_output"

Note: Global state
Let global_kotlin_runtime as Integer
Let kotlin_runtime_initialized as Boolean = False
Let global_kotlin_coroutines as Optional[Dictionary[String, KotlinCoroutine]] = Empty

Note: High-level convenience functions
Process run_kotlin_code that takes source_code as String returns KotlinResult[Any]:
    Let default_config be KotlinRuntimeConfig with:
    kotlin_version as KotlinVersion::Kotlin1_9,
    jvm_config as KotlinJVMConfig with:
    jvm_target as KotlinJVMTarget::JVM_17,
    java_parameters as True,
    use_ir as True,
    include_runtime as True,
    no_stdlib as False,
    no_kotlin_stdlib as False,
    classpath as new List,
    module_path as new List,
    compiler_config as KotlinCompilerConfig with:
    language_version as KotlinVersion::Kotlin1_9,
    api_version as KotlinVersion::Kotlin1_9,
    progressive_mode as False,
    suppress_warnings as new List,
    all_warnings_as_errors as False,
    no_warn as False,
    verbose as False,
    script_templates as new List,
    coroutine_config as KotlinCoroutineConfig with:
    context_dispatcher as KotlinDispatcher::Default,
    exception_handler as Empty,
    debug_probes as False,
    stacktrace_recovery as True,
    native_config as Empty,
    android_config as Empty If not kotlin_runtime_initialized:
    Let init_result be initialize_kotlin_runtime(default_config)
    If init_result is not KotlinResult::Success:
    Return init_result
    Note: Wrap code in a main function for execution
    Let main_code be "fun main() {\n" + source_code + "\n}"
    Note: Compile the code
    Let compile_result be compile_kotlin_source(main_code, default_config.compiler_config)
    If compile_result is not KotlinResult::Success:
    Return compile_result
    Note: Execute the main function
    Let execute_result be execute_kotlin_main(compile_result.value, "MainKt", new List)
    Return execute_result

Process shutdown_kotlin_runtime that takes returns KotlinResult[Boolean]:
    If not kotlin_runtime_initialized:
    Return KotlinResult::Success with value True
    Note: Cancel all active coroutines
    If global_kotlin_coroutines is not Empty:
    Let coroutine_ids be Collections::list_keys(global_kotlin_coroutines)
    For Each coroutine_id in coroutine_ids:
    cancel_kotlin_coroutine(coroutine_id, Some with value "Runtime shutdown")
    Note: Shutdown Kotlin runtime
    Let shutdown_func be FFI::get_symbol(global_kotlin_runtime, "kotlin_runtime_shutdown")
    If shutdown_func is not Empty:
    Let shutdown_result be FFI::call_function(shutdown_func, [])
    If shutdown_result.return_code is not equal to 0:
    Return KotlinResult::RuntimeError with message "Failed to shutdown Kotlin runtime" and error_code shutdown_result.return_code Set kotlin_runtime_initialized to False
    Set global_kotlin_runtime to 0
    Set global_kotlin_coroutines to Empty Return KotlinResult::Success with value True