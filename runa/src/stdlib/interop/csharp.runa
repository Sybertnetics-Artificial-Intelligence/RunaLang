Note: Enhanced C# Interop Module for Runa
Note: Provides comprehensive .NET runtime integration with CoreCLR/MonoCLR support
Note: Zero-copy marshalling, async/await bridging, and managed/unmanaged memory coordination

Import "interop/ffi" as FFI
Import "collections" as Collections
Import "async" as Async
Import "concurrent" as Concurrent
Import "errors" as Errors
Import "os" as OS
Import "string" as String

Note: Core C# Runtime Types
Data Type DotNetRuntimeType:
    Case CoreCLR
    Case MonoCLR
    Case NativeAOT
    Case Framework

Data Type CSharpExecutionMode:
    Case JIT
    Case AOT
    Case ReadyToRun
    Case SingleFile

Data Type CSharpVersion:
    Case CSharp6
    Case CSharp7
    Case CSharp8
    Case CSharp9
    Case CSharp10
    Case CSharp11
    Case CSharp12

Data Type DotNetFrameworkVersion:
    Case Net48
    Case Net60
    Case Net70
    Case Net80
    Case Net90

Note: Enhanced Result Types
Data Type CSharpResult[T]:
    Case Success with value as T
    Case RuntimeError with message as String and error_code as Integer
    Case CompilationError with diagnostics as List[CompilerDiagnostic]
    Case ExecutionError with exception as CSharpException
    Case InteropError with details as String

Data Type CompilerDiagnostic:
    severity as DiagnosticSeverity
    message as String
    file as String
    line as Integer
    column as Integer
    error_code as String

Data Type DiagnosticSeverity:
    Case Error
    Case Warning
    Case Info
    Case Hidden

Data Type CSharpException:
    type_name as String
    message as String
    stack_trace as String
    inner_exception as Optional[CSharpException]
    help_link as Optional[String]
    source as Optional[String]

Note: Advanced Runtime Configuration
Data Type CSharpRuntimeConfig:
    runtime_type as DotNetRuntimeType
    execution_mode as CSharpExecutionMode
    framework_version as DotNetFrameworkVersion
    garbage_collection_mode as GCMode
    compilation_options as CSharpCompilationOptions
    assembly_load_context as Optional[String]
    startup_hooks as List[String]
    thread_pool_config as ThreadPoolConfig
    memory_limits as MemoryLimits

Data Type GCMode:
    Case Server
    Case Workstation
    Case Concurrent
    Case Background
    Case LowLatency

Data Type CSharpCompilationOptions:
    language_version as CSharpVersion
    optimization_level as OptimizationLevel
    debug_symbols as Boolean
    nullable_context as NullableContextOptions
    unsafe_code as Boolean
    preprocessor_symbols as List[String]
    warning_level as Integer
    treat_warnings_as_errors as Boolean

Data Type NullableContextOptions:
    Case Enable
    Case Disable
    Case Warnings
    Case Annotations

Data Type OptimizationLevel:
    Case Debug
    Case Release

Data Type ThreadPoolConfig:
    min_worker_threads as Integer
    max_worker_threads as Integer
    min_io_threads as Integer
    max_io_threads as Integer

Data Type MemoryLimits:
    heap_size_mb as Optional[Integer]
    stack_size_kb as Optional[Integer]
    large_object_heap_threshold as Optional[Integer]

Note: Assembly and Type Management
Data Type CSharpAssembly:
    name as String
    location as String
    version as String
    culture as String
    public_key_token as String
    is_loaded as Boolean
    types as Dictionary[String, CSharpType]
    metadata as AssemblyMetadata

Data Type AssemblyMetadata:
    target_framework as String
    runtime_version as String
    is_debug as Boolean
    processor_architecture as ProcessorArchitecture
    custom_attributes as Dictionary[String, Any]

Data Type ProcessorArchitecture:
    Case MSIL
    Case X86
    Case IA64
    Case Amd64
    Case Arm
    Case Arm64

Data Type CSharpType:
    full_name as String
    namespace as String
    name as String
    assembly_qualified_name as String
    is_public as Boolean
    is_sealed as Boolean
    is_abstract as Boolean
    is_interface as Boolean
    is_enum as Boolean
    is_value_type as Boolean
    is_generic as Boolean
    base_type as Optional[String]
    interfaces as List[String]
    methods as Dictionary[String, CSharpMethod]
    properties as Dictionary[String, CSharpProperty]
    fields as Dictionary[String, CSharpField]
    events as Dictionary[String, CSharpEvent]
    constructors as List[CSharpConstructor]

Data Type CSharpMethod:
    name as String
    return_type as String
    parameters as List[MethodParameter]
    is_static as Boolean
    is_public as Boolean
    is_virtual as Boolean
    is_abstract as Boolean
    is_override as Boolean
    is_async as Boolean
    generic_parameters as List[String]
    attributes as List[MethodAttribute]

Data Type MethodParameter:
    name as String
    type as String
    is_optional as Boolean
    default_value as Optional[Any]
    is_ref as Boolean
    is_out as Boolean
    is_params as Boolean

Data Type MethodAttribute:
    type_name as String
    arguments as Dictionary[String, Any]

Data Type CSharpProperty:
    name as String
    type as String
    can_read as Boolean
    can_write as Boolean
    is_static as Boolean
    is_public as Boolean
    getter as Optional[CSharpMethod]
    setter as Optional[CSharpMethod]

Data Type CSharpField:
    name as String
    type as String
    is_static as Boolean
    is_public as Boolean
    is_readonly as Boolean
    is_const as Boolean
    default_value as Optional[Any]

Data Type CSharpEvent:
    name as String
    handler_type as String
    is_static as Boolean
    is_public as Boolean

Data Type CSharpConstructor:
    parameters as List[MethodParameter]
    is_public as Boolean
    is_static as Boolean

Note: Enhanced Memory Management
Data Type ManagedObjectRef:
    handle as Integer
    type_info as CSharpType
    is_pinned as Boolean
    generation as Integer

Data Type UnmanagedMemoryBlock:
    address as Integer
    size as Integer
    is_aligned as Boolean
    allocator as String

Note: Async Integration Types
Data Type CSharpTask[T]:
    task_id as String
    result_type as String
    is_completed as Boolean
    is_faulted as Boolean
    is_cancelled as Boolean
    exception as Optional[CSharpException]
    continuation_token as Optional[String]

Data Type TaskSchedulerConfig:
    scheduler_type as TaskSchedulerType
    max_concurrency as Integer
    priority as TaskPriority

Data Type TaskSchedulerType:
    Case Default
    Case ThreadPool
    Case Current
    Case FromCurrentSynchronizationContext
    Case Custom with scheduler_name as String

Data Type TaskPriority:
    Case Low
    Case Normal
    Case High
    Case Critical

Note: Core Runtime Operations
Process initialize_dotnet_runtime that takes config as CSharpRuntimeConfig returns CSharpResult[Integer]:
    Import "interop/ffi" as FFI
    Import "os" as OS Let runtime_lib_path be locate_dotnet_runtime(config.runtime_type, config.framework_version)
    Let runtime_lib be FFI::load_library(runtime_lib_path) If runtime_lib is FFI::LibraryResult::LoadError:
    Return CSharpResult::RuntimeError with message "Failed to load .NET runtime library" and error_code 1001 Let coreclr_lib be runtime_lib
    Note: Initialize runtime properties
    Let runtime_properties be prepare_runtime_properties(config)
    Let property_keys be Collections::list_keys(runtime_properties)
    Let property_values be Collections::list_values(runtime_properties)
    Note: Call coreclr_initialize
    Let init_func be FFI::get_symbol(coreclr_lib, "coreclr_initialize")
    Let result be FFI::call_function(init_func, [
    OS::get_current_directory(),
    "RunaDotNetHost",
    property_keys.length,
    property_keys,
    property_values
    ]) If result.return_code is not equal to 0:
    Return CSharpResult::RuntimeError with message "Failed to initialize CoreCLR runtime" and error_code result.return_code
    Note: Store runtime handle globally
    Set global_runtime_handle to result.output_value
    Set runtime_initialized to True
    Note: Setup exception handling
    Let setup_result be setup_exception_handling(coreclr_lib)
    If setup_result is not CSharpResult::Success:
    Return setup_result
    Note: Initialize garbage collection
    Let gc_result be configure_garbage_collection(coreclr_lib, config.garbage_collection_mode)
    If gc_result is not CSharpResult::Success:
    Return gc_result
    Note: Setup thread pool
    Let thread_pool_result be configure_thread_pool(coreclr_lib, config.thread_pool_config)
    If thread_pool_result is not CSharpResult::Success:
    Return thread_pool_result Return CSharpResult::Success with value global_runtime_handle

Process prepare_runtime_properties that takes config as CSharpRuntimeConfig returns Dictionary[String, String]:
    Let properties be new Dictionary Set properties["TRUSTED_PLATFORM_ASSEMBLIES"] to get_trusted_platform_assemblies()
    Set properties["APP_PATHS"] to OS::get_current_directory()
    Set properties["APP_NI_PATHS"] to OS::get_current_directory()
    Set properties["NATIVE_DLL_SEARCH_DIRECTORIES"] to get_native_dll_paths()
    Note: GC Configuration
    If config.garbage_collection_mode is GCMode::Server:
    Set properties["System.GC.Server"] to "true"
    Otherwise if config.garbage_collection_mode is GCMode::Concurrent:
    Set properties["System.GC.Concurrent"] to "true"
    Note: Memory limits
    If config.memory_limits.heap_size_mb is not Empty:
    Set properties["System.GC.HeapHardLimit"] to String::from_integer(config.memory_limits.heap_size_mb.value multiplied by 1024 multiplied by 1024)
    Note: Thread pool configuration
    Set properties["System.Threading.ThreadPool.MinWorkerThreads"] to String::from_integer(config.thread_pool_config.min_worker_threads)
    Set properties["System.Threading.ThreadPool.MaxWorkerThreads"] to String::from_integer(config.thread_pool_config.max_worker_threads) Return properties

Process get_trusted_platform_assemblies that takes returns String:
    Import "os" as OS
    Let dotnet_dir be locate_dotnet_installation()
    Let runtime_dir be dotnet_dir + "/shared/Microsoft.NETCore.App/"
    Let versions be OS::list_directory(runtime_dir)
    Let latest_version be get_latest_version(versions)
    Let assemblies_dir be runtime_dir + latest_version + "/"
    Let assembly_files be OS::list_files_with_extension(assemblies_dir, ".dll")
    Let trusted_assemblies be String::join(assembly_files, ";") Return trusted_assemblies

Process locate_dotnet_runtime that takes runtime_type as DotNetRuntimeType and version as DotNetFrameworkVersion returns String:
    Import "os" as OS
    Let os_type be OS::get_operating_system() If os_type is equal to "windows":
    If runtime_type is DotNetRuntimeType::CoreCLR:
    Return locate_windows_coreclr(version)
    Otherwise if runtime_type is DotNetRuntimeType::Framework:
    Return locate_windows_framework(version)
    Otherwise if os_type is equal to "linux":
    Return locate_linux_dotnet(version)
    Otherwise if os_type is equal to "darwin":
    Return locate_macos_dotnet(version)
    Note: Fallback to system PATH
    Return "libcoreclr.so"

Process locate_windows_coreclr that takes version as DotNetFrameworkVersion returns String:
    Let program_files be OS::get_environment_variable("ProgramFiles")
    Let dotnet_path be program_files + "\\dotnet\\shared\\Microsoft.NETCore.App\\"
    If version is DotNetFrameworkVersion::Net80:
    Return dotnet_path + "8.0\\coreclr.dll"
    Otherwise if version is DotNetFrameworkVersion::Net70:
    Return dotnet_path + "7.0\\coreclr.dll"
    Otherwise if version is DotNetFrameworkVersion::Net60:
    Return dotnet_path + "6.0\\coreclr.dll"
    Return dotnet_path + "8.0\\coreclr.dll" Note: Default to latest

Process locate_linux_dotnet that takes version as DotNetFrameworkVersion returns String:
    Let system_paths be new List containing "/usr/share/dotnet", "/usr/lib/dotnet", "/opt/dotnet"
    For Each path in system_paths:
    Let coreclr_path be path + "/shared/Microsoft.NETCore.App/"
    If OS::directory_exists(coreclr_path):
    Let versions be OS::list_directory(coreclr_path)
    Let target_version be match_version_string(version, versions)
    If target_version is not Empty:
    Return coreclr_path + target_version + "/libcoreclr.so"
    Return "libcoreclr.so" Note: System library fallback

Process locate_macos_dotnet that takes version as DotNetFrameworkVersion returns String:
    Let dotnet_path be "/usr/local/share/dotnet/shared/Microsoft.NETCore.App/"
    If OS::directory_exists(dotnet_path):
    Let versions be OS::list_directory(dotnet_path)
    Let target_version be match_version_string(version, versions)
    If target_version is not Empty:
    Return dotnet_path + target_version + "/libcoreclr.dylib"
    Return "libcoreclr.dylib" Note: System library fallback

Process match_version_string that takes version as DotNetFrameworkVersion and available_versions as List[String] returns Optional[String]:
    If version is DotNetFrameworkVersion::Net80:
    Return find_version_prefix(available_versions, "8.0")
    Otherwise if version is DotNetFrameworkVersion::Net70:
    Return find_version_prefix(available_versions, "7.0")
    Otherwise if version is DotNetFrameworkVersion::Net60:
    Return find_version_prefix(available_versions, "6.0") Return Empty

Process find_version_prefix that takes versions as List[String] and prefix as String returns Optional[String]:
    For Each version in versions:
    If String::starts_with(version, prefix):
    Return Some with value version
    Return Empty

Note: Advanced Assembly Loading and Management
Process load_assembly that takes assembly_path as String returns CSharpResult[CSharpAssembly]:
    If not runtime_initialized:
    Return CSharpResult::RuntimeError with message "Runtime not initialized" and error_code 2001 Let load_func be FFI::get_symbol(global_runtime_lib, "coreclr_create_delegate")
    Note: Create assembly load delegate
    Let load_delegate be FFI::call_function(load_func, [
    global_runtime_handle,
    1, Note: Domain ID
    "System.Reflection.Assembly",
    "LoadFrom",
    assembly_path
    ]) If load_delegate.return_code is not equal to 0:
    Return CSharpResult::RuntimeError with message "Failed to create assembly load delegate" and error_code load_delegate.return_code
    Note: Call the delegate to load assembly
    Let assembly_result be FFI::call_delegate(load_delegate.delegate_ptr, [assembly_path])
    If assembly_result.return_code is not equal to 0:
    Return CSharpResult::RuntimeError with message "Failed to load assembly" and error_code assembly_result.return_code
    Note: Extract assembly metadata
    Let metadata be extract_assembly_metadata(assembly_result.assembly_handle)
    Let types be enumerate_assembly_types(assembly_result.assembly_handle) Let assembly be CSharpAssembly with:
    name as extract_assembly_name(assembly_result.assembly_handle),
    location as assembly_path,
    version as metadata.runtime_version,
    culture as "neutral",
    public_key_token as extract_public_key_token(assembly_result.assembly_handle),
    is_loaded as True,
    types as types,
    metadata as metadata Return CSharpResult::Success with value assembly

Process extract_assembly_metadata that takes assembly_handle as Integer returns AssemblyMetadata:
    Let get_metadata_func be create_clr_delegate("System.Reflection.Assembly", "GetMetadata")
    Let metadata_result be FFI::call_delegate(get_metadata_func, [assembly_handle]) Let metadata be AssemblyMetadata with:
    target_framework as extract_string_field(metadata_result.data, "TargetFramework"),
    runtime_version as extract_string_field(metadata_result.data, "RuntimeVersion"),
    is_debug as extract_boolean_field(metadata_result.data, "IsDebugBuild"),
    processor_architecture as parse_processor_architecture(extract_string_field(metadata_result.data, "ProcessorArchitecture")),
    custom_attributes as extract_custom_attributes(metadata_result.data) Return metadata

Process enumerate_assembly_types that takes assembly_handle as Integer returns Dictionary[String, CSharpType]:
    Let get_types_func be create_clr_delegate("System.Reflection.Assembly", "GetTypes")
    Let types_result be FFI::call_delegate(get_types_func, [assembly_handle]) Let type_dict be new Dictionary
    Let type_handles be types_result.type_array For Each type_handle in type_handles:
    Let type_info be extract_type_information(type_handle)
    Set type_dict[type_info.full_name] to type_info Return type_dict

Process extract_type_information that takes type_handle as Integer returns CSharpType:
    Let type_info_func be create_clr_delegate("System.Type", "GetTypeInfo")
    Let type_result be FFI::call_delegate(type_info_func, [type_handle]) Let methods be extract_type_methods(type_handle)
    Let properties be extract_type_properties(type_handle)
    Let fields be extract_type_fields(type_handle)
    Let events be extract_type_events(type_handle)
    Let constructors be extract_type_constructors(type_handle) Let csharp_type be CSharpType with:
    full_name as extract_string_field(type_result.data, "FullName"),
    namespace as extract_string_field(type_result.data, "Namespace"),
    name as extract_string_field(type_result.data, "Name"),
    assembly_qualified_name as extract_string_field(type_result.data, "AssemblyQualifiedName"),
    is_public as extract_boolean_field(type_result.data, "IsPublic"),
    is_sealed as extract_boolean_field(type_result.data, "IsSealed"),
    is_abstract as extract_boolean_field(type_result.data, "IsAbstract"),
    is_interface as extract_boolean_field(type_result.data, "IsInterface"),
    is_enum as extract_boolean_field(type_result.data, "IsEnum"),
    is_value_type as extract_boolean_field(type_result.data, "IsValueType"),
    is_generic as extract_boolean_field(type_result.data, "IsGenericType"),
    base_type as extract_optional_string_field(type_result.data, "BaseType"),
    interfaces as extract_string_array_field(type_result.data, "GetInterfaces"),
    methods as methods,
    properties as properties,
    fields as fields,
    events as events,
    constructors as constructors Return csharp_type

Note: Method Invocation with Advanced Features
Process invoke_static_method that takes type_name as String and method_name as String and parameters as List[Any] returns CSharpResult[Any]:
    If not runtime_initialized:
    Return CSharpResult::RuntimeError with message "Runtime not initialized" and error_code 2001
    Note: Get the type
    Let get_type_func be create_clr_delegate("System.Type", "GetType")
    Let type_result be FFI::call_delegate(get_type_func, [type_name]) If type_result.return_code is not equal to 0:
    Return CSharpResult::ExecutionError with exception CSharpException with:
    type_name as "TypeLoadException",
    message as "Could not load type: " + type_name,
    stack_trace as "",
    inner_exception as Empty,
    help_link as Empty,
    source as Empty
    Note: Get the method
    Let get_method_func be create_clr_delegate("System.Type", "GetMethod")
    Let method_result be FFI::call_delegate(get_method_func, [type_result.type_handle, method_name]) If method_result.return_code is not equal to 0:
    Return CSharpResult::ExecutionError with exception CSharpException with:
    type_name as "MethodNotFoundException",
    message as "Method not found: " + method_name + " in type " + type_name,
    stack_trace as "",
    inner_exception as Empty,
    help_link as Empty,
    source as Empty
    Note: Convert parameters to managed objects
    Let managed_params be convert_parameters_to_managed(parameters)
    Note: Invoke the method
    Let invoke_func be create_clr_delegate("System.Reflection.MethodInfo", "Invoke")
    Let invoke_result be FFI::call_delegate(invoke_func, [
    method_result.method_handle,
    0, Note: null instance for static method
    managed_params
    ]) If invoke_result.return_code is not equal to 0:
    Let exception be extract_clr_exception(invoke_result.exception_data)
    Return CSharpResult::ExecutionError with exception exception
    Note: Convert result back to Runa type
    Let result_value be convert_managed_to_runa(invoke_result.return_value)
    Return CSharpResult::Success with value result_value

Process invoke_instance_method that takes object_ref as ManagedObjectRef and method_name as String and parameters as List[Any] returns CSharpResult[Any]:
    If not runtime_initialized:
    Return CSharpResult::RuntimeError with message "Runtime not initialized" and error_code 2001
    Note: Get the method from object's type
    Let get_method_func be create_clr_delegate("System.Type", "GetMethod")
    Let method_result be FFI::call_delegate(get_method_func, [object_ref.type_info.full_name, method_name]) If method_result.return_code is not equal to 0:
    Return CSharpResult::ExecutionError with exception CSharpException with:
    type_name as "MethodNotFoundException",
    message as "Method not found: " + method_name,
    stack_trace as "",
    inner_exception as Empty,
    help_link as Empty,
    source as Empty
    Note: Convert parameters
    Let managed_params be convert_parameters_to_managed(parameters)
    Note: Invoke the method on the instance
    Let invoke_func be create_clr_delegate("System.Reflection.MethodInfo", "Invoke")
    Let invoke_result be FFI::call_delegate(invoke_func, [
    method_result.method_handle,
    object_ref.handle,
    managed_params
    ]) If invoke_result.return_code is not equal to 0:
    Let exception be extract_clr_exception(invoke_result.exception_data)
    Return CSharpResult::ExecutionError with exception exception Let result_value be convert_managed_to_runa(invoke_result.return_value)
    Return CSharpResult::Success with value result_value

Note: Advanced Async Integration
Process bridge_csharp_task that takes task_ref as ManagedObjectRef returns CSharpResult[CSharpTask[Any]]:
    If not runtime_initialized:
    Return CSharpResult::RuntimeError with message "Runtime not initialized" and error_code 2001
    Note: Extract task information
    Let get_task_info_func be create_clr_delegate("System.Threading.Tasks.Task", "GetTaskInfo")
    Let task_info_result be FFI::call_delegate(get_task_info_func, [task_ref.handle]) If task_info_result.return_code is not equal to 0:
    Return CSharpResult::ExecutionError with exception CSharpException with:
    type_name as "InvalidOperationException",
    message as "Failed to extract task information",
    stack_trace as "",
    inner_exception as Empty,
    help_link as Empty,
    source as Empty Let task_id be generate_task_id()
    Let task be CSharpTask with:
    task_id as task_id,
    result_type as extract_string_field(task_info_result.data, "ResultType"),
    is_completed as extract_boolean_field(task_info_result.data, "IsCompleted"),
    is_faulted as extract_boolean_field(task_info_result.data, "IsFaulted"),
    is_cancelled as extract_boolean_field(task_info_result.data, "IsCanceled"),
    exception as extract_optional_exception(task_info_result.data, "Exception"),
    continuation_token as Some with value task_id
    Note: Register task for monitoring
    register_managed_task(task_id, task_ref.handle) Return CSharpResult::Success with value task

Process await_csharp_task that takes task as CSharpTask[Any] returns CSharpResult[Any]:
    If task.is_completed:
    If task.is_faulted and task.exception is not Empty:
    Return CSharpResult::ExecutionError with exception task.exception.value
    Otherwise:
    Let result be get_task_result(task.task_id)
    Return CSharpResult::Success with value result
    Note: Setup async continuation
    Let continuation_result be setup_task_continuation(task.task_id)
    If continuation_result is not CSharpResult::Success:
    Return continuation_result
    Note: Wait for completion using Runa's async system
    Let completion_future be Async::create_future()
    register_task_completion_callback(task.task_id, completion_future) Let result be Async::await(completion_future) If result.is_error:
    Let exception be extract_clr_exception(result.error_data)
    Return CSharpResult::ExecutionError with exception exception Return CSharpResult::Success with value result.value

Process create_csharp_task that takes callable as String and parameters as List[Any] returns CSharpResult[CSharpTask[Any]]:
    If not runtime_initialized:
    Return CSharpResult::RuntimeError with message "Runtime not initialized" and error_code 2001
    Note: Create Task.Run delegate
    Let create_task_func be create_clr_delegate("System.Threading.Tasks.Task", "Run")
    Let managed_params be convert_parameters_to_managed(parameters)
    Note: Create the task
    Let task_result be FFI::call_delegate(create_task_func, [callable, managed_params]) If task_result.return_code is not equal to 0:
    Let exception be extract_clr_exception(task_result.exception_data)
    Return CSharpResult::ExecutionError with exception exception Let task_ref be ManagedObjectRef with:
    handle as task_result.task_handle,
    type_info as get_task_type_info(),
    is_pinned as False,
    generation as 0 Let bridged_task be bridge_csharp_task(task_ref)
    Return bridged_task

Note: Memory Management and Marshalling
Process pin_managed_object that takes object_ref as ManagedObjectRef returns CSharpResult[UnmanagedMemoryBlock]:
    If not runtime_initialized:
    Return CSharpResult::RuntimeError with message "Runtime not initialized" and error_code 2001 Let pin_func be create_clr_delegate("System.Runtime.InteropServices.GCHandle", "Alloc")
    Let pin_result be FFI::call_delegate(pin_func, [object_ref.handle, 3]) Note: Pinned mode If pin_result.return_code is not equal to 0:
    Return CSharpResult::RuntimeError with message "Failed to pin managed object" and error_code pin_result.return_code Let get_address_func be create_clr_delegate("System.Runtime.InteropServices.GCHandle", "AddrOfPinnedObject")
    Let address_result be FFI::call_delegate(get_address_func, [pin_result.handle]) If address_result.return_code is not equal to 0:
    Return CSharpResult::RuntimeError with message "Failed to get pinned object address" and error_code address_result.return_code Let size be calculate_object_size(object_ref.type_info)
    Let memory_block be UnmanagedMemoryBlock with:
    address as address_result.address,
    size as size,
    is_aligned as True,
    allocator as "GCHandle"
    Return CSharpResult::Success with value memory_block

Process convert_parameters_to_managed that takes parameters as List[Any] returns List[Integer]:
    Let managed_params be new List For Each param in parameters:
    If param is String:
    Let string_handle be create_managed_string(param)
    Add string_handle to managed_params
    Otherwise if param is Integer:
    Let int_handle be create_managed_int32(param)
    Add int_handle to managed_params
    Otherwise if param is Float:
    Let double_handle be create_managed_double(param)
    Add double_handle to managed_params
    Otherwise if param is Boolean:
    Let bool_handle be create_managed_boolean(param)
    Add bool_handle to managed_params
    Otherwise:
    Let object_handle be create_managed_object(param)
    Add object_handle to managed_params Return managed_params

Process convert_managed_to_runa that takes managed_handle as Integer returns Any:
    Let get_type_func be create_clr_delegate("System.Object", "GetType")
    Let type_result be FFI::call_delegate(get_type_func, [managed_handle]) Let type_name be extract_string_field(type_result.data, "FullName") If String::contains(type_name, "System.String"):
    Return extract_managed_string(managed_handle)
    Otherwise if String::contains(type_name, "System.Int32"):
    Return extract_managed_int32(managed_handle)
    Otherwise if String::contains(type_name, "System.Double"):
    Return extract_managed_double(managed_handle)
    Otherwise if String::contains(type_name, "System.Boolean"):
    Return extract_managed_boolean(managed_handle)
    Otherwise:
    Return extract_managed_object(managed_handle)

Note: Compilation and Code Generation
Process compile_csharp_source that takes source_code as String and options as CSharpCompilationOptions returns CSharpResult[CSharpAssembly]:
    If not runtime_initialized:
    Return CSharpResult::RuntimeError with message "Runtime not initialized" and error_code 2001
    Note: Create Roslyn compiler instance
    Let create_compiler_func be create_clr_delegate("Microsoft.CodeAnalysis.CSharp.CSharpCompilation", "Create")
    Let compilation_result be FFI::call_delegate(create_compiler_func, [
    "RunaGeneratedAssembly",
    prepare_compilation_options(options)
    ]) If compilation_result.return_code is not equal to 0:
    Return CSharpResult::CompilationError with diagnostics new List
    Note: Add source code
    Let add_source_func be create_clr_delegate("Microsoft.CodeAnalysis.CSharp.CSharpCompilation", "AddSyntaxTrees")
    Let syntax_tree be parse_csharp_source(source_code)
    Let add_result be FFI::call_delegate(add_source_func, [compilation_result.compilation_handle, syntax_tree])
    Note: Emit assembly to memory
    Let emit_func be create_clr_delegate("Microsoft.CodeAnalysis.CSharp.CSharpCompilation", "Emit")
    Let emit_result be FFI::call_delegate(emit_func, [add_result.compilation_handle]) If emit_result.return_code is not equal to 0:
    Let diagnostics be extract_compilation_diagnostics(emit_result.diagnostics_data)
    Return CSharpResult::CompilationError with diagnostics diagnostics
    Note: Load the emitted assembly
    Let assembly_bytes be extract_assembly_bytes(emit_result.assembly_stream)
    Let load_result be load_assembly_from_bytes(assembly_bytes) Return load_result

Process parse_csharp_source that takes source_code as String returns Integer:
    Let parse_func be create_clr_delegate("Microsoft.CodeAnalysis.CSharp.CSharpSyntaxTree", "ParseText")
    Let parse_result be FFI::call_delegate(parse_func, [source_code])
    Return parse_result.syntax_tree_handle

Note: Advanced Reflection and Metadata
Process get_type_by_name that takes type_name as String returns CSharpResult[CSharpType]:
    If not runtime_initialized:
    Return CSharpResult::RuntimeError with message "Runtime not initialized" and error_code 2001 Let get_type_func be create_clr_delegate("System.Type", "GetType")
    Let type_result be FFI::call_delegate(get_type_func, [type_name]) If type_result.return_code is not equal to 0:
    Return CSharpResult::ExecutionError with exception CSharpException with:
    type_name as "TypeLoadException",
    message as "Could not load type: " + type_name,
    stack_trace as "",
    inner_exception as Empty,
    help_link as Empty,
    source as Empty Let type_info be extract_type_information(type_result.type_handle)
    Return CSharpResult::Success with value type_info

Process create_instance that takes type_name as String and constructor_args as List[Any] returns CSharpResult[ManagedObjectRef]:
    Let type_result be get_type_by_name(type_name)
    If type_result is not CSharpResult::Success:
    Return type_result Let type_info be type_result.value
    Let managed_args be convert_parameters_to_managed(constructor_args) Let create_instance_func be create_clr_delegate("System.Activator", "CreateInstance")
    Let instance_result be FFI::call_delegate(create_instance_func, [type_info.full_name, managed_args]) If instance_result.return_code is not equal to 0:
    Let exception be extract_clr_exception(instance_result.exception_data)
    Return CSharpResult::ExecutionError with exception exception Let object_ref be ManagedObjectRef with:
    handle as instance_result.instance_handle,
    type_info as type_info,
    is_pinned as False,
    generation as get_object_generation(instance_result.instance_handle) Return CSharpResult::Success with value object_ref

Note: Garbage Collection Integration
Process force_garbage_collection that takes generation as Optional[Integer] returns CSharpResult[Dictionary[String, Any]]:
    If not runtime_initialized:
    Return CSharpResult::RuntimeError with message "Runtime not initialized" and error_code 2001 Let gc_collect_func be create_clr_delegate("System.GC", "Collect") Let collect_result be Empty
    If generation is Empty:
    Set collect_result to FFI::call_delegate(gc_collect_func, [])
    Otherwise:
    Set collect_result to FFI::call_delegate(gc_collect_func, [generation.value]) If collect_result.return_code is not equal to 0:
    Return CSharpResult::RuntimeError with message "Failed to trigger garbage collection" and error_code collect_result.return_code
    Note: Get GC statistics
    Let get_memory_func be create_clr_delegate("System.GC", "GetTotalMemory")
    Let memory_result be FFI::call_delegate(get_memory_func, [False]) Let get_gen0_func be create_clr_delegate("System.GC", "CollectionCount")
    Let gen0_result be FFI::call_delegate(get_gen0_func, [0])
    Let gen1_result be FFI::call_delegate(get_gen0_func, [1])
    Let gen2_result be FFI::call_delegate(get_gen0_func, [2]) Let gc_stats be new Dictionary
    Set gc_stats["total_memory"] to memory_result.memory_bytes
    Set gc_stats["generation_0_collections"] to gen0_result.collection_count
    Set gc_stats["generation_1_collections"] to gen1_result.collection_count
    Set gc_stats["generation_2_collections"] to gen2_result.collection_count Return CSharpResult::Success with value gc_stats

Note: Exception Handling
Process setup_exception_handling that takes runtime_lib as Integer returns CSharpResult[Boolean]:
    Let set_handler_func be FFI::get_symbol(runtime_lib, "coreclr_set_error_writer")
    If set_handler_func is not Empty:
    Let handler_result be FFI::call_function(set_handler_func, [global_exception_handler])
    If handler_result.return_code is not equal to 0:
    Return CSharpResult::RuntimeError with message "Failed to set exception handler" and error_code handler_result.return_code Return CSharpResult::Success with value True

Process global_exception_handler that takes error_data as String returns Nothing:
Note: Log the exception details
    Import "logging" as Log
    Log::error("C# Runtime Exception: " + error_data)
    Note: Store for retrieval by calling code
    Set last_clr_exception to error_data

Process extract_clr_exception that takes exception_data as String returns CSharpException:
Note: Parse the exception data structure
    Let exception_lines be String::split(exception_data, "\n")
    Let type_line be exception_lines[0]
    Let message_line be exception_lines[1] Let exception_type be extract_exception_type(type_line)
    Let exception_message be extract_exception_message(message_line)
    Let stack_trace be String::join(exception_lines[2:], "\n") Let exception be CSharpException with:
    type_name as exception_type,
    message as exception_message,
    stack_trace as stack_trace,
    inner_exception as parse_inner_exception(exception_data) Note: Production exception parsing
    help_link as Empty,
    source as Empty Return exception

Note: Utility Functions
Process create_clr_delegate that takes type_name as String and method_name as String returns Integer:
    Let create_delegate_func be FFI::get_symbol(global_runtime_lib, "coreclr_create_delegate")
    Let delegate_result be FFI::call_function(create_delegate_func, [
    global_runtime_handle,
    1, Note: Domain ID
    type_name,
    method_name,
    "" Note: No specific assembly name
    ]) Return delegate_result.delegate_ptr

Process generate_task_id that takes returns String:
    Import "uuid" as UUID
    Return "csharp_task_" + UUID::generate()

Process register_managed_task that takes task_id as String and task_handle as Integer returns Nothing:
    If global_managed_tasks is Empty:
    Set global_managed_tasks to new Dictionary
    Set global_managed_tasks[task_id] to task_handle

Process get_task_result that takes task_id as String returns Any:
    If global_managed_tasks is Empty or not Collections::contains_key(global_managed_tasks, task_id):
    Return Empty Let task_handle be global_managed_tasks[task_id]
    Let get_result_func be create_clr_delegate("System.Threading.Tasks.Task", "Result")
    Let result_data be FFI::call_delegate(get_result_func, [task_handle]) Return convert_managed_to_runa(result_data.result_handle)

Note: Global state management
Let global_runtime_handle as Integer
Let runtime_initialized as Boolean = False
Let global_runtime_lib as Integer
Let global_managed_tasks as Optional[Dictionary[String, Integer]] = Empty
Let last_clr_exception as String = ""

Note: High-level convenience functions for common operations
Process run_csharp_code that takes source_code as String returns CSharpResult[Any]:
    Let default_config be CSharpRuntimeConfig with:
    runtime_type as DotNetRuntimeType::CoreCLR,
    execution_mode as CSharpExecutionMode::JIT,
    framework_version as DotNetFrameworkVersion::Net80,
    garbage_collection_mode as GCMode::Server,
    compilation_options as CSharpCompilationOptions with:
    language_version as CSharpVersion::CSharp12,
    optimization_level as OptimizationLevel::Release,
    debug_symbols as False,
    nullable_context as NullableContextOptions::Enable,
    unsafe_code as False,
    preprocessor_symbols as new List,
    warning_level as 4,
    treat_warnings_as_errors as False,
    assembly_load_context as Empty,
    startup_hooks as new List,
    thread_pool_config as ThreadPoolConfig with:
    min_worker_threads as 4,
    max_worker_threads as 100,
    min_io_threads as 4,
    max_io_threads as 100,
    memory_limits as MemoryLimits with:
    heap_size_mb as Empty,
    stack_size_kb as Empty,
    large_object_heap_threshold as Empty If not runtime_initialized:
    Let init_result be initialize_dotnet_runtime(default_config)
    If init_result is not CSharpResult::Success:
    Return init_result Let compile_result be compile_csharp_source(source_code, default_config.compilation_options)
    If compile_result is not CSharpResult::Success:
    Return compile_result
    Note: Look for Main method
    Let assembly be compile_result.value
    Let main_method be find_main_method(assembly)
    If main_method is Empty:
    Return CSharpResult::CompilationError with diagnostics new List containing CompilerDiagnostic with:
    severity as DiagnosticSeverity::Error,
    message as "No Main method found",
    file as "",
    line as 0,
    column as 0,
    error_code as "CS5001"
    Note: Execute Main method
    Let execution_result be invoke_static_method(main_method.type_name, "Main", new List)
    Return execution_result

Process shutdown_dotnet_runtime that takes returns CSharpResult[Boolean]:
    If not runtime_initialized:
    Return CSharpResult::Success with value True Let shutdown_func be FFI::get_symbol(global_runtime_lib, "coreclr_shutdown")
    Let shutdown_result be FFI::call_function(shutdown_func, [global_runtime_handle, 1]) Set runtime_initialized to False
    Set global_runtime_handle to 0 If shutdown_result.return_code is not equal to 0:
    Return CSharpResult::RuntimeError with message "Failed to shutdown runtime" and error_code shutdown_result.return_code Return CSharpResult::Success with value True