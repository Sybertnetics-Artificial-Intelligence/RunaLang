Note: Utility Functions
Process ensure_python_runtime_initialized returns PythonResult[PythonRuntime]:
    If global_python_runtime is equal to None:
        Let default_config be dict_utils.create_empty_dict
        Return initialize_python_runtime with config as default_config
    Else:
        Return PythonSuccess with value as global_python_runtime and metrics as create_empty_python_metrics

Process generate_runtime_id returns String:
    Return "py_runtime_" plus uuid_utils.generate_uuid

Process generate_module_id that takes name as String returns String:
    Return "py_module_" plus name plus "_" plus uuid_utils.generate_uuid

Process generate_object_id returns String:
    Return "py_obj_" plus uuid_utils.generate_uuid

Process generate_coroutine_id returns String:
    Return "py_coro_" plus uuid_utils.generate_uuid

Process generate_kernel_id returns String:
    Return "runa_kernel_" plus uuid_utils.generate_uuid

Process get_current_timestamp returns Float:
