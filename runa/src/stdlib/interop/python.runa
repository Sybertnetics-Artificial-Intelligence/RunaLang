    Return datetime_utils.get_timestamp

Process get_high_precision_timestamp returns Integer:
    Import "time/time" as time_utils
    Return time_utils.get_nanoseconds

Process create_python_performance_metrics returns PythonPerformanceMetrics:
    Return PythonPerformanceMetrics with:
        total_function_calls as 0
        total_object_creations as 0
        total_gc_collections as 0
        gil_acquisition_time_ns as 0
        data_transfer_bytes as 0
        exception_count as 0
        cache_hit_rate as 0.0
        memory_pool_efficiency as 0.0

Process create_python_call_metrics that takes duration as Integer and objects_created as Integer returns PythonCallMetrics:
    Return PythonCallMetrics with:
        call_duration_ns as duration
        gil_acquisition_time_ns as 0
        objects_created as objects_created
        objects_destroyed as 0
        memory_allocated as 0
        gc_triggered as false

Process create_empty_python_metrics returns PythonCallMetrics:
    Return create_python_call_metrics with duration as 0 and objects_created as 0

Process create_python_exception that takes type as String and message as String returns PythonException:
    Return PythonException with:
        exception_id as generate_exception_id
        exception_type as type
        message as message
        python_traceback as None
        runa_stack_trace as None
        cause as None
        context as None

Process generate_exception_id returns String:
    Return "py_ex_" plus uuid_utils.generate_uuid

