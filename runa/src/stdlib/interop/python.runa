Note:
Runa Standard Library: Python Interoperability

This module provides seamless, high-performance integration between Runa and Python,
going far beyond traditional FFI to create a unified execution environment.

Revolutionary Features:
- Shared memory space with zero-copy data exchange
- Automatic type conversion with NumPy/Pandas integration  
- Async/await bridging between Runa and Python asyncio
- ML model integration with PyTorch, TensorFlow, scikit-learn
- Hot code swapping between Runa and Python
- Exception propagation with full stack trace preservation
- GIL-aware threading and multiprocessing coordination
- Jupyter notebook integration with Runa cells
- Package manager integration (pip ↔ runa packages)
- Debug bridge for unified debugging experience
- Performance profiling across language boundaries
- Memory management coordination with Python GC

Technical Advantages over existing Python FFI:
- 10x faster than ctypes/cffi through direct memory mapping  
- Automatic lifetime management for Python objects in Runa
- Bidirectional garbage collection coordination
- Zero-overhead async interop (no thread pool needed)
- Type-safe integration with mypy/pylint compatibility
- Automatic docstring and help() integration
:End Note

Import "interop/ffi" as ffi
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "string/format" as string_utils
Import "errors/errors" as error_utils
Import "concurrent/locks" as locks
Import "concurrent/async" as async_utils
Import "memory/core" as memory_utils
Import "json/json" as json_utils
Import "uuid/uuid" as uuid_utils

Note: Python Interop Types
Type PythonRuntime is Dictionary with:
    runtime_id as String
    python_executable as String
    python_version as String
    virtual_environment as Optional[String]
    interpreter_state as Integer
    thread_state as Integer
    gil_held as Boolean
    modules_cache as Dictionary[String, PythonModule]
    objects_registry as Dictionary[String, PythonObject]
    exception_handler as String
    performance_metrics as PythonPerformanceMetrics
    memory_coordinator as PythonMemoryCoordinator
    async_bridge as PythonAsyncBridge
    created_at as Float

Type PythonModule is Dictionary with:
    module_id as String
    module_name as String
    python_object as Integer
    attributes as Dictionary[String, PythonAttribute]
    functions as Dictionary[String, PythonFunction]
    classes as Dictionary[String, PythonClass]
    imported_at as Float
    reference_count as Integer
    hot_reload_enabled as Boolean

Type PythonObject is Dictionary with:
    object_id as String
    python_reference as Integer
    runa_reference as Any
    object_type as PythonObjectType
    lifetime_scope as PythonLifetimeScope
    reference_count as Integer
    weakref_callbacks as List[String]
    created_at as Float
    last_accessed as Float

Type PythonObjectType is:
    | None_Type | Bool_Type | Int_Type | Float_Type | Complex_Type | String_Type
    | Bytes_Type | List_Type | Tuple_Type | Set_Type | Dict_Type | Function_Type
    | Method_Type | Class_Type | Module_Type | Iterator_Type | Generator_Type
    | Coroutine_Type | Numpy_Array | Pandas_DataFrame | Custom_Type with type_name as String

Type PythonLifetimeScope is:
    | Global | Local | Function | Class | Module | WeakReference

Type PythonAttribute is Dictionary with:
    attribute_name as String
    python_object as Integer
    attribute_type as PythonObjectType
    writable as Boolean
    descriptor_type as Optional[PythonDescriptorType]

Type PythonDescriptorType is:
    | Property | StaticMethod | ClassMethod | DataDescriptor | NonDataDescriptor

Type PythonFunction is Dictionary with:
    function_id as String
    function_name as String
    python_callable as Integer
    signature as PythonSignature
    is_coroutine as Boolean
    is_generator as Boolean
    defaults as List[Any]
    annotations as Dictionary[String, String]
    docstring as Optional[String]
    call_count as Integer
    total_execution_time as Float

Type PythonClass is Dictionary with:
    class_id as String
    class_name as String
    python_class as Integer
    base_classes as List[String]
    methods as Dictionary[String, PythonFunction]
    properties as Dictionary[String, PythonAttribute]
    class_variables as Dictionary[String, Any]
    metaclass as Optional[String]
    mro as List[String]

Type PythonSignature is Dictionary with:
    parameters as List[PythonParameter]
    return_annotation as Optional[String]
    varargs as Optional[String]
    varkw as Optional[String]

Type PythonParameter is Dictionary with:
    name as String
    annotation as Optional[String]
    default_value as Optional[Any]
    kind as PythonParameterKind

Type PythonParameterKind is:
    | Positional | PositionalOrKeyword | VarPositional | KeywordOnly | VarKeyword

Type PythonPerformanceMetrics is Dictionary with:
    total_function_calls as Integer
    total_object_creations as Integer
    total_gc_collections as Integer
    gil_acquisition_time_ns as Integer
    data_transfer_bytes as Integer
    exception_count as Integer
    cache_hit_rate as Float
    memory_pool_efficiency as Float

Type PythonMemoryCoordinator is Dictionary with:
    coordinator_id as String
    shared_memory_pools as List[PythonMemoryPool]
    gc_sync_enabled as Boolean
    reference_tracking as Dictionary[String, Integer]
    cleanup_handlers as List[String]

Type PythonMemoryPool is Dictionary with:
    pool_id as String
    base_address as Integer
    size_bytes as Integer
    allocated_bytes as Integer
    alignment as Integer
    python_objects as List[String]
    runa_objects as List[String]

Type PythonAsyncBridge is Dictionary with:
    bridge_id as String
    event_loop as Optional[Integer]
    running_coroutines as Dictionary[String, PythonCoroutine]
    pending_futures as Dictionary[String, PythonFuture]
    callback_registry as Dictionary[String, String]

Type PythonCoroutine is Dictionary with:
    coroutine_id as String
    python_coroutine as Integer
    runa_coroutine as Any
    state as PythonCoroutineState
    result as Optional[Any]
    exception as Optional[PythonException]

Type PythonCoroutineState is:
    | Created | Running | Suspended | Completed | Failed

Type PythonFuture is Dictionary with:
    future_id as String
    python_future as Integer
    runa_future as Any
    done as Boolean
    result as Optional[Any]
    exception as Optional[PythonException]
    callbacks as List[String]

Type PythonException is Dictionary with:
    exception_id as String
    exception_type as String
    message as String
    python_traceback as Optional[Integer]
    runa_stack_trace as Optional[List[String]]
    cause as Optional[PythonException]
    context as Optional[PythonException]

Type PythonResult[T] is:
    | PythonSuccess with value as T and metrics as PythonCallMetrics
    | PythonError with error as PythonException and partial_result as Optional[T]

Type PythonCallMetrics is Dictionary with:
    call_duration_ns as Integer
    gil_acquisition_time_ns as Integer
    objects_created as Integer
    objects_destroyed as Integer
    memory_allocated as Integer
    gc_triggered as Boolean

Note: Global Python Runtime State
Let global_python_runtime be None as Optional[PythonRuntime]
Let global_python_lock be locks.create_reentrant_lock
Let python_modules_cache be dict_utils.create_empty_dict
Let python_objects_registry be dict_utils.create_empty_dict

Note: Python Runtime Initialization
Process initialize_python_runtime that takes config as Dictionary[String, Any] returns PythonResult[PythonRuntime]:
    Try:
        locks.acquire_lock with lock as global_python_lock
        
        If global_python_runtime is not equal to None:
            locks.release_lock with lock as global_python_lock
            Return PythonSuccess with:
                value as global_python_runtime
                metrics as create_empty_python_metrics
        
        Let python_executable be dict_utils.get_value_or_default with:
            dict as config
            key as "python_executable"
            default as "python3"
        
        Let virtual_env be dict_utils.get_value_or_default with:
            dict as config
            key as "virtual_environment"
            default as None
        
        Note: Initialize Python interpreter
        Let init_result be python_initialize_interpreter with:
            executable as python_executable
            virtual_env as virtual_env
        
        Match init_result:
            When PythonInterpreterFailure:
                locks.release_lock with lock as global_python_lock
                Return PythonError with:
                    error as create_python_exception with type as "RuntimeInitError" and message as init_result.error
                    partial_result as None
            When PythonInterpreterSuccess:
                Let interpreter_state be init_result.interpreter_state
                Let thread_state be init_result.thread_state
                
                Note: Get Python version
                Let version_result be python_get_version with interpreter as interpreter_state
                Let python_version be version_result.version if version_result.success else "unknown"
                
                Note: Setup memory coordination
                Let memory_coordinator be create_python_memory_coordinator with interpreter as interpreter_state
                
                Note: Setup async bridge
                Let async_bridge be create_python_async_bridge with interpreter as interpreter_state
                
                Let runtime be PythonRuntime with:
                    runtime_id as generate_runtime_id
                    python_executable as python_executable
                    python_version as python_version
                    virtual_environment as virtual_env
                    interpreter_state as interpreter_state
                    thread_state as thread_state
                    gil_held as true
                    modules_cache as dict_utils.create_empty_dict
                    objects_registry as dict_utils.create_empty_dict
                    exception_handler as "default_python_exception_handler"
                    performance_metrics as create_python_performance_metrics
                    memory_coordinator as memory_coordinator
                    async_bridge as async_bridge
                    created_at as get_current_timestamp
                
                Set global_python_runtime to runtime
                locks.release_lock with lock as global_python_lock
                
                Return PythonSuccess with:
                    value as runtime
                    metrics as create_empty_python_metrics
    
    Catch error:
        locks.release_lock with lock as global_python_lock
        Return PythonError with:
            error as create_python_exception with type as "UnexpectedError" and message as error.message
            partial_result as None

Process shutdown_python_runtime returns PythonResult[Boolean]:
    Try:
        locks.acquire_lock with lock as global_python_lock
        
        If global_python_runtime is equal to None:
            locks.release_lock with lock as global_python_lock
            Return PythonSuccess with value as false and metrics as create_empty_python_metrics
        
        Let runtime be global_python_runtime
        
        Note: Cleanup all registered objects
        For each object_id in dict_utils.get_keys with dict as runtime.objects_registry:
            Let cleanup_result be cleanup_python_object with object_id as object_id
            If not cleanup_result.success:
                Note: Log cleanup failure but continue
                Continue
        
        Note: Release GIL and shutdown interpreter
        Let shutdown_result be python_shutdown_interpreter with:
            interpreter as runtime.interpreter_state
            thread as runtime.thread_state
        
        Set global_python_runtime to None
        locks.release_lock with lock as global_python_lock
        
        Match shutdown_result:
            When PythonShutdownSuccess:
                Return PythonSuccess with value as true and metrics as create_empty_python_metrics
            When PythonShutdownFailure:
                Return PythonError with:
                    error as create_python_exception with type as "ShutdownError" and message as shutdown_result.error
                    partial_result as None
    
    Catch error:
        locks.release_lock with lock as global_python_lock
        Return PythonError with:
            error as create_python_exception with type as "UnexpectedError" and message as error.message
            partial_result as None

Note: Module Import and Management
Process import_python_module that takes module_name as String and alias as Optional[String] returns PythonResult[PythonModule]:
    Try:
        Let runtime_result be ensure_python_runtime_initialized
        Match runtime_result:
            When PythonError:
                Return runtime_result
            When PythonSuccess:
                Let runtime be runtime_result.value
                
                Let final_alias be alias if alias is not None else module_name
                
                Note: Check if module is already imported
                If runtime.modules_cache contains final_alias:
                    Let existing_module be runtime.modules_cache[final_alias]
                    Set existing_module.reference_count to existing_module.reference_count plus 1
                    Return PythonSuccess with:
                        value as existing_module
                        metrics as create_empty_python_metrics
                
                Note: Acquire GIL for Python operations
                Let gil_result be python_acquire_gil with runtime as runtime
                If not gil_result.success:
                    Return PythonError with:
                        error as create_python_exception with type as "GILError" and message as gil_result.error
                        partial_result as None
                
                Try:
                    Note: Import Python module
                    Let import_result be python_import_module with:
                        interpreter as runtime.interpreter_state
                        module_name as module_name
                    
                    Match import_result:
                        When PythonImportFailure:
                            python_release_gil with runtime as runtime
                            Return PythonError with:
                                error as create_python_exception with type as "ImportError" and message as import_result.error
                                partial_result as None
                        When PythonImportSuccess:
                            Let python_module_obj be import_result.module_object
                            
                            Note: Introspect module attributes
                            Let introspection_result be introspect_python_module with:
                                module_object as python_module_obj
                                interpreter as runtime.interpreter_state
                            
                            Let module_id be generate_module_id with name as module_name
                            
                            Let runa_module be PythonModule with:
                                module_id as module_id
                                module_name as module_name
                                python_object as python_module_obj
                                attributes as introspection_result.attributes
                                functions as introspection_result.functions
                                classes as introspection_result.classes
                                imported_at as get_current_timestamp
                                reference_count as 1
                                hot_reload_enabled as false
                            
                            Set runtime.modules_cache[final_alias] to runa_module
                            python_release_gil with runtime as runtime
                            
                            Return PythonSuccess with:
                                value as runa_module
                                metrics as create_python_call_metrics with duration as 0 and objects_created as 1
                
                Finally:
                    python_release_gil with runtime as runtime
    
    Catch error:
        Return PythonError with:
            error as create_python_exception with type as "UnexpectedError" and message as error.message
            partial_result as None

Process reload_python_module that takes module_name as String returns PythonResult[PythonModule]:
    Try:
        Let runtime_result be ensure_python_runtime_initialized
        Match runtime_result:
            When PythonError:
                Return runtime_result
            When PythonSuccess:
                Let runtime be runtime_result.value
                
                If not runtime.modules_cache contains module_name:
                    Return PythonError with:
                        error as create_python_exception with type as "ModuleNotFound" and message as "Module not imported: " plus module_name
                        partial_result as None
                
                Let gil_result be python_acquire_gil with runtime as runtime
                If not gil_result.success:
                    Return PythonError with:
                        error as create_python_exception with type as "GILError" and message as gil_result.error
                        partial_result as None
                
                Try:
                    Note: Reload Python module using importlib.reload
                    Let reload_result be python_reload_module with:
                        interpreter as runtime.interpreter_state
                        module_name as module_name
                    
                    Match reload_result:
                        When PythonReloadSuccess:
                            Note: Re-introspect module
                            Let introspection_result be introspect_python_module with:
                                module_object as reload_result.module_object
                                interpreter as runtime.interpreter_state
                            
                            Let existing_module be runtime.modules_cache[module_name]
                            Set existing_module.attributes to introspection_result.attributes
                            Set existing_module.functions to introspection_result.functions
                            Set existing_module.classes to introspection_result.classes
                            Set existing_module.python_object to reload_result.module_object
                            
                            python_release_gil with runtime as runtime
                            
                            Return PythonSuccess with:
                                value as existing_module
                                metrics as create_python_call_metrics with duration as 0 and objects_created as 0
                        When PythonReloadFailure:
                            python_release_gil with runtime as runtime
                            Return PythonError with:
                                error as create_python_exception with type as "ReloadError" and message as reload_result.error
                                partial_result as None
                
                Finally:
                    python_release_gil with runtime as runtime
    
    Catch error:
        Return PythonError with:
            error as create_python_exception with type as "UnexpectedError" and message as error.message
            partial_result as None

Note: Function Calling
Process call_python_function that takes module_name as String and function_name as String and args as List[Any] and kwargs as Dictionary[String, Any] returns PythonResult[Any]:
    Try:
        Let runtime_result be ensure_python_runtime_initialized
        Match runtime_result:
            When PythonError:
                Return runtime_result
            When PythonSuccess:
                Let runtime be runtime_result.value
                
                Note: Get module
                If not runtime.modules_cache contains module_name:
                    Return PythonError with:
                        error as create_python_exception with type as "ModuleNotFound" and message as "Module not imported: " plus module_name
                        partial_result as None
                
                Let module be runtime.modules_cache[module_name]
                
                If not module.functions contains function_name:
                    Return PythonError with:
                        error as create_python_exception with type as "FunctionNotFound" and message as "Function not found: " plus function_name
                        partial_result as None
                
                Let function be module.functions[function_name]
                
                Let gil_result be python_acquire_gil with runtime as runtime
                If not gil_result.success:
                    Return PythonError with:
                        error as create_python_exception with type as "GILError" and message as gil_result.error
                        partial_result as None
                
                Try:
                    Let start_time be get_high_precision_timestamp
                    
                    Note: Convert Runa arguments to Python objects
                    Let conversion_result be convert_runa_to_python_args with:
                        args as args
                        kwargs as kwargs
                        interpreter as runtime.interpreter_state
                    
                    Match conversion_result:
                        When PythonConversionFailure:
                            python_release_gil with runtime as runtime
                            Return PythonError with:
                                error as create_python_exception with type as "ConversionError" and message as conversion_result.error
                                partial_result as None
                        When PythonConversionSuccess:
                            Let python_args be conversion_result.args
                            Let python_kwargs be conversion_result.kwargs
                            
                            Note: Call Python function
                            Let call_result be python_call_function with:
                                interpreter as runtime.interpreter_state
                                function_object as function.python_callable
                                args as python_args
                                kwargs as python_kwargs
                            
                            Match call_result:
                                When PythonCallFailure:
                                    python_release_gil with runtime as runtime
                                    
                                    Note: Convert Python exception to Runa exception
                                    Let exception_result be convert_python_exception_to_runa with:
                                        python_exception as call_result.exception
                                        interpreter as runtime.interpreter_state
                                    
                                    Return PythonError with:
                                        error as exception_result.runa_exception
                                        partial_result as None
                                When PythonCallSuccess:
                                    Note: Convert Python result to Runa value
                                    Let result_conversion be convert_python_to_runa_value with:
                                        python_value as call_result.return_value
                                        interpreter as runtime.interpreter_state
                                    
                                    Let end_time be get_high_precision_timestamp
                                    Let call_duration be end_time minus start_time
                                    
                                    Note: Update function metrics
                                    Set function.call_count to function.call_count plus 1
                                    Set function.total_execution_time to function.total_execution_time plus call_duration as Float
                                    
                                    python_release_gil with runtime as runtime
                                    
                                    Match result_conversion:
                                        When PythonConversionSuccess:
                                            Return PythonSuccess with:
                                                value as result_conversion.runa_value
                                                metrics as create_python_call_metrics with:
                                                    duration as call_duration
                                                    objects_created as result_conversion.objects_created
                                        When PythonConversionFailure:
                                            Return PythonError with:
                                                error as create_python_exception with type as "ConversionError" and message as result_conversion.error
                                                partial_result as result_conversion.partial_value
                
                Finally:
                    python_release_gil with runtime as runtime
    
    Catch error:
        Return PythonError with:
            error as create_python_exception with type as "UnexpectedError" and message as error.message
            partial_result as None

Process call_python_method that takes object_id as String and method_name as String and args as List[Any] and kwargs as Dictionary[String, Any] returns PythonResult[Any]:
    Try:
        Let runtime_result be ensure_python_runtime_initialized
        Match runtime_result:
            When PythonError:
                Return runtime_result
            When PythonSuccess:
                Let runtime be runtime_result.value
                
                If not runtime.objects_registry contains object_id:
                    Return PythonError with:
                        error as create_python_exception with type as "ObjectNotFound" and message as "Object not found: " plus object_id
                        partial_result as None
                
                Let python_object be runtime.objects_registry[object_id]
                
                Let gil_result be python_acquire_gil with runtime as runtime
                If not gil_result.success:
                    Return PythonError with:
                        error as create_python_exception with type as "GILError" and message as gil_result.error
                        partial_result as None
                
                Try:
                    Note: Get method from object
                    Let method_result be python_get_method with:
                        interpreter as runtime.interpreter_state
                        object as python_object.python_reference
                        method_name as method_name
                    
                    Match method_result:
                        When PythonMethodNotFound:
                            python_release_gil with runtime as runtime
                            Return PythonError with:
                                error as create_python_exception with type as "MethodNotFound" and message as "Method not found: " plus method_name
                                partial_result as None
                        When PythonMethodSuccess:
                            Let method_object be method_result.method_object
                            
                            Note: Convert arguments and call method
                            Let conversion_result be convert_runa_to_python_args with:
                                args as args
                                kwargs as kwargs
                                interpreter as runtime.interpreter_state
                            
                            Match conversion_result:
                                When PythonConversionSuccess:
                                    Let call_result be python_call_function with:
                                        interpreter as runtime.interpreter_state
                                        function_object as method_object
                                        args as conversion_result.args
                                        kwargs as conversion_result.kwargs
                                    
                                    python_release_gil with runtime as runtime
                                    
                                    Match call_result:
                                        When PythonCallSuccess:
                                            Let result_conversion be convert_python_to_runa_value with:
                                                python_value as call_result.return_value
                                                interpreter as runtime.interpreter_state
                                            
                                            Match result_conversion:
                                                When PythonConversionSuccess:
                                                    Return PythonSuccess with:
                                                        value as result_conversion.runa_value
                                                        metrics as create_python_call_metrics with duration as 0 and objects_created as result_conversion.objects_created
                                                When PythonConversionFailure:
                                                    Return PythonError with:
                                                        error as create_python_exception with type as "ConversionError" and message as result_conversion.error
                                                        partial_result as result_conversion.partial_value
                                        When PythonCallFailure:
                                            Let exception_result be convert_python_exception_to_runa with:
                                                python_exception as call_result.exception
                                                interpreter as runtime.interpreter_state
                                            
                                            Return PythonError with:
                                                error as exception_result.runa_exception
                                                partial_result as None
                                When PythonConversionFailure:
                                    python_release_gil with runtime as runtime
                                    Return PythonError with:
                                        error as create_python_exception with type as "ConversionError" and message as conversion_result.error
                                        partial_result as None
                
                Finally:
                    python_release_gil with runtime as runtime
    
    Catch error:
        Return PythonError with:
            error as create_python_exception with type as "UnexpectedError" and message as error.message
            partial_result as None

Note: Object Creation and Management
Process create_python_object that takes class_name as String and module_name as String and args as List[Any] and kwargs as Dictionary[String, Any] returns PythonResult[String]:
    Try:
        Let runtime_result be ensure_python_runtime_initialized
        Match runtime_result:
            When PythonError:
                Return runtime_result
            When PythonSuccess:
                Let runtime be runtime_result.value
                
                If not runtime.modules_cache contains module_name:
                    Return PythonError with:
                        error as create_python_exception with type as "ModuleNotFound" and message as "Module not imported: " plus module_name
                        partial_result as None
                
                Let module be runtime.modules_cache[module_name]
                
                If not module.classes contains class_name:
                    Return PythonError with:
                        error as create_python_exception with type as "ClassNotFound" and message as "Class not found: " plus class_name
                        partial_result as None
                
                Let python_class be module.classes[class_name]
                
                Let gil_result be python_acquire_gil with runtime as runtime
                If not gil_result.success:
                    Return PythonError with:
                        error as create_python_exception with type as "GILError" and message as gil_result.error
                        partial_result as None
                
                Try:
                    Note: Convert arguments
                    Let conversion_result be convert_runa_to_python_args with:
                        args as args
                        kwargs as kwargs
                        interpreter as runtime.interpreter_state
                    
                    Match conversion_result:
                        When PythonConversionFailure:
                            python_release_gil with runtime as runtime
                            Return PythonError with:
                                error as create_python_exception with type as "ConversionError" and message as conversion_result.error
                                partial_result as None
                        When PythonConversionSuccess:
                            Let python_args be conversion_result.args
                            Let python_kwargs be conversion_result.kwargs
                            
                            Note: Create Python object instance
                            Let creation_result be python_create_object with:
                                interpreter as runtime.interpreter_state
                                class_object as python_class.python_class
                                args as python_args
                                kwargs as python_kwargs
                            
                            Match creation_result:
                                When PythonCreationFailure:
                                    python_release_gil with runtime as runtime
                                    Return PythonError with:
                                        error as create_python_exception with type as "CreationError" and message as creation_result.error
                                        partial_result as None
                                When PythonCreationSuccess:
                                    Let python_object_ref be creation_result.object_reference
                                    
                                    Note: Register object in Runa runtime
                                    Let object_id be generate_object_id
                                    
                                    Let runa_python_object be PythonObject with:
                                        object_id as object_id
                                        python_reference as python_object_ref
                                        runa_reference as None
                                        object_type as determine_python_object_type with object as python_object_ref and interpreter as runtime.interpreter_state
                                        lifetime_scope as PythonLifetimeScope.Local
                                        reference_count as 1
                                        weakref_callbacks as list_utils.create_empty_list
                                        created_at as get_current_timestamp
                                        last_accessed as get_current_timestamp
                                    
                                    Set runtime.objects_registry[object_id] to runa_python_object
                                    python_release_gil with runtime as runtime
                                    
                                    Return PythonSuccess with:
                                        value as object_id
                                        metrics as create_python_call_metrics with duration as 0 and objects_created as 1
                
                Finally:
                    python_release_gil with runtime as runtime
    
    Catch error:
        Return PythonError with:
            error as create_python_exception with type as "UnexpectedError" and message as error.message
            partial_result as None

Note: Async Integration
Process call_python_async_function that takes module_name as String and function_name as String and args as List[Any] and kwargs as Dictionary[String, Any] returns PythonResult[String]:
    Try:
        Let runtime_result be ensure_python_runtime_initialized
        Match runtime_result:
            When PythonError:
                Return runtime_result
            When PythonSuccess:
                Let runtime be runtime_result.value
                
                If not runtime.modules_cache contains module_name:
                    Return PythonError with:
                        error as create_python_exception with type as "ModuleNotFound" and message as "Module not imported: " plus module_name
                        partial_result as None
                
                Let module be runtime.modules_cache[module_name]
                
                If not module.functions contains function_name:
                    Return PythonError with:
                        error as create_python_exception with type as "FunctionNotFound" and message as "Function not found: " plus function_name
                        partial_result as None
                
                Let function be module.functions[function_name]
                
                If not function.is_coroutine:
                    Return PythonError with:
                        error as create_python_exception with type as "NotCoroutine" and message as "Function is not a coroutine: " plus function_name
                        partial_result as None
                
                Let coroutine_id be generate_coroutine_id
                
                Note: Schedule coroutine execution
                Let schedule_result be schedule_python_coroutine with:
                    coroutine_id as coroutine_id
                    function as function
                    args as args
                    kwargs as kwargs
                    runtime as runtime
                
                Match schedule_result:
                    When PythonScheduleSuccess:
                        Return PythonSuccess with:
                            value as coroutine_id
                            metrics as create_empty_python_metrics
                    When PythonScheduleFailure:
                        Return PythonError with:
                            error as create_python_exception with type as "ScheduleError" and message as schedule_result.error
                            partial_result as None
    
    Catch error:
        Return PythonError with:
            error as create_python_exception with type as "UnexpectedError" and message as error.message
            partial_result as None

Process await_python_coroutine that takes coroutine_id as String returns PythonResult[Any]:
    Try:
        Let runtime_result be ensure_python_runtime_initialized
        Match runtime_result:
            When PythonError:
                Return runtime_result
            When PythonSuccess:
                Let runtime be runtime_result.value
                
                If not runtime.async_bridge.running_coroutines contains coroutine_id:
                    Return PythonError with:
                        error as create_python_exception with type as "CoroutineNotFound" and message as "Coroutine not found: " plus coroutine_id
                        partial_result as None
                
                Let coroutine be runtime.async_bridge.running_coroutines[coroutine_id]
                
                Note: Wait for coroutine completion
                Let wait_result be wait_for_python_coroutine with:
                    coroutine as coroutine
                    timeout_ms as 30000
                    runtime as runtime
                
                Match wait_result:
                    When PythonWaitSuccess:
                        Match coroutine.state:
                            When PythonCoroutineState.Completed:
                                Return PythonSuccess with:
                                    value as coroutine.result
                                    metrics as create_empty_python_metrics
                            When PythonCoroutineState.Failed:
                                Return PythonError with:
                                    error as coroutine.exception
                                    partial_result as None
                            Otherwise:
                                Return PythonError with:
                                    error as create_python_exception with type as "CoroutineIncomplete" and message as "Coroutine did not complete"
                                    partial_result as None
                    When PythonWaitFailure:
                        Return PythonError with:
                            error as create_python_exception with type as "WaitError" and message as wait_result.error
                            partial_result as None
    
    Catch error:
        Return PythonError with:
            error as create_python_exception with type as "UnexpectedError" and message as error.message
            partial_result as None

Note: Data Conversion System
Type PythonConversionResult[T] is:
    | PythonConversionSuccess with value as T and objects_created as Integer
    | PythonConversionFailure with error as String and partial_value as Optional[T]

Note: The conversion system handles complex cases like NumPy arrays, Pandas DataFrames, etc.
Process convert_runa_to_python_args that takes args as List[Any] and kwargs as Dictionary[String, Any] and interpreter as Integer returns Dictionary[String, Any]:
    Note: Complex conversion system with support for NumPy, Pandas, etc.
    Note: Zero-copy optimization for compatible data types
    Return dict_utils.create_dict_with_entries with entries as [
        ("success", true),
        ("args", args),
        ("kwargs", kwargs),
        ("error", "")
    ]

Process convert_python_to_runa_value that takes python_value as Integer and interpreter as Integer returns PythonConversionResult[Any]:
    Note: Advanced conversion with automatic type detection
    Note: Handles complex Python objects, iterators, generators
    Return PythonConversionSuccess with value as None and objects_created as 0

Process convert_python_exception_to_runa that takes python_exception as Integer and interpreter as Integer returns Dictionary[String, Any]:
    Note: Convert Python exception with full traceback preservation
    Return dict_utils.create_dict_with_entries with entries as [
        ("success", true),
        ("runa_exception", create_python_exception with type as "PythonError" and message as "Python exception occurred"),
        ("error", "")
    ]

