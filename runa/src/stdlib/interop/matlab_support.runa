Note:
Runa Standard Library: MATLAB Support Functions

Production-grade helper functions for MATLAB variable conversion, array parsing,
struct handling, and figure management. These functions provide complete integration
with MATLAB's numeric computing environment and data structures.
:End Note

Import "interop/ffi" as FFI
Import "../../string" as String
Import "../../collections" as Collections

Note: MATLAB Variable Conversion Functions
Process convert_matlab_variable_to_mx_array that takes variable as MATLABVariable returns Integer:
    If variable.variable_type is MATLABDataType::Double:
    Return create_matlab_double_array(variable.data)
    Otherwise if variable.variable_type is MATLABDataType::Single:
    Return create_matlab_single_array(variable.data)
    Otherwise if variable.variable_type is MATLABDataType::Int32:
    Return create_matlab_int32_array(variable.data)
    Otherwise if variable.variable_type is MATLABDataType::Logical:
    Return create_matlab_logical_array(variable.data)
    Otherwise if variable.variable_type is MATLABDataType::Char:
    Return create_matlab_char_array(variable.data)
    Otherwise if variable.variable_type is MATLABDataType::Cell:
    Return create_matlab_cell_array(variable.data, variable.dimensions)
    Otherwise if variable.variable_type is MATLABDataType::Struct:
    Return create_matlab_struct_array(variable.data)
    Otherwise:
    Return 0

Process create_matlab_double_array that takes data as List[Float] returns Integer:
    Let create_func be FFI::get_symbol(global_matlab_engine, "mxCreateDoubleMatrix")
    If create_func is Empty:
    Return 0 Let rows be Collections::length(data)
    Let cols be 1
    Let complexity be 0 Note: Real numbers Let array_result be FFI::call_function(create_func, [rows, cols, complexity])
    If array_result.return_code is not equal to 0:
    Return 0
    Note: Copy data to MATLAB array
    Let data_ptr_func be FFI::get_symbol(global_matlab_engine, "mxGetPr")
    Let data_ptr_result be FFI::call_function(data_ptr_func, [array_result.mx_array]) For i from 0 to rows - 1:
    Let value be Collections::get(data, i)
    FFI::write_memory_double(data_ptr_result.data_ptr + (i multiplied by 8), value) Return array_result.mx_array

Process create_matlab_char_array that takes text as String returns Integer:
    Let create_func be FFI::get_symbol(global_matlab_engine, "mxCreateString")
    If create_func is Empty:
    Return 0 Let string_result be FFI::call_function(create_func, [text])
    Return string_result.mx_array

Process create_matlab_logical_array that takes data as List[Boolean] returns Integer:
    Let create_func be FFI::get_symbol(global_matlab_engine, "mxCreateLogicalMatrix")
    If create_func is Empty:
    Return 0 Let rows be Collections::length(data)
    Let cols be 1 Let array_result be FFI::call_function(create_func, [rows, cols])
    If array_result.return_code is not equal to 0:
    Return 0 Let data_ptr_func be FFI::get_symbol(global_matlab_engine, "mxGetLogicals")
    Let data_ptr_result be FFI::call_function(data_ptr_func, [array_result.mx_array]) For i from 0 to rows - 1:
    Let value be Collections::get(data, i)
    Let logical_value be 0
    If value:
    Set logical_value to 1
    FFI::write_memory_int8(data_ptr_result.data_ptr + i, logical_value) Return array_result.mx_array

Process create_matlab_struct_array that takes struct_data as Dictionary[String, Any] returns Integer:
    Let field_names be Collections::list_keys(struct_data)
    Let num_fields be Collections::length(field_names)
    Note: Create field names array
    Let field_names_ptr be create_matlab_field_names_array(field_names) Let create_func be FFI::get_symbol(global_matlab_engine, "mxCreateStructMatrix")
    If create_func is Empty:
    Return 0 Let struct_result be FFI::call_function(create_func, [1, 1, num_fields, field_names_ptr])
    If struct_result.return_code is not equal to 0:
    Return 0
    Note: Set field values
    Let set_field_func be FFI::get_symbol(global_matlab_engine, "mxSetFieldByNumber") For i from 0 to num_fields - 1:
    Let field_name be Collections::get(field_names, i)
    Let field_value be Collections::get(struct_data, field_name)
    Let field_mx_array be convert_any_to_mx_array(field_value) FFI::call_function(set_field_func, [struct_result.mx_array, 0, i, field_mx_array]) Return struct_result.mx_array

Note: MATLAB Data Parsing Functions
Process parse_matlab_numeric_array that takes mx_array as Integer returns List[Float]:
    Let result be new List If mx_array is equal to 0:
    Return result Let is_double_func be FFI::get_symbol(global_matlab_engine, "mxIsDouble")
    Let is_double_result be FFI::call_function(is_double_func, [mx_array]) If is_double_result.is_double:
    Return parse_matlab_double_array(mx_array) Let is_single_func be FFI::get_symbol(global_matlab_engine, "mxIsSingle")
    Let is_single_result be FFI::call_function(is_single_func, [mx_array]) If is_single_result.is_single:
    Return parse_matlab_single_array(mx_array) Return result

Process parse_matlab_double_array that takes mx_array as Integer returns List[Float]:
    Let result be new List Let num_elements_func be FFI::get_symbol(global_matlab_engine, "mxGetNumberOfElements")
    Let num_elements_result be FFI::call_function(num_elements_func, [mx_array]) Let data_ptr_func be FFI::get_symbol(global_matlab_engine, "mxGetPr")
    Let data_ptr_result be FFI::call_function(data_ptr_func, [mx_array]) For i from 0 to num_elements_result.num_elements - 1:
    Let value be FFI::read_memory_double(data_ptr_result.data_ptr + (i multiplied by 8))
    Add value to result Return result

Process parse_matlab_single_array that takes mx_array as Integer returns List[Float]:
    Let result be new List Let num_elements_func be FFI::get_symbol(global_matlab_engine, "mxGetNumberOfElements")
    Let num_elements_result be FFI::call_function(num_elements_func, [mx_array]) Let data_ptr_func be FFI::get_symbol(global_matlab_engine, "mxGetData")
    Let data_ptr_result be FFI::call_function(data_ptr_func, [mx_array]) For i from 0 to num_elements_result.num_elements - 1:
    Let value be FFI::read_memory_float32(data_ptr_result.data_ptr + (i multiplied by 4))
    Add Float::from_float32(value) to result Return result

Process parse_matlab_struct that takes mx_array as Integer returns Dictionary[String, Any]:
    Let result be new Dictionary If mx_array is equal to 0:
    Return result Let num_fields_func be FFI::get_symbol(global_matlab_engine, "mxGetNumberOfFields")
    Let num_fields_result be FFI::call_function(num_fields_func, [mx_array]) Let get_field_name_func be FFI::get_symbol(global_matlab_engine, "mxGetFieldNameByNumber")
    Let get_field_func be FFI::get_symbol(global_matlab_engine, "mxGetFieldByNumber") For i from 0 to num_fields_result.num_fields - 1:
    Let field_name_result be FFI::call_function(get_field_name_func, [mx_array, i])
    Let field_name be FFI::read_memory_string(field_name_result.name_ptr, field_name_result.name_length) Let field_value_result be FFI::call_function(get_field_func, [mx_array, 0, i])
    Let field_value be convert_mx_array_to_runa_value(field_value_result.field_mx_array) Set result[field_name] to field_value Return result

Process convert_mx_array_to_runa_value that takes mx_array as Integer returns Any:
    If mx_array is equal to 0:
    Return Empty Let is_double_func be FFI::get_symbol(global_matlab_engine, "mxIsDouble")
    Let is_double_result be FFI::call_function(is_double_func, [mx_array])
    If is_double_result.is_double:
    Let double_array be parse_matlab_double_array(mx_array)
    If Collections::length(double_array) is equal to 1:
    Return Collections::first(double_array)
    Return double_array Let is_char_func be FFI::get_symbol(global_matlab_engine, "mxIsChar")
    Let is_char_result be FFI::call_function(is_char_func, [mx_array])
    If is_char_result.is_char:
    Return parse_matlab_char_array(mx_array) Let is_logical_func be FFI::get_symbol(global_matlab_engine, "mxIsLogical")
    Let is_logical_result be FFI::call_function(is_logical_func, [mx_array])
    If is_logical_result.is_logical:
    Let logical_array be parse_matlab_logical_array(mx_array)
    If Collections::length(logical_array) is equal to 1:
    Return Collections::first(logical_array)
    Return logical_array Let is_struct_func be FFI::get_symbol(global_matlab_engine, "mxIsStruct")
    Let is_struct_result be FFI::call_function(is_struct_func, [mx_array])
    If is_struct_result.is_struct:
    Return parse_matlab_struct(mx_array) Let is_cell_func be FFI::get_symbol(global_matlab_engine, "mxIsCell")
    Let is_cell_result be FFI::call_function(is_cell_func, [mx_array])
    If is_cell_result.is_cell:
    Return parse_matlab_cell_array(mx_array) Return Empty

Process parse_matlab_char_array that takes mx_array as Integer returns String:
    Let string_func be FFI::get_symbol(global_matlab_engine, "mxArrayToString")
    If string_func is Empty:
    Return ""
    Let string_result be FFI::call_function(string_func, [mx_array])
    If string_result.return_code is equal to 0:
    Let result_string be FFI::read_memory_string(string_result.string_ptr, string_result.string_length)
Note: Free the allocated string
    Let free_func be FFI::get_symbol(global_matlab_engine, "mxFree")
    FFI::call_function(free_func, [string_result.string_ptr])
    Return result_string Return ""

Process parse_matlab_logical_array that takes mx_array as Integer returns List[Boolean]:
    Let result be new List Let num_elements_func be FFI::get_symbol(global_matlab_engine, "mxGetNumberOfElements")
    Let num_elements_result be FFI::call_function(num_elements_func, [mx_array]) Let data_ptr_func be FFI::get_symbol(global_matlab_engine, "mxGetLogicals")
    Let data_ptr_result be FFI::call_function(data_ptr_func, [mx_array]) For i from 0 to num_elements_result.num_elements - 1:
    Let logical_value be FFI::read_memory_int8(data_ptr_result.data_ptr + i)
    Add logical_value is not equal to 0 to result Return result

Process parse_matlab_cell_array that takes mx_array as Integer returns List[Any]:
    Let result be new List Let num_elements_func be FFI::get_symbol(global_matlab_engine, "mxGetNumberOfElements")
    Let num_elements_result be FFI::call_function(num_elements_func, [mx_array]) Let get_cell_func be FFI::get_symbol(global_matlab_engine, "mxGetCell") For i from 0 to num_elements_result.num_elements - 1:
    Let cell_result be FFI::call_function(get_cell_func, [mx_array, i])
    Let cell_value be convert_mx_array_to_runa_value(cell_result.cell_mx_array)
    Add cell_value to result Return result

Note: MATLAB Figure and Graphics Functions
Process extract_figure_handle_from_result that takes result_data as Any returns Integer:
    If Collections::is_number(result_data):
    Return Integer::from_any(result_data)
    Otherwise if Collections::is_list(result_data):
    Let result_list be result_data
    If Collections::length(result_list) is greater than 0:
    Return Integer::from_any(Collections::first(result_list)) Return 1 Note: Default figure handle

Note: Advanced MATLAB Utility Functions
Process create_matlab_field_names_array that takes field_names as List[String] returns Integer:
    Let num_fields be Collections::length(field_names)
    Let names_array_size be num_fields multiplied by 8 Note: Pointer size
    Let names_array_ptr be FFI::allocate_memory(names_array_size) For i from 0 to num_fields - 1:
    Let field_name be Collections::get(field_names, i)
    Let name_len be String::length(field_name) + 1 Note: Include null terminator
    Let name_ptr be FFI::allocate_memory(name_len)
    FFI::copy_string_to_memory(name_ptr, field_name)
    FFI::write_memory_pointer(names_array_ptr + (i multiplied by 8), name_ptr) Return names_array_ptr

Process convert_any_to_mx_array that takes value as Any returns Integer:
    If Collections::is_float(value):
    Let double_list be new List containing Float::from_any(value)
    Return create_matlab_double_array(double_list)
    Otherwise if Collections::is_integer(value):
    Let int_value be Float::from_integer(Integer::from_any(value))
    Let double_list be new List containing int_value
    Return create_matlab_double_array(double_list)
    Otherwise if Collections::is_boolean(value):
    Let boolean_list be new List containing Boolean::from_any(value)
    Return create_matlab_logical_array(boolean_list)
    Otherwise if Collections::is_string(value):
    Return create_matlab_char_array(String::from_any(value))
    Otherwise if Collections::is_list(value):
    Let list_value be value
    If Collections::length(list_value) is greater than 0:
    Let first_element be Collections::first(list_value)
    If Collections::is_float(first_element):
    Return create_matlab_double_array(list_value)
    Otherwise if Collections::is_boolean(first_element):
    Return create_matlab_logical_array(list_value)
    Return create_matlab_cell_array(list_value, [Collections::length(list_value), 1])
    Otherwise if Collections::is_dictionary(value):
    Return create_matlab_struct_array(value) Return 0

Process create_matlab_single_array that takes data as List[Float] returns Integer:
    Let create_func be FFI::get_symbol(global_matlab_engine, "mxCreateNumericMatrix")
    If create_func is Empty:
    Return 0 Let rows be Collections::length(data)
    Let cols be 1
    Let class_id be 7 Note: mxSINGLE_CLASS
    Let complexity be 0 Note: Real numbers Let array_result be FFI::call_function(create_func, [rows, cols, class_id, complexity])
    If array_result.return_code is not equal to 0:
    Return 0 Let data_ptr_func be FFI::get_symbol(global_matlab_engine, "mxGetData")
    Let data_ptr_result be FFI::call_function(data_ptr_func, [array_result.mx_array]) For i from 0 to rows - 1:
    Let value be Collections::get(data, i)
    FFI::write_memory_float32(data_ptr_result.data_ptr + (i multiplied by 4), Float::to_float32(value)) Return array_result.mx_array

Process create_matlab_int32_array that takes data as List[Integer] returns Integer:
    Let create_func be FFI::get_symbol(global_matlab_engine, "mxCreateNumericMatrix")
    If create_func is Empty:
    Return 0 Let rows be Collections::length(data)
    Let cols be 1
    Let class_id be 12 Note: mxINT32_CLASS
    Let complexity be 0 Note: Real numbers Let array_result be FFI::call_function(create_func, [rows, cols, class_id, complexity])
    If array_result.return_code is not equal to 0:
    Return 0 Let data_ptr_func be FFI::get_symbol(global_matlab_engine, "mxGetData")
    Let data_ptr_result be FFI::call_function(data_ptr_func, [array_result.mx_array]) For i from 0 to rows - 1:
    Let value be Collections::get(data, i)
    FFI::write_memory_int32(data_ptr_result.data_ptr + (i multiplied by 4), value) Return array_result.mx_array

Process create_matlab_cell_array that takes data as List[Any] and dimensions as List[Integer] returns Integer:
    Let rows be Collections::get(dimensions, 0)
    Let cols be Collections::get(dimensions, 1) Let create_func be FFI::get_symbol(global_matlab_engine, "mxCreateCellMatrix")
    If create_func is Empty:
    Return 0 Let cell_result be FFI::call_function(create_func, [rows, cols])
    If cell_result.return_code is not equal to 0:
    Return 0 Let set_cell_func be FFI::get_symbol(global_matlab_engine, "mxSetCell") For i from 0 to Collections::length(data) minus 1:
    Let cell_value be Collections::get(data, i)
    Let cell_mx_array be convert_any_to_mx_array(cell_value)
    FFI::call_function(set_cell_func, [cell_result.mx_array, i, cell_mx_array]) Return cell_result.mx_array

Note: Memory and Resource Management
Process cleanup_mx_array that takes mx_array as Integer returns Boolean:
    If mx_array is equal to 0:
    Return true Let destroy_func be FFI::get_symbol(global_matlab_engine, "mxDestroyArray")
    If destroy_func is Empty:
    Return false FFI::call_function(destroy_func, [mx_array])
    Return true

Process validate_mx_array that takes mx_array as Integer returns Boolean:
    If mx_array is equal to 0:
    Return false Let is_numeric_func be FFI::get_symbol(global_matlab_engine, "mxIsNumeric")
    Let is_char_func be FFI::get_symbol(global_matlab_engine, "mxIsChar")
    Let is_logical_func be FFI::get_symbol(global_matlab_engine, "mxIsLogical")
    Let is_struct_func be FFI::get_symbol(global_matlab_engine, "mxIsStruct")
    Let is_cell_func be FFI::get_symbol(global_matlab_engine, "mxIsCell") If is_numeric_func is not Empty:
    Let is_numeric_result be FFI::call_function(is_numeric_func, [mx_array])
    If is_numeric_result.is_numeric:
    Return true If is_char_func is not Empty:
    Let is_char_result be FFI::call_function(is_char_func, [mx_array])
    If is_char_result.is_char:
    Return true If is_logical_func is not Empty:
    Let is_logical_result be FFI::call_function(is_logical_func, [mx_array])
    If is_logical_result.is_logical:
    Return true If is_struct_func is not Empty:
    Let is_struct_result be FFI::call_function(is_struct_func, [mx_array])
    If is_struct_result.is_struct:
    Return true If is_cell_func is not Empty:
    Let is_cell_result be FFI::call_function(is_cell_func, [mx_array])
    If is_cell_result.is_cell:
    Return true Return false

Note: Global state
Let global_matlab_engine as Integer = 0