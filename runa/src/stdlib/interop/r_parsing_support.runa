Note:
Runa Standard Library: R Language Parsing and Conversion Support

Production-grade helper functions for parsing R output, converting between R and Runa types,
extracting statistical results, and handling R package metadata. These functions provide
complete integration with R's statistical computing environment and data structures.
:End Note

Import "interop/ffi" as FFI
Import "../../string" as String
Import "../../collections" as Collections

Note: R Package Description Parsing
Process parse_r_package_description that takes r_object as RObject returns Dictionary[String, Any]:
    Let package_details be new Dictionary
    Set package_details["version"] to "unknown"
    Set package_details["title"] to "R Package"
    Set package_details["description"] to ""
    Set package_details["author"] to "unknown"
    Set package_details["maintainer"] to "unknown"
    Set package_details["dependencies"] to new List
    Set package_details["library_path"] to ""
    If r_object.object_type is not equal to RObjectType::List:
    Return package_details
    Note: Parse package description list
    Let desc_data be r_object.data
    If Collections::contains_key(desc_data, "Version"):
    Set package_details["version"] to Collections::get(desc_data, "Version") If Collections::contains_key(desc_data, "Title"):
    Set package_details["title"] to Collections::get(desc_data, "Title") If Collections::contains_key(desc_data, "Description"):
    Set package_details["description"] to Collections::get(desc_data, "Description") If Collections::contains_key(desc_data, "Author"):
    Set package_details["author"] to Collections::get(desc_data, "Author") If Collections::contains_key(desc_data, "Maintainer"):
    Set package_details["maintainer"] to Collections::get(desc_data, "Maintainer") If Collections::contains_key(desc_data, "LibPath"):
    Set package_details["library_path"] to Collections::get(desc_data, "LibPath")
    Note: Parse dependencies
    If Collections::contains_key(desc_data, "Depends"):
    Let depends_str be Collections::get(desc_data, "Depends")
    Set package_details["dependencies"] to parse_r_dependency_string(depends_str) If Collections::contains_key(desc_data, "Imports"):
    Let imports_str be Collections::get(desc_data, "Imports")
    Let import_deps be parse_r_dependency_string(imports_str)
    For Each dep in import_deps:
    Add dep to package_details["dependencies"] Return package_details

Process extract_r_package_namespace that takes package_name as String returns RNamespace:
    Let namespace be RNamespace with:
    exports as new List,
    imports as new Dictionary,
    s3_methods as new Dictionary,
    s4_classes as new List If not r_runtime_initialized:
    Return namespace
    Note: Get package namespace
    Let ns_cmd be "getNamespace(\"" + package_name + "\")"
    Let ns_result be evaluate_r_expression(ns_cmd) If ns_result is not RResult::Success:
    Return namespace
    Note: Extract exports
    Let exports_cmd be "getNamespaceExports(\"" + package_name + "\")"
    Let exports_result be evaluate_r_expression(exports_cmd)
    If exports_result is RResult::Success:
    Set namespace.exports to convert_r_character_vector_to_list(exports_result.value)
    Note: Extract S3 methods
    Let s3_cmd be "as.list(.S3methods(envir = getNamespace(\"" + package_name + "\")))"
    Let s3_result be evaluate_r_expression(s3_cmd)
    If s3_result is RResult::Success:
    Set namespace.s3_methods to parse_r_s3_methods_list(s3_result.value)
    Note: Extract imports
    Let imports_cmd be "getNamespaceImports(\"" + package_name + "\")"
    Let imports_result be evaluate_r_expression(imports_cmd)
    If imports_result is RResult::Success:
    Set namespace.imports to parse_r_imports_list(imports_result.value) Return namespace

Process parse_r_dependency_string that takes dep_string as String returns List[String]:
    Let dependencies be new List If String::length(dep_string) is equal to 0:
    Return dependencies
    Note: Split by comma and clean up
    Let parts be String::split(dep_string, ",")
    For Each part in parts:
    Let cleaned be String::trim(part)
Note: Remove version constraints (e.g., "R (>= 3.5.0)" becomes "R")
    Let paren_pos be String::index_of(cleaned, "(")
    If paren_pos is not equal to -1:
    Set cleaned to String::trim(String::substring(cleaned, 0, paren_pos)) If String::length(cleaned) is greater than 0 and cleaned is not equal to "R":
    Add cleaned to dependencies Return dependencies

Note: R Statistical Output Parsing
Process parse_r_summary_output that takes r_object as RObject returns Dictionary[String, Float]:
    Let statistics be new Dictionary If r_object.object_type is RObjectType::Numeric:
Note: Summary statistics for numeric vector
    Let values be r_object.data
    If Collections::length(values) is greater than or equal to 6:
    Set statistics["min"] to Collections::get(values, 0)
    Set statistics["q1"] to Collections::get(values, 1)
    Set statistics["median"] to Collections::get(values, 2)
    Set statistics["mean"] to Collections::get(values, 3)
    Set statistics["q3"] to Collections::get(values, 4)
    Set statistics["max"] to Collections::get(values, 5) Return statistics

Process parse_r_lm_summary that takes r_object as RObject returns Dictionary[String, Any]:
    Let results be new Dictionary
    Set results["intercept"] to 0.0
    Set results["slope"] to 0.0
    Set results["r_squared"] to 0.0
    Set results["adjusted_r_squared"] to 0.0
    Set results["p_value"] to 1.0
    Set results["f_statistic"] to 0.0
    Set results["residual_se"] to 0.0
    Set results["coefficients"] to new List If r_object.object_type is not equal to RObjectType::List:
    Return results Let summary_data be r_object.data
    Note: Extract coefficients
    If Collections::contains_key(summary_data, "coefficients"):
    Let coef_matrix be Collections::get(summary_data, "coefficients")
    Let coefficients be parse_r_coefficient_matrix(coef_matrix)
    Set results["coefficients"] to coefficients If Collections::length(coefficients) is greater than or equal to 2:
    Set results["intercept"] to Collections::get(coefficients, 0)["estimate"]
    Set results["slope"] to Collections::get(coefficients, 1)["estimate"]
    Note: Extract R-squared values
    If Collections::contains_key(summary_data, "r.squared"):
    Set results["r_squared"] to Collections::get(summary_data, "r.squared") If Collections::contains_key(summary_data, "adj.r.squared"):
    Set results["adjusted_r_squared"] to Collections::get(summary_data, "adj.r.squared")
    Note: Extract F-statistic
    If Collections::contains_key(summary_data, "fstatistic"):
    Let f_stat_info be Collections::get(summary_data, "fstatistic")
    If Collections::length(f_stat_info) is greater than 0:
    Set results["f_statistic"] to Collections::get(f_stat_info, 0)
    Note: Extract residual standard error
    If Collections::contains_key(summary_data, "sigma"):
    Set results["residual_se"] to Collections::get(summary_data, "sigma") Return results

Process parse_r_coefficient_matrix that takes coef_data as Any returns List[Dictionary[String, Float]]:
    Let coefficients be new List
    Note: Assume coef_data is a matrix with columns: Estimate, Std. Error, t value, Pr(>|t|)
    If Collections::is_list(coef_data):
    Let matrix_data be coef_data
    Let row_count be Collections::length(matrix_data) divided by 4 Note: 4 columns For i from 0 to row_count - 1:
    Let coef_info be new Dictionary
    Set coef_info["estimate"] to Collections::get(matrix_data, i multiplied by 4)
    Set coef_info["std_error"] to Collections::get(matrix_data, (i multiplied by 4) + 1)
    Set coef_info["t_value"] to Collections::get(matrix_data, (i multiplied by 4) + 2)
    Set coef_info["p_value"] to Collections::get(matrix_data, (i multiplied by 4) + 3)
    Add coef_info to coefficients Return coefficients

Note: R Type Conversion Functions
Process convert_robject_to_runa_value that takes r_object as RObject returns Any:
    If r_object.object_type is RObjectType::Logical:
    Let logical_data be r_object.data
    If Collections::length(logical_data) is equal to 1:
    Return Collections::first(logical_data)
    Return logical_data Otherwise if r_object.object_type is RObjectType::Integer:
    Let integer_data be r_object.data
    If Collections::length(integer_data) is equal to 1:
    Return Collections::first(integer_data)
    Return integer_data Otherwise if r_object.object_type is RObjectType::Numeric:
    Let numeric_data be r_object.data
    If Collections::length(numeric_data) is equal to 1:
    Return Collections::first(numeric_data)
    Return numeric_data Otherwise if r_object.object_type is RObjectType::Character:
    Let character_data be r_object.data
    If Collections::length(character_data) is equal to 1:
    Return Collections::first(character_data)
    Return character_data Otherwise if r_object.object_type is RObjectType::List:
    Let list_data be r_object.data
    Let converted_dict be new Dictionary
    Let keys be Collections::list_keys(list_data)
    For Each key in keys:
    Let value be Collections::get(list_data, key)
    Set converted_dict[key] to convert_robject_to_runa_value(value)
    Return converted_dict Otherwise if r_object.object_type is RObjectType::DataFrame:
    Return convert_r_dataframe_to_runa_dict(r_object) Otherwise:
    Return r_object.data

Process convert_r_dataframe_to_runa_dict that takes df_object as RObject returns Dictionary[String, List[Any]]:
    Let df_dict be new Dictionary If df_object.object_type is not equal to RObjectType::DataFrame:
    Return df_dict
    Note: Extract columns from data frame
    Let df_data be df_object.data
    If Collections::contains_key(df_data, "columns"):
    Let columns be Collections::get(df_data, "columns")
    Let column_names be Collections::list_keys(columns) For Each col_name in column_names:
    Let column_data be Collections::get(columns, col_name)
    Set df_dict[col_name] to convert_robject_to_runa_value(column_data) Return df_dict

Process convert_r_character_vector_to_list that takes sexp as Integer returns List[String]:
    Let result be new List If sexp is equal to 0:
    Return result Let length_func be FFI::get_symbol(global_r_runtime, "Rf_length")
    If length_func is Empty:
    Return result Let length_result be FFI::call_function(length_func, [sexp])
    Let vector_length be length_result.length Let string_elt_func be FFI::get_symbol(global_r_runtime, "STRING_ELT")
    Let char_func be FFI::get_symbol(global_r_runtime, "R_CHAR") For i from 0 to vector_length - 1:
    Let elt_result be FFI::call_function(string_elt_func, [sexp, i])
    Let char_result be FFI::call_function(char_func, [elt_result.string_elt])
    Let char_str be FFI::read_memory_string(char_result.char_ptr, char_result.char_length)
    Add char_str to result Return result

Process convert_sexp_to_robject that takes sexp as Integer returns RObject:
    Let sexp_type be get_r_sexp_type(sexp) If sexp_type is equal to 10: Note: LGLSXP (logical)
    Let logical_data be extract_r_logical_vector(sexp)
    Return RObject with:
    object_type as RObjectType::Logical,
    data as logical_data,
    attributes as new Dictionary Otherwise if sexp_type is equal to 13: Note: INTSXP (integer)
    Let integer_data be extract_r_integer_vector(sexp)
    Return RObject with:
    object_type as RObjectType::Integer,
    data as integer_data,
    attributes as new Dictionary Otherwise if sexp_type is equal to 14: Note: REALSXP (numeric)
    Let numeric_data be extract_r_numeric_vector(sexp)
    Return RObject with:
    object_type as RObjectType::Numeric,
    data as numeric_data,
    attributes as new Dictionary Otherwise if sexp_type is equal to 16: Note: STRSXP (character)
    Let character_data be convert_r_character_vector_to_list(sexp)
    Return RObject with:
    object_type as RObjectType::Character,
    data as character_data,
    attributes as new Dictionary Otherwise if sexp_type is equal to 19: Note: VECSXP (list)
    If has_r_dataframe_attributes(sexp):
    Let df_data be extract_r_dataframe(sexp)
    Return RObject with:
    object_type as RObjectType::DataFrame,
    data as df_data,
    attributes as extract_r_attributes(sexp)
    Else:
    Let list_data be extract_r_list(sexp)
    Return RObject with:
    object_type as RObjectType::List,
    data as list_data,
    attributes as extract_r_attributes(sexp) Otherwise:
    Return RObject with:
    object_type as RObjectType::Unknown,
    data as Empty,
    attributes as new Dictionary

Note: Advanced R Parsing Support Functions
Process parse_r_s3_methods_list that takes methods_object as RObject returns Dictionary[String, List[String]]:
    Let methods_dict be new Dictionary If methods_object.object_type is RObjectType::List:
    Let methods_data be methods_object.data
    Let method_names be Collections::list_keys(methods_data) For Each method_name in method_names:
    Let method_list be Collections::get(methods_data, method_name)
    If Collections::is_list(method_list):
    Set methods_dict[method_name] to method_list Return methods_dict

Process parse_r_imports_list that takes imports_object as RObject returns Dictionary[String, Any]:
    Let imports_dict be new Dictionary If imports_object.object_type is RObjectType::List:
    Let imports_data be imports_object.data
    Let import_keys be Collections::list_keys(imports_data) For Each key in import_keys:
    Let import_info be Collections::get(imports_data, key)
    Set imports_dict[key] to import_info Return imports_dict

Process parse_r_numeric_vector that takes r_object as RObject returns List[Float]:
    Let numbers be new List If r_object.object_type is RObjectType::Numeric:
    Return r_object.data
    Otherwise if r_object.object_type is RObjectType::Integer:
    Let integers be r_object.data
    For Each int_val in integers:
    Add Float::from_integer(int_val) to numbers
    Return numbers Return numbers

Process get_r_object_name that takes r_object as RObject returns String:
Note: Generate a unique variable name for the R object
    Let timestamp be get_current_timestamp_ms()
    Return "runa_obj_" + String::from_integer(timestamp)

Note: R Runtime Helper Functions
Process get_r_sexp_type that takes sexp as Integer returns Integer:
    Let typeof_func be FFI::get_symbol(global_r_runtime, "TYPEOF")
    If typeof_func is Empty:
    Return 0 Let type_result be FFI::call_function(typeof_func, [sexp])
    Return type_result.sexp_type

Process has_r_dataframe_attributes that takes sexp as Integer returns Boolean:
    Let class_attr be extract_r_class(sexp)
    If class_attr is not Empty:
    Return class_attr.value is equal to "data.frame"
    Note: Check for data.frame specific attributes
    Let attributes be extract_r_attributes(sexp)
    Return Collections::contains_key(attributes, "row.names") and Collections::contains_key(attributes, "names")

Process extract_r_logical_vector that takes sexp as Integer returns List[Boolean]:
    Let result be new List Let length_func be FFI::get_symbol(global_r_runtime, "Rf_length")
    Let logical_func be FFI::get_symbol(global_r_runtime, "LOGICAL") Let length_result be FFI::call_function(length_func, [sexp])
    Let logical_result be FFI::call_function(logical_func, [sexp]) For i from 0 to length_result.length - 1:
    Let logical_val be FFI::read_memory_int32(logical_result.logical_ptr + (i multiplied by 4))
    Add logical_val is not equal to 0 to result Return result

Process extract_r_integer_vector that takes sexp as Integer returns List[Integer]:
    Let result be new List Let length_func be FFI::get_symbol(global_r_runtime, "Rf_length")
    Let integer_func be FFI::get_symbol(global_r_runtime, "INTEGER") Let length_result be FFI::call_function(length_func, [sexp])
    Let integer_result be FFI::call_function(integer_func, [sexp]) For i from 0 to length_result.length - 1:
    Let int_val be FFI::read_memory_int32(integer_result.integer_ptr + (i multiplied by 4))
    Add int_val to result Return result

Process extract_r_numeric_vector that takes sexp as Integer returns List[Float]:
    Let result be new List Let length_func be FFI::get_symbol(global_r_runtime, "Rf_length")
    Let real_func be FFI::get_symbol(global_r_runtime, "REAL") Let length_result be FFI::call_function(length_func, [sexp])
    Let real_result be FFI::call_function(real_func, [sexp]) For i from 0 to length_result.length - 1:
    Let double_val be FFI::read_memory_double(real_result.real_ptr + (i multiplied by 8))
    Add double_val to result Return result

Process extract_r_dataframe that takes sexp as Integer returns Dictionary[String, Any]:
    Let df_data be new Dictionary
    Set df_data["columns"] to new Dictionary
    Note: Extract column names
    Let names_attr be extract_r_attributes(sexp)
    Let column_names be new List
    If Collections::contains_key(names_attr, "names"):
    Set column_names to names_attr["names"].data
    Note: Extract each column
    Let length_func be FFI::get_symbol(global_r_runtime, "Rf_length")
    Let vector_elt_func be FFI::get_symbol(global_r_runtime, "VECTOR_ELT") Let length_result be FFI::call_function(length_func, [sexp])
    Let num_columns be length_result.length For i from 0 to num_columns - 1:
    Let col_sexp_result be FFI::call_function(vector_elt_func, [sexp, i])
    Let column_object be convert_sexp_to_robject(col_sexp_result.column_sexp) Let column_name be "V" + String::from_integer(i + 1) Note: Default name
    If i is less than Collections::length(column_names):
    Set column_name to Collections::get(column_names, i) Set df_data["columns"][column_name] to column_object Return df_data

Process extract_r_list that takes sexp as Integer returns Dictionary[String, Any]:
    Let list_data be new Dictionary Let length_func be FFI::get_symbol(global_r_runtime, "Rf_length")
    Let vector_elt_func be FFI::get_symbol(global_r_runtime, "VECTOR_ELT") Let length_result be FFI::call_function(length_func, [sexp])
    Let list_length be length_result.length
    Note: Get list names if available
    Let attributes be extract_r_attributes(sexp)
    Let element_names be new List
    If Collections::contains_key(attributes, "names"):
    Set element_names to attributes["names"].data For i from 0 to list_length - 1:
    Let elt_sexp_result be FFI::call_function(vector_elt_func, [sexp, i])
    Let element_object be convert_sexp_to_robject(elt_sexp_result.element_sexp) Let element_name be String::from_integer(i + 1) Note: Default numeric name
    If i is less than Collections::length(element_names):
    Set element_name to Collections::get(element_names, i) Set list_data[element_name] to element_object Return list_data

Process create_r_symbol that takes name as String returns Integer:
    Let install_func be FFI::get_symbol(global_r_runtime, "Rf_install")
    If install_func is Empty:
    Return 0 Let symbol_result be FFI::call_function(install_func, [name])
    Return symbol_result.symbol_sexp

Process calculate_variance that takes values as List[Float] returns Float:
    If Collections::length(values) is less than 2:
    Return 0.0 Let mean be calculate_mean(values)
    Let sum_squares be 0.0 For Each value in values:
    Let diff be value - mean
    Set sum_squares to sum_squares + (diff multiplied by diff) Return sum_squares divided by Float::from_integer(Collections::length(values) minus 1)

Process get_current_timestamp_ms that takes returns Integer:
Note: Return current timestamp in milliseconds
    Let current_time be get_system_time_microseconds()
    Return current_time divided by 1000

Note: Global state
Let global_r_runtime as Integer = 0
Let r_runtime_initialized as Boolean = false