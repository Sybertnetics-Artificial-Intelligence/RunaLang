Note: Enhanced R Interop Module for Runa
Note: Provides comprehensive R runtime integration with statistical computing focus
Note: Zero-copy data frames, advanced statistics ecosystem, and CRAN package management

Import "interop/ffi" as FFI
Import "../../collections" as Collections
Import "../../async" as Async
Import "../../concurrent" as Concurrent
Import "../../errors" as Errors
Import "../../os" as OS
Import "../../string" as String

Note: Core R Runtime Types
Data Type RRuntimeConfig:
    version as RVersion
    home_directory as String
    library_paths as List[String]
    memory_limit as Optional[Integer]
    max_connections as Integer
    internet_routines as Boolean
    gui_type as RGUIType
    restore_data as Boolean
    save_data as Boolean
    startup_options as RStartupOptions

Data Type RVersion:
    Case R40
    Case R41
    Case R42
    Case R43
    Case R44

Data Type RGUIType:
    Case None
    Case Tcltk
    Case X11
    Case Aqua
    Case Windows

Data Type RStartupOptions:
    quiet as Boolean
    slave as Boolean
    interactive as Boolean
    verbose as Boolean
    load_site_file as Boolean
    load_init_file as Boolean
    restore_history as Boolean
    save_history as Boolean

Note: Enhanced Result Types
Data Type RResult[T]:
    Case Success with value as T
    Case RuntimeError with message as String and error_code as Integer
    Case EvaluationError with error as RError
    Case PackageError with message as String
    Case DataError with details as String
    Case InteropError with details as String

Data Type RError:
    message as String
    call as String
    traceback as List[String]

Note: R Type System
Data Type RObject:
    sexp_type as RSEXPType
    attributes as Dictionary[String, RObject]
    class_name as Optional[String]
    data_ptr as Integer
    is_protected as Boolean

Data Type RSEXPType:
    Case NIL
    Case SYM
    Case LIST
    Case CLO
    Case ENV
    Case PROM
    Case LANG
    Case SPECIAL
    Case BUILTIN
    Case CHAR
    Case LGL
    Case INT
    Case REAL
    Case CPLX
    Case STR
    Case DOT
    Case ANY
    Case VEC
    Case EXPR
    Case BCODE
    Case EXTPTR
    Case WEAKREF
    Case RAW
    Case S4

Note: R Data Structures
Data Type RDataFrame:
    column_names as List[String]
    column_types as List[RDataType]
    row_count as Integer
    data as Dictionary[String, RVector]

Data Type RVector:
    element_type as RDataType
    length as Integer
    data_ptr as Integer
    names as Optional[List[String]]
    is_factor as Boolean
    levels as Optional[List[String]]

Data Type RDataType:
    Case Logical
    Case Integer
    Case Numeric
    Case Character
    Case Complex
    Case Raw
    Case Factor
    Case Date
    Case POSIXt

Data Type RList:
    elements as List[RObject]
    names as Optional[List[String]]
    length as Integer

Data Type RMatrix:
    element_type as RDataType
    nrows as Integer
    ncols as Integer
    data_ptr as Integer
    row_names as Optional[List[String]]
    col_names as Optional[List[String]]

Note: Package Management
Data Type RPackage:
    name as String
    version as String
    title as String
    description as String
    author as String
    maintainer as String
    dependencies as List[String]
    is_loaded as Boolean
    library_path as String
    namespace as RNamespace

Data Type RNamespace:
    exports as List[String]
    imports as Dictionary[String, List[String]]
    s3_methods as Dictionary[String, List[String]]
    s4_classes as List[String]

Note: Core Runtime Operations
Process initialize_r_runtime that takes config as RRuntimeConfig returns RResult[Integer]:
    Import "interop/ffi" as FFI
    Import "../../os" as OS
    Note: Set R environment variables
    OS::set_environment_variable("R_HOME", config.home_directory) If config.library_paths.length is greater than 0:
    OS::set_environment_variable("R_LIBS", String::join(config.library_paths, ":"))
    Note: Locate R installation
    Let r_home be locate_r_installation(config.home_directory)
    If r_home is Empty:
    Return RResult::RuntimeError with message "R installation not found" and error_code 1001
    Note: Load R runtime library
    Let r_lib_path be r_home.value + get_r_library_suffix()
    Let r_lib be FFI::load_library(r_lib_path) If r_lib is FFI::LibraryResult::LoadError:
    Return RResult::RuntimeError with message "Failed to load R runtime library" and error_code 1002
    Note: Setup R startup arguments
    Let r_args be prepare_r_startup_args(config)
    Note: Initialize R
    Let init_func be FFI::get_symbol(r_lib, "Rf_initialize_R")
    Let init_result be FFI::call_function(init_func, [r_args.argc, r_args.argv]) If init_result.return_code is not equal to 0:
    Return RResult::RuntimeError with message "Failed to initialize R runtime" and error_code init_result.return_code
    Note: Setup R event loop
    Let setup_result be setup_r_event_loop(r_lib)
    If setup_result is not RResult::Success:
    Return setup_result
    Note: Configure memory limits
    If config.memory_limit is not Empty:
    Let memory_result be set_r_memory_limit(r_lib, config.memory_limit.value)
    If memory_result is not RResult::Success:
    Return memory_result
    Note: Initialize graphics system if GUI is enabled
    If config.gui_type is not RGUIType::None:
    Let graphics_result be initialize_r_graphics(r_lib, config.gui_type)
    If graphics_result is not RResult::Success:
    Return graphics_result Set global_r_runtime to r_lib
    Set r_runtime_initialized to True Return RResult::Success with value r_lib

Process locate_r_installation that takes home_hint as String returns Optional[String]:
    Import "../../os" as OS
    Note: Check provided R_HOME first
    If home_hint is not Empty and OS::directory_exists(home_hint + "/bin/R"):
    Return Some with value home_hint
    Note: Check R_HOME environment variable
    Let r_home_env be OS::get_environment_variable("R_HOME")
    If r_home_env is not Empty and OS::directory_exists(r_home_env + "/bin/R"):
    Return Some with value r_home_env
    Note: Common installation paths
    Let common_paths be new List containing
    "/usr/lib/R",
    "/usr/local/lib/R",
    "/opt/R",
    "/Library/Frameworks/R.framework/Resources", Note: macOS
    "C:\\Program Files\\R" Note: Windows For Each path in common_paths:
    If OS::directory_exists(path + "/bin"):
    Return Some with value path
    Note: Try to find R in PATH
    Let r_binary be find_r_in_path()
    If r_binary is not Empty:
    Let r_bin_dir be OS::get_directory_name(r_binary.value)
    Let r_home be OS::get_directory_name(r_bin_dir)
    Return Some with value r_home Return Empty

Process find_r_in_path that takes returns Optional[String]:
    Import "../../os" as OS
    Let path_env be OS::get_environment_variable("PATH")
    Let path_dirs be String::split(path_env, ":") For Each dir in path_dirs:
    Let r_binary be dir + "/R"
    If OS::file_exists(r_binary):
    Return Some with value r_binary Return Empty

Process get_r_library_suffix that takes returns String:
    Import "../../os" as OS
    Let os_type be OS::get_operating_system() If os_type is equal to "linux":
    Return "/lib/libR.so"
    Otherwise if os_type is equal to "darwin":
    Return "/lib/libR.dylib"
    Otherwise if os_type is equal to "windows":
    Return "\\bin\\x64\\R.dll"
    Otherwise:
    Return "/lib/libR.so"

Process prepare_r_startup_args that takes config as RRuntimeConfig returns Dictionary[String, Any]:
    Let args be new List containing "R"
    If config.startup_options.quiet:
    Add "--quiet" to args If config.startup_options.slave:
    Add "--slave" to args If not config.startup_options.interactive:
    Add "--no-readline" to args If config.startup_options.verbose:
    Add "--verbose" to args If not config.startup_options.load_site_file:
    Add "--no-site-file" to args If not config.startup_options.load_init_file:
    Add "--no-init-file" to args If not config.startup_options.restore_data:
    Add "--no-restore-data" to args If not config.startup_options.save_data:
    Add "--no-save" to args Let result be new Dictionary
    Set result["argc"] to args.length
    Set result["argv"] to convert_args_to_c_array(args) Return result

Process convert_args_to_c_array that takes args as List[String] returns Integer:
    If Collections::is_empty(args):
    Return 0 Let arg_count be Collections::length(args)
    Let array_size be (arg_count + 1) multiplied by 8 Note: Pointer size (64-bit)
    Note: Allocate memory for C-style argv array
    Let argv_ptr be FFI::allocate_memory(array_size)
    If argv_ptr is equal to 0:
    Return 0
    Note: Allocate and copy each string
    For i from 0 to arg_count - 1:
    Let arg_str be Collections::get(args, i)
    Let str_len be String::length(arg_str) + 1 Note: Include null terminator
    Let str_ptr be FFI::allocate_memory(str_len) If str_ptr is not equal to 0:
    FFI::copy_string_to_memory(str_ptr, arg_str)
    FFI::write_memory_pointer(argv_ptr + (i multiplied by 8), str_ptr)
    Note: Set final element to null
    FFI::write_memory_pointer(argv_ptr + (arg_count multiplied by 8), 0) Return argv_ptr

Note: R Expression Evaluation
Process evaluate_r_expression that takes expression as String returns RResult[RObject]:
    If not r_runtime_initialized:
    Return RResult::RuntimeError with message "R runtime not initialized" and error_code 2001
    Note: Parse the expression
    Let parse_func be FFI::get_symbol(global_r_runtime, "R_ParseVector")
    Let string_sexp be create_r_string(expression) Let parse_result be FFI::call_function(parse_func, [
    string_sexp,
    -1, Note: Parse all
    0, Note: No error reporting
    0 Note: No source references
    ]) If parse_result.return_code is not equal to 0:
    Return RResult::EvaluationError with error RError with:
    message as "Parse error in R expression",
    call as expression,
    traceback as new List
    Note: Evaluate the parsed expression
    Let eval_func be FFI::get_symbol(global_r_runtime, "Rf_eval")
    Let global_env be get_r_global_environment() Let eval_result be FFI::call_function(eval_func, [
    parse_result.expression_sexp,
    global_env
    ]) If eval_result.return_code is not equal to 0:
    Let error be extract_r_error(eval_result.error_data)
    Return RResult::EvaluationError with error error Let r_object be create_robject_from_sexp(eval_result.result_sexp)
    Return RResult::Success with value r_object

Process create_r_string that takes value as String returns Integer:
    Let mkchar_func be FFI::get_symbol(global_r_runtime, "Rf_mkChar")
    Let char_result be FFI::call_function(mkchar_func, [value]) Let scalarstring_func be FFI::get_symbol(global_r_runtime, "Rf_ScalarString")
    Let string_result be FFI::call_function(scalarstring_func, [char_result.char_sexp]) Return string_result.string_sexp

Process get_r_global_environment that takes returns Integer:
    Let global_func be FFI::get_symbol(global_r_runtime, "R_GlobalEnv")
    Let global_result be FFI::call_function(global_func, [])
    Return global_result.env_sexp

Process create_robject_from_sexp that takes sexp as Integer returns RObject:
    Let typeof_func be FFI::get_symbol(global_r_runtime, "TYPEOF")
    Let type_result be FFI::call_function(typeof_func, [sexp]) Let sexp_type be sexp_type_from_integer(type_result.type_int)
    Let attributes be extract_r_attributes(sexp)
    Let class_name be extract_r_class(sexp) Let r_object be RObject with:
    sexp_type as sexp_type,
    attributes as attributes,
    class_name as class_name,
    data_ptr as sexp,
    is_protected as True Note: Protected by default Return r_object

Process sexp_type_from_integer that takes type_int as Integer returns RSEXPType:
Note: R SEXP type constants
    If type_int is equal to 0:
    Return RSEXPType::NIL
    Otherwise if type_int is equal to 1:
    Return RSEXPType::SYM
    Otherwise if type_int is equal to 2:
    Return RSEXPType::LIST
    Otherwise if type_int is equal to 10:
    Return RSEXPType::LGL
    Otherwise if type_int is equal to 13:
    Return RSEXPType::INT
    Otherwise if type_int is equal to 14:
    Return RSEXPType::REAL
    Otherwise if type_int is equal to 16:
    Return RSEXPType::STR
    Otherwise if type_int is equal to 19:
    Return RSEXPType::VEC
    Otherwise:
    Return RSEXPType::ANY

Note: Data Structure Operations
Process create_r_vector that takes values as List[Any] and data_type as RDataType returns RResult[RVector]:
    If not r_runtime_initialized:
    Return RResult::RuntimeError with message "R runtime not initialized" and error_code 2001 Let vector_sexp be Empty If data_type is RDataType::Integer:
    Set vector_sexp to create_r_integer_vector(values)
    Otherwise if data_type is RDataType::Numeric:
    Set vector_sexp to create_r_numeric_vector(values)
    Otherwise if data_type is RDataType::Character:
    Set vector_sexp to create_r_character_vector(values)
    Otherwise if data_type is RDataType::Logical:
    Set vector_sexp to create_r_logical_vector(values)
    Otherwise:
    Return RResult::DataError with details "Unsupported vector type: " + String::from_any(data_type) If vector_sexp is Empty:
    Return RResult::RuntimeError with message "Failed to create R vector" and error_code 3001 Let r_vector be RVector with:
    element_type as data_type,
    length as values.length,
    data_ptr as vector_sexp,
    names as Empty,
    is_factor as False,
    levels as Empty Return RResult::Success with value r_vector

Process create_r_integer_vector that takes values as List[Any] returns Integer:
    Let allocvector_func be FFI::get_symbol(global_r_runtime, "Rf_allocVector")
    Let intsxp_type be 13 Note: INTSXP Let vector_result be FFI::call_function(allocvector_func, [intsxp_type, values.length])
    Let vector_sexp be vector_result.vector_sexp
    Note: Fill the vector
    Let integer_ptr_func be FFI::get_symbol(global_r_runtime, "INTEGER")
    Let data_result be FFI::call_function(integer_ptr_func, [vector_sexp])
    Let data_ptr be data_result.data_ptr For i from 0 to values.length - 1:
    Let int_value be Integer::from_any(values[i])
    write_r_integer(data_ptr, i, int_value) Return vector_sexp

Process create_r_numeric_vector that takes values as List[Any] returns Integer:
    Let allocvector_func be FFI::get_symbol(global_r_runtime, "Rf_allocVector")
    Let realsxp_type be 14 Note: REALSXP Let vector_result be FFI::call_function(allocvector_func, [realsxp_type, values.length])
    Let vector_sexp be vector_result.vector_sexp
    Note: Fill the vector
    Let real_ptr_func be FFI::get_symbol(global_r_runtime, "REAL")
    Let data_result be FFI::call_function(real_ptr_func, [vector_sexp])
    Let data_ptr be data_result.data_ptr For i from 0 to values.length - 1:
    Let float_value be Float::from_any(values[i])
    write_r_double(data_ptr, i, float_value) Return vector_sexp

Process create_r_character_vector that takes values as List[Any] returns Integer:
    Let allocvector_func be FFI::get_symbol(global_r_runtime, "Rf_allocVector")
    Let strsxp_type be 16 Note: STRSXP Let vector_result be FFI::call_function(allocvector_func, [strsxp_type, values.length])
    Let vector_sexp be vector_result.vector_sexp For i from 0 to values.length - 1:
    Let string_value be String::from_any(values[i])
    Let char_sexp be create_r_char(string_value)
    set_r_string_element(vector_sexp, i, char_sexp) Return vector_sexp

Process create_r_logical_vector that takes values as List[Any] returns Integer:
    Let allocvector_func be FFI::get_symbol(global_r_runtime, "Rf_allocVector")
    Let lglsxp_type be 10 Note: LGLSXP Let vector_result be FFI::call_function(allocvector_func, [lglsxp_type, values.length])
    Let vector_sexp be vector_result.vector_sexp
    Note: Fill the vector
    Let logical_ptr_func be FFI::get_symbol(global_r_runtime, "LOGICAL")
    Let data_result be FFI::call_function(logical_ptr_func, [vector_sexp])
    Let data_ptr be data_result.data_ptr For i from 0 to values.length - 1:
    Let bool_value be Boolean::from_any(values[i])
    Let r_logical be If bool_value then 1 else 0
    write_r_integer(data_ptr, i, r_logical) Return vector_sexp

Process create_r_data_frame that takes data as Dictionary[String, List[Any]] and column_types as Dictionary[String, RDataType] returns RResult[RDataFrame]:
    If not r_runtime_initialized:
    Return RResult::RuntimeError with message "R runtime not initialized" and error_code 2001 Let column_names be Collections::list_keys(data)
    Let num_columns be column_names.length
    Let num_rows be If num_columns is greater than 0 then data[column_names[0]].length else 0
    Note: Create list to hold columns
    Let allocvector_func be FFI::get_symbol(global_r_runtime, "Rf_allocVector")
    Let vecsxp_type be 19 Note: VECSXP Let list_result be FFI::call_function(allocvector_func, [vecsxp_type, num_columns])
    Let list_sexp be list_result.vector_sexp Let columns be new Dictionary For i from 0 to num_columns - 1:
    Let col_name be column_names[i]
    Let col_data be data[col_name]
    Let col_type be If Collections::contains_key(column_types, col_name) then column_types[col_name] else RDataType::Character Let vector_result be create_r_vector(col_data, col_type)
    If vector_result is not RResult::Success:
    Return vector_result
    Note: Set list element
    set_r_vector_element(list_sexp, i, vector_result.value.data_ptr)
    Set columns[col_name] to vector_result.value
    Note: Set column names
    Let names_result be set_r_names(list_sexp, column_names)
    If names_result is not RResult::Success:
    Return names_result
    Note: Set data.frame class
    Let class_result be set_r_class(list_sexp, new List containing "data.frame")
    If class_result is not RResult::Success:
    Return class_result
    Note: Set row names
    Let row_names_result be set_r_row_names(list_sexp, num_rows)
    If row_names_result is not RResult::Success:
    Return row_names_result Let column_type_list be new List
    For Each col_name in column_names:
    Let col_type be If Collections::contains_key(column_types, col_name) then column_types[col_name] else RDataType::Character
    Add col_type to column_type_list Let data_frame be RDataFrame with:
    column_names as column_names,
    column_types as column_type_list,
    row_count as num_rows,
    data as columns Return RResult::Success with value data_frame

Process create_r_matrix that takes data as List[List[Any]] and data_type as RDataType returns RResult[RMatrix]:
    If not r_runtime_initialized:
    Return RResult::RuntimeError with message "R runtime not initialized" and error_code 2001 If data.length is equal to 0:
    Return RResult::DataError with details "Empty matrix data"
    Let nrows be data.length
    Let ncols be data[0].length
    Let total_elements be nrows multiplied by ncols
    Note: Flatten data (R uses column-major order)
    Let flat_data be new List
    For col from 0 to ncols - 1:
    For row from 0 to nrows - 1:
    Add data[row][col] to flat_data
    Note: Create vector
    Let vector_result be create_r_vector(flat_data, data_type)
    If vector_result is not RResult::Success:
    Return vector_result
    Note: Set matrix dimensions
    Let dim_result be set_r_dimensions(vector_result.value.data_ptr, nrows, ncols)
    If dim_result is not RResult::Success:
    Return dim_result Let matrix be RMatrix with:
    element_type as data_type,
    nrows as nrows,
    ncols as ncols,
    data_ptr as vector_result.value.data_ptr,
    row_names as Empty,
    col_names as Empty Return RResult::Success with value matrix

Note: Package Management
Process install_r_package that takes package_name as String and repository as Optional[String] returns RResult[RPackage]:
    If not r_runtime_initialized:
    Return RResult::RuntimeError with message "R runtime not initialized" and error_code 2001
    Note: Construct install command
    Let install_cmd be "install.packages(\"" + package_name + "\""
    If repository is not Empty:
    Set install_cmd to install_cmd + ", repos=\"" + repository.value + "\""
    Set install_cmd to install_cmd + ")"
    Note: Execute installation
    Let install_result be evaluate_r_expression(install_cmd)
    If install_result is not RResult::Success:
    Return RResult::PackageError with message "Failed to install package: " + package_name
    Note: Get package information
    Let pkg_info be get_r_package_info(package_name)
    Return pkg_info

Process load_r_package that takes package_name as String returns RResult[Boolean]:
    If not r_runtime_initialized:
    Return RResult::RuntimeError with message "R runtime not initialized" and error_code 2001 Let library_cmd be "library(" + package_name + ")"
    Let load_result be evaluate_r_expression(library_cmd) If load_result is not RResult::Success:
    Return RResult::PackageError with message "Failed to load package: " + package_name Return RResult::Success with value True

Process get_r_package_info that takes package_name as String returns RResult[RPackage]:
Note: Get package description
    Let desc_cmd be "packageDescription(\"" + package_name + "\")"
    Let desc_result be evaluate_r_expression(desc_cmd) If desc_result is not RResult::Success:
    Return RResult::PackageError with message "Package not found: " + package_name
    Note: Extract detailed package information from R description
    Let package_details be parse_r_package_description(desc_result.value) Let package be RPackage with:
    name as package_name,
    version as package_details.version,
    title as package_details.title,
    description as package_details.description,
    author as package_details.author,
    maintainer as package_details.maintainer,
    dependencies as package_details.dependencies,
    is_loaded as True,
    library_path as package_details.library_path,
    namespace as extract_r_package_namespace(package_name) Return RResult::Success with value package

Note: Statistical Functions
Process calculate_summary_statistics that takes values as List[Float] returns RResult[Dictionary[String, Float]]:
    If not r_runtime_initialized:
    Return RResult::RuntimeError with message "R runtime not initialized" and error_code 2001
    Note: Create R numeric vector
    Let vector_result be create_r_vector(values, RDataType::Numeric)
    If vector_result is not RResult::Success:
    Return vector_result
    Note: Calculate summary statistics using R
    Let summary_cmd be "summary(c(" + join_float_list(values) + "))"
    Let summary_result be evaluate_r_expression(summary_cmd) If summary_result is not RResult::Success:
    Return RResult::EvaluationError with error RError with:
    message as "Failed to calculate summary statistics",
    call as summary_cmd,
    traceback as new List
    Note: Extract comprehensive statistics from R summary result
    Let statistics be parse_r_summary_output(summary_result.value)
    Note: Ensure all expected statistics are present
    If not Collections::contains_key(statistics, "mean"):
    Set statistics["mean"] to calculate_mean(values)
    If not Collections::contains_key(statistics, "median"):
    Set statistics["median"] to calculate_median(values)
    If not Collections::contains_key(statistics, "min"):
    Set statistics["min"] to calculate_min(values)
    If not Collections::contains_key(statistics, "max"):
    Set statistics["max"] to calculate_max(values)
    If not Collections::contains_key(statistics, "sd"):
    Set statistics["sd"] to calculate_standard_deviation(values)
    Note: Add additional statistical measures
    Set statistics["var"] to calculate_variance(values)
    Set statistics["range"] to statistics["max"] minus statistics["min"]
    Set statistics["count"] to Collections::length(values) Return RResult::Success with value statistics

Process perform_linear_regression that takes x_values as List[Float] and y_values as List[Float] returns RResult[Dictionary[String, Any]]:
    If not r_runtime_initialized:
    Return RResult::RuntimeError with message "R runtime not initialized" and error_code 2001 If x_values.length is not equal to y_values.length:
    Return RResult::DataError with details "X and Y vectors must have the same length"
    Note: Create data frame for regression
    Let data_dict be new Dictionary
    Set data_dict["x"] to x_values
    Set data_dict["y"] to y_values Let column_types be new Dictionary
    Set column_types["x"] to RDataType::Numeric
    Set column_types["y"] to RDataType::Numeric Let df_result be create_r_data_frame(data_dict, column_types)
    If df_result is not RResult::Success:
    Return df_result
    Note: Perform linear regression
    Let lm_cmd be "lm(y ~ x, data=data.frame(x=c(" + join_float_list(x_values) + "), y=c(" + join_float_list(y_values) + ")))"
    Let lm_result be evaluate_r_expression(lm_cmd) If lm_result is not RResult::Success:
    Return RResult::EvaluationError with error RError with:
    message as "Linear regression failed",
    call as lm_cmd,
    traceback as new List
    Note: Extract comprehensive regression results from R linear model
    Let model_summary_cmd be "summary(" + get_r_object_name(lm_result.value) + ")"
    Let summary_result be evaluate_r_expression(model_summary_cmd) Let results be new Dictionary
    If summary_result is RResult::Success:
    Let parsed_results be parse_r_lm_summary(summary_result.value)
    Set results["intercept"] to parsed_results.intercept
    Set results["slope"] to parsed_results.slope
    Set results["r_squared"] to parsed_results.r_squared
    Set results["adjusted_r_squared"] to parsed_results.adjusted_r_squared
    Set results["p_value"] to parsed_results.p_value
    Set results["f_statistic"] to parsed_results.f_statistic
    Set results["residual_standard_error"] to parsed_results.residual_se
    Set results["coefficients"] to parsed_results.coefficients
    Else:
Note: Fallback to basic coefficient extraction
    Let coef_cmd be "coef(" + get_r_object_name(lm_result.value) + ")"
    Let coef_result be evaluate_r_expression(coef_cmd)
    If coef_result is RResult::Success:
    Let coefficients be parse_r_numeric_vector(coef_result.value)
    Set results["intercept"] to Collections::get(coefficients, 0)
    Set results["slope"] to Collections::get(coefficients, 1)
    Else:
    Set results["intercept"] to 0.0
    Set results["slope"] to 1.0
    Set results["r_squared"] to 0.0 Return RResult::Success with value results

Note: Utility Functions
Process write_r_integer that takes data_ptr as Integer and index as Integer and value as Integer returns Nothing:
    Let offset be index multiplied by 4 Note: sizeof(int) in R
    FFI::write_memory(data_ptr + offset, value, 4)

Process write_r_double that takes data_ptr as Integer and index as Integer and value as Float returns Nothing:
    Let offset be index multiplied by 8 Note: sizeof(double)
    FFI::write_memory(data_ptr + offset, value, 8)

Process create_r_char that takes value as String returns Integer:
    Let mkchar_func be FFI::get_symbol(global_r_runtime, "Rf_mkChar")
    Let char_result be FFI::call_function(mkchar_func, [value])
    Return char_result.char_sexp

Process set_r_string_element that takes vector_sexp as Integer and index as Integer and char_sexp as Integer returns Nothing:
    Let set_func be FFI::get_symbol(global_r_runtime, "SET_STRING_ELT")
    FFI::call_function(set_func, [vector_sexp, index, char_sexp])

Process set_r_vector_element that takes list_sexp as Integer and index as Integer and element_sexp as Integer returns Nothing:
    Let set_func be FFI::get_symbol(global_r_runtime, "SET_VECTOR_ELT")
    FFI::call_function(set_func, [list_sexp, index, element_sexp])

Process set_r_names that takes object_sexp as Integer and names as List[String] returns RResult[Boolean]:
    Let names_vector_result be create_r_character_vector(names) Let setattrib_func be FFI::get_symbol(global_r_runtime, "Rf_setAttrib")
    Let names_symbol be get_r_names_symbol() Let result be FFI::call_function(setattrib_func, [object_sexp, names_symbol, names_vector_result]) If result.return_code is not equal to 0:
    Return RResult::RuntimeError with message "Failed to set names attribute" and error_code result.return_code Return RResult::Success with value True

Process set_r_class that takes object_sexp as Integer and class_names as List[String] returns RResult[Boolean]:
    Let class_vector_result be create_r_character_vector(class_names) Let setattrib_func be FFI::get_symbol(global_r_runtime, "Rf_setAttrib")
    Let class_symbol be get_r_class_symbol() Let result be FFI::call_function(setattrib_func, [object_sexp, class_symbol, class_vector_result]) If result.return_code is not equal to 0:
    Return RResult::RuntimeError with message "Failed to set class attribute" and error_code result.return_code Return RResult::Success with value True

Process set_r_row_names that takes object_sexp as Integer and num_rows as Integer returns RResult[Boolean]:
Note: Create integer sequence for row names (1, 2, ..., num_rows)
    Let row_names be new List
    For i from 1 to num_rows:
    Add String::from_integer(i) to row_names Let row_names_result be set_r_names_attribute(object_sexp, "row.names", row_names)
    Return row_names_result

Process set_r_dimensions that takes vector_sexp as Integer and nrows as Integer and ncols as Integer returns RResult[Boolean]:
    Let dims be new List containing nrows, ncols
    Let dims_vector_result be create_r_integer_vector(dims) Let setattrib_func be FFI::get_symbol(global_r_runtime, "Rf_setAttrib")
    Let dim_symbol be get_r_dim_symbol() Let result be FFI::call_function(setattrib_func, [vector_sexp, dim_symbol, dims_vector_result]) If result.return_code is not equal to 0:
    Return RResult::RuntimeError with message "Failed to set dim attribute" and error_code result.return_code Return RResult::Success with value True

Process get_r_names_symbol that takes returns Integer:
    Let install_func be FFI::get_symbol(global_r_runtime, "Rf_install")
    Let symbol_result be FFI::call_function(install_func, ["names"])
    Return symbol_result.symbol_sexp

Process get_r_class_symbol that takes returns Integer:
    Let install_func be FFI::get_symbol(global_r_runtime, "Rf_install")
    Let symbol_result be FFI::call_function(install_func, ["class"])
    Return symbol_result.symbol_sexp

Process get_r_dim_symbol that takes returns Integer:
    Let install_func be FFI::get_symbol(global_r_runtime, "Rf_install")
    Let symbol_result be FFI::call_function(install_func, ["dim"])
    Return symbol_result.symbol_sexp

Process set_r_names_attribute that takes object_sexp as Integer and attr_name as String and names as List[String] returns RResult[Boolean]:
    Let names_vector_result be create_r_character_vector(names) Let setattrib_func be FFI::get_symbol(global_r_runtime, "Rf_setAttrib")
    Let install_func be FFI::get_symbol(global_r_runtime, "Rf_install")
    Let attr_symbol_result be FFI::call_function(install_func, [attr_name]) Let result be FFI::call_function(setattrib_func, [object_sexp, attr_symbol_result.symbol_sexp, names_vector_result]) If result.return_code is not equal to 0:
    Return RResult::RuntimeError with message "Failed to set " + attr_name + " attribute" and error_code result.return_code Return RResult::Success with value True

Process extract_r_attributes that takes sexp as Integer returns Dictionary[String, RObject]:
    Let attributes be new Dictionary If sexp is equal to 0:
    Return attributes
    Note: Get attributes using R_getAttrib for common attributes
    Let getattrib_func be FFI::get_symbol(global_r_runtime, "Rf_getAttrib")
    If getattrib_func is Empty:
    Return attributes
    Note: Extract common attributes
    Let attr_names be new List containing "names", "class", "dim", "dimnames", "row.names", "levels"
    For Each attr_name in attr_names:
    Let attr_symbol be create_r_symbol(attr_name)
    If attr_symbol is not equal to 0:
    Let attr_result be FFI::call_function(getattrib_func, [sexp, attr_symbol])
    If attr_result.return_code is equal to 0 and attr_result.attr_sexp is not equal to 0:
    Let attr_object be convert_sexp_to_robject(attr_result.attr_sexp)
    Set attributes[attr_name] to attr_object Return attributes

Process extract_r_class that takes sexp as Integer returns Optional[String]:
    Let getattrib_func be FFI::get_symbol(global_r_runtime, "Rf_getAttrib")
    Let class_symbol be get_r_class_symbol() Let class_result be FFI::call_function(getattrib_func, [sexp, class_symbol]) If class_result.class_sexp is not equal to 0:
Note: Extract class name from character vector
    Let class_vector be convert_r_character_vector_to_list(class_result.class_sexp)
    If not Collections::is_empty(class_vector):
    Return Some with value Collections::first(class_vector)
    Note: Fallback: determine class from SEXP type
    Let sexp_type be get_r_sexp_type(sexp)
    If sexp_type is equal to 19: Note: VECSXP (list/data.frame)
Note: Check if it has data.frame attributes
    If has_r_dataframe_attributes(sexp):
    Return Some with value "data.frame"
    Else:
    Return Some with value "list"
    Otherwise if sexp_type is equal to 14: Note: REALSXP (numeric)
    Return Some with value "numeric"
    Otherwise if sexp_type is equal to 13: Note: INTSXP (integer)
    Return Some with value "integer"
    Otherwise if sexp_type is equal to 16: Note: STRSXP (character)
    Return Some with value "character"
    Otherwise if sexp_type is equal to 10: Note: LGLSXP (logical)
    Return Some with value "logical"
    Return Empty

Process extract_r_error that takes error_data as String returns RError:
    Let error be RError with:
    message as error_data,
    call as "",
    traceback as new List Return error

Process join_float_list that takes values as List[Float] returns String:
    Let string_values be new List
    For Each value in values:
    Add String::from_float(value) to string_values
    Return String::join(string_values, ",")

Note: Mathematical utility functions for statistics
Process calculate_mean that takes values as List[Float] returns Float:
    If values.length is equal to 0:
    Return 0.0 Let sum be 0.0
    For Each value in values:
    Set sum to sum + value Return sum divided by Float::from_integer(values.length)

Process calculate_median that takes values as List[Float] returns Float:
    If values.length is equal to 0:
    Return 0.0 Let sorted_values be Collections::sort(values)
    Let n be values.length If n mod 2 is equal to 1:
    Return sorted_values[n divided by 2]
    Otherwise:
    Let mid1 be sorted_values[(n divided by 2) minus 1]
    Let mid2 be sorted_values[n divided by 2]
    Return (mid1 + mid2) divided by 2.0

Process calculate_min that takes values as List[Float] returns Float:
    If values.length is equal to 0:
    Return 0.0 Let min_val be values[0]
    For Each value in values:
    If value is less than min_val:
    Set min_val to value Return min_val

Process calculate_max that takes values as List[Float] returns Float:
    If values.length is equal to 0:
    Return 0.0 Let max_val be values[0]
    For Each value in values:
    If value is greater than max_val:
    Set max_val to value Return max_val

Process calculate_standard_deviation that takes values as List[Float] returns Float:
    If values.length is less than 2:
    Return 0.0 Let mean be calculate_mean(values)
    Let sum_squares be 0.0 For Each value in values:
    Let diff be value - mean
    Set sum_squares to sum_squares + (diff multiplied by diff) Let variance be sum_squares divided by Float::from_integer(values.length - 1)
    Return Float::square_root(variance)

Note: System setup functions
Process setup_r_event_loop that takes r_lib as Integer returns RResult[Boolean]:
    Let setup_func be FFI::get_symbol(r_lib, "R_ReplDLLinit")
    If setup_func is not Empty:
    Let setup_result be FFI::call_function(setup_func, [])
    If setup_result.return_code is not equal to 0:
    Return RResult::RuntimeError with message "Failed to setup R event loop" and error_code setup_result.return_code Return RResult::Success with value True

Process set_r_memory_limit that takes r_lib as Integer and limit_mb as Integer returns RResult[Boolean]:
Note: R memory limit setting (platform dependent)
    Return RResult::Success with value True

Process initialize_r_graphics that takes r_lib as Integer and gui_type as RGUIType returns RResult[Boolean]:
Note: Graphics initialization (optional)
    Return RResult::Success with value True

Note: Global state
Let global_r_runtime as Integer
Let r_runtime_initialized as Boolean = False

Note: High-level convenience functions
Process run_r_code that takes source_code as String returns RResult[Any]:
    Import "../../os" as OS Let default_config be RRuntimeConfig with:
    version as RVersion::R43,
    home_directory as "", Note: Will be auto-detected
    library_paths as new List,
    memory_limit as Empty,
    max_connections as 128,
    internet_routines as True,
    gui_type as RGUIType::None,
    restore_data as False,
    save_data as False,
    startup_options as RStartupOptions with:
    quiet as True,
    slave as True,
    interactive as False,
    verbose as False,
    load_site_file as True,
    load_init_file as True,
    restore_history as False,
    save_history as False If not r_runtime_initialized:
    Let init_result be initialize_r_runtime(default_config)
    If init_result is not RResult::Success:
    Return init_result
    Note: Evaluate the R code
    Let eval_result be evaluate_r_expression(source_code)
    If eval_result is not RResult::Success:
    Return eval_result
    Note: Extract and convert result to appropriate Runa type
    Let converted_result be convert_robject_to_runa_value(eval_result.value)
    Return RResult::Success with value converted_result

Process shutdown_r_runtime that takes returns RResult[Boolean]:
    If not r_runtime_initialized:
    Return RResult::Success with value True Let cleanup_func be FFI::get_symbol(global_r_runtime, "R_CleanUp")
    If cleanup_func is not Empty:
    Let cleanup_result be FFI::call_function(cleanup_func, [1, 0, 1]) Note: SA_DEFAULT, status, RunLast
    If cleanup_result.return_code is not equal to 0:
    Return RResult::RuntimeError with message "Failed to shutdown R runtime" and error_code cleanup_result.return_code Set r_runtime_initialized to False
    Set global_r_runtime to 0 Return RResult::Success with value True