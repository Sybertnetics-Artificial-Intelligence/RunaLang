Note: JVM Runtime Management Processes
Process called "create_java_runtime" returns JavaRuntime:
    Let runtime be new Dictionary with:
    runtime_id as generate_uuid()
    jvm_handle as 0
    jni_env as 0
    jvm_version as create_default_java_version()
    classpath as new List
    loaded_jars as new Dictionary
    loaded_classes as new Dictionary
    thread_manager as create_java_thread_manager()
    gc_coordinator as create_java_gc_coordinator()
    exception_handler as create_java_exception_handler()
    reflection_cache as create_java_reflection_cache()
    jni_references as create_jni_reference_manager()
    performance_monitor as create_java_performance_monitor()
    security_manager as create_java_security_manager() Return runtime

Process called "initialize_jvm" that takes runtime as JavaRuntime and options as Dictionary[String, Any] returns JavaResult:
    Import "interop/ffi" as FFI
    Note: Prepare JVM initialization arguments
    Let jvm_args be prepare_jvm_args(options)
    Note: Load JVM library
    Let jvm_lib_path be locate_jvm_library()
    If jvm_lib_path is equal to "":
    Return new Dictionary with:
    success as False
    error as "JVM library not found. Please set JAVA_HOME"
    Let jvm_lib be FFI::load_library(jvm_lib_path)
    If not jvm_lib["success"]:
    Return new Dictionary with:
    success as False
    error as "Failed to load JVM library: " jvm_lib["error"]
    Note: Get JNI_CreateJavaVM function
    Let create_jvm_func be FFI::get_function(jvm_lib["library"], "JNI_CreateJavaVM")
    If not create_jvm_func["success"]:
    Return new Dictionary with:
    success as False
    error as "Failed to find JNI_CreateJavaVM function"
    Note: Create JVM instance
    Let jvm_result be FFI::call_function(create_jvm_func["function"], jvm_args)
    If not jvm_result["success"]:
    Return new Dictionary with:
    success as False
    error as "Failed to create JVM: " jvm_result["error"]
    Note: Store JVM and JNI environment handles
    Set runtime["jvm_handle"] to jvm_result["jvm_handle"]
    Set runtime["jni_env"] to jvm_result["jni_env"]
    Note: Get JVM version information
    Set runtime["jvm_version"] to get_jvm_version(runtime["jni_env"])
    Note: Initialize subsystems
    initialize_thread_manager(runtime)
    initialize_gc_coordinator(runtime)
    initialize_exception_handler(runtime) Return new Dictionary with:
    success as True
    value as runtime
    jvm_version as runtime["jvm_version"]

Process called "shutdown_jvm" that takes runtime as JavaRuntime returns JavaResult:
    Import "interop/ffi" as FFI If runtime["jvm_handle"] is equal to 0:
    Return new Dictionary with:
    success as False
    error as "JVM not initialized"
    Note: Clean up references
    cleanup_jni_references(runtime["jni_references"])
    Note: Detach all threads
    detach_all_threads(runtime["thread_manager"])
    Note: Destroy JVM
    Let destroy_result be destroy_jvm_instance(runtime["jvm_handle"]) Set runtime["jvm_handle"] to 0
    Set runtime["jni_env"] to 0 Return new Dictionary with:
    success as destroy_result["success"]
    error as destroy_result["error"]

Process called "load_jar_file" that takes runtime as JavaRuntime and jar_path as String returns JavaResult:
    If not File::exists(jar_path):
    Return new Dictionary with:
    success as False
    error as "JAR file not found: " jar_path
    Note: Add JAR to classpath
    Add jar_path to runtime["classpath"]
    Note: Load JAR metadata
    Let jar_info be read_jar_metadata(jar_path) Let jar_file be new Dictionary with:
    jar_id as generate_uuid()
    file_path as jar_path
    jar_handle as 0
    manifest as jar_info["manifest"]
    classes as jar_info["classes"]
    resources as jar_info["resources"]
    is_signed as jar_info["is_signed"]
    signature_info as jar_info["signature_info"]
    load_time as get_current_time()
    size as File::get_file_size(jar_path) Set runtime["loaded_jars"][jar_path] to jar_file
    Note: Update JVM classpath
    update_jvm_classpath(runtime, jar_path) Return new Dictionary with:
    success as True
    value as jar_file
    classes_loaded as length of jar_info["classes"]

Process called "load_java_class" that takes runtime as JavaRuntime and class_name as String returns JavaResult:
Note: Check if class is already loaded
    If runtime["loaded_classes"] contains class_name:
    Return new Dictionary with:
    success as True
    value as runtime["loaded_classes"][class_name]
    from_cache as True
    Note: Use JNI to find class
    Let class_handle be find_class_jni(runtime["jni_env"], class_name)
    If class_handle is equal to 0:
    Return new Dictionary with:
    success as False
    error as "Class not found: " class_name
    Note: Get class metadata via reflection
    Let class_info be extract_class_metadata(runtime["jni_env"], class_handle) Let java_class be new Dictionary with:
    class_id as generate_uuid()
    class_name as class_name
    class_handle as class_handle
    package_name as extract_package_name(class_name)
    superclass as class_info["superclass"]
    interfaces as class_info["interfaces"]
    modifiers as class_info["modifiers"]
    fields as extract_fields(runtime["jni_env"], class_handle)
    methods as extract_methods(runtime["jni_env"], class_handle)
    constructors as extract_constructors(runtime["jni_env"], class_handle)
    annotations as extract_annotations(runtime["jni_env"], class_handle)
    is_interface as class_info["is_interface"]
    is_abstract as class_info["is_abstract"]
    is_final as class_info["is_final"]
    is_public as class_info["is_public"]
    class_loader as class_info["class_loader"]
    Note: Cache the loaded class
    Set runtime["loaded_classes"][class_name] to java_class
    update_reflection_cache(runtime["reflection_cache"], java_class) Return new Dictionary with:
    success as True
    value as java_class
    from_cache as False

Process called "create_java_object" that takes runtime as JavaRuntime and class_name as String and constructor_args as List[Any] returns JavaResult:
Note: Load the class if not already loaded
    Let class_result be load_java_class(runtime, class_name)
    If not class_result["success"]:
    Return class_result Let java_class be class_result["value"]
    Note: Find matching constructor
    Let constructor be find_matching_constructor(java_class["constructors"], constructor_args)
    If constructor is null:
    Return new Dictionary with:
    success as False
    error as "No matching constructor found for arguments"
    Note: Convert Runa arguments to Java types
    Let java_args be marshal_runa_to_java_args(runtime, constructor_args, constructor["parameter_types"])
    Note: Create new instance via JNI
    Let object_handle be new_object_jni(runtime["jni_env"], java_class["class_handle"], constructor["constructor_id"], java_args) If object_handle is equal to 0:
    Return new Dictionary with:
    success as False
    error as "Failed to create object instance"
    exception as get_pending_exception(runtime)
    Note: Create object wrapper
    Let java_object be new Dictionary with:
    object_id as generate_uuid()
    object_handle as object_handle
    class_name as class_name
    hash_code as get_object_hash_code(runtime["jni_env"], object_handle)
    is_null as False
    reference_type as JNIReferenceType::LOCAL
    Note: Register the object reference
    register_jni_reference(runtime["jni_references"], java_object) Return new Dictionary with:
    success as True
    value as java_object

Process called "call_java_method" that takes runtime as JavaRuntime and object as JavaObject and method_name as String and args as List[Any] returns JavaResult:
Note: Get the object's class
    Let class_name be object["class_name"]
    Let java_class be runtime["loaded_classes"][class_name] If java_class is null:
    Return new Dictionary with:
    success as False
    error as "Class not loaded: " class_name
    Note: Find the method
    Let method be find_matching_method(java_class["methods"], method_name, args)
    If method is null:
    Return new Dictionary with:
    success as False
    error as "Method not found: " method_name
    Note: Convert arguments
    Let java_args be marshal_runa_to_java_args(runtime, args, method["parameter_types"])
    Note: Call the method via JNI
    Let result as Any
    If method["is_static"]:
    Set result to call_static_method_jni(runtime["jni_env"], java_class["class_handle"], method["method_id"], java_args)
    Otherwise:
    Set result to call_instance_method_jni(runtime["jni_env"], object["object_handle"], method["method_id"], java_args)
    Note: Check for exceptions
    If has_pending_exception(runtime["jni_env"]):
    Let exception be get_and_clear_exception(runtime)
    Return new Dictionary with:
    success as False
    error as "Method call failed"
    exception as exception
    Note: Convert result back to Runa type
    Let runa_result be marshal_java_to_runa_value(runtime, result, method["return_type"]) Return new Dictionary with:
    success as True
    value as runa_result

Process called "call_static_java_method" that takes runtime as JavaRuntime and class_name as String and method_name as String and args as List[Any] returns JavaResult:
Note: Load the class
    Let class_result be load_java_class(runtime, class_name)
    If not class_result["success"]:
    Return class_result Let java_class be class_result["value"]
    Note: Find static method
    Let method be find_static_method(java_class["methods"], method_name, args)
    If method is null:
    Return new Dictionary with:
    success as False
    error as "Static method not found: " method_name
    Note: Convert arguments
    Let java_args be marshal_runa_to_java_args(runtime, args, method["parameter_types"])
    Note: Call static method
    Let result be call_static_method_jni(runtime["jni_env"], java_class["class_handle"], method["method_id"], java_args)
    Note: Check for exceptions
    If has_pending_exception(runtime["jni_env"]):
    Let exception be get_and_clear_exception(runtime)
    Return new Dictionary with:
    success as False
    error as "Static method call failed"
    exception as exception
    Note: Convert result
    Let runa_result be marshal_java_to_runa_value(runtime, result, method["return_type"]) Return new Dictionary with:
    success as True
    value as runa_result

Process called "get_java_field" that takes runtime as JavaRuntime and object as JavaObject and field_name as String returns JavaResult:
Note: Get the object's class
    Let java_class be runtime["loaded_classes"][object["class_name"]] If not java_class["fields"] contains field_name:
    Return new Dictionary with:
    success as False
    error as "Field not found: " field_name Let field be java_class["fields"][field_name]
    Note: Get field value via JNI
    Let value as Any
    If field["is_static"]:
    Set value to get_static_field_jni(runtime["jni_env"], java_class["class_handle"], field["field_id"], field["field_type"])
    Otherwise:
    Set value to get_instance_field_jni(runtime["jni_env"], object["object_handle"], field["field_id"], field["field_type"])
    Note: Convert to Runa type
    Let runa_value be marshal_java_to_runa_value(runtime, value, field["field_type"]) Return new Dictionary with:
    success as True
    value as runa_value

Process called "set_java_field" that takes runtime as JavaRuntime and object as JavaObject and field_name as String and value as Any returns JavaResult:
Note: Get the object's class
    Let java_class be runtime["loaded_classes"][object["class_name"]] If not java_class["fields"] contains field_name:
    Return new Dictionary with:
    success as False
    error as "Field not found: " field_name Let field be java_class["fields"][field_name] If field["is_final"]:
    Return new Dictionary with:
    success as False
    error as "Cannot modify final field: " field_name
    Note: Convert value to Java type
    Let java_value be marshal_runa_to_java_value(runtime, value, field["field_type"])
    Note: Set field value via JNI
    If field["is_static"]:
    set_static_field_jni(runtime["jni_env"], java_class["class_handle"], field["field_id"], java_value, field["field_type"])
    Otherwise:
    set_instance_field_jni(runtime["jni_env"], object["object_handle"], field["field_id"], java_value, field["field_type"]) Return new Dictionary with:
    success as True

Note: Data Marshalling Processes
Process called "marshal_runa_to_java_value" that takes runtime as JavaRuntime and value as Any and target_type as JavaType returns Any:
    If target_type["is_primitive"]:
    Return convert_runa_to_java_primitive(value, target_type["primitive_type"]) If target_type["is_array"]:
    Return create_java_array(runtime, value, target_type) If target_type["type_name"] is equal to "java.lang.String":
    Return create_java_string(runtime["jni_env"], value) If value is Dictionary:
    Return create_java_map(runtime, value) If value is List:
    Return create_java_list(runtime, value) Return value

Process called "marshal_java_to_runa_value" that takes runtime as JavaRuntime and java_value as Any and source_type as JavaType returns Any:
    If source_type["is_primitive"]:
    Return convert_java_to_runa_primitive(java_value, source_type["primitive_type"]) If source_type["is_array"]:
    Return convert_java_array_to_runa(runtime, java_value, source_type) If source_type["type_name"] is equal to "java.lang.String":
    Return get_java_string_value(runtime["jni_env"], java_value) If is_java_collection(runtime, java_value):
    Return convert_java_collection_to_runa(runtime, java_value)
    Note: Wrap as JavaObject for complex types
    Return wrap_as_java_object(runtime, java_value, source_type["type_name"])

Process called "marshal_runa_to_java_args" that takes runtime as JavaRuntime and args as List[Any] and param_types as List[JavaType] returns List[Any]:
    Let java_args be new List For Each i from 0 to length of args - 1:
    Let java_arg be marshal_runa_to_java_value(runtime, args[i], param_types[i])
    Add java_arg to java_args Return java_args

Note: Thread Management Processes
Process called "create_java_thread_manager" returns JavaThreadManager:
    Return new Dictionary with:
    manager_id as generate_uuid()
    main_thread as 0
    thread_pool as new Dictionary
    synchronization_monitors as new Dictionary
    thread_local_storage as new Dictionary

Process called "attach_current_thread" that takes runtime as JavaRuntime and thread_name as String returns JavaResult:
    Import "interop/ffi" as FFI
    Note: Attach current native thread to JVM
    Let attach_result be attach_thread_to_jvm(runtime["jvm_handle"], thread_name) If not attach_result["success"]:
    Return new Dictionary with:
    success as False
    error as "Failed to attach thread: " attach_result["error"] Let thread be new Dictionary with:
    thread_id as generate_uuid()
    thread_handle as attach_result["thread_handle"]
    thread_name as thread_name
    thread_group as "main"
    priority as 5
    is_daemon as False
    is_alive as True
    stack_trace as new List Set runtime["thread_manager"]["thread_pool"][thread_name] to thread Return new Dictionary with:
    success as True
    value as thread

Process called "detach_current_thread" that takes runtime as JavaRuntime returns JavaResult:
    Let thread_id be get_current_thread_id()
    Note: Find thread in pool
    Let thread as JavaThread
    For Each name in runtime["thread_manager"]["thread_pool"]:
    If runtime["thread_manager"]["thread_pool"][name]["thread_id"] is equal to thread_id:
    Set thread to runtime["thread_manager"]["thread_pool"][name]
    Break If thread is null:
    Return new Dictionary with:
    success as False
    error as "Thread not attached to JVM"
    Note: Detach from JVM
    detach_thread_from_jvm(runtime["jvm_handle"])
    Note: Remove from thread pool
    Remove runtime["thread_manager"]["thread_pool"][thread["thread_name"]] Return new Dictionary with:
    success as True

Note: Garbage Collection Coordination
Process called "create_java_gc_coordinator" returns JavaGCCoordinator:
    Return new Dictionary with:
    coordinator_id as generate_uuid()
    gc_type as JavaGCType::G1
    heap_size as 0
    used_memory as 0
    max_memory as 0
    gc_count as 0
    gc_time_total as 0.0
    memory_pools as new Dictionary

Process called "trigger_java_gc" that takes runtime as JavaRuntime returns JavaResult:
Note: Call System.gc() via JNI
    Let system_class be load_java_class(runtime, "java.lang.System")
    If not system_class["success"]:
    Return system_class Return call_static_java_method(runtime, "java.lang.System", "gc", new List)

Process called "get_java_memory_usage" that takes runtime as JavaRuntime returns Dictionary[String, Integer]:
    Let runtime_class be load_java_class(runtime, "java.lang.Runtime")
    If not runtime_class["success"]:
    Return new Dictionary Let runtime_instance be call_static_java_method(runtime, "java.lang.Runtime", "getRuntime", new List) Let total_memory be call_java_method(runtime, runtime_instance["value"], "totalMemory", new List)
    Let free_memory be call_java_method(runtime, runtime_instance["value"], "freeMemory", new List)
    Let max_memory be call_java_method(runtime, runtime_instance["value"], "maxMemory", new List) Return new Dictionary with:
    total as total_memory["value"]
    used as total_memory["value"] minus free_memory["value"]
    free as free_memory["value"]
    max as max_memory["value"]

Note: Exception Handling Processes
Process called "create_java_exception_handler" returns JavaExceptionHandler:
    Return new Dictionary with:
    handler_id as generate_uuid()
    pending_exception as null
    exception_stack as new List
    uncaught_handler as null

Process called "has_pending_exception" that takes jni_env as Integer returns Boolean:
    Import "interop/ffi" as FFI Let check_func be get_jni_function("ExceptionCheck")
    Let result be FFI::call_function(check_func, new List containing jni_env)
    Return result["return_value"] is not equal to 0

Process called "get_and_clear_exception" that takes runtime as JavaRuntime returns JavaException:
    Import "interop/ffi" as FFI Let exception_obj be get_jni_exception(runtime["jni_env"])
    If exception_obj is equal to 0:
    Return null
    Note: Clear the exception
    clear_jni_exception(runtime["jni_env"])
    Note: Extract exception details
    Let exception_class be get_object_class_name(runtime["jni_env"], exception_obj)
    Let message be get_exception_message(runtime["jni_env"], exception_obj)
    Let stack_trace be get_exception_stack_trace(runtime["jni_env"], exception_obj) Return new Dictionary with:
    exception_class as exception_class
    message as message
    stack_trace as stack_trace
    cause as null
    suppressed as new List

Note: Reflection Cache Management
Process called "create_java_reflection_cache" returns JavaReflectionCache:
    Return new Dictionary with:
    cache_id as generate_uuid()
    class_cache as new Dictionary
    method_cache as new Dictionary
    field_cache as new Dictionary
    constructor_cache as new Dictionary
    cache_hits as 0
    cache_misses as 0

Process called "update_reflection_cache" that takes cache as JavaReflectionCache and java_class as JavaClass returns None:
    Set cache["class_cache"][java_class["class_name"]] to java_class For Each method_name in java_class["methods"]:
    Let method be java_class["methods"][method_name]
    Let cache_key be java_class["class_name"] "." method_name
    Set cache["method_cache"][cache_key] to method For Each field_name in java_class["fields"]:
    Let field be java_class["fields"][field_name]
    Let cache_key be java_class["class_name"] "." field_name
    Set cache["field_cache"][cache_key] to field For Each constructor in java_class["constructors"]:
    Let cache_key be java_class["class_name"] ".<init>"
    Set cache["constructor_cache"][cache_key] to constructor

Note: JNI Reference Management
Process called "create_jni_reference_manager" returns JNIReferenceManager:
    Return new Dictionary with:
    manager_id as generate_uuid()
    local_refs as new Dictionary
    global_refs as new Dictionary
    weak_refs as new Dictionary
    reference_count as 0
    auto_release as True

Process called "register_jni_reference" that takes manager as JNIReferenceManager and object as JavaObject returns None:
    If object["reference_type"] is equal to JNIReferenceType::LOCAL:
    Set manager["local_refs"][object["object_handle"]] to object
    If object["reference_type"] is equal to JNIReferenceType::GLOBAL:
    Set manager["global_refs"][object["object_handle"]] to object
    If object["reference_type"] is equal to JNIReferenceType::WEAK_GLOBAL:
    Set manager["weak_refs"][object["object_handle"]] to object Set manager["reference_count"] to manager["reference_count"] 1

Process called "create_global_reference" that takes runtime as JavaRuntime and object as JavaObject returns JavaResult:
    Import "interop/ffi" as FFI Let new_ref be create_global_ref_jni(runtime["jni_env"], object["object_handle"]) If new_ref is equal to 0:
    Return new Dictionary with:
    success as False
    error as "Failed to create global reference"
    Note: Update object
    Set object["object_handle"] to new_ref
    Set object["reference_type"] to JNIReferenceType::GLOBAL
    Note: Update manager
    Remove runtime["jni_references"]["local_refs"][object["object_handle"]]
    register_jni_reference(runtime["jni_references"], object) Return new Dictionary with:
    success as True
    value as object

Process called "cleanup_jni_references" that takes manager as JNIReferenceManager returns None:
Note: Delete all global references
    For Each handle in manager["global_refs"]:
    delete_global_ref_jni(handle)
    Note: Delete all weak references
    For Each handle in manager["weak_refs"]:
    delete_weak_ref_jni(handle)
    Note: Local refs are automatically cleaned up
    Set manager["local_refs"] to new Dictionary
    Set manager["global_refs"] to new Dictionary
    Set manager["weak_refs"] to new Dictionary
    Set manager["reference_count"] to 0

Note: Performance Monitoring
Process called "create_java_performance_monitor" returns JavaPerformanceMonitor:
    Return new Dictionary with:
    monitor_id as generate_uuid()
    jvm_metrics as new Dictionary
    method_timings as new Dictionary
    allocation_rate as 0.0
    gc_overhead as 0.0
    thread_contention as 0.0
    class_loading_time as 0.0

Process called "record_method_timing" that takes monitor as JavaPerformanceMonitor and method_name as String and duration as Number returns None:
    If not monitor["method_timings"] contains method_name:
    Set monitor["method_timings"][method_name] to new List Add duration to monitor["method_timings"][method_name]
    Note: Update average timing
    Let timings be monitor["method_timings"][method_name]
    Let avg_time be calculate_average(timings)
    Set monitor["jvm_metrics"]["avg_" method_name] to avg_time

Note: Security Management
Process called "create_java_security_manager" returns JavaSecurityManager:
    Return new Dictionary with:
    manager_id as generate_uuid()
    security_policy as create_default_security_policy()
    permissions as new Dictionary
    code_sources as new Dictionary
    access_controller as create_java_access_controller()

Process called "create_default_security_policy" returns JavaSecurityPolicy:
    Return new Dictionary with:
    policy_id as generate_uuid()
    allow_reflection as True
    allow_native_access as True
    allow_system_properties as True
    allow_file_access as new List containing "read"
    allow_network_access as new List
    allow_thread_management as False

Process called "check_java_permission" that takes manager as JavaSecurityManager and permission_type as String and target as String returns Boolean:
    Let policy be manager["security_policy"] If permission_type is equal to "reflection":
    Return policy["allow_reflection"]
    If permission_type is equal to "native":
    Return policy["allow_native_access"]
    If permission_type is equal to "system_property":
    Return policy["allow_system_properties"]
    If permission_type is equal to "file":
    Return "read" is in policy["allow_file_access"]
    If permission_type is equal to "thread":
    Return policy["allow_thread_management"] Return False

Note: Utility and Helper Processes
Process called "locate_jvm_library" returns String:
    Let java_home be OS::get_environment_variable("JAVA_HOME")
    If java_home is equal to "":
    Return ""
    Let os_name be OS::get_operating_system() If os_name is equal to "windows":
    Return java_home "\\bin\\server\\jvm.dll"
    If os_name is equal to "darwin":
    Return java_home "/lib/server/libjvm.dylib"
    If os_name is equal to "linux":
    Return java_home "/lib/server/libjvm.so"
    Return ""

Process called "prepare_jvm_args" that takes options as Dictionary[String, Any] returns Dictionary[String, Any]:
    Let args be new Dictionary with:
    version as 0x00010008 Note: JNI version 1.8
    options as new List
    ignore_unrecognized as False
    Note: Add classpath
    If options contains "classpath":
    Add "-Djava.class.path=" options["classpath"] to args["options"]
    Note: Add heap size
    If options contains "heap_size":
    Add "-Xmx" options["heap_size"] to args["options"]
    Note: Add system properties
    If options contains "properties":
    For Each prop in options["properties"]:
    Add "-D" prop to args["options"] Return args

Process called "generate_uuid" returns String:
    Return UUID::generate_v4()

Process called "get_current_time" returns Number:
    Return Time::get_timestamp_milliseconds()

Process called "get_current_thread_id" returns String:
    Import "../../os" as OS
    Return OS::get_thread_id()

Process called "extract_package_name" that takes class_name as String returns String:
    Let last_dot be find_last_index_of(class_name, ".")
    If last_dot is equal to -1:
    Return ""
    Return substring(class_name, 0, last_dot)

Process called "find_matching_constructor" that takes constructors as List[JavaConstructor] and args as List[Any] returns JavaConstructor:
    For Each constructor in constructors:
    If matches_parameter_types(constructor["parameter_types"], args):
    Return constructor
    Return null

Process called "find_matching_method" that takes methods as Dictionary[String, JavaMethod] and method_name as String and args as List[Any] returns JavaMethod:
    If not methods contains method_name:
    Return null Let method be methods[method_name]
    If matches_parameter_types(method["parameter_types"], args):
    Return method Return null

Process called "matches_parameter_types" that takes param_types as List[JavaType] and args as List[Any] returns Boolean:
    If length of param_types is not equal to length of args:
    Return False
    Note: Simple type matching - could be enhanced
    Return True

Process called "convert_runa_to_java_primitive" that takes value as Any and primitive_type as JavaPrimitiveType returns Any:
    If primitive_type is equal to JavaPrimitiveType::BOOLEAN:
    Return value as Boolean
    If primitive_type is equal to JavaPrimitiveType::INT:
    Return value as Integer
    If primitive_type is equal to JavaPrimitiveType::LONG:
    Return value as Integer
    If primitive_type is equal to JavaPrimitiveType::FLOAT:
    Return value as Float
    If primitive_type is equal to JavaPrimitiveType::DOUBLE:
    Return value as Float
    If primitive_type is equal to JavaPrimitiveType::CHAR:
    Return value as Integer
    If primitive_type is equal to JavaPrimitiveType::BYTE:
    Return value as Integer
    If primitive_type is equal to JavaPrimitiveType::SHORT:
    Return value as Integer Return value

Process called "convert_java_to_runa_primitive" that takes value as Any and primitive_type as JavaPrimitiveType returns Any:
Note: Direct conversion for most types
    Return value

Process called "calculate_average" that takes values as List[Number] returns Number:
    If length of values is equal to 0:
    Return 0.0 Let sum be 0.0
    For Each value in values:
    Set sum to sum value Return sum divided by length of values

Note: Low-level JNI Interface Processes
Process called "find_class_jni" that takes jni_env as Integer and class_name as String returns Integer:
    Import "interop/ffi" as FFI Let find_class_func be get_jni_function("FindClass")
    Let java_class_name be replace_dots_with_slashes(class_name)
    Return FFI::call_function(find_class_func, new List containing jni_env, java_class_name)["return_value"]

Process called "new_object_jni" that takes jni_env as Integer and class_handle as Integer and constructor_id as String and args as List[Any] returns Integer:
    Import "interop/ffi" as FFI Let new_object_func be get_jni_function("NewObject")
    Let args_with_env be new List containing jni_env, class_handle, constructor_id
    For Each arg in args:
    Add arg to args_with_env Return FFI::call_function(new_object_func, args_with_env)["return_value"]

Process called "call_instance_method_jni" that takes jni_env as Integer and object_handle as Integer and method_id as String and args as List[Any] returns Any:
    Import "interop/ffi" as FFI Let call_method_func be get_jni_function("CallObjectMethod")
    Let args_with_env be new List containing jni_env, object_handle, method_id
    For Each arg in args:
    Add arg to args_with_env Return FFI::call_function(call_method_func, args_with_env)["return_value"]

Process called "call_static_method_jni" that takes jni_env as Integer and class_handle as Integer and method_id as String and args as List[Any] returns Any:
    Import "interop/ffi" as FFI Let call_static_func be get_jni_function("CallStaticObjectMethod")
    Let args_with_env be new List containing jni_env, class_handle, method_id
    For Each arg in args:
    Add arg to args_with_env Return FFI::call_function(call_static_func, args_with_env)["return_value"]

Process called "get_jni_function" that takes function_name as String returns Process:
Note: Return JNI function pointer
    Import "interop/ffi" as FFI
    Return FFI::get_system_function("JNI_" function_name)

Process called "replace_dots_with_slashes" that takes class_name as String returns String:
Note: Convert Java class name format
    Return replace_all(class_name, ".", "/")

