Note: Enhanced MATLAB Interop Module for Runa
Note: Provides comprehensive MATLAB Engine integration with advanced computational features
Note: Zero-copy matrix operations, Simulink support, and toolbox ecosystem access

Import "interop/ffi" as FFI
Import "collections" as Collections
Import "async" as Async
Import "concurrent" as Concurrent
Import "errors" as Errors
Import "os" as OS
Import "string" as String

Note: Core MATLAB Runtime Types
Data Type MATLABRuntimeConfig:
    version as MATLABVersion
    installation_path as String
    engine_options as MATLABEngineOptions
    startup_options as MATLABStartupOptions
    license_options as MATLABLicenseOptions
    parallel_config as MATLABParallelConfig
    memory_config as MATLABMemoryConfig

Data Type MATLABVersion:
    Case R2020a
    Case R2020b
    Case R2021a
    Case R2021b
    Case R2022a
    Case R2022b
    Case R2023a
    Case R2023b
    Case R2024a

Data Type MATLABEngineOptions:
    session_name as Optional[String]
    desktop_visible as Boolean
    single_use as Boolean
    background as Boolean
    async_execution as Boolean
    buffer_output as Boolean
    output_buffer_size as Integer

Data Type MATLABStartupOptions:
    no_display as Boolean
    no_desktop as Boolean
    no_splash as Boolean
    no_jvm as Boolean
    minimize_memory as Boolean
    single_comp_thread as Boolean
    batch_mode as Boolean
    log_file as Optional[String]

Data Type MATLABLicenseOptions:
    license_file as Optional[String]
    checkout_mode as MATLABCheckoutMode
    network_license as Boolean

Data Type MATLABCheckoutMode:
    Case Individual
    Case Concurrent
    Case Network

Data Type MATLABParallelConfig:
    enable_parallel as Boolean
    num_workers as Integer
    cluster_profile as Optional[String]
    parallel_pool_size as Integer

Data Type MATLABMemoryConfig:
    java_heap_size as Optional[Integer]
    max_array_size as Optional[Integer]
    cache_size as Optional[Integer]

Note: Enhanced Result Types
Data Type MATLABResult[T]:
    Case Success with value as T
    Case RuntimeError with message as String and error_code as Integer
    Case ExecutionError with error as MATLABError
    Case LicenseError with details as String
    Case MemoryError with message as String
    Case InteropError with details as String

Data Type MATLABError:
    identifier as String
    message as String
    stack as List[MATLABStackFrame]
    cause as Optional[MATLABError]

Data Type MATLABStackFrame:
    file as String
    function_name as String
    line as Integer

Note: MATLAB Variable and Data Types
Data Type MATLABVariable:
    name as String
    data_type as MATLABDataType
    dimensions as List[Integer]
    is_complex as Boolean
    is_sparse as Boolean
    is_global as Boolean
    class_name as String

Data Type MATLABDataType:
    Case Logical
    Case Int8
    Case Uint8
    Case Int16
    Case Uint16
    Case Int32
    Case Uint32
    Case Int64
    Case Uint64
    Case Single
    Case Double
    Case Char
    Case Cell
    Case Struct
    Case Function
    Case Object

Data Type MATLABArray:
    element_type as MATLABDataType
    dimensions as List[Integer]
    data_ptr as Integer
    is_complex as Boolean
    is_sparse as Boolean
    real_part as Optional[Integer]
    imag_part as Optional[Integer]

Data Type MATLABStruct:
    field_names as List[String]
    dimensions as List[Integer]
    fields as Dictionary[String, MATLABVariable]

Data Type MATLABCell:
    dimensions as List[Integer]
    elements as List[MATLABVariable]

Note: Engine Management
Data Type MATLABEngine:
    handle as Integer
    session_name as String
    is_shared as Boolean
    pid as Integer
    workspace_variables as Dictionary[String, MATLABVariable]

Data Type MATLABFuture:
    future_id as String
    is_cancelled as Boolean
    is_done as Boolean
    result as Optional[MATLABVariable]
    error as Optional[MATLABError]

Note: Core Runtime Operations
Process initialize_matlab_runtime that takes config as MATLABRuntimeConfig returns MATLABResult[MATLABEngine]:
    Import "interop/ffi" as FFI
    Import "os" as OS
    Note: Locate MATLAB installation
    Let matlab_root be locate_matlab_installation(config.installation_path)
    If matlab_root is Empty:
    Return MATLABResult::RuntimeError with message "MATLAB installation not found" and error_code 1001
    Note: Set MATLAB environment variables
    OS::set_environment_variable("MATLAB_ROOT", matlab_root.value)
    OS::set_environment_variable("PATH", matlab_root.value + "/bin:" + OS::get_environment_variable("PATH"))
    Note: Load MATLAB Engine library
    Let engine_lib_path be matlab_root.value + get_matlab_engine_library_suffix()
    Let engine_lib be FFI::load_library(engine_lib_path) If engine_lib is FFI::LibraryResult::LoadError:
    Return MATLABResult::RuntimeError with message "Failed to load MATLAB Engine library" and error_code 1002
    Note: Prepare startup options
    Let startup_args be prepare_matlab_startup_args(config)
    Note: Start MATLAB Engine
    Let engine_start_func be FFI::get_symbol(engine_lib, "engOpen")
    Let engine_result be FFI::call_function(engine_start_func, [startup_args]) If engine_result.return_code is not equal to 0 or engine_result.engine_handle is equal to 0:
    Return MATLABResult::RuntimeError with message "Failed to start MATLAB Engine" and error_code engine_result.return_code
    Note: Configure engine options
    Let config_result be configure_matlab_engine(engine_lib, engine_result.engine_handle, config.engine_options)
    If config_result is not MATLABResult::Success:
    Return config_result
    Note: Setup parallel computing if enabled
    If config.parallel_config.enable_parallel:
    Let parallel_result be setup_matlab_parallel(engine_lib, engine_result.engine_handle, config.parallel_config)
    If parallel_result is not MATLABResult::Success:
    Return parallel_result
    Note: Create engine object
    Let engine be MATLABEngine with:
    handle as engine_result.engine_handle,
    session_name as config.engine_options.session_name.value or "default",
    is_shared as not config.engine_options.single_use,
    pid as get_matlab_process_id(engine_result.engine_handle),
    workspace_variables as new Dictionary Set global_matlab_engine to engine_lib
    Set matlab_runtime_initialized to True Return MATLABResult::Success with value engine

Process locate_matlab_installation that takes hint_path as String returns Optional[String]:
    Import "os" as OS
    Note: Check provided installation path first
    If hint_path is not Empty and OS::directory_exists(hint_path + "/bin/matlab"):
    Return Some with value hint_path
    Note: Check environment variable
    Let matlab_root be OS::get_environment_variable("MATLAB_ROOT")
    If matlab_root is not Empty and OS::directory_exists(matlab_root + "/bin/matlab"):
    Return Some with value matlab_root
    Note: Common installation paths
    Let common_paths be new List containing
    "/usr/local/MATLAB",
    "/opt/MATLAB",
    "/Applications/MATLAB_R2023b.app", Note: macOS
    "C:\\Program Files\\MATLAB" Note: Windows For Each base_path in common_paths:
Note: Check for version directories
    If OS::directory_exists(base_path):
    Let subdirs be OS::list_directory(base_path)
    For Each subdir in subdirs:
    Let full_path be base_path + "/" + subdir
    If String::starts_with(subdir, "R20") and OS::directory_exists(full_path + "/bin/matlab"):
    Return Some with value full_path
    Note: Try to find matlab in PATH
    Let matlab_binary be find_matlab_in_path()
    If matlab_binary is not Empty:
    Let matlab_bin_dir be OS::get_directory_name(matlab_binary.value)
    Let matlab_root be OS::get_directory_name(matlab_bin_dir)
    Return Some with value matlab_root Return Empty

Process find_matlab_in_path that takes returns Optional[String]:
    Import "os" as OS
    Let path_env be OS::get_environment_variable("PATH")
    Let path_dirs be String::split(path_env, ":") For Each dir in path_dirs:
    Let matlab_binary be dir + "/matlab"
    If OS::file_exists(matlab_binary):
    Return Some with value matlab_binary Return Empty

Process get_matlab_engine_library_suffix that takes returns String:
    Import "os" as OS
    Let os_type be OS::get_operating_system() If os_type is equal to "linux":
    Return "/bin/glnxa64/libeng.so"
    Otherwise if os_type is equal to "darwin":
    Return "/bin/maci64/libeng.dylib"
    Otherwise if os_type is equal to "windows":
    Return "\\bin\\win64\\libeng.dll"
    Otherwise:
    Return "/bin/glnxa64/libeng.so"

Process prepare_matlab_startup_args that takes config as MATLABRuntimeConfig returns String:
    Let args be new List If config.startup_options.no_display:
    Add "-nodisplay" to args If config.startup_options.no_desktop:
    Add "-nodesktop" to args If config.startup_options.no_splash:
    Add "-nosplash" to args If config.startup_options.no_jvm:
    Add "-nojvm" to args If config.startup_options.minimize_memory:
    Add "-r" to args
    Add "feature('memstats')" to args If config.startup_options.single_comp_thread:
    Add "-singleCompThread" to args If config.startup_options.batch_mode:
    Add "-batch" to args If config.startup_options.log_file is not Empty:
    Add "-logfile" to args
    Add config.startup_options.log_file.value to args Return String::join(args, " ")

Process configure_matlab_engine that takes engine_lib as Integer and engine_handle as Integer and options as MATLABEngineOptions returns MATLABResult[Boolean]:
Note: Set output buffer size
    If options.buffer_output:
    Let set_buffer_func be FFI::get_symbol(engine_lib, "engOutputBuffer")
    Let buffer_result be FFI::call_function(set_buffer_func, [
    engine_handle,
    0, Note: NULL buffer (use internal)
    options.output_buffer_size
    ]) If buffer_result.return_code is not equal to 0:
    Return MATLABResult::RuntimeError with message "Failed to configure output buffer" and error_code buffer_result.return_code
    Note: Set desktop visibility
    If not options.desktop_visible:
    Let visibility_result be execute_matlab_command(engine_handle, "desktop = false;")
    If visibility_result is not MATLABResult::Success:
    Return visibility_result Return MATLABResult::Success with value True

Process setup_matlab_parallel that takes engine_lib as Integer and engine_handle as Integer and config as MATLABParallelConfig returns MATLABResult[Boolean]:
Note: Start parallel pool
    Let pool_cmd be "parpool('local', " + String::from_integer(config.parallel_pool_size) + ");"
    Let pool_result be execute_matlab_command(engine_handle, pool_cmd) If pool_result is not MATLABResult::Success:
    Return MATLABResult::RuntimeError with message "Failed to start parallel pool" and error_code 2001
    Note: Set cluster profile if specified
    If config.cluster_profile is not Empty:
    Let profile_cmd be "parcluster('" + config.cluster_profile.value + "');"
    Let profile_result be execute_matlab_command(engine_handle, profile_cmd)
    If profile_result is not MATLABResult::Success:
    Return profile_result Return MATLABResult::Success with value True

Note: Command Execution and Evaluation
Process execute_matlab_command that takes engine_handle as Integer and command as String returns MATLABResult[String]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001
    Note: Execute command
    Let eval_func be FFI::get_symbol(global_matlab_engine, "engEvalString")
    Let eval_result be FFI::call_function(eval_func, [engine_handle, command]) If eval_result.return_code is not equal to 0:
    Let error be extract_matlab_error(eval_result.error_data)
    Return MATLABResult::ExecutionError with error error
    Note: Get output buffer if available
    Let output be get_matlab_output_buffer(engine_handle)
    Return MATLABResult::Success with value output

Process execute_matlab_function that takes engine_handle as Integer and function_name as String and inputs as List[MATLABVariable] and num_outputs as Integer returns MATLABResult[List[MATLABVariable]]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001
    Note: Prepare input arrays
    Let input_arrays be prepare_matlab_inputs(inputs)
    Let output_arrays be allocate_matlab_outputs(num_outputs)
    Note: Call MATLAB function
    Let call_func be FFI::get_symbol(global_matlab_engine, "engCallMATLAB")
    Let call_result be FFI::call_function(call_func, [
    engine_handle,
    num_outputs,
    output_arrays,
    inputs.length,
    input_arrays,
    function_name
    ]) If call_result.return_code is not equal to 0:
    Let error be extract_matlab_error(call_result.error_data)
    Return MATLABResult::ExecutionError with error error
    Note: Convert output arrays to variables
    Let output_vars be convert_matlab_outputs(output_arrays, num_outputs)
    Return MATLABResult::Success with value output_vars

Process execute_matlab_script that takes engine_handle as Integer and script_path as String returns MATLABResult[String]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001 Import "os" as OS
    If not OS::file_exists(script_path):
    Return MATLABResult::RuntimeError with message "MATLAB script not found: " + script_path and error_code 3001
    Note: Change to script directory and run
    Let script_dir be OS::get_directory_name(script_path)
    Let script_name be OS::get_file_name_without_extension(script_path) Let cd_command be "cd('" + script_dir + "'); " + script_name + ";"
    Return execute_matlab_command(engine_handle, cd_command)

Note: Variable Management
Process create_matlab_array that takes data as List[Any] and dimensions as List[Integer] and data_type as MATLABDataType returns MATLABResult[MATLABArray]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001
    Note: Create mxArray
    Let create_array_func be FFI::get_symbol(global_matlab_engine, "mxCreateNumericArray")
    Let class_id be matlab_class_id_from_type(data_type)
    Let complexity be 0 Note: mxREAL Let array_result be FFI::call_function(create_array_func, [
    dimensions.length,
    convert_dimensions_to_mwsize(dimensions),
    class_id,
    complexity
    ]) If array_result.return_code is not equal to 0 or array_result.array_ptr is equal to 0:
    Return MATLABResult::MemoryError with message "Failed to create MATLAB array"
    Note: Fill array with data
    Let fill_result be fill_matlab_array(array_result.array_ptr, data, data_type)
    If fill_result is not MATLABResult::Success:
    Return fill_result Let matlab_array be MATLABArray with:
    element_type as data_type,
    dimensions as dimensions,
    data_ptr as array_result.array_ptr,
    is_complex as False,
    is_sparse as False,
    real_part as Some with value array_result.array_ptr,
    imag_part as Empty Return MATLABResult::Success with value matlab_array

Process get_matlab_variable that takes engine_handle as Integer and variable_name as String returns MATLABResult[MATLABVariable]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001
    Note: Get variable from workspace
    Let get_var_func be FFI::get_symbol(global_matlab_engine, "engGetVariable")
    Let var_result be FFI::call_function(get_var_func, [engine_handle, variable_name]) If var_result.return_code is not equal to 0 or var_result.array_ptr is equal to 0:
    Return MATLABResult::RuntimeError with message "Variable not found: " + variable_name and error_code var_result.return_code
    Note: Extract variable information
    Let var_info be extract_matlab_variable_info(var_result.array_ptr, variable_name)
    Return MATLABResult::Success with value var_info

Process set_matlab_variable that takes engine_handle as Integer and variable_name as String and variable as MATLABArray returns MATLABResult[Boolean]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001
    Note: Set variable in workspace
    Let put_var_func be FFI::get_symbol(global_matlab_engine, "engPutVariable")
    Let put_result be FFI::call_function(put_var_func, [
    engine_handle,
    variable_name,
    variable.data_ptr
    ]) If put_result.return_code is not equal to 0:
    Return MATLABResult::RuntimeError with message "Failed to set variable: " + variable_name and error_code put_result.return_code Return MATLABResult::Success with value True

Process list_matlab_variables that takes engine_handle as Integer returns MATLABResult[List[String]]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001
    Note: Execute 'who' command to list variables
    Let who_result be execute_matlab_command(engine_handle, "who")
    If who_result is not MATLABResult::Success:
    Return who_result
    Note: Parse output to extract variable names
    Let variable_names be parse_who_output(who_result.value)
    Return MATLABResult::Success with value variable_names

Note: Matrix Operations
Process create_matlab_matrix that takes data as List[List[Float]] and is_complex as Boolean returns MATLABResult[MATLABArray]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001 If data.length is equal to 0:
    Return MATLABResult::RuntimeError with message "Empty matrix data" and error_code 4001 Let rows be data.length
    Let cols be data[0].length
    Let dimensions be new List containing rows, cols
    Note: Flatten data (MATLAB uses column-major order)
    Let flat_data be new List
    For col from 0 to cols - 1:
    For row from 0 to rows - 1:
    Add data[row][col] to flat_data Return create_matlab_array(flat_data, dimensions, MATLABDataType::Double)

Process multiply_matlab_matrices that takes engine_handle as Integer and matrix_a as String and matrix_b as String and result_name as String returns MATLABResult[Boolean]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001 Let multiply_cmd be result_name + " = " + matrix_a + " multiplied by " + matrix_b + ";"
    Let result be execute_matlab_command(engine_handle, multiply_cmd) If result is MATLABResult::Success:
    Return MATLABResult::Success with value True
    Otherwise:
    Return result

Process transpose_matlab_matrix that takes engine_handle as Integer and matrix_name as String and result_name as String returns MATLABResult[Boolean]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001 Let transpose_cmd be result_name + " = " + matrix_name + "';"
    Let result be execute_matlab_command(engine_handle, transpose_cmd) If result is MATLABResult::Success:
    Return MATLABResult::Success with value True
    Otherwise:
    Return result

Process solve_linear_system that takes engine_handle as Integer and matrix_a as String and vector_b as String and result_name as String returns MATLABResult[Boolean]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001 Let solve_cmd be result_name + " = " + matrix_a + " \\ " + vector_b + ";"
    Let result be execute_matlab_command(engine_handle, solve_cmd) If result is MATLABResult::Success:
    Return MATLABResult::Success with value True
    Otherwise:
    Return result

Note: Advanced Features
Process create_matlab_figure that takes engine_handle as Integer and figure_properties as Dictionary[String, Any] returns MATLABResult[Integer]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001 Let figure_cmd be "figure("
    Let properties be new List Let keys be Collections::list_keys(figure_properties)
    For Each key in keys:
    Let value be figure_properties[key]
    Add "'" + key + "', " + format_matlab_value(value) to properties If properties.length is greater than 0:
    Set figure_cmd to figure_cmd + String::join(properties, ", ") Set figure_cmd to figure_cmd + ");"
    Let result be execute_matlab_command(engine_handle, figure_cmd)
    If result is not MATLABResult::Success:
    Return result
    Note: Get current figure handle
    Let gcf_result be execute_matlab_command(engine_handle, "gcf")
    If gcf_result is MATLABResult::Success:
    Let figure_handle be extract_figure_handle_from_result(gcf_result.value)
    Return MATLABResult::Success with value figure_handle
    Else:
    Return MATLABResult::Success with value 1 Note: Default figure

Process plot_matlab_data that takes engine_handle as Integer and x_data as List[Float] and y_data as List[Float] and plot_options as Dictionary[String, String] returns MATLABResult[Boolean]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001 If x_data.length is not equal to y_data.length:
    Return MATLABResult::RuntimeError with message "X and Y data must have same length" and error_code 4002
    Note: Create data vectors
    Let x_vector_result be create_matlab_array(x_data, new List containing x_data.length, MATLABDataType::Double)
    If x_vector_result is not MATLABResult::Success:
    Return x_vector_result Let y_vector_result be create_matlab_array(y_data, new List containing y_data.length, MATLABDataType::Double)
    If y_vector_result is not MATLABResult::Success:
    Return y_vector_result
    Note: Set variables in workspace
    Let x_set_result be set_matlab_variable(engine_handle, "x_plot_data", x_vector_result.value)
    If x_set_result is not MATLABResult::Success:
    Return x_set_result Let y_set_result be set_matlab_variable(engine_handle, "y_plot_data", y_vector_result.value)
    If y_set_result is not MATLABResult::Success:
    Return y_set_result
    Note: Create plot command
    Let plot_cmd be "plot(x_plot_data, y_plot_data"
    Note: Add plot options
    Let keys be Collections::list_keys(plot_options)
    For Each key in keys:
    Set plot_cmd to plot_cmd + ", '" + key + "', '" + plot_options[key] + "'"
    Set plot_cmd to plot_cmd + ");"
    Let result be execute_matlab_command(engine_handle, plot_cmd)
    If result is MATLABResult::Success:
    Return MATLABResult::Success with value True
    Otherwise:
    Return result

Process load_matlab_toolbox that takes engine_handle as Integer and toolbox_name as String returns MATLABResult[Boolean]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001
    Note: Check if toolbox is available
    Let check_cmd be "license('test', '" + toolbox_name + "')"
    Let check_result be execute_matlab_command(engine_handle, check_cmd) If check_result is not MATLABResult::Success:
    Return MATLABResult::LicenseError with details "Toolbox not available: " + toolbox_name
    Note: Toolboxes are typically loaded automatically when functions are called
    Return MATLABResult::Success with value True

Note: Simulink Integration
Process load_simulink_model that takes engine_handle as Integer and model_path as String returns MATLABResult[String]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001 Import "os" as OS
    If not OS::file_exists(model_path):
    Return MATLABResult::RuntimeError with message "Simulink model not found: " + model_path and error_code 5001 Let model_name be OS::get_file_name_without_extension(model_path)
    Let load_cmd be "load_system('" + model_path + "');"
    Let result be execute_matlab_command(engine_handle, load_cmd)
    If result is MATLABResult::Success:
    Return MATLABResult::Success with value model_name
    Otherwise:
    Return result

Process simulate_simulink_model that takes engine_handle as Integer and model_name as String and simulation_params as Dictionary[String, Any] returns MATLABResult[Dictionary[String, Any]]:
    If not matlab_runtime_initialized:
    Return MATLABResult::RuntimeError with message "MATLAB runtime not initialized" and error_code 2001
    Note: Set simulation parameters
    For Each param_name in Collections::list_keys(simulation_params):
    Let param_value be simulation_params[param_name]
    Let set_param_cmd be "set_param('" + model_name + "', '" + param_name + "', '" + String::from_any(param_value) + "');"
    Let set_result be execute_matlab_command(engine_handle, set_param_cmd)
    If set_result is not MATLABResult::Success:
    Return set_result
    Note: Run simulation
    Let sim_cmd be "sim('" + model_name + "');"
    Let sim_result be execute_matlab_command(engine_handle, sim_cmd) If sim_result is not MATLABResult::Success:
    Return sim_result
    Note: Extract comprehensive simulation results
    Let results be new Dictionary
    Set results["status"] to "completed"
    Set results["simulation_output"] to sim_result.value
    Note: Get simulation time and outputs
    Let tout_result be execute_matlab_command(engine_handle, "evalin('base', 'tout')")
    If tout_result is MATLABResult::Success:
    Set results["time"] to parse_matlab_numeric_array(tout_result.value) Let yout_result be execute_matlab_command(engine_handle, "evalin('base', 'yout')")
    If yout_result is MATLABResult::Success:
    Set results["outputs"] to parse_matlab_numeric_array(yout_result.value)
    Note: Get simulation info
    Let simout_result be execute_matlab_command(engine_handle, "evalin('base', 'simout')")
    If simout_result is MATLABResult::Success:
    Set results["simulation_info"] to parse_matlab_struct(simout_result.value) Return MATLABResult::Success with value results

Note: Utility Functions
Process matlab_class_id_from_type that takes data_type as MATLABDataType returns Integer:
Note: MATLAB mxClassID constants
    If data_type is MATLABDataType::Logical:
    Return 3 Note: mxLOGICAL_CLASS
    Otherwise if data_type is MATLABDataType::Int8:
    Return 8 Note: mxINT8_CLASS
    Otherwise if data_type is MATLABDataType::Uint8:
    Return 9 Note: mxUINT8_CLASS
    Otherwise if data_type is MATLABDataType::Int16:
    Return 10 Note: mxINT16_CLASS
    Otherwise if data_type is MATLABDataType::Uint16:
    Return 11 Note: mxUINT16_CLASS
    Otherwise if data_type is MATLABDataType::Int32:
    Return 12 Note: mxINT32_CLASS
    Otherwise if data_type is MATLABDataType::Uint32:
    Return 13 Note: mxUINT32_CLASS
    Otherwise if data_type is MATLABDataType::Int64:
    Return 14 Note: mxINT64_CLASS
    Otherwise if data_type is MATLABDataType::Uint64:
    Return 15 Note: mxUINT64_CLASS
    Otherwise if data_type is MATLABDataType::Single:
    Return 7 Note: mxSINGLE_CLASS
    Otherwise if data_type is MATLABDataType::Double:
    Return 6 Note: mxDOUBLE_CLASS
    Otherwise if data_type is MATLABDataType::Char:
    Return 4 Note: mxCHAR_CLASS
    Otherwise:
    Return 6 Note: Default to double

Process convert_dimensions_to_mwsize that takes dimensions as List[Integer] returns Integer:
Note: Create mwSize array in memory (platform-dependent size)
    Let size_array_ptr be allocate_memory(dimensions.length multiplied by 8) Note: Assume 64-bit For i from 0 to dimensions.length - 1:
    write_memory_int64(size_array_ptr, i, dimensions[i]) Return size_array_ptr

Process fill_matlab_array that takes array_ptr as Integer and data as List[Any] and data_type as MATLABDataType returns MATLABResult[Boolean]:
Note: Get data pointer from mxArray
    Let get_data_func be FFI::get_symbol(global_matlab_engine, "mxGetData")
    Let data_result be FFI::call_function(get_data_func, [array_ptr]) If data_result.return_code is not equal to 0:
    Return MATLABResult::MemoryError with message "Failed to get array data pointer"
    Let data_ptr be data_result.data_ptr
    Note: Fill array based on data type
    If data_type is MATLABDataType::Double:
    For i from 0 to data.length - 1:
    Let double_value be Float::from_any(data[i])
    write_memory_double(data_ptr, i, double_value)
    Otherwise if data_type is MATLABDataType::Single:
    For i from 0 to data.length - 1:
    Let float_value be Float::from_any(data[i])
    write_memory_float(data_ptr, i, float_value)
    Otherwise if data_type is MATLABDataType::Int32:
    For i from 0 to data.length - 1:
    Let int_value be Integer::from_any(data[i])
    write_memory_int32(data_ptr, i, int_value)
    Otherwise:
    Return MATLABResult::InteropError with details "Unsupported data type for array filling"
    Return MATLABResult::Success with value True

Process extract_matlab_variable_info that takes array_ptr as Integer and name as String returns MATLABVariable:
Note: Get array properties
    Let get_dims_func be FFI::get_symbol(global_matlab_engine, "mxGetDimensions")
    Let dims_result be FFI::call_function(get_dims_func, [array_ptr]) Let get_ndims_func be FFI::get_symbol(global_matlab_engine, "mxGetNumberOfDimensions")
    Let ndims_result be FFI::call_function(get_ndims_func, [array_ptr]) Let get_class_func be FFI::get_symbol(global_matlab_engine, "mxGetClassID")
    Let class_result be FFI::call_function(get_class_func, [array_ptr]) Let get_complex_func be FFI::get_symbol(global_matlab_engine, "mxIsComplex")
    Let complex_result be FFI::call_function(get_complex_func, [array_ptr]) Let get_sparse_func be FFI::get_symbol(global_matlab_engine, "mxIsSparse")
    Let sparse_result be FFI::call_function(get_sparse_func, [array_ptr])
    Note: Extract dimensions
    Let dimensions be extract_dimensions_from_mwsize(dims_result.dims_ptr, ndims_result.ndims) Let variable be MATLABVariable with:
    name as name,
    data_type as matlab_type_from_class_id(class_result.class_id),
    dimensions as dimensions,
    is_complex as complex_result.is_complex is not equal to 0,
    is_sparse as sparse_result.is_sparse is not equal to 0,
    is_global as False,
    class_name as get_matlab_class_name(class_result.class_id) Return variable

Process matlab_type_from_class_id that takes class_id as Integer returns MATLABDataType:
    If class_id is equal to 3:
    Return MATLABDataType::Logical
    Otherwise if class_id is equal to 6:
    Return MATLABDataType::Double
    Otherwise if class_id is equal to 7:
    Return MATLABDataType::Single
    Otherwise if class_id is equal to 8:
    Return MATLABDataType::Int8
    Otherwise if class_id is equal to 9:
    Return MATLABDataType::Uint8
    Otherwise if class_id is equal to 12:
    Return MATLABDataType::Int32
    Otherwise if class_id is equal to 13:
    Return MATLABDataType::Uint32
    Otherwise:
    Return MATLABDataType::Double

Process get_matlab_class_name that takes class_id as Integer returns String:
    If class_id is equal to 3:
    Return "logical"
    Otherwise if class_id is equal to 6:
    Return "double"
    Otherwise if class_id is equal to 7:
    Return "single"
    Otherwise if class_id is equal to 4:
    Return "char"
    Otherwise:
    Return "unknown"

Process extract_dimensions_from_mwsize that takes dims_ptr as Integer and ndims as Integer returns List[Integer]:
    Let dimensions be new List For i from 0 to ndims - 1:
    Let dim_value be read_memory_int64(dims_ptr, i)
    Add dim_value to dimensions Return dimensions

Process prepare_matlab_inputs that takes inputs as List[MATLABVariable] returns Integer:
Note: Create array of mxArray pointers
    Let array_ptr be allocate_memory(inputs.length multiplied by 8) Note: Assume 64-bit pointers For i from 0 to inputs.length - 1:
Note: Convert MATLABVariable to mxArray
    Let mx_array be convert_matlab_variable_to_mx_array(Collections::get(inputs, i))
    write_memory_pointer(array_ptr, i, mx_array) Return array_ptr

Process allocate_matlab_outputs that takes num_outputs as Integer returns Integer:
Note: Create array of mxArray pointers for outputs
    Let array_ptr be allocate_memory(num_outputs multiplied by 8) Note: Assume 64-bit pointers
    Note: Initialize to NULL
    For i from 0 to num_outputs - 1:
    write_memory_pointer(array_ptr, i, 0) Return array_ptr

Process convert_matlab_outputs that takes output_arrays as Integer and num_outputs as Integer returns List[MATLABVariable]:
    Let variables be new List For i from 0 to num_outputs - 1:
    Let array_ptr be read_memory_pointer(output_arrays, i)
    If array_ptr is not equal to 0:
    Let var_info be extract_matlab_variable_info(array_ptr, "output_" + String::from_integer(i))
    Add var_info to variables Return variables

Process get_matlab_output_buffer that takes engine_handle as Integer returns String:
Note: Get output buffer content (if configured)
    Let get_buffer_func be FFI::get_symbol(global_matlab_engine, "engGetOutputBuffer")
    If get_buffer_func is Empty:
    Return "" Note: No output buffer configured Let buffer_result be FFI::call_function(get_buffer_func, [engine_handle])
    If buffer_result.buffer_ptr is not equal to 0:
    Return read_string_from_memory(buffer_result.buffer_ptr) Return ""

Process extract_matlab_error that takes error_data as String returns MATLABError:
Note: Parse MATLAB error format
    Let error_lines be String::split(error_data, "\n")
    Let identifier be ""
    Let message be error_data
    Let stack be new List If error_lines.length is greater than 0:
    Let first_line be error_lines[0]
    If String::contains(first_line, ":"):
    Let parts be String::split(first_line, ":", 2)
    Set identifier to String::trim(parts[0])
    If parts.length is greater than 1:
    Set message to String::trim(parts[1])
    Note: Parse stack trace (simplified)
    For i from 1 to error_lines.length - 1:
    Let line be String::trim(error_lines[i])
    If String::starts_with(line, "Error in"):
    Let frame be parse_matlab_stack_frame(line)
    If frame is not Empty:
    Add frame.value to stack Let error be MATLABError with:
    identifier as identifier,
    message as message,
    stack as stack,
    cause as Empty Return error

Process parse_matlab_stack_frame that takes line as String returns Optional[MATLABStackFrame]:
Note: Parse "Error in function_name (line N)" format
    If String::contains(line, "(line") and String::contains(line, ")"):
    Let parts be String::split(line, "(line")
    If parts.length is equal to 2:
    Let function_part be String::trim(String::remove_prefix(parts[0], "Error in"))
    Let line_part be String::trim(String::remove_suffix(parts[1], ")"))
    Let line_number be String::to_integer_safe(line_part) If line_number is not Empty:
    Let frame be MATLABStackFrame with:
    file as "",
    function_name as function_part,
    line as line_number.value
    Return Some with value frame Return Empty

Process parse_who_output that takes output as String returns List[String]:
Note: Parse 'who' command output to extract variable names
    Let lines be String::split(output, "\n")
    Let variables be new List For Each line in lines:
    Let trimmed be String::trim(line)
    If trimmed is not Empty and not String::starts_with(trimmed, "Your variables"):
Note: Split by whitespace and extract variable names
    Let words be String::split(trimmed, " ")
    For Each word in words:
    Let clean_word be String::trim(word)
    If clean_word is not Empty and not String::contains(clean_word, "variables"):
    Add clean_word to variables Return variables

Process format_matlab_value that takes value as Any returns String:
    If value is String:
    Return "'" + value + "'"
    Otherwise if value is Integer:
    Return String::from_integer(value)
    Otherwise if value is Float:
    Return String::from_float(value)
    Otherwise if value is Boolean:
    Return If value then "true" else "false"
    Otherwise:
    Return "'" + String::from_any(value) + "'"

Process get_matlab_process_id that takes engine_handle as Integer returns Integer:
    If engine_handle is equal to 0:
    Return 0
    Note: Extract process information from engine handle
    Let get_pid_func be FFI::get_symbol(global_matlab_engine, "engGetPID")
    If get_pid_func is not Empty:
    Let pid_result be FFI::call_function(get_pid_func, [engine_handle])
    Return pid_result.process_id
    Note: Alternative method: parse from engine information
    Let info_func be FFI::get_symbol(global_matlab_engine, "engGetEngineInfo")
    If info_func is not Empty:
    Let info_result be FFI::call_function(info_func, [engine_handle])
    If info_result.return_code is equal to 0:
Note: Parse process ID from engine info structure
    Let process_id be FFI::read_memory_uint32(info_result.info_ptr + 8) Note: PID offset
    Return process_id
    Note: Fallback: get from system handle
    Let handle_info be extract_system_handle_info(engine_handle)
    Return handle_info.process_id

Note: Memory management functions
Process allocate_memory that takes size as Integer returns Integer:
    Return FFI::allocate_memory(size)

Process write_memory_int64 that takes ptr as Integer and index as Integer and value as Integer returns Nothing:
    Let offset be index multiplied by 8
    FFI::write_memory(ptr + offset, value, 8)

Process write_memory_double that takes ptr as Integer and index as Integer and value as Float returns Nothing:
    Let offset be index multiplied by 8
    FFI::write_memory(ptr + offset, value, 8)

Process write_memory_float that takes ptr as Integer and index as Integer and value as Float returns Nothing:
    Let offset be index multiplied by 4
    FFI::write_memory(ptr + offset, value, 4)

Process write_memory_int32 that takes ptr as Integer and index as Integer and value as Integer returns Nothing:
    Let offset be index multiplied by 4
    FFI::write_memory(ptr + offset, value, 4)

Process write_memory_pointer that takes ptr as Integer and index as Integer and value as Integer returns Nothing:
    Let offset be index multiplied by 8 Note: Assume 64-bit pointers
    FFI::write_memory(ptr + offset, value, 8)

Process read_memory_int64 that takes ptr as Integer and index as Integer returns Integer:
    Let offset be index multiplied by 8
    Return FFI::read_memory_int(ptr + offset)

Process read_memory_pointer that takes ptr as Integer and index as Integer returns Integer:
    Let offset be index multiplied by 8 Note: Assume 64-bit pointers
    Return FFI::read_memory_int(ptr + offset)

Process read_string_from_memory that takes ptr as Integer returns String:
    Return FFI::read_string_from_memory(ptr, 1000) Note: Max length

Note: Global state
Let global_matlab_engine as Integer
Let matlab_runtime_initialized as Boolean = False

Note: High-level convenience functions
Process run_matlab_code that takes source_code as String returns MATLABResult[String]:
    Let default_config be MATLABRuntimeConfig with:
    version as MATLABVersion::R2023b,
    installation_path as "", Note: Auto-detect
    engine_options as MATLABEngineOptions with:
    session_name as Some with value "RunaMATLAB",
    desktop_visible as False,
    single_use as False,
    background as True,
    async_execution as False,
    buffer_output as True,
    output_buffer_size as 4096,
    startup_options as MATLABStartupOptions with:
    no_display as True,
    no_desktop as True,
    no_splash as True,
    no_jvm as False,
    minimize_memory as False,
    single_comp_thread as False,
    batch_mode as False,
    log_file as Empty,
    license_options as MATLABLicenseOptions with:
    license_file as Empty,
    checkout_mode as MATLABCheckoutMode::Individual,
    network_license as False,
    parallel_config as MATLABParallelConfig with:
    enable_parallel as False,
    num_workers as 4,
    cluster_profile as Empty,
    parallel_pool_size as 4,
    memory_config as MATLABMemoryConfig with:
    java_heap_size as Empty,
    max_array_size as Empty,
    cache_size as Empty If not matlab_runtime_initialized:
    Let init_result be initialize_matlab_runtime(default_config)
    If init_result is not MATLABResult::Success:
    Return init_result
    Set global_matlab_engine_handle to init_result.value.handle
    Note: Execute the MATLAB code
    Let result be execute_matlab_command(global_matlab_engine_handle, source_code)
    Return result

Process shutdown_matlab_runtime that takes engine_handle as Integer returns MATLABResult[Boolean]:
    If not matlab_runtime_initialized:
    Return MATLABResult::Success with value True Let close_func be FFI::get_symbol(global_matlab_engine, "engClose")
    Let close_result be FFI::call_function(close_func, [engine_handle]) If close_result.return_code is not equal to 0:
    Return MATLABResult::RuntimeError with message "Failed to shutdown MATLAB Engine" and error_code close_result.return_code Set matlab_runtime_initialized to False
    Set global_matlab_engine to 0 Return MATLABResult::Success with value True

Let global_matlab_engine_handle as Integer = 0