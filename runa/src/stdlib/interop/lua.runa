Note: Enhanced Lua Interop Module for Runa
Note: Provides comprehensive Lua runtime integration with embedded scripting focus
Note: Zero-copy string operations, coroutine management, and dynamic loading

Import "interop/ffi" as FFI
Import "collections" as Collections
Import "async" as Async
Import "concurrent" as Concurrent
Import "errors" as Errors
Import "os" as OS
Import "string" as String

Note: Core Lua Runtime Types
Data Type LuaRuntimeConfig:
    version as LuaVersion
    memory_allocator as LuaMemoryAllocator
    garbage_collection as LuaGCConfig
    stack_size as Integer
    preload_libraries as List[LuaLibrary]
    hook_config as LuaHookConfig
    security_config as LuaSecurityConfig

Data Type LuaVersion:
    Case Lua51
    Case Lua52
    Case Lua53
    Case Lua54
    Case LuaJIT20
    Case LuaJIT21

Data Type LuaMemoryAllocator:
    Case System
    Case Custom with allocator_func as String
    Case Pool with pool_size as Integer
    Case Debug

Data Type LuaGCConfig:
    mode as LuaGCMode
    pause as Integer Note: GC pause percentage
    step_multiplier as Integer Note: Step multiplier
    minor_multiplier as Integer Note: Minor multiplier (5.4)
    major_multiplier as Integer Note: Major multiplier (5.4)

Data Type LuaGCMode:
    Case Incremental
    Case Generational Note: Lua 5.4+
    Case Stop

Data Type LuaLibrary:
    Case Base
    Case Coroutine
    Case Package
    Case String
    Case UTF8
    Case Table
    Case Math
    Case IO
    Case OS
    Case Debug

Data Type LuaHookConfig:
    call_hook as Boolean
    return_hook as Boolean
    line_hook as Boolean
    count_hook as Boolean
    hook_count as Integer

Data Type LuaSecurityConfig:
    disable_io as Boolean
    disable_os as Boolean
    disable_package as Boolean
    disable_debug as Boolean
    sandbox_mode as Boolean
    allowed_modules as List[String]

Note: Enhanced Result Types
Data Type LuaResult[T]:
    Case Success with value as T
    Case RuntimeError with message as String and error_code as Integer
    Case SyntaxError with error as LuaSyntaxError
    Case ExecutionError with error as LuaExecutionError
    Case MemoryError with details as String
    Case SecurityError with violation as String

Data Type LuaSyntaxError:
    message as String
    line as Integer
    column as Integer
    source as String

Data Type LuaExecutionError:
    message as String
    traceback as List[LuaStackFrame]
    error_type as LuaErrorType

Data Type LuaErrorType:
    Case Runtime
    Case Yield
    Case ErrorHandler
    Case Memory
    Case GC
    Case MessageHandler

Data Type LuaStackFrame:
    function_name as String
    source as String
    line as Integer
    is_c_function as Boolean
    is_tail_call as Boolean

Note: Lua Type System
Data Type LuaValue:
    lua_type as LuaType
    data as Any
    reference_id as Optional[Integer]

Data Type LuaType:
    Case Nil
    Case Boolean
    Case Number
    Case String
    Case Function
    Case Userdata
    Case Thread
    Case Table

Data Type LuaTable:
    array_part as List[LuaValue]
    hash_part as Dictionary[String, LuaValue]
    metatable as Optional[LuaTable]
    reference_id as Integer

Data Type LuaFunction:
    function_type as LuaFunctionType
    reference_id as Integer
    upvalue_count as Integer

Data Type LuaFunctionType:
    Case Lua
    Case C
    Case Closure

Data Type LuaThread:
    thread_id as Integer
    status as LuaThreadStatus
    stack_level as Integer

Data Type LuaThreadStatus:
    Case Running
    Case Suspended
    Case Normal
    Case Dead

Note: Core Runtime Operations
Process initialize_lua_runtime that takes config as LuaRuntimeConfig returns LuaResult[Integer]:
    Import "interop/ffi" as FFI
    Import "os" as OS
    Note: Load Lua library
    Let lua_lib_path be locate_lua_library(config.version)
    If lua_lib_path is Empty:
    Return LuaResult::RuntimeError with message "Lua library not found" and error_code 1001 Let lua_lib be FFI::load_library(lua_lib_path.value)
    If lua_lib is FFI::LibraryResult::LoadError:
    Return LuaResult::RuntimeError with message "Failed to load Lua library" and error_code 1002
    Note: Create new Lua state
    Let newstate_func be FFI::get_symbol(lua_lib, lua_newstate_symbol(config.version)) Let state_result be Empty
    If config.memory_allocator is LuaMemoryAllocator::System:
    Let luaL_newstate_func be FFI::get_symbol(lua_lib, "luaL_newstate")
    Set state_result to FFI::call_function(luaL_newstate_func, [])
    Otherwise if config.memory_allocator is LuaMemoryAllocator::Custom:
Note: Custom allocator would require more setup
    Let luaL_newstate_func be FFI::get_symbol(lua_lib, "luaL_newstate")
    Set state_result to FFI::call_function(luaL_newstate_func, [])
    Otherwise:
    Let luaL_newstate_func be FFI::get_symbol(lua_lib, "luaL_newstate")
    Set state_result to FFI::call_function(luaL_newstate_func, []) If state_result.return_code is not equal to 0 or state_result.lua_state is equal to 0:
    Return LuaResult::RuntimeError with message "Failed to create Lua state" and error_code state_result.return_code Let lua_state be state_result.lua_state
    Note: Set stack size
    If config.stack_size is greater than 0:
    Let checkstack_func be FFI::get_symbol(lua_lib, "lua_checkstack")
    Let stack_result be FFI::call_function(checkstack_func, [lua_state, config.stack_size])
    If stack_result.return_code is equal to 0:
    Return LuaResult::RuntimeError with message "Failed to set Lua stack size" and error_code 2001
    Note: Load standard libraries
    Let lib_result be load_lua_libraries(lua_lib, lua_state, config.preload_libraries)
    If lib_result is not LuaResult::Success:
    Return lib_result
    Note: Configure garbage collector
    Let gc_result be configure_lua_gc(lua_lib, lua_state, config.garbage_collection)
    If gc_result is not LuaResult::Success:
    Return gc_result
    Note: Set up hooks if configured
    If config.hook_config.call_hook or config.hook_config.return_hook or config.hook_config.line_hook:
    Let hook_result be setup_lua_hooks(lua_lib, lua_state, config.hook_config)
    If hook_result is not LuaResult::Success:
    Return hook_result
    Note: Apply security restrictions
    If config.security_config.sandbox_mode:
    Let security_result be apply_lua_security(lua_lib, lua_state, config.security_config)
    If security_result is not LuaResult::Success:
    Return security_result Set global_lua_runtime to lua_lib
    Set global_lua_state to lua_state
    Set lua_runtime_initialized to True Return LuaResult::Success with value lua_state

Process locate_lua_library that takes version as LuaVersion returns Optional[String]:
    Import "os" as OS
    Let os_type be OS::get_operating_system()
    Note: Library names for different versions
    Let lib_names be new List
    If version is LuaVersion::Lua51:
    Add "liblua5.1.so" to lib_names
    Add "liblua.so.5.1" to lib_names
    Add "lua51.dll" to lib_names
    Otherwise if version is LuaVersion::Lua52:
    Add "liblua5.2.so" to lib_names
    Add "liblua.so.5.2" to lib_names
    Add "lua52.dll" to lib_names
    Otherwise if version is LuaVersion::Lua53:
    Add "liblua5.3.so" to lib_names
    Add "liblua.so.5.3" to lib_names
    Add "lua53.dll" to lib_names
    Otherwise if version is LuaVersion::Lua54:
    Add "liblua5.4.so" to lib_names
    Add "liblua.so.5.4" to lib_names
    Add "lua54.dll" to lib_names
    Otherwise if version is LuaVersion::LuaJIT20:
    Add "libluajit-5.1.so" to lib_names
    Add "luajit.dll" to lib_names
    Otherwise if version is LuaVersion::LuaJIT21:
    Add "libluajit-5.1.so.2" to lib_names
    Add "luajit.dll" to lib_names
    Note: Common library paths
    Let lib_paths be new List containing
    "/usr/lib",
    "/usr/local/lib",
    "/opt/lua/lib",
    "/lib",
    "C:\\lua\\lib"
    For Each lib_name in lib_names:
    For Each lib_path in lib_paths:
    Let full_path be lib_path + "/" + lib_name
    If OS::file_exists(full_path):
    Return Some with value full_path
    Note: Try system library
    For Each lib_name in lib_names:
    If try_load_system_library(lib_name):
    Return Some with value lib_name Return Empty

Process try_load_system_library that takes lib_name as String returns Boolean:
Note: Try to load library without full path (system will find it)
    Let test_lib be FFI::load_library(lib_name)
    If test_lib is FFI::LibraryResult::Success:
    FFI::unload_library(test_lib)
    Return True
    Return False

Process lua_newstate_symbol that takes version as LuaVersion returns String:
Note: Different Lua versions may have different symbols
    If version is LuaVersion::LuaJIT20 or version is LuaVersion::LuaJIT21:
    Return "luaL_newstate"
    Otherwise:
    Return "luaL_newstate"

Process load_lua_libraries that takes lua_lib as Integer and lua_state as Integer and libraries as List[LuaLibrary] returns LuaResult[Boolean]:
    For Each library in libraries:
    Let load_result be load_lua_library(lua_lib, lua_state, library)
    If load_result is not LuaResult::Success:
    Return load_result Return LuaResult::Success with value True

Process load_lua_library that takes lua_lib as Integer and lua_state as Integer and library as LuaLibrary returns LuaResult[Boolean]:
    Let lib_func be Empty If library is LuaLibrary::Base:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_base")
    Otherwise if library is LuaLibrary::Coroutine:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_coroutine")
    Otherwise if library is LuaLibrary::Package:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_package")
    Otherwise if library is LuaLibrary::String:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_string")
    Otherwise if library is LuaLibrary::UTF8:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_utf8")
    Otherwise if library is LuaLibrary::Table:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_table")
    Otherwise if library is LuaLibrary::Math:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_math")
    Otherwise if library is LuaLibrary::IO:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_io")
    Otherwise if library is LuaLibrary::OS:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_os")
    Otherwise if library is LuaLibrary::Debug:
    Set lib_func to FFI::get_symbol(lua_lib, "luaopen_debug") If lib_func is Empty:
    Return LuaResult::RuntimeError with message "Library function not found" and error_code 2002
    Note: Load library
    Let load_result be FFI::call_function(lib_func, [lua_state])
    If load_result.return_code is not equal to 0:
    Return LuaResult::RuntimeError with message "Failed to load Lua library" and error_code load_result.return_code
    Note: Pop the result from stack
    Let pop_func be FFI::get_symbol(lua_lib, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 1]) Return LuaResult::Success with value True

Process configure_lua_gc that takes lua_lib as Integer and lua_state as Integer and config as LuaGCConfig returns LuaResult[Boolean]:
    Let gc_func be FFI::get_symbol(lua_lib, "lua_gc")
    Note: Set GC mode
    If config.mode is LuaGCMode::Stop:
    Let gc_result be FFI::call_function(gc_func, [lua_state, 0]) Note: LUA_GCSTOP
    If gc_result.return_code is less than 0:
    Return LuaResult::RuntimeError with message "Failed to stop GC" and error_code gc_result.return_code
    Otherwise if config.mode is LuaGCMode::Incremental:
    Let gc_result be FFI::call_function(gc_func, [lua_state, 1]) Note: LUA_GCRESTART
    If gc_result.return_code is less than 0:
    Return LuaResult::RuntimeError with message "Failed to restart GC" and error_code gc_result.return_code
    Note: Set GC parameters
    If config.pause is greater than 0:
    Let pause_result be FFI::call_function(gc_func, [lua_state, 6, config.pause]) Note: LUA_GCSETPAUSE
    If pause_result.return_code is less than 0:
    Return LuaResult::RuntimeError with message "Failed to set GC pause" and error_code pause_result.return_code If config.step_multiplier is greater than 0:
    Let step_result be FFI::call_function(gc_func, [lua_state, 7, config.step_multiplier]) Note: LUA_GCSETSTEPMUL
    If step_result.return_code is less than 0:
    Return LuaResult::RuntimeError with message "Failed to set GC step multiplier" and error_code step_result.return_code Return LuaResult::Success with value True

Note: Lua Code Execution
Process execute_lua_code that takes lua_state as Integer and code as String returns LuaResult[LuaValue]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001
    Note: Load and compile the code
    Let load_func be FFI::get_symbol(global_lua_runtime, "luaL_loadstring")
    Let load_result be FFI::call_function(load_func, [lua_state, code]) If load_result.return_code is not equal to 0:
    Let error_msg be get_lua_error_message(lua_state)
    Return LuaResult::SyntaxError with error LuaSyntaxError with:
    message as error_msg,
    line as 0,
    column as 0,
    source as code
    Note: Execute the loaded code
    Let call_func be FFI::get_symbol(global_lua_runtime, "lua_pcall")
    Let call_result be FFI::call_function(call_func, [
    lua_state,
    0, Note: nargs
    1, Note: nresults
    0 Note: errfunc
    ]) If call_result.return_code is not equal to 0:
    Let error_msg be get_lua_error_message(lua_state)
    Let traceback be get_lua_traceback(lua_state)
    Return LuaResult::ExecutionError with error LuaExecutionError with:
    message as error_msg,
    traceback as traceback,
    error_type as lua_error_type_from_code(call_result.return_code)
    Note: Get result from stack
    Let result_value be get_lua_stack_value(lua_state, -1)
    Note: Pop result from stack
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 1]) Return LuaResult::Success with value result_value

Process load_lua_file that takes lua_state as Integer and file_path as String returns LuaResult[LuaValue]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001 Import "os" as OS
    If not OS::file_exists(file_path):
    Return LuaResult::RuntimeError with message "Lua file not found: " + file_path and error_code 3002
    Note: Load file
    Let loadfile_func be FFI::get_symbol(global_lua_runtime, "luaL_loadfile")
    Let load_result be FFI::call_function(loadfile_func, [lua_state, file_path]) If load_result.return_code is not equal to 0:
    Let error_msg be get_lua_error_message(lua_state)
    Return LuaResult::SyntaxError with error LuaSyntaxError with:
    message as error_msg,
    line as 0,
    column as 0,
    source as file_path
    Note: Execute the loaded file
    Let call_func be FFI::get_symbol(global_lua_runtime, "lua_pcall")
    Let call_result be FFI::call_function(call_func, [
    lua_state,
    0, Note: nargs
    1, Note: nresults
    0 Note: errfunc
    ]) If call_result.return_code is not equal to 0:
    Let error_msg be get_lua_error_message(lua_state)
    Let traceback be get_lua_traceback(lua_state)
    Return LuaResult::ExecutionError with error LuaExecutionError with:
    message as error_msg,
    traceback as traceback,
    error_type as lua_error_type_from_code(call_result.return_code)
    Note: Get result from stack
    Let result_value be get_lua_stack_value(lua_state, -1)
    Note: Pop result from stack
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 1]) Return LuaResult::Success with value result_value

Note: Function Calls
Process call_lua_function that takes lua_state as Integer and function_name as String and arguments as List[LuaValue] returns LuaResult[LuaValue]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001
    Note: Get global function
    Let getglobal_func be FFI::get_symbol(global_lua_runtime, "lua_getglobal")
    Let get_result be FFI::call_function(getglobal_func, [lua_state, function_name])
    Note: Check if function exists and is callable
    Let type_func be FFI::get_symbol(global_lua_runtime, "lua_type")
    Let type_result be FFI::call_function(type_func, [lua_state, -1]) If type_result.lua_type is not equal to 6: Note: LUA_TFUNCTION
Note: Pop the non-function value
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 1])
    Return LuaResult::ExecutionError with error LuaExecutionError with:
    message as "'" + function_name + "' is not a function",
    traceback as new List,
    error_type as LuaErrorType::Runtime
    Note: Push arguments onto stack
    For Each arg in arguments:
    Let push_result be push_lua_value(lua_state, arg)
    If push_result is not LuaResult::Success:
    Return push_result
    Note: Call function
    Let call_func be FFI::get_symbol(global_lua_runtime, "lua_pcall")
    Let call_result be FFI::call_function(call_func, [
    lua_state,
    arguments.length, Note: nargs
    1, Note: nresults
    0 Note: errfunc
    ]) If call_result.return_code is not equal to 0:
    Let error_msg be get_lua_error_message(lua_state)
    Let traceback be get_lua_traceback(lua_state)
    Return LuaResult::ExecutionError with error LuaExecutionError with:
    message as error_msg,
    traceback as traceback,
    error_type as lua_error_type_from_code(call_result.return_code)
    Note: Get result from stack
    Let result_value be get_lua_stack_value(lua_state, -1)
    Note: Pop result from stack
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 1]) Return LuaResult::Success with value result_value

Note: Variable Management
Process set_lua_global that takes lua_state as Integer and name as String and value as LuaValue returns LuaResult[Boolean]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001
    Note: Push value onto stack
    Let push_result be push_lua_value(lua_state, value)
    If push_result is not LuaResult::Success:
    Return push_result
    Note: Set global variable
    Let setglobal_func be FFI::get_symbol(global_lua_runtime, "lua_setglobal")
    Let set_result be FFI::call_function(setglobal_func, [lua_state, name]) If set_result.return_code is not equal to 0:
    Return LuaResult::RuntimeError with message "Failed to set global variable" and error_code set_result.return_code Return LuaResult::Success with value True

Process get_lua_global that takes lua_state as Integer and name as String returns LuaResult[LuaValue]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001
    Note: Get global variable
    Let getglobal_func be FFI::get_symbol(global_lua_runtime, "lua_getglobal")
    Let get_result be FFI::call_function(getglobal_func, [lua_state, name])
    Note: Get value from stack
    Let value be get_lua_stack_value(lua_state, -1)
    Note: Pop value from stack
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 1]) Return LuaResult::Success with value value

Note: Table Operations
Process create_lua_table that takes lua_state as Integer and array_size as Integer and hash_size as Integer returns LuaResult[Integer]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001
    Note: Create new table
    Let createtable_func be FFI::get_symbol(global_lua_runtime, "lua_createtable")
    Let create_result be FFI::call_function(createtable_func, [lua_state, array_size, hash_size]) If create_result.return_code is not equal to 0:
    Return LuaResult::MemoryError with details "Failed to create Lua table"
    Note: Get reference to table
    Let ref_func be FFI::get_symbol(global_lua_runtime, "luaL_ref")
    Let registry_func be FFI::get_symbol(global_lua_runtime, "lua_pushvalue")
    FFI::call_function(registry_func, [lua_state, -1]) Note: Duplicate table on stack Let ref_result be FFI::call_function(ref_func, [lua_state, -10002]) Note: LUA_REGISTRYINDEX Return LuaResult::Success with value ref_result.reference_id

Process set_lua_table_field that takes lua_state as Integer and table_ref as Integer and key as String and value as LuaValue returns LuaResult[Boolean]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001
    Note: Get table from registry
    Let rawgeti_func be FFI::get_symbol(global_lua_runtime, "lua_rawgeti")
    FFI::call_function(rawgeti_func, [lua_state, -10002, table_ref]) Note: LUA_REGISTRYINDEX
    Note: Push key
    Let pushstring_func be FFI::get_symbol(global_lua_runtime, "lua_pushstring")
    FFI::call_function(pushstring_func, [lua_state, key])
    Note: Push value
    Let push_result be push_lua_value(lua_state, value)
    If push_result is not LuaResult::Success:
Note: Clean up stack
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 2]) Note: Pop table and key
    Return push_result
    Note: Set table field
    Let settable_func be FFI::get_symbol(global_lua_runtime, "lua_settable")
    FFI::call_function(settable_func, [lua_state, -3]) Note: Table is at index -3
    Note: Pop table from stack
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 1]) Return LuaResult::Success with value True

Process get_lua_table_field that takes lua_state as Integer and table_ref as Integer and key as String returns LuaResult[LuaValue]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001
    Note: Get table from registry
    Let rawgeti_func be FFI::get_symbol(global_lua_runtime, "lua_rawgeti")
    FFI::call_function(rawgeti_func, [lua_state, -10002, table_ref]) Note: LUA_REGISTRYINDEX
    Note: Push key and get field
    Let getfield_func be FFI::get_symbol(global_lua_runtime, "lua_getfield")
    Let get_result be FFI::call_function(getfield_func, [lua_state, -1, key])
    Note: Get value from stack
    Let value be get_lua_stack_value(lua_state, -1)
    Note: Pop value and table from stack
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 2]) Return LuaResult::Success with value value

Note: Coroutine Management
Process create_lua_coroutine that takes lua_state as Integer and function_code as String returns LuaResult[LuaThread]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001
    Note: Create new thread
    Let newthread_func be FFI::get_symbol(global_lua_runtime, "lua_newthread")
    Let thread_result be FFI::call_function(newthread_func, [lua_state]) If thread_result.thread_state is equal to 0:
    Return LuaResult::MemoryError with details "Failed to create Lua thread"
    Let thread_state be thread_result.thread_state
    Note: Load function into thread
    Let loadstring_func be FFI::get_symbol(global_lua_runtime, "luaL_loadstring")
    Let load_result be FFI::call_function(loadstring_func, [thread_state, function_code]) If load_result.return_code is not equal to 0:
    Let error_msg be get_lua_error_message(thread_state)
    Return LuaResult::SyntaxError with error LuaSyntaxError with:
    message as error_msg,
    line as 0,
    column as 0,
    source as function_code
    Note: Get thread reference
    Let ref_func be FFI::get_symbol(global_lua_runtime, "luaL_ref")
    Let ref_result be FFI::call_function(ref_func, [lua_state, -10002]) Note: LUA_REGISTRYINDEX Let thread be LuaThread with:
    thread_id as ref_result.reference_id,
    status as LuaThreadStatus::Suspended,
    stack_level as 0 Return LuaResult::Success with value thread

Process resume_lua_coroutine that takes lua_state as Integer and thread as LuaThread and arguments as List[LuaValue] returns LuaResult[List[LuaValue]]:
    If not lua_runtime_initialized:
    Return LuaResult::RuntimeError with message "Lua runtime not initialized" and error_code 3001
    Note: Get thread from registry
    Let rawgeti_func be FFI::get_symbol(global_lua_runtime, "lua_rawgeti")
    FFI::call_function(rawgeti_func, [lua_state, -10002, thread.thread_id]) Note: LUA_REGISTRYINDEX Let tothread_func be FFI::get_symbol(global_lua_runtime, "lua_tothread")
    Let thread_result be FFI::call_function(tothread_func, [lua_state, -1])
    Let thread_state be thread_result.thread_state
    Note: Push arguments onto thread stack
    For Each arg in arguments:
    Let push_result be push_lua_value(thread_state, arg)
    If push_result is not LuaResult::Success:
    Return push_result
    Note: Resume thread
    Let resume_func be FFI::get_symbol(global_lua_runtime, "lua_resume")
    Let resume_result be FFI::call_function(resume_func, [thread_state, lua_state, arguments.length])
    Note: Get results
    Let results be new List
    If resume_result.return_code is equal to 1: Note: LUA_YIELD
Note: Thread yielded, collect yielded values
    Let top_func be FFI::get_symbol(global_lua_runtime, "lua_gettop")
    Let top_result be FFI::call_function(top_func, [thread_state]) For i from 1 to top_result.stack_size:
    Let value be get_lua_stack_value(thread_state, i)
    Add value to results
    Otherwise if resume_result.return_code is equal to 0: Note: LUA_OK
Note: Thread finished, collect return values
    Let top_func be FFI::get_symbol(global_lua_runtime, "lua_gettop")
    Let top_result be FFI::call_function(top_func, [thread_state]) For i from 1 to top_result.stack_size:
    Let value be get_lua_stack_value(thread_state, i)
    Add value to results
    Otherwise:
Note: Thread error
    Let error_msg be get_lua_error_message(thread_state)
    Return LuaResult::ExecutionError with error LuaExecutionError with:
    message as error_msg,
    traceback as new List,
    error_type as LuaErrorType::Yield
    Note: Pop thread from main stack
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 1]) Return LuaResult::Success with value results

Note: Utility Functions
Process get_lua_stack_value that takes lua_state as Integer and index as Integer returns LuaValue:
    Let type_func be FFI::get_symbol(global_lua_runtime, "lua_type")
    Let type_result be FFI::call_function(type_func, [lua_state, index]) Let lua_type be lua_type_from_integer(type_result.lua_type) If lua_type is LuaType::Nil:
    Return LuaValue with lua_type as LuaType::Nil, data as Empty, reference_id as Empty
    Otherwise if lua_type is LuaType::Boolean:
    Let toboolean_func be FFI::get_symbol(global_lua_runtime, "lua_toboolean")
    Let bool_result be FFI::call_function(toboolean_func, [lua_state, index])
    Return LuaValue with lua_type as LuaType::Boolean, data as bool_result.boolean_value is not equal to 0, reference_id as Empty
    Otherwise if lua_type is LuaType::Number:
    Let tonumber_func be FFI::get_symbol(global_lua_runtime, "lua_tonumber")
    Let number_result be FFI::call_function(tonumber_func, [lua_state, index])
    Return LuaValue with lua_type as LuaType::Number, data as number_result.number_value, reference_id as Empty
    Otherwise if lua_type is LuaType::String:
    Let tolstring_func be FFI::get_symbol(global_lua_runtime, "lua_tolstring")
    Let string_result be FFI::call_function(tolstring_func, [lua_state, index, 0])
    Let string_value be read_string_from_memory(string_result.string_ptr, string_result.string_length)
    Return LuaValue with lua_type as LuaType::String, data as string_value, reference_id as Empty
    Otherwise if lua_type is LuaType::Table:
Note: Create reference to table
    Let pushvalue_func be FFI::get_symbol(global_lua_runtime, "lua_pushvalue")
    FFI::call_function(pushvalue_func, [lua_state, index]) Let ref_func be FFI::get_symbol(global_lua_runtime, "luaL_ref")
    Let ref_result be FFI::call_function(ref_func, [lua_state, -10002]) Note: LUA_REGISTRYINDEX Return LuaValue with lua_type as LuaType::Table, data as Empty, reference_id as Some with value ref_result.reference_id
    Otherwise if lua_type is LuaType::Function:
Note: Create reference to function
    Let pushvalue_func be FFI::get_symbol(global_lua_runtime, "lua_pushvalue")
    FFI::call_function(pushvalue_func, [lua_state, index]) Let ref_func be FFI::get_symbol(global_lua_runtime, "luaL_ref")
    Let ref_result be FFI::call_function(ref_func, [lua_state, -10002]) Note: LUA_REGISTRYINDEX Return LuaValue with lua_type as LuaType::Function, data as Empty, reference_id as Some with value ref_result.reference_id
    Otherwise:
    Return LuaValue with lua_type as LuaType::Nil, data as Empty, reference_id as Empty

Process push_lua_value that takes lua_state as Integer and value as LuaValue returns LuaResult[Boolean]:
    If value.lua_type is LuaType::Nil:
    Let pushnil_func be FFI::get_symbol(global_lua_runtime, "lua_pushnil")
    FFI::call_function(pushnil_func, [lua_state])
    Otherwise if value.lua_type is LuaType::Boolean:
    Let pushboolean_func be FFI::get_symbol(global_lua_runtime, "lua_pushboolean")
    Let bool_val be If Boolean::from_any(value.data) then 1 else 0
    FFI::call_function(pushboolean_func, [lua_state, bool_val])
    Otherwise if value.lua_type is LuaType::Number:
    Let pushnumber_func be FFI::get_symbol(global_lua_runtime, "lua_pushnumber")
    FFI::call_function(pushnumber_func, [lua_state, Float::from_any(value.data)])
    Otherwise if value.lua_type is LuaType::String:
    Let pushstring_func be FFI::get_symbol(global_lua_runtime, "lua_pushstring")
    FFI::call_function(pushstring_func, [lua_state, String::from_any(value.data)])
    Otherwise if value.lua_type is LuaType::Table and value.reference_id is not Empty:
    Let rawgeti_func be FFI::get_symbol(global_lua_runtime, "lua_rawgeti")
    FFI::call_function(rawgeti_func, [lua_state, -10002, value.reference_id.value]) Note: LUA_REGISTRYINDEX
    Otherwise if value.lua_type is LuaType::Function and value.reference_id is not Empty:
    Let rawgeti_func be FFI::get_symbol(global_lua_runtime, "lua_rawgeti")
    FFI::call_function(rawgeti_func, [lua_state, -10002, value.reference_id.value]) Note: LUA_REGISTRYINDEX
    Otherwise:
    Let pushnil_func be FFI::get_symbol(global_lua_runtime, "lua_pushnil")
    FFI::call_function(pushnil_func, [lua_state]) Return LuaResult::Success with value True

Process lua_type_from_integer that takes type_int as Integer returns LuaType:
    If type_int is equal to 0:
    Return LuaType::Nil
    Otherwise if type_int is equal to 1:
    Return LuaType::Boolean
    Otherwise if type_int is equal to 3:
    Return LuaType::Number
    Otherwise if type_int is equal to 4:
    Return LuaType::String
    Otherwise if type_int is equal to 5:
    Return LuaType::Table
    Otherwise if type_int is equal to 6:
    Return LuaType::Function
    Otherwise if type_int is equal to 7:
    Return LuaType::Userdata
    Otherwise if type_int is equal to 8:
    Return LuaType::Thread
    Otherwise:
    Return LuaType::Nil

Process get_lua_error_message that takes lua_state as Integer returns String:
    Let tolstring_func be FFI::get_symbol(global_lua_runtime, "lua_tolstring")
    Let error_result be FFI::call_function(tolstring_func, [lua_state, -1, 0]) If error_result.string_ptr is not equal to 0:
    Return read_string_from_memory(error_result.string_ptr, error_result.string_length) Return "Unknown Lua error"

Process get_lua_traceback that takes lua_state as Integer returns List[LuaStackFrame]:
Note: Get traceback using debug.traceback
    Let getglobal_func be FFI::get_symbol(global_lua_runtime, "lua_getglobal")
    FFI::call_function(getglobal_func, [lua_state, "debug"]) Let getfield_func be FFI::get_symbol(global_lua_runtime, "lua_getfield")
    FFI::call_function(getfield_func, [lua_state, -1, "traceback"]) Let call_func be FFI::get_symbol(global_lua_runtime, "lua_pcall")
    Let call_result be FFI::call_function(call_func, [lua_state, 0, 1, 0]) Let traceback_str be ""
    If call_result.return_code is equal to 0:
    Let tolstring_func be FFI::get_symbol(global_lua_runtime, "lua_tolstring")
    Let str_result be FFI::call_function(tolstring_func, [lua_state, -1, 0])
    Set traceback_str to read_string_from_memory(str_result.string_ptr, str_result.string_length)
    Note: Pop results
    Let pop_func be FFI::get_symbol(global_lua_runtime, "lua_pop")
    FFI::call_function(pop_func, [lua_state, 2]) Note: Pop debug table and traceback result Return parse_lua_traceback(traceback_str)

Process parse_lua_traceback that takes traceback as String returns List[LuaStackFrame]:
    Let frames be new List
    Let lines be String::split(traceback, "\n") For Each line in lines:
    Let trimmed be String::trim(line)
    If String::contains(trimmed, ":") and not String::starts_with(trimmed, "stack traceback"):
    Let frame be parse_lua_stack_frame_line(trimmed)
    If frame is not Empty:
    Add frame.value to frames Return frames

Process parse_lua_stack_frame_line that takes line as String returns Optional[LuaStackFrame]:
Note: Parse format like "filename:line: in function 'function_name'"
    Let colon_pos be String::find_first(line, ":")
    If colon_pos is Empty:
    Return Empty Let file_part be String::substring(line, 0, colon_pos.value)
    Let rest be String::substring(line, colon_pos.value + 1) Let second_colon be String::find_first(rest, ":")
    If second_colon is Empty:
    Return Empty Let line_str be String::trim(String::substring(rest, 0, second_colon.value))
    Let line_number be String::to_integer_safe(line_str)
    If line_number is Empty:
    Return Empty Let function_part be String::trim(String::substring(rest, second_colon.value + 1))
    Let function_name be extract_function_name(function_part) Let frame be LuaStackFrame with:
    function_name as function_name,
    source as file_part,
    line as line_number.value,
    is_c_function as String::contains(function_part, "[C]"),
    is_tail_call as String::contains(function_part, "(tail call)") Return Some with value frame

Process extract_function_name that takes function_part as String returns String:
    If String::contains(function_part, "in function"):
    Let parts be String::split(function_part, "in function")
    If parts.length is greater than 1:
    Let name_part be String::trim(parts[1])
    Return String::remove_prefix(String::remove_suffix(name_part, "'"), "'") Return "?"

Process lua_error_type_from_code that takes error_code as Integer returns LuaErrorType:
    If error_code is equal to 1:
    Return LuaErrorType::Yield
    Otherwise if error_code is equal to 2:
    Return LuaErrorType::Runtime
    Otherwise if error_code is equal to 3:
    Return LuaErrorType::Runtime
    Otherwise if error_code is equal to 4:
    Return LuaErrorType::Memory
    Otherwise if error_code is equal to 5:
    Return LuaErrorType::GC
    Otherwise if error_code is equal to 6:
    Return LuaErrorType::ErrorHandler
    Otherwise:
    Return LuaErrorType::Runtime

Process setup_lua_hooks that takes lua_lib as Integer and lua_state as Integer and config as LuaHookConfig returns LuaResult[Boolean]:
Note: Set up Lua hooks for debugging/profiling
    Let hook_mask be 0 If config.call_hook:
    Set hook_mask to hook_mask + 1 Note: LUA_MASKCALL If config.return_hook:
    Set hook_mask to hook_mask + 2 Note: LUA_MASKRET If config.line_hook:
    Set hook_mask to hook_mask + 4 Note: LUA_MASKLINE If config.count_hook:
    Set hook_mask to hook_mask + 8 Note: LUA_MASKCOUNT If hook_mask is greater than 0:
    Let sethook_func be FFI::get_symbol(lua_lib, "lua_sethook")
    Let hook_result be FFI::call_function(sethook_func, [lua_state, global_lua_hook_handler, hook_mask, config.hook_count]) If hook_result.return_code is not equal to 0:
    Return LuaResult::RuntimeError with message "Failed to set Lua hooks" and error_code hook_result.return_code Return LuaResult::Success with value True

Process apply_lua_security that takes lua_lib as Integer and lua_state as Integer and config as LuaSecurityConfig returns LuaResult[Boolean]:
Note: Remove dangerous functions if in sandbox mode
    If config.sandbox_mode:
    If config.disable_io:
    Let result be set_lua_global(lua_state, "io", LuaValue with lua_type as LuaType::Nil, data as Empty, reference_id as Empty)
    If result is not LuaResult::Success:
    Return result If config.disable_os:
    Let result be set_lua_global(lua_state, "os", LuaValue with lua_type as LuaType::Nil, data as Empty, reference_id as Empty)
    If result is not LuaResult::Success:
    Return result If config.disable_package:
    Let result be set_lua_global(lua_state, "package", LuaValue with lua_type as LuaType::Nil, data as Empty, reference_id as Empty)
    If result is not LuaResult::Success:
    Return result If config.disable_debug:
    Let result be set_lua_global(lua_state, "debug", LuaValue with lua_type as LuaType::Nil, data as Empty, reference_id as Empty)
    If result is not LuaResult::Success:
    Return result Return LuaResult::Success with value True

Process read_string_from_memory that takes ptr as Integer and length as Integer returns String:
    Return FFI::read_string_from_memory(ptr, length)

Note: Comprehensive Lua hook handler for debugging and profiling
Process global_lua_hook_handler that takes lua_state as Integer and ar as Integer returns Nothing:
    If lua_state is equal to 0 or ar is equal to 0:
    Return
    Note: Get hook information
    Let getinfo_func be FFI::get_symbol(global_lua_runtime, "lua_getinfo")
    If getinfo_func is Empty:
    Return
    Note: Extract debug information
    Let info_result be FFI::call_function(getinfo_func, [lua_state, "nSl", ar])
    If info_result.return_code is not equal to 0:
    Return
    Note: Handle different hook types
    Let hook_type be FFI::read_memory_int32(ar + 0) Note: Hook type from lua_Debug If hook_type is equal to 0: Note: LUA_HOOKCALL
    handle_lua_call_hook(lua_state, ar)
    Otherwise if hook_type is equal to 1: Note: LUA_HOOKRET
    handle_lua_return_hook(lua_state, ar)
    Otherwise if hook_type is equal to 2: Note: LUA_HOOKLINE
    handle_lua_line_hook(lua_state, ar)
    Otherwise if hook_type is equal to 3: Note: LUA_HOOKCOUNT
    handle_lua_count_hook(lua_state, ar)

Note: Global state
Let global_lua_runtime as Integer
Let global_lua_state as Integer
Let lua_runtime_initialized as Boolean = False

Note: High-level convenience functions
Process run_lua_code that takes source_code as String returns LuaResult[Any]:
    Let default_config be LuaRuntimeConfig with:
    version as LuaVersion::Lua54,
    memory_allocator as LuaMemoryAllocator::System,
    garbage_collection as LuaGCConfig with:
    mode as LuaGCMode::Incremental,
    pause as 200,
    step_multiplier as 200,
    minor_multiplier as 20,
    major_multiplier as 100,
    stack_size as 1000000,
    preload_libraries as new List containing LuaLibrary::Base, LuaLibrary::String, LuaLibrary::Table, LuaLibrary::Math,
    hook_config as LuaHookConfig with:
    call_hook as False,
    return_hook as False,
    line_hook as False,
    count_hook as False,
    hook_count as 0,
    security_config as LuaSecurityConfig with:
    disable_io as False,
    disable_os as False,
    disable_package as False,
    disable_debug as False,
    sandbox_mode as False,
    allowed_modules as new List If not lua_runtime_initialized:
    Let init_result be initialize_lua_runtime(default_config)
    If init_result is not LuaResult::Success:
    Return init_result
    Note: Execute the Lua code
    Let exec_result be execute_lua_code(global_lua_state, source_code)
    If exec_result is not LuaResult::Success:
    Return exec_result
    Note: Convert result to Runa type
    If exec_result.value.lua_type is LuaType::String:
    Return LuaResult::Success with value exec_result.value.data
    Otherwise if exec_result.value.lua_type is LuaType::Number:
    Return LuaResult::Success with value exec_result.value.data
    Otherwise if exec_result.value.lua_type is LuaType::Boolean:
    Return LuaResult::Success with value exec_result.value.data
    Otherwise:
    Return LuaResult::Success with value "Lua code executed successfully"

Process shutdown_lua_runtime that takes lua_state as Integer returns LuaResult[Boolean]:
    If not lua_runtime_initialized:
    Return LuaResult::Success with value True Let close_func be FFI::get_symbol(global_lua_runtime, "lua_close")
    FFI::call_function(close_func, [lua_state]) Set lua_runtime_initialized to False
    Set global_lua_runtime to 0
    Set global_lua_state to 0 Return LuaResult::Success with value True