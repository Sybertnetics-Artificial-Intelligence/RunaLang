Note:
Runa Standard Library: C Interop Module

This module provides comprehensive C language integration capabilities, enabling seamless
interoperation between Runa and C code. Features zero-copy data exchange, automatic
memory management, and advanced error handling.

Key Features:
- Zero-copy data exchange with automatic lifetime management
- C structure and union bidirectional mapping
- Function pointer and callback support
- Shared library dynamic loading
- Memory allocation coordination
- Exception-safe resource management
- Performance monitoring and optimization
- Thread-safe operations across C and Runa boundaries
- Automatic header parsing and binding generation
- POSIX and Windows API integration
- Inline assembly support with safety checks
- Memory protection and bounds checking
:End Note

Import "interop/ffi" as FFI
Import "collections/dict" as Dict
Import "collections/list" as List
Import "datetime/time" as Time
Import "uuid" as UUID
Import "errors" as Errors
Import "logging" as Log

Note: C Runtime Type System
Type CRuntime is Dictionary with:
    runtime_id as String
    compiler_type as CCompilerType
    target_architecture as CArchitecture
    loaded_libraries as Dictionary[String, CLibrary]
    function_cache as Dictionary[String, CFunction]
    struct_cache as Dictionary[String, CStruct]
    memory_allocator as CMemoryAllocator
    symbol_table as CSymbolTable
    error_handler as CErrorHandler
    performance_monitor as CPerformanceMonitor
    security_context as CSecurityContext
    header_parser as CHeaderParser
    inline_assembler as CInlineAssembler

Type CCompilerType is Enumeration with:
    GCC
    CLANG
    MSVC
    ICC
    TCC
    CUSTOM

Type CArchitecture is Enumeration with:
    X86
    X86_64
    ARM
    ARM64
    MIPS
    RISC_V
    SPARC
    POWER

Type CLibrary is Dictionary with:
    library_id as String
    library_name as String
    library_path as String
    library_handle as Integer
    exported_functions as Dictionary[String, CFunction]
    exported_symbols as Dictionary[String, CSymbol]
    dependencies as List[String]
    version as String
    architecture as String
    compiler_info as Dictionary[String, String]
    debug_symbols as Boolean
    is_system_library as Boolean
    security_attributes as Dictionary[String, Any]
    performance_profile as Dictionary[String, Number]

Type CFunction is Dictionary with:
    function_id as String
    function_name as String
    signature as String
    return_type as CType
    parameters as List[CParameter]
    calling_convention as CCallingConvention
    function_pointer as Integer
    is_variadic as Boolean
    is_inline as Boolean
    is_static as Boolean
    linkage as CLinkage
    attributes as List[String]
    documentation as String
    performance_hints as Dictionary[String, Any]
    safety_annotations as List[String]

Type CType is Dictionary with:
    type_id as String
    base_type as CBaseType
    qualifiers as List[CTypeQualifier]
    size as Integer
    alignment as Integer
    is_pointer as Boolean
    pointer_depth as Integer
    is_array as Boolean
    array_dimensions as List[Integer]
    is_function_pointer as Boolean
    struct_definition as CStruct
    union_definition as CUnion
    enum_definition as CEnum

Type CBaseType is Enumeration with:
    VOID
    CHAR
    SHORT
    INT
    LONG
    LONG_LONG
    FLOAT
    DOUBLE
    LONG_DOUBLE
    SIGNED_CHAR
    UNSIGNED_CHAR
    UNSIGNED_SHORT
    UNSIGNED_INT
    UNSIGNED_LONG
    UNSIGNED_LONG_LONG
    BOOL
    STRUCT
    UNION
    ENUM
    FUNCTION_POINTER

Type CTypeQualifier is Enumeration with:
    CONST
    VOLATILE
    RESTRICT
    ATOMIC

Type CParameter is Dictionary with:
    parameter_id as String
    name as String
    type as CType
    default_value as Any
    is_optional as Boolean
    annotations as List[String]

Type CCallingConvention is Enumeration with:
    CDECL
    STDCALL
    FASTCALL
    THISCALL
    VECTORCALL
