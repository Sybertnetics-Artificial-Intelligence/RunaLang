Note: Runa Standard Library - Asymmetric Cryptography
This module provides production-grade public key cryptography including RSA, ECDSA, EdDSA,
ECDH, X25519, Ed25519, and post-quantum algorithms for digital signatures, key exchange,
and public key encryption.

Supports multiple elliptic curves (P-256, P-384, P-521, secp256k1, Curve25519, Ed25519)
and various padding schemes (PKCS#1, PSS, OAEP) with comprehensive security features.

Specification compliance: FIPS 186-4, RFC 8032, RFC 7748, NIST SP 800-56A, and emerging PQC standards.

Import "crypto/primitives/random" as random
Import "crypto/primitives/bignum" as bignum
Import "crypto/primitives/curve" as curve
Import "crypto/primitives/field" as field
Import "crypto/hash" as hash

Type called "AsymmetricKeyPair":
    algorithm as String
    key_size as Integer
    private_key as PrivateKey
    public_key as PublicKey
    curve_name as Optional[String]
    key_usage as List[String]

Type called "PrivateKey":
    algorithm as String
    key_size as Integer
    key_bytes as List[Integer]
    parameters as Dictionary[String, Any]
    curve_name as Optional[String]

Type called "PublicKey":
    algorithm as String
    key_size as Integer
    key_bytes as List[Integer]
    parameters as Dictionary[String, Any]
    curve_name as Optional[String]

Type called "DigitalSignature":
    signature_bytes as List[Integer]
    algorithm as String
    hash_algorithm as String
    padding_scheme as Optional[String]
    r_component as Optional[List[Integer]]
    s_component as Optional[List[Integer]]

Type called "SharedSecret":
    secret_bytes as List[Integer]
    algorithm as String
    key_size as Integer
    derivation_info as Dictionary[String, Any]

Type AsymmetricResult is Union with:
    AsymmetricSuccess with value as Dictionary[String, Any]
    AsymmetricFailure with error as AsymmetricError and message as String

Type AsymmetricError is Enum with:
    Invalid_Key
    Invalid_Signature
    Invalid_Parameters
    Key_Generation_Failed
    Signature_Failed
    Verification_Failed
    Encryption_Failed
    Decryption_Failed
    Key_Exchange_Failed
    Unsupported_Algorithm
    Unsupported_Curve
    Invalid_Padding
    Weak_Key
    Internal_Error

Note: Asymmetric Algorithm Constants
Let RSA_2048 be "RSA-2048"
Let RSA_3072 be "RSA-3072"
Let RSA_4096 be "RSA-4096"
Let ECDSA_P256 be "ECDSA-P256"
Let ECDSA_P384 be "ECDSA-P384"
Let ECDSA_P521 be "ECDSA-P521"
Let ECDSA_SECP256K1 be "ECDSA-secp256k1"
Let ED25519 be "Ed25519"
Let X25519 be "X25519"
Let ECDH_P256 be "ECDH-P256"
Let ECDH_P384 be "ECDH-P384"
Let ECDH_P521 be "ECDH-P521"

Note: Curve Names
Let CURVE_P256 be "P-256"
Let CURVE_P384 be "P-384"
Let CURVE_P521 be "P-521"
Let CURVE_SECP256K1 be "secp256k1"
Let CURVE_25519 be "Curve25519"
Let CURVE_ED25519 be "Ed25519"

Note: Padding Schemes
Let PADDING_PKCS1 be "PKCS#1"
Let PADDING_PSS be "PSS"
Let PADDING_OAEP be "OAEP"
Let PADDING_NONE be "None"

Note: Key Usage Types
Let USAGE_SIGN be "sign"
Let USAGE_VERIFY be "verify"
Let USAGE_ENCRYPT be "encrypt"
Let USAGE_DECRYPT be "decrypt"
Let USAGE_KEY_AGREEMENT be "key_agreement"

Note: Primary Asymmetric Interface Functions

Process called "generate_key_pair" that takes algorithm as String and key_size as Optional[Integer] returns AsymmetricResult[AsymmetricKeyPair]:
    Note: Generate a new asymmetric key pair for the specified algorithm
    Try:
        Note: Validate algorithm and determine parameters
        Let validation_result be validate_key_generation_parameters with algorithm as algorithm and key_size as key_size
        Match validation_result:
            When AsymmetricFailure:
                Return validation_result
            When AsymmetricSuccess with value as params:
                Note: Generate key pair based on algorithm type
                Match algorithm:
                    When RSA_2048:
                        Return generate_rsa_key_pair with key_size as 2048
                    When RSA_3072:
                        Return generate_rsa_key_pair with key_size as 3072
                    When RSA_4096:
                        Return generate_rsa_key_pair with key_size as 4096
                    When ECDSA_P256:
                        Return generate_ecdsa_key_pair with curve as CURVE_P256
                    When ECDSA_P384:
                        Return generate_ecdsa_key_pair with curve as CURVE_P384
                    When ECDSA_P521:
                        Return generate_ecdsa_key_pair with curve as CURVE_P521
                    When ECDSA_SECP256K1:
                        Return generate_ecdsa_key_pair with curve as CURVE_SECP256K1
                    When ED25519:
                        Return generate_ed25519_key_pair
                    When X25519:
                        Return generate_x25519_key_pair
                    When ECDH_P256:
                        Return generate_ecdh_key_pair with curve as CURVE_P256
                    When ECDH_P384:
                        Return generate_ecdh_key_pair with curve as CURVE_P384
                    When ECDH_P521:
                        Return generate_ecdh_key_pair with curve as CURVE_P521
                    Otherwise:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Unsupported_Algorithm
                            message as "Unsupported asymmetric algorithm: " plus algorithm
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Key_Generation_Failed
            message as "Key generation error: " plus error as String

Process called "sign_message" that takes private_key as PrivateKey and message as List[Integer] and hash_algorithm as String and padding_scheme as Optional[String] returns AsymmetricResult[DigitalSignature]:
    Note: Create a digital signature for the given message using the private key
    Try:
        Note: Validate signing parameters
        Let validation_result be validate_signing_parameters with private_key as private_key and message as message and hash_algorithm as hash_algorithm and padding_scheme as padding_scheme
        Match validation_result:
            When AsymmetricFailure:
                Return validation_result
            When AsymmetricSuccess:
                Note: Hash the message first
                Let hash_result be hash.compute_hash with data as message and algorithm as hash_algorithm
                Match hash_result:
                    When hash.HashFailure:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Signature_Failed
                            message as "Message hashing failed: " plus hash_result.message
                    When hash.HashSuccess with value as message_hash:
                        Note: Perform algorithm-specific signing
                        Match private_key.algorithm:
                            When RSA_2048:
                                Return rsa_sign with private_key as private_key and message_hash as message_hash and hash_algorithm as hash_algorithm and padding_scheme as padding_scheme
                            When RSA_3072:
                                Return rsa_sign with private_key as private_key and message_hash as message_hash and hash_algorithm as hash_algorithm and padding_scheme as padding_scheme
                            When RSA_4096:
                                Return rsa_sign with private_key as private_key and message_hash as message_hash and hash_algorithm as hash_algorithm and padding_scheme as padding_scheme
                            When ECDSA_P256:
                                Return ecdsa_sign with private_key as private_key and message_hash as message_hash and hash_algorithm as hash_algorithm
                            When ECDSA_P384:
                                Return ecdsa_sign with private_key as private_key and message_hash as message_hash and hash_algorithm as hash_algorithm
                            When ECDSA_P521:
                                Return ecdsa_sign with private_key as private_key and message_hash as message_hash and hash_algorithm as hash_algorithm
                            When ECDSA_SECP256K1:
                                Return ecdsa_sign with private_key as private_key and message_hash as message_hash and hash_algorithm as hash_algorithm
                            When ED25519:
                                Return ed25519_sign with private_key as private_key and message as message
                            Otherwise:
                                Return AsymmetricFailure with:
                                    error as AsymmetricError.Unsupported_Algorithm
                                    message as "Signing not supported for algorithm: " plus private_key.algorithm
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Signature_Failed
            message as "Signature creation error: " plus error as String

Process called "verify_signature" that takes public_key as PublicKey and message as List[Integer] and signature as DigitalSignature returns AsymmetricResult[Boolean]:
    Note: Verify a digital signature against the message using the public key
    Try:
        Note: Validate verification parameters
        Let validation_result be validate_verification_parameters with public_key as public_key and message as message and signature as signature
        Match validation_result:
            When AsymmetricFailure:
                Return validation_result
            When AsymmetricSuccess:
                Note: Hash the message for verification
                Let hash_result be hash.compute_hash with data as message and algorithm as signature.hash_algorithm
                Match hash_result:
                    When hash.HashFailure:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Verification_Failed
                            message as "Message hashing failed: " plus hash_result.message
                    When hash.HashSuccess with value as message_hash:
                        Note: Perform algorithm-specific verification
                        Match public_key.algorithm:
                            When RSA_2048:
                                Return rsa_verify with public_key as public_key and message_hash as message_hash and signature as signature
                            When RSA_3072:
                                Return rsa_verify with public_key as public_key and message_hash as message_hash and signature as signature
                            When RSA_4096:
                                Return rsa_verify with public_key as public_key and message_hash as message_hash and signature as signature
                            When ECDSA_P256:
                                Return ecdsa_verify with public_key as public_key and message_hash as message_hash and signature as signature
                            When ECDSA_P384:
                                Return ecdsa_verify with public_key as public_key and message_hash as message_hash and signature as signature
                            When ECDSA_P521:
                                Return ecdsa_verify with public_key as public_key and message_hash as message_hash and signature as signature
                            When ECDSA_SECP256K1:
                                Return ecdsa_verify with public_key as public_key and message_hash as message_hash and signature as signature
                            When ED25519:
                                Return ed25519_verify with public_key as public_key and message as message and signature as signature
                            Otherwise:
                                Return AsymmetricFailure with:
                                    error as AsymmetricError.Unsupported_Algorithm
                                    message as "Verification not supported for algorithm: " plus public_key.algorithm
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Verification_Failed
            message as "Signature verification error: " plus error as String

Process called "encrypt_message" that takes public_key as PublicKey and plaintext as List[Integer] and padding_scheme as Optional[String] returns AsymmetricResult[List[Integer]]:
    Note: Encrypt a message using public key encryption (RSA only)
    Try:
        Note: Validate encryption parameters
        Let validation_result be validate_encryption_parameters with public_key as public_key and plaintext as plaintext and padding_scheme as padding_scheme
        Match validation_result:
            When AsymmetricFailure:
                Return validation_result
            When AsymmetricSuccess:
                Note: Only RSA supports direct encryption
                Match public_key.algorithm:
                    When RSA_2048:
                        Return rsa_encrypt with public_key as public_key and plaintext as plaintext and padding_scheme as padding_scheme
                    When RSA_3072:
                        Return rsa_encrypt with public_key as public_key and plaintext as plaintext and padding_scheme as padding_scheme
                    When RSA_4096:
                        Return rsa_encrypt with public_key as public_key and plaintext as plaintext and padding_scheme as padding_scheme
                    Otherwise:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Unsupported_Algorithm
                            message as "Public key encryption not supported for: " plus public_key.algorithm
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Encryption_Failed
            message as "Encryption error: " plus error as String

Process called "decrypt_message" that takes private_key as PrivateKey and ciphertext as List[Integer] and padding_scheme as Optional[String] returns AsymmetricResult[List[Integer]]:
    Note: Decrypt a message using private key decryption (RSA only)
    Try:
        Note: Validate decryption parameters
        Let validation_result be validate_decryption_parameters with private_key as private_key and ciphertext as ciphertext and padding_scheme as padding_scheme
        Match validation_result:
            When AsymmetricFailure:
                Return validation_result
            When AsymmetricSuccess:
                Note: Only RSA supports direct decryption
                Match private_key.algorithm:
                    When RSA_2048:
                        Return rsa_decrypt with private_key as private_key and ciphertext as ciphertext and padding_scheme as padding_scheme
                    When RSA_3072:
                        Return rsa_decrypt with private_key as private_key and ciphertext as ciphertext and padding_scheme as padding_scheme
                    When RSA_4096:
                        Return rsa_decrypt with private_key as private_key and ciphertext as ciphertext and padding_scheme as padding_scheme
                    Otherwise:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Unsupported_Algorithm
                            message as "Private key decryption not supported for: " plus private_key.algorithm
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Decryption_Failed
            message as "Decryption error: " plus error as String

Process called "perform_key_exchange" that takes private_key as PrivateKey and peer_public_key as PublicKey returns AsymmetricResult[SharedSecret]:
    Note: Perform key exchange to establish shared secret (ECDH/X25519)
    Try:
        Note: Validate key exchange parameters
        Let validation_result be validate_key_exchange_parameters with private_key as private_key and peer_public_key as peer_public_key
        Match validation_result:
            When AsymmetricFailure:
                Return validation_result
            When AsymmetricSuccess:
                Note: Perform algorithm-specific key exchange
                Match private_key.algorithm:
                    When X25519:
                        Return x25519_key_exchange with private_key as private_key and peer_public_key as peer_public_key
                    When ECDH_P256:
                        Return ecdh_key_exchange with private_key as private_key and peer_public_key as peer_public_key
                    When ECDH_P384:
                        Return ecdh_key_exchange with private_key as private_key and peer_public_key as peer_public_key
                    When ECDH_P521:
                        Return ecdh_key_exchange with private_key as private_key and peer_public_key as peer_public_key
                    Otherwise:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Unsupported_Algorithm
                            message as "Key exchange not supported for: " plus private_key.algorithm
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Key_Exchange_Failed
            message as "Key exchange error: " plus error as String

Note: RSA Implementation

Process called "generate_rsa_key_pair" that takes key_size as Integer returns AsymmetricResult[AsymmetricKeyPair]:
    Note: Generate RSA key pair with specified bit length
    Try:
        Note: Generate RSA parameters
        Let prime_p_result be generate_large_prime with bit_length as (key_size divided by 2)
        Match prime_p_result:
            When bignum.BignumFailure:
                Return AsymmetricFailure with:
                    error as AsymmetricError.Key_Generation_Failed
                    message as "Failed to generate prime p: " plus prime_p_result.message
            When bignum.BignumSuccess with value as p:
                Let prime_q_result be generate_large_prime with bit_length as (key_size divided by 2)
                Match prime_q_result:
                    When bignum.BignumFailure:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Key_Generation_Failed
                            message as "Failed to generate prime q: " plus prime_q_result.message
                    When bignum.BignumSuccess with value as q:
                        Note: Compute RSA modulus n = p * q
                        Let n_result be bignum.multiply with a as p and b as q
                        Match n_result:
                            When bignum.BignumSuccess with value as n:
                                Note: Compute Euler's totient φ(n) = (p-1)(q-1)
                                Let p_minus_1_result be bignum.subtract with a as p and b as bignum.one
                                Let q_minus_1_result be bignum.subtract with a as q and b as bignum.one
                                Match p_minus_1_result:
                                    When bignum.BignumSuccess with value as p_minus_1:
                                        Match q_minus_1_result:
                                            When bignum.BignumSuccess with value as q_minus_1:
                                                Let phi_result be bignum.multiply with a as p_minus_1 and b as q_minus_1
                                                Match phi_result:
                                                    When bignum.BignumSuccess with value as phi:
                                                        Note: Use standard public exponent e = 65537
                                                        Let e be bignum.from_integer with value as 65537
                                                        
                                                        Note: Compute private exponent d = e^(-1) mod φ(n)
                                                        Let d_result be bignum.modular_inverse with a as e and modulus as phi
                                                        Match d_result:
                                                            When bignum.BignumSuccess with value as d:
                                                                Note: Create key structures
                                                                Let private_params be dictionary containing:
                                                                    "n" as n,
                                                                    "e" as e,
                                                                    "d" as d,
                                                                    "p" as p,
                                                                    "q" as q,
                                                                    "dp" as bignum.modulo with a as d and b as p_minus_1,
                                                                    "dq" as bignum.modulo with a as d and b as q_minus_1,
                                                                    "qinv" as bignum.modular_inverse with a as q and modulus as p
                                                                
                                                                Let public_params be dictionary containing:
                                                                    "n" as n,
                                                                    "e" as e
                                                                
                                                                Let private_key be PrivateKey with:
                                                                    algorithm as "RSA-" plus key_size as String
                                                                    key_size as key_size
                                                                    key_bytes as bignum.to_bytes with value as d
                                                                    parameters as private_params
                                                                    curve_name as None
                                                                
                                                                Let public_key be PublicKey with:
                                                                    algorithm as "RSA-" plus key_size as String
                                                                    key_size as key_size
                                                                    key_bytes as bignum.to_bytes with value as n
                                                                    parameters as public_params
                                                                    curve_name as None
                                                                
                                                                Let key_pair be AsymmetricKeyPair with:
                                                                    algorithm as "RSA-" plus key_size as String
                                                                    key_size as key_size
                                                                    private_key as private_key
                                                                    public_key as public_key
                                                                    curve_name as None
                                                                    key_usage as list containing USAGE_SIGN, USAGE_VERIFY, USAGE_ENCRYPT, USAGE_DECRYPT
                                                                
                                                                Return AsymmetricSuccess with value as key_pair
                                                            When bignum.BignumFailure:
                                                                Return AsymmetricFailure with:
                                                                    error as AsymmetricError.Key_Generation_Failed
                                                                    message as "Failed to compute private exponent"
                                                    When bignum.BignumFailure:
                                                        Return AsymmetricFailure with:
                                                            error as AsymmetricError.Key_Generation_Failed
                                                            message as "Failed to compute Euler's totient"
                                            When bignum.BignumFailure:
                                                Return AsymmetricFailure with:
                                                    error as AsymmetricError.Key_Generation_Failed
                                                    message as "Failed to compute q-1"
                                    When bignum.BignumFailure:
                                        Return AsymmetricFailure with:
                                            error as AsymmetricError.Key_Generation_Failed
                                            message as "Failed to compute p-1"
                            When bignum.BignumFailure:
                                Return AsymmetricFailure with:
                                    error as AsymmetricError.Key_Generation_Failed
                                    message as "Failed to compute RSA modulus"
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Key_Generation_Failed
            message as "RSA key generation error: " plus error as String

Process called "rsa_sign" that takes private_key as PrivateKey and message_hash as List[Integer] and hash_algorithm as String and padding_scheme as Optional[String] returns AsymmetricResult[DigitalSignature]:
    Note: Create RSA digital signature using PKCS#1 or PSS padding
    Try:
        Let padding be padding_scheme if padding_scheme is not None else PADDING_PKCS1
        
        Note: Prepare padded message based on scheme
        Let padded_message_result be apply_rsa_signature_padding with message_hash as message_hash and hash_algorithm as hash_algorithm and padding_scheme as padding and key_size as private_key.key_size
        Match padded_message_result:
            When AsymmetricFailure:
                Return padded_message_result
            When AsymmetricSuccess with value as padded_message:
                Note: Convert padded message to bignum
                Let message_bignum_result be bignum.from_bytes with bytes as padded_message
                Match message_bignum_result:
                    When bignum.BignumSuccess with value as message_bignum:
                        Note: Perform RSA signature operation: s = m^d mod n
                        Let n be private_key.parameters["n"]
                        Let d be private_key.parameters["d"]
                        
                        Let signature_result be bignum.modular_exponentiation with base as message_bignum and exponent as d and modulus as n
                        Match signature_result:
                            When bignum.BignumSuccess with value as signature_bignum:
                                Let signature_bytes be bignum.to_bytes with value as signature_bignum
                                
                                Let signature be DigitalSignature with:
                                    signature_bytes as signature_bytes
                                    algorithm as private_key.algorithm
                                    hash_algorithm as hash_algorithm
                                    padding_scheme as Some with value as padding
                                    r_component as None
                                    s_component as None
                                
                                Return AsymmetricSuccess with value as signature
                            When bignum.BignumFailure:
                                Return AsymmetricFailure with:
                                    error as AsymmetricError.Signature_Failed
                                    message as "RSA signature computation failed"
                    When bignum.BignumFailure:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Signature_Failed
                            message as "Failed to convert padded message to bignum"
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Signature_Failed
            message as "RSA signature error: " plus error as String

Process called "rsa_verify" that takes public_key as PublicKey and message_hash as List[Integer] and signature as DigitalSignature returns AsymmetricResult[Boolean]:
    Note: Verify RSA digital signature using PKCS#1 or PSS padding
    Try:
        Note: Convert signature to bignum
        Let signature_bignum_result be bignum.from_bytes with bytes as signature.signature_bytes
        Match signature_bignum_result:
            When bignum.BignumSuccess with value as signature_bignum:
                Note: Perform RSA verification operation: m = s^e mod n
                Let n be public_key.parameters["n"]
                Let e be public_key.parameters["e"]
                
                Let recovered_result be bignum.modular_exponentiation with base as signature_bignum and exponent as e and modulus as n
                Match recovered_result:
                    When bignum.BignumSuccess with value as recovered_bignum:
                        Let recovered_bytes be bignum.to_bytes with value as recovered_bignum
                        
                        Note: Verify padding and hash
                        Let padding be signature.padding_scheme if signature.padding_scheme is not None else PADDING_PKCS1
                        Let verification_result be verify_rsa_signature_padding with recovered_bytes as recovered_bytes and message_hash as message_hash and hash_algorithm as signature.hash_algorithm and padding_scheme as padding and key_size as public_key.key_size
                        
                        Return verification_result
                    When bignum.BignumFailure:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Verification_Failed
                            message as "RSA verification computation failed"
            When bignum.BignumFailure:
                Return AsymmetricFailure with:
                    error as AsymmetricError.Verification_Failed
                    message as "Failed to convert signature to bignum"
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Verification_Failed
            message as "RSA verification error: " plus error as String

Note: ECDSA Implementation

Process called "generate_ecdsa_key_pair" that takes curve as String returns AsymmetricResult[AsymmetricKeyPair]:
    Note: Generate ECDSA key pair on specified elliptic curve
    Try:
        Note: Get curve parameters
        Let curve_params_result be curve.get_curve_parameters with curve_name as curve
        Match curve_params_result:
            When curve.CurveFailure:
                Return AsymmetricFailure with:
                    error as AsymmetricError.Unsupported_Curve
                    message as "Unsupported curve: " plus curve
            When curve.CurveSuccess with value as curve_params:
                Note: Generate private key as random scalar in [1, n-1]
                Let order be curve_params["order"]
                Let private_scalar_result be generate_random_scalar with max_value as order
                Match private_scalar_result:
                    When AsymmetricFailure:
                        Return private_scalar_result
                    When AsymmetricSuccess with value as private_scalar:
                        Note: Compute public key as G * private_scalar
                        Let generator be curve_params["generator"]
                        Let public_point_result be curve.point_multiply with point as generator and scalar as private_scalar and curve_params as curve_params
                        Match public_point_result:
                            When curve.CurveSuccess with value as public_point:
                                Note: Encode keys
                                Let private_key_bytes be bignum.to_bytes with value as private_scalar
                                Let public_key_bytes be curve.point_to_bytes with point as public_point and compressed as false
                                
                                Let private_key be PrivateKey with:
                                    algorithm as "ECDSA-" plus curve
                                    key_size be curve.get_curve_key_size with curve_name as curve
                                    key_bytes as private_key_bytes
                                    parameters as dictionary containing: "curve" as curve, "private_scalar" as private_scalar
                                    curve_name as Some with value as curve
                                
                                Let public_key be PublicKey with:
                                    algorithm as "ECDSA-" plus curve
                                    key_size be curve.get_curve_key_size with curve_name as curve
                                    key_bytes as public_key_bytes
                                    parameters as dictionary containing: "curve" as curve, "public_point" as public_point
                                    curve_name as Some with value as curve
                                
                                Let key_pair be AsymmetricKeyPair with:
                                    algorithm as "ECDSA-" plus curve
                                    key_size be curve.get_curve_key_size with curve_name as curve
                                    private_key as private_key
                                    public_key as public_key
                                    curve_name as Some with value as curve
                                    key_usage as list containing USAGE_SIGN, USAGE_VERIFY
                                
                                Return AsymmetricSuccess with value as key_pair
                            When curve.CurveFailure:
                                Return AsymmetricFailure with:
                                    error as AsymmetricError.Key_Generation_Failed
                                    message as "Failed to compute public key point: " plus public_point_result.message
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Key_Generation_Failed
            message as "ECDSA key generation error: " plus error as String

Process called "ecdsa_sign" that takes private_key as PrivateKey and message_hash as List[Integer] and hash_algorithm as String returns AsymmetricResult[DigitalSignature]:
    Note: Create ECDSA digital signature using RFC 6979 deterministic nonce
    Try:
        Note: Get curve parameters
        Let curve_name be private_key.parameters["curve"]
        Let curve_params_result be curve.get_curve_parameters with curve_name as curve_name
        Match curve_params_result:
            When curve.CurveSuccess with value as curve_params:
                Let order be curve_params["order"]
                Let generator be curve_params["generator"]
                Let private_scalar be private_key.parameters["private_scalar"]
                
                Note: Convert message hash to integer
                Let hash_integer_result be bignum.from_bytes with bytes as message_hash
                Match hash_integer_result:
                    When bignum.BignumSuccess with value as hash_integer:
                        Note: Generate deterministic nonce using RFC 6979
                        Let nonce_result be generate_rfc6979_nonce with private_key as private_scalar and message_hash as hash_integer and order as order and hash_algorithm as hash_algorithm
                        Match nonce_result:
                            When AsymmetricSuccess with value as k:
                                Note: Compute r = (k * G).x mod n
                                Let r_point_result be curve.point_multiply with point as generator and scalar as k and curve_params as curve_params
                                Match r_point_result:
                                    When curve.CurveSuccess with value as r_point:
                                        Let r_coordinate be curve.point_get_x with point as r_point
                                        Let r_result be bignum.modulo with a as r_coordinate and b as order
                                        Match r_result:
                                            When bignum.BignumSuccess with value as r:
                                                Note: Check r ≠ 0
                                                If bignum.is_zero with value as r:
                                                    Return AsymmetricFailure with:
                                                        error as AsymmetricError.Signature_Failed
                                                        message as "ECDSA signature r component is zero"
                                                
                                                Note: Compute s = k^(-1) * (hash + r * private_key) mod n
                                                Let k_inv_result be bignum.modular_inverse with a as k and modulus as order
                                                Match k_inv_result:
                                                    When bignum.BignumSuccess with value as k_inv:
                                                        Let r_times_private_result be bignum.multiply with a as r and b as private_scalar
                                                        Match r_times_private_result:
                                                            When bignum.BignumSuccess with value as r_times_private:
                                                                Let hash_plus_r_private_result be bignum.add with a as hash_integer and b as r_times_private
                                                                Match hash_plus_r_private_result:
                                                                    When bignum.BignumSuccess with value as hash_plus_r_private:
                                                                        Let s_result be bignum.multiply with a as k_inv and b as hash_plus_r_private
                                                                        Match s_result:
                                                                            When bignum.BignumSuccess with value as s_temp:
                                                                                Let s_final_result be bignum.modulo with a as s_temp and b as order
                                                                                Match s_final_result:
                                                                                    When bignum.BignumSuccess with value as s:
                                                                                        Note: Check s ≠ 0
                                                                                        If bignum.is_zero with value as s:
                                                                                            Return AsymmetricFailure with:
                                                                                                error as AsymmetricError.Signature_Failed
                                                                                                message as "ECDSA signature s component is zero"
                                                                                        
                                                                                        Note: Apply low-s malleability fix (if s > n/2, use n - s)
                                                                                        Let half_order_result be bignum.divide with a as order and b as bignum.from_integer with value as 2
                                                                                        Match half_order_result:
                                                                                            When bignum.BignumSuccess with value as half_order:
                                                                                                Let s_final be if bignum.compare with a as s and b as half_order is greater than 0:
                                                                                                    bignum.subtract with a as order and b as s
                                                                                                else:
                                                                                                    s
                                                                                                
                                                                                                Let r_bytes be bignum.to_bytes with value as r
                                                                                                Let s_bytes be bignum.to_bytes with value as s_final
                                                                                                
                                                                                                Note: Encode signature as DER or concatenated r||s
                                                                                                Let signature_bytes be encode_ecdsa_signature with r as r_bytes and s as s_bytes
                                                                                                
                                                                                                Let signature be DigitalSignature with:
                                                                                                    signature_bytes as signature_bytes
                                                                                                    algorithm as private_key.algorithm
                                                                                                    hash_algorithm as hash_algorithm
                                                                                                    padding_scheme as None
                                                                                                    r_component as Some with value as r_bytes
                                                                                                    s_component as Some with value as s_bytes
                                                                                                
                                                                                                Return AsymmetricSuccess with value as signature
                                                                                            When bignum.BignumFailure:
                                                                                                Return AsymmetricFailure with:
                                                                                                    error as AsymmetricError.Signature_Failed
                                                                                                    message as "Failed to compute half order"
                                                                                    When bignum.BignumFailure:
                                                                                        Return AsymmetricFailure with:
                                                                                            error as AsymmetricError.Signature_Failed
                                                                                            message as "Failed to compute s modulo order"
                                                                            When bignum.BignumFailure:
                                                                                Return AsymmetricFailure with:
                                                                                    error as AsymmetricError.Signature_Failed
                                                                                    message as "Failed to compute s component"
                                                                    When bignum.BignumFailure:
                                                                        Return AsymmetricFailure with:
                                                                            error as AsymmetricError.Signature_Failed
                                                                            message as "Failed to add hash and r*private"
                                                            When bignum.BignumFailure:
                                                                Return AsymmetricFailure with:
                                                                    error as AsymmetricError.Signature_Failed
                                                                    message as "Failed to compute r * private_key"
                                                    When bignum.BignumFailure:
                                                        Return AsymmetricFailure with:
                                                            error as AsymmetricError.Signature_Failed
                                                            message as "Failed to compute k inverse"
                                            When bignum.BignumFailure:
                                                Return AsymmetricFailure with:
                                                    error as AsymmetricError.Signature_Failed
                                                    message as "Failed to compute r modulo order"
                                    When curve.CurveFailure:
                                        Return AsymmetricFailure with:
                                            error as AsymmetricError.Signature_Failed
                                            message as "Failed to compute r point: " plus r_point_result.message
                            When AsymmetricFailure:
                                Return nonce_result
                    When bignum.BignumFailure:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Signature_Failed
                            message as "Failed to convert message hash to integer"
            When curve.CurveFailure:
                Return AsymmetricFailure with:
                    error as AsymmetricError.Signature_Failed
                    message as "Failed to get curve parameters: " plus curve_params_result.message
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Signature_Failed
            message as "ECDSA signature error: " plus error as String

Process called "ecdsa_verify" that takes public_key as PublicKey and message_hash as List[Integer] and signature as DigitalSignature returns AsymmetricResult[Boolean]:
    Note: Verify ECDSA digital signature
    Try:
        Note: Decode signature components
        Let decode_result be decode_ecdsa_signature with signature_bytes as signature.signature_bytes
        Match decode_result:
            When AsymmetricSuccess with value as components:
                Let r_bytes be components["r"]
                Let s_bytes be components["s"]
                
                Note: Convert to bignums
                Let r_result be bignum.from_bytes with bytes as r_bytes
                Let s_result be bignum.from_bytes with bytes as s_bytes
                Let hash_result be bignum.from_bytes with bytes as message_hash
                
                Match r_result:
                    When bignum.BignumSuccess with value as r:
                        Match s_result:
                            When bignum.BignumSuccess with value as s:
                                Match hash_result:
                                    When bignum.BignumSuccess with value as hash_integer:
                                        Note: Get curve parameters
                                        Let curve_name be public_key.parameters["curve"]
                                        Let curve_params_result be curve.get_curve_parameters with curve_name as curve_name
                                        Match curve_params_result:
                                            When curve.CurveSuccess with value as curve_params:
                                                Let order be curve_params["order"]
                                                Let generator be curve_params["generator"]
                                                Let public_point be public_key.parameters["public_point"]
                                                
                                                Note: Verify r and s are in valid range [1, n-1]
                                                If bignum.is_zero with value as r or bignum.compare with a as r and b as order is greater than or equal to 0:
                                                    Return AsymmetricSuccess with value as false
                                                
                                                If bignum.is_zero with value as s or bignum.compare with a as s and b as order is greater than or equal to 0:
                                                    Return AsymmetricSuccess with value as false
                                                
                                                Note: Compute w = s^(-1) mod n
                                                Let w_result be bignum.modular_inverse with a as s and modulus as order
                                                Match w_result:
                                                    When bignum.BignumSuccess with value as w:
                                                        Note: Compute u1 = hash * w mod n
                                                        Let u1_temp_result be bignum.multiply with a as hash_integer and b as w
                                                        Match u1_temp_result:
                                                            When bignum.BignumSuccess with value as u1_temp:
                                                                Let u1_result be bignum.modulo with a as u1_temp and b as order
                                                                Match u1_result:
                                                                    When bignum.BignumSuccess with value as u1:
                                                                        Note: Compute u2 = r * w mod n
                                                                        Let u2_temp_result be bignum.multiply with a as r and b as w
                                                                        Match u2_temp_result:
                                                                            When bignum.BignumSuccess with value as u2_temp:
                                                                                Let u2_result be bignum.modulo with a as u2_temp and b as order
                                                                                Match u2_result:
                                                                                    When bignum.BignumSuccess with value as u2:
                                                                                        Note: Compute verification point = u1*G + u2*public_key
                                                                                        Let u1_g_result be curve.point_multiply with point as generator and scalar as u1 and curve_params as curve_params
                                                                                        Match u1_g_result:
                                                                                            When curve.CurveSuccess with value as u1_g:
                                                                                                Let u2_pub_result be curve.point_multiply with point as public_point and scalar as u2 and curve_params as curve_params
                                                                                                Match u2_pub_result:
                                                                                                    When curve.CurveSuccess with value as u2_pub:
                                                                                                        Let verification_point_result be curve.point_add with a as u1_g and b as u2_pub and curve_params as curve_params
                                                                                                        Match verification_point_result:
                                                                                                            When curve.CurveSuccess with value as verification_point:
                                                                                                                Note: Check if verification point is at infinity
                                                                                                                If curve.is_point_at_infinity with point as verification_point:
                                                                                                                    Return AsymmetricSuccess with value as false
                                                                                                                
                                                                                                                Note: Compute v = verification_point.x mod n
                                                                                                                Let v_coordinate be curve.point_get_x with point as verification_point
                                                                                                                Let v_result be bignum.modulo with a as v_coordinate and b as order
                                                                                                                Match v_result:
                                                                                                                    When bignum.BignumSuccess with value as v:
                                                                                                                        Note: Signature is valid if v == r
                                                                                                                        Let is_valid be bignum.equals with a as v and b as r
                                                                                                                        Return AsymmetricSuccess with value as is_valid
                                                                                                                    When bignum.BignumFailure:
                                                                                                                        Return AsymmetricSuccess with value as false
                                                                                                            When curve.CurveFailure:
                                                                                                                Return AsymmetricSuccess with value as false
                                                                                                    When curve.CurveFailure:
                                                                                                        Return AsymmetricSuccess with value as false
                                                                                            When curve.CurveFailure:
                                                                                                Return AsymmetricSuccess with value as false
                                                                                    When bignum.BignumFailure:
                                                                                        Return AsymmetricSuccess with value as false
                                                                            When bignum.BignumFailure:
                                                                                Return AsymmetricSuccess with value as false
                                                                    When bignum.BignumFailure:
                                                                        Return AsymmetricSuccess with value as false
                                                            When bignum.BignumFailure:
                                                                Return AsymmetricSuccess with value as false
                                                    When bignum.BignumFailure:
                                                        Return AsymmetricSuccess with value as false
                                            When curve.CurveFailure:
                                                Return AsymmetricFailure with:
                                                    error as AsymmetricError.Verification_Failed
                                                    message as "Failed to get curve parameters"
                                    When bignum.BignumFailure:
                                        Return AsymmetricFailure with:
                                            error as AsymmetricError.Verification_Failed
                                            message as "Failed to convert message hash to integer"
                            When bignum.BignumFailure:
                                Return AsymmetricFailure with:
                                    error as AsymmetricError.Verification_Failed
                                    message as "Failed to convert s component to integer"
                    When bignum.BignumFailure:
                        Return AsymmetricFailure with:
                            error as AsymmetricError.Verification_Failed
                            message as "Failed to convert r component to integer"
            When AsymmetricFailure:
                Return decode_result
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Verification_Failed
            message as "ECDSA verification error: " plus error as String

Note: Ed25519 Implementation

Process called "generate_ed25519_key_pair" returns AsymmetricResult[AsymmetricKeyPair]:
    Note: Generate Ed25519 key pair using Curve25519
    Try:
        Note: Generate 32-byte private key
        Let private_bytes_result be random.generate_secure_bytes with count as 32
        Match private_bytes_result:
            When random.RandomSuccess with value as private_bytes:
                Note: Compute public key using Ed25519 base point
                Let public_bytes_result be ed25519_compute_public_key with private_key as private_bytes
                Match public_bytes_result:
                    When AsymmetricSuccess with value as public_bytes:
                        Let private_key be PrivateKey with:
                            algorithm as ED25519
                            key_size as 32
                            key_bytes as private_bytes
                            parameters as dictionary containing: "curve" as CURVE_ED25519
                            curve_name as Some with value as CURVE_ED25519
                        
                        Let public_key be PublicKey with:
                            algorithm as ED25519
                            key_size as 32
                            key_bytes as public_bytes
                            parameters as dictionary containing: "curve" as CURVE_ED25519
                            curve_name as Some with value as CURVE_ED25519
                        
                        Let key_pair be AsymmetricKeyPair with:
                            algorithm as ED25519
                            key_size as 32
                            private_key as private_key
                            public_key as public_key
                            curve_name as Some with value as CURVE_ED25519
                            key_usage as list containing USAGE_SIGN, USAGE_VERIFY
                        
                        Return AsymmetricSuccess with value as key_pair
                    When AsymmetricFailure:
                        Return public_bytes_result
            When random.RandomFailure:
                Return AsymmetricFailure with:
                    error as AsymmetricError.Key_Generation_Failed
                    message as "Failed to generate Ed25519 private key"
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Key_Generation_Failed
            message as "Ed25519 key generation error: " plus error as String

Process called "ed25519_sign" that takes private_key as PrivateKey and message as List[Integer] returns AsymmetricResult[DigitalSignature]:
    Note: Create Ed25519 signature using RFC 8032
    Try:
        Note: Ed25519 signature is deterministic and doesn't require pre-hashing
        Let signature_result be ed25519_sign_message with private_key as private_key.key_bytes and message as message
        Match signature_result:
            When AsymmetricSuccess with value as signature_bytes:
                Let signature be DigitalSignature with:
                    signature_bytes as signature_bytes
                    algorithm as ED25519
                    hash_algorithm as "Ed25519-Internal"
                    padding_scheme as None
                    r_component as Some with value as (signature_bytes from index 0 to 31)
                    s_component as Some with value as (signature_bytes from index 32 to 63)
                
                Return AsymmetricSuccess with value as signature
            When AsymmetricFailure:
                Return signature_result
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Signature_Failed
            message as "Ed25519 signature error: " plus error as String

Process called "ed25519_verify" that takes public_key as PublicKey and message as List[Integer] and signature as DigitalSignature returns AsymmetricResult[Boolean]:
    Note: Verify Ed25519 signature using RFC 8032
    Try:
        Let verification_result be ed25519_verify_signature with public_key as public_key.key_bytes and message as message and signature as signature.signature_bytes
        Return verification_result
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Verification_Failed
            message as "Ed25519 verification error: " plus error as String

Note: X25519 Key Exchange Implementation

Process called "generate_x25519_key_pair" returns AsymmetricResult[AsymmetricKeyPair]:
    Note: Generate X25519 key pair for ECDH
    Try:
        Note: Generate 32-byte private key
        Let private_bytes_result be random.generate_secure_bytes with count as 32
        Match private_bytes_result:
            When random.RandomSuccess with value as private_bytes:
                Note: Clamp private key bits per RFC 7748
                Let clamped_private be clamp_x25519_private_key with private_key as private_bytes
                
                Note: Compute public key = private * base_point
                Let public_bytes_result be x25519_compute_public_key with private_key as clamped_private
                Match public_bytes_result:
                    When AsymmetricSuccess with value as public_bytes:
                        Let private_key be PrivateKey with:
                            algorithm as X25519
                            key_size as 32
                            key_bytes as clamped_private
                            parameters as dictionary containing: "curve" as CURVE_25519
                            curve_name as Some with value as CURVE_25519
                        
                        Let public_key be PublicKey with:
                            algorithm as X25519
                            key_size as 32
                            key_bytes as public_bytes
                            parameters as dictionary containing: "curve" as CURVE_25519
                            curve_name as Some with value as CURVE_25519
                        
                        Let key_pair be AsymmetricKeyPair with:
                            algorithm as X25519
                            key_size as 32
                            private_key as private_key
                            public_key as public_key
                            curve_name as Some with value as CURVE_25519
                            key_usage as list containing USAGE_KEY_AGREEMENT
                        
                        Return AsymmetricSuccess with value as key_pair
                    When AsymmetricFailure:
                        Return public_bytes_result
            When random.RandomFailure:
                Return AsymmetricFailure with:
                    error as AsymmetricError.Key_Generation_Failed
                    message as "Failed to generate X25519 private key"
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Key_Generation_Failed
            message as "X25519 key generation error: " plus error as String

Process called "x25519_key_exchange" that takes private_key as PrivateKey and peer_public_key as PublicKey returns AsymmetricResult[SharedSecret]:
    Note: Perform X25519 ECDH key exchange
    Try:
        Let shared_secret_result be x25519_compute_shared_secret with private_key as private_key.key_bytes and peer_public_key as peer_public_key.key_bytes
        Match shared_secret_result:
            When AsymmetricSuccess with value as secret_bytes:
                Let shared_secret be SharedSecret with:
                    secret_bytes as secret_bytes
                    algorithm as X25519
                    key_size as 32
                    derivation_info as dictionary containing: "curve" as CURVE_25519
                
                Return AsymmetricSuccess with value as shared_secret
            When AsymmetricFailure:
                Return shared_secret_result
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Key_Exchange_Failed
            message as "X25519 key exchange error: " plus error as String

Note: Validation and Utility Functions

Process called "validate_key_generation_parameters" that takes algorithm as String and key_size as Optional[Integer] returns AsymmetricResult[Dictionary[String, Any]]:
    Note: Validate parameters for key generation
    Try:
        Let supported_algorithms be list containing RSA_2048, RSA_3072, RSA_4096, ECDSA_P256, ECDSA_P384, ECDSA_P521, ECDSA_SECP256K1, ED25519, X25519, ECDH_P256, ECDH_P384, ECDH_P521
        
        If algorithm is not in supported_algorithms:
            Return AsymmetricFailure with:
                error as AsymmetricError.Unsupported_Algorithm
                message as "Unsupported algorithm: " plus algorithm
        
        Note: Validate key size requirements
        Match algorithm:
            When RSA_2048:
                If key_size is not None and key_size is not equal to 2048:
                    Return AsymmetricFailure with:
                        error as AsymmetricError.Invalid_Parameters
                        message as "RSA-2048 requires key size of 2048 bits"
            When RSA_3072:
                If key_size is not None and key_size is not equal to 3072:
                    Return AsymmetricFailure with:
                        error as AsymmetricError.Invalid_Parameters
                        message as "RSA-3072 requires key size of 3072 bits"
            When RSA_4096:
                If key_size is not None and key_size is not equal to 4096:
                    Return AsymmetricFailure with:
                        error as AsymmetricError.Invalid_Parameters
                        message as "RSA-4096 requires key size of 4096 bits"
            Otherwise:
                Note: ECC algorithms have fixed key sizes
                If key_size is not None:
                    Return AsymmetricFailure with:
                        error as AsymmetricError.Invalid_Parameters
                        message as "ECC algorithms do not accept custom key sizes"
        
        Let params be dictionary containing: "algorithm" as algorithm
        Return AsymmetricSuccess with value as params
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Internal_Error
            message as "Parameter validation error: " plus error as String

Process called "generate_large_prime" that takes bit_length as Integer returns bignum.BignumResult[bignum.Bignum]:
    Note: Generate a cryptographically secure large prime number
    Try:
        Let max_attempts be 1000
        
        For attempt from 1 to max_attempts:
            Note: Generate random odd number of specified bit length
            Let candidate_result be generate_random_odd_number with bit_length as bit_length
            Match candidate_result:
                When bignum.BignumSuccess with value as candidate:
                    Note: Test primality using Miller-Rabin
                    Let is_prime_result be bignum.is_probably_prime with value as candidate and rounds as 40
                    Match is_prime_result:
                        When bignum.BignumSuccess with value as is_prime:
                            If is_prime:
                                Return bignum.BignumSuccess with value as candidate
                        When bignum.BignumFailure:
                            Continue
                When bignum.BignumFailure:
                    Continue
        
        Return bignum.BignumFailure with message as "Failed to generate prime after " plus max_attempts as String plus " attempts"
    
    Catch error:
        Return bignum.BignumFailure with message as "Prime generation error: " plus error as String

Process called "generate_random_odd_number" that takes bit_length as Integer returns bignum.BignumResult[bignum.Bignum]:
    Note: Generate random odd number with specified bit length
    Try:
        Let byte_length be (bit_length plus 7) divided by 8
        Let random_bytes_result be random.generate_secure_bytes with count as byte_length
        Match random_bytes_result:
            When random.RandomSuccess with value as bytes:
                Note: Set high bit to ensure correct bit length
                Set bytes at index 0 to (bytes at index 0) bitwise_or 128
                
                Note: Set low bit to ensure odd number
                Let last_index be byte_length minus 1
                Set bytes at index last_index to (bytes at index last_index) bitwise_or 1
                
                Let number_result be bignum.from_bytes with bytes as bytes
                Return number_result
            When random.RandomFailure:
                Return bignum.BignumFailure with message as "Failed to generate random bytes"
    
    Catch error:
        Return bignum.BignumFailure with message as "Random number generation error: " plus error as String

Process called "generate_random_scalar" that takes max_value as bignum.Bignum returns AsymmetricResult[bignum.Bignum]:
    Note: Generate random scalar in range [1, max_value - 1]
    Try:
        Let max_attempts be 100
        
        For attempt from 1 to max_attempts:
            Let bit_length be bignum.bit_length with value as max_value
            Let candidate_result be generate_random_odd_number with bit_length as bit_length
            Match candidate_result:
                When bignum.BignumSuccess with value as candidate:
                    Note: Check if candidate is in valid range
                    Let is_positive be bignum.compare with a as candidate and b as bignum.zero
                    Let is_less_than_max be bignum.compare with a as candidate and b as max_value
                    
                    If is_positive is greater than 0 and is_less_than_max is less than 0:
                        Return AsymmetricSuccess with value as candidate
                When bignum.BignumFailure:
                    Continue
        
        Return AsymmetricFailure with:
            error as AsymmetricError.Key_Generation_Failed
            message as "Failed to generate random scalar"
    
    Catch error:
        Return AsymmetricFailure with:
            error as AsymmetricError.Key_Generation_Failed
            message as "Random scalar generation error: " plus error as String

