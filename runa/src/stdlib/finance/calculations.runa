Note: Financial Calculations Module
Note: Provides comprehensive financial mathematics including time value of money,
Note: loan calculations, investment analysis, depreciation, and advanced financial
Note: modeling with production-grade precision and error handling.

Import "decimal/decimal" as decimal_module
Import "decimal/context" as decimal_context
Import "math/core" as math_module
Import "collections/list" as list_utils
Import "collections/dict" as dict_utils
Import "datetime/datetime" as datetime_module
Import "errors/errors" as error_handling

Note: Core Financial Types

Type PaymentFrequency is:
    | ANNUAL
    | SEMI_ANNUAL
    | QUARTERLY
    | MONTHLY
    | WEEKLY
    | DAILY
    | CONTINUOUS

Type CompoundingMethod is:
    | SIMPLE
    | COMPOUND
    | CONTINUOUS

Type DepreciationMethod is:
    | STRAIGHT_LINE
    | DECLINING_BALANCE
    | DOUBLE_DECLINING_BALANCE
    | SUM_OF_YEARS_DIGITS
    | UNITS_OF_PRODUCTION

Type LoanType is:
    | FIXED_RATE
    | VARIABLE_RATE
    | INTEREST_ONLY
    | BALLOON
    | AMORTIZING

Type CashFlow is Dictionary with:
    period as Integer
    amount as decimal_module.Decimal
    date as datetime_module.DateTime
    description as String
    category as String

Type InvestmentAnalysis is Dictionary with:
    npv as decimal_module.Decimal
    irr as decimal_module.Decimal
    payback_period as decimal_module.Decimal
    discounted_payback as decimal_module.Decimal
    profitability_index as decimal_module.Decimal
    roi as decimal_module.Decimal
    cash_flows as List[CashFlow]
    discount_rate as decimal_module.Decimal

Type LoanAmortization is Dictionary with:
    payment_number as Integer
    payment_amount as decimal_module.Decimal
    principal_payment as decimal_module.Decimal
    interest_payment as decimal_module.Decimal
    remaining_balance as decimal_module.Decimal
    cumulative_principal as decimal_module.Decimal
    cumulative_interest as decimal_module.Decimal
    payment_date as datetime_module.DateTime

Type BondPricing is Dictionary with:
    present_value as decimal_module.Decimal
    yield_to_maturity as decimal_module.Decimal
    duration as decimal_module.Decimal
    modified_duration as decimal_module.Decimal
    convexity as decimal_module.Decimal
    accrued_interest as decimal_module.Decimal

Note: Time Value of Money Calculations

Process calculate_future_value with 
    present_value as decimal_module.Decimal and
    rate as decimal_module.Decimal and 
    periods as Integer and
    compounding as CompoundingMethod and
    payments_per_year as Integer:

    Let context be decimal_context.get_default_context
    
    If compounding is equal to SIMPLE:
        Let simple_interest be present_value multiplied by rate multiplied by decimal_module.from_integer with value as periods and context as context
        Return present_value plus simple_interest
    
    If compounding is equal to CONTINUOUS:
        Let exp_power be rate multiplied by decimal_module.from_integer with value as periods and context as context
        Let e_approximation be math_module.calculate_e with precision as context.precision
        Let growth_factor be math_module.power with base as e_approximation and exponent as exp_power and precision as context.precision
        Return present_value multiplied by growth_factor
    
    Note: Compound interest calculation
    Let periods_per_year be decimal_module.from_integer with value as payments_per_year and context as context
    Let effective_rate be rate divided by periods_per_year
    Let total_periods be decimal_module.from_integer with value as periods and context as context multiplied by periods_per_year
    
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let growth_base be one plus effective_rate
    Let growth_factor be math_module.power with base as growth_base and exponent as total_periods and precision as context.precision
    
    Return present_value multiplied by growth_factor

Process calculate_present_value with
    future_value as decimal_module.Decimal and
    rate as decimal_module.Decimal and
    periods as Integer and
    compounding as CompoundingMethod and
    payments_per_year as Integer:

    Let context be decimal_context.get_default_context
    
    If compounding is equal to SIMPLE:
        Let one be decimal_module.from_integer with value as 1 and context as context
        Let simple_factor be one plus rate multiplied by decimal_module.from_integer with value as periods and context as context
        Return future_value divided by simple_factor
    
    If compounding is equal to CONTINUOUS:
        Let exp_power be rate multiplied by decimal_module.from_integer with value as periods and context as context
        Let e_approximation be math_module.calculate_e with precision as context.precision
        Let discount_factor be math_module.power with base as e_approximation and exponent as exp_power and precision as context.precision
        Return future_value divided by discount_factor
    
    Note: Compound discounting
    Let periods_per_year be decimal_module.from_integer with value as payments_per_year and context as context
    Let effective_rate be rate divided by periods_per_year
    Let total_periods be decimal_module.from_integer with value as periods and context as context multiplied by periods_per_year
    
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let discount_base be one plus effective_rate
    Let discount_factor be math_module.power with base as discount_base and exponent as total_periods and precision as context.precision
    
    Return future_value divided by discount_factor

Process calculate_pmt with
    present_value as decimal_module.Decimal and
    rate as decimal_module.Decimal and
    periods as Integer and
    future_value as decimal_module.Decimal and
    payment_timing as Integer:

    Let context be decimal_context.get_default_context
    Let zero be decimal_module.from_integer with value as 0 and context as context
    
    Note: Handle zero interest rate case
    If rate is equal to zero:
        Let total_periods be decimal_module.from_integer with value as periods and context as context
        Let total_amount be present_value plus future_value
        Return total_amount divided by total_periods
    
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let periods_decimal be decimal_module.from_integer with value as periods and context as context
    Let rate_plus_one be one plus rate
    
    Let pv_factor be math_module.power with base as rate_plus_one and exponent as periods_decimal and precision as context.precision
    Let fv_factor be future_value divided by pv_factor
    
    Let annuity_factor be one minus (one divided by pv_factor)
    Let denominator be annuity_factor divided by rate
    
    If payment_timing is equal to 1:
        Set denominator to denominator multiplied by rate_plus_one
    
    Let numerator be present_value plus fv_factor
    Return numerator divided by denominator

Process calculate_npv with 
    cash_flows as List[CashFlow] and
    discount_rate as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    Let npv be decimal_module.from_integer with value as 0 and context as context
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let discount_base be one plus discount_rate
    
    For Each flow in cash_flows:
        Let period_decimal be decimal_module.from_integer with value as flow.period and context as context
        Let discount_factor be math_module.power with base as discount_base and exponent as period_decimal and precision as context.precision
        Let present_value be flow.amount divided by discount_factor
        Set npv to npv plus present_value
    
    Return npv

Process calculate_irr with
    cash_flows as List[CashFlow] and
    initial_guess as decimal_module.Decimal and
    max_iterations as Integer and
    tolerance as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    Let current_rate be initial_guess
    Let iteration be 0
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let two be decimal_module.from_integer with value as 2 and context as context
    Let small_increment be decimal_module.from_string with value as "0.0001" and context as context
    
    While iteration is less than max_iterations:
        Note: Calculate NPV at current rate
        Let npv be calculate_npv with cash_flows as cash_flows and discount_rate as current_rate
        
        Note: Check if we're close enough to zero
        Let abs_npv be math_module.absolute with value as npv
        If abs_npv is less than tolerance:
            Return current_rate
        
        Note: Calculate derivative (NPV at rate + small increment)
        Let rate_plus_increment be current_rate plus small_increment
        Let npv_plus be calculate_npv with cash_flows as cash_flows and discount_rate as rate_plus_increment
        Let derivative be npv_plus minus npv divided by small_increment
        
        Note: Newton-Raphson iteration
        If derivative is not equal to decimal_module.from_integer with value as 0 and context as context:
            Set current_rate to current_rate minus npv divided by derivative
        Otherwise:
            Set current_rate to current_rate plus small_increment
        
        Set iteration to iteration plus 1
    
    Note: If no convergence, return the last calculated rate
    Return current_rate

Process calculate_payback_period with cash_flows as List[CashFlow]:
    Let context be decimal_context.get_default_context
    Let cumulative_cash_flow be decimal_module.from_integer with value as 0 and context as context
    Let zero be decimal_module.from_integer with value as 0 and context as context
    
    For Each flow in cash_flows:
        Set cumulative_cash_flow to cumulative_cash_flow plus flow.amount
        
        If cumulative_cash_flow is greater than or equal to zero:
            Note: Calculate fractional payback period
            Let previous_cumulative be cumulative_cash_flow minus flow.amount
            Let fraction be previous_cumulative divided by flow.amount
            Let payback_period be decimal_module.from_integer with value as flow.period and context as context minus fraction
            Return payback_period
    
    Note: Investment never pays back within the cash flow period
    Let max_period be decimal_module.from_integer with value as 999 and context as context
    Return max_period

Process calculate_discounted_payback with
    cash_flows as List[CashFlow] and
    discount_rate as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    Let cumulative_pv be decimal_module.from_integer with value as 0 and context as context
    Let zero be decimal_module.from_integer with value as 0 and context as context
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let discount_base be one plus discount_rate
    
    For Each flow in cash_flows:
        Let period_decimal be decimal_module.from_integer with value as flow.period and context as context
        Let discount_factor be math_module.power with base as discount_base and exponent as period_decimal and precision as context.precision
        Let present_value be flow.amount divided by discount_factor
        Set cumulative_pv to cumulative_pv plus present_value
        
        If cumulative_pv is greater than or equal to zero:
            Let previous_cumulative be cumulative_pv minus present_value
            Let fraction be previous_cumulative divided by present_value
            Let payback_period be decimal_module.from_integer with value as flow.period and context as context minus fraction
            Return payback_period
    
    Note: Investment never pays back on discounted basis
    Let max_period be decimal_module.from_integer with value as 999 and context as context
    Return max_period

Note: Loan and Amortization Calculations

Process calculate_loan_payment with
    principal as decimal_module.Decimal and
    annual_rate as decimal_module.Decimal and
    years as Integer and
    payments_per_year as Integer:

    Let context be decimal_context.get_default_context
    Let total_payments be years multiplied by payments_per_year
    Let periods_per_year be decimal_module.from_integer with value as payments_per_year and context as context
    Let periodic_rate be annual_rate divided by periods_per_year
    Let zero_fv be decimal_module.from_integer with value as 0 and context as context
    
    Return calculate_pmt with 
        present_value as principal and
        rate as periodic_rate and
        periods as total_payments and
        future_value as zero_fv and
        payment_timing as 0

Process generate_amortization_schedule with
    principal as decimal_module.Decimal and
    annual_rate as decimal_module.Decimal and
    years as Integer and
    payments_per_year as Integer and
    start_date as datetime_module.DateTime:

    Let context be decimal_context.get_default_context
    Let schedule be list_utils.create_empty_list
    Let remaining_balance be principal
    Let cumulative_principal be decimal_module.from_integer with value as 0 and context as context
    Let cumulative_interest be decimal_module.from_integer with value as 0 and context as context
    
    Let payment_amount be calculate_loan_payment with
        principal as principal and
        annual_rate as annual_rate and
        years as years and
        payments_per_year as payments_per_year
    
    Let periods_per_year be decimal_module.from_integer with value as payments_per_year and context as context
    Let periodic_rate be annual_rate divided by periods_per_year
    Let total_payments be years multiplied by payments_per_year
    
    Let payment_number be 1
    Let current_date be start_date
    Let days_between_payments be 365 divided by payments_per_year
    
    While payment_number is less than or equal to total_payments:
        Let interest_payment be remaining_balance multiplied by periodic_rate
        Let principal_payment be payment_amount minus interest_payment
        
        Note: Ensure last payment doesn't result in negative balance
        If principal_payment is greater than remaining_balance:
            Set principal_payment to remaining_balance
            Set payment_amount to principal_payment plus interest_payment
        
        Set remaining_balance to remaining_balance minus principal_payment
        Set cumulative_principal to cumulative_principal plus principal_payment
        Set cumulative_interest to cumulative_interest plus interest_payment
        
        Let payment_entry be Dictionary with:
            payment_number as payment_number and
            payment_amount as payment_amount and
            principal_payment as principal_payment and
            interest_payment as interest_payment and
            remaining_balance as remaining_balance and
            cumulative_principal as cumulative_principal and
            cumulative_interest as cumulative_interest and
            payment_date as current_date
        
        Call list_utils.append with list as schedule and item as payment_entry
        
        Set payment_number to payment_number plus 1
        Set current_date to datetime_module.add_days with date as current_date and days as days_between_payments
    
    Return schedule

Note: Bond and Fixed Income Calculations

Process calculate_bond_price with
    face_value as decimal_module.Decimal and
    coupon_rate as decimal_module.Decimal and
    yield_rate as decimal_module.Decimal and
    years_to_maturity as decimal_module.Decimal and
    payments_per_year as Integer:

    Let context be decimal_context.get_default_context
    Let periods_per_year be decimal_module.from_integer with value as payments_per_year and context as context
    Let total_periods be years_to_maturity multiplied by periods_per_year
    Let periodic_coupon_rate be coupon_rate divided by periods_per_year
    Let periodic_yield_rate be yield_rate divided by periods_per_year
    Let coupon_payment be face_value multiplied by periodic_coupon_rate
    
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let yield_plus_one be one plus periodic_yield_rate
    
    Note: Present value of coupon payments (annuity)
    Let discount_factor be math_module.power with base as yield_plus_one and exponent as total_periods and precision as context.precision
    Let annuity_factor be one minus one divided by discount_factor
    Let coupon_pv be coupon_payment multiplied by annuity_factor divided by periodic_yield_rate
    
    Note: Present value of face value
    Let face_value_pv be face_value divided by discount_factor
    
    Let bond_price be coupon_pv plus face_value_pv
    Return bond_price

Process calculate_bond_yield with
    bond_price as decimal_module.Decimal and
    face_value as decimal_module.Decimal and
    coupon_rate as decimal_module.Decimal and
    years_to_maturity as decimal_module.Decimal and
    payments_per_year as Integer and
    initial_guess as decimal_module.Decimal and
    max_iterations as Integer and
    tolerance as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    Let current_yield be initial_guess
    Let iteration be 0
    Let small_increment be decimal_module.from_string with value as "0.0001" and context as context
    
    While iteration is less than max_iterations:
        Let calculated_price be calculate_bond_price with
            face_value as face_value and
            coupon_rate as coupon_rate and
            yield_rate as current_yield and
            years_to_maturity as years_to_maturity and
            payments_per_year as payments_per_year
        
        Let price_difference be calculated_price minus bond_price
        Let abs_difference be math_module.absolute with value as price_difference
        
        If abs_difference is less than tolerance:
            Return current_yield
        
        Note: Calculate derivative for Newton-Raphson
        Let yield_plus_increment be current_yield plus small_increment
        Let price_plus be calculate_bond_price with
            face_value as face_value and
            coupon_rate as coupon_rate and
            yield_rate as yield_plus_increment and
            years_to_maturity as years_to_maturity and
            payments_per_year as payments_per_year
        
        Let derivative be price_plus minus calculated_price divided by small_increment
        
        If derivative is not equal to decimal_module.from_integer with value as 0 and context as context:
            Set current_yield to current_yield minus price_difference divided by derivative
        Otherwise:
            Set current_yield to current_yield plus small_increment
        
        Set iteration to iteration plus 1
    
    Return current_yield

Process calculate_duration with
    face_value as decimal_module.Decimal and
    coupon_rate as decimal_module.Decimal and
    yield_rate as decimal_module.Decimal and
    years_to_maturity as decimal_module.Decimal and
    payments_per_year as Integer:

    Let context be decimal_context.get_default_context
    Let periods_per_year be decimal_module.from_integer with value as payments_per_year and context as context
    Let total_periods be years_to_maturity multiplied by periods_per_year
    Let periodic_coupon_rate be coupon_rate divided by periods_per_year
    Let periodic_yield_rate be yield_rate divided by periods_per_year
    Let coupon_payment be face_value multiplied by periodic_coupon_rate
    
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let yield_plus_one be one plus periodic_yield_rate
    Let weighted_cash_flows be decimal_module.from_integer with value as 0 and context as context
    Let bond_price be decimal_module.from_integer with value as 0 and context as context
    
    Note: Calculate weighted present value of each cash flow
    Let period be 1
    While period is less than or equal to total_periods:
        Let period_decimal be decimal_module.from_integer with value as period and context as context
        Let discount_factor be math_module.power with base as yield_plus_one and exponent as period_decimal and precision as context.precision
        Let cash_flow be coupon_payment
        
        Note: Add face value to final payment
        If period is equal to total_periods:
            Set cash_flow to cash_flow plus face_value
        
        Let present_value be cash_flow divided by discount_factor
        Let time_weighted_pv be present_value multiplied by period_decimal divided by periods_per_year
        
        Set weighted_cash_flows to weighted_cash_flows plus time_weighted_pv
        Set bond_price to bond_price plus present_value
        Set period to period plus 1
    
    Let duration be weighted_cash_flows divided by bond_price
    Return duration

Note: Depreciation Calculations

Process calculate_straight_line_depreciation with
    cost as decimal_module.Decimal and
    salvage_value as decimal_module.Decimal and
    useful_life_years as Integer:

    Let context be decimal_context.get_default_context
    Let depreciable_base be cost minus salvage_value
    Let useful_life be decimal_module.from_integer with value as useful_life_years and context as context
    Let annual_depreciation be depreciable_base divided by useful_life
    
    Return annual_depreciation

Process calculate_declining_balance_depreciation with
    cost as decimal_module.Decimal and
    salvage_value as decimal_module.Decimal and
    useful_life_years as Integer and
    depreciation_rate as decimal_module.Decimal and
    year as Integer:

    Let context be decimal_context.get_default_context
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let year_decimal be decimal_module.from_integer with value as year and context as context
    Let rate_complement be one minus depreciation_rate
    
    Let accumulated_rate_factor be math_module.power with 
        base as rate_complement and 
        exponent as year_decimal minus one and 
        precision as context.precision
    
    Let book_value_start_of_year be cost multiplied by accumulated_rate_factor
    Let depreciation_this_year be book_value_start_of_year multiplied by depreciation_rate
    
    Note: Ensure book value doesn't go below salvage value
    Let book_value_end_of_year be book_value_start_of_year minus depreciation_this_year
    If book_value_end_of_year is less than salvage_value:
        Set depreciation_this_year to book_value_start_of_year minus salvage_value
    
    Return depreciation_this_year

Process calculate_sum_of_years_digits_depreciation with
    cost as decimal_module.Decimal and
    salvage_value as decimal_module.Decimal and
    useful_life_years as Integer and
    year as Integer:

    Let context be decimal_context.get_default_context
    Let depreciable_base be cost minus salvage_value
    Let useful_life be decimal_module.from_integer with value as useful_life_years and context as context
    Let year_decimal be decimal_module.from_integer with value as year and context as context
    
    Note: Calculate sum of years digits
    Let sum_of_years be useful_life multiplied by useful_life plus one divided by decimal_module.from_integer with value as 2 and context as context
    
    Note: Calculate depreciation fraction
    Let remaining_life be useful_life minus year_decimal plus decimal_module.from_integer with value as 1 and context as context
    Let depreciation_fraction be remaining_life divided by sum_of_years
    
    Let annual_depreciation be depreciable_base multiplied by depreciation_fraction
    Return annual_depreciation

Note: Advanced Financial Analysis

Process perform_investment_analysis with
    initial_investment as decimal_module.Decimal and
    cash_flows as List[CashFlow] and
    discount_rate as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    
    Note: Ensure initial investment is included as negative cash flow
    Let all_cash_flows be list_utils.create_empty_list
    Let initial_flow be Dictionary with:
        period as 0 and
        amount as decimal_module.multiply with 
            x as initial_investment and 
            y as decimal_module.from_integer with value as -1 and context as context and
            context as context and
        date as datetime_module.now and
        description as "Initial Investment" and
        category as "Investment"
    Call list_utils.append with list as all_cash_flows and item as initial_flow
    
    For Each flow in cash_flows:
        Call list_utils.append with list as all_cash_flows and item as flow
    
    Let npv be calculate_npv with cash_flows as all_cash_flows and discount_rate as discount_rate
    Let irr be calculate_irr with 
        cash_flows as all_cash_flows and
        initial_guess as decimal_module.from_string with value as "0.1" and context as context and
        max_iterations as 1000 and
        tolerance as decimal_module.from_string with value as "0.000001" and context as context
    
    Let payback_period be calculate_payback_period with cash_flows as all_cash_flows
    Let discounted_payback be calculate_discounted_payback with cash_flows as all_cash_flows and discount_rate as discount_rate
    
    Note: Calculate Profitability Index
    Let positive_cash_flows_pv be decimal_module.from_integer with value as 0 and context as context
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let discount_base be one plus discount_rate
    
    For Each flow in cash_flows:
        If flow.amount is greater than decimal_module.from_integer with value as 0 and context as context:
            Let period_decimal be decimal_module.from_integer with value as flow.period and context as context
            Let discount_factor be math_module.power with base as discount_base and exponent as period_decimal and precision as context.precision
            Let present_value be flow.amount divided by discount_factor
            Set positive_cash_flows_pv to positive_cash_flows_pv plus present_value
    
    Let profitability_index be positive_cash_flows_pv divided by initial_investment
    
    Note: Calculate ROI
    Let total_cash_inflows be decimal_module.from_integer with value as 0 and context as context
    For Each flow in cash_flows:
        Set total_cash_inflows to total_cash_inflows plus flow.amount
    
    Let net_gain be total_cash_inflows minus initial_investment
    Let roi be net_gain divided by initial_investment multiplied by decimal_module.from_integer with value as 100 and context as context
    
    Let analysis be Dictionary with:
        npv as npv and
        irr as irr and
        payback_period as payback_period and
        discounted_payback as discounted_payback and
        profitability_index as profitability_index and
        roi as roi and
        cash_flows as all_cash_flows and
        discount_rate as discount_rate
    
    Return analysis

Process calculate_effective_annual_rate with
    nominal_rate as decimal_module.Decimal and
    compounding_periods as Integer:

    Let context be decimal_context.get_default_context
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let periods_decimal be decimal_module.from_integer with value as compounding_periods and context as context
    Let periodic_rate be nominal_rate divided by periods_decimal
    
    Let effective_base be one plus periodic_rate
    Let effective_rate_factor be math_module.power with base as effective_base and exponent as periods_decimal and precision as context.precision
    Let effective_annual_rate be effective_rate_factor minus one
    
    Return effective_annual_rate

Process calculate_continuous_compounding_rate with nominal_rate as decimal_module.Decimal:
    Let context be decimal_context.get_default_context
    Let e_approximation be math_module.calculate_e with precision as context.precision
    Let continuous_factor be math_module.power with base as e_approximation and exponent as nominal_rate and precision as context.precision
    Let one be decimal_module.from_integer with value as 1 and context as context
    Let continuous_rate be continuous_factor minus one
    
    Return continuous_rate

Note: Financial ratios and metrics commonly used in analysis

Process calculate_debt_to_equity_ratio with
    total_debt as decimal_module.Decimal and
    total_equity as decimal_module.Decimal:

    Let zero be decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context
    If total_equity is equal to zero:
        Note: Return a large number to indicate infinite ratio
        Return decimal_module.from_integer with value as 999999 and context as decimal_context.get_default_context
    
    Return total_debt divided by total_equity

Process calculate_return_on_assets with
    net_income as decimal_module.Decimal and
    total_assets as decimal_module.Decimal:

    Let zero be decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context
    If total_assets is equal to zero:
        Return zero
    
    Return net_income divided by total_assets

Process calculate_return_on_equity with
    net_income as decimal_module.Decimal and
    shareholders_equity as decimal_module.Decimal:

    Let zero be decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context
    If shareholders_equity is equal to zero:
        Return zero
    
    Return net_income divided by shareholders_equity