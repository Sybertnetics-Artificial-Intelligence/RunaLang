Note: Financial Markets and Securities Module
Note: Provides comprehensive market data management, securities analysis,
Note: portfolio tracking, market indicators, and trading support with
Note: real-time data processing and advanced financial modeling.

Import "decimal/decimal" as decimal_module
Import "decimal/context" as decimal_context
Import "datetime/datetime" as datetime_module
Import "collections/list" as list_utils
Import "collections/dict" as dict_utils
Import "math/core" as math_module
Import "statistics/statistics" as stats_module
Import "finance/calculations" as finance_calc

Note: Core Market Types

Type SecurityType is:
    | STOCK
    | BOND
    | ETF
    | MUTUAL_FUND
    | OPTION
    | FUTURE
    | COMMODITY
    | CURRENCY
    | CRYPTOCURRENCY
    | INDEX

Type MarketSector is:
    | TECHNOLOGY
    | HEALTHCARE
    | FINANCIALS
    | CONSUMER_DISCRETIONARY
    | CONSUMER_STAPLES
    | INDUSTRIALS
    | ENERGY
    | MATERIALS
    | UTILITIES
    | REAL_ESTATE
    | TELECOMMUNICATIONS

Type OrderType is:
    | MARKET
    | LIMIT
    | STOP
    | STOP_LIMIT
    | TRAILING_STOP
    | FILL_OR_KILL
    | IMMEDIATE_OR_CANCEL
    | GOOD_TILL_CANCELED

Type Security is Dictionary with:
    symbol as String
    name as String
    security_type as SecurityType
    sector as MarketSector
    exchange as String
    currency as String
    isin as String
    cusip as String
    market_cap as decimal_module.Decimal
    shares_outstanding as decimal_module.Decimal
    is_active as Boolean

Type MarketData is Dictionary with:
    symbol as String
    timestamp as datetime_module.DateTime
    open_price as decimal_module.Decimal
    high_price as decimal_module.Decimal
    low_price as decimal_module.Decimal
    close_price as decimal_module.Decimal
    volume as Integer
    adjusted_close as decimal_module.Decimal
    dividend_amount as decimal_module.Decimal
    split_ratio as decimal_module.Decimal

Type Quote is Dictionary with:
    symbol as String
    bid_price as decimal_module.Decimal
    ask_price as decimal_module.Decimal
    bid_size as Integer
    ask_size as Integer
    last_price as decimal_module.Decimal
    last_size as Integer
    spread as decimal_module.Decimal
    timestamp as datetime_module.DateTime
    market_status as String

Type Portfolio is Dictionary with:
    id as String
    name as String
    owner as String
    holdings as Dictionary[String, Holding]
    total_value as decimal_module.Decimal
    total_cost_basis as decimal_module.Decimal
    unrealized_gain_loss as decimal_module.Decimal
    realized_gain_loss as decimal_module.Decimal
    cash_balance as decimal_module.Decimal
    currency as String
    created_date as datetime_module.DateTime
    last_updated as datetime_module.DateTime

Type Holding is Dictionary with:
    symbol as String
    quantity as decimal_module.Decimal
    average_cost as decimal_module.Decimal
    current_price as decimal_module.Decimal
    market_value as decimal_module.Decimal
    cost_basis as decimal_module.Decimal
    unrealized_gain_loss as decimal_module.Decimal
    unrealized_gain_loss_percent as decimal_module.Decimal
    dividend_yield as decimal_module.Decimal
    purchase_dates as List[datetime_module.DateTime]

Type MarketIndex is Dictionary with:
    symbol as String
    name as String
    value as decimal_module.Decimal
    change as decimal_module.Decimal
    change_percent as decimal_module.Decimal
    constituents as List[String]
    weights as Dictionary[String, decimal_module.Decimal]
    methodology as String
    base_value as decimal_module.Decimal
    base_date as datetime_module.DateTime

Note: Market Data Management

Process create_security with
    symbol as String and
    name as String and
    security_type as SecurityType and
    sector as MarketSector and
    exchange as String:

    Let context be decimal_context.get_default_context
    
    Return Dictionary with:
        symbol as symbol and
        name as name and
        security_type as security_type and
        sector as sector and
        exchange as exchange and
        currency as "USD" and
        isin as "" and
        cusip as "" and
        market_cap as decimal_module.from_integer with value as 0 and context as context and
        shares_outstanding as decimal_module.from_integer with value as 0 and context as context and
        is_active as true

Process create_market_data with
    symbol as String and
    open_price as decimal_module.Decimal and
    high_price as decimal_module.Decimal and
    low_price as decimal_module.Decimal and
    close_price as decimal_module.Decimal and
    volume as Integer:

    Let context be decimal_context.get_default_context
    Let current_time be datetime_module.now
    
    Return Dictionary with:
        symbol as symbol and
        timestamp as current_time and
        open_price as open_price and
        high_price as high_price and
        low_price as low_price and
        close_price as close_price and
        volume as volume and
        adjusted_close as close_price and
        dividend_amount as decimal_module.from_integer with value as 0 and context as context and
        split_ratio as decimal_module.from_integer with value as 1 and context as context

Process create_quote with
    symbol as String and
    bid_price as decimal_module.Decimal and
    ask_price as decimal_module.Decimal and
    last_price as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    Let spread be ask_price minus bid_price
    Let current_time be datetime_module.now
    
    Return Dictionary with:
        symbol as symbol and
        bid_price as bid_price and
        ask_price as ask_price and
        bid_size as 100 and
        ask_size as 100 and
        last_price as last_price and
        last_size as 100 and
        spread as spread and
        timestamp as current_time and
        market_status as "OPEN"

Note: Technical Analysis Indicators

Process calculate_simple_moving_average with
    prices as List[decimal_module.Decimal] and
    period as Integer:

    Let context be decimal_context.get_default_context
    Let price_count be list_utils.get_length with list as prices
    
    If price_count is less than period:
        Return decimal_module.from_integer with value as 0 and context as context
    
    Let sum be decimal_module.from_integer with value as 0 and context as context
    Let start_index be price_count minus period
    Let i be start_index
    
    While i is less than price_count:
        Let price be list_utils.get_item with list as prices and index as i
        Set sum to sum plus price
        Set i to i plus 1
    
    Let period_decimal be decimal_module.from_integer with value as period and context as context
    Let sma be sum divided by period_decimal
    
    Return sma

Process calculate_exponential_moving_average with
    prices as List[decimal_module.Decimal] and
    period as Integer:

    Let context be decimal_context.get_default_context
    Let price_count be list_utils.get_length with list as prices
    
    If price_count is equal to 0:
        Return decimal_module.from_integer with value as 0 and context as context
    
    Note: Calculate smoothing factor: 2 / (period + 1)
    Let two be decimal_module.from_integer with value as 2 and context as context
    Let period_decimal be decimal_module.from_integer with value as period and context as context
    Let smoothing_factor be two divided by period_decimal plus decimal_module.from_integer with value as 1 and context as context
    
    Note: Start with first price as initial EMA
    Let current_ema be list_utils.get_item with list as prices and index as 0
    Let i be 1
    
    While i is less than price_count:
        Let current_price be list_utils.get_item with list as prices and index as i
        Let one_minus_smoothing be decimal_module.from_integer with value as 1 and context as context minus smoothing_factor
        Set current_ema to current_price multiplied by smoothing_factor plus current_ema multiplied by one_minus_smoothing
        Set i to i plus 1
    
    Return current_ema

Process calculate_bollinger_bands with
    prices as List[decimal_module.Decimal] and
    period as Integer and
    standard_deviations as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    Let sma be calculate_simple_moving_average with prices as prices and period as period
    
    If sma is equal to decimal_module.from_integer with value as 0 and context as context:
        Return Dictionary with:
            upper_band as decimal_module.from_integer with value as 0 and context as context and
            middle_band as decimal_module.from_integer with value as 0 and context as context and
            lower_band as decimal_module.from_integer with value as 0 and context as context
    
    Note: Calculate standard deviation for the period
    Let price_count be list_utils.get_length with list as prices
    Let start_index be price_count minus period
    Let period_prices be list_utils.create_empty_list
    Let i be start_index
    
    While i is less than price_count:
        Let price be list_utils.get_item with list as prices and index as i
        Call list_utils.append with list as period_prices and item as price
        Set i to i plus 1
    
    Let standard_deviation be stats_module.calculate_standard_deviation with values as period_prices
    Let band_width be standard_deviation multiplied by standard_deviations
    
    Let upper_band be sma plus band_width
    Let lower_band be sma minus band_width
    
    Return Dictionary with:
        upper_band as upper_band and
        middle_band as sma and
        lower_band as lower_band

Process calculate_rsi with
    prices as List[decimal_module.Decimal] and
    period as Integer:

    Let context be decimal_context.get_default_context
    Let price_count be list_utils.get_length with list as prices
    
    If price_count is less than period plus 1:
        Return decimal_module.from_integer with value as 50 and context as context
    
    Let gains be list_utils.create_empty_list
    Let losses be list_utils.create_empty_list
    Let i be 1
    
    Note: Calculate price changes
    While i is less than price_count:
        Let current_price be list_utils.get_item with list as prices and index as i
        Let previous_price be list_utils.get_item with list as prices and index as i minus 1
        Let change be current_price minus previous_price
        
        Let zero be decimal_module.from_integer with value as 0 and context as context
        If change is greater than zero:
            Call list_utils.append with list as gains and item as change
            Call list_utils.append with list as losses and item as zero
        Otherwise:
            Call list_utils.append with list as gains and item as zero
            Let loss be decimal_module.multiply with x as change and y as decimal_module.from_integer with value as -1 and context as context and context as context
            Call list_utils.append with list as losses and item as loss
        
        Set i to i plus 1
    
    Note: Calculate average gains and losses
    Let avg_gain be calculate_simple_moving_average with prices as gains and period as period
    Let avg_loss be calculate_simple_moving_average with prices as losses and period as period
    
    If avg_loss is equal to decimal_module.from_integer with value as 0 and context as context:
        Return decimal_module.from_integer with value as 100 and context as context
    
    Let relative_strength be avg_gain divided by avg_loss
    let one be decimal_module.from_integer with value as 1 and context as context
    let hundred be decimal_module.from_integer with value as 100 and context as context
    Let rsi be hundred minus hundred divided by one plus relative_strength
    
    Return rsi

Process calculate_macd with
    prices as List[decimal_module.Decimal] and
    fast_period as Integer and
    slow_period as Integer and
    signal_period as Integer:

    Let context be decimal_context.get_default_context
    
    Note: Calculate fast and slow EMAs
    Let fast_ema be calculate_exponential_moving_average with prices as prices and period as fast_period
    Let slow_ema be calculate_exponential_moving_average with prices as prices and period as slow_period
    
    Note: MACD line is the difference between fast and slow EMA
    Let macd_line be fast_ema minus slow_ema
    
    Note: Create MACD line history for signal line calculation
    Let macd_history be list_utils.create_empty_list
    Call list_utils.append with list as macd_history and item as macd_line
    
    Note: Calculate signal line (EMA of MACD line)
    Let signal_line be calculate_exponential_moving_average with prices as macd_history and period as signal_period
    
    Note: Calculate histogram (MACD - Signal)
    Let histogram be macd_line minus signal_line
    
    Return Dictionary with:
        macd_line as macd_line and
        signal_line as signal_line and
        histogram as histogram

Note: Portfolio Management

Process create_portfolio with
    id as String and
    name as String and
    owner as String and
    currency as String:

    Let context be decimal_context.get_default_context
    Let current_time be datetime_module.now
    
    Return Dictionary with:
        id as id and
        name as name and
        owner as owner and
        holdings as Dictionary and
        total_value as decimal_module.from_integer with value as 0 and context as context and
        total_cost_basis as decimal_module.from_integer with value as 0 and context as context and
        unrealized_gain_loss as decimal_module.from_integer with value as 0 and context as context and
        realized_gain_loss as decimal_module.from_integer with value as 0 and context as context and
        cash_balance as decimal_module.from_integer with value as 0 and context as context and
        currency as currency and
        created_date as current_time and
        last_updated as current_time

Process add_holding_to_portfolio with
    portfolio as Portfolio and
    symbol as String and
    quantity as decimal_module.Decimal and
    purchase_price as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    Let holdings be portfolio.holdings
    Let current_time be datetime_module.now
    
    If dict_utils.contains_key with dictionary as holdings and key as symbol:
        Note: Update existing holding with weighted average cost
        Let existing_holding be dict_utils.get_value with dictionary as holdings and key as symbol
        Let existing_quantity be existing_holding.quantity
        Let existing_avg_cost be existing_holding.average_cost
        
        Let total_quantity be existing_quantity plus quantity
        Let total_cost be existing_quantity multiplied by existing_avg_cost plus quantity multiplied by purchase_price
        Let new_average_cost be total_cost divided by total_quantity
        
        Let updated_purchase_dates be existing_holding.purchase_dates
        Call list_utils.append with list as updated_purchase_dates and item as current_time
        
        Let updated_holding be Dictionary with:
            symbol as symbol and
            quantity as total_quantity and
            average_cost as new_average_cost and
            current_price as existing_holding.current_price and
            market_value as total_quantity multiplied by existing_holding.current_price and
            cost_basis as total_quantity multiplied by new_average_cost and
            unrealized_gain_loss as decimal_module.from_integer with value as 0 and context as context and
            unrealized_gain_loss_percent as decimal_module.from_integer with value as 0 and context as context and
            dividend_yield as existing_holding.dividend_yield and
            purchase_dates as updated_purchase_dates
        
        Call dict_utils.set_value with dictionary as holdings and key as symbol and value as updated_holding
    Otherwise:
        Note: Create new holding
        Let purchase_dates be list_utils.create_empty_list
        Call list_utils.append with list as purchase_dates and item as current_time
        
        Let new_holding be Dictionary with:
            symbol as symbol and
            quantity as quantity and
            average_cost as purchase_price and
            current_price as purchase_price and
            market_value as quantity multiplied by purchase_price and
            cost_basis as quantity multiplied by purchase_price and
            unrealized_gain_loss as decimal_module.from_integer with value as 0 and context as context and
            unrealized_gain_loss_percent as decimal_module.from_integer with value as 0 and context as context and
            dividend_yield as decimal_module.from_integer with value as 0 and context as context and
            purchase_dates as purchase_dates
        
        Call dict_utils.set_value with dictionary as holdings and key as symbol and value as new_holding
    
    Set portfolio.last_updated to current_time
    Return portfolio

Process update_portfolio_prices with
    portfolio as Portfolio and
    market_prices as Dictionary[String, decimal_module.Decimal]:

    Let context be decimal_context.get_default_context
    Let holdings be portfolio.holdings
    Let symbol_keys be dict_utils.get_keys with dictionary as holdings
    
    Let total_market_value be decimal_module.from_integer with value as 0 and context as context
    Let total_cost_basis be decimal_module.from_integer with value as 0 and context as context
    
    For Each symbol in symbol_keys:
        Let holding be dict_utils.get_value with dictionary as holdings and key as symbol
        
        If dict_utils.contains_key with dictionary as market_prices and key as symbol:
            Let current_price be dict_utils.get_value with dictionary as market_prices and key as symbol
            Let market_value be holding.quantity multiplied by current_price
            Let cost_basis be holding.quantity multiplied by holding.average_cost
            Let unrealized_gain_loss be market_value minus cost_basis
            
            Note: Calculate unrealized gain/loss percentage
            Let gain_loss_percent be decimal_module.from_integer with value as 0 and context as context
            If cost_basis is not equal to decimal_module.from_integer with value as 0 and context as context:
                Set gain_loss_percent to unrealized_gain_loss divided by cost_basis multiplied by decimal_module.from_integer with value as 100 and context as context
            
            Note: Update holding with new prices
            Set holding.current_price to current_price
            Set holding.market_value to market_value
            Set holding.unrealized_gain_loss to unrealized_gain_loss
            Set holding.unrealized_gain_loss_percent to gain_loss_percent
            
            Set total_market_value to total_market_value plus market_value
            Set total_cost_basis to total_cost_basis plus cost_basis
        Otherwise:
            Set total_market_value to total_market_value plus holding.market_value
            Set total_cost_basis to total_cost_basis plus holding.cost_basis
    
    Note: Update portfolio totals
    Set portfolio.total_value to total_market_value plus portfolio.cash_balance
    Set portfolio.total_cost_basis to total_cost_basis
    Set portfolio.unrealized_gain_loss to total_market_value minus total_cost_basis
    Set portfolio.last_updated to datetime_module.now
    
    Return portfolio

Process calculate_portfolio_metrics with portfolio as Portfolio:
    Let context be decimal_context.get_default_context
    
    Note: Calculate total return
    Let total_return_percent be decimal_module.from_integer with value as 0 and context as context
    If portfolio.total_cost_basis is not equal to decimal_module.from_integer with value as 0 and context as context:
        Let total_gain_loss be portfolio.unrealized_gain_loss plus portfolio.realized_gain_loss
        Set total_return_percent to total_gain_loss divided by portfolio.total_cost_basis multiplied by decimal_module.from_integer with value as 100 and context as context
    
    Note: Calculate sector allocation
    Let sector_allocation be Dictionary
    let holdings be portfolio.holdings
    Let symbol_keys be dict_utils.get_keys with dictionary as holdings
    
    For Each symbol in symbol_keys:
        Let holding be dict_utils.get_value with dictionary as holdings and key as symbol
        Note: This would need integration with security master data for sector information
        Note: For now, we'll calculate based on holdings value
        Let allocation_percent be decimal_module.from_integer with value as 0 and context as context
        If portfolio.total_value is not equal to decimal_module.from_integer with value as 0 and context as context:
            Set allocation_percent to holding.market_value divided by portfolio.total_value multiplied by decimal_module.from_integer with value as 100 and context as context
        
        Call dict_utils.set_value with dictionary as sector_allocation and key as symbol and value as allocation_percent
    
    Return Dictionary with:
        total_return_percent as total_return_percent and
        unrealized_gain_loss as portfolio.unrealized_gain_loss and
        realized_gain_loss as portfolio.realized_gain_loss and
        total_value as portfolio.total_value and
        cost_basis as portfolio.total_cost_basis and
        cash_percentage as portfolio.cash_balance divided by portfolio.total_value multiplied by decimal_module.from_integer with value as 100 and context as context and
        sector_allocation as sector_allocation

Note: Market Index Calculations

Process create_market_index with
    symbol as String and
    name as String and
    constituents as List[String] and
    base_value as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    Let current_time be datetime_module.now
    
    Return Dictionary with:
        symbol as symbol and
        name as name and
        value as base_value and
        change as decimal_module.from_integer with value as 0 and context as context and
        change_percent as decimal_module.from_integer with value as 0 and context as context and
        constituents as constituents and
        weights as Dictionary and
        methodology as "MARKET_CAP_WEIGHTED" and
        base_value as base_value and
        base_date as current_time

Process calculate_market_cap_weighted_index with
    index as MarketIndex and
    constituent_prices as Dictionary[String, decimal_module.Decimal] and
    constituent_shares as Dictionary[String, decimal_module.Decimal]:

    Let context be decimal_context.get_default_context
    Let constituents be index.constituents
    
    Let total_market_cap be decimal_module.from_integer with value as 0 and context as context
    Let constituent_market_caps be Dictionary
    
    Note: Calculate market cap for each constituent
    For Each symbol in constituents:
        If dict_utils.contains_key with dictionary as constituent_prices and key as symbol:
            If dict_utils.contains_key with dictionary as constituent_shares and key as symbol:
                Let price be dict_utils.get_value with dictionary as constituent_prices and key as symbol
                Let shares be dict_utils.get_value with dictionary as constituent_shares and key as symbol
                Let market_cap be price multiplied by shares
                
                Call dict_utils.set_value with dictionary as constituent_market_caps and key as symbol and value as market_cap
                Set total_market_cap to total_market_cap plus market_cap
    
    Note: Calculate weights and index value
    Let weighted_value be decimal_module.from_integer with value as 0 and context as context
    Let weights be Dictionary
    
    For Each symbol in constituents:
        If dict_utils.contains_key with dictionary as constituent_market_caps and key as symbol:
            Let market_cap be dict_utils.get_value with dictionary as constituent_market_caps and key as symbol
            Let weight be decimal_module.from_integer with value as 0 and context as context
            
            If total_market_cap is not equal to decimal_module.from_integer with value as 0 and context as context:
                Set weight to market_cap divided by total_market_cap
            
            Call dict_utils.set_value with dictionary as weights and key as symbol and value as weight
            
            If dict_utils.contains_key with dictionary as constituent_prices and key as symbol:
                Let price be dict_utils.get_value with dictionary as constituent_prices and key as symbol
                Set weighted_value to weighted_value plus price multiplied by weight
    
    Note: Calculate index value relative to base
    Let index_multiplier be index.base_value divided by weighted_value
    Let current_index_value be weighted_value multiplied by index_multiplier
    
    Let previous_value be index.value
    Let change be current_index_value minus previous_value
    Let change_percent be decimal_module.from_integer with value as 0 and context as context
    
    If previous_value is not equal to decimal_module.from_integer with value as 0 and context as context:
        Set change_percent to change divided by previous_value multiplied by decimal_module.from_integer with value as 100 and context as context
    
    Set index.value to current_index_value
    Set index.change to change
    Set index.change_percent to change_percent
    Set index.weights to weights
    
    Return index

Note: Risk and Performance Metrics

Process calculate_sharpe_ratio with
    returns as List[decimal_module.Decimal] and
    risk_free_rate as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    
    If list_utils.get_length with list as returns is equal to 0:
        Return decimal_module.from_integer with value as 0 and context as context
    
    Let average_return be stats_module.calculate_mean with values as returns
    Let return_standard_deviation be stats_module.calculate_standard_deviation with values as returns
    
    If return_standard_deviation is equal to decimal_module.from_integer with value as 0 and context as context:
        Return decimal_module.from_integer with value as 0 and context as context
    
    Let excess_return be average_return minus risk_free_rate
    Let sharpe_ratio be excess_return divided by return_standard_deviation
    
    Return sharpe_ratio

Process calculate_beta with
    asset_returns as List[decimal_module.Decimal] and
    market_returns as List[decimal_module.Decimal]:

    Let context be decimal_context.get_default_context
    
    Let asset_count be list_utils.get_length with list as asset_returns
    Let market_count be list_utils.get_length with list as market_returns
    
    If asset_count is not equal to market_count or asset_count is equal to 0:
        Return decimal_module.from_integer with value as 1 and context as context
    
    Let covariance be stats_module.calculate_covariance with x_values as asset_returns and y_values as market_returns
    Let market_variance be stats_module.calculate_variance with values as market_returns
    
    If market_variance is equal to decimal_module.from_integer with value as 0 and context as context:
        Return decimal_module.from_integer with value as 1 and context as context
    
    Let beta be covariance divided by market_variance
    Return beta

Process calculate_maximum_drawdown with prices as List[decimal_module.Decimal]:
    Let context be decimal_context.get_default_context
    Let price_count be list_utils.get_length with list as prices
    
    If price_count is less than 2:
        Return decimal_module.from_integer with value as 0 and context as context
    
    Let max_drawdown be decimal_module.from_integer with value as 0 and context as context
    Let peak_price be list_utils.get_item with list as prices and index as 0
    Let i be 1
    
    While i is less than price_count:
        Let current_price be list_utils.get_item with list as prices and index as i
        
        If current_price is greater than peak_price:
            Set peak_price to current_price
        Otherwise:
            Let drawdown be peak_price minus current_price divided by peak_price
            If drawdown is greater than max_drawdown:
                Set max_drawdown to drawdown
        
        Set i to i plus 1
    
    Return max_drawdown

Process calculate_volatility with
    returns as List[decimal_module.Decimal] and
    annualization_factor as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    
    If list_utils.get_length with list as returns is less than 2:
        Return decimal_module.from_integer with value as 0 and context as context
    
    Let return_std_dev be stats_module.calculate_standard_deviation with values as returns
    Let annualized_volatility be return_std_dev multiplied by math_module.square_root with value as annualization_factor and precision as context.precision
    
    Return annualized_volatility