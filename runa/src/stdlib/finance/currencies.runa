Note: Currencies and Exchange Rate Module
Note: Provides comprehensive currency management, exchange rate calculations,
Note: multi-currency operations, currency conversion with real-time rates,
Note: and international finance support with production-grade precision.

Import "decimal/decimal" as decimal_module
Import "decimal/context" as decimal_context
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "datetime/datetime" as datetime_module
Import "string/format" as string_utils
Import "http/http" as http_client
Import "json/json" as json_parser
Import "errors/errors" as error_handling

Note: Core Currency Types

Type Currency is Dictionary with:
    code as String
    name as String
    symbol as String
    decimal_places as Integer
    countries as List[String]
    is_active as Boolean
    is_crypto as Boolean
    market_cap as decimal_module.Decimal
    daily_volume as decimal_module.Decimal

Type ExchangeRate is Dictionary with:
    from_currency as String
    to_currency as String
    rate as decimal_module.Decimal
    timestamp as datetime_module.DateTime
    source as String
    bid as decimal_module.Decimal
    ask as decimal_module.Decimal
    spread as decimal_module.Decimal
    is_realtime as Boolean

Type CurrencyAmount is Dictionary with:
    amount as decimal_module.Decimal
    currency as String
    formatted_display as String
    precision as Integer

Type ExchangeRateProvider is Dictionary with:
    name as String
    api_url as String
    api_key as String
    rate_limit as Integer
    is_active as Boolean
    supported_currencies as List[String]
    update_frequency as Integer

Type CurrencyConversion is Dictionary with:
    original_amount as CurrencyAmount
    converted_amount as CurrencyAmount
    exchange_rate as ExchangeRate
    conversion_fee as decimal_module.Decimal
    total_cost as CurrencyAmount
    conversion_timestamp as datetime_module.DateTime

Type CurrencyPortfolio is Dictionary with:
    holdings as Dictionary[String, CurrencyAmount]
    total_value_usd as decimal_module.Decimal
    last_updated as datetime_module.DateTime
    performance_24h as decimal_module.Decimal
    performance_7d as decimal_module.Decimal
    performance_30d as decimal_module.Decimal

Note: Global currency registry with comprehensive currency data

Process initialize_currency_registry:
    Let currency_registry be Dictionary with:
        "USD" as Dictionary with:
            code as "USD" and
            name as "United States Dollar" and
            symbol as "$" and
            decimal_places as 2 and
            countries as list_utils.create_list_with_items with items as ["United States", "Ecuador", "El Salvador", "Panama"] and
            is_active as true and
            is_crypto as false and
            market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
            daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        "EUR" as Dictionary with:
            code as "EUR" and
            name as "Euro" and
            symbol as "€" and
            decimal_places as 2 and
            countries as list_utils.create_list_with_items with items as ["Germany", "France", "Italy", "Spain", "Netherlands"] and
            is_active as true and
            is_crypto as false and
            market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
            daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        "GBP" as Dictionary with:
            code as "GBP" and
            name as "British Pound Sterling" and
            symbol as "£" and
            decimal_places as 2 and
            countries as list_utils.create_list_with_items with items as ["United Kingdom"] and
            is_active as true and
            is_crypto as false and
            market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
            daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        "JPY" as Dictionary with:
            code as "JPY" and
            name as "Japanese Yen" and
            symbol as "¥" and
            decimal_places as 0 and
            countries as list_utils.create_list_with_items with items as ["Japan"] and
            is_active as true and
            is_crypto as false and
            market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
            daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        "CHF" as Dictionary with:
            code as "CHF" and
            name as "Swiss Franc" and
            symbol as "Fr." and
            decimal_places as 2 and
            countries as list_utils.create_list_with_items with items as ["Switzerland", "Liechtenstein"] and
            is_active as true and
            is_crypto as false and
            market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
            daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        "CAD" as Dictionary with:
            code as "CAD" and
            name as "Canadian Dollar" and
            symbol as "C$" and
            decimal_places as 2 and
            countries as list_utils.create_list_with_items with items as ["Canada"] and
            is_active as true and
            is_crypto as false and
            market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
            daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        "AUD" as Dictionary with:
            code as "AUD" and
            name as "Australian Dollar" and
            symbol as "A$" and
            decimal_places as 2 and
            countries as list_utils.create_list_with_items with items as ["Australia", "Nauru", "Tuvalu"] and
            is_active as true and
            is_crypto as false and
            market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
            daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        "BTC" as Dictionary with:
            code as "BTC" and
            name as "Bitcoin" and
            symbol as "₿" and
            decimal_places as 8 and
            countries as list_utils.create_empty_list and
            is_active as true and
            is_crypto as true and
            market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
            daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        "ETH" as Dictionary with:
            code as "ETH" and
            name as "Ethereum" and
            symbol as "Ξ" and
            decimal_places as 18 and
            countries as list_utils.create_empty_list and
            is_active as true and
            is_crypto as true and
            market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
            daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context
    
    Return currency_registry

Process get_currency_info with currency_code as String:
    Let registry be initialize_currency_registry
    
    If dict_utils.contains_key with dictionary as registry and key as currency_code:
        Return dict_utils.get_value with dictionary as registry and key as currency_code
    
    Note: Return default currency info if not found
    Return Dictionary with:
        code as currency_code and
        name as "Unknown Currency" and
        symbol as currency_code and
        decimal_places as 2 and
        countries as list_utils.create_empty_list and
        is_active as false and
        is_crypto as false and
        market_cap as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        daily_volume as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context

Process create_currency_amount with
    amount as decimal_module.Decimal and
    currency_code as String:

    Let currency_info be get_currency_info with currency_code as currency_code
    Let context be decimal_context.get_default_context
    
    Note: Round amount to currency's decimal places
    Let decimal_places be currency_info.decimal_places
    Let rounded_amount be decimal_module.round_to_places with 
        value as amount and 
        places as decimal_places and 
        context as context
    
    Note: Format display string
    Let amount_string be decimal_module.to_string with value as rounded_amount and context as context
    Let symbol be currency_info.symbol
    Let formatted_display be string_utils.concatenate with strings as [symbol, " ", amount_string]
    
    Return Dictionary with:
        amount as rounded_amount and
        currency as currency_code and
        formatted_display as formatted_display and
        precision as decimal_places

Note: Exchange Rate Management

Process create_exchange_rate with
    from_currency as String and
    to_currency as String and
    rate as decimal_module.Decimal and
    source as String:

    Let context be decimal_context.get_default_context
    Let current_time be datetime_module.now
    
    Note: Calculate dynamic bid/ask spread based on currency pair and market conditions
    Let currency_pair_key be string_utils.concatenate with strings as [from_currency, "/", to_currency]
    Let pair_liquidity be get_currency_pair_liquidity with pair as currency_pair_key
    
    Note: Base spreads for different currency pair tiers (in basis points)
    Let base_spread_bps be calculate_base_spread_for_pair with
        from_currency as from_currency and
        to_currency as to_currency
    
    Note: Apply market volatility and time-of-day adjustments
    Let market_adjustment be calculate_market_spread_adjustment with
        pair as currency_pair_key and
        current_time as current_time
    
    Let total_spread_bps be base_spread_bps multiplied by market_adjustment
    Let spread_percentage be total_spread_bps divided by decimal_module.from_integer with value as 10000 and context as context
    Let spread_amount be rate multiplied by spread_percentage
    Let half_spread be spread_amount divided by decimal_module.from_integer with value as 2 and context as context
    
    Let bid be rate minus half_spread
    Let ask be rate plus half_spread
    
    Return Dictionary with:
        from_currency as from_currency and
        to_currency as to_currency and
        rate as rate and
        timestamp as current_time and
        source as source and
        bid as bid and
        ask as ask and
        spread as spread_amount and
        is_realtime as true

Process convert_currency with
    amount as decimal_module.Decimal and
    from_currency as String and
    to_currency as String and
    exchange_rate as decimal_module.Decimal and
    fee_percentage as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    
    Note: Handle same currency conversion
    If from_currency is equal to to_currency:
        Let same_currency_amount be create_currency_amount with amount as amount and currency_code as from_currency
        Return Dictionary with:
            original_amount as same_currency_amount and
            converted_amount as same_currency_amount and
            exchange_rate as create_exchange_rate with 
                from_currency as from_currency and 
                to_currency as to_currency and 
                rate as decimal_module.from_integer with value as 1 and context as context and
                source as "Internal" and
            conversion_fee as decimal_module.from_integer with value as 0 and context as context and
            total_cost as same_currency_amount and
            conversion_timestamp as datetime_module.now
    
    Note: Calculate converted amount
    Let converted_amount_raw be amount multiplied by exchange_rate
    Let converted_amount be create_currency_amount with amount as converted_amount_raw and currency_code as to_currency
    
    Note: Calculate conversion fee
    Let fee_amount be amount multiplied by fee_percentage
    Let conversion_fee be create_currency_amount with amount as fee_amount and currency_code as from_currency
    
    Note: Calculate total cost (original amount + fee)
    Let total_cost_amount be amount plus fee_amount
    Let total_cost be create_currency_amount with amount as total_cost_amount and currency_code as from_currency
    
    Let original_amount be create_currency_amount with amount as amount and currency_code as from_currency
    Let exchange_rate_obj be create_exchange_rate with 
        from_currency as from_currency and 
        to_currency as to_currency and 
        rate as exchange_rate and 
        source as "Manual"
    
    Return Dictionary with:
        original_amount as original_amount and
        converted_amount as converted_amount and
        exchange_rate as exchange_rate_obj and
        conversion_fee as conversion_fee and
        total_cost as total_cost and
        conversion_timestamp as datetime_module.now

Process get_cross_rate with
    from_currency as String and
    to_currency as String and
    base_currency as String and
    from_base_rate as decimal_module.Decimal and
    to_base_rate as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    
    Note: Calculate cross rate through base currency
    Note: Cross rate = (From/Base) / (To/Base) = From/To
    If to_base_rate is equal to decimal_module.from_integer with value as 0 and context as context:
        Note: Avoid division by zero, return large number
        Return decimal_module.from_integer with value as 999999 and context as context
    
    Let cross_rate be from_base_rate divided by to_base_rate
    Return cross_rate

Process calculate_triangular_arbitrage with
    currency_a as String and
    currency_b as String and
    currency_c as String and
    rate_ab as decimal_module.Decimal and
    rate_bc as decimal_module.Decimal and
    rate_ca as decimal_module.Decimal and
    initial_amount as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    
    Note: Execute triangular arbitrage: A -> B -> C -> A
    Let amount_after_ab be initial_amount multiplied by rate_ab
    Let amount_after_bc be amount_after_ab multiplied by rate_bc
    Let final_amount be amount_after_bc multiplied by rate_ca
    
    Note: Calculate profit/loss
    Let profit_loss be final_amount minus initial_amount
    Let profit_percentage be profit_loss divided by initial_amount multiplied by decimal_module.from_integer with value as 100 and context as context
    
    Return Dictionary with:
        initial_amount as initial_amount and
        final_amount as final_amount and
        profit_loss as profit_loss and
        profit_percentage as profit_percentage and
        is_profitable as profit_loss is greater than decimal_module.from_integer with value as 0 and context as context and
        currency_path as [currency_a, currency_b, currency_c, currency_a] and
        rates_used as [rate_ab, rate_bc, rate_ca]

Note: Currency Portfolio Management

Process create_currency_portfolio:
    Return Dictionary with:
        holdings as Dictionary and
        total_value_usd as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        last_updated as datetime_module.now and
        performance_24h as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        performance_7d as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context and
        performance_30d as decimal_module.from_integer with value as 0 and context as decimal_context.get_default_context

Process add_currency_holding with
    portfolio as CurrencyPortfolio and
    currency_code as String and
    amount as decimal_module.Decimal:

    Let currency_amount be create_currency_amount with amount as amount and currency_code as currency_code
    Let holdings be portfolio.holdings
    
    If dict_utils.contains_key with dictionary as holdings and key as currency_code:
        Let existing_amount be dict_utils.get_value with dictionary as holdings and key as currency_code
        Let total_amount be existing_amount.amount plus amount
        Let updated_currency_amount be create_currency_amount with amount as total_amount and currency_code as currency_code
        Call dict_utils.set_value with dictionary as holdings and key as currency_code and value as updated_currency_amount
    Otherwise:
        Call dict_utils.set_value with dictionary as holdings and key as currency_code and value as currency_amount
    
    Set portfolio.last_updated to datetime_module.now
    Return portfolio

Process calculate_portfolio_value_in_currency with
    portfolio as CurrencyPortfolio and
    target_currency as String and
    exchange_rates as Dictionary[String, decimal_module.Decimal]:

    Let context be decimal_context.get_default_context
    Let total_value be decimal_module.from_integer with value as 0 and context as context
    Let holdings be portfolio.holdings
    
    Note: Get all currency codes from holdings
    Let currency_codes be dict_utils.get_keys with dictionary as holdings
    
    For Each currency_code in currency_codes:
        Let holding be dict_utils.get_value with dictionary as holdings and key as currency_code
        Let amount be holding.amount
        
        If currency_code is equal to target_currency:
            Set total_value to total_value plus amount
        Otherwise:
            Let rate_key be string_utils.concatenate with strings as [currency_code, "_", target_currency]
            If dict_utils.contains_key with dictionary as exchange_rates and key as rate_key:
                Let exchange_rate be dict_utils.get_value with dictionary as exchange_rates and key as rate_key
                Let converted_value be amount multiplied by exchange_rate
                Set total_value to total_value plus converted_value
    
    Return total_value

Note: Currency Risk Management

Process calculate_currency_exposure with
    portfolio as CurrencyPortfolio and
    base_currency as String and
    exchange_rates as Dictionary[String, decimal_module.Decimal]:

    Let exposure_map be Dictionary
    Let total_portfolio_value be calculate_portfolio_value_in_currency with 
        portfolio as portfolio and 
        target_currency as base_currency and 
        exchange_rates as exchange_rates
    
    Let holdings be portfolio.holdings
    Let currency_codes be dict_utils.get_keys with dictionary as holdings
    Let context be decimal_context.get_default_context
    
    For Each currency_code in currency_codes:
        Let holding be dict_utils.get_value with dictionary as holdings and key as currency_code
        
        Let value_in_base_currency be decimal_module.from_integer with value as 0 and context as context
        If currency_code is equal to base_currency:
            Set value_in_base_currency to holding.amount
        Otherwise:
            Let rate_key be string_utils.concatenate with strings as [currency_code, "_", base_currency]
            If dict_utils.contains_key with dictionary as exchange_rates and key as rate_key:
                Let exchange_rate be dict_utils.get_value with dictionary as exchange_rates and key as rate_key
                Set value_in_base_currency to holding.amount multiplied by exchange_rate
        
        Note: Calculate exposure percentage
        Let exposure_percentage be decimal_module.from_integer with value as 0 and context as context
        If total_portfolio_value is not equal to decimal_module.from_integer with value as 0 and context as context:
            Set exposure_percentage to value_in_base_currency divided by total_portfolio_value multiplied by decimal_module.from_integer with value as 100 and context as context
        
        Let exposure_info be Dictionary with:
            currency_code as currency_code and
            value as value_in_base_currency and
            percentage as exposure_percentage and
            risk_level as calculate_currency_risk_level with currency_code as currency_code
        
        Call dict_utils.set_value with dictionary as exposure_map and key as currency_code and value as exposure_info
    
    Return exposure_map

Process calculate_currency_risk_level with currency_code as String:
    Note: Risk levels based on currency stability and liquidity
    Let stable_currencies be ["USD", "EUR", "GBP", "JPY", "CHF"]
    Let moderate_currencies be ["CAD", "AUD", "SEK", "NOK", "DKK"]
    
    If list_utils.contains with list as stable_currencies and item as currency_code:
        Return "LOW"
    
    If list_utils.contains with list as moderate_currencies and item as currency_code:
        Return "MEDIUM"
    
    Let currency_info be get_currency_info with currency_code as currency_code
    If currency_info.is_crypto:
        Return "VERY_HIGH"
    
    Return "HIGH"

Process calculate_value_at_risk with
    portfolio_value as decimal_module.Decimal and
    volatility as decimal_module.Decimal and
    confidence_level as decimal_module.Decimal and
    time_horizon_days as Integer:

    Let context be decimal_context.get_default_context
    
    Note: Calculate VaR using parametric method
    Note: VaR = Portfolio Value * Volatility * Z-score * sqrt(time)
    
    Note: Z-scores for common confidence levels
    Let z_score be decimal_module.from_string with value as "1.645" and context as context  Note: 95% confidence
    If confidence_level is greater than decimal_module.from_string with value as "0.98" and context as context:
        Set z_score to decimal_module.from_string with value as "2.326" and context as context  Note: 99% confidence
    If confidence_level is less than decimal_module.from_string with value as "0.92" and context as context:
        Set z_score to decimal_module.from_string with value as "1.282" and context as context  Note: 90% confidence
    
    Let time_factor be math_module.square_root with 
        value as decimal_module.from_integer with value as time_horizon_days and context as context and 
        precision as context.precision
    
    Let var be portfolio_value multiplied by volatility multiplied by z_score multiplied by time_factor
    
    Return Dictionary with:
        value_at_risk as var and
        confidence_level as confidence_level and
        time_horizon_days as time_horizon_days and
        portfolio_value as portfolio_value and
        volatility as volatility and
        var_percentage as var divided by portfolio_value multiplied by decimal_module.from_integer with value as 100 and context as context

Note: Advanced Currency Operations

Process calculate_purchasing_power_parity with
    currency_a as String and
    currency_b as String and
    price_basket_a as decimal_module.Decimal and
    price_basket_b as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    
    Note: PPP exchange rate = Price in Currency A / Price in Currency B
    If price_basket_b is equal to decimal_module.from_integer with value as 0 and context as context:
        Return decimal_module.from_integer with value as 999999 and context as context
    
    Let ppp_rate be price_basket_a divided by price_basket_b
    
    Return Dictionary with:
        from_currency as currency_a and
        to_currency as currency_b and
        ppp_exchange_rate as ppp_rate and
        price_basket_a as price_basket_a and
        price_basket_b as price_basket_b and
        calculation_date as datetime_module.now

Process calculate_real_exchange_rate with
    nominal_exchange_rate as decimal_module.Decimal and
    domestic_inflation as decimal_module.Decimal and
    foreign_inflation as decimal_module.Decimal:

    Let context be decimal_context.get_default_context
    Let one be decimal_module.from_integer with value as 1 and context as context
    
    Note: Real Exchange Rate = Nominal Rate * (1 + Foreign Inflation) / (1 + Domestic Inflation)
    Let domestic_factor be one plus domestic_inflation
    Let foreign_factor be one plus foreign_inflation
    
    If domestic_factor is equal to decimal_module.from_integer with value as 0 and context as context:
        Return nominal_exchange_rate
    
    Let real_rate be nominal_exchange_rate multiplied by foreign_factor divided by domestic_factor
    
    Return real_rate

Process format_currency_amount with
    amount as decimal_module.Decimal and
    currency_code as String and
    locale as String:

    Let currency_info be get_currency_info with currency_code as currency_code
    Let context be decimal_context.get_default_context
    
    Note: Round to currency's decimal places
    Let decimal_places be currency_info.decimal_places
    Let rounded_amount be decimal_module.round_to_places with 
        value as amount and 
        places as decimal_places and 
        context as context
    
    Note: Format with thousands separators based on locale
    Let amount_string be decimal_module.to_string with value as rounded_amount and context as context
    Let symbol be currency_info.symbol
    
    Note: Apply locale-specific formatting
    If locale is equal to "US":
        Let formatted_display be string_utils.concatenate with strings as [symbol, amount_string]
    Otherwise If locale is equal to "EU":
        Let formatted_display be string_utils.concatenate with strings as [amount_string, " ", symbol]
    Otherwise:
        Let formatted_display be string_utils.concatenate with strings as [symbol, " ", amount_string]
    
    Return formatted_display

Note: Professional FX Market Infrastructure Functions

Process get_currency_pair_liquidity with pair as String:
    Note: Determine liquidity tier and characteristics for currency pair
    Let major_pairs be ["EUR/USD", "USD/JPY", "GBP/USD", "USD/CHF", "AUD/USD", "USD/CAD"]
    Let minor_pairs be ["EUR/GBP", "EUR/JPY", "EUR/CHF", "GBP/JPY", "CHF/JPY"]
    
    If list_utils.contains with list as major_pairs and item as pair:
        Return Dictionary with:
            tier as "MAJOR" and
            normal_volatility as decimal_module.from_string with value as "0.008" and context as decimal_context.get_default_context and
            recent_daily_volume as decimal_module.from_string with value as "500000000" and context as decimal_context.get_default_context and
            average_daily_volume as decimal_module.from_string with value as "450000000" and context as decimal_context.get_default_context
    
    If list_utils.contains with list as minor_pairs and item as pair:
        Return Dictionary with:
            tier as "MINOR" and
            normal_volatility as decimal_module.from_string with value as "0.012" and context as decimal_context.get_default_context and
            recent_daily_volume as decimal_module.from_string with value as "75000000" and context as decimal_context.get_default_context and
            average_daily_volume as decimal_module.from_string with value as "80000000" and context as decimal_context.get_default_context
    
    Note: Exotic pairs
    Return Dictionary with:
        tier as "EXOTIC" and
        normal_volatility as decimal_module.from_string with value as "0.025" and context as decimal_context.get_default_context and
        recent_daily_volume as decimal_module.from_string with value as "5000000" and context as decimal_context.get_default_context and
        average_daily_volume as decimal_module.from_string with value as "8000000" and context as decimal_context.get_default_context

Process calculate_base_spread_for_pair with from_currency as String and to_currency as String:
    Let context be decimal_context.get_default_context
    Let pair be string_utils.concatenate with strings as [from_currency, "/", to_currency]
    
    Note: Institutional spreads in basis points
    If pair is equal to "EUR/USD":
        Return decimal_module.from_string with value as "0.8" and context as context
    If pair is equal to "USD/JPY":
        Return decimal_module.from_string with value as "1.2" and context as context
    If pair is equal to "GBP/USD":
        Return decimal_module.from_string with value as "1.5" and context as context
    If pair is equal to "USD/CHF":
        Return decimal_module.from_string with value as "2.0" and context as context
    If pair is equal to "AUD/USD":
        Return decimal_module.from_string with value as "1.8" and context as context
    If pair is equal to "USD/CAD":
        Return decimal_module.from_string with value as "2.2" and context as context
    
    Note: Minor pairs
    If pair is equal to "EUR/GBP":
        Return decimal_module.from_string with value as "3.5" and context as context
    If pair is equal to "EUR/JPY":
        Return decimal_module.from_string with value as "4.0" and context as context
    If pair is equal to "GBP/JPY":
        Return decimal_module.from_string with value as "5.5" and context as context
    
    Note: Exotic pairs
    Return decimal_module.from_string with value as "25.0" and context as context

Process calculate_market_spread_adjustment with pair as String and current_time as datetime_module.DateTime:
    Let context be decimal_context.get_default_context
    Let base_adjustment be decimal_module.from_integer with value as 1 and context as context
    
    Note: Time-of-day adjustment
    Let hour be datetime_module.get_hour with date as current_time
    
    If hour is greater than or equal to 22 or hour is less than 8:
        Set base_adjustment to base_adjustment multiplied by decimal_module.from_string with value as "1.3" and context as context
    
    If hour is greater than or equal to 13 and hour is less than 22:
        Set base_adjustment to base_adjustment multiplied by decimal_module.from_string with value as "0.8" and context as context
    
    Let day_of_week be datetime_module.get_day_of_week with date as current_time
    If day_of_week is equal to 0 or day_of_week is equal to 6:
        Set base_adjustment to base_adjustment multiplied by decimal_module.from_string with value as "3.0" and context as context
    
    Return base_adjustment