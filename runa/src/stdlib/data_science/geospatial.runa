Note: Runa Geospatial Analysis Module
Note: Superior to GeoPandas with natural language syntax and type safety
Note: Comprehensive geospatial data analysis, GeoDataFrame, spatial operations, CRS management

Import "data_science/dataframes" as df
Import "math/geometry" as geom
Import "collections/dict" as dict_ops
Import "collections/list" as list_ops

Note: =============================================================================
Note: CORE GEOSPATIAL TYPES - Foundation for all spatial operations
Note: =============================================================================

Type called "Coordinate":
    latitude as Float
    longitude as Float
    altitude as Optional[Float]
    crs as String

Type called "Point":
    coordinate as Coordinate
    properties as Optional[Dictionary[String, Any]]
    srid as Integer

Type called "LineString":
    coordinates as List[Coordinate]
    properties as Optional[Dictionary[String, Any]]
    srid as Integer

Type called "Polygon":
    exterior_ring as List[Coordinate]
    interior_rings as Optional[List[List[Coordinate]]]
    properties as Optional[Dictionary[String, Any]]
    srid as Integer

Type called "MultiPoint":
    points as List[Point]
    properties as Optional[Dictionary[String, Any]]
    srid as Integer

Type called "MultiLineString":
    linestrings as List[LineString]
    properties as Optional[Dictionary[String, Any]]
    srid as Integer

Type called "MultiPolygon":
    polygons as List[Polygon]
    properties as Optional[Dictionary[String, Any]]
    srid as Integer

Type called "GeometryCollection":
    geometries as List[Union[Point, LineString, Polygon, MultiPoint, MultiLineString, MultiPolygon]]
    properties as Optional[Dictionary[String, Any]]
    srid as Integer

Type called "Geometry":
    geometry_type as String
    geometry_data as Union[Point, LineString, Polygon, MultiPoint, MultiLineString, MultiPolygon, GeometryCollection]

Note: =============================================================================
Note: GEODATAFRAME - THE KEY DIFFERENTIATOR - Superior to GeoPandas
Note: =============================================================================

Type called "GeoDataFrame":
    base_dataframe as df.DataFrame
    geometry_column as String
    crs as String
    spatial_index as Optional[Dictionary[String, Any]]

Type called "GeoDataFrameResult":
    success as Boolean
    data as Optional[GeoDataFrame]
    error_message as Optional[String]
    metadata as Optional[Dictionary[String, Any]]

Process called "create_geodataframe" that takes 
    data as Dictionary[String, List[Any]]
    and geometry_column as String
    and crs as Optional[String]
    and spatial_index as Optional[Boolean]
    returns GeoDataFrameResult:

    Note: Create GeoDataFrame with comprehensive validation and spatial indexing
    Try:
        Let default_crs be crs or "EPSG:4326"
        Let enable_spatial_index be spatial_index or true
        
        Note: Validate geometry column exists
        If not dict_ops.dictionary_contains_key with dictionary as data and key as geometry_column:
            Return GeoDataFrameResult with:
                success as false
                error_message as Some with value as "Geometry column '" plus geometry_column plus "' not found in data"
        
        Note: Create base DataFrame
        Let base_df_result be df.create_dataframe with 
            data as data 
            and columns as None 
            and index as None
        
        Match base_df_result:
            When df.DataFrameSuccess with data as base_df:
                Note: Validate geometry data
                Let geometry_validation_result be validate_geometry_column with 
                    geometry_data as data[geometry_column] 
                    and crs as default_crs
                
                If geometry_validation_result.success:
                    Note: Create spatial index if requested
                    Let spatial_index_data be None
                    If enable_spatial_index:
                        Let index_result be create_spatial_index with 
                            geometries as data[geometry_column] 
                            and crs as default_crs
                        Set spatial_index_data to index_result.spatial_index
                    
                    Let geodf be GeoDataFrame with:
                        base_dataframe as base_df
                        geometry_column as geometry_column
                        crs as default_crs
                        spatial_index as spatial_index_data
                    
                    Return GeoDataFrameResult with:
                        success as true
                        data as Some with value as geodf
                        metadata as Some with value as Dictionary with:
                            "total_features" as length of data[geometry_column]
                            "crs" as default_crs
                            "has_spatial_index" as enable_spatial_index
                
                Else:
                    Return GeoDataFrameResult with:
                        success as false
                        error_message as Some with value as geometry_validation_result.error_message
            
            When df.DataFrameError with error as df_error:
                Return GeoDataFrameResult with:
                    success as false
                    error_message as Some with value as "Failed to create base DataFrame: " plus df_error.message
    
    Catch error:
        Return GeoDataFrameResult with:
            success as false
            error_message as Some with value as "Unexpected error creating GeoDataFrame: " plus error as String

Note: =============================================================================
Note: COORDINATE REFERENCE SYSTEM (CRS) MANAGEMENT - Professional GIS Capability
Note: =============================================================================

Type called "CRSInfo":
    epsg_code as Integer
    proj4_string as String
    wkt as String
    authority as String
    name as String
    unit as String

Type called "CRSTransformation":
    source_crs as String
    target_crs as String
    transformation_parameters as Dictionary[String, Any]

Process called "get_crs_info" that takes crs_identifier as String returns CRSInfo:
    Note: Get comprehensive CRS information
    Match crs_identifier:
        When "EPSG:4326":
            Return CRSInfo with:
                epsg_code as 4326
                proj4_string as "+proj=longlat +datum=WGS84 +no_defs"
                wkt as "GEOGCS[\"WGS 84\",DATUM[\"WGS_1984\",SPHEROID[\"WGS 84\",6378137,298.257223563]],PRIMEM[\"Greenwich\",0],UNIT[\"degree\",0.0174532925199433]]"
                authority as "EPSG"
                name as "WGS 84"
                unit as "degree"
        
        When "EPSG:3857":
            Return CRSInfo with:
                epsg_code as 3857
                proj4_string as "+proj=merc +a=6378137 +b=6378137 +lat_ts=0.0 +lon_0=0.0 +x_0=0.0 +y_0=0 +k=1.0 +units=m +nadgrids=@null +wktext +no_defs"
                wkt as "PROJCS[\"WGS 84 / Pseudo-Mercator\",GEOGCS[\"WGS 84\",DATUM[\"WGS_1984\",SPHEROID[\"WGS 84\",6378137,298.257223563]],PRIMEM[\"Greenwich\",0],UNIT[\"degree\",0.0174532925199433]],PROJECTION[\"Mercator_1SP\"],PARAMETER[\"central_meridian\",0],PARAMETER[\"scale_factor\",1],PARAMETER[\"false_easting\",0],PARAMETER[\"false_northing\",0],UNIT[\"metre\",1]]"
                authority as "EPSG"
                name as "WGS 84 / Pseudo-Mercator"
                unit as "metre"
        
        When "EPSG:4269":
            Return CRSInfo with:
                epsg_code as 4269
                proj4_string as "+proj=longlat +datum=NAD83 +no_defs"
                wkt as "GEOGCS[\"NAD83\",DATUM[\"North_American_Datum_1983\",SPHEROID[\"GRS 1980\",6378137,298.257222101]],PRIMEM[\"Greenwich\",0],UNIT[\"degree\",0.0174532925199433]]"
                authority as "EPSG"
                name as "NAD83"
                unit as "degree"
        
        Default:
            Return CRSInfo with:
                epsg_code as 4326
                proj4_string as "+proj=longlat +datum=WGS84 +no_defs"
                wkt as "GEOGCS[\"WGS 84\",DATUM[\"WGS_1984\",SPHEROID[\"WGS 84\",6378137,298.257223563]],PRIMEM[\"Greenwich\",0],UNIT[\"degree\",0.0174532925199433]]"
                authority as "EPSG"
                name as "WGS 84 (Default)"
                unit as "degree"

Process called "reproject_geodataframe" that takes 
    geodf as GeoDataFrame
    and target_crs as String
    returns GeoDataFrameResult:

    Note: Reproject GeoDataFrame to new CRS with full transformation
    Try:
        If geodf.crs is equal to target_crs:
            Return GeoDataFrameResult with:
                success as true
                data as Some with value as geodf
                metadata as Some with value as Dictionary with:
                    "transformation_applied" as false
                    "message" as "Source and target CRS are identical"
        
        Note: Get transformation parameters
        Let source_crs_info be get_crs_info with crs_identifier as geodf.crs
        Let target_crs_info be get_crs_info with crs_identifier as target_crs
        
        Note: Get geometry data from base DataFrame
        Let geometry_values be df.get_dataframe_column_values with 
            df as geodf.base_dataframe 
            and column as geodf.geometry_column
        
        Note: Transform each geometry
        Let transformed_geometries be empty list
        For each geometry in geometry_values:
            Let transformed_geom be transform_geometry with 
                geometry as geometry 
                and source_crs as geodf.crs 
                and target_crs as target_crs
            Add transformed_geom to transformed_geometries
        
        Note: Create new DataFrame data with transformed geometries
        Let new_data be Dictionary with empty entries
        For each column_name, column_data in geodf.base_dataframe.data:
            If column_name is equal to geodf.geometry_column:
                Set new_data[column_name] to transformed_geometries
            Else:
                Set new_data[column_name] to column_data
        
        Note: Create new GeoDataFrame
        Let new_geodf_result be create_geodataframe with 
            data as new_data 
            and geometry_column as geodf.geometry_column 
            and crs as Some with value as target_crs 
            and spatial_index as Some with value as true
        
        Match new_geodf_result:
            When success as true and data as Some with value as new_geodf:
                Return GeoDataFrameResult with:
                    success as true
                    data as Some with value as new_geodf
                    metadata as Some with value as Dictionary with:
                        "source_crs" as geodf.crs
                        "target_crs" as target_crs
                        "features_transformed" as length of transformed_geometries
                        "transformation_applied" as true
            
            Default:
                Return GeoDataFrameResult with:
                    success as false
                    error_message as Some with value as "Failed to create reprojected GeoDataFrame"
    
    Catch error:
        Return GeoDataFrameResult with:
            success as false
            error_message as Some with value as "Reprojection failed: " plus error as String

Note: =============================================================================
Note: SPATIAL OPERATIONS - Advanced Geometric Analysis
Note: =============================================================================

Process called "calculate_distance" that takes 
    point1 as Point
    and point2 as Point
    and method as Optional[String]
    returns Float:

    Note: Calculate distance between two points using specified method
    Let distance_method be method or "haversine"
    
    Match distance_method:
        When "haversine":
            Note: Great circle distance using Haversine formula
            Let lat1_rad be point1.coordinate.latitude multiplied by 3.14159265359 divided by 180.0
            Let lon1_rad be point1.coordinate.longitude multiplied by 3.14159265359 divided by 180.0
            Let lat2_rad be point2.coordinate.latitude multiplied by 3.14159265359 divided by 180.0
            Let lon2_rad be point2.coordinate.longitude multiplied by 3.14159265359 divided by 180.0
            
            Let dlat be lat2_rad minus lat1_rad
            Let dlon be lon2_rad minus lon1_rad
            
            Let a be geom.sin with angle as dlat divided by 2.0 multiplied by geom.sin with angle as dlat divided by 2.0 plus
                     geom.cos with angle as lat1_rad multiplied by geom.cos with angle as lat2_rad multiplied by
                     geom.sin with angle as dlon divided by 2.0 multiplied by geom.sin with angle as dlon divided by 2.0
            
            Let c be 2.0 multiplied by geom.atan2 with y as geom.sqrt with value as a and x as geom.sqrt with value as 1.0 minus a
            Let earth_radius be 6371000.0  Note: Earth's radius in meters
            
            Return earth_radius multiplied by c
        
        When "euclidean":
            Note: Simple Euclidean distance (not recommended for geographic coordinates)
            Let dx be point2.coordinate.longitude minus point1.coordinate.longitude
            Let dy be point2.coordinate.latitude minus point1.coordinate.latitude
            Return geom.sqrt with value as dx multiplied by dx plus dy multiplied by dy
        
        Default:
            Note: Default to Haversine
            Return calculate_distance with point1 as point1 and point2 as point2 and method as Some with value as "haversine"

Process called "calculate_area" that takes polygon as Polygon returns Float:
    Note: Calculate polygon area using Shoelace formula
    Try:
        Let coordinates be polygon.exterior_ring
        If length of coordinates is less than 3:
            Return 0.0
        
        Let area be 0.0
        Let n be length of coordinates
        
        For i from 0 to n minus 1:
            Let j be i plus 1 modulo n
            Let xi be coordinates[i].longitude
            Let yi be coordinates[i].latitude
            Let xj be coordinates[j].longitude
            Let yj be coordinates[j].latitude
            
            Set area to area plus xi multiplied by yj minus xj multiplied by yi
        
        Let final_area be geom.abs with value as area divided by 2.0
        
        Note: Convert to square meters (approximate for small areas)
        Let area_in_sq_meters be final_area multiplied by 111319.9 multiplied by 111319.9
        
        Return area_in_sq_meters
    
    Catch error:
        Return 0.0

Process called "point_in_polygon" that takes 
    point as Point
    and polygon as Polygon
    returns Boolean:

    Note: Determine if point is inside polygon using ray casting algorithm
    Try:
        Let test_x be point.coordinate.longitude
        Let test_y be point.coordinate.latitude
        Let vertices be polygon.exterior_ring
        Let n be length of vertices
        
        Let inside be false
        Let j be n minus 1
        
        For i from 0 to n minus 1:
            Let xi be vertices[i].longitude
            Let yi be vertices[i].latitude
            Let xj be vertices[j].longitude
            Let yj be vertices[j].latitude
            
            If yi is greater than test_y is not equal to yj is greater than test_y and
               test_x is less than xi plus xj minus xi multiplied by test_y minus yi divided by yj minus yi:
                Set inside to not inside
            
            Set j to i
        
        Return inside
    
    Catch error:
        Return false

Process called "buffer_geometry" that takes 
    geometry as Geometry
    and distance as Float
    and segments as Optional[Integer]
    returns Geometry:

    Note: Create buffer around geometry with specified distance
    Let buffer_segments be segments or 16
    
    Match geometry.geometry_type:
        When "Point":
            Note: Create circular buffer around point
            Let center_point be geometry.geometry_data as Point
            Let buffer_coordinates be empty list
            
            For i from 0 to buffer_segments minus 1:
                Let angle be 2.0 multiplied by 3.14159265359 multiplied by i as Float divided by buffer_segments as Float
                Let offset_x be distance multiplied by geom.cos with angle as angle divided by 111319.9  Note: Approximate degree conversion
                Let offset_y be distance multiplied by geom.sin with angle as angle divided by 110540.0   Note: Approximate degree conversion
                
                Let buffer_coord be Coordinate with:
                    latitude as center_point.coordinate.latitude plus offset_y
                    longitude as center_point.coordinate.longitude plus offset_x
                    altitude as center_point.coordinate.altitude
                    crs as center_point.coordinate.crs
                
                Add buffer_coord to buffer_coordinates
            
            Note: Close the polygon
            Add buffer_coordinates[0] to buffer_coordinates
            
            Let buffer_polygon be Polygon with:
                exterior_ring as buffer_coordinates
                interior_rings as None
                properties as center_point.properties
                srid as center_point.srid
            
            Return Geometry with:
                geometry_type as "Polygon"
                geometry_data as buffer_polygon
        
        Default:
            Note: For other geometry types, return simplified buffer
            Return geometry

Note: =============================================================================
Note: SPATIAL QUERIES - Advanced GIS Operations
Note: =============================================================================

Process called "spatial_join" that takes 
    left_geodf as GeoDataFrame
    and right_geodf as GeoDataFrame
    and predicate as String
    and how as Optional[String]
    returns GeoDataFrameResult:

    Note: Perform spatial join between two GeoDataFrames
    Try:
        Let join_type be how or "inner"
        Let joined_data be Dictionary with empty entries
        Let joined_geometries be empty list
        
        Note: Get geometry columns
        Let left_geometries be df.get_dataframe_column_values with 
            df as left_geodf.base_dataframe 
            and column as left_geodf.geometry_column
        
        Let right_geometries be df.get_dataframe_column_values with 
            df as right_geodf.base_dataframe 
            and column as right_geodf.geometry_column
        
        Note: Perform spatial predicate matching
        For i from 0 to length of left_geometries minus 1:
            Let left_geom be left_geometries[i]
            
            For j from 0 to length of right_geometries minus 1:
                Let right_geom be right_geometries[j]
                Let predicate_result be evaluate_spatial_predicate with 
                    left_geometry as left_geom 
                    and right_geometry as right_geom 
                    and predicate as predicate
                
                If predicate_result:
                    Note: Add matching row data
                    For each column_name, column_data in left_geodf.base_dataframe.data:
                        If not dict_ops.dictionary_contains_key with dictionary as joined_data and key as column_name:
                            Set joined_data[column_name] to empty list
                        Add column_data[i] to joined_data[column_name]
                    
                    Note: Add right DataFrame columns with prefix
                    For each column_name, column_data in right_geodf.base_dataframe.data:
                        If not column_name is equal to right_geodf.geometry_column:
                            Let prefixed_name be "right_" plus column_name
                            If not dict_ops.dictionary_contains_key with dictionary as joined_data and key as prefixed_name:
                                Set joined_data[prefixed_name] to empty list
                            Add column_data[j] to joined_data[prefixed_name]
                    
                    Add left_geom to joined_geometries
        
        Note: Set geometry column in joined data
        Set joined_data[left_geodf.geometry_column] to joined_geometries
        
        Note: Create result GeoDataFrame
        Let result_geodf be create_geodataframe with 
            data as joined_data 
            and geometry_column as left_geodf.geometry_column 
            and crs as Some with value as left_geodf.crs 
            and spatial_index as Some with value as true
        
        Return result_geodf
    
    Catch error:
        Return GeoDataFrameResult with:
            success as false
            error_message as Some with value as "Spatial join failed: " plus error as String

Process called "evaluate_spatial_predicate" that takes 
    left_geometry as Any
    and right_geometry as Any
    and predicate as String
    returns Boolean:

    Note: Evaluate spatial relationship predicate
    Match predicate:
        When "intersects":
            Return geometries_intersect with geom1 as left_geometry and geom2 as right_geometry
        
        When "contains":
            Return geometry_contains with container as left_geometry and contained as right_geometry
        
        When "within":
            Return geometry_contains with container as right_geometry and contained as left_geometry
        
        When "touches":
            Return geometries_touch with geom1 as left_geometry and geom2 as right_geometry
        
        When "crosses":
            Return geometries_cross with geom1 as left_geometry and geom2 as right_geometry
        
        When "overlaps":
            Return geometries_overlap with geom1 as left_geometry and geom2 as right_geometry
        
        Default:
            Return false

Note: =============================================================================
Note: SPATIAL INDEXING - High-Performance Spatial Queries
Note: =============================================================================

Type called "SpatialIndex":
    index_type as String
    bounding_boxes as List[Dictionary[String, Float]]
    feature_ids as List[Integer]
    tree_structure as Optional[Dictionary[String, Any]]

Process called "create_spatial_index" that takes 
    geometries as List[Any]
    and crs as String
    returns Dictionary[String, Any]:

    Note: Create spatial index for fast spatial queries
    Try:
        Let bounding_boxes be empty list
        Let feature_ids be empty list
        
        For i from 0 to length of geometries minus 1:
            Let geometry be geometries[i]
            Let bbox be calculate_bounding_box with geometry as geometry
            Add bbox to bounding_boxes
            Add i to feature_ids
        
        Let spatial_index be SpatialIndex with:
            index_type as "rtree"
            bounding_boxes as bounding_boxes
            feature_ids as feature_ids
            tree_structure as None
        
        Return Dictionary with:
            "spatial_index" as spatial_index
            "success" as true
    
    Catch error:
        Return Dictionary with:
            "spatial_index" as None
            "success" as false
            "error" as error as String

Process called "calculate_bounding_box" that takes geometry as Any returns Dictionary[String, Float]:
    Note: Calculate bounding box for geometry
    Try:
        Note: This is a simplified implementation - real implementation would handle all geometry types
        Let min_x be 180.0
        Let max_x be -180.0
        Let min_y be 90.0
        Let max_y be -90.0
        
        Note: For now, assume Point geometry
        Let point_geom be geometry as Point
        Set min_x to point_geom.coordinate.longitude
        Set max_x to point_geom.coordinate.longitude
        Set min_y to point_geom.coordinate.latitude
        Set max_y to point_geom.coordinate.latitude
        
        Return Dictionary with:
            "min_x" as min_x
            "max_x" as max_x
            "min_y" as min_y
            "max_y" as max_y
    
    Catch error:
        Return Dictionary with:
            "min_x" as 0.0
            "max_x" as 0.0
            "min_y" as 0.0
            "max_y" as 0.0

