            When \"3\": Return 3
            When \"4\": Return 4
            When \"5\": Return 5
            When \"6\": Return 6
            When \"7\": Return 7
            When \"8\": Return 8
            When \"9\": Return 9
            Otherwise: Return -1
    
    Catch error:
        Return -1

Process called \"is_likely_numeric\" that takes text as String returns Boolean:
    Note: Check if text looks like a number
    Try:
        If length of text is equal to 0:
            Return false
        
        Note: Check each character
        Let pos be 0
        Let has_digit be false
        Let decimal_count be 0
        
        While pos is less than length of text:
            Let char be substring_from_position with text as text and start_pos as pos and length as 1
            
            If char is equal to \".\": 
                Set decimal_count to decimal_count plus 1
                If decimal_count is greater than 1:
                    Return false
            Else:
                If char is equal to \"-\" and pos is not equal to 0:
                    Return false
                Else:
                    Let digit_val be simple_char_to_digit with char as char
                    If digit_val is greater than or equal to 0:
                        Set has_digit to true
                    Else:
                        If char is not equal to \"-\":
                            Return false
            
            Set pos to pos plus 1
        
        Return has_digit
    
    Catch error:
        Return false

Process called \"substring_from_position\" that takes text as String and start_pos as Integer and length as Optional[Integer] returns String:
