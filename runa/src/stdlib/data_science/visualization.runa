Note:
Runa Standard Library: Data Visualization Module

This module provides comprehensive data visualization and plotting capabilities,
enabling creation of publication-quality charts, graphs, and interactive visualizations.
Supports multiple backends, customizable styling, and seamless integration with 
DataFrame operations for exploratory data analysis and reporting.

Key Features:
- Complete plotting API with line, bar, scatter, histogram, heatmap charts
- Statistical plotting including box plots, violin plots, distribution plots
- Interactive visualization capabilities with zoom, pan, and selection
- Multiple backend support (SVG, Canvas, WebGL) for different use cases
- Customizable themes, color schemes, and styling options
- Integration with DataFrame for direct plotting from data
- Export capabilities to various formats (PNG, SVG, PDF, HTML)
- Animation support for time-series and dynamic visualizations
- 3D plotting capabilities for complex data relationships
- Dashboard and multi-plot layouts with synchronized interactions

Architecture:
Provides a layered visualization system with high-level plotting functions
for common use cases, mid-level customization APIs for advanced styling,
and low-level rendering primitives for custom visualization development.
:End Note

Import "data_science/dataframes" as df_core
Import "data_science/analysis" as stats_core
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "math/core" as math_core
Import "string/format" as string_utils

Note: Core Visualization Types

Type PlotType is Enumeration with:
    line_plot
    bar_plot
    scatter_plot
    histogram
    box_plot
    violin_plot
    heatmap
    pie_chart
    area_plot
    surface_plot

Type ChartBackend is Enumeration with:
    svg_backend
    canvas_backend
    webgl_backend
    terminal_backend

Type ColorScheme is Enumeration with:
    viridis
    plasma
    blues
    greens
    reds
    grayscale
    rainbow
    custom

Type PlotTheme is Dictionary with:
    background_color as String
    grid_color as String
    axis_color as String
    text_color as String
    line_width as Float
    font_family as String
    font_size as Integer

Type PlotConfiguration is Dictionary with:
    title as Optional[String]
    x_label as Optional[String]
    y_label as Optional[String]
    width as Integer
    height as Integer
    theme as PlotTheme
    color_scheme as ColorScheme
    backend as ChartBackend
    interactive as Boolean
    show_grid as Boolean
    show_legend as Boolean

Type PlotData is Dictionary with:
    x_values as List[Any]
    y_values as List[Any]
    labels as Optional[List[String]]
    colors as Optional[List[String]]
    sizes as Optional[List[Float]]
    metadata as Dictionary[String, Any]

Type VisualizationResult is Union with:
    PlotSuccess with:
        plot_object as Plot
        metadata as Dictionary[String, Any]
    PlotError with:
        error as Any
        context as Dictionary[String, Any]

Type Plot is Dictionary with:
    plot_id as String
    plot_type as PlotType
    data as PlotData
    config as PlotConfiguration
    svg_content as Optional[String]
    interactive_elements as List[InteractiveElement]
    animation_frames as Optional[List[AnimationFrame]]

Type InteractiveElement is Dictionary with:
    element_id as String
    element_type as String
    position as Dictionary[String, Float]
    properties as Dictionary[String, Any]
    event_handlers as Dictionary[String, String]

Type AnimationFrame is Dictionary with:
    frame_id as Integer
    timestamp as Float
    data_updates as Dictionary[String, Any]
    style_updates as Dictionary[String, Any]

Note: High-Level Plotting Functions

Process called "create_line_plot" that takes x_data as List[Any] and y_data as List[Any] and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create line plot with customizable styling and interactivity
    Try:
        Let plot_config be config if config is not None else create_default_plot_config
        Let validation_result be validate_plot_data with x_data as x_data and y_data as y_data
        
        If not validation_result:
            Return PlotError with:
                error as DataValidationError with:
                    message as "Invalid data for line plot"
                    x_length as length of x_data
                    y_length as length of y_data
                context as Dictionary with "plot_type" as "line_plot"
        
        Let plot_data be PlotData with:
            x_values as x_data
            y_values as y_data
            labels as None
            colors as None
            sizes as None
            metadata as Dictionary with "interpolation" as "linear"
        
        Let line_plot_result be create_plot_object with:
            plot_type as PlotType.line_plot
            data as plot_data
            config as plot_config
        
        Match line_plot_result:
            When PlotCreationSuccess with plot as created_plot:
                Let svg_result be render_line_plot_svg with plot as created_plot
                Match svg_result:
                    When SvgRenderSuccess with svg as svg_content:
                        Set created_plot.svg_content to svg_content
                        Return PlotSuccess with:
                            plot_object as created_plot
                            metadata as Dictionary with:
                                "render_time_ms" as get_current_time_milliseconds
                                "data_points" as length of x_data
                    When SvgRenderError:
                        Return PlotError with:
                            error as RenderingError with message as "Failed to render line plot"
                            context as Dictionary with "plot_type" as "line_plot"
            
            When PlotCreationError with error as creation_error:
                Return PlotError with:
                    error as creation_error
                    context as Dictionary with "plot_type" as "line_plot"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in line plot creation"
                original_error as error
            context as Dictionary with "plot_type" as "line_plot"

Process called "create_scatter_plot" that takes x_data as List[Any] and y_data as List[Any] and sizes as Optional[List[Float]] and colors as Optional[List[String]] and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create scatter plot with variable point sizes and colors
    Try:
        Let plot_config be config if config is not None else create_default_plot_config
        Let validation_result be validate_plot_data with x_data as x_data and y_data as y_data
        
        If not validation_result:
            Return PlotError with:
                error as DataValidationError with:
                    message as "Invalid data for scatter plot"
                    x_length as length of x_data
                    y_length as length of y_data
                context as Dictionary with "plot_type" as "scatter_plot"
        
        Let plot_data be PlotData with:
            x_values as x_data
            y_values as y_data
            labels as None
            colors as colors
            sizes as sizes if sizes is not None else generate_default_sizes with count as length of x_data
            metadata as Dictionary with:
                "point_style" as "circle"
                "alpha" as 0.7
        
        Let scatter_plot_result be create_plot_object with:
            plot_type as PlotType.scatter_plot
            data as plot_data
            config as plot_config
        
        Match scatter_plot_result:
            When PlotCreationSuccess with plot as created_plot:
                Let svg_result be render_scatter_plot_svg with plot as created_plot
                Match svg_result:
                    When SvgRenderSuccess with svg as svg_content:
                        Set created_plot.svg_content to svg_content
                        
                        Note: Add interactive elements for data exploration
                        Let interactive_elements be create_scatter_interactive_elements with plot as created_plot
                        Set created_plot.interactive_elements to interactive_elements
                        
                        Return PlotSuccess with:
                            plot_object as created_plot
                            metadata as Dictionary with:
                                "render_time_ms" as get_current_time_milliseconds
                                "data_points" as length of x_data
                                "interactive" as plot_config.interactive
                    When SvgRenderError:
                        Return PlotError with:
                            error as RenderingError with message as "Failed to render scatter plot"
                            context as Dictionary with "plot_type" as "scatter_plot"
            
            When PlotCreationError with error as creation_error:
                Return PlotError with:
                    error as creation_error
                    context as Dictionary with "plot_type" as "scatter_plot"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in scatter plot creation"
                original_error as error
            context as Dictionary with "plot_type" as "scatter_plot"

Process called "create_bar_plot" that takes categories as List[String] and values as List[Float] and orientation as Optional[String] and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create bar plot with horizontal or vertical orientation
    Try:
        Let plot_config be config if config is not None else create_default_plot_config
        Let bar_orientation be orientation if orientation is not None else "vertical"
        
        If length of categories is not equal to length of values:
            Return PlotError with:
                error as DataValidationError with:
                    message as "Categories and values must have same length"
                    categories_length as length of categories
                    values_length as length of values
                context as Dictionary with "plot_type" as "bar_plot"
        
        Let plot_data be PlotData with:
            x_values as categories as List[Any]
            y_values as values as List[Any]
            labels as categories
            colors as generate_bar_colors with count as length of categories and scheme as plot_config.color_scheme
            sizes as None
            metadata as Dictionary with:
                "orientation" as bar_orientation
                "bar_width" as 0.8
        
        Let bar_plot_result be create_plot_object with:
            plot_type as PlotType.bar_plot
            data as plot_data
            config as plot_config
        
        Match bar_plot_result:
            When PlotCreationSuccess with plot as created_plot:
                Let svg_result be render_bar_plot_svg with plot as created_plot
                Match svg_result:
                    When SvgRenderSuccess with svg as svg_content:
                        Set created_plot.svg_content to svg_content
                        Return PlotSuccess with:
                            plot_object as created_plot
                            metadata as Dictionary with:
                                "render_time_ms" as get_current_time_milliseconds
                                "categories" as length of categories
                                "orientation" as bar_orientation
                    When SvgRenderError:
                        Return PlotError with:
                            error as RenderingError with message as "Failed to render bar plot"
                            context as Dictionary with "plot_type" as "bar_plot"
            
            When PlotCreationError with error as creation_error:
                Return PlotError with:
                    error as creation_error
                    context as Dictionary with "plot_type" as "bar_plot"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in bar plot creation"
                original_error as error
            context as Dictionary with "plot_type" as "bar_plot"

Process called "create_histogram" that takes data as List[Float] and bins as Optional[Integer] and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create histogram with automatic or manual binning
    Try:
        Let plot_config be config if config is not None else create_default_plot_config
        Let num_bins be bins if bins is not None else calculate_optimal_bins with data as data
        
        If length of data is equal to 0:
            Return PlotError with:
                error as DataValidationError with:
                    message as "Cannot create histogram from empty data"
                    data_length as 0
                context as Dictionary with "plot_type" as "histogram"
        
        Let histogram_result be calculate_histogram_bins with data as data and num_bins as num_bins
        Match histogram_result:
            When HistogramSuccess with bins as bin_edges and counts as bin_counts:
                Let plot_data be PlotData with:
                    x_values as bin_edges
                    y_values as bin_counts as List[Any]
                    labels as generate_bin_labels with edges as bin_edges
                    colors as generate_histogram_colors with count as length of bin_counts and scheme as plot_config.color_scheme
                    sizes as None
                    metadata as Dictionary with:
                        "bin_width" as calculate_bin_width with edges as bin_edges
                        "total_count" as calculate_total_count with counts as bin_counts
                
                Let hist_plot_result be create_plot_object with:
                    plot_type as PlotType.histogram
                    data as plot_data
                    config as plot_config
                
                Match hist_plot_result:
                    When PlotCreationSuccess with plot as created_plot:
                        Let svg_result be render_histogram_svg with plot as created_plot
                        Match svg_result:
                            When SvgRenderSuccess with svg as svg_content:
                                Set created_plot.svg_content to svg_content
                                Return PlotSuccess with:
                                    plot_object as created_plot
                                    metadata as Dictionary with:
                                        "render_time_ms" as get_current_time_milliseconds
                                        "data_points" as length of data
                                        "bins" as num_bins
                            When SvgRenderError:
                                Return PlotError with:
                                    error as RenderingError with message as "Failed to render histogram"
                                    context as Dictionary with "plot_type" as "histogram"
                    
                    When PlotCreationError with error as creation_error:
                        Return PlotError with:
                            error as creation_error
                            context as Dictionary with "plot_type" as "histogram"
            
            When HistogramError with error as hist_error:
                Return PlotError with:
                    error as hist_error
                    context as Dictionary with "plot_type" as "histogram"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in histogram creation"
                original_error as error
            context as Dictionary with "plot_type" as "histogram"

Process called "create_heatmap" that takes data_matrix as List[List[Float]] and row_labels as Optional[List[String]] and column_labels as Optional[List[String]] and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create heatmap from 2D data matrix with optional labels
    Try:
        Let plot_config be config if config is not None else create_default_plot_config
        
        If length of data_matrix is equal to 0:
            Return PlotError with:
                error as DataValidationError with:
                    message as "Cannot create heatmap from empty matrix"
                    matrix_rows as 0
                    matrix_cols as 0
                context as Dictionary with "plot_type" as "heatmap"
        
        Let matrix_dims be validate_matrix_dimensions with matrix as data_matrix
        If not matrix_dims["is_valid"] as Boolean:
            Return PlotError with:
                error as DataValidationError with:
                    message as "Matrix must have consistent row lengths"
                    matrix_validation as matrix_dims
                context as Dictionary with "plot_type" as "heatmap"
        
        Let num_rows be matrix_dims["rows"] as Integer
        Let num_cols be matrix_dims["cols"] as Integer
        
        Let heatmap_data be prepare_heatmap_data with:
            matrix as data_matrix
            row_labels as row_labels if row_labels is not None else generate_row_labels with count as num_rows
            col_labels as column_labels if column_labels is not None else generate_column_labels with count as num_cols
        
        Let plot_data be PlotData with:
            x_values as heatmap_data["column_positions"] as List[Any]
            y_values as heatmap_data["row_positions"] as List[Any]
            labels as heatmap_data["cell_labels"] as List[String]
            colors as generate_heatmap_colors with:
                values as heatmap_data["flattened_values"] as List[Float]
                scheme as plot_config.color_scheme
            sizes as None
            metadata as Dictionary with:
                "matrix_shape" as list containing num_rows, num_cols
                "value_range" as calculate_value_range with values as heatmap_data["flattened_values"] as List[Float]
                "color_normalization" as "min_max"
        
        Let heatmap_plot_result be create_plot_object with:
            plot_type as PlotType.heatmap
            data as plot_data
            config as plot_config
        
        Match heatmap_plot_result:
            When PlotCreationSuccess with plot as created_plot:
                Let svg_result be render_heatmap_svg with plot as created_plot
                Match svg_result:
                    When SvgRenderSuccess with svg as svg_content:
                        Set created_plot.svg_content to svg_content
                        
                        Note: Add interactive elements for value inspection
                        Let interactive_elements be create_heatmap_interactive_elements with plot as created_plot
                        Set created_plot.interactive_elements to interactive_elements
                        
                        Return PlotSuccess with:
                            plot_object as created_plot
                            metadata as Dictionary with:
                                "render_time_ms" as get_current_time_milliseconds
                                "matrix_cells" as num_rows times num_cols
                                "interactive" as plot_config.interactive
                    When SvgRenderError:
                        Return PlotError with:
                            error as RenderingError with message as "Failed to render heatmap"
                            context as Dictionary with "plot_type" as "heatmap"
            
            When PlotCreationError with error as creation_error:
                Return PlotError with:
                    error as creation_error
                    context as Dictionary with "plot_type" as "heatmap"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in heatmap creation"
                original_error as error
            context as Dictionary with "plot_type" as "heatmap"

Note: Statistical Plotting Functions

Process called "create_box_plot" that takes data_groups as List[List[Float]] and group_labels as Optional[List[String]] and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create box plot showing distribution statistics for multiple groups
    Try:
        Let plot_config be config if config is not None else create_default_plot_config
        
        If length of data_groups is equal to 0:
            Return PlotError with:
                error as DataValidationError with:
                    message as "Cannot create box plot from empty data groups"
                    groups_count as 0
                context as Dictionary with "plot_type" as "box_plot"
        
        Let box_statistics be empty list
        Let group_names be group_labels if group_labels is not None else generate_group_labels with count as length of data_groups
        
        For each group_data in data_groups:
            If length of group_data is less than 5:
                Add create_minimal_box_stats with data as group_data to box_statistics
            Otherwise:
                Let stats_result be calculate_box_plot_statistics with data as group_data
                Match stats_result:
                    When StatisticsSuccess with stats as calculated_stats:
                        Add calculated_stats to box_statistics
                    When StatisticsError:
                        Add create_minimal_box_stats with data as group_data to box_statistics
        
        Let plot_data be PlotData with:
            x_values as group_names as List[Any]
            y_values as box_statistics as List[Any]
            labels as group_names
            colors as generate_box_plot_colors with count as length of data_groups and scheme as plot_config.color_scheme
            sizes as None
            metadata as Dictionary with:
                "show_outliers" as true
                "box_width" as 0.6
                "whisker_range" as 1.5
        
        Let box_plot_result be create_plot_object with:
            plot_type as PlotType.box_plot
            data as plot_data
            config as plot_config
        
        Match box_plot_result:
            When PlotCreationSuccess with plot as created_plot:
                Let svg_result be render_box_plot_svg with plot as created_plot
                Match svg_result:
                    When SvgRenderSuccess with svg as svg_content:
                        Set created_plot.svg_content to svg_content
                        Return PlotSuccess with:
                            plot_object as created_plot
                            metadata as Dictionary with:
                                "render_time_ms" as get_current_time_milliseconds
                                "groups" as length of data_groups
                                "total_data_points" as calculate_total_data_points with groups as data_groups
                    When SvgRenderError:
                        Return PlotError with:
                            error as RenderingError with message as "Failed to render box plot"
                            context as Dictionary with "plot_type" as "box_plot"
            
            When PlotCreationError with error as creation_error:
                Return PlotError with:
                    error as creation_error
                    context as Dictionary with "plot_type" as "box_plot"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in box plot creation"
                original_error as error
            context as Dictionary with "plot_type" as "box_plot"

Process called "create_violin_plot" that takes data_groups as List[List[Float]] and group_labels as Optional[List[String]] and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create violin plot showing distribution density for multiple groups
    Try:
        Let plot_config be config if config is not None else create_default_plot_config
        
        If length of data_groups is equal to 0:
            Return PlotError with:
                error as DataValidationError with:
                    message as "Cannot create violin plot from empty data groups"
                    groups_count as 0
                context as Dictionary with "plot_type" as "violin_plot"
        
        Let density_estimates be empty list
        Let group_names be group_labels if group_labels is not None else generate_group_labels with count as length of data_groups
        
        For each group_data in data_groups:
            If length of group_data is less than 3:
                Add create_minimal_density_estimate with data as group_data to density_estimates
            Otherwise:
                Let density_result be calculate_kernel_density_estimate with data as group_data
                Match density_result:
                    When DensitySuccess with density as calculated_density:
                        Add calculated_density to density_estimates
                    When DensityError:
                        Add create_minimal_density_estimate with data as group_data to density_estimates
        
        Let plot_data be PlotData with:
            x_values as group_names as List[Any]
            y_values as density_estimates as List[Any]
            labels as group_names
            colors as generate_violin_plot_colors with count as length of data_groups and scheme as plot_config.color_scheme
            sizes as None
            metadata as Dictionary with:
                "show_box_plot" as true
                "violin_width" as 0.8
                "kernel_bandwidth" as "auto"
        
        Let violin_plot_result be create_plot_object with:
            plot_type as PlotType.violin_plot
            data as plot_data
            config as plot_config
        
        Match violin_plot_result:
            When PlotCreationSuccess with plot as created_plot:
                Let svg_result be render_violin_plot_svg with plot as created_plot
                Match svg_result:
                    When SvgRenderSuccess with svg as svg_content:
                        Set created_plot.svg_content to svg_content
                        Return PlotSuccess with:
                            plot_object as created_plot
                            metadata as Dictionary with:
                                "render_time_ms" as get_current_time_milliseconds
                                "groups" as length of data_groups
                                "total_data_points" as calculate_total_data_points with groups as data_groups
                    When SvgRenderError:
                        Return PlotError with:
                            error as RenderingError with message as "Failed to render violin plot"
                            context as Dictionary with "plot_type" as "violin_plot"
            
            When PlotCreationError with error as creation_error:
                Return PlotError with:
                    error as creation_error
                    context as Dictionary with "plot_type" as "violin_plot"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in violin plot creation"
                original_error as error
            context as Dictionary with "plot_type" as "violin_plot"

Note: DataFrame Integration Functions

Process called "dataframe_plot" that takes df as df_core.DataFrame and x as Optional[String] and y as Optional[String] and kind as Optional[String] and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create plot directly from DataFrame columns
    Try:
        Let plot_type be kind if kind is not None else "line"
        Let plot_config be config if config is not None else create_default_plot_config
        
        Note: Extract data from DataFrame based on column specifications
        Let data_extraction_result be extract_dataframe_plot_data with:
            df as df
            x_column as x
            y_column as y
            plot_type as plot_type
        
        Match data_extraction_result:
            When DataExtractionSuccess with x_data as x_values and y_data as y_values and metadata as extraction_metadata:
                Match plot_type:
                    When "line":
                        Return create_line_plot with x_data as x_values and y_data as y_values and config as plot_config
                    
                    When "scatter":
                        Return create_scatter_plot with x_data as x_values and y_data as y_values and sizes as None and colors as None and config as plot_config
                    
                    When "bar":
                        Let categories be convert_to_string_list with data as x_values
                        Let values be convert_to_float_list with data as y_values
                        Return create_bar_plot with categories as categories and values as values and orientation as None and config as plot_config
                    
                    When "hist":
                        If y is None:
                            Let numeric_data be convert_to_float_list with data as x_values
                            Return create_histogram with data as numeric_data and bins as None and config as plot_config
                        Otherwise:
                            Let numeric_data be convert_to_float_list with data as y_values
                            Return create_histogram with data as numeric_data and bins as None and config as plot_config
                    
                    Otherwise:
                        Return PlotError with:
                            error as UnsupportedPlotTypeError with:
                                message as "Unsupported plot type for DataFrame plotting"
                                requested_type as plot_type
                                supported_types as list containing "line", "scatter", "bar", "hist"
                            context as Dictionary with "source" as "dataframe_plot"
            
            When DataExtractionError with error as extraction_error:
                Return PlotError with:
                    error as extraction_error
                    context as Dictionary with "source" as "dataframe_plot"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in DataFrame plotting"
                original_error as error
            context as Dictionary with "source" as "dataframe_plot"

Process called "dataframe_correlation_heatmap" that takes df as df_core.DataFrame and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create correlation heatmap from DataFrame numeric columns
    Try:
        Let plot_config be config if config is not None else create_default_plot_config
        
        Let numeric_columns be extract_numeric_columns_from_dataframe with df as df
        If length of numeric_columns is less than 2:
            Return PlotError with:
                error as InsufficientDataError with:
                    message as "Need at least 2 numeric columns for correlation heatmap"
                    numeric_columns_count as length of numeric_columns
                context as Dictionary with "source" as "correlation_heatmap"
        
        Let correlation_result be stats_core.correlation_analysis with:
            variables as extract_numeric_column_data with df as df and columns as numeric_columns
            variable_names as numeric_columns
            method as "pearson"
        
        Match correlation_result:
            When stats_core.AnalysisSuccess with data as correlation_matrix:
                Let matrix_data be convert_correlation_matrix_to_2d_array with matrix as correlation_matrix
                Return create_heatmap with:
                    data_matrix as matrix_data
                    row_labels as Some with value as numeric_columns
                    column_labels as Some with value as numeric_columns
                    config as plot_config
            
            When stats_core.AnalysisError with error as correlation_error:
                Return PlotError with:
                    error as correlation_error
                    context as Dictionary with "source" as "correlation_heatmap"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in correlation heatmap creation"
                original_error as error
            context as Dictionary with "source" as "correlation_heatmap"

Note: Plot Configuration and Theming

Process called "create_default_plot_config" returns PlotConfiguration:
    Note: Create default plot configuration with standard styling
    Return PlotConfiguration with:
        title as None
        x_label as None
        y_label as None
        width as 800
        height as 600
        theme as create_default_theme
        color_scheme as ColorScheme.viridis
        backend as ChartBackend.svg_backend
        interactive as true
        show_grid as true
        show_legend as true

Process called "create_default_theme" returns PlotTheme:
    Note: Create default plot theme with professional styling
    Return PlotTheme with:
        background_color as "#ffffff"
        grid_color as "#e0e0e0"
        axis_color as "#333333"
        text_color as "#333333"
        line_width as 2.0
        font_family as "Arial, sans-serif"
        font_size as 12

Process called "create_dark_theme" returns PlotTheme:
    Note: Create dark plot theme for presentations and dashboards
    Return PlotTheme with:
        background_color as "#2e2e2e"
        grid_color as "#555555"
        axis_color as "#cccccc"
        text_color as "#ffffff"
        line_width as 2.0
        font_family as "Arial, sans-serif"
        font_size as 12

Process called "create_minimal_theme" returns PlotTheme:
    Note: Create minimal plot theme with reduced visual elements
    Return PlotTheme with:
        background_color as "#ffffff"
        grid_color as "#f5f5f5"
        axis_color as "#666666"
        text_color as "#333333"
        line_width as 1.5
        font_family as "Arial, sans-serif"
        font_size as 11

Note: Color Generation Functions

Process called "generate_color_palette" that takes scheme as ColorScheme and count as Integer returns List[String]:
    Note: Generate color palette based on scheme and number of colors needed
    Try:
        Match scheme:
            When ColorScheme.viridis:
                Return generate_viridis_colors with count as count
            
            When ColorScheme.plasma:
                Return generate_plasma_colors with count as count
            
            When ColorScheme.blues:
                Return generate_blues_colors with count as count
            
            When ColorScheme.greens:
                Return generate_greens_colors with count as count
            
            When ColorScheme.reds:
                Return generate_reds_colors with count as count
            
            When ColorScheme.grayscale:
                Return generate_grayscale_colors with count as count
            
            When ColorScheme.rainbow:
                Return generate_rainbow_colors with count as count
            
            When ColorScheme.custom:
                Return generate_default_categorical_colors with count as count
            
            Otherwise:
                Return generate_default_categorical_colors with count as count
    
    Catch error:
        Return generate_default_categorical_colors with count as count

Process called "generate_viridis_colors" that takes count as Integer returns List[String]:
    Note: Generate colors from viridis color scheme
    Try:
        Let viridis_base be list containing "#440154", "#31688e", "#35b779", "#fde725"
        Return interpolate_color_palette with base_colors as viridis_base and target_count as count
    
    Catch error:
        Return generate_default_categorical_colors with count as count

Process called "generate_plasma_colors" that takes count as Integer returns List[String]:
    Note: Generate colors from plasma color scheme
    Try:
        Let plasma_base be list containing "#0d0887", "#7e03a8", "#cc4778", "#f89441", "#f0f921"
        Return interpolate_color_palette with base_colors as plasma_base and target_count as count
    
    Catch error:
        Return generate_default_categorical_colors with count as count

Process called "generate_blues_colors" that takes count as Integer returns List[String]:
    Note: Generate blue color gradient
    Try:
        Let blues_base be list containing "#f7fbff", "#4292c6", "#08519c", "#08306b"
        Return interpolate_color_palette with base_colors as blues_base and target_count as count
    
    Catch error:
        Return generate_default_categorical_colors with count as count

Process called "generate_default_categorical_colors" that takes count as Integer returns List[String]:
    Note: Generate default categorical color palette
    Try:
        Let base_colors be list containing:
            "#1f77b4", "#ff7f0e", "#2ca02c", "#d62728", "#9467bd", 
            "#8c564b", "#e377c2", "#7f7f7f", "#bcbd22", "#17becf"
        
        If count is less than or equal to length of base_colors:
            Return take_first_n_elements with list as base_colors and n as count
        Otherwise:
            Return cycle_colors_to_count with base_colors as base_colors and target_count as count
    
    Catch error:
        Return list containing "#1f77b4"

Note: SVG Rendering Functions

Process called "render_line_plot_svg" that takes plot as Plot returns Union[SvgRenderSuccess, SvgRenderError]:
    Note: Render line plot as SVG with interactive elements
    Try:
        Let svg_builder be create_svg_builder with:
            width as plot.config.width
            height as plot.config.height
            theme as plot.config.theme
        
        Note: Add background and grid
        Let background_svg be render_plot_background with builder as svg_builder and config as plot.config
        Let grid_svg be render_plot_grid with builder as svg_builder and config as plot.config
        
        Let scales_result be calculate_plot_scales with:
            x_data as plot.data.x_values
            y_data as plot.data.y_values
            width as plot.config.width
            height as plot.config.height
        
        Match scales_result:
            When ScaleCalculationSuccess with x_scale as x_scale_func and y_scale as y_scale_func:
                Note: Generate path for line plot
                Let line_path be generate_line_path with:
                    x_data as plot.data.x_values
                    y_data as plot.data.y_values
                    x_scale as x_scale_func
                    y_scale as y_scale_func
                
                Let line_svg be create_svg_path_element with:
                    path_data as line_path
                    stroke_color as get_primary_color_from_scheme with scheme as plot.config.color_scheme
                    stroke_width as plot.config.theme.line_width
                    fill as "none"
                
                Note: Add axes and labels
                Let axes_svg be render_plot_axes with:
                    builder as svg_builder
                    x_scale as x_scale_func
                    y_scale as y_scale_func
                    config as plot.config
                
                Let complete_svg be combine_svg_elements with elements as list containing:
                    background_svg, grid_svg, line_svg, axes_svg
                
                Return SvgRenderSuccess with svg as complete_svg
            
            When ScaleCalculationError with error as scale_error:
                Return SvgRenderError with error as scale_error
    
    Catch error:
        Return SvgRenderError with error as SvgRenderingError with:
            message as "Failed to render line plot SVG"
            original_error as error

Process called "render_scatter_plot_svg" that takes plot as Plot returns Union[SvgRenderSuccess, SvgRenderError]:
    Note: Render scatter plot as SVG with variable point sizes and colors
    Try:
        Let svg_builder be create_svg_builder with:
            width as plot.config.width
            height as plot.config.height
            theme as plot.config.theme
        
        Let background_svg be render_plot_background with builder as svg_builder and config as plot.config
        Let grid_svg be render_plot_grid with builder as svg_builder and config as plot.config
        
        Let scales_result be calculate_plot_scales with:
            x_data as plot.data.x_values
            y_data as plot.data.y_values
            width as plot.config.width
            height as plot.config.height
        
        Match scales_result:
            When ScaleCalculationSuccess with x_scale as x_scale_func and y_scale as y_scale_func:
                Let points_svg be empty list
                Let point_colors be plot.data.colors if plot.data.colors is not None else generate_color_palette with scheme as plot.config.color_scheme and count as length of plot.data.x_values
                Let point_sizes be plot.data.sizes if plot.data.sizes is not None else generate_default_sizes with count as length of plot.data.x_values
                
                For i from 0 to (length of plot.data.x_values minus 1):
                    Let x_pos be apply_scale_function with scale as x_scale_func and value as plot.data.x_values at index i
                    Let y_pos be apply_scale_function with scale as y_scale_func and value as plot.data.y_values at index i
                    
                    Let point_svg be create_svg_circle_element with:
                        cx as x_pos
                        cy as y_pos
                        radius as point_sizes at index i
                        fill_color as point_colors at index i
                        stroke_color as "#ffffff"
                        stroke_width as 1.0
                    
                    Add point_svg to points_svg
                
                Let axes_svg be render_plot_axes with:
                    builder as svg_builder
                    x_scale as x_scale_func
                    y_scale as y_scale_func
                    config as plot.config
                
                Let complete_svg be combine_svg_elements with elements as list containing:
                    background_svg, grid_svg, combine_svg_list with list as points_svg, axes_svg
                
                Return SvgRenderSuccess with svg as complete_svg
            
            When ScaleCalculationError with error as scale_error:
                Return SvgRenderError with error as scale_error
    
    Catch error:
        Return SvgRenderError with error as SvgRenderingError with:
            message as "Failed to render scatter plot SVG"
            original_error as error

Note: Utility Functions

Process called "validate_plot_data" that takes x_data as List[Any] and y_data as List[Any] returns Boolean:
    Note: Validate that plot data is suitable for visualization
    Try:
        If length of x_data is equal to 0 or length of y_data is equal to 0:
            Return false
        
        If length of x_data is not equal to length of y_data:
            Return false
        
        Return true
    
    Catch error:
        Return false

Process called "calculate_optimal_bins" that takes data as List[Float] returns Integer:
    Note: Calculate optimal number of bins for histogram using Sturges' rule
    Try:
        If length of data is less than 2:
            Return 1
        
        Let n be length of data as Float
        Let optimal_bins be calculate_ceiling with value as (calculate_log2 with number as n) plus 1.0
        
        Let min_bins be 5
        Let max_bins be 50
        
        If optimal_bins is less than min_bins:
            Return min_bins
        
        If optimal_bins is greater than max_bins:
            Return max_bins
        
        Return optimal_bins as Integer
    
    Catch error:
        Return 10

Process called "calculate_log2" that takes number as Float returns Float:
    Note: Calculate base-2 logarithm using natural logarithm
    Try:
        If number is less than or equal to 0.0:
            Return 0.0
        
        Let natural_log be calculate_natural_log with value as number
        Let log2_value be natural_log divided by 0.693147  Note: ln(2) ≈ 0.693147
        
        Return log2_value
    
    Catch error:
        Return 0.0

Process called "calculate_natural_log" that takes value as Float returns Float:
    Note: Calculate natural logarithm using Taylor series approximation
    Try:
        If value is less than or equal to 0.0:
            Return 0.0
        
        If value is equal to 1.0:
            Return 0.0
        
        Note: Use Taylor series around 1: ln(1+x) = x - x²/2 + x³/3 - x⁴/4 + ...
        Let x be value minus 1.0
        
        If calculate_absolute_value with number as x is greater than 0.5:
            Note: For values far from 1, use different approach
            Return approximate_natural_log_iterative with value as value
        
        Let result be 0.0
        Let term be x
        Let sign be 1.0
        
        For n from 1 to 20:
            Set result to result plus (sign times term divided by (n as Float))
            Set term to term times x
            Set sign to sign times (-1.0)
            
            If calculate_absolute_value with number as term is less than 0.000001:
                Break
        
        Return result
    
    Catch error:
        Return 0.0

Process called "calculate_ceiling" that takes value as Float returns Integer:
    Note: Calculate ceiling (smallest integer greater than or equal to value)
    Try:
        Let integer_part be value as Integer
        
        If value is equal to (integer_part as Float):
            Return integer_part
        
        If value is greater than 0.0:
            Return integer_part plus 1
        Otherwise:
            Return integer_part
    
    Catch error:
        Return 0

Process called "calculate_absolute_value" that takes number as Float returns Float:
    Note: Calculate absolute value of a number
    If number is greater than or equal to 0.0:
        Return number
    Otherwise:
        Return number times (-1.0)

Process called "approximate_natural_log_iterative" that takes value as Float returns Float:
    Note: Approximate natural logarithm using simple algorithm
    Try:
        If value is less than or equal to 0.0:
            Return 0.0
        
        If value is equal to 1.0:
            Return 0.0
        
        Note: Use simple iterative approximation for ln(x)
        Let result be 0.0
        Let x be value
        
        Note: Reduce x to range [0.5, 1.5] by counting powers of 2
        Let power_of_2_count be 0
        While x is greater than 1.5:
            Set x to x divided by 2.0
            Set power_of_2_count to power_of_2_count plus 1
        
        While x is less than 0.5:
            Set x to x times 2.0
            Set power_of_2_count to power_of_2_count minus 1
        
        Note: Use Taylor series for ln(1 + (x-1))
        Let t be x minus 1.0
        Let term be t
        Let sign be 1.0
        
        For n from 1 to 10:
            Set result to result plus (sign times term divided by (n as Float))
            Set term to term times t
            Set sign to sign times (-1.0)
        
        Note: Add back the ln(2) terms
        Let ln_2 be 0.693147  Note: Approximation of ln(2)
        Set result to result plus ((power_of_2_count as Float) times ln_2)
        
        Return result
    
    Catch error:
        Return 0.0

Process called "create_plot_object" that takes plot_type as PlotType and data as PlotData and config as PlotConfiguration returns Union[PlotCreationSuccess, PlotCreationError]:
    Note: Create plot object with validation and initialization
    Try:
        Let plot_id be generate_unique_plot_id
        
        Let plot_object be Plot with:
            plot_id as plot_id
            plot_type as plot_type
            data as data
            config as config
            svg_content as None
            interactive_elements as empty list
            animation_frames as None
        
        Return PlotCreationSuccess with plot as plot_object
    
    Catch error:
        Return PlotCreationError with error as PlotObjectCreationError with:
            message as "Failed to create plot object"
            original_error as error

Process called "generate_unique_plot_id" returns String:
    Note: Generate unique identifier for plot object
    Try:
        Let timestamp be get_current_time_milliseconds as String
        Let random_suffix be generate_random_string with length as 6
        Return "plot_" plus timestamp plus "_" plus random_suffix
    
    Catch error:
        Return "plot_default"

Process called "generate_random_string" that takes length as Integer returns String:
    Note: Generate random alphanumeric string of specified length
    Try:
        Let chars be "abcdefghijklmnopqrstuvwxyz0123456789"
        Let result be ""
        
        For i from 1 to length:
            Let random_index be generate_random_integer with max as (length of chars minus 1)
            Let random_char be chars at index random_index
            Set result to result plus random_char
        
        Return result
    
    Catch error:
        Return "random"

Process called "generate_random_integer" that takes max as Integer returns Integer:
    Note: Generate random integer between 0 and max (inclusive)
    Try:
        Note: Simplified random number generation - production would use proper PRNG
        Let current_time be get_current_time_milliseconds
        Let pseudo_random be (current_time times 1103515245 plus 12345) mod 2147483647
        Return pseudo_random mod (max plus 1)
    
    Catch error:
        Return 0

Process called "get_current_time_milliseconds" returns Integer:
    Note: Get current time in milliseconds since epoch
    Try:
        Note: This would interface with system clock to get actual time
        Note: For deterministic behavior, we use a counter-based approach
        Let base_time be 1640995200000  Note: Base timestamp (Jan 1, 2022)
        Let incremental_time be get_incremental_counter
        Return base_time plus incremental_time
    
    Catch error:
        Return 1640995200000

Note: Export and Save Functions

Process called "save_plot_as_svg" that takes plot as Plot and file_path as String returns Boolean:
    Note: Save plot as SVG file to specified path
    Try:
        If plot.svg_content is None:
            Return false
        
        Let svg_content be plot.svg_content as String
        Let write_result be write_text_file with path as file_path and content as svg_content
        
        Return write_result
    
    Catch error:
        Return false

Process called "save_plot_as_png" that takes plot as Plot and file_path as String and width as Optional[Integer] and height as Optional[Integer] returns Boolean:
    Note: Convert SVG plot to PNG and save to file
    Try:
        If plot.svg_content is None:
            Return false
        
        Let target_width be width if width is not None else plot.config.width
        Let target_height be height if height is not None else plot.config.height
        
        Note: Create PNG header and basic structure
        Let png_data be create_basic_png_data with 
            width as target_width 
            and height as target_height 
            and svg_content as plot.svg_content as String
        
        Let write_result be write_binary_file with path as file_path and data as png_data
        Return write_result
    
    Catch error:
        Return false

Process called "export_plot_data_as_csv" that takes plot as Plot and file_path as String returns Boolean:
    Note: Export plot data as CSV file for external analysis
    Try:
        Let csv_content be convert_plot_data_to_csv with data as plot.data
        Let write_result be write_text_file with path as file_path and content as csv_content
        
        Return write_result
    
    Catch error:
        Return false

Process called "convert_plot_data_to_csv" that takes data as PlotData returns String:
    Note: Convert plot data to CSV format string
    Try:
        Let csv_lines be empty list
        
        Note: Create header
        Add "x,y" to csv_lines
        
        Note: Add data rows
        For i from 0 to (length of data.x_values minus 1):
            Let x_val be data.x_values at index i as String
            Let y_val be data.y_values at index i as String
            Let csv_row be x_val plus "," plus y_val
            Add csv_row to csv_lines
        
        Return join_strings with strings as csv_lines and separator as "\n"
    
    Catch error:
        Return ""

Process called "write_text_file" that takes path as String and content as String returns Boolean:
    Note: Write text content to file at specified path
    Try:
        Note: Validate file path and content
        If length of path is equal to 0:
            Return false
        
        If content is None:
            Return false
        
        Note: Create file operation record
        Let file_operation be Dictionary with:
            "operation" as "write"
            "path" as path
            "content_length" as length of content
            "timestamp" as get_current_time_milliseconds
        
        Note: In a real implementation, this would write to file system
        Note: For now, simulate successful write for valid inputs
        Let operation_successful be simulate_file_write with operation as file_operation
        Return operation_successful
    
    Catch error:
        Return false

Process called "join_strings" that takes strings as List[String] and separator as String returns String:
    Note: Join list of strings with specified separator
    Try:
        If length of strings is equal to 0:
            Return ""
        
        If length of strings is equal to 1:
            Return strings at index 0
        
        Let result be strings at index 0
        
        For i from 1 to (length of strings minus 1):
            Set result to result plus separator plus (strings at index i)
        
        Return result
    
    Catch error:
        Return ""

Note: Interactive Visualization Functions

Process called "create_interactive_plot" that takes plot_type as PlotType and data as PlotData and config as PlotConfiguration returns VisualizationResult:
    Note: Create interactive plot with zoom, pan, and selection capabilities
    Try:
        Let interactive_config be config
        Set interactive_config.interactive to true
        Set interactive_config.backend to ChartBackend.webgl_backend
        
        Match plot_type:
            When PlotType.scatter_plot:
                Let scatter_result be create_scatter_plot with:
                    x_data as data.x_values
                    y_data as data.y_values
                    sizes as data.sizes
                    colors as data.colors
                    config as interactive_config
                
                Match scatter_result:
                    When PlotSuccess with plot_object as scatter_plot and metadata as plot_metadata:
                        Let enhanced_plot be add_interactive_features with plot as scatter_plot
                        Return PlotSuccess with:
                            plot_object as enhanced_plot
                            metadata as plot_metadata
                    When PlotError:
                        Return scatter_result
            
            When PlotType.line_plot:
                Let line_result be create_line_plot with:
                    x_data as data.x_values
                    y_data as data.y_values
                    config as interactive_config
                
                Match line_result:
                    When PlotSuccess with plot_object as line_plot and metadata as plot_metadata:
                        Let enhanced_plot be add_interactive_features with plot as line_plot
                        Return PlotSuccess with:
                            plot_object as enhanced_plot
                            metadata as plot_metadata
                    When PlotError:
                        Return line_result
            
            Otherwise:
                Return PlotError with:
                    error as UnsupportedFeatureError with:
                        message as "Interactive mode not supported for this plot type"
                        plot_type as plot_type as String
                    context as Dictionary with "feature" as "interactive"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in interactive plot creation"
                original_error as error
            context as Dictionary with "feature" as "interactive"

Process called "add_interactive_features" that takes plot as Plot returns Plot:
    Note: Add interactive elements like zoom, pan, and data point selection
    Try:
        Let enhanced_plot be plot
        
        Note: Add zoom and pan controls
        Let zoom_control be InteractiveElement with:
            element_id as "zoom_control"
            element_type as "zoom_pan"
            position as Dictionary with "x" as 10.0 and "y" as 10.0
            properties as Dictionary with:
                "zoom_factor" as 1.0
                "pan_x" as 0.0
                "pan_y" as 0.0
            event_handlers as Dictionary with:
                "wheel" as "handleZoom"
                "mousedown" as "startPan"
                "mousemove" as "handlePan"
                "mouseup" as "endPan"
        
        Add zoom_control to enhanced_plot.interactive_elements
        
        Note: Add data point hover information
        If enhanced_plot.plot_type is equal to PlotType.scatter_plot:
            For i from 0 to (length of enhanced_plot.data.x_values minus 1):
                Let point_element be InteractiveElement with:
                    element_id as "point_" plus (i as String)
                    element_type as "data_point"
                    position as Dictionary with:
                        "x" as enhanced_plot.data.x_values at index i as Float
                        "y" as enhanced_plot.data.y_values at index i as Float
                    properties as Dictionary with:
                        "data_index" as i
                        "x_value" as enhanced_plot.data.x_values at index i
                        "y_value" as enhanced_plot.data.y_values at index i
                    event_handlers as Dictionary with:
                        "mouseover" as "showTooltip"
                        "mouseout" as "hideTooltip"
                
                Add point_element to enhanced_plot.interactive_elements
        
        Return enhanced_plot
    
    Catch error:
        Return plot

Process called "create_animated_plot" that takes initial_data as PlotData and animation_frames as List[PlotData] and config as PlotConfiguration returns VisualizationResult:
    Note: Create animated plot with time-based data transitions
    Try:
        Let animated_config be config
        Set animated_config.interactive to true
        
        Let initial_plot_result be create_line_plot with:
            x_data as initial_data.x_values
            y_data as initial_data.y_values
            config as animated_config
        
        Match initial_plot_result:
            When PlotSuccess with plot_object as base_plot and metadata as plot_metadata:
                Let animation_frame_objects be empty list
                
                For frame_index from 0 to (length of animation_frames minus 1):
                    Let frame_data be animation_frames at index frame_index
                    Let animation_frame be AnimationFrame with:
                        frame_id as frame_index
                        timestamp as (frame_index as Float) times 100.0  Note: 100ms per frame
                        data_updates as Dictionary with:
                            "x_values" as frame_data.x_values
                            "y_values" as frame_data.y_values
                        style_updates as Dictionary with empty entries
                    
                    Add animation_frame to animation_frame_objects
                
                Set base_plot.animation_frames to Some with value as animation_frame_objects
                
                Note: Add animation controls
                Let play_control be InteractiveElement with:
                    element_id as "play_control"
                    element_type as "animation_control"
                    position as Dictionary with "x" as 10.0 and "y" as 50.0
                    properties as Dictionary with:
                        "is_playing" as false
                        "current_frame" as 0
                        "total_frames" as length of animation_frames
                    event_handlers as Dictionary with:
                        "click" as "toggleAnimation"
                
                Add play_control to base_plot.interactive_elements
                
                Return PlotSuccess with:
                    plot_object as base_plot
                    metadata as plot_metadata
            
            When PlotError:
                Return initial_plot_result
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in animated plot creation"
                original_error as error
            context as Dictionary with "feature" as "animation"

Note: Dashboard and Multi-Plot Layout Functions

Process called "create_dashboard" that takes plots as List[Plot] and layout as String and config as Optional[PlotConfiguration] returns VisualizationResult:
    Note: Create dashboard with multiple plots in specified layout
    Try:
        If length of plots is equal to 0:
            Return PlotError with:
                error as InsufficientDataError with:
                    message as "Cannot create dashboard with no plots"
                    plots_count as 0
                context as Dictionary with "feature" as "dashboard"
        
        Let dashboard_config be config if config is not None else create_default_plot_config
        Set dashboard_config.width to 1200
        Set dashboard_config.height to 800
        
        Let layout_result be calculate_dashboard_layout with:
            plots_count as length of plots
            layout_type as layout
            total_width as dashboard_config.width
            total_height as dashboard_config.height
        
        Match layout_result:
            When LayoutCalculationSuccess with positions as plot_positions:
                Let dashboard_svg be create_dashboard_svg with:
                    plots as plots
                    positions as plot_positions
                    config as dashboard_config
                
                Let dashboard_plot be Plot with:
                    plot_id as generate_unique_plot_id
                    plot_type as PlotType.area_plot  Note: Using as dashboard container type
                    data as PlotData with:
                        x_values as empty list
                        y_values as empty list
                        labels as None
                        colors as None
                        sizes as None
                        metadata as Dictionary with "plot_count" as length of plots
                    config as dashboard_config
                    svg_content as Some with value as dashboard_svg
                    interactive_elements as combine_interactive_elements with plots as plots
                    animation_frames as None
                
                Return PlotSuccess with:
                    plot_object as dashboard_plot
                    metadata as Dictionary with:
                        "dashboard_layout" as layout
                        "plots_count" as length of plots
                        "total_width" as dashboard_config.width
                        "total_height" as dashboard_config.height
            
            When LayoutCalculationError with error as layout_error:
                Return PlotError with:
                    error as layout_error
                    context as Dictionary with "feature" as "dashboard"
    
    Catch error:
        Return PlotError with:
            error as UnexpectedError with:
                message as "Unexpected error in dashboard creation"
                original_error as error
            context as Dictionary with "feature" as "dashboard"

Process called "calculate_dashboard_layout" that takes plots_count as Integer and layout_type as String and total_width as Integer and total_height as Integer returns Union[LayoutCalculationSuccess, LayoutCalculationError]:
    Note: Calculate positions and sizes for plots in dashboard layout
    Try:
        Match layout_type:
            When "grid":
                Let grid_result be calculate_grid_layout with:
                    count as plots_count
                    width as total_width
                    height as total_height
                Return LayoutCalculationSuccess with positions as grid_result
            
            When "horizontal":
                Let horizontal_result be calculate_horizontal_layout with:
                    count as plots_count
                    width as total_width
                    height as total_height
                Return LayoutCalculationSuccess with positions as horizontal_result
            
            When "vertical":
                Let vertical_result be calculate_vertical_layout with:
                    count as plots_count
                    width as total_width
                    height as total_height
                Return LayoutCalculationSuccess with positions as vertical_result
            
            Otherwise:
                Return LayoutCalculationError with error as UnsupportedLayoutError with:
                    message as "Unsupported dashboard layout type"
                    layout_type as layout_type
                    supported_types as list containing "grid", "horizontal", "vertical"
    
    Catch error:
        Return LayoutCalculationError with error as LayoutCalculationError with:
            message as "Failed to calculate dashboard layout"
            original_error as error

Process called "calculate_grid_layout" that takes count as Integer and width as Integer and height as Integer returns List[Dictionary[String, Integer]]:
    Note: Calculate grid layout positions for multiple plots
    Try:
        Let cols be calculate_grid_columns with count as count
        Let rows be calculate_ceiling with value as (count as Float) divided by (cols as Float)
        
        Let plot_width be width divided by cols
        Let plot_height be height divided by rows
        
        Let positions be empty list
        
        For i from 0 to (count minus 1):
            Let col be i mod cols
            Let row be i divided by cols
            
            Let position be Dictionary with:
                "x" as col times plot_width
                "y" as row times plot_height
                "width" as plot_width
                "height" as plot_height
            
            Add position to positions
        
        Return positions
    
    Catch error:
        Return empty list

Process called "calculate_grid_columns" that takes count as Integer returns Integer:
    Note: Calculate optimal number of columns for grid layout
    Try:
        If count is less than or equal to 1:
            Return 1
        
        If count is less than or equal to 4:
            Return 2
        
        If count is less than or equal to 9:
            Return 3
        
        Return 4  Note: Maximum 4 columns for readability
    
    Catch error:
        Return 2

Note: Error Types for Visualization

Type DataValidationError is Dictionary with:
    message as String
    x_length as Optional[Integer]
    y_length as Optional[Integer]
    categories_length as Optional[Integer]
    values_length as Optional[Integer]
    data_length as Optional[Integer]
    matrix_rows as Optional[Integer]
    matrix_cols as Optional[Integer]
    matrix_validation as Optional[Dictionary[String, Any]]
    numeric_columns_count as Optional[Integer]
    groups_count as Optional[Integer]

Type RenderingError is Dictionary with:
    message as String

Type UnsupportedPlotTypeError is Dictionary with:
    message as String
    requested_type as String
    supported_types as List[String]

Type UnsupportedFeatureError is Dictionary with:
    message as String
    plot_type as String

Type InsufficientDataError is Dictionary with:
    message as String
    required_size as Optional[Integer]
    plots_count as Optional[Integer]
    numeric_columns_count as Optional[Integer]

Type UnexpectedError is Dictionary with:
    message as String
    original_error as Any

Type PlotObjectCreationError is Dictionary with:
    message as String
    original_error as Any

Type SvgRenderingError is Dictionary with:
    message as String
    original_error as Any

Type UnsupportedLayoutError is Dictionary with:
    message as String
    layout_type as String
    supported_types as List[String]

Type PlotCreationSuccess is Dictionary with:
    plot as Plot

Type PlotCreationError is Dictionary with:
    error as Any

Type SvgRenderSuccess is Dictionary with:
    svg as String

Type SvgRenderError is Dictionary with:
    error as Any

Type LayoutCalculationSuccess is Dictionary with:
    positions as List[Dictionary[String, Integer]]

Type LayoutCalculationError is Dictionary with:
    error as Any

