Type called "LogisticRegression":
    coefficients as List[Float]
    intercept as Float
    regularization as String
    max_iterations as Integer
    learning_rate as Float
    is_fitted as Boolean

Process called "create_logistic_regression" that takes 
    regularization as Optional[String]
    and max_iterations as Optional[Integer]
    and learning_rate as Optional[Float]
    returns LogisticRegression:

    Note: Create logistic regression classifier
    Return LogisticRegression with:
        coefficients as empty list
        intercept as 0.0
        regularization as regularization or "none"
        max_iterations as max_iterations or 1000
        learning_rate as learning_rate or 0.01
        is_fitted as false

Process called "fit_logistic_regression" that takes 
    model as LogisticRegression
    and X_train as df.DataFrame
    and y_train as df.DataFrame
    returns LogisticRegression:

    Note: Train logistic regression model using gradient descent
    Try:
        Let n_features be length of X_train.columns
        Let n_samples be df.get_dataframe_shape with df as X_train["rows"]
        
        Note: Initialize coefficients
        Let coefficients be empty list
        For i from 0 to n_features minus 1:
            Add 0.0 to coefficients
        
        Let intercept be 0.0
        
        Note: Get training data
        Let X_matrix be convert_dataframe_to_matrix with df as X_train
        Let y_vector be df.get_dataframe_column_values with 
            df as y_train 
            and column as y_train.columns[0]
        
        Note: Gradient descent training
        For iteration from 0 to model.max_iterations minus 1:
            Let predictions be empty list
            
            Note: Calculate predictions for all samples
            For i from 0 to n_samples minus 1:
                Let linear_combination be intercept
                For j from 0 to n_features minus 1:
                    Set linear_combination to linear_combination plus coefficients[j] multiplied by X_matrix[i][j]
                
                Let prediction be sigmoid_function with value as linear_combination
                Add prediction to predictions
            
            Note: Calculate gradients
            Let intercept_gradient be 0.0
            Let coefficient_gradients be empty list
            For j from 0 to n_features minus 1:
                Add 0.0 to coefficient_gradients
            
            For i from 0 to n_samples minus 1:
                Let error be predictions[i] minus y_vector[i] as Float
                Set intercept_gradient to intercept_gradient plus error
                
                For j from 0 to n_features minus 1:
                    Set coefficient_gradients[j] to coefficient_gradients[j] plus error multiplied by X_matrix[i][j]
            
            Note: Update parameters
            Set intercept to intercept minus model.learning_rate multiplied by intercept_gradient divided by n_samples as Float
            
            For j from 0 to n_features minus 1:
                Set coefficients[j] to coefficients[j] minus model.learning_rate multiplied by coefficient_gradients[j] divided by n_samples as Float
        
        Return LogisticRegression with:
            coefficients as coefficients
            intercept as intercept
            regularization as model.regularization
            max_iterations as model.max_iterations
            learning_rate as model.learning_rate
            is_fitted as true
    
    Catch error:
        Return model

Type called "RandomForest":
    n_estimators as Integer
    max_depth as Optional[Integer]
    min_samples_split as Integer
    min_samples_leaf as Integer
    trees as List[Dictionary[String, Any]]
    feature_importance as List[Float]
    is_fitted as Boolean

Process called "create_random_forest" that takes 
    n_estimators as Optional[Integer]
    and max_depth as Optional[Integer]
    and min_samples_split as Optional[Integer]
    and min_samples_leaf as Optional[Integer]
    returns RandomForest:

    Note: Create random forest classifier
    Return RandomForest with:
        n_estimators as n_estimators or 100
        max_depth as max_depth
        min_samples_split as min_samples_split or 2
        min_samples_leaf as min_samples_leaf or 1
        trees as empty list
        feature_importance as empty list
        is_fitted as false

Process called "fit_random_forest" that takes 
    model as RandomForest
    and X_train as df.DataFrame
    and y_train as df.DataFrame
    returns RandomForest:

    Note: Train random forest model
    Try:
        Let trained_trees be empty list
        Let n_features be length of X_train.columns
        
        Note: Train individual decision trees
        For i from 0 to model.n_estimators minus 1:
            Note: Bootstrap sampling
            Let bootstrap_indices be create_bootstrap_sample with 
                n_samples as df.get_dataframe_shape with df as X_train["rows"]
                and random_seed as i
            
            Let X_bootstrap be df.select_dataframe_rows_by_indices with 
                df as X_train 
                and indices as bootstrap_indices
            
            Let y_bootstrap be df.select_dataframe_rows_by_indices with 
                df as y_train 
                and indices as bootstrap_indices
            
            Note: Train decision tree (simplified)
            Let tree be train_decision_tree with 
                X_data as X_bootstrap 
                and y_data as y_bootstrap 
                and max_depth as model.max_depth 
                and min_samples_split as model.min_samples_split
            
            Add tree to trained_trees
        
        Note: Calculate feature importance
        Let importance_scores be empty list
        For i from 0 to n_features minus 1:
            Add 1.0 divided by n_features as Float to importance_scores
        
        Return RandomForest with:
            n_estimators as model.n_estimators
            max_depth as model.max_depth
            min_samples_split as model.min_samples_split
            min_samples_leaf as model.min_samples_leaf
            trees as trained_trees
            feature_importance as importance_scores
            is_fitted as true
    
    Catch error:
        Return model

