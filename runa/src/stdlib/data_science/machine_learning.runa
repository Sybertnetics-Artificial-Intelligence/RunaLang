Type called "LinearRegression":
    coefficients as List[Float]
    intercept as Float
    r_squared as Float
    residuals as List[Float]
    is_fitted as Boolean

Process called "create_linear_regression" returns LinearRegression:
    Note: Create linear regression model
    Return LinearRegression with:
        coefficients as empty list
        intercept as 0.0
        r_squared as 0.0
        residuals as empty list
        is_fitted as false

Process called "fit_linear_regression" that takes 
    model as LinearRegression
    and X_train as df.DataFrame
    and y_train as df.DataFrame
    returns LinearRegression:

    Note: Train linear regression using normal equation
    Try:
        Let X_matrix be convert_dataframe_to_matrix with df as X_train
        Let y_vector be df.get_dataframe_column_values with 
            df as y_train 
            and column as y_train.columns[0]
        
        Let n_samples be length of X_matrix
        Let n_features be length of X_train.columns
        
        Note: Add intercept column (column of ones)
        Let X_with_intercept be empty list
        For i from 0 to n_samples minus 1:
            Let row_with_intercept be list containing 1.0
            For j from 0 to n_features minus 1:
                Add X_matrix[i][j] to row_with_intercept
            Add row_with_intercept to X_with_intercept
        
        Note: Solve normal equation: θ = (X^T X)^(-1) X^T y
        Let XTX be matrix_multiply_transpose with matrix as X_with_intercept
        Let XTy be matrix_vector_multiply_transpose with matrix as X_with_intercept and vector as y_vector
        Let theta be solve_linear_system with matrix as XTX and vector as XTy
        
        Let intercept_value be theta[0]
        Let coefficient_values be list_ops.slice_list with list as theta and start as 1 and end as length of theta
        
        Note: Calculate R-squared
        Let predictions be empty list
        For i from 0 to n_samples minus 1:
            Let prediction be intercept_value
            For j from 0 to n_features minus 1:
                Set prediction to prediction plus coefficient_values[j] multiplied by X_matrix[i][j]
            Add prediction to predictions
        
        Let r_squared_value be calculate_r_squared with actual as y_vector and predicted as predictions
        
        Note: Calculate residuals
        Let residual_values be empty list
        For i from 0 to n_samples minus 1:
            Let residual be y_vector[i] as Float minus predictions[i]
            Add residual to residual_values
        
        Return LinearRegression with:
            coefficients as coefficient_values
            intercept as intercept_value
            r_squared as r_squared_value
            residuals as residual_values
            is_fitted as true
    
    Catch error:
        Return model

Type called "RidgeRegression":
    coefficients as List[Float]
    intercept as Float
    alpha as Float
    r_squared as Float
    is_fitted as Boolean

Process called "create_ridge_regression" that takes alpha as Optional[Float] returns RidgeRegression:
    Note: Create Ridge regression with L2 regularization
    Return RidgeRegression with:
        coefficients as empty list
        intercept as 0.0
        alpha as alpha or 1.0
        r_squared as 0.0
        is_fitted as false

Process called "fit_ridge_regression" that takes 
    model as RidgeRegression
    and X_train as df.DataFrame
    and y_train as df.DataFrame
    returns RidgeRegression:

    Note: Train Ridge regression with L2 regularization
    Try:
        Let X_matrix be convert_dataframe_to_matrix with df as X_train
        Let y_vector be df.get_dataframe_column_values with 
            df as y_train 
            and column as y_train.columns[0]
        
        Let n_features be length of X_train.columns
        
        Note: Create regularization matrix
        Let regularization_matrix be create_identity_matrix with size as n_features plus 1
        Set regularization_matrix[0][0] to 0.0  Note: Don't regularize intercept
        
        For i from 1 to n_features:
            Set regularization_matrix[i][i] to model.alpha
        
        Note: Add intercept column
        Let X_with_intercept be add_intercept_column with matrix as X_matrix
        
        Note: Solve regularized normal equation: θ = (X^T X + αI)^(-1) X^T y
        Let XTX be matrix_multiply_transpose with matrix as X_with_intercept
        Let regularized_XTX be matrix_add with matrix1 as XTX and matrix2 as regularization_matrix
        Let XTy be matrix_vector_multiply_transpose with matrix as X_with_intercept and vector as y_vector
        Let theta be solve_linear_system with matrix as regularized_XTX and vector as XTy
        
        Let intercept_value be theta[0]
        Let coefficient_values be list_ops.slice_list with list as theta and start as 1 and end as length of theta
        
        Note: Calculate R-squared
        Let predictions be make_predictions_linear with 
            coefficients as coefficient_values 
            and intercept as intercept_value 
            and X_data as X_matrix
        
        Let r_squared_value be calculate_r_squared with actual as y_vector and predicted as predictions
        
        Return RidgeRegression with:
            coefficients as coefficient_values
            intercept as intercept_value
            alpha as model.alpha
            r_squared as r_squared_value
            is_fitted as true
    
    Catch error:
        Return model

