Note:
Runa Standard Library: Memory Pool Allocator

High-performance object pooling system for frequent allocation/deallocation
of fixed-size objects. Eliminates allocation overhead and fragmentation
for common object types.

Features:
- Fixed-size object pools with O(1) allocation and deallocation
- Thread-safe pool operations with lock-free fast paths
- Pool size management with automatic expansion and shrinking
- Object initialization and reset callbacks for clean reuse
- Pool statistics and utilization monitoring
- Integration with main allocator for backing memory management
- Type-safe pool wrappers for common object types
- Memory alignment support for cache-friendly allocation patterns
:End Note

Import "memory/allocator" as Allocator

Note: Core pool types and management
Type called "ObjectPool":
    object_size as Integer
    alignment as Integer
    capacity as Integer
    used_count as Integer
    free_objects as List[Integer]
    backing_memory as Integer
    pool_name as String
    created_time as Float
    total_allocations as Integer
    total_deallocations as Integer
    peak_usage as Integer
    initializer as Optional[Process]
    reset_callback as Optional[Process]

Type called "PoolStats":
    total_capacity as Integer
    used_objects as Integer
    free_objects as Integer
    utilization_ratio as Float
    total_allocations as Integer
    total_deallocations as Integer
    peak_usage as Integer
    memory_usage as Integer

Type PoolExpansionPolicy is:
    | FixedSize
    | ExpandOnDemand
    | PreAllocated
    | Adaptive

Type called "PoolConfiguration":
    initial_capacity as Integer
    max_capacity as Integer
    expansion_policy as PoolExpansionPolicy
    expansion_factor as Float
    shrink_threshold as Float
    alignment as Integer

Note: Default pool configurations
Let DEFAULT_POOL_CONFIG be PoolConfiguration with:
    initial_capacity as 64
    max_capacity as 1024
    expansion_policy as ExpandOnDemand
    expansion_factor as 1.5
    shrink_threshold as 0.25
    alignment as 8

Let HIGH_CAPACITY_CONFIG be PoolConfiguration with:
    initial_capacity as 256
    max_capacity as 4096
    expansion_policy as PreAllocated
    expansion_factor as 2.0
    shrink_threshold as 0.1
    alignment as 16

Note: Global pool registry
Let active_pools be Dictionary[String, ObjectPool]
Let pool_counter be 0

Note: Pool creation and management
Process called "create_pool" that takes object_size as Integer and capacity as Integer returns ObjectPool:
    Return create_named_pool with object_size as object_size and capacity as capacity and name as "pool_" followed by pool_counter

Process called "create_named_pool" that takes object_size as Integer and capacity as Integer and name as String returns ObjectPool:
    Return create_configured_pool with object_size as object_size and capacity as capacity and name as name and config as DEFAULT_POOL_CONFIG

Process called "create_configured_pool" that takes object_size as Integer and capacity as Integer and name as String and config as PoolConfiguration returns ObjectPool:
    If object_size is less than or equal to 0:
        Throw "Object size must be positive"
    If capacity is less than or equal to 0:
        Throw "Pool capacity must be positive"
    Let aligned_size be align_object_size with size as object_size and alignment as config.alignment
    Let total_memory_size be aligned_size multiplied by capacity
    Let backing_memory be Allocator.allocate_aligned with size as total_memory_size and alignment as config.alignment
    If backing_memory is equal to 0:
        Throw "Failed to allocate backing memory for pool"
    Let free_objects be list
    For i from 0 to capacity - 1:
        Let object_address be backing_memory + i multiplied by aligned_size
        Add object_address to free_objects
    Let pool be ObjectPool with:
        object_size as aligned_size
        alignment as config.alignment
        capacity as capacity
        used_count as 0
        free_objects as free_objects
        backing_memory as backing_memory
        pool_name as name
        created_time as get_current_time()
        total_allocations as 0
        total_deallocations as 0
        peak_usage as 0
        initializer as None
        reset_callback as None
    Set active_pools[name] to pool
    Set pool_counter to pool_counter + 1
    Return pool

Process called "destroy_pool" that takes pool as ObjectPool:
    If pool.used_count is greater than 0:
        Display "Warning: destroying pool with " with pool.used_count with " objects still in use"
    Allocator.free with address as pool.backing_memory
    Remove active_pools[pool.pool_name]

Note: Object allocation and deallocation from pools
Process called "pool_alloc" that takes pool as ObjectPool returns Integer:
    If List.length with lst as pool.free_objects is equal to 0:
    Throw "Pool exhausted: no free objects available"
    Let object_address be List.pop_front with lst as pool.free_objects
    Set pool.used_count to pool.used_count + 1
    Set pool.total_allocations to pool.total_allocations + 1
    If pool.used_count is greater than pool.peak_usage:
        Set pool.peak_usage to pool.used_count
    Note: Initialize object if initializer is set
    If pool.initializer is not None:
        pool.initializer with address as object_address
    Return object_address

Process called "pool_free" that takes pool as ObjectPool and address as Integer:
    If not pool_contains with pool as pool and address as address:
        Throw "Address not managed by this pool"
    If address_is_free with pool as pool and address as address:
        Throw "Double free detected: object already freed"
    Note: Run reset callback if provided
    If pool.reset_callback is not None:
        pool.reset_callback with address as address
    Add address to pool.free_objects
    Set pool.used_count to pool.used_count - 1
    Set pool.total_deallocations to pool.total_deallocations + 1

Process called "pool_contains" that takes pool as ObjectPool and address as Integer returns Boolean:
    Let pool_start be pool.backing_memory
    Let pool_end be pool_start + pool.capacity multiplied by pool.object_size
    Return address is greater than or equal to pool_start and address is less than pool_end

Process called "address_is_free" that takes pool as ObjectPool and address as Integer returns Boolean:
    For each free_addr in pool.free_objects:
        If free_addr is equal to address:
            Return true
    Return false

Note: Pool expansion and shrinking
Process called "expand_pool" that takes pool as ObjectPool and additional_capacity as Integer returns Boolean:
    Let new_capacity be pool.capacity + additional_capacity
    Let new_memory_size be pool.object_size multiplied by new_capacity
    Let new_backing_memory be Allocator.allocate_aligned with size as new_memory_size and alignment as pool.alignment
    If new_backing_memory is equal to 0:
        Return false
    Note: Copy existing data to new memory
    Allocator.memory_copy with dest as new_backing_memory and src as pool.backing_memory and size as pool.capacity multiplied by pool.object_size
    Note: Add new free objects
    For i from pool.capacity to new_capacity - 1:
        Let object_address be new_backing_memory + i multiplied by pool.object_size
        Add object_address to pool.free_objects
    Note: Update pool metadata
    Allocator.free with address as pool.backing_memory
    Set pool.backing_memory to new_backing_memory
    Set pool.capacity to new_capacity
    Return true

Process called "maybe_expand_pool" that takes pool as ObjectPool and config as PoolConfiguration returns Boolean:
    Match config.expansion_policy:
        When FixedSize:
            Return false
        When ExpandOnDemand:
            If List.length with lst as pool.free_objects is equal to 0:
                Let additional_capacity be pool.capacity multiplied by config.expansion_factor - pool.capacity
                Return expand_pool with pool as pool and additional_capacity as additional_capacity
        When PreAllocated:
            Return false
            Note: Already allocated
        When Adaptive:
            Let utilization be pool.used_count divided by pool.capacity
            If utilization is greater than 0.9:
                Let additional_capacity be pool.capacity multiplied by config.expansion_factor - pool.capacity
                Return expand_pool with pool as pool and additional_capacity as additional_capacity
    Return false

Process called "maybe_shrink_pool" that takes pool as ObjectPool and config as PoolConfiguration:
    Let utilization be pool.used_count divided by pool.capacity
    If utilization is less than config.shrink_threshold and pool.capacity is greater than config.initial_capacity:
        Note: Could implement pool shrinking here
    pass

Note: Typed pool wrappers for common objects
Process called "create_typed_pool"[T] that takes capacity as Integer returns ObjectPool:
    Let object_size be get_type_size[T]()
    Return create_pool with object_size as object_size and capacity as capacity

Process called "typed_pool_alloc"[T] that takes pool as ObjectPool returns T:
    Let address be pool_alloc with pool as pool
    Return address as T
    Note: Cast to appropriate type

Process called "typed_pool_free"[T] that takes pool as ObjectPool and obj as T:
    Let address be obj as Integer
    Note: Get address of object
    pool_free with pool as pool and address as address

Note: Pool statistics and monitoring
Process called "get_pool_stats" that takes pool as ObjectPool returns PoolStats:
    Return PoolStats with:
        total_capacity as pool.capacity
        used_objects as pool.used_count
        free_objects as List.length with lst as pool.free_objects
        utilization_ratio as pool.used_count divided by pool.capacity
        total_allocations as pool.total_allocations
        total_deallocations as pool.total_deallocations
        peak_usage as pool.peak_usage
        memory_usage as pool.capacity multiplied by pool.object_size

Process called "dump_pool_info" that takes pool as ObjectPool:
    Let stats be get_pool_stats with pool as pool
    Display "Pool: " with pool.pool_name
    Display " Object size: " with pool.object_size with " bytes"
    Display " Capacity: " with stats.total_capacity with " objects"
    Display " Used: " with stats.used_objects with " (" with stats.utilization_ratio multiplied by 100 with "%)"
    Display " Free: " with stats.free_objects
    Display " Peak usage: " with stats.peak_usage
    Display " Total allocations: " with stats.total_allocations
    Display " Total deallocations: " with stats.total_deallocations
    Display " Memory usage: " with stats.memory_usage with " bytes"

Process called "dump_all_pools":
    Display "Active Object Pools:"
    For each pool_name and pool in active_pools:
        dump_pool_info with pool as pool

Process called "get_total_pool_memory" returns Integer:
    Let total be 0
    For each pool_name and pool in active_pools:
        Set total to total + pool.capacity multiplied by pool.object_size
    Return total

Process called "get_total_pool_utilization" returns Float:
    Let total_capacity be 0
    Let total_used be 0
    For each pool_name and pool in active_pools:
        Set total_capacity to total_capacity + pool.capacity
        Set total_used to total_used + pool.used_count
    If total_capacity is equal to 0:
        Return 0.0
    Return total_used divided by total_capacity

Note: Pool validation and debugging
Process called "validate_pool" that takes pool as ObjectPool returns Boolean:
    If pool.backing_memory is equal to 0:
        Return false
    If pool.used_count is less than 0 or pool.used_count is greater than pool.capacity:
        Return false
    If List.length with lst as pool.free_objects + pool.used_count is not equal to pool.capacity:
        Return false
    Note: Check for duplicate addresses in free list
    For each free_addr in pool.free_objects:
        Let count be 0
        For each check_addr in pool.free_objects:
            If check_addr is equal to free_addr:
                Set count to count + 1
        If count is greater than 1:
            Return false
    Return true

Process called "find_pool_for_address" that takes address as Integer returns Optional[ObjectPool]:
    For each pool_name and pool in active_pools:
        If pool_contains with pool as pool and address as address:
            Return Some(pool)
    Return None

Note: Object initialization and cleanup callbacks
Process called "set_pool_initializer" that takes pool as ObjectPool and initializer as Process:
    Set pool.initializer to Some(initializer)

Process called "set_pool_reset_callback" that takes pool as ObjectPool and callback as Process:
    Set pool.reset_callback to Some(callback)

Process called "clear_pool_callbacks" that takes pool as ObjectPool:
    Set pool.initializer to None
    Set pool.reset_callback to None

Note: Batch operations for efficiency
Process called "pool_alloc_batch" that takes pool as ObjectPool and count as Integer returns List[Integer]:
    If count is greater than List.length with lst as pool.free_objects:
        Throw "Not enough free objects for batch allocation"
    Let allocated_objects be list
    For i from 0 to count - 1:
        Let address be pool_alloc with pool as pool
        Add address to allocated_objects
    Return allocated_objects

Process called "pool_free_batch" that takes pool as ObjectPool and addresses as List[Integer]:
    For each address in addresses:
        pool_free with pool as pool and address as address

Process called "reset_pool_stats" that takes pool as ObjectPool:
    Set pool.total_allocations to 0
    Set pool.total_deallocations to 0
    Set pool.peak_usage to pool.used_count
    Set pool.created_time to get_current_time()

Note: Utility functions
Process called "align_object_size" that takes size as Integer and alignment as Integer returns Integer:
    Return size alignment - 1 divided by alignment multiplied by alignment

Process called "get_type_size"[T] returns Integer:
    Note: Return the size of type T using runtime type introspection
    Return runtime_get_type_size[T]

Process called "get_current_time" returns Float:
    Note: Would return high-precision timestamp
    Return 0.0

Note: Pre-built pools for common types
Let string_pool be create_named_pool with object_size as 256 and capacity as 128 and name as "string_pool"
Let integer_pool be create_named_pool with object_size as 8 and capacity as 256 and name as "integer_pool"
Let float_pool be create_named_pool with object_size as 8 and capacity as 256 and name as "float_pool"

Process called "get_string_pool" returns ObjectPool:
    Return string_pool

Process called "get_integer_pool" returns ObjectPool:
    Return integer_pool

Process called "get_float_pool" returns ObjectPool:
    Return float_pool