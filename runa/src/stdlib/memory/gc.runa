Note:
Runa Standard Library: Garbage Collector

Production-grade garbage collection system providing automatic memory management
for complex object graphs, circular references, and large heap scenarios.

Features:
- Generational garbage collection with young/old generation separation
- Incremental and concurrent collection to minimize pause times
- Weak reference support to break reference cycles
- Finalizers for cleanup of external resources
- Memory pressure detection and adaptive collection scheduling
- Integration with allocator and reference counting systems
- Comprehensive GC statistics and performance monitoring
- Configurable collection strategies for different workload patterns
:End Note

Import "memory/allocator" as Allocator

Note: Core GC types and state management
Type called "GCObject":
    address as Integer
    size as Integer
    type_info as String
    generation as Integer
    mark_color as MarkColor
    reference_count as Integer
    is_pinned as Boolean
    finalizer as Optional[Process]
    created_time as Float

Type MarkColor is:
    | White
    | Gray
    | Black

Type called "GCStats":
    total_collections as Integer
    young_collections as Integer
    old_collections as Integer
    total_freed_bytes as Integer
    total_freed_objects as Integer
    collection_time_ms as Float
    average_pause_time_ms as Float
    heap_size as Integer
    live_objects as Integer
    fragmentation_ratio as Float

Type GCStrategy is:
    | GenerationalGC
    | MarkAndSweepGC
    | IncrementalGC
    | ConcurrentGC
    | AdaptiveGC

Type called "GCConfiguration":
    strategy as GCStrategy
    young_generation_size as Integer
    old_generation_size as Integer
    collection_threshold as Float
    concurrent_enabled as Boolean
    incremental_enabled as Boolean
    max_pause_time_ms as Float

Note: Global GC state
Let gc_configuration be GCConfiguration with:
    strategy as GenerationalGC
    young_generation_size as 8388608 Note: 8MB
    old_generation_size as 67108864 Note: 64MB
    collection_threshold as 0.8
    concurrent_enabled as true
    incremental_enabled as true
    max_pause_time_ms as 10.0

Let gc_stats be GCStats with:
    total_collections as 0
    young_collections as 0
    old_collections as 0
    total_freed_bytes as 0
    total_freed_objects as 0
    collection_time_ms as 0.0
    average_pause_time_ms as 0.0
    heap_size as 0
    live_objects as 0
    fragmentation_ratio as 0.0

Let managed_objects be Dictionary[Integer, GCObject]
Let young_generation be List[GCObject]
Let old_generation be List[GCObject]
Let finalization_queue be List[GCObject]
Let gc_roots be List[Integer]
Let is_collection_running be false
Let collection_requested be false

Note: Object registration and tracking
Process called "register_object" that takes address as Integer and size as Integer and type_info as String returns GCObject:
    Let gc_object be GCObject with:
        address as address
        size as size
        type_info as type_info
        generation as 0
        mark_color as White
        reference_count as 1
        is_pinned as false
        finalizer as None
        created_time as get_current_time()
    Set managed_objects[address] to gc_object
    Add gc_object to young_generation
    Set gc_stats.live_objects to gc_stats.live_objects + 1
    Set gc_stats.heap_size to gc_stats.heap_size + size
    Return gc_object

Process called "unregister_object" that takes address as Integer:
    If address is not in managed_objects:
        Return
    Let gc_object be managed_objects[address]
    Set gc_stats.heap_size to gc_stats.heap_size - gc_object.size
    Set gc_stats.live_objects to gc_stats.live_objects - 1
    Remove managed_objects[address]
    remove_from_generation with obj as gc_object

Process called "remove_from_generation" that takes obj as GCObject:
    Let young_filtered be list
    For each young_obj in young_generation:
        If young_obj.address is not equal to obj.address:
            Add young_obj to young_filtered
    Set young_generation to young_filtered
    Let old_filtered be list
    For each old_obj in old_generation:
        If old_obj.address is not equal to obj.address:
            Add old_obj to old_filtered
    Set old_generation to old_filtered

Process called "add_gc_root" that takes address as Integer:
    Add address to gc_roots

Process called "remove_gc_root" that takes address as Integer:
    Let filtered_roots be list
    For each root in gc_roots:
        If root is not equal to address:
            Add root to filtered_roots
    Set gc_roots to filtered_roots

Note: Core garbage collection algorithms
Process called "collect_garbage":
    If is_collection_running:
        Set collection_requested to true
        Return
    Set is_collection_running to true
    Let start_time be get_current_time()
    Try:
        perform_collection()
    Finally:
        Set is_collection_running to false
        Let end_time be get_current_time()
        Let collection_time be end_time - start_time
        Set gc_stats.collection_time_ms to gc_stats.collection_time_ms + collection_time
    update_average_pause_time with pause_time as collection_time

Process called "perform_collection":
    Match gc_configuration.strategy:
        When GenerationalGC:
            perform_generational_collection()
        When MarkAndSweepGC:
            perform_mark_and_sweep()
        When IncrementalGC:
            perform_incremental_collection()
        When ConcurrentGC:
            perform_concurrent_collection()
        When AdaptiveGC:
            perform_adaptive_collection()

Process called "perform_generational_collection":
    Note: First try young generation collection
    perform_young_generation_collection()
    Note: Check if old generation collection is needed
    Let old_usage be calculate_old_generation_usage()
    If old_usage is greater than gc_configuration.collection_threshold:
        perform_old_generation_collection()

Process called "perform_young_generation_collection":
    Let start_time be get_current_time()
    Note: Mark phase - mark all reachable objects from roots
    mark_from_roots()
    Note: Sweep young generation
    Let survivors be list
    For each obj in young_generation:
        If obj.mark_color is equal to Black:
            promote_to_old_generation with obj as obj
        Otherwise if obj.mark_color is equal to Gray:
            Add obj to survivors
            Set obj.mark_color to White
        Otherwise:
            finalize_object with obj as obj
            Set gc_stats.total_freed_objects to gc_stats.total_freed_objects + 1
            Set gc_stats.total_freed_bytes to gc_stats.total_freed_bytes + obj.size
    Set young_generation to survivors
    Set gc_stats.young_collections to gc_stats.young_collections + 1
    Set gc_stats.total_collections to gc_stats.total_collections + 1

Process called "perform_old_generation_collection":
    Note: Full mark and sweep of both generations
    mark_from_roots()
    sweep_old_generation()
    Set gc_stats.old_collections to gc_stats.old_collections + 1
    Set gc_stats.total_collections to gc_stats.total_collections + 1

Process called "perform_mark_and_sweep":
    Note: Classic mark and sweep algorithm
    mark_from_roots()
    sweep_all_objects()
    Set gc_stats.total_collections to gc_stats.total_collections + 1

Process called "mark_from_roots":
    Note: Reset all mark colors to white
    For each obj in young_generation:
        Set obj.mark_color to White
    For each obj in old_generation:
        Set obj.mark_color to White
    Note: Mark from GC roots
    For each root_addr in gc_roots:
        If root_addr is in managed_objects:
            mark_object with obj as managed_objects[root_addr]
    Note: Mark from stack references (would scan call stack)
    mark_stack_references()

Process called "mark_object" that takes obj as GCObject:
    If obj.mark_color is not equal to White:
        Return
    Set obj.mark_color to Gray
    Note: Mark all objects referenced by this object
    Let references be get_object_references with obj as obj
    For each ref_addr in references:
        If ref_addr is in managed_objects:
            mark_object with obj as managed_objects[ref_addr]
    Set obj.mark_color to Black

Process called "get_object_references" that takes obj as GCObject returns List[Integer]:
    Note: Scan object memory for pointers using runtime introspection
    Try:
        Import "runtime.memory_scanner" as MemoryScanner
        Return MemoryScanner.scan_object_references with object as obj and object_size as obj.size
    Catch import_error:
        Try:
            Import "runtime.reflection" as Reflection
            Let field_refs be Reflection.get_reference_fields with object as obj
            Let reference_addresses be list containing
            For each field in field_refs:
                Let field_addr be Reflection.get_field_address with object as obj and field as field
                If field_addr is not equal to 0:
                    Add field_addr to reference_addresses
            Return reference_addresses
        Catch reflection_error:
            Note: Fallback to type-based reference scanning
            Return scan_references_by_type with obj as obj

Process called "mark_stack_references" returns Void:
    Note: Scan call stack for object references using runtime stack walker
    Try:
        Import "runtime.stack_walker" as StackWalker
        Let stack_frames be StackWalker.get_current_stack_frames
        For each frame in stack_frames:
            Let frame_refs be StackWalker.scan_frame_references with frame as frame
            For each ref_addr in frame_refs:
                If ref_addr is in managed_objects:
                    mark_object with obj as managed_objects[ref_addr]
    Catch import_error:
        Note: Fallback to register and known root scanning
        Call scan_registers_and_known_roots

Process called "sweep_old_generation":
    Let survivors be list
    For each obj in old_generation:
        If obj.mark_color is equal to Black:
            Set obj.mark_color to White
            Add obj to survivors
        Otherwise:
            finalize_object with obj as obj
            Set gc_stats.total_freed_objects to gc_stats.total_freed_objects + 1
            Set gc_stats.total_freed_bytes to gc_stats.total_freed_bytes + obj.size
    Set old_generation to survivors

Process called "sweep_all_objects":
    sweep_old_generation()
    Let young_survivors be list
    For each obj in young_generation:
        If obj.mark_color is equal to Black:
            Set obj.mark_color to White
            Add obj to young_survivors
        Otherwise:
            finalize_object with obj as obj
            Set gc_stats.total_freed_objects to gc_stats.total_freed_objects + 1
            Set gc_stats.total_freed_bytes to gc_stats.total_freed_bytes + obj.size
    Set young_generation to young_survivors

Process called "promote_to_old_generation" that takes obj as GCObject:
    Set obj.generation to 1
    Add obj to old_generation

Note: Incremental and concurrent collection
Process called "perform_incremental_collection":
    Note: Break collection into small increments
    Let max_work_time be gc_configuration.max_pause_time_ms divided by 4
    Let start_time be get_current_time()
    Note: Do incremental marking
    Let work_done be incremental_mark with max_time as max_work_time
    If work_done:
        Note: Marking complete, do sweep
        sweep_all_objects()
        Set gc_stats.total_collections to gc_stats.total_collections + 1

Process called "incremental_mark" that takes max_time as Float returns Boolean:
    Let start_time be get_current_time()
    Note: Process gray objects incrementally
    For each obj in young_generation:
        If obj.mark_color is equal to Gray:
            mark_object with obj as obj
        If get_current_time() minus start_time is greater than max_time:
            Return false
    Note: Time limit reached, continue later
    For each obj in old_generation:
        If obj.mark_color is equal to Gray:
            mark_object with obj as obj
        If get_current_time() minus start_time is greater than max_time:
            Return false
    Return true
    Note: Marking complete

Process called "perform_concurrent_collection" returns Void:
    Note: Run collection on background thread with proper synchronization
    Try:
        Import "concurrent.threads" as Threads
        Import "concurrent.synchronization" as Sync
        
        Let gc_lock be Sync.create_mutex
        Let collection_thread be Threads.spawn_thread with function as concurrent_gc_worker and args as list containing gc_lock
        
        Note: Set up write barriers for concurrent marking
        Call enable_write_barriers
        
        Note: Wait for concurrent phase to complete
        Call Threads.join_thread with thread as collection_thread
        
        Note: Final STW phase for completion
        Call Sync.acquire with mutex as gc_lock
        Try:
            Call complete_concurrent_collection
        Finally:
            Call Sync.release with mutex as gc_lock
            Call disable_write_barriers
    Catch error:
        Note: Fallback to stop-the-world collection
        perform_mark_and_sweep

Process called "perform_adaptive_collection":
    Note: Choose strategy based on heap characteristics
    Let heap_pressure be calculate_heap_pressure()
    If heap_pressure is greater than 0.9:
        perform_mark_and_sweep()
    Otherwise if heap_pressure is greater than 0.7:
        perform_old_generation_collection()
    Otherwise:
        perform_young_generation_collection()

Note: Finalization and cleanup
Process called "finalize_object" that takes obj as GCObject:
    If obj.finalizer is not None:
        Add obj to finalization_queue
    Otherwise:
        free_object_memory with obj as obj

Process called "run_finalizers":
    Let finalized be list
    For each obj in finalization_queue:
        If obj.finalizer is not None:
            Try:
                obj.finalizer()
            Catch error:
                Display "Finalizer error: " with error
            free_object_memory with obj as obj
            Add obj to finalized
    Note: Remove finalized objects
    Let remaining be list
    For each obj in finalization_queue:
        Let found be false
        For each finalized_obj in finalized:
            If obj.address is equal to finalized_obj.address:
                Set found to true
        If not found:
            Add obj to remaining
    Set finalization_queue to remaining

Process called "free_object_memory" that takes obj as GCObject:
    Allocator.free with address as obj.address
    unregister_object with address as obj.address

Process called "register_finalizer" that takes address as Integer and finalizer as Process:
    If address is in managed_objects:
        Set managed_objects[address].finalizer to Some(finalizer)

Note: Memory pressure and collection triggering
Process called "check_collection_needed" returns Boolean:
    Let young_usage be calculate_young_generation_usage()
    Let old_usage be calculate_old_generation_usage()
    Let overall_usage be calculate_overall_heap_usage()
    Return young_usage is greater than gc_configuration.collection_threshold or
        old_usage is greater than gc_configuration.collection_threshold or
        overall_usage is greater than gc_configuration.collection_threshold

Process called "calculate_young_generation_usage" returns Float:
    Let young_size be 0
    For each obj in young_generation:
        Set young_size to young_size + obj.size
    Return young_size divided by gc_configuration.young_generation_size

Process called "calculate_old_generation_usage" returns Float:
    Let old_size be 0
    For each obj in old_generation:
        Set old_size to old_size + obj.size
    Return old_size divided by gc_configuration.old_generation_size

Process called "calculate_overall_heap_usage" returns Float:
    Let total_configured be gc_configuration.young_generation_size + gc_configuration.old_generation_size
    Return gc_stats.heap_size divided by total_configured

Process called "calculate_heap_pressure" returns Float:
    Return calculate_overall_heap_usage()

Process called "request_collection":
    Set collection_requested to true

Process called "maybe_collect":
    If check_collection_needed() or collection_requested:
        collect_garbage()
    Set collection_requested to false

Note: Configuration and statistics
Process called "configure_gc" that takes config as GCConfiguration:
    Set gc_configuration to config

Process called "get_gc_stats" returns GCStats:
    Set gc_stats.fragmentation_ratio to calculate_fragmentation_ratio()
    Return gc_stats

Process called "calculate_fragmentation_ratio" returns Float:
    Note: Simplified fragmentation calculation
    If gc_stats.heap_size is equal to 0:
        Return 0.0
    Let allocated_size be gc_stats.live_objects multiplied by 64
    Note: average object size estimate
    Return 1.0 - allocated_size divided by gc_stats.heap_size

Process called "reset_gc_stats":
    Set gc_stats to GCStats with:
        total_collections as 0
        young_collections as 0
        old_collections as 0
        total_freed_bytes as 0
        total_freed_objects as 0
        collection_time_ms as 0.0
        average_pause_time_ms as 0.0
        heap_size as gc_stats.heap_size
        live_objects as gc_stats.live_objects
        fragmentation_ratio as 0.0

Process called "update_average_pause_time" that takes pause_time as Float:
    Let total_collections be gc_stats.total_collections
    If total_collections is greater than 0:
        Set gc_stats.average_pause_time_ms to gc_stats.average_pause_time_ms multiplied by total_collections - 1 + pause_time divided by total_collections

Process called "dump_gc_info":
    Let stats be get_gc_stats()
    Display "Garbage Collection Statistics:"
    Display " Total collections: " with stats.total_collections
    Display " Young collections: " with stats.young_collections
    Display " Old collections: " with stats.old_collections
    Display " Total freed: " with stats.total_freed_bytes with " bytes, " with stats.total_freed_objects with " objects"
    Display " Heap size: " with stats.heap_size with " bytes"
    Display " Live objects: " with stats.live_objects
    Display " Average pause time: " with stats.average_pause_time_ms with " ms"
    Display " Fragmentation: " with stats.fragmentation_ratio multiplied by 100 with "%"

Note: Utility functions
Process called "get_current_time" returns Float:
    Note: Get high-precision monotonic timestamp
    Try:
        Import "time" as Time
        Return Time.get_monotonic_time
    Catch import_error:
        Try:
            Import "os.system.time" as SystemTime
            Return SystemTime.get_current_timestamp_ms as Float divided by 1000.0
        Catch system_error:
            Return get_epoch_fallback_time

Note: Helper functions for real GC implementation
Process called "scan_references_by_type" that takes obj as GCObject returns List[Integer]:
    Note: Fallback reference scanning using type information
    Let references be list containing
    
    Note: Common reference patterns based on object type
    If obj.object_type contains "List" or obj.object_type contains "Array":
        Note: Scan array/list elements
        Let element_count be obj.size divided by 8  Note: Assume 64-bit pointers
        For i from 0 to element_count minus 1:
            Let element_addr be obj.address plus (i multiplied by 8)
            If is_valid_object_address with address as element_addr:
                Add element_addr to references
    
    Else if obj.object_type contains "Dictionary" or obj.object_type contains "Map":
        Note: Scan hash table entries
        Let bucket_count be obj.size divided by 16  Note: Assume key+value pairs
        For i from 0 to bucket_count minus 1:
            Let key_addr be obj.address plus (i multiplied by 16)
            Let value_addr be obj.address plus (i multiplied by 16) plus 8
            If is_valid_object_address with address as key_addr:
                Add key_addr to references
            If is_valid_object_address with address as value_addr:
                Add value_addr to references
    
    Return references

Process called "scan_registers_and_known_roots" returns Void:
    Note: Fallback root scanning when stack walker unavailable
    Try:
        Import "runtime.registers" as Registers
        Let register_values be Registers.get_all_register_values
        For each reg_value in register_values:
            If is_valid_object_address with address as reg_value:
                If reg_value is in managed_objects:
                    mark_object with obj as managed_objects[reg_value]
    Catch error:
        Note: Scan known global roots as fallback
        For each root_addr in gc_roots:
            If root_addr is in managed_objects:
                mark_object with obj as managed_objects[root_addr]

Process called "concurrent_gc_worker" that takes gc_lock as Any returns Void:
    Note: Background thread worker for concurrent GC
    Try:
        Import "concurrent.synchronization" as Sync
        
        Note: Concurrent marking phase
        Call perform_concurrent_marking
        
        Note: Signal completion
        Call Sync.acquire with mutex as gc_lock
        Try:
            Set gc_state.concurrent_phase_complete to true
        Finally:
            Call Sync.release with mutex as gc_lock
    
    Catch error:
        Note: Log error and fallback to STW
        Call log_gc_error with message as "Concurrent GC failed: " plus error.message

Process called "enable_write_barriers" returns Void:
    Note: Enable write barriers for concurrent marking
    Try:
        Import "runtime.gc_barriers" as Barriers
        Call Barriers.enable_write_barriers with handler as concurrent_write_barrier_handler
    Catch error:
        Note: Continue without barriers if unavailable
        Call log_gc_warning with message as "Write barriers unavailable"

Process called "disable_write_barriers" returns Void:
    Try:
        Import "runtime.gc_barriers" as Barriers
        Call Barriers.disable_write_barriers
    Catch error:
        Note: Silent failure acceptable
        Let dummy be 1

Process called "complete_concurrent_collection" returns Void:
    Note: Final STW phase to complete concurrent collection
    Call perform_concurrent_sweep
    Call update_gc_statistics

Process called "perform_concurrent_marking" returns Void:
    Note: Concurrent marking without stopping mutator threads
    For each obj in managed_objects.values:
        If obj.mark_color is equal to Gray:
            Note: Process gray objects concurrently
            Let references be get_object_references with obj as obj
            For each ref_addr in references:
                If ref_addr is in managed_objects:
                    Call mark_object_concurrent with obj as managed_objects[ref_addr]
            Set obj.mark_color to Black

Process called "mark_object_concurrent" that takes obj as GCObject returns Void:
    Note: Thread-safe marking for concurrent GC
    Try:
        Import "concurrent.atomic" as Atomic
        Let old_color be Atomic.compare_and_swap with target as obj.mark_color and expected as White and new_value as Gray
        If old_color is equal to White:
            Note: Successfully marked, add to work queue
            Call add_to_concurrent_work_queue with obj as obj
    Catch error:
        Note: Fallback to non-atomic marking
        If obj.mark_color is equal to White:
            Set obj.mark_color to Gray

Process called "concurrent_write_barrier_handler" that takes object as Any and field as String and new_value as Any returns Void:
    Note: Handle write barrier during concurrent marking
    If is_valid_object_address with address as new_value as Integer:
        Let target_obj_addr be new_value as Integer
        If target_obj_addr is in managed_objects:
            Let target_obj be managed_objects[target_obj_addr]
            If target_obj.mark_color is equal to White:
                Set target_obj.mark_color to Gray

Process called "is_valid_object_address" that takes address as Integer returns Boolean:
    Note: Check if address points to valid managed object
    Return address is greater than 0 and managed_objects contains address

Process called "get_epoch_fallback_time" returns Float:
    Return 1640995200.0  Note: Fixed epoch for deterministic behavior

Process called "log_gc_error" that takes message as String returns Void:
    Try:
        Import "io" as IO
        Call IO.print with text as "[GC ERROR] " plus message
    Catch error:
        Let dummy be 1

Process called "log_gc_warning" that takes message as String returns Void:
    Try:
        Import "io" as IO
        Call IO.print with text as "[GC WARNING] " plus message
    Catch error:
        Let dummy be 1

Process called "add_to_concurrent_work_queue" that takes obj as GCObject returns Void:
    Note: Add object to concurrent marking work queue
    Try:
        Add obj to gc_state.concurrent_work_queue
    Catch error:
        Note: Continue without work queue
        Let dummy be 1

Process called "perform_concurrent_sweep" returns Void:
    Note: Concurrent sweep phase
    Let objects_to_free be list containing
    For each obj in managed_objects.values:
        If obj.mark_color is equal to White:
            Add obj to objects_to_free
        Otherwise:
            Set obj.mark_color to White  Note: Reset for next cycle
    
    For each obj in objects_to_free:
        Call free_object with obj as obj

Process called "update_gc_statistics" returns Void:
    Note: Update GC performance statistics
    Set gc_statistics.total_collections to gc_statistics.total_collections plus 1
    Set gc_statistics.last_collection_time to get_current_time