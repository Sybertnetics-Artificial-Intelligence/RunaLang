Note:
Runa Standard Library: Memory Arena Allocator

High-performance arena-based memory allocation for scenarios requiring
fast allocation/deallocation with bulk cleanup. Ideal for temporary
computations, parsing, and short-lived object hierarchies.

Features:
- Linear allocation with O(1) allocation time
- Bulk deallocation with arena reset/destroy
- Memory alignment support for optimal cache performance
- Nested arena scopes with automatic cleanup
- Thread-safe arena management with per-thread arenas
- Memory usage tracking and overflow detection
- Integration with main allocator for arena backing memory
- Checkpoint/restore functionality for transactional allocation
:End Note

Import "memory/allocator" as Allocator

Note: Arena types and configuration
Type called "Arena":
    backing_memory as Integer
    size as Integer
    used as Integer
    alignment as Integer
    name as String
    created_time as Float
    allocation_count as Integer
    is_active as Boolean
    checkpoints as List[ArenaCheckpoint]
    owner_thread_id as Integer
    epoch_counter as Integer
    pending_deallocations as List[Dictionary[String, Any]]
    allocation_history as List[Dictionary[String, Any]]

Type called "ArenaCheckpoint":
    used_bytes as Integer
    allocation_count as Integer
    timestamp as Float
    name as String

Type called "ArenaScope":
    arena as Arena
    checkpoint as ArenaCheckpoint
    is_active as Boolean

Type ArenaConfig is:
    | DefaultArena
    | HighPerformanceArena
    | DebugArena
    | CompactArena

Note: Default arena sizes for different configurations
Let DEFAULT_ARENA_SIZE be 1048576 Note: 1MB
Let HIGH_PERF_ARENA_SIZE be 16777216 Note: 16MB
Let DEBUG_ARENA_SIZE be 65536 Note: 64KB
Let COMPACT_ARENA_SIZE be 4096 Note: 4KB

Note: Global arena registry
Let active_arenas be List[Arena]
Let thread_local_arenas be Dictionary[Integer, Arena]
Let arena_counter be 0

Note: Arena creation and management
Process called "create_arena" that takes size as Integer returns Arena:
    Return create_named_arena with size as size and name as "arena_" followed by arena_counter

Process called "create_named_arena" that takes size as Integer and name as String returns Arena:
    If size is less than or equal to 0:
        Throw "Arena size must be positive"
    Let backing_memory be Allocator.allocate_aligned with size as size and alignment as 64
    If backing_memory is equal to 0:
        Throw "Failed to allocate backing memory for arena"
    Let arena be Arena with:
        backing_memory as backing_memory
        size as size
        used as 0
        alignment as 8
        name as name
        created_time as get_current_time()
        allocation_count as 0
        is_active as true
        checkpoints as list
    Add arena to active_arenas
    Set arena_counter to arena_counter + 1
    Return arena

Process called "create_arena_with_config" that takes config as ArenaConfig returns Arena:
    Let size be get_config_size with config as config
    Let name be get_config_name with config as config
    Return create_named_arena with size as size and name as name

Process called "get_config_size" that takes config as ArenaConfig returns Integer:
    Match config:
        When DefaultArena:
            Return DEFAULT_ARENA_SIZE
        When HighPerformanceArena:
            Return HIGH_PERF_ARENA_SIZE
        When DebugArena:
            Return DEBUG_ARENA_SIZE
        When CompactArena:
            Return COMPACT_ARENA_SIZE

Process called "get_config_name" that takes config as ArenaConfig returns String:
    Match config:
        When DefaultArena:
            Return "default"
        When HighPerformanceArena:
            Return "high_perf"
        When DebugArena:
            Return "debug"
        When CompactArena:
            Return "compact"

Process called "destroy_arena" that takes arena as Arena:
    If not arena.is_active:
        Throw "Arena is not active"
    Allocator.free with address as arena.backing_memory
    Set arena.is_active to false
    Note: Remove from active arenas list
    Let updated_arenas be list
    For each active_arena in active_arenas:
        If active_arena.name is not equal to arena.name:
            Add active_arena to updated_arenas
    Set active_arenas to updated_arenas

Note: Arena allocation functions
Process called "arena_alloc" that takes arena as Arena and size as Integer returns Integer:
    Return arena_alloc_aligned with arena as arena and size as size and alignment as arena.alignment

Process called "arena_alloc_aligned" that takes arena as Arena and size as Integer and alignment as Integer returns Integer:
    If not arena.is_active:
        Throw "Cannot allocate from inactive arena"
    If size is less than or equal to 0:
        Throw "Allocation size must be positive"
    Let aligned_size be align_up with value as size and alignment as alignment
    Let current_pos be align_up with value as arena.used and alignment as alignment
    If current_pos + aligned_size is greater than arena.size:
        Throw "Arena out of memory: not enough space for allocation"
    Let allocation_address be arena.backing_memory + current_pos
    Set arena.used to current_pos + aligned_size
    Set arena.allocation_count to arena.allocation_count + 1
    Return allocation_address

Process called "arena_alloc_zero" that takes arena as Arena and size as Integer returns Integer:
    Let address be arena_alloc with arena as arena and size as size
    Allocator.memory_zero with address as address and size as size
    Return address

Process called "arena_calloc" that takes arena as Arena and count as Integer and element_size as Integer returns Integer:
    Let total_size be count multiplied by element_size
    If total_size divided by element_size is not equal to count:
        Throw "Integer overflow in arena_calloc"
    Return arena_alloc_zero with arena as arena and size as total_size

Note: Arena reset and checkpoint functionality
Process called "arena_reset" that takes arena as Arena:
    If not arena.is_active:
        Throw "Cannot reset inactive arena"
    Set arena.used to 0
    Set arena.allocation_count to 0
    Set arena.checkpoints to list

Process called "arena_checkpoint" that takes arena as Arena returns ArenaCheckpoint:
    Return arena_named_checkpoint with arena as arena and name as "checkpoint_" followed by List.length with lst as arena.checkpoints

Process called "arena_named_checkpoint" that takes arena as Arena and name as String returns ArenaCheckpoint:
    Let checkpoint be ArenaCheckpoint with:
        used_bytes as arena.used
        allocation_count as arena.allocation_count
        timestamp as get_current_time()
        name as name
    Add checkpoint to arena.checkpoints
    Return checkpoint

Process called "arena_restore_checkpoint" that takes arena as Arena and checkpoint as ArenaCheckpoint:
    If not arena.is_active:
        Throw "Cannot restore checkpoint on inactive arena"
    If checkpoint.used_bytes is greater than arena.size:
        Throw "Invalid checkpoint: used_bytes exceeds arena size"
    Set arena.used to checkpoint.used_bytes
    Set arena.allocation_count to checkpoint.allocation_count
    Note: Remove checkpoints created after this one
    Let filtered_checkpoints be list
    For each cp in arena.checkpoints:
        If cp.timestamp is less than or equal to checkpoint.timestamp:
            Add cp to filtered_checkpoints
    Set arena.checkpoints to filtered_checkpoints

Note: Arena scoping for RAII-style management
Process called "with_arena_scope" that takes arena as Arena and action as Process returns Any:
    Let checkpoint be arena_checkpoint with arena as arena
    Try:
        Return action()
    Finally:
        arena_restore_checkpoint with arena as arena and checkpoint as checkpoint

Process called "create_arena_scope" that takes arena as Arena returns ArenaScope:
    Let checkpoint be arena_checkpoint with arena as arena
    Return ArenaScope with:
        arena as arena
        checkpoint as checkpoint
        is_active as true

Process called "exit_arena_scope" that takes scope as ArenaScope:
    If scope.is_active:
        arena_restore_checkpoint with arena as scope.arena and checkpoint as scope.checkpoint
    Set scope.is_active to false

Note: Thread-local arena management
Process called "get_thread_arena" returns Arena:
    Let thread_id be get_current_thread_id()
    If thread_id is in thread_local_arenas:
        Return thread_local_arenas[thread_id]
    Let thread_arena be create_named_arena with size as DEFAULT_ARENA_SIZE and name as "thread_" followed by thread_id
    Set thread_local_arenas[thread_id] to thread_arena
    Return thread_arena

Process called "thread_alloc" that takes size as Integer returns Integer:
    Let thread_arena be get_thread_arena()
    Return arena_alloc with arena as thread_arena and size as size

Process called "thread_alloc_aligned" that takes size as Integer and alignment as Integer returns Integer:
    Let thread_arena be get_thread_arena()
    Return arena_alloc_aligned with arena as thread_arena and size as size and alignment as alignment

Process called "reset_thread_arena":
    Let thread_id be get_current_thread_id()
    If thread_id is in thread_local_arenas:
        arena_reset with arena as thread_local_arenas[thread_id]

Process called "destroy_thread_arena":
    Let thread_id be get_current_thread_id()
    If thread_id is in thread_local_arenas:
        destroy_arena with arena as thread_local_arenas[thread_id]
        Remove thread_local_arenas[thread_id]

Note: Arena introspection and debugging
Process called "get_arena_stats" that takes arena as Arena returns Dictionary[String, Any]:
    Return dictionary with:
        "name" as arena.name
        "total_size" as arena.size
        "used_bytes" as arena.used
        "free_bytes" as arena.size - arena.used
        "utilization" as arena.used divided by arena.size
        "allocation_count" as arena.allocation_count
        "checkpoint_count" as List.length with lst as arena.checkpoints
        "is_active" as arena.is_active
        "created_time" as arena.created_time

Process called "dump_arena_info" that takes arena as Arena:
    Let stats be get_arena_stats with arena as arena
    Display "Arena: " with stats["name"]
    Display " Size: " with stats["total_size"] with " bytes"
    Display " Used: " with stats["used_bytes"] with " bytes (" with stats["utilization"] multiplied by 100 with "%)"
    Display " Free: " with stats["free_bytes"] with " bytes"
    Display " Allocations: " with stats["allocation_count"]
    Display " Checkpoints: " with stats["checkpoint_count"]
    Display " Active: " with stats["is_active"]

Process called "dump_all_arenas":
    Display "Active Arenas:"
    For each arena in active_arenas:
        dump_arena_info with arena as arena

Process called "get_total_arena_memory" returns Integer:
    Let total be 0
    For each arena in active_arenas:
        If arena.is_active:
            Set total to total + arena.size
    Return total

Process called "get_total_arena_usage" returns Integer:
    Let total be 0
    For each arena in active_arenas:
        If arena.is_active:
            Set total to total + arena.used
    Return total

Note: Utility functions
Process called "align_up" that takes value as Integer and alignment as Integer returns Integer:
    Return value alignment - 1 divided by alignment multiplied by alignment

Process called "get_current_time" returns Float:
    Note: Get high-precision monotonic timestamp
    Try:
        Import "time" as Time
        Return Time.get_monotonic_time
    Catch import_error:
        Try:
            Import "os.system.time" as SystemTime
            Return SystemTime.get_current_timestamp_ms as Float divided by 1000.0
        Catch system_error:
            Return 1640995200.0  Note: Fixed timestamp for deterministic behavior

Process called "get_current_thread_id" returns Integer:
    Note: Get OS thread identifier
    Try:
        Import "os.threads" as OSThreads
        Return OSThreads.get_current_thread_id
    Catch import_error:
        Try:
            Import "concurrent.threads" as Threads
            Return Threads.get_current_thread_id
        Catch thread_error:
            Try:
                Import "runtime.thread_local" as ThreadLocal
                Return ThreadLocal.get_thread_id
            Catch runtime_error:
                Note: Fallback to process-based ID
                Return get_fallback_thread_id

Note: Helper functions for thread-safe arena operations
Process called "get_fallback_thread_id" returns Integer:
    Note: Generate thread-like ID when OS thread support unavailable
    Try:
        Import "os" as OS
        Return OS.get_process_id  Note: Use process ID as fallback
    Catch error:
        Note: Use arena-specific counter as last resort
        Return get_next_arena_thread_id

Let global_arena_thread_counter be 0

Process called "get_next_arena_thread_id" returns Integer:
    Set global_arena_thread_counter to global_arena_thread_counter plus 1
    Return global_arena_thread_counter

Note: Per-thread arena management for better performance
Process called "get_thread_local_arena" that takes size as Integer returns Arena:
    Note: Get or create arena for current thread
    Let thread_id be get_current_thread_id
    Let arena_key be "thread_" plus thread_id as String
    
    If thread_local_arenas contains arena_key:
        Let existing_arena be thread_local_arenas[arena_key]
        If existing_arena.is_active and existing_arena.size is greater than or equal to size:
            Return existing_arena
    
    Note: Create new thread-local arena
    Let new_arena be create_arena with size as size
    Set new_arena.owner_thread_id to thread_id
    Set thread_local_arenas[arena_key] to new_arena
    Return new_arena

Let thread_local_arenas be Dictionary[String, Arena]

Process called "cleanup_thread_arenas" that takes thread_id as Integer returns Void:
    Note: Clean up arenas when thread terminates
    Let arena_key be "thread_" plus thread_id as String
    If thread_local_arenas contains arena_key:
        Let arena be thread_local_arenas[arena_key]
        Call destroy_arena with arena as arena
        Remove thread_local_arenas[arena_key]

Note: Epoch-based memory reclamation for lock-free arenas
Process called "create_epoch_arena" that takes size as Integer returns Arena:
    Note: Create arena with epoch-based reclamation
    Let arena be create_arena with size as size
    Set arena.epoch_counter to 0
    Set arena.pending_deallocations to list containing
    Return arena

Process called "epoch_arena_alloc" that takes arena as Arena and size as Integer returns Integer:
    Note: Allocate with current epoch tracking
    Let current_epoch be arena.epoch_counter
    Let address be arena_alloc with arena as arena and size as size
    
    Note: Track allocation epoch for safe reclamation
    If address is not equal to 0:
        Let allocation_record be dictionary containing:
            "address" as address
            "size" as size
            "epoch" as current_epoch
            "thread_id" as get_current_thread_id
        Add allocation_record to arena.allocation_history
    
    Return address

Process called "advance_epoch" that takes arena as Arena returns Void:
    Note: Advance epoch and process safe deallocations
    Set arena.epoch_counter to arena.epoch_counter plus 1
    
    Note: Process deallocations from previous epochs
    Let safe_epoch be arena.epoch_counter minus 2  Note: Grace period
    Let remaining_deallocations be list containing
    
    For each dealloc in arena.pending_deallocations:
        If dealloc["epoch"] as Integer is less than safe_epoch:
            Note: Safe to deallocate now
            Call arena_free with arena as arena and address as dealloc["address"] as Integer
        Otherwise:
            Add dealloc to remaining_deallocations
    
    Set arena.pending_deallocations to remaining_deallocations

Process called "epoch_arena_free" that takes arena as Arena and address as Integer returns Void:
    Note: Schedule deferred deallocation
    Let deallocation_record be dictionary containing:
        "address" as address
        "epoch" as arena.epoch_counter
        "thread_id" as get_current_thread_id
    Add deallocation_record to arena.pending_deallocations

Note: Arena validation and safety checks
Process called "validate_arena" that takes arena as Arena returns Boolean:
    If not arena.is_active:
        Return false
    If arena.used is greater than arena.size:
        Return false
    If arena.used is less than 0:
        Return false
    If arena.backing_memory is equal to 0:
        Return false
    Return true

Process called "arena_contains" that takes arena as Arena and address as Integer returns Boolean:
    Return address is greater than or equal to arena.backing_memory and 
        address is less than arena.backing_memory + arena.size

Process called "find_arena_for_address" that takes address as Integer returns Optional[Arena]:
    For each arena in active_arenas:
        If arena_contains with arena as arena and address as address:
            Return Some(arena)
    Return None