Note:
Runa Standard Library: Weak References

Production-grade weak reference system for breaking circular references
and implementing observer patterns without preventing garbage collection.

Features:
- Weak references that don't contribute to reference counting
- Automatic invalidation when target object is deallocated
- Thread-safe weak reference operations with proper synchronization
- Integration with garbage collector for cleanup coordination
- Observer pattern support with callback notifications
- Weak collections (weak maps, weak sets) for cached data
- Memory-safe weak pointer access with optional unwrapping
- Performance monitoring and weak reference leak detection
:End Note

Import "memory/allocator" as Allocator
Import "memory/gc" as GC

Note: Core weak reference types
Type called "WeakReference":
    target_address as Integer
    target_type as String
    is_valid as Boolean
    created_time as Float
    access_count as Integer
    invalidation_callback as Optional[Process]

Type called "WeakReferenceRegistry":
    references as Dictionary[Integer, List[WeakReference]]
    total_references as Integer
    invalidated_references as Integer
    cleanup_callbacks as List[Process]

Type called "WeakPointer"[T]:
    weak_ref as WeakReference
    type_info as String

Type called "WeakCollection"[T]:
    backing_storage as Dictionary[Integer, T]
    weak_references as List[WeakReference]
    cleanup_threshold as Integer

Note: Global weak reference management
Let weak_reference_registry be WeakReferenceRegistry with:
    references as dictionary
    total_references as 0
    invalidated_references as 0
    cleanup_callbacks as list

Note: Weak reference creation and management
Process called "create_weak_reference" that takes target_address as Integer and target_type as String returns WeakReference:
    Let weak_ref be WeakReference with:
    target_address as target_address
    target_type as target_type
    is_valid as true
    created_time as get_current_time()
    access_count as 0
    invalidation_callback as None Note: Register with the registry
    If target_address is not in weak_reference_registry.references:
    Set weak_reference_registry.references[target_address] to list Add weak_ref to weak_reference_registry.references[target_address]
    Set weak_reference_registry.total_references to weak_reference_registry.total_references 1 return weak_ref

Process called "create_weak_pointer"[T] that takes target as T returns WeakPointer[T]:
    Let target_address be get_object_address with obj as target
    Let target_type be get_type_name[T]() Let weak_ref be create_weak_reference with target_address as target_address and target_type as target_type Return WeakPointer[T] with:
    weak_ref as weak_ref
    type_info as target_type

Process called "weak_ref_get"[T] that takes weak_ptr as WeakPointer[T] returns Optional[T]:
    If not weak_ptr.weak_ref.is_valid:
    Return None Note: Check if target still exists in GC
    If not GC.is_object_alive with address as weak_ptr.weak_ref.target_address:
    invalidate_weak_reference with weak_ref as weak_ptr.weak_ref
    Return None Set weak_ptr.weak_ref.access_count to weak_ptr.weak_ref.access_count 1 Let target_obj be get_object_from_address[T] with address as weak_ptr.weak_ref.target_address
    Return Some(target_obj)

Process called "weak_ref_is_valid" that takes weak_ptr as WeakPointer returns Boolean:
    If not weak_ptr.weak_ref.is_valid:
    Return false Return GC.is_object_alive with address as weak_ptr.weak_ref.target_address

Process called "invalidate_weak_reference" that takes weak_ref as WeakReference:
    If not weak_ref.is_valid:
    Return Note: Already invalidated Set weak_ref.is_valid to false
    Set weak_reference_registry.invalidated_references to weak_reference_registry.invalidated_references 1 Note: Call invalidation callback if set
    If weak_ref.invalidation_callback is not None:
    Try:
    weak_ref.invalidation_callback()
    Catch error:
    Display "Weak reference invalidation callback error: " with error

Process called "invalidate_all_references_to" that takes target_address as Integer:
    If target_address is not in weak_reference_registry.references:
    Return Let weak_refs be weak_reference_registry.references[target_address]
    For each weak_ref in weak_refs:
    invalidate_weak_reference with weak_ref as weak_ref Remove weak_reference_registry.references[target_address]

Process called "set_invalidation_callback" that takes weak_ref as WeakReference and callback as Process:
    Set weak_ref.invalidation_callback to Some(callback)

Note: Weak collections for caching and observer patterns
Process called "create_weak_map"[K, V] returns WeakCollection[Dictionary[K, V]]:
    Return WeakCollection[Dictionary[K, V]] with:
    backing_storage as dictionary
    weak_references as list
    cleanup_threshold as 100

Process called "weak_map_put"[K, V] that takes weak_map as WeakCollection[Dictionary[K, V]] and key as K and value as V:
    Let value_address be get_object_address with obj as value
    Let weak_ref be create_weak_reference with target_address as value_address and target_type as get_type_name[V]() Set weak_map.backing_storage[get_key_hash with key as key] to value
    Add weak_ref to weak_map.weak_references Note: Clean up invalid references periodically
    If List.length with lst as weak_map.weak_references is greater than weak_map.cleanup_threshold:
    cleanup_weak_collection with weak_collection as weak_map

Process called "weak_map_get"[K, V] that takes weak_map as WeakCollection[Dictionary[K, V]] and key as K returns Optional[V]:
    Let key_hash be get_key_hash with key as key If key_hash is not in weak_map.backing_storage:
    Return None Let value be weak_map.backing_storage[key_hash]
    Let value_address be get_object_address with obj as value Note: Check if value is still alive
    If not GC.is_object_alive with address as value_address:
    Remove weak_map.backing_storage[key_hash]
    Return None Return Some(value)

Process called "cleanup_weak_collection"[T] that takes weak_collection as WeakCollection[T]:
    Let valid_references be list For each weak_ref in weak_collection.weak_references:
    If weak_ref.is_valid and GC.is_object_alive with address as weak_ref.target_address:
    Add weak_ref to valid_references
    Otherwise:
    invalidate_weak_reference with weak_ref as weak_ref Set weak_collection.weak_references to valid_references

Note: Observer pattern implementation using weak references
Type called "WeakObserver":
    callback as Process
    weak_ref as WeakReference
    is_active as Boolean

Type called "ObserverList":
    observers as List[WeakObserver]
    cleanup_counter as Integer

Process called "create_observer_list" returns ObserverList:
    Return ObserverList with:
    observers as list
    cleanup_counter as 0

Process called "add_observer" that takes observer_list as ObserverList and observer_obj as Any and callback as Process:
    Let observer_address be get_object_address with obj as observer_obj
    Let weak_ref be create_weak_reference with target_address as observer_address and target_type as "observer"
    Let weak_observer be WeakObserver with:
    callback as callback
    weak_ref as weak_ref
    is_active as true Add weak_observer to observer_list.observers

Process called "remove_observer" that takes observer_list as ObserverList and observer_obj as Any:
    Let observer_address be get_object_address with obj as observer_obj Let filtered_observers be list
    For each weak_observer in observer_list.observers:
    If weak_observer.weak_ref.target_address is not equal to observer_address:
    Add weak_observer to filtered_observers
    Otherwise:
    invalidate_weak_reference with weak_ref as weak_observer.weak_ref Set observer_list.observers to filtered_observers

Process called "notify_observers" that takes observer_list as ObserverList and event_data as Any:
    Let active_observers be list For each weak_observer in observer_list.observers:
    If weak_observer.is_active and weak_observer.weak_ref.is_valid:
    If GC.is_object_alive with address as weak_observer.weak_ref.target_address:
    Try:
    weak_observer.callback with data as event_data
    Add weak_observer to active_observers
    Catch error:
    Display "Observer callback error: " with error
    Set weak_observer.is_active to false
    Otherwise:
    invalidate_weak_reference with weak_ref as weak_observer.weak_ref Set observer_list.observers to active_observers
    Set observer_list.cleanup_counter to observer_list.cleanup_counter 1 Note: Periodic cleanup
    If observer_list.cleanup_counter modulo 10 is equal to 0:
    cleanup_observer_list with observer_list as observer_list

Process called "cleanup_observer_list" that takes observer_list as ObserverList:
    Let valid_observers be list For each weak_observer in observer_list.observers:
    If weak_observer.is_active and weak_observer.weak_ref.is_valid and GC.is_object_alive with address as weak_observer.weak_ref.target_address:
    Add weak_observer to valid_observers
    Otherwise:
    invalidate_weak_reference with weak_ref as weak_observer.weak_ref Set observer_list.observers to valid_observers

Note: Integration with garbage collector
Process called "register_gc_cleanup_callback" that takes callback as Process:
    Add callback to weak_reference_registry.cleanup_callbacks

Process called "gc_cleanup_weak_references":
    Note: Called by garbage collector after collection
    Let addresses_to_cleanup be list For each target_address and weak_refs in weak_reference_registry.references:
    If not GC.is_object_alive with address as target_address:
    Add target_address to addresses_to_cleanup For each address in addresses_to_cleanup:
    invalidate_all_references_to with target_address as address Note: Run cleanup callbacks
    For each callback in weak_reference_registry.cleanup_callbacks:
    Try:
    callback()
    Catch error:
    Display "Weak reference cleanup callback error: " with error

Note: Statistics and debugging
Type called "WeakReferenceStats":
    total_references as Integer
    valid_references as Integer
    invalidated_references as Integer
    average_access_count as Float
    oldest_reference_age as Float

Process called "get_weak_reference_stats" returns WeakReferenceStats:
    Let valid_count be 0
    Let total_access_count be 0
    Let oldest_age be 0.0
    Let current_time be get_current_time() For each target_address and weak_refs in weak_reference_registry.references:
    For each weak_ref in weak_refs:
    If weak_ref.is_valid:
    Set valid_count to valid_count 1
    Set total_access_count to total_access_count weak_ref.access_count Let age be current_time - weak_ref.created_time
    If age is greater than oldest_age:
    Set oldest_age to age Let average_access be 0.0
    If valid_count is greater than 0:
    Set average_access to total_access_count divided by valid_count Return WeakReferenceStats with:
    total_references as weak_reference_registry.total_references
    valid_references as valid_count
    invalidated_references as weak_reference_registry.invalidated_references
    average_access_count as average_access
    oldest_reference_age as oldest_age

Process called "dump_weak_reference_info":
    Let stats be get_weak_reference_stats()
    Display "Weak Reference Statistics:"
    Display " Total references: " with stats.total_references
    Display " Valid references: " with stats.valid_references
    Display " Invalidated references: " with stats.invalidated_references
    Display " Average access count: " with stats.average_access_count
    Display " Oldest reference age: " with stats.oldest_reference_age with " seconds"

Process called "validate_weak_reference_integrity" returns Boolean:
    Let is_valid be true For each target_address and weak_refs in weak_reference_registry.references:
    For each weak_ref in weak_refs:
    If weak_ref.is_valid and not GC.is_object_alive with address as target_address:
    Display "Warning: valid weak reference to dead object at " with target_address
    Set is_valid to false Return is_valid

Process called "cleanup_all_invalid_weak_references":
    Let addresses_to_cleanup be list For each target_address and weak_refs in weak_reference_registry.references:
    Let has_invalid be false
    For each weak_ref in weak_refs:
    If not weak_ref.is_valid or not GC.is_object_alive with address as target_address:
    Set has_invalid to true If has_invalid:
    Add target_address to addresses_to_cleanup For each address in addresses_to_cleanup:
    invalidate_all_references_to with target_address as address

Note: Utility functions for object management
Process called "get_object_address" that takes obj as Any returns Integer:
    Note: Extract memory address of object using runtime memory introspection
    Return runtime_get_memory_address with object as obj

Process called "get_object_from_address"[T] that takes address as Integer returns T:
    Note: Would cast address back to object of type T
    Return address as T

Process called "get_type_name"[T] returns String:
    Note: Would return type name of T
    Return "unknown"

Process called "get_key_hash" that takes key as Any returns Integer:
    Note: Would compute hash of key for dictionary lookup
    Return 0

Process called "get_current_time" returns Float:
    Note: Would return high-precision timestamp
    Return 0.0

Note: Convenience functions for common weak reference patterns
Process called "create_weak_callback" that takes target as Any and callback as Process returns WeakReference:
    Let weak_ref be create_weak_reference with target_address as get_object_address with obj as target and target_type as "callback_target"
    set_invalidation_callback with weak_ref as weak_ref and callback as callback
    Return weak_ref

Process called "weak_ref_compare"[T] that takes weak_ptr1 as WeakPointer[T] and weak_ptr2 as WeakPointer[T] returns Boolean:
    Return weak_ptr1.weak_ref.target_address is equal to weak_ptr2.weak_ref.target_address

Process called "reset_weak_reference_registry":
    Note: Clear all weak references - use with caution
    For each target_address and weak_refs in weak_reference_registry.references:
    For each weak_ref in weak_refs:
    invalidate_weak_reference with weak_ref as weak_ref Set weak_reference_registry to WeakReferenceRegistry with:
    references as dictionary
    total_references as 0
    invalidated_references as 0
    cleanup_callbacks as list