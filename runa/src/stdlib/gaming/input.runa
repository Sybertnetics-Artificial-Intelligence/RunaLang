Note: Gaming Input System
Note: Comprehensive input handling for games including keyboard, mouse, and gamepad support
Note: Provides input state management, event handling, and input mapping
:End Note

Import "gaming/core" as core
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "string/format" as string_utils
Import "datetime/datetime" as datetime_module
Import "errors/errors" as error_handling

Note: Input Types and States

Type KeyCode is:
    | KEY_SPACE
    | KEY_ENTER
    | KEY_ESCAPE
    | KEY_BACKSPACE
    | KEY_TAB
    | KEY_SHIFT_LEFT
    | KEY_SHIFT_RIGHT
    | KEY_CTRL_LEFT
    | KEY_CTRL_RIGHT
    | KEY_ALT_LEFT
    | KEY_ALT_RIGHT
    | KEY_ARROW_UP
    | KEY_ARROW_DOWN
    | KEY_ARROW_LEFT
    | KEY_ARROW_RIGHT
    | KEY_A | KEY_B | KEY_C | KEY_D | KEY_E | KEY_F | KEY_G | KEY_H
    | KEY_I | KEY_J | KEY_K | KEY_L | KEY_M | KEY_N | KEY_O | KEY_P
    | KEY_Q | KEY_R | KEY_S | KEY_T | KEY_U | KEY_V | KEY_W | KEY_X
    | KEY_Y | KEY_Z
    | KEY_0 | KEY_1 | KEY_2 | KEY_3 | KEY_4 | KEY_5 | KEY_6 | KEY_7
    | KEY_8 | KEY_9
    | KEY_F1 | KEY_F2 | KEY_F3 | KEY_F4 | KEY_F5 | KEY_F6
    | KEY_F7 | KEY_F8 | KEY_F9 | KEY_F10 | KEY_F11 | KEY_F12

Type MouseButton is:
    | MOUSE_LEFT
    | MOUSE_RIGHT
    | MOUSE_MIDDLE
    | MOUSE_X1
    | MOUSE_X2

Type GamepadButton is:
    | GAMEPAD_A
    | GAMEPAD_B
    | GAMEPAD_X
    | GAMEPAD_Y
    | GAMEPAD_LEFT_BUMPER
    | GAMEPAD_RIGHT_BUMPER
    | GAMEPAD_BACK
    | GAMEPAD_START
    | GAMEPAD_GUIDE
    | GAMEPAD_LEFT_THUMB
    | GAMEPAD_RIGHT_THUMB
    | GAMEPAD_DPAD_UP
    | GAMEPAD_DPAD_RIGHT
    | GAMEPAD_DPAD_DOWN
    | GAMEPAD_DPAD_LEFT

Type InputState is:
    | RELEASED
    | PRESSED
    | HELD
    | JUST_PRESSED
    | JUST_RELEASED

Type InputEvent is Dictionary with:
    event_type as String
    timestamp as Integer
    key_code as KeyCode
    mouse_button as MouseButton
    gamepad_button as GamepadButton
    mouse_position as core.Vector2D
    mouse_delta as core.Vector2D
    wheel_delta as core.Vector2D
    gamepad_id as Integer
    axis_values as Dictionary[String, Float]
    modifiers as Dictionary[String, Boolean]
    metadata as Dictionary[String, String]

Type InputManager is Dictionary with:
    keyboard_state as Dictionary[KeyCode, InputState]
    mouse_state as Dictionary[MouseButton, InputState]
    gamepad_states as Dictionary[Integer, Dictionary[GamepadButton, InputState]]
    mouse_position as core.Vector2D
    mouse_delta as core.Vector2D
    wheel_delta as core.Vector2D
    event_queue as List[InputEvent]
    input_mappings as Dictionary[String, List[Any]]
    frame_counter as Integer
    metadata as Dictionary[String, String]

Type InputMapping is Dictionary with:
    action_name as String
    input_sources as List[Any]
    threshold as Float
    metadata as Dictionary[String, String]

Note: Input Manager Creation and Management

Process create_input_manager:
    Let keyboard_state be dict_utils.create_empty_dict
    Let mouse_state be dict_utils.create_empty_dict
    Let gamepad_states be dict_utils.create_empty_dict
    Let mouse_pos be core.create_vector2d with x as 0.0 and y as 0.0
    Let mouse_delta be core.create_vector2d with x as 0.0 and y as 0.0
    Let wheel_delta be core.create_vector2d with x as 0.0 and y as 0.0
    Let event_queue be list_utils.create_empty_list
    Let input_mappings be dict_utils.create_empty_dict
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "input_manager"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    Call dict_utils.set_value with dict as metadata and key as "version" and value as "1.0.0"
    
    Return InputManager with:
        keyboard_state as keyboard_state and
        mouse_state as mouse_state and
        gamepad_states as gamepad_states and
        mouse_position as mouse_pos and
        mouse_delta as mouse_delta and
        wheel_delta as wheel_delta and
        event_queue as event_queue and
        input_mappings as input_mappings and
        frame_counter as 0 and
        metadata as metadata

Process update_input_manager with manager as InputManager:
    Note: Update input states for frame transitions (JUST_PRESSED -> HELD, etc.)
    For Each key_code in dict_utils.get_keys with dict as manager.keyboard_state:
        Let current_state be dict_utils.get_value with dict as manager.keyboard_state and key as key_code
        Match current_state:
            When JUST_PRESSED:
                Call dict_utils.set_value with dict as manager.keyboard_state and key as key_code and value as HELD
            When JUST_RELEASED:
                Call dict_utils.set_value with dict as manager.keyboard_state and key as key_code and value as RELEASED
    
    For Each mouse_button in dict_utils.get_keys with dict as manager.mouse_state:
        Let current_state be dict_utils.get_value with dict as manager.mouse_state and key as mouse_button
        Match current_state:
            When JUST_PRESSED:
                Call dict_utils.set_value with dict as manager.mouse_state and key as mouse_button and value as HELD
            When JUST_RELEASED:
                Call dict_utils.set_value with dict as manager.mouse_state and key as mouse_button and value as RELEASED
    
    For Each gamepad_id in dict_utils.get_keys with dict as manager.gamepad_states:
        Let gamepad_state be dict_utils.get_value with dict as manager.gamepad_states and key as gamepad_id
        For Each button in dict_utils.get_keys with dict as gamepad_state:
            Let current_state be dict_utils.get_value with dict as gamepad_state and key as button
            Match current_state:
                When JUST_PRESSED:
                    Call dict_utils.set_value with dict as gamepad_state and key as button and value as HELD
                When JUST_RELEASED:
                    Call dict_utils.set_value with dict as gamepad_state and key as button and value as RELEASED
    
    Set manager.frame_counter to manager.frame_counter plus 1
    Call list_utils.clear with list as manager.event_queue
    
    Note: Reset mouse delta for next frame
    Set manager.mouse_delta to core.create_vector2d with x as 0.0 and y as 0.0
    Set manager.wheel_delta to core.create_vector2d with x as 0.0 and y as 0.0

Note: Keyboard Input Handling

Process process_key_event with manager as InputManager and key_code as KeyCode and is_pressed as Boolean:
    Let current_state be dict_utils.get_value_with_default with dict as manager.keyboard_state and key as key_code and default as RELEASED
    Let new_state be RELEASED
    
    If is_pressed:
        Match current_state:
            When RELEASED:
                Set new_state to JUST_PRESSED
            Otherwise:
                Set new_state to HELD
    Otherwise:
        Match current_state:
            When PRESSED:
                Set new_state to JUST_RELEASED
            When HELD:
                Set new_state to JUST_RELEASED
            Otherwise:
                Set new_state to RELEASED
    
    Call dict_utils.set_value with dict as manager.keyboard_state and key as key_code and value as new_state
    
    Note: Create and queue input event
    Let event be create_input_event_key with key_code as key_code and state as new_state
    Call list_utils.append with list as manager.event_queue and item as event

Process is_key_pressed with manager as InputManager and key_code as KeyCode:
    Let state be dict_utils.get_value_with_default with dict as manager.keyboard_state and key as key_code and default as RELEASED
    Return state is equal to PRESSED or state is equal to HELD

Process is_key_just_pressed with manager as InputManager and key_code as KeyCode:
    Let state be dict_utils.get_value_with_default with dict as manager.keyboard_state and key as key_code and default as RELEASED
    Return state is equal to JUST_PRESSED

Process is_key_just_released with manager as InputManager and key_code as KeyCode:
    Let state be dict_utils.get_value_with_default with dict as manager.keyboard_state and key as key_code and default as RELEASED
    Return state is equal to JUST_RELEASED

Process get_pressed_keys with manager as InputManager:
    Let pressed_keys be list_utils.create_empty_list
    For Each key_code in dict_utils.get_keys with dict as manager.keyboard_state:
        Let state be dict_utils.get_value with dict as manager.keyboard_state and key as key_code
        If state is equal to PRESSED or state is equal to HELD:
            Call list_utils.append with list as pressed_keys and item as key_code
    Return pressed_keys

Note: Mouse Input Handling

Process process_mouse_button_event with manager as InputManager and button as MouseButton and is_pressed as Boolean:
    Let current_state be dict_utils.get_value_with_default with dict as manager.mouse_state and key as button and default as RELEASED
    Let new_state be RELEASED
    
    If is_pressed:
        Match current_state:
            When RELEASED:
                Set new_state to JUST_PRESSED
            Otherwise:
                Set new_state to HELD
    Otherwise:
        Match current_state:
            When PRESSED:
                Set new_state to JUST_RELEASED
            When HELD:
                Set new_state to JUST_RELEASED
            Otherwise:
                Set new_state to RELEASED
    
    Call dict_utils.set_value with dict as manager.mouse_state and key as button and value as new_state
    
    Let event be create_input_event_mouse with button as button and position as manager.mouse_position and state as new_state
    Call list_utils.append with list as manager.event_queue and item as event

Process process_mouse_move_event with manager as InputManager and x as Float and y as Float:
    Let new_position be core.create_vector2d with x as x and y as y
    Let delta be core.vector2d_subtract with a as new_position and b as manager.mouse_position
    
    Set manager.mouse_position to new_position
    Set manager.mouse_delta to core.vector2d_add with a as manager.mouse_delta and b as delta
    
    Let event be create_input_event_mouse_move with position as new_position and delta as delta
    Call list_utils.append with list as manager.event_queue and item as event

Process process_mouse_wheel_event with manager as InputManager and delta_x as Float and delta_y as Float:
    Let wheel_delta be core.create_vector2d with x as delta_x and y as delta_y
    Set manager.wheel_delta to core.vector2d_add with a as manager.wheel_delta and b as wheel_delta
    
    Let event be create_input_event_mouse_wheel with delta as wheel_delta
    Call list_utils.append with list as manager.event_queue and item as event

Process is_mouse_button_pressed with manager as InputManager and button as MouseButton:
    Let state be dict_utils.get_value_with_default with dict as manager.mouse_state and key as button and default as RELEASED
    Return state is equal to PRESSED or state is equal to HELD

Process is_mouse_button_just_pressed with manager as InputManager and button as MouseButton:
    Let state be dict_utils.get_value_with_default with dict as manager.mouse_state and key as button and default as RELEASED
    Return state is equal to JUST_PRESSED

Process is_mouse_button_just_released with manager as InputManager and button as MouseButton:
    Let state be dict_utils.get_value_with_default with dict as manager.mouse_state and key as button and default as RELEASED
    Return state is equal to JUST_RELEASED

Process get_mouse_position with manager as InputManager:
    Return manager.mouse_position

Process get_mouse_delta with manager as InputManager:
    Return manager.mouse_delta

Process get_mouse_wheel_delta with manager as InputManager:
    Return manager.wheel_delta

Note: Gamepad Input Handling

Process register_gamepad with manager as InputManager and gamepad_id as Integer:
    If not dict_utils.has_key with dict as manager.gamepad_states and key as gamepad_id:
        Let gamepad_state be dict_utils.create_empty_dict
        Call dict_utils.set_value with dict as manager.gamepad_states and key as gamepad_id and value as gamepad_state
        Return true
    Return false

Process unregister_gamepad with manager as InputManager and gamepad_id as Integer:
    If dict_utils.has_key with dict as manager.gamepad_states and key as gamepad_id:
        Call dict_utils.remove_key with dict as manager.gamepad_states and key as gamepad_id
        Return true
    Return false

Process process_gamepad_button_event with manager as InputManager and gamepad_id as Integer and button as GamepadButton and is_pressed as Boolean:
    If not dict_utils.has_key with dict as manager.gamepad_states and key as gamepad_id:
        Call register_gamepad with manager as manager and gamepad_id as gamepad_id
    
    Let gamepad_state be dict_utils.get_value with dict as manager.gamepad_states and key as gamepad_id
    Let current_state be dict_utils.get_value_with_default with dict as gamepad_state and key as button and default as RELEASED
    Let new_state be RELEASED
    
    If is_pressed:
        Match current_state:
            When RELEASED:
                Set new_state to JUST_PRESSED
            Otherwise:
                Set new_state to HELD
    Otherwise:
        Match current_state:
            When PRESSED:
                Set new_state to JUST_RELEASED
            When HELD:
                Set new_state to JUST_RELEASED
            Otherwise:
                Set new_state to RELEASED
    
    Call dict_utils.set_value with dict as gamepad_state and key as button and value as new_state
    
    Let event be create_input_event_gamepad with gamepad_id as gamepad_id and button as button and state as new_state
    Call list_utils.append with list as manager.event_queue and item as event

Process is_gamepad_button_pressed with manager as InputManager and gamepad_id as Integer and button as GamepadButton:
    If not dict_utils.has_key with dict as manager.gamepad_states and key as gamepad_id:
        Return false
    
    Let gamepad_state be dict_utils.get_value with dict as manager.gamepad_states and key as gamepad_id
    Let state be dict_utils.get_value_with_default with dict as gamepad_state and key as button and default as RELEASED
    Return state is equal to PRESSED or state is equal to HELD

Process is_gamepad_button_just_pressed with manager as InputManager and gamepad_id as Integer and button as GamepadButton:
    If not dict_utils.has_key with dict as manager.gamepad_states and key as gamepad_id:
        Return false
    
    Let gamepad_state be dict_utils.get_value with dict as manager.gamepad_states and key as gamepad_id
    Let state be dict_utils.get_value_with_default with dict as gamepad_state and key as button and default as RELEASED
    Return state is equal to JUST_PRESSED

Process get_connected_gamepads with manager as InputManager:
    Return dict_utils.get_keys with dict as manager.gamepad_states

Note: Input Mapping System

Process create_input_mapping with action_name as String and input_sources as List[Any] and threshold as Float:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "input_mapping"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return InputMapping with:
        action_name as action_name and
        input_sources as input_sources and
        threshold as threshold and
        metadata as metadata

Process add_input_mapping with manager as InputManager and mapping as InputMapping:
    Let existing_mappings be dict_utils.get_value_with_default with dict as manager.input_mappings and key as mapping.action_name and default as list_utils.create_empty_list
    Call list_utils.append with list as existing_mappings and item as mapping
    Call dict_utils.set_value with dict as manager.input_mappings and key as mapping.action_name and value as existing_mappings

Process remove_input_mapping with manager as InputManager and action_name as String:
    If dict_utils.has_key with dict as manager.input_mappings and key as action_name:
        Call dict_utils.remove_key with dict as manager.input_mappings and key as action_name
        Return true
    Return false

Process is_action_pressed with manager as InputManager and action_name as String:
    If not dict_utils.has_key with dict as manager.input_mappings and key as action_name:
        Return false
    
    Let mappings be dict_utils.get_value with dict as manager.input_mappings and key as action_name
    For Each mapping in mappings:
        For Each input_source in mapping.input_sources:
            If check_input_source_active with manager as manager and input_source as input_source:
                Return true
    
    Return false

Process check_input_source_active with manager as InputManager and input_source as Any:
    Note: Check if the input source is currently active based on its type
    Match input_source:
        When key_code as KeyCode:
            Return is_key_pressed with manager as manager and key_code as key_code
        When mouse_button as MouseButton:
            Return is_mouse_button_pressed with manager as manager and button as mouse_button
        Otherwise:
            Return false

Note: Event Creation Helpers

Process create_input_event_key with key_code as KeyCode and state as InputState:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "key_event"
    
    Return InputEvent with:
        event_type as "keyboard" and
        timestamp as datetime_module.get_timestamp and
        key_code as key_code and
        mouse_button as MOUSE_LEFT and
        gamepad_button as GAMEPAD_A and
        mouse_position as core.create_vector2d with x as 0.0 and y as 0.0 and
        mouse_delta as core.create_vector2d with x as 0.0 and y as 0.0 and
        wheel_delta as core.create_vector2d with x as 0.0 and y as 0.0 and
        gamepad_id as 0 and
        axis_values as dict_utils.create_empty_dict and
        modifiers as dict_utils.create_empty_dict and
        metadata as metadata

Process create_input_event_mouse with button as MouseButton and position as core.Vector2D and state as InputState:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "mouse_button_event"
    
    Return InputEvent with:
        event_type as "mouse_button" and
        timestamp as datetime_module.get_timestamp and
        key_code as KEY_A and
        mouse_button as button and
        gamepad_button as GAMEPAD_A and
        mouse_position as position and
        mouse_delta as core.create_vector2d with x as 0.0 and y as 0.0 and
        wheel_delta as core.create_vector2d with x as 0.0 and y as 0.0 and
        gamepad_id as 0 and
        axis_values as dict_utils.create_empty_dict and
        modifiers as dict_utils.create_empty_dict and
        metadata as metadata

Process create_input_event_mouse_move with position as core.Vector2D and delta as core.Vector2D:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "mouse_move_event"
    
    Return InputEvent with:
        event_type as "mouse_move" and
        timestamp as datetime_module.get_timestamp and
        key_code as KEY_A and
        mouse_button as MOUSE_LEFT and
        gamepad_button as GAMEPAD_A and
        mouse_position as position and
        mouse_delta as delta and
        wheel_delta as core.create_vector2d with x as 0.0 and y as 0.0 and
        gamepad_id as 0 and
        axis_values as dict_utils.create_empty_dict and
        modifiers as dict_utils.create_empty_dict and
        metadata as metadata

Process create_input_event_mouse_wheel with delta as core.Vector2D:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "mouse_wheel_event"
    
    Return InputEvent with:
        event_type as "mouse_wheel" and
        timestamp as datetime_module.get_timestamp and
        key_code as KEY_A and
        mouse_button as MOUSE_LEFT and
        gamepad_button as GAMEPAD_A and
        mouse_position as core.create_vector2d with x as 0.0 and y as 0.0 and
        mouse_delta as core.create_vector2d with x as 0.0 and y as 0.0 and
        wheel_delta as delta and
        gamepad_id as 0 and
        axis_values as dict_utils.create_empty_dict and
        modifiers as dict_utils.create_empty_dict and
        metadata as metadata

Process create_input_event_gamepad with gamepad_id as Integer and button as GamepadButton and state as InputState:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "gamepad_event"
    
    Return InputEvent with:
        event_type as "gamepad" and
        timestamp as datetime_module.get_timestamp and
        key_code as KEY_A and
        mouse_button as MOUSE_LEFT and
        gamepad_button as button and
        mouse_position as core.create_vector2d with x as 0.0 and y as 0.0 and
        mouse_delta as core.create_vector2d with x as 0.0 and y as 0.0 and
        wheel_delta as core.create_vector2d with x as 0.0 and y as 0.0 and
        gamepad_id as gamepad_id and
        axis_values as dict_utils.create_empty_dict and
        modifiers as dict_utils.create_empty_dict and
        metadata as metadata

Process get_input_events with manager as InputManager:
    Return manager.event_queue

Process clear_input_events with manager as InputManager:
    Call list_utils.clear with list as manager.event_queue