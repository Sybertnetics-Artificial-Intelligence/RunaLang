Note: Gaming Core Module
Note: Essential data types and utilities for game development
Note: Provides Vector2D, Vector3D, Transform, Bounds, and foundational game math
:End Note

Import "math/core" as math_module
Import "collections/dict" as dict_utils
Import "string/format" as string_utils
Import "errors/errors" as error_handling

Note: Core Gaming Types

Type Vector2D is Dictionary with:
    x as Float
    y as Float
    metadata as Dictionary[String, String]

Type Vector3D is Dictionary with:
    x as Float
    y as Float
    z as Float
    metadata as Dictionary[String, String]

Type Transform2D is Dictionary with:
    position as Vector2D
    rotation as Float
    scale as Vector2D
    metadata as Dictionary[String, String]

Type Transform3D is Dictionary with:
    position as Vector3D
    rotation as Vector3D
    scale as Vector3D
    metadata as Dictionary[String, String]

Type Bounds2D is Dictionary with:
    min_point as Vector2D
    max_point as Vector2D
    metadata as Dictionary[String, String]

Type Bounds3D is Dictionary with:
    min_point as Vector3D
    max_point as Vector3D
    metadata as Dictionary[String, String]

Type Color is Dictionary with:
    red as Float
    green as Float
    blue as Float
    alpha as Float
    metadata as Dictionary[String, String]

Type GameResult is:
    | GameSuccess with value as Any
    | GameError with message as String and code as String

Note: Vector2D Operations

Process create_vector2d with x as Float and y as Float:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "vector2d"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return Vector2D with:
        x as x and
        y as y and
        metadata as metadata

Process vector2d_add with a as Vector2D and b as Vector2D:
    Return create_vector2d with x as a.x plus b.x and y as a.y plus b.y

Process vector2d_subtract with a as Vector2D and b as Vector2D:
    Return create_vector2d with x as a.x minus b.x and y as a.y minus b.y

Process vector2d_multiply_scalar with vector as Vector2D and scalar as Float:
    Return create_vector2d with x as vector.x multiplied by scalar and y as vector.y multiplied by scalar

Process vector2d_divide_scalar with vector as Vector2D and scalar as Float:
    If scalar is equal to 0.0:
        Return GameError with message as "Cannot divide vector by zero" and code as "DIVISION_BY_ZERO"
    
    Return GameSuccess with value as create_vector2d with x as vector.x divided by scalar and y as vector.y divided by scalar

Process vector2d_dot_product with a as Vector2D and b as Vector2D:
    Return a.x multiplied by b.x plus a.y multiplied by b.y

Process vector2d_cross_product with a as Vector2D and b as Vector2D:
    Note: 2D cross product returns scalar (z component of 3D cross product)
    Return a.x multiplied by b.y minus a.y multiplied by b.x

Process vector2d_magnitude with vector as Vector2D:
    Let squared_magnitude be vector.x multiplied by vector.x plus vector.y multiplied by vector.y
    Return math_module.square_root with value as squared_magnitude

Process vector2d_magnitude_squared with vector as Vector2D:
    Return vector.x multiplied by vector.x plus vector.y multiplied by vector.y

Process vector2d_normalize with vector as Vector2D:
    Let magnitude be vector2d_magnitude with vector as vector
    If magnitude is equal to 0.0:
        Return GameError with message as "Cannot normalize zero vector" and code as "ZERO_VECTOR_NORMALIZATION"
    
    Let normalized_vector be vector2d_divide_scalar with vector as vector and scalar as magnitude
    Match normalized_vector:
        When GameSuccess with value as normalized:
            Return GameSuccess with value as normalized
        Otherwise:
            Return normalized_vector

Process vector2d_distance with a as Vector2D and b as Vector2D:
    Let diff be vector2d_subtract with a as a and b as b
    Return vector2d_magnitude with vector as diff

Process vector2d_distance_squared with a as Vector2D and b as Vector2D:
    Let diff be vector2d_subtract with a as a and b as b
    Return vector2d_magnitude_squared with vector as diff

Process vector2d_lerp with a as Vector2D and b as Vector2D and t as Float:
    Note: Linear interpolation between two vectors
    Let clamped_t be math_module.clamp with value as t and min_value as 0.0 and max_value as 1.0
    Let diff be vector2d_subtract with a as b and b as a
    Let scaled_diff be vector2d_multiply_scalar with vector as diff and scalar as clamped_t
    Return vector2d_add with a as a and b as scaled_diff

Process vector2d_angle with vector as Vector2D:
    Note: Returns angle in radians from positive x-axis
    Return math_module.atan2 with y as vector.y and x as vector.x

Process vector2d_angle_between with a as Vector2D and b as Vector2D:
    Let dot be vector2d_dot_product with a as a and b as b
    Let mag_a be vector2d_magnitude with vector as a
    Let mag_b be vector2d_magnitude with vector as b
    Let product be mag_a multiplied by mag_b
    
    If product is equal to 0.0:
        Return 0.0
    
    Let cos_angle be dot divided by product
    Let clamped_cos be math_module.clamp with value as cos_angle and min_value as negative 1.0 and max_value as 1.0
    Return math_module.acos with value as clamped_cos

Note: Vector3D Operations

Process create_vector3d with x as Float and y as Float and z as Float:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "vector3d"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return Vector3D with:
        x as x and
        y as y and
        z as z and
        metadata as metadata

Process vector3d_add with a as Vector3D and b as Vector3D:
    Return create_vector3d with x as a.x plus b.x and y as a.y plus b.y and z as a.z plus b.z

Process vector3d_subtract with a as Vector3D and b as Vector3D:
    Return create_vector3d with x as a.x minus b.x and y as a.y minus b.y and z as a.z minus b.z

Process vector3d_multiply_scalar with vector as Vector3D and scalar as Float:
    Return create_vector3d with x as vector.x multiplied by scalar and y as vector.y multiplied by scalar and z as vector.z multiplied by scalar

Process vector3d_divide_scalar with vector as Vector3D and scalar as Float:
    If scalar is equal to 0.0:
        Return GameError with message as "Cannot divide vector by zero" and code as "DIVISION_BY_ZERO"
    
    Return GameSuccess with value as create_vector3d with x as vector.x divided by scalar and y as vector.y divided by scalar and z as vector.z divided by scalar

Process vector3d_dot_product with a as Vector3D and b as Vector3D:
    Return a.x multiplied by b.x plus a.y multiplied by b.y plus a.z multiplied by b.z

Process vector3d_cross_product with a as Vector3D and b as Vector3D:
    Let x_component be a.y multiplied by b.z minus a.z multiplied by b.y
    Let y_component be a.z multiplied by b.x minus a.x multiplied by b.z
    Let z_component be a.x multiplied by b.y minus a.y multiplied by b.x
    
    Return create_vector3d with x as x_component and y as y_component and z as z_component

Process vector3d_magnitude with vector as Vector3D:
    Let squared_magnitude be vector.x multiplied by vector.x plus vector.y multiplied by vector.y plus vector.z multiplied by vector.z
    Return math_module.square_root with value as squared_magnitude

Process vector3d_magnitude_squared with vector as Vector3D:
    Return vector.x multiplied by vector.x plus vector.y multiplied by vector.y plus vector.z multiplied by vector.z

Process vector3d_normalize with vector as Vector3D:
    Let magnitude be vector3d_magnitude with vector as vector
    If magnitude is equal to 0.0:
        Return GameError with message as "Cannot normalize zero vector" and code as "ZERO_VECTOR_NORMALIZATION"
    
    Let normalized_vector be vector3d_divide_scalar with vector as vector and scalar as magnitude
    Match normalized_vector:
        When GameSuccess with value as normalized:
            Return GameSuccess with value as normalized
        Otherwise:
            Return normalized_vector

Process vector3d_distance with a as Vector3D and b as Vector3D:
    Let diff be vector3d_subtract with a as a and b as b
    Return vector3d_magnitude with vector as diff

Process vector3d_distance_squared with a as Vector3D and b as Vector3D:
    Let diff be vector3d_subtract with a as a and b as b
    Return vector3d_magnitude_squared with vector as diff

Process vector3d_lerp with a as Vector3D and b as Vector3D and t as Float:
    Let clamped_t be math_module.clamp with value as t and min_value as 0.0 and max_value as 1.0
    Let diff be vector3d_subtract with a as b and b as a
    Let scaled_diff be vector3d_multiply_scalar with vector as diff and scalar as clamped_t
    Return vector3d_add with a as a and b as scaled_diff

Note: Transform Operations

Process create_transform2d with position as Vector2D and rotation as Float and scale as Vector2D:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "transform2d"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return Transform2D with:
        position as position and
        rotation as rotation and
        scale as scale and
        metadata as metadata

Process create_transform3d with position as Vector3D and rotation as Vector3D and scale as Vector3D:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "transform3d"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return Transform3D with:
        position as position and
        rotation as rotation and
        scale as scale and
        metadata as metadata

Process transform2d_apply_to_vector with transform as Transform2D and vector as Vector2D:
    Note: Apply scaling, rotation, then translation
    Let scaled be vector2d_multiply_scalar with vector as vector and scalar as transform.scale.x
    Let cos_angle be math_module.cosine with angle as transform.rotation
    Let sin_angle be math_module.sine with angle as transform.rotation
    
    Let rotated_x be scaled.x multiplied by cos_angle minus scaled.y multiplied by sin_angle
    Let rotated_y be scaled.x multiplied by sin_angle plus scaled.y multiplied by cos_angle
    Let rotated be create_vector2d with x as rotated_x and y as rotated_y
    
    Return vector2d_add with a as rotated and b as transform.position

Note: Bounds Operations

Process create_bounds2d with min_point as Vector2D and max_point as Vector2D:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "bounds2d"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return Bounds2D with:
        min_point as min_point and
        max_point as max_point and
        metadata as metadata

Process create_bounds3d with min_point as Vector3D and max_point as Vector3D:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "bounds3d"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return Bounds3D with:
        min_point as min_point and
        max_point as max_point and
        metadata as metadata

Process bounds2d_contains_point with bounds as Bounds2D and point as Vector2D:
    Return point.x is greater than or equal to bounds.min_point.x and
           point.x is less than or equal to bounds.max_point.x and
           point.y is greater than or equal to bounds.min_point.y and
           point.y is less than or equal to bounds.max_point.y

Process bounds2d_intersects with a as Bounds2D and b as Bounds2D:
    Return not (a.max_point.x is less than b.min_point.x or
               b.max_point.x is less than a.min_point.x or
               a.max_point.y is less than b.min_point.y or
               b.max_point.y is less than a.min_point.y)

Process bounds2d_area with bounds as Bounds2D:
    Let width be bounds.max_point.x minus bounds.min_point.x
    Let height be bounds.max_point.y minus bounds.min_point.y
    Return width multiplied by height

Process bounds3d_contains_point with bounds as Bounds3D and point as Vector3D:
    Return point.x is greater than or equal to bounds.min_point.x and
           point.x is less than or equal to bounds.max_point.x and
           point.y is greater than or equal to bounds.min_point.y and
           point.y is less than or equal to bounds.max_point.y and
           point.z is greater than or equal to bounds.min_point.z and
           point.z is less than or equal to bounds.max_point.z

Process bounds3d_volume with bounds as Bounds3D:
    Let width be bounds.max_point.x minus bounds.min_point.x
    Let height be bounds.max_point.y minus bounds.min_point.y
    Let depth be bounds.max_point.z minus bounds.min_point.z
    Return width multiplied by height multiplied by depth

Note: Color Operations

Process create_color with red as Float and green as Float and blue as Float and alpha as Float:
    Let clamped_red be math_module.clamp with value as red and min_value as 0.0 and max_value as 1.0
    Let clamped_green be math_module.clamp with value as green and min_value as 0.0 and max_value as 1.0
    Let clamped_blue be math_module.clamp with value as blue and min_value as 0.0 and max_value as 1.0
    Let clamped_alpha be math_module.clamp with value as alpha and min_value as 0.0 and max_value as 1.0
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "color"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return Color with:
        red as clamped_red and
        green as clamped_green and
        blue as clamped_blue and
        alpha as clamped_alpha and
        metadata as metadata

Process create_color_rgb with red as Float and green as Float and blue as Float:
    Return create_color with red as red and green as green and blue as blue and alpha as 1.0

Process color_lerp with a as Color and b as Color and t as Float:
    Let clamped_t be math_module.clamp with value as t and min_value as 0.0 and max_value as 1.0
    Let lerp_red be a.red plus (b.red minus a.red) multiplied by clamped_t
    Let lerp_green be a.green plus (b.green minus a.green) multiplied by clamped_t
    Let lerp_blue be a.blue plus (b.blue minus a.blue) multiplied by clamped_t
    Let lerp_alpha be a.alpha plus (b.alpha minus a.alpha) multiplied by clamped_t
    
    Return create_color with red as lerp_red and green as lerp_green and blue as lerp_blue and alpha as lerp_alpha

Process color_to_hex with color as Color:
    Let red_int be math_module.floor with value as color.red multiplied by 255.0
    Let green_int be math_module.floor with value as color.green multiplied by 255.0
    Let blue_int be math_module.floor with value as color.blue multiplied by 255.0
    
    Return string_utils.concatenate with strings as [
        "#",
        string_utils.integer_to_hex with value as red_int,
        string_utils.integer_to_hex with value as green_int,
        string_utils.integer_to_hex with value as blue_int
    ]

Note: Utility Functions

Process degrees_to_radians with degrees as Float:
    Return degrees multiplied by math_module.PI divided by 180.0

Process radians_to_degrees with radians as Float:
    Return radians multiplied by 180.0 divided by math_module.PI

Process wrap_angle with angle as Float:
    Note: Wrap angle to [-PI, PI] range
    Let wrapped be math_module.modulo with dividend as angle plus math_module.PI and divisor as 2.0 multiplied by math_module.PI
    Return wrapped minus math_module.PI