Note: Gaming Statistics and Metrics System
Note: Comprehensive game metrics tracking, performance monitoring, and player analytics
Note: Provides session tracking, achievement systems, and gameplay metrics
:End Note

Import "gaming/core" as core
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "string/format" as string_utils
Import "datetime/datetime" as datetime_module
Import "math/core" as math_module

Note: Statistics Types

Type GameSession is Dictionary with:
    session_id as String
    start_time as Integer
    end_time as Integer
    duration as Integer
    player_id as String
    game_mode as String
    level as String
    score as Integer
    events as List[GameEvent]
    metadata as Dictionary[String, String]

Type GameEvent is Dictionary with:
    event_type as String
    timestamp as Integer
    event_data as Dictionary[String, Any]
    player_id as String
    session_id as String
    metadata as Dictionary[String, String]

Type PlayerStatistics is Dictionary with:
    player_id as String
    total_playtime as Integer
    sessions_played as Integer
    high_score as Integer
    total_score as Integer
    achievements_unlocked as List[String]
    levels_completed as List[String]
    deaths as Integer
    kills as Integer
    items_collected as Integer
    distance_traveled as Float
    performance_metrics as Dictionary[String, Float]
    metadata as Dictionary[String, String]

Type Achievement is Dictionary with:
    achievement_id as String
    name as String
    description as String
    unlock_condition as String
    unlock_value as Any
    is_unlocked as Boolean
    unlock_timestamp as Integer
    progress as Float
    metadata as Dictionary[String, String]

Type PerformanceMetrics is Dictionary with:
    fps_samples as List[Float]
    frame_time_samples as List[Float]
    memory_usage_samples as List[Integer]
    draw_call_samples as List[Integer]
    vertex_count_samples as List[Integer]
    current_fps as Float
    average_fps as Float
    min_fps as Float
    max_fps as Float
    frame_time_variance as Float
    metadata as Dictionary[String, String]

Type Leaderboard is Dictionary with:
    leaderboard_id as String
    game_mode as String
    entries as List[LeaderboardEntry]
    max_entries as Integer
    sort_order as String
    metadata as Dictionary[String, String]

Type LeaderboardEntry is Dictionary with:
    rank as Integer
    player_id as String
    player_name as String
    score as Integer
    timestamp as Integer
    additional_data as Dictionary[String, Any]
    metadata as Dictionary[String, String]

Note: Game Session Management

Process create_game_session with player_id as String and game_mode as String and level as String:
    Let session_id be generate_session_id
    Let current_time be datetime_module.get_timestamp
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "game_session"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as current_time
    Call dict_utils.set_value with dict as metadata and key as "version" and value as "1.0.0"
    
    Return GameSession with:
        session_id as session_id and
        start_time as current_time and
        end_time as 0 and
        duration as 0 and
        player_id as player_id and
        game_mode as game_mode and
        level as level and
        score as 0 and
        events as list_utils.create_empty_list and
        metadata as metadata

Process end_game_session with session as GameSession:
    Let end_time be datetime_module.get_timestamp
    Set session.end_time to end_time
    Set session.duration to end_time minus session.start_time
    
    Call dict_utils.set_value with dict as session.metadata and key as "ended_at" and value as string_utils.integer_to_string with value as end_time
    Call dict_utils.set_value with dict as session.metadata and key as "duration_seconds" and value as string_utils.integer_to_string with value as session.duration
    
    Return session

Process add_session_event with session as GameSession and event_type as String and event_data as Dictionary[String, Any]:
    Let event be create_game_event with event_type as event_type and event_data as event_data and player_id as session.player_id and session_id as session.session_id
    Call list_utils.append with list as session.events and item as event
    
    Note: Update session score if event contains score data
    If dict_utils.has_key with dict as event_data and key as "score":
        Let score_delta be dict_utils.get_value with dict as event_data and key as "score"
        Set session.score to session.score plus score_delta

Process generate_session_id:
    Let timestamp be datetime_module.get_timestamp
    Let random_suffix be math_module.random_integer with min as 1000 and max as 9999
    Return string_utils.concatenate with strings as [
        "session_",
        string_utils.integer_to_string with value as timestamp,
        "_",
        string_utils.integer_to_string with value as random_suffix
    ]

Note: Game Event System

Process create_game_event with event_type as String and event_data as Dictionary[String, Any] and player_id as String and session_id as String:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "game_event"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return GameEvent with:
        event_type as event_type and
        timestamp as datetime_module.get_timestamp and
        event_data as event_data and
        player_id as player_id and
        session_id as session_id and
        metadata as metadata

Process log_player_death with session as GameSession and cause as String and position as core.Vector2D:
    Let death_data be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as death_data and key as "cause" and value as cause
    Call dict_utils.set_value with dict as death_data and key as "position_x" and value as position.x
    Call dict_utils.set_value with dict as death_data and key as "position_y" and value as position.y
    
    Call add_session_event with session as session and event_type as "player_death" and event_data as death_data

Process log_score_update with session as GameSession and score_delta as Integer and reason as String:
    Let score_data be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as score_data and key as "score" and value as score_delta
    Call dict_utils.set_value with dict as score_data and key as "reason" and value as reason
    Call dict_utils.set_value with dict as score_data and key as "new_total" and value as session.score plus score_delta
    
    Call add_session_event with session as session and event_type as "score_update" and event_data as score_data

Process log_level_completion with session as GameSession and completion_time as Float and collectibles_found as Integer:
    Let completion_data be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as completion_data and key as "completion_time" and value as completion_time
    Call dict_utils.set_value with dict as completion_data and key as "collectibles_found" and value as collectibles_found
    Call dict_utils.set_value with dict as completion_data and key as "level" and value as session.level
    
    Call add_session_event with session as session and event_type as "level_completion" and event_data as completion_data

Process log_item_collection with session as GameSession and item_type as String and item_value as Integer and position as core.Vector2D:
    Let item_data be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as item_data and key as "item_type" and value as item_type
    Call dict_utils.set_value with dict as item_data and key as "item_value" and value as item_value
    Call dict_utils.set_value with dict as item_data and key as "position_x" and value as position.x
    Call dict_utils.set_value with dict as item_data and key as "position_y" and value as position.y
    
    Call add_session_event with session as session and event_type as "item_collection" and event_data as item_data

Note: Player Statistics System

Process create_player_statistics with player_id as String:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "player_statistics"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    Call dict_utils.set_value with dict as metadata and key as "version" and value as "1.0.0"
    
    Return PlayerStatistics with:
        player_id as player_id and
        total_playtime as 0 and
        sessions_played as 0 and
        high_score as 0 and
        total_score as 0 and
        achievements_unlocked as list_utils.create_empty_list and
        levels_completed as list_utils.create_empty_list and
        deaths as 0 and
        kills as 0 and
        items_collected as 0 and
        distance_traveled as 0.0 and
        performance_metrics as dict_utils.create_empty_dict and
        metadata as metadata

Process update_player_statistics_from_session with stats as PlayerStatistics and session as GameSession:
    Set stats.total_playtime to stats.total_playtime plus session.duration
    Set stats.sessions_played to stats.sessions_played plus 1
    
    If session.score is greater than stats.high_score:
        Set stats.high_score to session.score
    Set stats.total_score to stats.total_score plus session.score
    
    Note: Process events to update specific statistics
    For Each event in session.events:
        Match event.event_type:
            When "player_death":
                Set stats.deaths to stats.deaths plus 1
            When "item_collection":
                Set stats.items_collected to stats.items_collected plus 1
            When "level_completion":
                If not list_utils.contains with list as stats.levels_completed and item as session.level:
                    Call list_utils.append with list as stats.levels_completed and item as session.level
    
    Call dict_utils.set_value with dict as stats.metadata and key as "last_updated" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp

Process calculate_player_kdr with stats as PlayerStatistics:
    If stats.deaths is equal to 0:
        Return stats.kills
    Otherwise:
        Return stats.kills divided by stats.deaths

Process calculate_average_session_score with stats as PlayerStatistics:
    If stats.sessions_played is equal to 0:
        Return 0.0
    Otherwise:
        Return stats.total_score divided by stats.sessions_played

Process calculate_average_session_duration with stats as PlayerStatistics:
    If stats.sessions_played is equal to 0:
        Return 0.0
    Otherwise:
        Return stats.total_playtime divided by stats.sessions_played

Note: Achievement System

Process create_achievement with achievement_id as String and name as String and description as String and unlock_condition as String and unlock_value as Any:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "achievement"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return Achievement with:
        achievement_id as achievement_id and
        name as name and
        description as description and
        unlock_condition as unlock_condition and
        unlock_value as unlock_value and
        is_unlocked as false and
        unlock_timestamp as 0 and
        progress as 0.0 and
        metadata as metadata

Process check_achievement_progress with achievement as Achievement and stats as PlayerStatistics:
    Let progress_value be 0.0
    
    Match achievement.unlock_condition:
        When "total_score":
            Set progress_value to stats.total_score divided by achievement.unlock_value
        When "high_score":
            Set progress_value to stats.high_score divided by achievement.unlock_value
        When "sessions_played":
            Set progress_value to stats.sessions_played divided by achievement.unlock_value
        When "total_playtime":
            Set progress_value to stats.total_playtime divided by achievement.unlock_value
        When "levels_completed":
            Set progress_value to list_utils.get_length with list as stats.levels_completed divided by achievement.unlock_value
        When "items_collected":
            Set progress_value to stats.items_collected divided by achievement.unlock_value
        When "deaths":
            Set progress_value to stats.deaths divided by achievement.unlock_value
        When "kills":
            Set progress_value to stats.kills divided by achievement.unlock_value
        Otherwise:
            Set progress_value to 0.0
    
    Set achievement.progress to math_module.clamp with value as progress_value and min_value as 0.0 and max_value as 1.0
    
    If achievement.progress is greater than or equal to 1.0 and not achievement.is_unlocked:
        Call unlock_achievement with achievement as achievement and stats as stats

Process unlock_achievement with achievement as Achievement and stats as PlayerStatistics:
    Set achievement.is_unlocked to true
    Set achievement.unlock_timestamp to datetime_module.get_timestamp
    Set achievement.progress to 1.0
    
    If not list_utils.contains with list as stats.achievements_unlocked and item as achievement.achievement_id:
        Call list_utils.append with list as stats.achievements_unlocked and item as achievement.achievement_id
    
    Call dict_utils.set_value with dict as achievement.metadata and key as "unlocked_at" and value as string_utils.integer_to_string with value as achievement.unlock_timestamp

Note: Performance Metrics System

Process create_performance_metrics:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "performance_metrics"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return PerformanceMetrics with:
        fps_samples as list_utils.create_empty_list and
        frame_time_samples as list_utils.create_empty_list and
        memory_usage_samples as list_utils.create_empty_list and
        draw_call_samples as list_utils.create_empty_list and
        vertex_count_samples as list_utils.create_empty_list and
        current_fps as 0.0 and
        average_fps as 0.0 and
        min_fps as 0.0 and
        max_fps as 0.0 and
        frame_time_variance as 0.0 and
        metadata as metadata

Process record_frame_performance with metrics as PerformanceMetrics and fps as Float and frame_time as Float and memory_usage as Integer and draw_calls as Integer and vertex_count as Integer:
    Set metrics.current_fps to fps
    
    Call list_utils.append with list as metrics.fps_samples and item as fps
    Call list_utils.append with list as metrics.frame_time_samples and item as frame_time
    Call list_utils.append with list as metrics.memory_usage_samples and item as memory_usage
    Call list_utils.append with list as metrics.draw_call_samples and item as draw_calls
    Call list_utils.append with list as metrics.vertex_count_samples and item as vertex_count
    
    Note: Maintain rolling window of samples (last 300 frames ~ 5 seconds at 60fps)
    Let max_samples be 300
    If list_utils.get_length with list as metrics.fps_samples is greater than max_samples:
        Call list_utils.remove_at_index with list as metrics.fps_samples and index as 0
        Call list_utils.remove_at_index with list as metrics.frame_time_samples and index as 0
        Call list_utils.remove_at_index with list as metrics.memory_usage_samples and index as 0
        Call list_utils.remove_at_index with list as metrics.draw_call_samples and index as 0
        Call list_utils.remove_at_index with list as metrics.vertex_count_samples and index as 0
    
    Call calculate_performance_statistics with metrics as metrics

Process calculate_performance_statistics with metrics as PerformanceMetrics:
    If list_utils.get_length with list as metrics.fps_samples is equal to 0:
        Return
    
    Let fps_sum be 0.0
    Let min_fps be 999999.0
    Let max_fps be 0.0
    
    For Each fps_sample in metrics.fps_samples:
        Set fps_sum to fps_sum plus fps_sample
        If fps_sample is less than min_fps:
            Set min_fps to fps_sample
        If fps_sample is greater than max_fps:
            Set max_fps to fps_sample
    
    Set metrics.average_fps to fps_sum divided by list_utils.get_length with list as metrics.fps_samples
    Set metrics.min_fps to min_fps
    Set metrics.max_fps to max_fps
    
    Note: Calculate frame time variance
    Let variance_sum be 0.0
    For Each frame_time in metrics.frame_time_samples:
        Let diff be frame_time minus (1.0 divided by metrics.average_fps)
        Set variance_sum to variance_sum plus diff multiplied by diff
    
    Set metrics.frame_time_variance to variance_sum divided by list_utils.get_length with list as metrics.frame_time_samples

Process get_performance_summary with metrics as PerformanceMetrics:
    Let summary be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as summary and key as "current_fps" and value as metrics.current_fps
    Call dict_utils.set_value with dict as summary and key as "average_fps" and value as metrics.average_fps
    Call dict_utils.set_value with dict as summary and key as "min_fps" and value as metrics.min_fps
    Call dict_utils.set_value with dict as summary and key as "max_fps" and value as metrics.max_fps
    Call dict_utils.set_value with dict as summary and key as "frame_time_variance" and value as metrics.frame_time_variance
    Call dict_utils.set_value with dict as summary and key as "sample_count" and value as list_utils.get_length with list as metrics.fps_samples
    
    Return summary

Note: Leaderboard System

Process create_leaderboard with leaderboard_id as String and game_mode as String and max_entries as Integer and sort_order as String:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "leaderboard"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return Leaderboard with:
        leaderboard_id as leaderboard_id and
        game_mode as game_mode and
        entries as list_utils.create_empty_list and
        max_entries as max_entries and
        sort_order as sort_order and
        metadata as metadata

Process create_leaderboard_entry with player_id as String and player_name as String and score as Integer and additional_data as Dictionary[String, Any]:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "leaderboard_entry"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return LeaderboardEntry with:
        rank as 0 and
        player_id as player_id and
        player_name as player_name and
        score as score and
        timestamp as datetime_module.get_timestamp and
        additional_data as additional_data and
        metadata as metadata

Process add_leaderboard_entry with leaderboard as Leaderboard and entry as LeaderboardEntry:
    Call list_utils.append with list as leaderboard.entries and item as entry
    Call sort_leaderboard with leaderboard as leaderboard
    
    Note: Trim to max entries
    While list_utils.get_length with list as leaderboard.entries is greater than leaderboard.max_entries:
        Call list_utils.remove_at_index with list as leaderboard.entries and index as list_utils.get_length with list as leaderboard.entries minus 1
    
    Call update_leaderboard_ranks with leaderboard as leaderboard

Process sort_leaderboard with leaderboard as Leaderboard:
    Note: Simple bubble sort for demonstration (use proper sorting algorithm in production)
    Let n be list_utils.get_length with list as leaderboard.entries
    For i from 0 to n minus 1:
        For j from 0 to n minus 2 minus i:
            Let entry_a be list_utils.get_item with list as leaderboard.entries and index as j
            Let entry_b be list_utils.get_item with list as leaderboard.entries and index as j plus 1
            
            Let should_swap be false
            If leaderboard.sort_order is equal to "descending":
                Set should_swap to entry_a.score is less than entry_b.score
            Otherwise:
                Set should_swap to entry_a.score is greater than entry_b.score
            
            If should_swap:
                Call list_utils.set_item with list as leaderboard.entries and index as j and item as entry_b
                Call list_utils.set_item with list as leaderboard.entries and index as j plus 1 and item as entry_a

Process update_leaderboard_ranks with leaderboard as Leaderboard:
    For i from 0 to list_utils.get_length with list as leaderboard.entries minus 1:
        Let entry be list_utils.get_item with list as leaderboard.entries and index as i
        Set entry.rank to i plus 1

Process get_player_leaderboard_rank with leaderboard as Leaderboard and player_id as String:
    For Each entry in leaderboard.entries:
        If entry.player_id is equal to player_id:
            Return entry.rank
    Return 0

Process get_top_leaderboard_entries with leaderboard as Leaderboard and count as Integer:
    Let result_count be math_module.minimum with a as count and b as list_utils.get_length with list as leaderboard.entries
    Let top_entries be list_utils.create_empty_list
    
    For i from 0 to result_count minus 1:
        Let entry be list_utils.get_item with list as leaderboard.entries and index as i
        Call list_utils.append with list as top_entries and item as entry
    
    Return top_entries