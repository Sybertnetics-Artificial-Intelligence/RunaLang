Note: Gaming Module - Main Interface
Note: Unified gaming utilities providing a comprehensive API for game development
Note: Re-exports all gaming submodules for convenient access and provides high-level functions
:End Note

Import "gaming/core" as core
Import "gaming/input" as input
Import "gaming/collision" as collision
Import "gaming/statistics" as stats
Import "gaming/math" as game_math
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "string/format" as string_utils
Import "datetime/datetime" as datetime_module

Note: Re-export Core Types and Functions

Type Vector2D is core.Vector2D
Type Vector3D is core.Vector3D
Type Transform2D is core.Transform2D
Type Transform3D is core.Transform3D
Type Bounds2D is core.Bounds2D
Type Bounds3D is core.Bounds3D
Type Color is core.Color
Type GameResult is core.GameResult

Process create_vector2d with x as Float and y as Float:
    Return core.create_vector2d with x as x and y as y

Process create_vector3d with x as Float and y as Float and z as Float:
    Return core.create_vector3d with x as x and y as y and z as z

Process create_color with red as Float and green as Float and blue as Float and alpha as Float:
    Return core.create_color with red as red and green as green and blue as blue and alpha as alpha

Note: Re-export Input Types and Functions

Type InputManager is input.InputManager
Type KeyCode is input.KeyCode
Type MouseButton is input.MouseButton
Type GamepadButton is input.GamepadButton
Type InputState is input.InputState

Process create_input_manager:
    Return input.create_input_manager

Process is_key_pressed with manager as InputManager and key_code as KeyCode:
    Return input.is_key_pressed with manager as manager and key_code as key_code

Process is_mouse_button_pressed with manager as InputManager and button as MouseButton:
    Return input.is_mouse_button_pressed with manager as manager and button as button

Note: Re-export Collision Types and Functions

Type Circle is collision.Circle
Type Rectangle is collision.Rectangle
Type Sphere is collision.Sphere
Type CollisionResult is collision.CollisionResult

Process create_circle with center as Vector2D and radius as Float:
    Return collision.create_circle with center as center and radius as radius

Process circle_circle_collision with a as Circle and b as Circle:
    Return collision.circle_circle_collision with a as a and b as b

Note: Re-export Statistics Types and Functions

Type GameSession is stats.GameSession
Type PlayerStatistics is stats.PlayerStatistics
Type Achievement is stats.Achievement
Type PerformanceMetrics is stats.PerformanceMetrics

Process create_game_session with player_id as String and game_mode as String and level as String:
    Return stats.create_game_session with player_id as player_id and game_mode as game_mode and level as level

Process create_player_statistics with player_id as String:
    Return stats.create_player_statistics with player_id as player_id

Note: Gaming Utilities and Helpers

Type GameEngine is Dictionary with:
    input_manager as InputManager
    performance_metrics as PerformanceMetrics
    current_session as GameSession
    player_stats as PlayerStatistics
    achievements as List[Achievement]
    is_running as Boolean
    delta_time as Float
    frame_count as Integer
    metadata as Dictionary[String, String]

Process create_game_engine with player_id as String and game_mode as String:
    Let input_mgr be create_input_manager
    Let perf_metrics be stats.create_performance_metrics
    Let session be create_game_session with player_id as player_id and game_mode as game_mode and level as "main"
    Let player_stats be create_player_statistics with player_id as player_id
    Let achievements be list_utils.create_empty_list
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "game_engine"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    Call dict_utils.set_value with dict as metadata and key as "version" and value as "1.0.0"
    Call dict_utils.set_value with dict as metadata and key as "player_id" and value as player_id
    Call dict_utils.set_value with dict as metadata and key as "game_mode" and value as game_mode
    
    Return GameEngine with:
        input_manager as input_mgr and
        performance_metrics as perf_metrics and
        current_session as session and
        player_stats as player_stats and
        achievements as achievements and
        is_running as true and
        delta_time as 0.0 and
        frame_count as 0 and
        metadata as metadata

Process update_game_engine with engine as GameEngine and delta_time as Float:
    Set engine.delta_time to delta_time
    Set engine.frame_count to engine.frame_count plus 1
    
    Note: Update input manager
    Call input.update_input_manager with manager as engine.input_manager
    
    Note: Record performance metrics (simulated values - real implementation would measure actual performance)
    Let current_fps be 1.0 divided by delta_time
    Let frame_time_ms be delta_time multiplied by 1000.0
    Let memory_usage be 50000000  # 50MB simulated
    Let draw_calls be 100  # Simulated
    Let vertex_count be 10000  # Simulated
    
    Call stats.record_frame_performance with:
        metrics as engine.performance_metrics and
        fps as current_fps and
        frame_time as frame_time_ms and
        memory_usage as memory_usage and
        draw_calls as draw_calls and
        vertex_count as vertex_count
    
    Call dict_utils.set_value with dict as engine.metadata and key as "last_updated" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp

Process shutdown_game_engine with engine as GameEngine:
    Set engine.is_running to false
    
    Note: End current session
    Call stats.end_game_session with session as engine.current_session
    
    Note: Update player statistics
    Call stats.update_player_statistics_from_session with stats as engine.player_stats and session as engine.current_session
    
    Call dict_utils.set_value with dict as engine.metadata and key as "shutdown_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp

Process add_achievement_to_engine with engine as GameEngine and achievement_id as String and name as String and description as String and unlock_condition as String and unlock_value as Any:
    Let achievement be stats.create_achievement with:
        achievement_id as achievement_id and
        name as name and
        description as description and
        unlock_condition as unlock_condition and
        unlock_value as unlock_value
    
    Call list_utils.append with list as engine.achievements and item as achievement
    
    Note: Check if achievement should be unlocked immediately
    Call stats.check_achievement_progress with achievement as achievement and stats as engine.player_stats

Process check_all_achievements with engine as GameEngine:
    For Each achievement in engine.achievements:
        Call stats.check_achievement_progress with achievement as achievement and stats as engine.player_stats

Note: Common Game Patterns and Helpers

Process create_game_timer with duration as Float:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "game_timer"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return dict_utils.create_dict_with_entries with entries as [
        ("duration", duration),
        ("remaining", duration),
        ("is_active", true),
        ("is_finished", false),
        ("metadata", metadata)
    ]

Process update_game_timer with timer as Dictionary[String, Any] and delta_time as Float:
    If not dict_utils.get_value_with_default with dict as timer and key as "is_active" and default as false:
        Return timer
    
    Let remaining be dict_utils.get_value_with_default with dict as timer and key as "remaining" and default as 0.0
    Let new_remaining be remaining minus delta_time
    
    If new_remaining is less than or equal to 0.0:
        Set new_remaining to 0.0
        Call dict_utils.set_value with dict as timer and key as "is_finished" and value as true
        Call dict_utils.set_value with dict as timer and key as "is_active" and value as false
    
    Call dict_utils.set_value with dict as timer and key as "remaining" and value as new_remaining
    Return timer

Process create_health_system with max_health as Integer:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "health_system"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return dict_utils.create_dict_with_entries with entries as [
        ("max_health", max_health),
        ("current_health", max_health),
        ("is_alive", true),
        ("damage_taken", 0),
        ("healing_received", 0),
        ("metadata", metadata)
    ]

Process apply_damage with health_system as Dictionary[String, Any] and damage as Integer:
    Let current_health be dict_utils.get_value_with_default with dict as health_system and key as "current_health" and default as 0
    Let damage_taken be dict_utils.get_value_with_default with dict as health_system and key as "damage_taken" and default as 0
    
    Let new_health be current_health minus damage
    If new_health is less than 0:
        Set new_health to 0
    
    Call dict_utils.set_value with dict as health_system and key as "current_health" and value as new_health
    Call dict_utils.set_value with dict as health_system and key as "damage_taken" and value as damage_taken plus damage
    Call dict_utils.set_value with dict as health_system and key as "is_alive" and value as new_health is greater than 0
    
    Return health_system

Process apply_healing with health_system as Dictionary[String, Any] and healing as Integer:
    Let current_health be dict_utils.get_value_with_default with dict as health_system and key as "current_health" and default as 0
    Let max_health be dict_utils.get_value_with_default with dict as health_system and key as "max_health" and default as 100
    Let healing_received be dict_utils.get_value_with_default with dict as health_system and key as "healing_received" and default as 0
    
    Let new_health be current_health plus healing
    If new_health is greater than max_health:
        Set new_health to max_health
    
    Call dict_utils.set_value with dict as health_system and key as "current_health" and value as new_health
    Call dict_utils.set_value with dict as health_system and key as "healing_received" and value as healing_received plus healing
    Call dict_utils.set_value with dict as health_system and key as "is_alive" and value as new_health is greater than 0
    
    Return health_system

Process create_inventory_system with max_slots as Integer:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "inventory_system"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return dict_utils.create_dict_with_entries with entries as [
        ("max_slots", max_slots),
        ("items", list_utils.create_empty_list),
        ("item_counts", dict_utils.create_empty_dict),
        ("metadata", metadata)
    ]

Process add_item_to_inventory with inventory as Dictionary[String, Any] and item_id as String and quantity as Integer:
    Let items be dict_utils.get_value_with_default with dict as inventory and key as "items" and default as list_utils.create_empty_list
    Let item_counts be dict_utils.get_value_with_default with dict as inventory and key as "item_counts" and default as dict_utils.create_empty_dict
    Let max_slots be dict_utils.get_value_with_default with dict as inventory and key as "max_slots" and default as 10
    
    If not list_utils.contains with list as items and item as item_id:
        If list_utils.get_length with list as items is greater than or equal to max_slots:
            Return false  # Inventory full
        Call list_utils.append with list as items and item as item_id
    
    Let current_count be dict_utils.get_value_with_default with dict as item_counts and key as item_id and default as 0
    Call dict_utils.set_value with dict as item_counts and key as item_id and value as current_count plus quantity
    
    Return true

Process remove_item_from_inventory with inventory as Dictionary[String, Any] and item_id as String and quantity as Integer:
    Let items be dict_utils.get_value_with_default with dict as inventory and key as "items" and default as list_utils.create_empty_list
    Let item_counts be dict_utils.get_value_with_default with dict as inventory and key as "item_counts" and default as dict_utils.create_empty_dict
    
    Let current_count be dict_utils.get_value_with_default with dict as item_counts and key as item_id and default as 0
    If current_count is less than quantity:
        Return false  # Not enough items
    
    Let new_count be current_count minus quantity
    If new_count is equal to 0:
        Call dict_utils.remove_key with dict as item_counts and key as item_id
        Call list_utils.remove_item with list as items and item as item_id
    Otherwise:
        Call dict_utils.set_value with dict as item_counts and key as item_id and value as new_count
    
    Return true

Process get_item_count with inventory as Dictionary[String, Any] and item_id as String:
    Let item_counts be dict_utils.get_value_with_default with dict as inventory and key as "items" and default as dict_utils.create_empty_dict
    Return dict_utils.get_value_with_default with dict as item_counts and key as item_id and default as 0

Note: Game State Management

Process create_game_state_manager:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "game_state_manager"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return dict_utils.create_dict_with_entries with entries as [
        ("current_state", "menu"),
        ("previous_state", ""),
        ("state_stack", list_utils.create_empty_list),
        ("state_data", dict_utils.create_empty_dict),
        ("metadata", metadata)
    ]

Process push_game_state with state_manager as Dictionary[String, Any] and new_state as String:
    Let current_state be dict_utils.get_value_with_default with dict as state_manager and key as "current_state" and default as ""
    Let state_stack be dict_utils.get_value_with_default with dict as state_manager and key as "state_stack" and default as list_utils.create_empty_list
    
    Call list_utils.append with list as state_stack and item as current_state
    Call dict_utils.set_value with dict as state_manager and key as "previous_state" and value as current_state
    Call dict_utils.set_value with dict as state_manager and key as "current_state" and value as new_state

Process pop_game_state with state_manager as Dictionary[String, Any]:
    Let state_stack be dict_utils.get_value_with_default with dict as state_manager and key as "state_stack" and default as list_utils.create_empty_list
    
    If list_utils.get_length with list as state_stack is greater than 0:
        Let previous_state be list_utils.get_item with list as state_stack and index as list_utils.get_length with list as state_stack minus 1
        Call list_utils.remove_at_index with list as state_stack and index as list_utils.get_length with list as state_stack minus 1
        
        Let current_state be dict_utils.get_value_with_default with dict as state_manager and key as "current_state" and default as ""
        Call dict_utils.set_value with dict as state_manager and key as "previous_state" and value as current_state
        Call dict_utils.set_value with dict as state_manager and key as "current_state" and value as previous_state
        
        Return true
    
    Return false

Process get_current_game_state with state_manager as Dictionary[String, Any]:
    Return dict_utils.get_value_with_default with dict as state_manager and key as "current_state" and default as ""

Note: Utility Functions

Process create_game_object with id as String and position as Vector2D and object_type as String:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "game_object"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    Call dict_utils.set_value with dict as metadata and key as "object_type" and value as object_type
    
    Return dict_utils.create_dict_with_entries with entries as [
        ("id", id),
        ("position", position),
        ("velocity", create_vector2d with x as 0.0 and y as 0.0),
        ("active", true),
        ("visible", true),
        ("components", dict_utils.create_empty_dict),
        ("metadata", metadata)
    ]

Process update_game_object with game_object as Dictionary[String, Any] and delta_time as Float:
    If not dict_utils.get_value_with_default with dict as game_object and key as "active" and default as false:
        Return game_object
    
    Let position be dict_utils.get_value with dict as game_object and key as "position"
    Let velocity be dict_utils.get_value with dict as game_object and key as "velocity"
    
    Let velocity_offset be core.vector2d_multiply_scalar with vector as velocity and scalar as delta_time
    Let new_position be core.vector2d_add with a as position and b as velocity_offset
    
    Call dict_utils.set_value with dict as game_object and key as "position" and value as new_position
    Return game_object

Process distance_between_game_objects with obj_a as Dictionary[String, Any] and obj_b as Dictionary[String, Any]:
    Let pos_a be dict_utils.get_value with dict as obj_a and key as "position"
    Let pos_b be dict_utils.get_value with dict as obj_b and key as "position"
    Return core.vector2d_distance with a as pos_a and b as pos_b

Note: Version and Module Information

Process get_gaming_module_info:
    Let info be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as info and key as "module_name" and value as "gaming"
    Call dict_utils.set_value with dict as info and key as "version" and value as "1.0.0"
    Call dict_utils.set_value with dict as info and key as "description" and value as "Comprehensive gaming utilities for Runa"
    Call dict_utils.set_value with dict as info and key as "submodules" and value as "core, input, collision, statistics, math"
    Call dict_utils.set_value with dict as info and key as "capabilities" and value as "vectors, transforms, input handling, collision detection, game statistics, performance metrics, easing functions, procedural generation"
    Call dict_utils.set_value with dict as info and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return info