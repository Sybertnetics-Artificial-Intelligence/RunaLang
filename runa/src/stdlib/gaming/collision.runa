Note: Gaming Collision Detection System
Note: Comprehensive 2D and 3D collision detection algorithms for game development
Note: Provides shape definitions, collision testing, and spatial partitioning
:End Note

Import "gaming/core" as core
Import "math/core" as math_module
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "string/format" as string_utils
Import "datetime/datetime" as datetime_module

Note: Collision Shape Types

Type Circle is Dictionary with:
    center as core.Vector2D
    radius as Float
    metadata as Dictionary[String, String]

Type Rectangle is Dictionary with:
    center as core.Vector2D
    width as Float
    height as Float
    rotation as Float
    metadata as Dictionary[String, String]

Type Sphere is Dictionary with:
    center as core.Vector3D
    radius as Float
    metadata as Dictionary[String, String]

Type Box is Dictionary with:
    center as core.Vector3D
    width as Float
    height as Float
    depth as Float
    rotation as core.Vector3D
    metadata as Dictionary[String, String]

Type Ray2D is Dictionary with:
    origin as core.Vector2D
    direction as core.Vector2D
    length as Float
    metadata as Dictionary[String, String]

Type Ray3D is Dictionary with:
    origin as core.Vector3D
    direction as core.Vector3D
    length as Float
    metadata as Dictionary[String, String]

Type CollisionResult is Dictionary with:
    is_colliding as Boolean
    penetration_depth as Float
    collision_normal as core.Vector2D
    collision_point as core.Vector2D
    collision_time as Float
    metadata as Dictionary[String, String]

Type CollisionResult3D is Dictionary with:
    is_colliding as Boolean
    penetration_depth as Float
    collision_normal as core.Vector3D
    collision_point as core.Vector3D
    collision_time as Float
    metadata as Dictionary[String, String]

Note: 2D Collision Shape Creation

Process create_circle with center as core.Vector2D and radius as Float:
    If radius is less than or equal to 0.0:
        Return core.GameError with message as "Circle radius must be positive" and code as "INVALID_RADIUS"
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "circle"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return core.GameSuccess with value as Circle with:
        center as center and
        radius as radius and
        metadata as metadata

Process create_rectangle with center as core.Vector2D and width as Float and height as Float and rotation as Float:
    If width is less than or equal to 0.0 or height is less than or equal to 0.0:
        Return core.GameError with message as "Rectangle dimensions must be positive" and code as "INVALID_DIMENSIONS"
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "rectangle"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return core.GameSuccess with value as Rectangle with:
        center as center and
        width as width and
        height as height and
        rotation as rotation and
        metadata as metadata

Process create_ray2d with origin as core.Vector2D and direction as core.Vector2D and length as Float:
    If length is less than or equal to 0.0:
        Return core.GameError with message as "Ray length must be positive" and code as "INVALID_LENGTH"
    
    Let normalized_direction_result be core.vector2d_normalize with vector as direction
    Match normalized_direction_result:
        When core.GameSuccess with value as normalized_direction:
            Let metadata be dict_utils.create_empty_dict
            Call dict_utils.set_value with dict as metadata and key as "type" and value as "ray2d"
            Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
            
            Return core.GameSuccess with value as Ray2D with:
                origin as origin and
                direction as normalized_direction and
                length as length and
                metadata as metadata
        Otherwise:
            Return normalized_direction_result

Note: 3D Collision Shape Creation

Process create_sphere with center as core.Vector3D and radius as Float:
    If radius is less than or equal to 0.0:
        Return core.GameError with message as "Sphere radius must be positive" and code as "INVALID_RADIUS"
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "sphere"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return core.GameSuccess with value as Sphere with:
        center as center and
        radius as radius and
        metadata as metadata

Process create_box with center as core.Vector3D and width as Float and height as Float and depth as Float and rotation as core.Vector3D:
    If width is less than or equal to 0.0 or height is less than or equal to 0.0 or depth is less than or equal to 0.0:
        Return core.GameError with message as "Box dimensions must be positive" and code as "INVALID_DIMENSIONS"
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "box"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return core.GameSuccess with value as Box with:
        center as center and
        width as width and
        height as height and
        depth as depth and
        rotation as rotation and
        metadata as metadata

Note: 2D Collision Detection

Process circle_circle_collision with a as Circle and b as Circle:
    Let distance_between_centers be core.vector2d_distance with a as a.center and b as b.center
    Let combined_radius be a.radius plus b.radius
    Let is_colliding be distance_between_centers is less than or equal to combined_radius
    
    Let collision_normal be core.create_vector2d with x as 0.0 and y as 0.0
    Let collision_point be core.create_vector2d with x as 0.0 and y as 0.0
    Let penetration_depth be 0.0
    
    If is_colliding and distance_between_centers is greater than 0.0:
        Let direction be core.vector2d_subtract with a as b.center and b as a.center
        Let normalize_result be core.vector2d_normalize with vector as direction
        Match normalize_result:
            When core.GameSuccess with value as normalized:
                Set collision_normal to normalized
                Set penetration_depth to combined_radius minus distance_between_centers
                Let collision_offset be core.vector2d_multiply_scalar with vector as normalized and scalar as a.radius minus penetration_depth divided by 2.0
                Set collision_point to core.vector2d_add with a as a.center and b as collision_offset
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "collision_type" and value as "circle_circle"
    Call dict_utils.set_value with dict as metadata and key as "timestamp" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return CollisionResult with:
        is_colliding as is_colliding and
        penetration_depth as penetration_depth and
        collision_normal as collision_normal and
        collision_point as collision_point and
        collision_time as 0.0 and
        metadata as metadata

Process circle_rectangle_collision with circle as Circle and rect as Rectangle:
    Note: AABB vs Circle collision (simplified - assumes no rotation for now)
    Let rect_min_x be rect.center.x minus rect.width divided by 2.0
    Let rect_max_x be rect.center.x plus rect.width divided by 2.0
    Let rect_min_y be rect.center.y minus rect.height divided by 2.0
    Let rect_max_y be rect.center.y plus rect.height divided by 2.0
    
    Let closest_x be math_module.clamp with value as circle.center.x and min_value as rect_min_x and max_value as rect_max_x
    Let closest_y be math_module.clamp with value as circle.center.y and min_value as rect_min_y and max_value as rect_max_y
    Let closest_point be core.create_vector2d with x as closest_x and y as closest_y
    
    Let distance_to_closest be core.vector2d_distance with a as circle.center and b as closest_point
    Let is_colliding be distance_to_closest is less than or equal to circle.radius
    
    Let collision_normal be core.create_vector2d with x as 0.0 and y as 0.0
    Let penetration_depth be 0.0
    
    If is_colliding:
        If distance_to_closest is greater than 0.0:
            Let direction be core.vector2d_subtract with a as circle.center and b as closest_point
            Let normalize_result be core.vector2d_normalize with vector as direction
            Match normalize_result:
                When core.GameSuccess with value as normalized:
                    Set collision_normal to normalized
        Set penetration_depth to circle.radius minus distance_to_closest
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "collision_type" and value as "circle_rectangle"
    Call dict_utils.set_value with dict as metadata and key as "timestamp" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return CollisionResult with:
        is_colliding as is_colliding and
        penetration_depth as penetration_depth and
        collision_normal as collision_normal and
        collision_point as closest_point and
        collision_time as 0.0 and
        metadata as metadata

Process rectangle_rectangle_collision with a as Rectangle and b as Rectangle:
    Note: AABB vs AABB collision (simplified - assumes no rotation)
    Let a_min_x be a.center.x minus a.width divided by 2.0
    Let a_max_x be a.center.x plus a.width divided by 2.0
    Let a_min_y be a.center.y minus a.height divided by 2.0
    Let a_max_y be a.center.y plus a.height divided by 2.0
    
    Let b_min_x be b.center.x minus b.width divided by 2.0
    Let b_max_x be b.center.x plus b.width divided by 2.0
    Let b_min_y be b.center.y minus b.height divided by 2.0
    Let b_max_y be b.center.y plus b.height divided by 2.0
    
    Let is_colliding be not (a_max_x is less than b_min_x or b_max_x is less than a_min_x or a_max_y is less than b_min_y or b_max_y is less than a_min_y)
    
    Let collision_normal be core.create_vector2d with x as 0.0 and y as 0.0
    Let collision_point be core.create_vector2d with x as 0.0 and y as 0.0
    Let penetration_depth be 0.0
    
    If is_colliding:
        Let center_diff be core.vector2d_subtract with a as b.center and b as a.center
        Let overlap_x be math_module.minimum with a as a_max_x minus b_min_x and b as b_max_x minus a_min_x
        Let overlap_y be math_module.minimum with a as a_max_y minus b_min_y and b as b_max_y minus a_min_y
        
        If overlap_x is less than overlap_y:
            Set penetration_depth to overlap_x
            If center_diff.x is greater than 0.0:
                Set collision_normal to core.create_vector2d with x as 1.0 and y as 0.0
            Otherwise:
                Set collision_normal to core.create_vector2d with x as negative 1.0 and y as 0.0
        Otherwise:
            Set penetration_depth to overlap_y
            If center_diff.y is greater than 0.0:
                Set collision_normal to core.create_vector2d with x as 0.0 and y as 1.0
            Otherwise:
                Set collision_normal to core.create_vector2d with x as 0.0 and y as negative 1.0
        
        Set collision_point to core.vector2d_add with a as a.center and b as core.vector2d_multiply_scalar with vector as center_diff and scalar as 0.5
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "collision_type" and value as "rectangle_rectangle"
    Call dict_utils.set_value with dict as metadata and key as "timestamp" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return CollisionResult with:
        is_colliding as is_colliding and
        penetration_depth as penetration_depth and
        collision_normal as collision_normal and
        collision_point as collision_point and
        collision_time as 0.0 and
        metadata as metadata

Note: 3D Collision Detection

Process sphere_sphere_collision with a as Sphere and b as Sphere:
    Let distance_between_centers be core.vector3d_distance with a as a.center and b as b.center
    Let combined_radius be a.radius plus b.radius
    Let is_colliding be distance_between_centers is less than or equal to combined_radius
    
    Let collision_normal be core.create_vector3d with x as 0.0 and y as 0.0 and z as 0.0
    Let collision_point be core.create_vector3d with x as 0.0 and y as 0.0 and z as 0.0
    Let penetration_depth be 0.0
    
    If is_colliding and distance_between_centers is greater than 0.0:
        Let direction be core.vector3d_subtract with a as b.center and b as a.center
        Let normalize_result be core.vector3d_normalize with vector as direction
        Match normalize_result:
            When core.GameSuccess with value as normalized:
                Set collision_normal to normalized
                Set penetration_depth to combined_radius minus distance_between_centers
                Let collision_offset be core.vector3d_multiply_scalar with vector as normalized and scalar as a.radius minus penetration_depth divided by 2.0
                Set collision_point to core.vector3d_add with a as a.center and b as collision_offset
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "collision_type" and value as "sphere_sphere"
    Call dict_utils.set_value with dict as metadata and key as "timestamp" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return CollisionResult3D with:
        is_colliding as is_colliding and
        penetration_depth as penetration_depth and
        collision_normal as collision_normal and
        collision_point as collision_point and
        collision_time as 0.0 and
        metadata as metadata

Note: Ray Casting

Process raycast_circle with ray as Ray2D and circle as Circle:
    Let ray_to_circle be core.vector2d_subtract with a as circle.center and b as ray.origin
    Let projection_length be core.vector2d_dot_product with a as ray_to_circle and b as ray.direction
    
    If projection_length is less than 0.0 or projection_length is greater than ray.length:
        Return create_raycast_miss
    
    Let closest_point_on_ray be core.vector2d_add with a as ray.origin and b as core.vector2d_multiply_scalar with vector as ray.direction and scalar as projection_length
    Let distance_to_circle_center be core.vector2d_distance with a as closest_point_on_ray and b as circle.center
    
    Let is_hit be distance_to_circle_center is less than or equal to circle.radius
    
    If is_hit:
        Let offset_to_surface be math_module.square_root with value as circle.radius multiplied by circle.radius minus distance_to_circle_center multiplied by distance_to_circle_center
        Let hit_distance be projection_length minus offset_to_surface
        Let hit_point be core.vector2d_add with a as ray.origin and b as core.vector2d_multiply_scalar with vector as ray.direction and scalar as hit_distance
        
        Let hit_to_center be core.vector2d_subtract with a as circle.center and b as hit_point
        Let normal_result be core.vector2d_normalize with vector as hit_to_center
        Match normal_result:
            When core.GameSuccess with value as normal:
                Return create_raycast_hit with point as hit_point and normal as normal and distance as hit_distance
            Otherwise:
                Return create_raycast_miss
    Otherwise:
        Return create_raycast_miss

Process raycast_rectangle with ray as Ray2D and rect as Rectangle:
    Note: Simplified ray-AABB intersection (assumes no rotation)
    Let rect_min_x be rect.center.x minus rect.width divided by 2.0
    Let rect_max_x be rect.center.x plus rect.width divided by 2.0
    Let rect_min_y be rect.center.y minus rect.height divided by 2.0
    Let rect_max_y be rect.center.y plus rect.height divided by 2.0
    
    Let ray_end be core.vector2d_add with a as ray.origin and b as core.vector2d_multiply_scalar with vector as ray.direction and scalar as ray.length
    
    Let t_min_x be (rect_min_x minus ray.origin.x) divided by ray.direction.x
    Let t_max_x be (rect_max_x minus ray.origin.x) divided by ray.direction.x
    Let t_min_y be (rect_min_y minus ray.origin.y) divided by ray.direction.y
    Let t_max_y be (rect_max_y minus ray.origin.y) divided by ray.direction.y
    
    If t_min_x is greater than t_max_x:
        Let temp be t_min_x
        Set t_min_x to t_max_x
        Set t_max_x to temp
    
    If t_min_y is greater than t_max_y:
        Let temp be t_min_y
        Set t_min_y to t_max_y
        Set t_max_y to temp
    
    Let t_enter be math_module.maximum with a as t_min_x and b as t_min_y
    Let t_exit be math_module.minimum with a as t_max_x and b as t_max_y
    
    If t_enter is less than or equal to t_exit and t_enter is greater than or equal to 0.0 and t_enter is less than or equal to ray.length:
        Let hit_point be core.vector2d_add with a as ray.origin and b as core.vector2d_multiply_scalar with vector as ray.direction and scalar as t_enter
        
        Let normal_x be 0.0
        Let normal_y be 0.0
        If t_min_x is greater than t_min_y:
            If ray.direction.x is greater than 0.0:
                Set normal_x to negative 1.0
            Otherwise:
                Set normal_x to 1.0
        Otherwise:
            If ray.direction.y is greater than 0.0:
                Set normal_y to negative 1.0
            Otherwise:
                Set normal_y to 1.0
        
        Let normal be core.create_vector2d with x as normal_x and y as normal_y
        Return create_raycast_hit with point as hit_point and normal as normal and distance as t_enter
    Otherwise:
        Return create_raycast_miss

Note: Raycast Result Helpers

Process create_raycast_hit with point as core.Vector2D and normal as core.Vector2D and distance as Float:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "hit" and value as "true"
    Call dict_utils.set_value with dict as metadata and key as "timestamp" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return CollisionResult with:
        is_colliding as true and
        penetration_depth as 0.0 and
        collision_normal as normal and
        collision_point as point and
        collision_time as distance and
        metadata as metadata

Process create_raycast_miss:
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "hit" and value as "false"
    Call dict_utils.set_value with dict as metadata and key as "timestamp" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return CollisionResult with:
        is_colliding as false and
        penetration_depth as 0.0 and
        collision_normal as core.create_vector2d with x as 0.0 and y as 0.0 and
        collision_point as core.create_vector2d with x as 0.0 and y as 0.0 and
        collision_time as 0.0 and
        metadata as metadata

Note: Collision Resolution Helpers

Process resolve_collision_simple with object_a_pos as core.Vector2D and object_b_pos as core.Vector2D and collision as CollisionResult:
    Note: Simple position-based collision resolution
    If not collision.is_colliding:
        Return (object_a_pos, object_b_pos)
    
    Let separation_vector be core.vector2d_multiply_scalar with vector as collision.collision_normal and scalar as collision.penetration_depth divided by 2.0
    Let new_pos_a be core.vector2d_subtract with a as object_a_pos and b as separation_vector
    Let new_pos_b be core.vector2d_add with a as object_b_pos and b as separation_vector
    
    Return (new_pos_a, new_pos_b)

Process calculate_collision_impulse with velocity_a as core.Vector2D and velocity_b as core.Vector2D and mass_a as Float and mass_b as Float and normal as core.Vector2D and restitution as Float:
    Note: Calculate impulse for velocity-based collision response
    Let relative_velocity be core.vector2d_subtract with a as velocity_b and b as velocity_a
    Let relative_speed_along_normal be core.vector2d_dot_product with a as relative_velocity and b as normal
    
    If relative_speed_along_normal is greater than 0.0:
        Return 0.0
    
    Let impulse_magnitude be negative (1.0 plus restitution) multiplied by relative_speed_along_normal divided by (1.0 divided by mass_a plus 1.0 divided by mass_b)
    Return impulse_magnitude

Note: Spatial Partitioning Helpers

Type SpatialGrid is Dictionary with:
    cell_size as Float
    grid_cells as Dictionary[String, List[Any]]
    bounds as core.Bounds2D
    metadata as Dictionary[String, String]

Process create_spatial_grid with bounds as core.Bounds2D and cell_size as Float:
    If cell_size is less than or equal to 0.0:
        Return core.GameError with message as "Cell size must be positive" and code as "INVALID_CELL_SIZE"
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "spatial_grid"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return core.GameSuccess with value as SpatialGrid with:
        cell_size as cell_size and
        grid_cells as dict_utils.create_empty_dict and
        bounds as bounds and
        metadata as metadata

Process grid_hash with x as Integer and y as Integer:
    Return string_utils.concatenate with strings as [
        string_utils.integer_to_string with value as x,
        ",",
        string_utils.integer_to_string with value as y
    ]

Process add_to_grid with grid as SpatialGrid and object as Any and position as core.Vector2D:
    Let grid_x be math_module.floor with value as position.x divided by grid.cell_size
    Let grid_y be math_module.floor with value as position.y divided by grid.cell_size
    Let cell_key be grid_hash with x as grid_x and y as grid_y
    
    Let cell_objects be dict_utils.get_value_with_default with dict as grid.grid_cells and key as cell_key and default as list_utils.create_empty_list
    Call list_utils.append with list as cell_objects and item as object
    Call dict_utils.set_value with dict as grid.grid_cells and key as cell_key and value as cell_objects

Process query_grid with grid as SpatialGrid and position as core.Vector2D:
    Let grid_x be math_module.floor with value as position.x divided by grid.cell_size
    Let grid_y be math_module.floor with value as position.y divided by grid.cell_size
    Let cell_key be grid_hash with x as grid_x and y as grid_y
    
    Return dict_utils.get_value_with_default with dict as grid.grid_cells and key as cell_key and default as list_utils.create_empty_list

Process clear_grid with grid as SpatialGrid:
    Call dict_utils.clear with dict as grid.grid_cells