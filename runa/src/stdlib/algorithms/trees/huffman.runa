Note:
algorithms/trees/huffman.runa
Huffman Coding Tree Construction and Analysis

This module provides Huffman coding tree construction for optimal prefix-free encoding
based on symbol frequencies. Implements the classic Huffman algorithm using priority
queues to build minimum-cost binary trees for data compression applications.

Key features include tree construction, code generation, compression analysis,
and adaptive Huffman coding support for streaming data compression.
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: HUFFMAN CODING DATA STRUCTURES
Note: =====================================================================

Type called "HuffmanNode":
    symbol as String
    frequency as Float
    left_child as HuffmanNode
    right_child as HuffmanNode
    is_leaf as Boolean
    code as String
    depth as Integer

Type called "HuffmanTree":
    root as HuffmanNode
    symbol_codes as Dictionary[String, String]
    total_symbols as Integer
    average_code_length as Float
    compression_ratio as Float
    entropy as Float

Type called "HuffmanResult":
    tree as HuffmanTree
    encoded_data as List[String]
    compression_statistics as Dictionary[String, Float]
    encoding_table as Dictionary[String, String]
    decoding_table as Dictionary[String, String]

Note: =====================================================================
Note: HUFFMAN TREE CONSTRUCTION OPERATIONS
Note: =====================================================================

Process called "build_huffman_tree" that takes symbol_frequencies as Dictionary[String, Float] returns HuffmanTree:
    Note: Build optimal Huffman tree from symbol frequency distribution
    Note: Uses priority queue to merge nodes with minimum frequencies
    
    If symbol_frequencies.size() equals 0:
        Throw Errors.InvalidArgument with "Cannot build Huffman tree from empty frequency distribution"
    
    If symbol_frequencies.size() equals 1:
        Let single_symbol be symbol_frequencies.keys().get(0)
        Let single_freq be symbol_frequencies[single_symbol]
        Let root_node be HuffmanNode
        Set root_node.symbol to single_symbol
        Set root_node.frequency to single_freq
        Set root_node.is_leaf to true
        Set root_node.code to "0"
        Set root_node.depth to 1
        
        Let result_tree be HuffmanTree
        Set result_tree.root to root_node
        Set result_tree.symbol_codes to Dictionary[String, String]
        Set result_tree.symbol_codes[single_symbol] to "0"
        Set result_tree.total_symbols to 1
        Set result_tree.average_code_length to 1.0
        Return result_tree
    
    Note: Create leaf nodes for each symbol
    Let node_queue be List[HuffmanNode]
    For each symbol in symbol_frequencies.keys():
        Let leaf_node be HuffmanNode
        Set leaf_node.symbol to symbol
        Set leaf_node.frequency to symbol_frequencies[symbol]
        Set leaf_node.is_leaf to true
        Set leaf_node.depth to 0
        Call node_queue.append(leaf_node)
    
    Note: Sort nodes by frequency (priority queue simulation)
    Call sort_nodes_by_frequency(node_queue)
    
    Note: Build tree bottom-up by merging minimum frequency nodes
    While node_queue.size() > 1:
        Let node1 be node_queue[0]
        Let node2 be node_queue[1]
        Call node_queue.remove_at(0)
        Call node_queue.remove_at(0)
        
        Let merged_node be HuffmanNode
        Set merged_node.symbol to ""
        Set merged_node.frequency to node1.frequency + node2.frequency
        Set merged_node.left_child to node1
        Set merged_node.right_child to node2
        Set merged_node.is_leaf to false
        Set merged_node.depth to Math.max(node1.depth, node2.depth) + 1
        
        Call insert_node_sorted(node_queue, merged_node)
    
    Let root_node be node_queue[0]
    
    Note: Generate codes by traversing tree
    Let codes be Dictionary[String, String]
    Call generate_huffman_codes(root_node, "", codes)
    
    Note: Calculate statistics
    Let total_freq be 0.0
    Let weighted_length be 0.0
    For each symbol in codes.keys():
        Let freq be symbol_frequencies[symbol]
        Let code_length be codes[symbol].length()
        Set total_freq to total_freq + freq
        Set weighted_length to weighted_length + (freq * code_length)
    
    Let avg_length be weighted_length / total_freq
    
    Let result_tree be HuffmanTree
    Set result_tree.root to root_node
    Set result_tree.symbol_codes to codes
    Set result_tree.total_symbols to symbol_frequencies.size()
    Set result_tree.average_code_length to avg_length
    
    Return result_tree

Process called "sort_nodes_by_frequency" that takes nodes as List[HuffmanNode] returns Nothing:
    Note: Sort nodes in ascending order by frequency using insertion sort
    
    For i from 1 to nodes.size() - 1:
        Let key_node be nodes[i]
        Let j be i - 1
        While j >= 0 and nodes[j].frequency > key_node.frequency:
            Set nodes[j + 1] to nodes[j]
            Set j to j - 1
        Set nodes[j + 1] to key_node

Process called "insert_node_sorted" that takes sorted_nodes as List[HuffmanNode], new_node as HuffmanNode returns Nothing:
    Note: Insert node into sorted list maintaining frequency order
    
    Let insert_pos be 0
    While insert_pos < sorted_nodes.size() and sorted_nodes[insert_pos].frequency <= new_node.frequency:
        Set insert_pos to insert_pos + 1
    
    Call sorted_nodes.insert(insert_pos, new_node)

Process called "generate_huffman_codes" that takes node as HuffmanNode, current_code as String, codes as Dictionary[String, String] returns Nothing:
    Note: Recursively generate binary codes for all leaf nodes
    
    If node.is_leaf:
        If current_code equals "":
            Set codes[node.symbol] to "0"
        Otherwise:
            Set codes[node.symbol] to current_code
        Set node.code to codes[node.symbol]
        Return
    
    Call generate_huffman_codes(node.left_child, current_code + "0", codes)
    Call generate_huffman_codes(node.right_child, current_code + "1", codes)

Process called "encode_with_huffman" that takes data as List[String], huffman_tree as HuffmanTree returns HuffmanResult:
    Note: Encode data using constructed Huffman tree
    
    Let encoded_bits be List[String]
    Let total_input_bits be 0
    Let total_output_bits be 0
    
    For each symbol in data:
        If not huffman_tree.symbol_codes.contains_key(symbol):
            Throw Errors.InvalidArgument with "Symbol not found in Huffman tree: " + symbol
        
        Let code be huffman_tree.symbol_codes[symbol]
        Call encoded_bits.append(code)
        Set total_input_bits to total_input_bits + 8
        Set total_output_bits to total_output_bits + code.length()
    
    Let compression_ratio be Float(total_input_bits) / Float(total_output_bits)
    
    Let statistics be Dictionary[String, Float]
    Set statistics["input_bits"] to Float(total_input_bits)
    Set statistics["output_bits"] to Float(total_output_bits)
    Set statistics["compression_ratio"] to compression_ratio
    Set statistics["space_savings"] to (1.0 - (1.0 / compression_ratio)) * 100.0
    
    Let result be HuffmanResult
    Set result.tree to huffman_tree
    Set result.encoded_data to encoded_bits
    Set result.compression_statistics to statistics
    Set result.encoding_table to huffman_tree.symbol_codes
    
    Note: Create reverse decoding table
    Let decoding_table be Dictionary[String, String]
    For each symbol in huffman_tree.symbol_codes.keys():
        Let code be huffman_tree.symbol_codes[symbol]
        Set decoding_table[code] to symbol
    Set result.decoding_table to decoding_table
    
    Return result

Process called "calculate_huffman_efficiency" that takes symbol_frequencies as Dictionary[String, Float], huffman_tree as HuffmanTree returns Dictionary[String, Float]:
    Note: Calculate compression efficiency metrics
    
    Let total_frequency be 0.0
    Let entropy be 0.0
    For each symbol in symbol_frequencies.keys():
        Let freq be symbol_frequencies[symbol]
        Set total_frequency to total_frequency + freq
    
    For each symbol in symbol_frequencies.keys():
        Let prob be symbol_frequencies[symbol] / total_frequency
        If prob > 0.0:
            Set entropy to entropy - (prob * Math.log2(prob))
    
    Let efficiency be Dictionary[String, Float]
    Set efficiency["entropy"] to entropy
    Set efficiency["average_code_length"] to huffman_tree.average_code_length
    Set efficiency["compression_efficiency"] to (entropy / huffman_tree.average_code_length) * 100.0
    Set efficiency["redundancy"] to huffman_tree.average_code_length - entropy
    
    Return efficiency