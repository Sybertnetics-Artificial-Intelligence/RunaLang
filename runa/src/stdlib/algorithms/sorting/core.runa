Note:
algorithms/sorting/core.runa
Sorting Algorithms and Array Manipulation

This module provides comprehensive sorting algorithm implementations including
comparison-based sorts, distribution sorts, and specialized sorting methods
for different data types and performance requirements.

Key features include quicksort, mergesort, heapsort, radix sort, and hybrid
algorithms with optimizations for different input characteristics and sizes.
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: SORTING DATA STRUCTURES
Note: =====================================================================

Type called "SortingResult":
    sorted_array as List[String]
    comparisons_made as Integer
    swaps_made as Integer
    algorithm_used as String
    time_complexity as String
    space_complexity as String

Type called "SortingConfig":
    algorithm_preference as String
    stability_required as Boolean
    memory_constraint as String
    expected_data_size as Integer
    data_characteristics as String

Note: =====================================================================
Note: COMPARISON-BASED SORTING OPERATIONS
Note: =====================================================================

Process called "quicksort" that takes array as List[String], comparator as String returns SortingResult:
    Note: Sort array using quicksort with median-of-three pivot selection
    
    Let result be SortingResult
    Set result.sorted_array to List[String]
    For each element in array:
        Call result.sorted_array.append(element)
    
    Set result.comparisons_made to 0
    Set result.swaps_made to 0
    Set result.algorithm_used to "quicksort"
    Set result.time_complexity to "O(n log n) average, O(n²) worst"
    Set result.space_complexity to "O(log n)"
    
    Call quicksort_recursive(result.sorted_array, 0, array.size() - 1, result, comparator)
    
    Return result

Process called "quicksort_recursive" that takes array as List[String], low as Integer, high as Integer, result as SortingResult, comparator as String returns Nothing:
    Note: Recursive quicksort implementation with pivot partitioning
    
    If low < high:
        Let pivot_index be partition_array(array, low, high, result, comparator)
        Call quicksort_recursive(array, low, pivot_index - 1, result, comparator)
        Call quicksort_recursive(array, pivot_index + 1, high, result, comparator)

Process called "partition_array" that takes array as List[String], low as Integer, high as Integer, result as SortingResult, comparator as String returns Integer:
    Note: Partition array around pivot element using Lomuto partition scheme
    
    Let pivot_value be array[high]
    Let i be low - 1
    
    For j from low to high - 1:
        Set result.comparisons_made to result.comparisons_made + 1
        If compare_elements(array[j], pivot_value, comparator) <= 0:
            Set i to i + 1
            Call swap_elements(array, i, j, result)
    
    Call swap_elements(array, i + 1, high, result)
    Return i + 1

Process called "mergesort" that takes array as List[String], comparator as String returns SortingResult:
    Note: Sort array using stable mergesort algorithm
    
    Let result be SortingResult
    Set result.sorted_array to List[String]
    For each element in array:
        Call result.sorted_array.append(element)
    
    Set result.comparisons_made to 0
    Set result.swaps_made to 0
    Set result.algorithm_used to "mergesort"
    Set result.time_complexity to "O(n log n)"
    Set result.space_complexity to "O(n)"
    
    Call mergesort_recursive(result.sorted_array, 0, array.size() - 1, result, comparator)
    
    Return result

Process called "mergesort_recursive" that takes array as List[String], left as Integer, right as Integer, result as SortingResult, comparator as String returns Nothing:
    Note: Recursive mergesort with divide and conquer approach
    
    If left < right:
        Let middle be left + ((right - left) / 2)
        Call mergesort_recursive(array, left, middle, result, comparator)
        Call mergesort_recursive(array, middle + 1, right, result, comparator)
        Call merge_subarrays(array, left, middle, right, result, comparator)

Process called "merge_subarrays" that takes array as List[String], left as Integer, middle as Integer, right as Integer, result as SortingResult, comparator as String returns Nothing:
    Note: Merge two sorted subarrays into single sorted array
    
    Let left_size be middle - left + 1
    Let right_size be right - middle
    
    Let left_array be List[String]
    Let right_array be List[String]
    
    For i from 0 to left_size - 1:
        Call left_array.append(array[left + i])
    
    For j from 0 to right_size - 1:
        Call right_array.append(array[middle + 1 + j])
    
    Let i be 0
    Let j be 0
    Let k be left
    
    While i < left_size and j < right_size:
        Set result.comparisons_made to result.comparisons_made + 1
        If compare_elements(left_array[i], right_array[j], comparator) <= 0:
            Set array[k] to left_array[i]
            Set i to i + 1
        Otherwise:
            Set array[k] to right_array[j]
            Set j to j + 1
            Set result.swaps_made to result.swaps_made + 1
        Set k to k + 1
    
    While i < left_size:
        Set array[k] to left_array[i]
        Set i to i + 1
        Set k to k + 1
    
    While j < right_size:
        Set array[k] to right_array[j]
        Set j to j + 1
        Set k to k + 1

Process called "heapsort" that takes array as List[String], comparator as String returns SortingResult:
    Note: Sort array using heapsort with binary heap data structure
    
    Let result be SortingResult
    Set result.sorted_array to List[String]
    For each element in array:
        Call result.sorted_array.append(element)
    
    Set result.comparisons_made to 0
    Set result.swaps_made to 0
    Set result.algorithm_used to "heapsort"
    Set result.time_complexity to "O(n log n)"
    Set result.space_complexity to "O(1)"
    
    Let n be array.size()
    
    Note: Build max heap
    For i from (n / 2) - 1 down to 0:
        Call heapify(result.sorted_array, n, i, result, comparator)
    
    Note: Extract elements one by one
    For i from n - 1 down to 1:
        Call swap_elements(result.sorted_array, 0, i, result)
        Call heapify(result.sorted_array, i, 0, result, comparator)
    
    Return result

Process called "heapify" that takes array as List[String], heap_size as Integer, root_index as Integer, result as SortingResult, comparator as String returns Nothing:
    Note: Maintain max heap property for subtree rooted at given index
    
    Let largest be root_index
    Let left_child be (2 * root_index) + 1
    Let right_child be (2 * root_index) + 2
    
    If left_child < heap_size:
        Set result.comparisons_made to result.comparisons_made + 1
        If compare_elements(array[left_child], array[largest], comparator) > 0:
            Set largest to left_child
    
    If right_child < heap_size:
        Set result.comparisons_made to result.comparisons_made + 1
        If compare_elements(array[right_child], array[largest], comparator) > 0:
            Set largest to right_child
    
    If largest != root_index:
        Call swap_elements(array, root_index, largest, result)
        Call heapify(array, heap_size, largest, result, comparator)

Note: =====================================================================
Note: UTILITY OPERATIONS
Note: =====================================================================

Process called "compare_elements" that takes element1 as String, element2 as String, comparator as String returns Integer:
    Note: Compare two elements based on specified comparison strategy
    
    If comparator equals "lexicographic":
        If element1 < element2:
            Return -1
        Otherwise if element1 > element2:
            Return 1
        Otherwise:
            Return 0
    Otherwise if comparator equals "numeric":
        Let num1 be Float(element1)
        Let num2 be Float(element2)
        If num1 < num2:
            Return -1
        Otherwise if num1 > num2:
            Return 1
        Otherwise:
            Return 0
    Otherwise if comparator equals "length":
        If element1.length() < element2.length():
            Return -1
        Otherwise if element1.length() > element2.length():
            Return 1
        Otherwise:
            Return 0
    Otherwise:
        Note: Default to lexicographic comparison
        If element1 < element2:
            Return -1
        Otherwise if element1 > element2:
            Return 1
        Otherwise:
            Return 0

Process called "swap_elements" that takes array as List[String], index1 as Integer, index2 as Integer, result as SortingResult returns Nothing:
    Note: Swap two elements in array and increment swap counter
    
    Let temp be array[index1]
    Set array[index1] to array[index2]
    Set array[index2] to temp
    Set result.swaps_made to result.swaps_made + 1

Process called "is_sorted" that takes array as List[String], comparator as String returns Boolean:
    Note: Check if array is sorted according to specified comparator
    
    For i from 1 to array.size() - 1:
        If compare_elements(array[i - 1], array[i], comparator) > 0:
            Return false
    
    Return true

Process called "insertion_sort" that takes array as List[String], comparator as String returns SortingResult:
    Note: Sort array using insertion sort - efficient for small arrays
    
    Let result be SortingResult
    Set result.sorted_array to List[String]
    For each element in array:
        Call result.sorted_array.append(element)
    
    Set result.comparisons_made to 0
    Set result.swaps_made to 0
    Set result.algorithm_used to "insertion_sort"
    Set result.time_complexity to "O(n²)"
    Set result.space_complexity to "O(1)"
    
    For i from 1 to result.sorted_array.size() - 1:
        Let key_element be result.sorted_array[i]
        Let j be i - 1
        
        While j >= 0:
            Set result.comparisons_made to result.comparisons_made + 1
            If compare_elements(result.sorted_array[j], key_element, comparator) > 0:
                Set result.sorted_array[j + 1] to result.sorted_array[j]
                Set result.swaps_made to result.swaps_made + 1
                Set j to j - 1
            Otherwise:
                Break
        
        Set result.sorted_array[j + 1] to key_element
    
    Return result