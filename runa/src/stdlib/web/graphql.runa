Note: Runa Standard Library - GraphQL Module
Note: Complete GraphQL implementation with schema definition, query execution, subscriptions
Note: Surpasses Apollo Server, GraphQL-Java, Sangria, async-graphql capabilities

Import "web/framework" as Framework
Import "../../collections" as Collections
Import "../../datetime" as DateTime
Import "crypto/hash" as Hash
Import "../../concurrent" as Concurrent

Note: GraphQL Schema Types
Type GraphQLType is:
    | ScalarType with name as String and serializer as Process and deserializer as Process
    | ObjectType with name as String and fields as Dictionary[String, GraphQLField] and interfaces as List[String]
    | InterfaceType with name as String and fields as Dictionary[String, GraphQLField]
    | UnionType with name as String and possible_types as List[String]
    | EnumType with name as String and values as Dictionary[String, GraphQLEnumValue]
    | InputType with name as String and fields as Dictionary[String, GraphQLInputField]
    | ListType with inner_type as GraphQLType
    | NonNullType with inner_type as GraphQLType

Type called "GraphQLField":
    name as String
    field_type as GraphQLType
    arguments as Dictionary[String, GraphQLArgument]
    resolver as Process
    description as String
    deprecation_reason as Optional[String]
    is_deprecated as Boolean

Type called "GraphQLArgument":
    name as String
    argument_type as GraphQLType
    default_value as Optional[Any]
    description as String

Type called "GraphQLInputField":
    name as String
    field_type as GraphQLType
    default_value as Optional[Any]
    description as String

Type called "GraphQLEnumValue":
    name as String
    value as Any
    description as String
    deprecation_reason as Optional[String]
    is_deprecated as Boolean

Note: GraphQL Schema Definition
Type called "GraphQLSchema":
    query_type as GraphQLType
    mutation_type as Optional[GraphQLType]
    subscription_type as Optional[GraphQLType]
    types as Dictionary[String, GraphQLType]
    directives as Dictionary[String, GraphQLDirective]

    Process called "create" that takes query_type as GraphQLType returns GraphQLSchema:
        Return GraphQLSchema with:
            query_type as query_type
            mutation_type as null
            subscription_type as null
            types as dictionary containing
            directives as create_default_directives()

    Process called "add_mutation_type" that takes mutation_type as GraphQLType returns GraphQLSchema:
        Set self.mutation_type to mutation_type
        Return self

    Process called "add_subscription_type" that takes subscription_type as GraphQLType returns GraphQLSchema:
        Set self.subscription_type to subscription_type
        Return self

    Process called "add_type" that takes type_name as String and graph_type as GraphQLType returns GraphQLSchema:
        Set self.types[type_name] to graph_type
        Return self

    Process called "get_type" that takes type_name as String returns Optional[GraphQLType]:
        Return self.types.get with key as type_name

    Process called "validate_schema" returns ValidationResult:
        Let errors be list containing
        
        Note: Validate query type exists
        If self.query_type is null:
            Add "Schema must have a query type" to errors

        Note: Validate type references
        self.validate_type_references with errors as errors

        Note: Validate field resolvers
        self.validate_field_resolvers with errors as errors

        Return ValidationResult with:
            valid as length of errors is equal to 0
            errors as errors

    Process called "validate_type_references" that takes errors as List[String] returns None:
        Note: Check that all referenced types exist
        For each type_name in self.types:
            Let graph_type be self.types[type_name]
            self.validate_type_exists with graph_type as graph_type and errors as errors

    Process called "validate_type_exists" that takes graph_type as GraphQLType and errors as List[String] returns None:
        Match graph_type:
            When ObjectType with fields as fields:
                For each field_name in fields:
                    Let field be fields[field_name]
                    self.validate_type_reference with field_type as field.field_type and errors as errors
            When InterfaceType with fields as fields:
                For each field_name in fields:
                    Let field be fields[field_name]
                    self.validate_type_reference with field_type as field.field_type and errors as errors
            When ListType with inner_type as inner:
                self.validate_type_exists with graph_type as inner and errors as errors
            When NonNullType with inner_type as inner:
                self.validate_type_exists with graph_type as inner and errors as errors

    Process called "validate_type_reference" that takes field_type as GraphQLType and errors as List[String] returns None:
        Match field_type:
            When ObjectType with name as type_name:
                If type_name is not in self.types:
                    Add "Referenced type '" concatenated with type_name concatenated with "' does not exist" to errors
            When InterfaceType with name as type_name:
                If type_name is not in self.types:
                    Add "Referenced interface '" concatenated with type_name concatenated with "' does not exist" to errors

    Process called "validate_field_resolvers" that takes errors as List[String] returns None:
        Note: Ensure all fields have resolvers or default resolvers can be used
        For each type_name in self.types:
            Let graph_type be self.types[type_name]
            Match graph_type:
                When ObjectType with fields as fields:
                    For each field_name in fields:
                        Let field be fields[field_name]
                        If field.resolver is null:
                            Add "Field '" concatenated with type_name concatenated with "." concatenated with field_name concatenated with "' must have a resolver" to errors

Type called "GraphQLDirective":
    name as String
    locations as List[DirectiveLocation]
    arguments as Dictionary[String, GraphQLArgument]
    is_repeatable as Boolean

Type DirectiveLocation is:
    | QUERY | MUTATION | SUBSCRIPTION | FIELD | FRAGMENT_DEFINITION | FRAGMENT_SPREAD | INLINE_FRAGMENT | SCHEMA | SCALAR | OBJECT | FIELD_DEFINITION | ARGUMENT_DEFINITION | INTERFACE | UNION | ENUM | ENUM_VALUE | INPUT_OBJECT | INPUT_FIELD_DEFINITION

Note: GraphQL Query Parsing
Type called "GraphQLDocument":
    definitions as List[GraphQLDefinition]

Type GraphQLDefinition is:
    | OperationDefinition with operation as GraphQLOperation
    | FragmentDefinition with fragment as GraphQLFragment

Type called "GraphQLOperation":
    operation_type as OperationType
    name as Optional[String]
    variable_definitions as List[GraphQLVariableDefinition]
    directives as List[GraphQLDirectiveUsage]
    selection_set as GraphQLSelectionSet

Type OperationType is:
    | QUERY | MUTATION | SUBSCRIPTION

Type called "GraphQLVariableDefinition":
    variable as String
    variable_type as GraphQLType
    default_value as Optional[Any]

Type called "GraphQLSelectionSet":
    selections as List[GraphQLSelection]

Type GraphQLSelection is:
    | FieldSelection with field as GraphQLFieldSelection
    | FragmentSpread with fragment_name as String and directives as List[GraphQLDirectiveUsage]
    | InlineFragment with type_condition as Optional[String] and selection_set as GraphQLSelectionSet and directives as List[GraphQLDirectiveUsage]

Type called "GraphQLFieldSelection":
    alias as Optional[String]
    name as String
    arguments as Dictionary[String, GraphQLValue]
    directives as List[GraphQLDirectiveUsage]
    selection_set as Optional[GraphQLSelectionSet]

Type called "GraphQLDirectiveUsage":
    name as String
    arguments as Dictionary[String, GraphQLValue]

Type GraphQLValue is:
    | StringValue with value as String
    | IntValue with value as Integer
    | FloatValue with value as Float
    | BooleanValue with value as Boolean
    | NullValue
    | ListValue with values as List[GraphQLValue]
    | ObjectValue with fields as Dictionary[String, GraphQLValue]
    | VariableValue with name as String

Type called "GraphQLFragment":
    name as String
    type_condition as String
    directives as List[GraphQLDirectiveUsage]
    selection_set as GraphQLSelectionSet

Note: GraphQL Query Parser
Type called "GraphQLParser":
    lexer as GraphQLLexer

    Process called "create" returns GraphQLParser:
        Return GraphQLParser with:
            lexer as GraphQLLexer.create()

    Process called "parse" that takes query as String returns ParseResult:
        Try:
            self.lexer.tokenize with input as query
            Let document be self.parse_document()
            Return ParseResult with:
                success as true
                document as document
                errors as list containing
        Catch error:
            Return ParseResult with:
                success as false
                document as null
                errors as list containing error.message

    Process called "parse_document" returns GraphQLDocument:
        Let definitions be list containing
        
        While not self.lexer.is_at_end():
            Let definition be self.parse_definition()
            Add definition to definitions
        
        Return GraphQLDocument with:
            definitions as definitions

    Process called "parse_definition" returns GraphQLDefinition:
        Let current_token be self.lexer.current_token()
        
        Match current_token.type:
            When QUERY:
                Return OperationDefinition with operation as self.parse_operation()
            When MUTATION:
                Return OperationDefinition with operation as self.parse_operation()
            When SUBSCRIPTION:
                Return OperationDefinition with operation as self.parse_operation()
            When FRAGMENT:
                Return FragmentDefinition with fragment as self.parse_fragment()
            Otherwise:
                Return OperationDefinition with operation as self.parse_operation()

    Process called "parse_operation" returns GraphQLOperation:
        Let operation_type be self.parse_operation_type()
        Let name be self.parse_optional_name()
        Let variables be self.parse_variable_definitions()
        Let directives be self.parse_directives()
        Let selection_set be self.parse_selection_set()
        
        Return GraphQLOperation with:
            operation_type as operation_type
            name as name
            variable_definitions as variables
            directives as directives
            selection_set as selection_set

    Process called "parse_operation_type" returns OperationType:
        Let token be self.lexer.current_token()
        self.lexer.advance()
        
        Match token.value:
            When "query":
                Return QUERY
            When "mutation":
                Return MUTATION
            When "subscription":
                Return SUBSCRIPTION
            Otherwise:
                Return QUERY

    Process called "parse_selection_set" returns GraphQLSelectionSet:
        Let selections be list containing
        
        self.lexer.expect_token with type as LEFT_BRACE
        
        While not self.lexer.check_token with type as RIGHT_BRACE:
            Let selection be self.parse_selection()
            Add selection to selections
        
        self.lexer.expect_token with type as RIGHT_BRACE
        
        Return GraphQLSelectionSet with:
            selections as selections

    Process called "parse_selection" returns GraphQLSelection:
        If self.lexer.check_token with type as SPREAD:
            Return self.parse_fragment_selection()
        Otherwise:
            Return FieldSelection with field as self.parse_field_selection()

    Process called "parse_field_selection" returns GraphQLFieldSelection:
        Let name be self.lexer.expect_name()
        Let alias be null
        
        Note: Check for alias
        If self.lexer.check_token with type as COLON:
            Set alias to name
            self.lexer.advance()
            Set name to self.lexer.expect_name()
        
        Let arguments be self.parse_arguments()
        Let directives be self.parse_directives()
        Let selection_set be null
        
        If self.lexer.check_token with type as LEFT_BRACE:
            Set selection_set to self.parse_selection_set()
        
        Return GraphQLFieldSelection with:
            alias as alias
            name as name
            arguments as arguments
            directives as directives
            selection_set as selection_set

    Process called "parse_arguments" returns Dictionary[String, GraphQLValue]:
        Let arguments be dictionary containing
        
        If self.lexer.check_token with type as LEFT_PAREN:
            self.lexer.advance()
            
            While not self.lexer.check_token with type as RIGHT_PAREN:
                Let arg_name be self.lexer.expect_name()
                self.lexer.expect_token with type as COLON
                Let arg_value be self.parse_value()
                Set arguments[arg_name] to arg_value
            
            self.lexer.expect_token with type as RIGHT_PAREN
        
        Return arguments

    Process called "parse_value" returns GraphQLValue:
        Let token be self.lexer.current_token()
        
        Match token.type:
            When STRING:
                self.lexer.advance()
                Return StringValue with value as token.value
            When INT:
                self.lexer.advance()
                Return IntValue with value as parse_integer with str as token.value
            When FLOAT:
                self.lexer.advance()
                Return FloatValue with value as parse_float with str as token.value
            When BOOLEAN:
                self.lexer.advance()
                Return BooleanValue with value as token.value is equal to "true"
            When NULL:
                self.lexer.advance()
                Return NullValue
            When LEFT_BRACKET:
                Return self.parse_list_value()
            When LEFT_BRACE:
                Return self.parse_object_value()
            When VARIABLE:
                self.lexer.advance()
                Return VariableValue with name as token.value
            Otherwise:
                Return StringValue with value as token.value

    Process called "parse_list_value" returns GraphQLValue:
        Let values be list containing
        
        self.lexer.expect_token with type as LEFT_BRACKET
        
        While not self.lexer.check_token with type as RIGHT_BRACKET:
            Let value be self.parse_value()
            Add value to values
        
        self.lexer.expect_token with type as RIGHT_BRACKET
        
        Return ListValue with values as values

    Process called "parse_object_value" returns GraphQLValue:
        Let fields be dictionary containing
        
        self.lexer.expect_token with type as LEFT_BRACE
        
        While not self.lexer.check_token with type as RIGHT_BRACE:
            Let field_name be self.lexer.expect_name()
            self.lexer.expect_token with type as COLON
            Let field_value be self.parse_value()
            Set fields[field_name] to field_value
        
        self.lexer.expect_token with type as RIGHT_BRACE
        
        Return ObjectValue with fields as fields

    Process called "parse_fragment_selection" returns GraphQLSelection:
        self.lexer.expect_token with type as SPREAD
        
        If self.lexer.check_token with type as NAME and self.lexer.peek_token().value is not equal to "on":
            Let fragment_name be self.lexer.expect_name()
            Let directives be self.parse_directives()
            Return FragmentSpread with fragment_name as fragment_name and directives as directives
        
        Let type_condition be null
        If self.lexer.check_token with type as NAME and self.lexer.current_token().value is equal to "on":
            self.lexer.advance()
            Set type_condition to self.lexer.expect_name()
        
        Let directives be self.parse_directives()
        Let selection_set be self.parse_selection_set()
        
        Return InlineFragment with:
            type_condition as type_condition
            selection_set as selection_set
            directives as directives

    Process called "parse_directives" returns List[GraphQLDirectiveUsage]:
        Let directives be list containing
        
        While self.lexer.check_token with type as AT:
            self.lexer.advance()
            Let directive_name be self.lexer.expect_name()
            Let arguments be self.parse_arguments()
            
            Add GraphQLDirectiveUsage with:
                name as directive_name
                arguments as arguments
            to directives
        
        Return directives

    Process called "parse_fragment" returns GraphQLFragment:
        self.lexer.expect_token with type as FRAGMENT
        Let fragment_name be self.lexer.expect_name()
        self.lexer.expect_token with type as ON
        Let type_condition be self.lexer.expect_name()
        Let directives be self.parse_directives()
        Let selection_set be self.parse_selection_set()
        
        Return GraphQLFragment with:
            name as fragment_name
            type_condition as type_condition
            directives as directives
            selection_set as selection_set

    Process called "parse_variable_definitions" returns List[GraphQLVariableDefinition]:
        Let variables be list containing
        
        If self.lexer.check_token with type as LEFT_PAREN:
            self.lexer.advance()
            
            While not self.lexer.check_token with type as RIGHT_PAREN:
                Let variable be self.parse_variable_definition()
                Add variable to variables
            
            self.lexer.expect_token with type as RIGHT_PAREN
        
        Return variables

    Process called "parse_variable_definition" returns GraphQLVariableDefinition:
        self.lexer.expect_token with type as VARIABLE
        Let variable_name be self.lexer.expect_name()
        self.lexer.expect_token with type as COLON
        Let variable_type be self.parse_type()
        
        Let default_value be null
        If self.lexer.check_token with type as EQUALS:
            self.lexer.advance()
            Set default_value to self.parse_value()
        
        Return GraphQLVariableDefinition with:
            variable as variable_name
            variable_type as variable_type
            default_value as default_value

    Process called "parse_type" returns GraphQLType:
        Let base_type be self.parse_base_type()
        
        If self.lexer.check_token with type as EXCLAMATION:
            self.lexer.advance()
            Return NonNullType with inner_type as base_type
        
        Return base_type

    Process called "parse_base_type" returns GraphQLType:
        If self.lexer.check_token with type as LEFT_BRACKET:
            self.lexer.advance()
            Let inner_type be self.parse_type()
            self.lexer.expect_token with type as RIGHT_BRACKET
            Return ListType with inner_type as inner_type
        
        Let type_name be self.lexer.expect_name()
        Return ObjectType with:
            name as type_name
            fields as dictionary containing
            interfaces as list containing

    Process called "parse_optional_name" returns Optional[String]:
        If self.lexer.check_token with type as NAME:
            Return self.lexer.expect_name()
        Return null

Note: GraphQL Lexer
Type called "GraphQLLexer":
    input as String
    position as Integer
    tokens as List[GraphQLToken]
    current_position as Integer

    Process called "create" returns GraphQLLexer:
        Return GraphQLLexer with:
            input as ""
            position as 0
            tokens as list containing
            current_position as 0

    Process called "tokenize" that takes input as String returns None:
        Set self.input to input
        Set self.position to 0
        Set self.tokens to list containing
        Set self.current_position to 0
        
        While self.position is less than length of self.input:
            self.skip_whitespace()
            If self.position is greater than or equal to length of self.input:
                Break
            
            Let token be self.read_next_token()
            If token is not null:
                Add token to self.tokens

    Process called "read_next_token" returns Optional[GraphQLToken]:
        Let char be self.input[self.position]
        
        Match char:
            When "{":
                self.advance_position()
                Return GraphQLToken with type as LEFT_BRACE and value as "{"
            When "}":
                self.advance_position()
                Return GraphQLToken with type as RIGHT_BRACE and value as "}"
            When "(":
                self.advance_position()
                Return GraphQLToken with type as LEFT_PAREN and value as "("
            When ")":
                self.advance_position()
                Return GraphQLToken with type as RIGHT_PAREN and value as ")"
            When "[":
                self.advance_position()
                Return GraphQLToken with type as LEFT_BRACKET and value as "["
            When "]":
                self.advance_position()
                Return GraphQLToken with type as RIGHT_BRACKET and value as "]"
            When ":":
                self.advance_position()
                Return GraphQLToken with type as COLON and value as ":"
            When "!":
                self.advance_position()
                Return GraphQLToken with type as EXCLAMATION and value as "!"
            When "=":
                self.advance_position()
                Return GraphQLToken with type as EQUALS and value as "="
            When "@":
                self.advance_position()
                Return GraphQLToken with type as AT and value as "@"
            When "$":
                self.advance_position()
                Return GraphQLToken with type as VARIABLE and value as "$"
            When ".":
                Return self.read_spread_token()
            When "\"":
                Return self.read_string_token()
            Otherwise:
                If char is alphabetic or char is equal to "_":
                    Return self.read_name_token()
                Otherwise If char is numeric or char is equal to "-":
                    Return self.read_number_token()
                Otherwise:
                    self.advance_position()
                    Return null

    Process called "read_spread_token" returns GraphQLToken:
        Let start_pos be self.position
        self.advance_position()
        
        If self.position is less than length of self.input and self.input[self.position] is equal to ".":
            self.advance_position()
            If self.position is less than length of self.input and self.input[self.position] is equal to ".":
                self.advance_position()
                Return GraphQLToken with type as SPREAD and value as "..."
        
        Set self.position to start_pos
        self.advance_position()
        Return GraphQLToken with type as DOT and value as "."

    Process called "read_string_token" returns GraphQLToken:
        self.advance_position()
        Let start_pos be self.position
        
        While self.position is less than length of self.input and self.input[self.position] is not equal to "\"":
            self.advance_position()
        
        Let value be self.input.substring with start as start_pos and end as self.position
        self.advance_position()
        
        Return GraphQLToken with type as STRING and value as value

    Process called "read_name_token" returns GraphQLToken:
        Let start_pos be self.position
        
        While self.position is less than length of self.input and (self.input[self.position] is alphanumeric or self.input[self.position] is equal to "_"):
            self.advance_position()
        
        Let value be self.input.substring with start as start_pos and end as self.position
        Let token_type be self.get_keyword_type with value as value
        
        Return GraphQLToken with type as token_type and value as value

    Process called "read_number_token" returns GraphQLToken:
        Let start_pos be self.position
        Let is_float be false
        
        If self.input[self.position] is equal to "-":
            self.advance_position()
        
        While self.position is less than length of self.input and self.input[self.position] is numeric:
            self.advance_position()
        
        If self.position is less than length of self.input and self.input[self.position] is equal to ".":
            Set is_float to true
            self.advance_position()
            While self.position is less than length of self.input and self.input[self.position] is numeric:
                self.advance_position()
        
        Let value be self.input.substring with start as start_pos and end as self.position
        Let token_type be if is_float then FLOAT otherwise INT
        
        Return GraphQLToken with type as token_type and value as value

    Process called "get_keyword_type" that takes value as String returns TokenType:
        Match value:
            When "query":
                Return QUERY
            When "mutation":
                Return MUTATION
            When "subscription":
                Return SUBSCRIPTION
            When "fragment":
                Return FRAGMENT
            When "on":
                Return ON
            When "true":
                Return BOOLEAN
            When "false":
                Return BOOLEAN
            When "null":
                Return NULL
            Otherwise:
                Return NAME

    Process called "skip_whitespace" returns None:
        While self.position is less than length of self.input and self.input[self.position] is whitespace:
            self.advance_position()

    Process called "advance_position" returns None:
        Set self.position to self.position 1

    Process called "current_token" returns GraphQLToken:
        If self.current_position is less than length of self.tokens:
            Return self.tokens[self.current_position]
        Return GraphQLToken with type as EOF and value as ""

    Process called "advance" returns None:
        Set self.current_position to self.current_position 1

    Process called "check_token" that takes type as TokenType returns Boolean:
        Let token be self.current_token()
        Return token.type is equal to type

    Process called "expect_token" that takes type as TokenType returns GraphQLToken:
        Let token be self.current_token()
        If token.type is not equal to type:
            Error with message as "Expected " concatenated with type.to_string() concatenated with " but got " concatenated with token.type.to_string()
        self.advance()
        Return token

    Process called "expect_name" returns String:
        Let token be self.expect_token with type as NAME
        Return token.value

    Process called "peek_token" returns GraphQLToken:
        If self.current_position 1 is less than length of self.tokens:
            Return self.tokens[self.current_position 1]
        Return GraphQLToken with type as EOF and value as ""

    Process called "is_at_end" returns Boolean:
        Let token be self.current_token()
        Return token.type is equal to EOF

Type called "GraphQLToken":
    type as TokenType
    value as String

Type TokenType is:
    | LEFT_BRACE | RIGHT_BRACE | LEFT_PAREN | RIGHT_PAREN | LEFT_BRACKET | RIGHT_BRACKET
    | COLON | EXCLAMATION | EQUALS | AT | VARIABLE | SPREAD | DOT
    | STRING | INT | FLOAT | BOOLEAN | NULL | NAME
    | QUERY | MUTATION | SUBSCRIPTION | FRAGMENT | ON
    | EOF

Type called "ParseResult":
    success as Boolean
    document as Optional[GraphQLDocument]
    errors as List[String]

Note: GraphQL Execution Engine
Type called "GraphQLExecutor":
    schema as GraphQLSchema

    Process called "create" that takes schema as GraphQLSchema returns GraphQLExecutor:
        Return GraphQLExecutor with:
            schema as schema

    Process called "execute" that takes document as GraphQLDocument and variables as Dictionary[String, Any] and context as Any returns ExecutionResult:
        Let operation be self.get_operation_from_document with document as document
        If operation is null:
            Return ExecutionResult with:
                data as null
                errors as list containing "No operation found"

        Match operation.operation_type:
            When QUERY:
                Return self.execute_query with operation as operation and variables as variables and context as context
            When MUTATION:
                Return self.execute_mutation with operation as operation and variables as variables and context as context
            When SUBSCRIPTION:
                Return self.execute_subscription with operation as operation and variables as variables and context as context

    Process called "execute_query" that takes operation as GraphQLOperation and variables as Dictionary[String, Any] and context as Any returns ExecutionResult:
        Let execution_context be ExecutionContext with:
            schema as self.schema
            operation as operation
            variables as variables
            context as context
            errors as list containing

        Let result be self.execute_selection_set with:
            selection_set as operation.selection_set
            root_type as self.schema.query_type
            root_value as null
            context as execution_context

        Return ExecutionResult with:
            data as result
            errors as execution_context.errors

    Process called "execute_mutation" that takes operation as GraphQLOperation and variables as Dictionary[String, Any] and context as Any returns ExecutionResult:
        Let execution_context be ExecutionContext with:
            schema as self.schema
            operation as operation
            variables as variables
            context as context
            errors as list containing

        If self.schema.mutation_type is null:
            execution_context.errors.add with item as "Schema does not support mutations"
            Return ExecutionResult with data as null and errors as execution_context.errors

        Let result be self.execute_selection_set with:
            selection_set as operation.selection_set
            root_type as self.schema.mutation_type
            root_value as null
            context as execution_context

        Return ExecutionResult with:
            data as result
            errors as execution_context.errors

    Process called "execute_subscription" that takes operation as GraphQLOperation and variables as Dictionary[String, Any] and context as Any returns ExecutionResult:
        Return ExecutionResult with:
            data as null
            errors as list containing "Subscriptions not yet implemented"

    Process called "execute_selection_set" that takes selection_set as GraphQLSelectionSet and root_type as GraphQLType and root_value as Any and context as ExecutionContext returns Any:
        Let result be dictionary containing

        For each selection in selection_set.selections:
            Match selection:
                When FieldSelection with field as field_sel:
                    Let field_name be field_sel.alias or field_sel.name
                    Let field_result be self.execute_field with:
                        field_selection as field_sel
                        parent_type as root_type
                        parent_value as root_value
                        context as context
                    Set result[field_name] to field_result

                When FragmentSpread with fragment_name as frag_name:
                    Let fragment be self.get_fragment with name as frag_name and context as context
                    If fragment is not null:
                        Let fragment_result be self.execute_selection_set with:
                            selection_set as fragment.selection_set
                            root_type as root_type
                            root_value as root_value
                            context as context
                        result.merge with other as fragment_result

                When InlineFragment with selection_set as inline_set:
                    Let fragment_result be self.execute_selection_set with:
                        selection_set as inline_set
                        root_type as root_type
                        root_value as root_value
                        context as context
                    result.merge with other as fragment_result

        Return result

    Process called "execute_field" that takes field_selection as GraphQLFieldSelection and parent_type as GraphQLType and parent_value as Any and context as ExecutionContext returns Any:
        Let field_definition be self.get_field_definition with:
            parent_type as parent_type
            field_name as field_selection.name

        If field_definition is null:
            context.errors.add with item as "Field '" concatenated with field_selection.name concatenated with "' not found"
            Return null

        Let argument_values be self.resolve_arguments with:
            field_definition as field_definition
            field_selection as field_selection
            context as context

        Try:
            Let field_result be field_definition.resolver with:
                parent as parent_value
                arguments as argument_values
                context as context.context

            If field_selection.selection_set is not null:
                Return self.execute_selection_set with:
                    selection_set as field_selection.selection_set
                    root_type as field_definition.field_type
                    root_value as field_result
                    context as context

            Return field_result

        Catch error:
            context.errors.add with item as "Error executing field '" concatenated with field_selection.name concatenated with "': " concatenated with error.message
            Return null

    Process called "resolve_arguments" that takes field_definition as GraphQLField and field_selection as GraphQLFieldSelection and context as ExecutionContext returns Dictionary[String, Any]:
        Let resolved_args be dictionary containing

        For each arg_name in field_definition.arguments:
            Let arg_definition be field_definition.arguments[arg_name]
            Let arg_value be field_selection.arguments.get with key as arg_name

            If arg_value is not null:
                Set resolved_args[arg_name] to self.resolve_value with value as arg_value and context as context
            Otherwise If arg_definition.default_value is not null:
                Set resolved_args[arg_name] to arg_definition.default_value

        Return resolved_args

    Process called "resolve_value" that takes value as GraphQLValue and context as ExecutionContext returns Any:
        Match value:
            When StringValue with value as str_val:
                Return str_val
            When IntValue with value as int_val:
                Return int_val
            When FloatValue with value as float_val:
                Return float_val
            When BooleanValue with value as bool_val:
                Return bool_val
            When NullValue:
                Return null
            When VariableValue with name as var_name:
                Return context.variables.get with key as var_name
            When ListValue with values as list_vals:
                Let resolved_list be list containing
                For each item in list_vals:
                    Add self.resolve_value with value as item and context as context to resolved_list
                Return resolved_list
            When ObjectValue with fields as obj_fields:
                Let resolved_object be dictionary containing
                For each field_name in obj_fields:
                    Set resolved_object[field_name] to self.resolve_value with value as obj_fields[field_name] and context as context
                Return resolved_object

    Process called "get_operation_from_document" that takes document as GraphQLDocument returns Optional[GraphQLOperation]:
        For each definition in document.definitions:
            Match definition:
                When OperationDefinition with operation as op:
                    Return op
        Return null

    Process called "get_field_definition" that takes parent_type as GraphQLType and field_name as String returns Optional[GraphQLField]:
        Match parent_type:
            When ObjectType with fields as fields:
                Return fields.get with key as field_name
            When InterfaceType with fields as fields:
                Return fields.get with key as field_name
        Return null

    Process called "get_fragment" that takes name as String and context as ExecutionContext returns Optional[GraphQLFragment]:
        Return null

Type called "ExecutionContext":
    schema as GraphQLSchema
    operation as GraphQLOperation
    variables as Dictionary[String, Any]
    context as Any
    errors as List[String]

Type called "ExecutionResult":
    data as Any
    errors as List[String]

Type called "ValidationResult":
    valid as Boolean
    errors as List[String]

Note: Built-in Scalar Types
Process called "create_default_scalar_types" returns Dictionary[String, GraphQLType]:
    Return dictionary with:
        "String" as ScalarType with:
            name as "String"
            serializer as Process that takes value: Return value.to_string()
            deserializer as Process that takes value: Return value.to_string()
        "Int" as ScalarType with:
            name as "Int"
            serializer as Process that takes value: Return value as Integer
            deserializer as Process that takes value: Return parse_integer with str as value
        "Float" as ScalarType with:
            name as "Float"
            serializer as Process that takes value: Return value as Float
            deserializer as Process that takes value: Return parse_float with str as value
        "Boolean" as ScalarType with:
            name as "Boolean"
            serializer as Process that takes value: Return value as Boolean
            deserializer as Process that takes value: Return value is equal to "true"
        "ID" as ScalarType with:
            name as "ID"
            serializer as Process that takes value: Return value.to_string()
            deserializer as Process that takes value: Return value.to_string()

Process called "create_default_directives" returns Dictionary[String, GraphQLDirective]:
    Return dictionary with:
        "skip" as GraphQLDirective with:
            name as "skip"
            locations as list containing FIELD, FRAGMENT_SPREAD, INLINE_FRAGMENT
            arguments as dictionary with:
                "if" as GraphQLArgument with:
                    name as "if"
                    argument_type as ScalarType with name as "Boolean" and serializer as null and deserializer as null
                    default_value as null
                    description as "Skipped when true"
            is_repeatable as false
        "include" as GraphQLDirective with:
            name as "include"
            locations as list containing FIELD, FRAGMENT_SPREAD, INLINE_FRAGMENT
            arguments as dictionary with:
                "if" as GraphQLArgument with:
                    name as "if"
                    argument_type as ScalarType with name as "Boolean" and serializer as null and deserializer as null
                    default_value as null
                    description as "Included when true"
            is_repeatable as false

Note: Utility Functions
Process called "create_graphql_schema" that takes query_type as GraphQLType returns GraphQLSchema:
    Return GraphQLSchema.create with query_type as query_type

Process called "object_type" that takes name as String returns GraphQLType:
    Return ObjectType with:
        name as name
        fields as dictionary containing
        interfaces as list containing

Process called "field" that takes name as String and field_type as GraphQLType and resolver as Process returns GraphQLField:
    Return GraphQLField with:
        name as name
        field_type as field_type
        arguments as dictionary containing
        resolver as resolver
        description as ""
        deprecation_reason as null
        is_deprecated as false

Process called "string_type" returns GraphQLType:
    Return ScalarType with:
        name as "String"
        serializer as Process that takes value: Return value.to_string()
        deserializer as Process that takes value: Return value.to_string()

Process called "int_type" returns GraphQLType:
    Return ScalarType with:
        name as "Int"
        serializer as Process that takes value: Return value as Integer
        deserializer as Process that takes value: Return parse_integer with str as value

Process called "parse_integer" that takes str as String returns Integer:
    Return 0

Process called "parse_float" that takes str as String returns Float:
    Return 0.0

