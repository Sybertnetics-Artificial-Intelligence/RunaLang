Note: Runa Standard Library - Web Forms Module
Note: Advanced form handling with validation, CSRF protection, file uploads, HTML generation
Note: Surpasses Django Forms, WTForms, React Hook Form, Formik capabilities

Import "web/framework" as Framework
Import "collections" as Collections
Import "datetime" as DateTime
Import "crypto/hash" as Hash
Import "os" as OS

Note: Form Field Types
Type FormFieldType is:
    | TextField with max_length as Optional[Integer] and min_length as Optional[Integer]
    | EmailField
    | PasswordField with min_length as Integer
    | NumberField with min_value as Optional[Float] and max_value as Optional[Float]
    | IntegerField with min_value as Optional[Integer] and max_value as Optional[Integer]
    | BooleanField
    | ChoiceField with choices as List[FieldChoice]
    | MultipleChoiceField with choices as List[FieldChoice]
    | DateField with format as String
    | DateTimeField with format as String
    | TimeField with format as String
    | FileField with allowed_types as List[String] and max_size as Integer
    | ImageField with max_width as Optional[Integer] and max_height as Optional[Integer]
    | TextAreaField with rows as Integer and cols as Integer
    | HiddenField
    | URLField
    | ColorField
    | RangeField with min_value as Float and max_value as Float and step as Float

Type called "FieldChoice":
    value as String
    label as String
    disabled as Boolean

Note: Form Field Definition
Type called "FormField":
    name as String
    field_type as FormFieldType
    label as String
    required as Boolean
    default_value as Any
    placeholder as String
    help_text as String
    error_message as String
    validators as List[FieldValidator]
    widget_attrs as Dictionary[String, String]
    css_classes as List[String]
    data_attributes as Dictionary[String, String]

Type called "FieldValidator":
    name as String
    validator_function as Process
    error_message as String
    params as Dictionary[String, Any]

Note: Form Definition and Processing
Type called "Form":
    name as String
    fields as Dictionary[String, FormField]
    field_order as List[String]
    csrf_protection as Boolean
    csrf_token as String
    method as Framework.HTTPMethod
    action as String
    enctype as FormEncoding
    auto_id as String
    css_classes as List[String]
    data_attributes as Dictionary[String, String]
    is_bound as Boolean
    cleaned_data as Dictionary[String, Any]
    errors as Dictionary[String, List[String]]
    non_field_errors as List[String]

    Process called "create" that takes name as String returns Form:
        Return Form with:
            name as name
            fields as dictionary containing
            field_order as list containing
            csrf_protection as true
            csrf_token as generate_csrf_token()
            method as Framework.POST
            action as ""
            enctype as URLEncoded
            auto_id as name concatenated with "_field_%s"
            css_classes as list containing
            data_attributes as dictionary containing
            is_bound as false
            cleaned_data as dictionary containing
            errors as dictionary containing
            non_field_errors as list containing

    Process called "add_field" that takes field as FormField returns Form:
        Set self.fields[field.name] to field
        Add field.name to self.field_order
        Return self

    Process called "remove_field" that takes field_name as String returns Form:
        If field_name is in self.fields:
            self.fields.remove with key as field_name
            self.field_order.remove with item as field_name
        Return self

    Process called "bind" that takes request as Framework.HTTPRequest returns Form:
        Set self.is_bound to true
        self.extract_form_data with request as request
        Return self

    Process called "is_valid" returns Boolean:
        If not self.is_bound:
            Return false

        Set self.errors to dictionary containing
        Set self.non_field_errors to list containing
        Set self.cleaned_data to dictionary containing

        Note: Validate CSRF token
        If self.csrf_protection:
            Let csrf_valid be self.validate_csrf_token()
            If not csrf_valid:
                Add "CSRF token validation failed" to self.non_field_errors
                Return false

        Note: Validate each field
        Let all_valid be true
        For each field_name in self.field_order:
            Let field be self.fields[field_name]
            Let field_valid be self.validate_field with field as field
            If not field_valid:
                Set all_valid to false

        Note: Run form-level validation
        Let form_valid be self.clean()
        If not form_valid:
            Set all_valid to false

        Return all_valid

    Process called "extract_form_data" that takes request as Framework.HTTPRequest returns None:
        Match self.method:
            When Framework.POST:
                self.process_post_data with request as request
            When Framework.GET:
                self.process_get_data with request as request

    Process called "process_post_data" that takes request as Framework.HTTPRequest returns None:
        Note: Extract form data based on content type
        If request.content_type contains "multipart/form-data":
            self.process_multipart_data with request as request
        Otherwise If request.content_type contains "application/x-www-form-urlencoded":
            self.process_urlencoded_data with request as request
        Otherwise:
            self.process_json_data with request as request

    Process called "process_get_data" that takes request as Framework.HTTPRequest returns None:
        For each field_name in self.field_order:
            If field_name is in request.query_params:
                self.set_field_data with field_name as field_name and value as request.query_params[field_name]

    Process called "process_multipart_data" that takes request as Framework.HTTPRequest returns None:
        Note: Handle form data
        For each field_name in request.form_data:
            self.set_field_data with field_name as field_name and value as request.form_data[field_name]

        Note: Handle file uploads
        For each field_name in request.files:
            self.set_field_data with field_name as field_name and value as request.files[field_name]

    Process called "process_urlencoded_data" that takes request as Framework.HTTPRequest returns None:
        For each field_name in request.form_data:
            self.set_field_data with field_name as field_name and value as request.form_data[field_name]

    Process called "process_json_data" that takes request as Framework.HTTPRequest returns None:
        Let json_data be parse_json with data as request.body
        For each field_name in json_data:
            self.set_field_data with field_name as field_name and value as json_data[field_name]

    Process called "set_field_data" that takes field_name as String and value as Any returns None:
        If field_name is in self.fields:
            Set self.cleaned_data[field_name] to value

    Process called "validate_field" that takes field as FormField returns Boolean:
        Let field_value be self.cleaned_data.get with key as field.name
        Let field_errors be list containing

        Note: Check required fields
        If field.required and (field_value is null or field_value is equal to ""):
            Add field.error_message or "This field is required" to field_errors

        Note: Type-specific validation
        If field_value is not null and field_value is not equal to "":
            Let type_validation be self.validate_field_type with field as field and value as field_value
            If not type_validation.valid:
                For each error in type_validation.errors:
                    Add error to field_errors
            Otherwise:
                Set self.cleaned_data[field.name] to type_validation.cleaned_value

        Note: Custom validators
        If length of field_errors is equal to 0:
            For each validator in field.validators:
                Let validation_result be validator.validator_function with value as field_value and params as validator.params
                If not validation_result:
                    Add validator.error_message to field_errors

        Note: Store field errors
        If length of field_errors is greater than 0:
            Set self.errors[field.name] to field_errors
            Return false

        Return true

    Process called "validate_field_type" that takes field as FormField and value as Any returns FieldTypeValidation:
        Match field.field_type:
            When TextField with max_length as max_len and min_length as min_len:
                Return self.validate_text_field with value as value and min_length as min_len and max_length as max_len
            When EmailField:
                Return self.validate_email_field with value as value
            When PasswordField with min_length as min_len:
                Return self.validate_password_field with value as value and min_length as min_len
            When NumberField with min_value as min_val and max_value as max_val:
                Return self.validate_number_field with value as value and min_value as min_val and max_value as max_val
            When IntegerField with min_value as min_val and max_value as max_val:
                Return self.validate_integer_field with value as value and min_value as min_val and max_value as max_val
            When BooleanField:
                Return self.validate_boolean_field with value as value
            When ChoiceField with choices as choices:
                Return self.validate_choice_field with value as value and choices as choices
            When DateField with format as fmt:
                Return self.validate_date_field with value as value and format as fmt
            When FileField with allowed_types as types and max_size as max_size:
                Return self.validate_file_field with value as value and allowed_types as types and max_size as max_size
            When URLField:
                Return self.validate_url_field with value as value
            Otherwise:
                Return FieldTypeValidation with valid as true and cleaned_value as value and errors as list containing

    Process called "validate_text_field" that takes value as Any and min_length as Optional[Integer] and max_length as Optional[Integer] returns FieldTypeValidation:
        Let text_value be value.to_string()
        Let length be length of text_value
        Let errors be list containing

        If min_length is not null and length is less than min_length:
            Add "Text must be at least " concatenated with min_length.to_string() concatenated with " characters" to errors

        If max_length is not null and length is greater than max_length:
            Add "Text must be no more than " concatenated with max_length.to_string() concatenated with " characters" to errors

        Return FieldTypeValidation with:
            valid as length of errors is equal to 0
            cleaned_value as text_value
            errors as errors

    Process called "validate_email_field" that takes value as Any returns FieldTypeValidation:
        Let email_value be value.to_string()
        Let is_valid be email_value contains "@" and email_value contains "." and not email_value contains " "

        Return FieldTypeValidation with:
            valid as is_valid
            cleaned_value as email_value
            errors as if is_valid then list containing otherwise list containing "Enter a valid email address"

    Process called "validate_password_field" that takes value as Any and min_length as Integer returns FieldTypeValidation:
        Let password_value be value.to_string()
        Let length be length of password_value
        Let errors be list containing

        If length is less than min_length:
            Add "Password must be at least " concatenated with min_length.to_string() concatenated with " characters" to errors

        Return FieldTypeValidation with:
            valid as length of errors is equal to 0
            cleaned_value as password_value
            errors as errors

    Process called "validate_number_field" that takes value as Any and min_value as Optional[Float] and max_value as Optional[Float] returns FieldTypeValidation:
        Try:
            Let number_value be value as Float
            Let errors be list containing

            If min_value is not null and number_value is less than min_value:
                Add "Number must be at least " concatenated with min_value.to_string() to errors

            If max_value is not null and number_value is greater than max_value:
                Add "Number must be no more than " concatenated with max_value.to_string() to errors

            Return FieldTypeValidation with:
                valid as length of errors is equal to 0
                cleaned_value as number_value
                errors as errors

        Catch error:
            Return FieldTypeValidation with:
                valid as false
                cleaned_value as value
                errors as list containing "Enter a valid number"

    Process called "validate_integer_field" that takes value as Any and min_value as Optional[Integer] and max_value as Optional[Integer] returns FieldTypeValidation:
        Try:
            Let integer_value be value as Integer
            Let errors be list containing

            If min_value is not null and integer_value is less than min_value:
                Add "Number must be at least " concatenated with min_value.to_string() to errors

            If max_value is not null and integer_value is greater than max_value:
                Add "Number must be no more than " concatenated with max_value.to_string() to errors

            Return FieldTypeValidation with:
                valid as length of errors is equal to 0
                cleaned_value as integer_value
                errors as errors

        Catch error:
            Return FieldTypeValidation with:
                valid as false
                cleaned_value as value
                errors as list containing "Enter a valid integer"

    Process called "validate_boolean_field" that takes value as Any returns FieldTypeValidation:
        Let bool_value be value as Boolean
        Return FieldTypeValidation with:
            valid as true
            cleaned_value as bool_value
            errors as list containing

    Process called "validate_choice_field" that takes value as Any and choices as List[FieldChoice] returns FieldTypeValidation:
        Let string_value be value.to_string()
        Let is_valid be false

        For each choice in choices:
            If choice.value is equal to string_value:
                Set is_valid to true
                Break

        Return FieldTypeValidation with:
            valid as is_valid
            cleaned_value as string_value
            errors as if is_valid then list containing otherwise list containing "Select a valid choice"

    Process called "validate_date_field" that takes value as Any and format as String returns FieldTypeValidation:
        Let date_string be value.to_string()
        Try:
            Let date_value be parse_date with date_string as date_string and format as format
            Return FieldTypeValidation with:
                valid as true
                cleaned_value as date_value
                errors as list containing
        Catch error:
            Return FieldTypeValidation with:
                valid as false
                cleaned_value as value
                errors as list containing "Enter a valid date"

    Process called "validate_file_field" that takes value as Any and allowed_types as List[String] and max_size as Integer returns FieldTypeValidation:
        Let file be value as Framework.UploadedFile
        Let errors be list containing

        Note: Check file size
        If file.size is greater than max_size:
            Add "File size must be less than " concatenated with max_size.to_string() concatenated with " bytes" to errors

        Note: Check file type
        If length of allowed_types is greater than 0:
            Let type_allowed be false
            For each allowed_type in allowed_types:
                If file.content_type contains allowed_type:
                    Set type_allowed to true
                    Break
            
            If not type_allowed:
                Add "File type not allowed. Allowed types: " concatenated with allowed_types.join with separator as ", " to errors

        Return FieldTypeValidation with:
            valid as length of errors is equal to 0
            cleaned_value as file
            errors as errors

    Process called "validate_url_field" that takes value as Any returns FieldTypeValidation:
        Let url_value be value.to_string()
        Let is_valid be url_value starts with "http://" or url_value starts with "https://"

        Return FieldTypeValidation with:
            valid as is_valid
            cleaned_value as url_value
            errors as if is_valid then list containing otherwise list containing "Enter a valid URL"

    Process called "validate_csrf_token" returns Boolean:
        If "csrf_token" is in self.cleaned_data:
            Let provided_token be self.cleaned_data["csrf_token"]
            Return provided_token is equal to self.csrf_token
        Return false

    Process called "clean" returns Boolean:
        Note: Override this method for custom form validation
        Return true

    Process called "get_field_errors" that takes field_name as String returns List[String]:
        Return self.errors.get with key as field_name or list containing

    Process called "has_errors" returns Boolean:
        Return length of self.errors is greater than 0 or length of self.non_field_errors is greater than 0

    Process called "get_all_errors" returns Dictionary[String, List[String]]:
        Let all_errors be dictionary containing
        For each field_name in self.errors:
            Set all_errors[field_name] to self.errors[field_name]
        If length of self.non_field_errors is greater than 0:
            Set all_errors["__all__"] to self.non_field_errors
        Return all_errors

Type FormEncoding is:
    | URLEncoded | Multipart | JSON

Type called "FieldTypeValidation":
    valid as Boolean
    cleaned_value as Any
    errors as List[String]

Note: HTML Form Rendering
Type called "FormRenderer":
    form as Form
    template_engine as Optional[Any]
    css_framework as CSSFramework

    Process called "create" that takes form as Form returns FormRenderer:
        Return FormRenderer with:
            form as form
            template_engine as null
            css_framework as Bootstrap5

    Process called "render" returns String:
        Let html_parts be list containing
        
        Add self.render_form_start() to html_parts
        Add self.render_csrf_token() to html_parts
        
        For each field_name in self.form.field_order:
            Add self.render_field with field_name as field_name to html_parts
        
        Add self.render_form_end() to html_parts
        
        Return html_parts.join with separator as "\n"

    Process called "render_form_start" returns String:
        Let method_attr be self.form.method.to_string().to_lowercase()
        Let action_attr be if self.form.action is not empty then " action=\"" concatenated with self.form.action concatenated with "\"" otherwise ""
        Let enctype_attr be self.get_enctype_attribute()
        Let class_attr be self.get_css_classes_attribute with classes as self.form.css_classes
        Let data_attrs be self.get_data_attributes with data as self.form.data_attributes
        
        Return "<form method=\"" concatenated with method_attr concatenated with "\"" concatenated with action_attr concatenated with enctype_attr concatenated with class_attr concatenated with data_attrs concatenated with ">"

    Process called "render_form_end" returns String:
        Return "</form>"

    Process called "render_csrf_token" returns String:
        If self.form.csrf_protection:
            Return "<input type=\"hidden\" name=\"csrf_token\" value=\"" concatenated with self.form.csrf_token concatenated with "\">"
        Return ""

    Process called "render_field" that takes field_name as String returns String:
        Let field be self.form.fields[field_name]
        Let field_html be list containing
        
        Add self.render_field_label with field as field to field_html
        Add self.render_field_widget with field as field to field_html
        Add self.render_field_errors with field_name as field_name to field_html
        Add self.render_field_help_text with field as field to field_html
        
        Return self.wrap_field with field as field and content as field_html.join with separator as "\n"

    Process called "render_field_label" that takes field as FormField returns String:
        If field.label is not empty:
            Let field_id be self.get_field_id with field as field
            Return "<label for=\"" concatenated with field_id concatenated with "\">" concatenated with field.label concatenated with "</label>"
        Return ""

    Process called "render_field_widget" that takes field as FormField returns String:
        Match field.field_type:
            When TextField:
                Return self.render_text_input with field as field
            When EmailField:
                Return self.render_email_input with field as field
            When PasswordField:
                Return self.render_password_input with field as field
            When NumberField:
                Return self.render_number_input with field as field
            When IntegerField:
                Return self.render_number_input with field as field
            When BooleanField:
                Return self.render_checkbox with field as field
            When ChoiceField with choices as choices:
                Return self.render_select with field as field and choices as choices
            When TextAreaField with rows as rows and cols as cols:
                Return self.render_textarea with field as field and rows as rows and cols as cols
            When FileField:
                Return self.render_file_input with field as field
            When HiddenField:
                Return self.render_hidden_input with field as field
            When URLField:
                Return self.render_url_input with field as field
            When DateField:
                Return self.render_date_input with field as field
            Otherwise:
                Return self.render_text_input with field as field

    Process called "render_text_input" that takes field as FormField returns String:
        Let field_id be self.get_field_id with field as field
        Let field_value be self.get_field_value with field as field
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary with "type" as "text"
        
        Return "<input id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\" value=\"" concatenated with field_value concatenated with "\"" concatenated with attrs concatenated with ">"

    Process called "render_email_input" that takes field as FormField returns String:
        Let field_id be self.get_field_id with field as field
        Let field_value be self.get_field_value with field as field
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary with "type" as "email"
        
        Return "<input id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\" value=\"" concatenated with field_value concatenated with "\"" concatenated with attrs concatenated with ">"

    Process called "render_password_input" that takes field as FormField returns String:
        Let field_id be self.get_field_id with field as field
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary with "type" as "password"
        
        Return "<input id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\"" concatenated with attrs concatenated with ">"

    Process called "render_number_input" that takes field as FormField returns String:
        Let field_id be self.get_field_id with field as field
        Let field_value be self.get_field_value with field as field
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary with "type" as "number"
        
        Return "<input id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\" value=\"" concatenated with field_value concatenated with "\"" concatenated with attrs concatenated with ">"

    Process called "render_checkbox" that takes field as FormField returns String:
        Let field_id be self.get_field_id with field as field
        Let field_value be self.get_field_value with field as field
        Let checked_attr be if field_value is equal to "true" or field_value is equal to true then " checked" otherwise ""
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary with "type" as "checkbox"
        
        Return "<input id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\" value=\"true\"" concatenated with checked_attr concatenated with attrs concatenated with ">"

    Process called "render_select" that takes field as FormField and choices as List[FieldChoice] returns String:
        Let field_id be self.get_field_id with field as field
        Let field_value be self.get_field_value with field as field
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary containing
        
        Let options_html be list containing
        For each choice in choices:
            Let selected_attr be if choice.value is equal to field_value then " selected" otherwise ""
            Let disabled_attr be if choice.disabled then " disabled" otherwise ""
            Add "<option value=\"" concatenated with choice.value concatenated with "\"" concatenated with selected_attr concatenated with disabled_attr concatenated with ">" concatenated with choice.label concatenated with "</option>" to options_html
        
        Return "<select id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\"" concatenated with attrs concatenated with ">" concatenated with options_html.join with separator as "\n" concatenated with "</select>"

    Process called "render_textarea" that takes field as FormField and rows as Integer and cols as Integer returns String:
        Let field_id be self.get_field_id with field as field
        Let field_value be self.get_field_value with field as field
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary with "rows" as rows.to_string() and "cols" as cols.to_string()
        
        Return "<textarea id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\"" concatenated with attrs concatenated with ">" concatenated with field_value concatenated with "</textarea>"

    Process called "render_file_input" that takes field as FormField returns String:
        Let field_id be self.get_field_id with field as field
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary with "type" as "file"
        
        Return "<input id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\"" concatenated with attrs concatenated with ">"

    Process called "render_hidden_input" that takes field as FormField returns String:
        Let field_value be self.get_field_value with field as field
        
        Return "<input type=\"hidden\" name=\"" concatenated with field.name concatenated with "\" value=\"" concatenated with field_value concatenated with "\">"

    Process called "render_url_input" that takes field as FormField returns String:
        Let field_id be self.get_field_id with field as field
        Let field_value be self.get_field_value with field as field
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary with "type" as "url"
        
        Return "<input id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\" value=\"" concatenated with field_value concatenated with "\"" concatenated with attrs concatenated with ">"

    Process called "render_date_input" that takes field as FormField returns String:
        Let field_id be self.get_field_id with field as field
        Let field_value be self.get_field_value with field as field
        Let attrs be self.get_widget_attributes with field as field and extra_attrs as dictionary with "type" as "date"
        
        Return "<input id=\"" concatenated with field_id concatenated with "\" name=\"" concatenated with field.name concatenated with "\" value=\"" concatenated with field_value concatenated with "\"" concatenated with attrs concatenated with ">"

    Process called "render_field_errors" that takes field_name as String returns String:
        Let errors be self.form.get_field_errors with field_name as field_name
        If length of errors is greater than 0:
            Let error_html be list containing
            For each error in errors:
                Add "<div class=\"field-error\">" concatenated with error concatenated with "</div>" to error_html
            Return error_html.join with separator as "\n"
        Return ""

    Process called "render_field_help_text" that takes field as FormField returns String:
        If field.help_text is not empty:
            Return "<div class=\"field-help\">" concatenated with field.help_text concatenated with "</div>"
        Return ""

    Process called "wrap_field" that takes field as FormField and content as String returns String:
        Let field_classes be list containing "field-wrapper"
        If field.name is in self.form.errors:
            Add "field-error" to field_classes
        If field.required:
            Add "field-required" to field_classes
        
        Let class_attr be " class=\"" concatenated with field_classes.join with separator as " " concatenated with "\""
        Return "<div" concatenated with class_attr concatenated with ">" concatenated with content concatenated with "</div>"

    Process called "get_field_id" that takes field as FormField returns String:
        Return self.form.auto_id.replace with old as "%s" and new as field.name

    Process called "get_field_value" that takes field as FormField returns String:
        If self.form.is_bound and field.name is in self.form.cleaned_data:
            Let value be self.form.cleaned_data[field.name]
            If value is not null:
                Return value.to_string()
        
        If field.default_value is not null:
            Return field.default_value.to_string()
        
        Return ""

    Process called "get_widget_attributes" that takes field as FormField and extra_attrs as Dictionary[String, String] returns String:
        Let all_attrs be dictionary containing
        
        Note: Merge all attribute sources
        For each key in field.widget_attrs:
            Set all_attrs[key] to field.widget_attrs[key]
        For each key in extra_attrs:
            Set all_attrs[key] to extra_attrs[key]
        For each key in field.data_attributes:
            Set all_attrs["data-" concatenated with key] to field.data_attributes[key]
        
        Note: Add common attributes
        If field.placeholder is not empty:
            Set all_attrs["placeholder"] to field.placeholder
        If field.required:
            Set all_attrs["required"] to "required"
        
        Note: Add CSS classes
        If length of field.css_classes is greater than 0:
            Set all_attrs["class"] to field.css_classes.join with separator as " "
        
        Note: Convert to HTML attribute string
        Let attr_parts be list containing
        For each key in all_attrs:
            Add " " concatenated with key concatenated with "=\"" concatenated with all_attrs[key] concatenated with "\"" to attr_parts
        
        Return attr_parts.join with separator as ""

    Process called "get_enctype_attribute" returns String:
        Match self.form.enctype:
            When Multipart:
                Return " enctype=\"multipart/form-data\""
            When URLEncoded:
                Return " enctype=\"application/x-www-form-urlencoded\""
            When JSON:
                Return " enctype=\"application/json\""

    Process called "get_css_classes_attribute" that takes classes as List[String] returns String:
        If length of classes is greater than 0:
            Return " class=\"" concatenated with classes.join with separator as " " concatenated with "\""
        Return ""

    Process called "get_data_attributes" that takes data as Dictionary[String, String] returns String:
        Let attr_parts be list containing
        For each key in data:
            Add " data-" concatenated with key concatenated with "=\"" concatenated with data[key] concatenated with "\"" to attr_parts
        Return attr_parts.join with separator as ""

Type CSSFramework is:
    | Bootstrap5 | TailwindCSS | Bulma | Foundation | Custom

