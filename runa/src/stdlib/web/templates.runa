Note: Runa Standard Library - Template Engine Module
Note: Advanced template engine with inheritance, includes, filters, macros, security
Note: Surpasses Jinja2, Django Templates, Handlebars, Mustache, Go templates capabilities

Import "web/framework" as Framework
Import "collections" as Collections
Import "datetime" as DateTime
Import "crypto/hash" as Hash
Import "concurrent" as Concurrent
Import "os" as OS
Import "io" as IO

Note: Template Engine Configuration
Type called "TemplateConfig":
    template_directories as List[String]
    auto_reload as Boolean
    cache_size as Integer
    strict_mode as Boolean
    auto_escape as Boolean
    block_start_string as String
    block_end_string as String
    variable_start_string as String
    variable_end_string as String
    comment_start_string as String
    comment_end_string as String
    line_statement_prefix as String
    line_comment_prefix as String
    trim_blocks as Boolean
    lstrip_blocks as Boolean
    enable_includes as Boolean
    enable_extends as Boolean
    enable_macros as Boolean
    enable_filters as Boolean
    max_recursion_depth as Integer
    security_policy as SecurityPolicy

Type called "SecurityPolicy":
    allowed_functions as List[String]
    allowed_attributes as List[String]
    allow_eval as Boolean
    allow_exec as Boolean
    allow_file_access as Boolean
    sandbox_mode as Boolean

Note: Template Engine
Type called "TemplateEngine":
    config as TemplateConfig
    template_cache as TemplateCache
    loader as TemplateLoader
    filters as Dictionary[String, TemplateFilter]
    functions as Dictionary[String, TemplateFunction]
    globals as Dictionary[String, Any]
    lexer as TemplateLexer
    parser as TemplateParser
    compiler as TemplateCompiler

    Process called "create" that takes config as TemplateConfig returns TemplateEngine:
        Return TemplateEngine with:
            config as config
            template_cache as TemplateCache.create with config as config
            loader as TemplateLoader.create with directories as config.template_directories
            filters as create_builtin_filters()
            functions as create_builtin_functions()
            globals as dictionary containing
            lexer as TemplateLexer.create with config as config
            parser as TemplateParser.create()
            compiler as TemplateCompiler.create()

    Process called "render" that takes template_name as String and context as Dictionary[String, Any] returns String:
        Let template be self.get_template with name as template_name
        Return template.render with context as context and engine as self

    Process called "render_string" that takes template_source as String and context as Dictionary[String, Any] returns String:
        Let template be self.compile_string with source as template_source
        Return template.render with context as context and engine as self

    Process called "get_template" that takes name as String returns Template:
        Let cache_key be name
        
        If self.config.cache_size is greater than 0:
            Let cached_template be self.template_cache.get with key as cache_key
            If cached_template is not null:
                If not self.config.auto_reload or not self.is_template_modified with template as cached_template:
                    Return cached_template

        Let template_source be self.loader.load with name as name
        If template_source is null:
            Error with message as "Template not found: " concatenated with name

        Let template be self.compile_template with source as template_source.content and name as name
        
        If self.config.cache_size is greater than 0:
            self.template_cache.put with key as cache_key and template as template

        Return template

    Process called "compile_string" that takes source as String returns Template:
        Return self.compile_template with source as source and name as "<string>"

    Process called "compile_template" that takes source as String and name as String returns Template:
        Let tokens be self.lexer.tokenize with source as source
        Let ast be self.parser.parse with tokens as tokens
        Let compiled_template be self.compiler.compile with ast as ast and name as name
        Return compiled_template

    Process called "is_template_modified" that takes template as Template returns Boolean:
        Let source_info be self.loader.get_source_info with name as template.name
        If source_info is null:
            Return true
        Return source_info.modified_time is greater than template.compiled_time

    Process called "add_filter" that takes name as String and filter as TemplateFilter returns None:
        Set self.filters[name] to filter

    Process called "add_function" that takes name as String and function as TemplateFunction returns None:
        Set self.functions[name] to function

    Process called "add_global" that takes name as String and value as Any returns None:
        Set self.globals[name] to value

    Process called "get_filter" that takes name as String returns Optional[TemplateFilter]:
        Return self.filters.get with key as name

    Process called "get_function" that takes name as String returns Optional[TemplateFunction]:
        Return self.functions.get with key as name

    Process called "create_context" that takes variables as Dictionary[String, Any] returns TemplateContext:
        Let context be TemplateContext.create()
        
        Note: Add globals
        For each global_name in self.globals:
            context.set with name as global_name and value as self.globals[global_name]
        
        Note: Add variables
        For each var_name in variables:
            context.set with name as var_name and value as variables[var_name]
        
        Return context

Note: Template Object
Type called "Template":
    name as String
    source as String
    compiled_time as Float
    ast as TemplateAST
    blocks as Dictionary[String, TemplateBlock]
    parent_template as Optional[String]
    included_templates as List[String]

    Process called "create" that takes name as String and source as String and ast as TemplateAST returns Template:
        Return Template with:
            name as name
            source as source
            compiled_time as DateTime.now()
            ast as ast
            blocks as dictionary containing
            parent_template as null
            included_templates as list containing

    Process called "render" that takes context as Dictionary[String, Any] and engine as TemplateEngine returns String:
        Let template_context be engine.create_context with variables as context
        Return self.execute with context as template_context and engine as engine

    Process called "execute" that takes context as TemplateContext and engine as TemplateEngine returns String:
        Note: Handle template inheritance
        If self.parent_template is not null:
            Let parent be engine.get_template with name as self.parent_template
            return self.render_with_parent with parent as parent and context as context and engine as engine

        Note: Execute template nodes
        Let output be list containing
        self.execute_nodes with nodes as self.ast.nodes and context as context and engine as engine and output as output
        Return output.join with separator as ""

    Process called "render_with_parent" that takes parent as Template and context as TemplateContext and engine as TemplateEngine returns String:
        Note: Merge blocks with parent
        For each block_name in self.blocks:
            parent.blocks[block_name] be self.blocks[block_name]
        
        Return parent.execute with context as context and engine as engine

    Process called "execute_nodes" that takes nodes as List[TemplateNode] and context as TemplateContext and engine as TemplateEngine and output as List[String] returns None:
        For each node in nodes:
            Let result be node.execute with context as context and engine as engine
            If result is not null:
                Add result to output

Note: Template AST
Type called "TemplateAST":
    nodes as List[TemplateNode]

Type TemplateNode is:
    | TextNode with content as String
    | VariableNode with expression as Expression and filters as List[FilterCall]
    | BlockNode with name as String and nodes as List[TemplateNode]
    | ExtendsNode with template_name as String
    | IncludeNode with template_name as String and context as Optional[Expression]
    | ForNode with variable as String and iterable as Expression and nodes as List[TemplateNode] and else_nodes as List[TemplateNode]
    | IfNode with condition as Expression and nodes as List[TemplateNode] and elif_branches as List[ElifBranch] and else_nodes as List[TemplateNode]
    | SetNode with variable as String and value as Expression
    | MacroNode with name as String and parameters as List[String] and nodes as List[TemplateNode]
    | CallNode with macro_name as String and arguments as List[Expression]
    | FilterNode with nodes as List[TemplateNode] and filters as List[FilterCall]
    | CommentNode with content as String

Type called "ElifBranch":
    condition as Expression
    nodes as List[TemplateNode]

Type Expression is:
    | Literal with value as Any
    | Variable with name as String
    | Attribute with object as Expression and attribute as String
    | Index with object as Expression and index as Expression
    | Call with function as Expression and arguments as List[Expression]
    | BinaryOp with left as Expression and operator as BinaryOperator and right as Expression
    | UnaryOp with operator as UnaryOperator and operand as Expression
    | Conditional with test as Expression and true_expr as Expression and false_expr as Expression
    | List with elements as List[Expression]
    | Dict with pairs as List[KeyValuePair]

Type called "KeyValuePair":
    key as Expression
    value as Expression

Type BinaryOperator is:
    | Add | Sub | Mul | Div | Mod | Pow
    | Eq | Ne | Lt | Le | Gt | Ge
    | And | Or | In | NotIn

Type UnaryOperator is:
    | Not | Plus | Minus

Type called "FilterCall":
    name as String
    arguments as List[Expression]

Note: Template Lexer
Type called "TemplateLexer":
    config as TemplateConfig
    source as String
    position as Integer
    line as Integer
    column as Integer
    tokens as List[TemplateToken]

    Process called "create" that takes config as TemplateConfig returns TemplateLexer:
        Return TemplateLexer with:
            config as config
            source as ""
            position as 0
            line as 1
            column as 1
            tokens as list containing

    Process called "tokenize" that takes source as String returns List[TemplateToken]:
        Set self.source to source
        Set self.position to 0
        Set self.line to 1
        Set self.column to 1
        Set self.tokens to list containing

        While self.position is less than length of self.source:
            self.scan_token()

        Add TemplateToken with type as EOF and value as "" and line as self.line and column as self.column to self.tokens
        Return self.tokens

    Process called "scan_token" returns None:
        Let start_pos be self.position
        
        Note: Check for template syntax
        If self.match_string with str as self.config.block_start_string:
            self.scan_block()
        Otherwise If self.match_string with str as self.config.variable_start_string:
            self.scan_variable()
        Otherwise If self.match_string with str as self.config.comment_start_string:
            self.scan_comment()
        Otherwise:
            self.scan_text()

    Process called "scan_block" returns None:
        Let start_line be self.line
        Let start_column be self.column
        self.advance_by with count as length of self.config.block_start_string
        
        self.skip_whitespace()
        Let block_content be self.scan_until with end_string as self.config.block_end_string
        self.advance_by with count as length of self.config.block_end_string
        
        Let tokens be self.tokenize_block_content with content as block_content
        For each token in tokens:
            Add token to self.tokens

    Process called "scan_variable" returns None:
        Let start_line be self.line
        Let start_column be self.column
        self.advance_by with count as length of self.config.variable_start_string
        
        self.skip_whitespace()
        Let var_content be self.scan_until with end_string as self.config.variable_end_string
        self.advance_by with count as length of self.config.variable_end_string
        
        Add TemplateToken with:
            type as VARIABLE_BEGIN
            value as ""
            line as start_line
            column as start_column
        to self.tokens
        
        Let expr_tokens be self.tokenize_expression with content as var_content
        For each token in expr_tokens:
            Add token to self.tokens
        
        Add TemplateToken with:
            type as VARIABLE_END
            value as ""
            line as self.line
            column as self.column
        to self.tokens

    Process called "scan_comment" returns None:
        self.advance_by with count as length of self.config.comment_start_string
        Let comment_content be self.scan_until with end_string as self.config.comment_end_string
        self.advance_by with count as length of self.config.comment_end_string
        
        Add TemplateToken with:
            type as COMMENT
            value as comment_content
            line as self.line
            column as self.column
        to self.tokens

    Process called "scan_text" returns None:
        Let start_pos be self.position
        Let start_line be self.line
        Let start_column be self.column
        
        While self.position is less than length of self.source:
            If self.peek_string with str as self.config.block_start_string or 
               self.peek_string with str as self.config.variable_start_string or 
               self.peek_string with str as self.config.comment_start_string:
                Break
            
            self.advance()
        
        If self.position is greater than start_pos:
            Let text_content be self.source.substring with start as start_pos and end as self.position
            Add TemplateToken with:
                type as TEXT
                value as text_content
                line as start_line
                column as start_column
            to self.tokens

    Process called "scan_until" that takes end_string as String returns String:
        Let start_pos be self.position
        
        While self.position is less than length of self.source:
            If self.peek_string with str as end_string:
                Break
            self.advance()
        
        Return self.source.substring with start as start_pos and end as self.position

    Process called "tokenize_block_content" that takes content as String returns List[TemplateToken]:
        Note: Simple tokenization - would be more sophisticated in real implementation
        Let words be content.split with separator as " "
        Let tokens be list containing
        
        For each word in words:
            Let trimmed_word be word.trim()
            If trimmed_word is not empty:
                Add TemplateToken with:
                    type as self.classify_block_token with word as trimmed_word
                    value as trimmed_word
                    line as self.line
                    column as self.column
                to tokens
        
        Return tokens

    Process called "tokenize_expression" that takes content as String returns List[TemplateToken]:
        Note: Simple expression tokenization
        Return list containing TemplateToken with:
            type as IDENTIFIER
            value as content.trim()
            line as self.line
            column as self.column

    Process called "classify_block_token" that takes word as String returns TokenType:
        Match word:
            When "if":
                Return IF
            When "elif":
                Return ELIF
            When "else":
                Return ELSE
            When "endif":
                Return ENDIF
            When "for":
                Return FOR
            When "endfor":
                Return ENDFOR
            When "block":
                Return BLOCK
            When "endblock":
                Return ENDBLOCK
            When "extends":
                Return EXTENDS
            When "include":
                Return INCLUDE
            When "set":
                Return SET
            When "macro":
                Return MACRO
            When "endmacro":
                Return ENDMACRO
            When "call":
                Return CALL
            When "filter":
                Return FILTER
            When "endfilter":
                Return ENDFILTER
            Otherwise:
                Return IDENTIFIER

    Process called "match_string" that takes str as String returns Boolean:
        If self.position length of str is greater than length of self.source:
            Return false
        
        Let substring be self.source.substring with start as self.position and end as self.position length of str
        Return substring is equal to str

    Process called "peek_string" that takes str as String returns Boolean:
        Return self.match_string with str as str

    Process called "advance" returns None:
        If self.position is less than length of self.source:
            If self.source[self.position] is equal to "\n":
                Set self.line to self.line 1
                Set self.column to 1
            Otherwise:
                Set self.column to self.column 1
            Set self.position to self.position 1

    Process called "advance_by" that takes count as Integer returns None:
        For i from 0 to count - 1:
            self.advance()

    Process called "skip_whitespace" returns None:
        While self.position is less than length of self.source and self.source[self.position] is whitespace:
            self.advance()

Type called "TemplateToken":
    type as TokenType
    value as String
    line as Integer
    column as Integer

Type TokenType is:
    | TEXT | VARIABLE_BEGIN | VARIABLE_END | COMMENT
    | IF | ELIF | ELSE | ENDIF | FOR | ENDFOR
    | BLOCK | ENDBLOCK | EXTENDS | INCLUDE | SET
    | MACRO | ENDMACRO | CALL | FILTER | ENDFILTER
    | IDENTIFIER | STRING | NUMBER | BOOLEAN
    | PIPE | DOT | COMMA | COLON | SEMICOLON
    | LPAREN | RPAREN | LBRACKET | RBRACKET | LBRACE | RBRACE
    | PLUS | MINUS | MULTIPLY | DIVIDE | MODULO
    | EQUALS | NOT_EQUALS | LESS_THAN | GREATER_THAN
    | LESS_EQUAL | GREATER_EQUAL | AND | OR | NOT | IN
    | EOF

Note: Template Parser
Type called "TemplateParser":
    tokens as List[TemplateToken]
    position as Integer

    Process called "create" returns TemplateParser:
        Return TemplateParser with:
            tokens as list containing
            position as 0

    Process called "parse" that takes tokens as List[TemplateToken] returns TemplateAST:
        Set self.tokens to tokens
        Set self.position to 0
        
        Let nodes be list containing
        
        While not self.is_at_end():
            Let node be self.parse_node()
            If node is not null:
                Add node to nodes
        
        Return TemplateAST with nodes as nodes

    Process called "parse_node" returns Optional[TemplateNode]:
        Let token be self.current_token()
        
        Match token.type:
            When TEXT:
                self.advance()
                Return TextNode with content as token.value
            When VARIABLE_BEGIN:
                Return self.parse_variable_node()
            When IF:
                Return self.parse_if_node()
            When FOR:
                Return self.parse_for_node()
            When BLOCK:
                Return self.parse_block_node()
            When EXTENDS:
                Return self.parse_extends_node()
            When INCLUDE:
                Return self.parse_include_node()
            When SET:
                Return self.parse_set_node()
            When MACRO:
                Return self.parse_macro_node()
            When CALL:
                Return self.parse_call_node()
            When FILTER:
                Return self.parse_filter_node()
            When COMMENT:
                self.advance()
                Return CommentNode with content as token.value
            Otherwise:
                self.advance()
                Return null

    Process called "parse_variable_node" returns TemplateNode:
        self.consume with type as VARIABLE_BEGIN
        Let expression be self.parse_expression()
        Let filters be self.parse_filters()
        self.consume with type as VARIABLE_END
        
        Return VariableNode with expression as expression and filters as filters

    Process called "parse_if_node" returns TemplateNode:
        self.consume with type as IF
        Let condition be self.parse_expression()
        Let nodes be self.parse_nodes_until with end_types as list containing ELIF, ELSE, ENDIF
        
        Let elif_branches be list containing
        While self.current_token().type is equal to ELIF:
            self.advance()
            Let elif_condition be self.parse_expression()
            Let elif_nodes be self.parse_nodes_until with end_types as list containing ELIF, ELSE, ENDIF
            Add ElifBranch with condition as elif_condition and nodes as elif_nodes to elif_branches
        
        Let else_nodes be list containing
        If self.current_token().type is equal to ELSE:
            self.advance()
            Set else_nodes to self.parse_nodes_until with end_types as list containing ENDIF
        
        self.consume with type as ENDIF
        
        Return IfNode with:
            condition as condition
            nodes as nodes
            elif_branches as elif_branches
            else_nodes as else_nodes

    Process called "parse_for_node" returns TemplateNode:
        self.consume with type as FOR
        Let variable be self.consume with type as IDENTIFIER
        self.consume with type as IN
        Let iterable be self.parse_expression()
        
        Let nodes be self.parse_nodes_until with end_types as list containing ENDFOR
        Let else_nodes be list containing
        
        self.consume with type as ENDFOR
        
        Return ForNode with:
            variable as variable.value
            iterable as iterable
            nodes as nodes
            else_nodes as else_nodes

    Process called "parse_block_node" returns TemplateNode:
        self.consume with type as BLOCK
        Let name_token be self.consume with type as IDENTIFIER
        Let nodes be self.parse_nodes_until with end_types as list containing ENDBLOCK
        self.consume with type as ENDBLOCK
        
        Return BlockNode with name as name_token.value and nodes as nodes

    Process called "parse_extends_node" returns TemplateNode:
        self.consume with type as EXTENDS
        Let template_name_token be self.consume with type as STRING
        Return ExtendsNode with template_name as template_name_token.value

    Process called "parse_include_node" returns TemplateNode:
        self.consume with type as INCLUDE
        Let template_name_token be self.consume with type as STRING
        Return IncludeNode with template_name as template_name_token.value and context as null

    Process called "parse_set_node" returns TemplateNode:
        self.consume with type as SET
        Let variable_token be self.consume with type as IDENTIFIER
        self.consume with type as EQUALS
        Let value be self.parse_expression()
        
        Return SetNode with variable as variable_token.value and value as value

    Process called "parse_macro_node" returns TemplateNode:
        self.consume with type as MACRO
        Let name_token be self.consume with type as IDENTIFIER
        
        Let parameters be list containing
        If self.current_token().type is equal to LPAREN:
            self.advance()
            While self.current_token().type is not equal to RPAREN:
                Let param_token be self.consume with type as IDENTIFIER
                Add param_token.value to parameters
                If self.current_token().type is equal to COMMA:
                    self.advance()
            self.consume with type as RPAREN
        
        Let nodes be self.parse_nodes_until with end_types as list containing ENDMACRO
        self.consume with type as ENDMACRO
        
        Return MacroNode with:
            name as name_token.value
            parameters as parameters
            nodes as nodes

    Process called "parse_call_node" returns TemplateNode:
        self.consume with type as CALL
        Let macro_name_token be self.consume with type as IDENTIFIER
        
        Let arguments be list containing
        If self.current_token().type is equal to LPAREN:
            self.advance()
            While self.current_token().type is not equal to RPAREN:
                Let arg be self.parse_expression()
                Add arg to arguments
                If self.current_token().type is equal to COMMA:
                    self.advance()
            self.consume with type as RPAREN
        
        Return CallNode with macro_name as macro_name_token.value and arguments as arguments

    Process called "parse_filter_node" returns TemplateNode:
        self.consume with type as FILTER
        Let filters be self.parse_filters()
        Let nodes be self.parse_nodes_until with end_types as list containing ENDFILTER
        self.consume with type as ENDFILTER
        
        Return FilterNode with nodes as nodes and filters as filters

    Process called "parse_expression" returns Expression:
        Return self.parse_or_expression()

    Process called "parse_or_expression" returns Expression:
        Let left be self.parse_and_expression()
        
        While self.current_token().type is equal to OR:
            self.advance()
            Let right be self.parse_and_expression()
            Set left to BinaryOp with left as left and operator as Or and right as right
        
        Return left

    Process called "parse_and_expression" returns Expression:
        Let left be self.parse_equality_expression()
        
        While self.current_token().type is equal to AND:
            self.advance()
            Let right be self.parse_equality_expression()
            Set left to BinaryOp with left as left and operator as And and right as right
        
        Return left

    Process called "parse_equality_expression" returns Expression:
        Let left be self.parse_comparison_expression()
        
        While self.current_token().type is equal to EQUALS or self.current_token().type is equal to NOT_EQUALS:
            Let operator_token be self.current_token()
            self.advance()
            Let right be self.parse_comparison_expression()
            Let operator be if operator_token.type is equal to EQUALS then Eq otherwise Ne
            Set left to BinaryOp with left as left and operator as operator and right as right
        
        Return left

    Process called "parse_comparison_expression" returns Expression:
        Let left be self.parse_additive_expression()
        
        While self.current_token().type is equal to LESS_THAN or 
              self.current_token().type is equal to GREATER_THAN or
              self.current_token().type is equal to LESS_EQUAL or
              self.current_token().type is equal to GREATER_EQUAL:
            Let operator_token be self.current_token()
            self.advance()
            Let right be self.parse_additive_expression()
            Let operator be self.token_to_comparison_operator with token as operator_token
            Set left to BinaryOp with left as left and operator as operator and right as right
        
        Return left

    Process called "parse_additive_expression" returns Expression:
        Let left be self.parse_multiplicative_expression()
        
        While self.current_token().type is equal to PLUS or self.current_token().type is equal to MINUS:
            Let operator_token be self.current_token()
            self.advance()
            Let right be self.parse_multiplicative_expression()
            Let operator be if operator_token.type is equal to PLUS then Add otherwise Sub
            Set left to BinaryOp with left as left and operator as operator and right as right
        
        Return left

    Process called "parse_multiplicative_expression" returns Expression:
        Let left be self.parse_unary_expression()
        
        While self.current_token().type is equal to MULTIPLY or 
              self.current_token().type is equal to DIVIDE or
              self.current_token().type is equal to MODULO:
            Let operator_token be self.current_token()
            self.advance()
            Let right be self.parse_unary_expression()
            Let operator be self.token_to_multiplicative_operator with token as operator_token
            Set left to BinaryOp with left as left and operator as operator and right as right
        
        Return left

    Process called "parse_unary_expression" returns Expression:
        If self.current_token().type is equal to NOT or 
           self.current_token().type is equal to PLUS or
           self.current_token().type is equal to MINUS:
            Let operator_token be self.current_token()
            self.advance()
            Let operand be self.parse_unary_expression()
            Let operator be self.token_to_unary_operator with token as operator_token
            Return UnaryOp with operator as operator and operand as operand
        
        Return self.parse_postfix_expression()

    Process called "parse_postfix_expression" returns Expression:
        Let left be self.parse_primary_expression()
        
        While true:
            If self.current_token().type is equal to DOT:
                self.advance()
                Let attribute_token be self.consume with type as IDENTIFIER
                Set left to Attribute with object as left and attribute as attribute_token.value
            Otherwise If self.current_token().type is equal to LBRACKET:
                self.advance()
                Let index be self.parse_expression()
                self.consume with type as RBRACKET
                Set left to Index with object as left and index as index
            Otherwise If self.current_token().type is equal to LPAREN:
                self.advance()
                Let arguments be list containing
                While self.current_token().type is not equal to RPAREN:
                    Let arg be self.parse_expression()
                    Add arg to arguments
                    If self.current_token().type is equal to COMMA:
                        self.advance()
                self.consume with type as RPAREN
                Set left to Call with function as left and arguments as arguments
            Otherwise:
                Break
        
        Return left

    Process called "parse_primary_expression" returns Expression:
        Let token be self.current_token()
        
        Match token.type:
            When IDENTIFIER:
                self.advance()
                Return Variable with name as token.value
            When STRING:
                self.advance()
                Return Literal with value as token.value
            When NUMBER:
                self.advance()
                Return Literal with value as parse_number with str as token.value
            When BOOLEAN:
                self.advance()
                Return Literal with value as token.value is equal to "true"
            When LPAREN:
                self.advance()
                Let expression be self.parse_expression()
                self.consume with type as RPAREN
                Return expression
            When LBRACKET:
                Return self.parse_list_expression()
            When LBRACE:
                Return self.parse_dict_expression()
            Otherwise:
                Error with message as "Unexpected token: " concatenated with token.value

    Process called "parse_list_expression" returns Expression:
        self.consume with type as LBRACKET
        Let elements be list containing
        
        While self.current_token().type is not equal to RBRACKET:
            Let element be self.parse_expression()
            Add element to elements
            If self.current_token().type is equal to COMMA:
                self.advance()
        
        self.consume with type as RBRACKET
        Return List with elements as elements

    Process called "parse_dict_expression" returns Expression:
        self.consume with type as LBRACE
        Let pairs be list containing
        
        While self.current_token().type is not equal to RBRACE:
            Let key be self.parse_expression()
            self.consume with type as COLON
            Let value be self.parse_expression()
            Add KeyValuePair with key as key and value as value to pairs
            If self.current_token().type is equal to COMMA:
                self.advance()
        
        self.consume with type as RBRACE
        Return Dict with pairs as pairs

    Process called "parse_filters" returns List[FilterCall]:
        Let filters be list containing
        
        While self.current_token().type is equal to PIPE:
            self.advance()
            Let filter_name_token be self.consume with type as IDENTIFIER
            Let arguments be list containing
            
            If self.current_token().type is equal to LPAREN:
                self.advance()
                While self.current_token().type is not equal to RPAREN:
                    Let arg be self.parse_expression()
                    Add arg to arguments
                    If self.current_token().type is equal to COMMA:
                        self.advance()
                self.consume with type as RPAREN
            
            Add FilterCall with name as filter_name_token.value and arguments as arguments to filters
        
        Return filters

    Process called "parse_nodes_until" that takes end_types as List[TokenType] returns List[TemplateNode]:
        Let nodes be list containing
        
        While not self.is_at_end() and not self.current_token().type is in end_types:
            Let node be self.parse_node()
            If node is not null:
                Add node to nodes
        
        Return nodes

    Process called "current_token" returns TemplateToken:
        If self.position is less than length of self.tokens:
            Return self.tokens[self.position]
        Return TemplateToken with type as EOF and value as "" and line as 0 and column as 0

    Process called "advance" returns TemplateToken:
        Let token be self.current_token()
        If not self.is_at_end():
            Set self.position to self.position 1
        Return token

    Process called "consume" that takes type as TokenType returns TemplateToken:
        Let token be self.current_token()
        If token.type is not equal to type:
            Error with message as "Expected " concatenated with type.to_string() concatenated with " but got " concatenated with token.type.to_string()
        Return self.advance()

    Process called "is_at_end" returns Boolean:
        Return self.current_token().type is equal to EOF

    Process called "token_to_comparison_operator" that takes token as TemplateToken returns BinaryOperator:
        Match token.type:
            When LESS_THAN:
                Return Lt
            When GREATER_THAN:
                Return Gt
            When LESS_EQUAL:
                Return Le
            When GREATER_EQUAL:
                Return Ge
            Otherwise:
                Return Eq

    Process called "token_to_multiplicative_operator" that takes token as TemplateToken returns BinaryOperator:
        Match token.type:
            When MULTIPLY:
                Return Mul
            When DIVIDE:
                Return Div
            When MODULO:
                Return Mod
            Otherwise:
                Return Mul

    Process called "token_to_unary_operator" that takes token as TemplateToken returns UnaryOperator:
        Match token.type:
            When NOT:
                Return Not
            When PLUS:
                Return Plus
            When MINUS:
                Return Minus
            Otherwise:
                Return Not

Note: Template Context
Type called "TemplateContext":
    variables as Dictionary[String, Any]
    parent as Optional[TemplateContext]

    Process called "create" returns TemplateContext:
        Return TemplateContext with:
            variables as dictionary containing
            parent as null

    Process called "get" that takes name as String returns Optional[Any]:
        If name is in self.variables:
            Return self.variables[name]
        
        If self.parent is not null:
            Return self.parent.get with name as name
        
        Return null

    Process called "set" that takes name as String and value as Any returns None:
        Set self.variables[name] to value

    Process called "push_scope" returns TemplateContext:
        Return TemplateContext with:
            variables as dictionary containing
            parent as self

    Process called "pop_scope" returns Optional[TemplateContext]:
        Return self.parent

Note: Template Filters and Functions
Type called "TemplateFilter":
    name as String
    function as Process

Type called "TemplateFunction":
    name as String
    function as Process

Note: Template Loader
Type called "TemplateLoader":
    directories as List[String]

    Process called "create" that takes directories as List[String] returns TemplateLoader:
        Return TemplateLoader with:
            directories as directories

    Process called "load" that takes name as String returns Optional[TemplateSource]:
        For each directory in self.directories:
            Let file_path be directory concatenated with "/" concatenated with name
            If OS.file_exists with path as file_path:
                Let content be OS.read_file with path as file_path
                Let modified_time be OS.file_modified_time with path as file_path
                Return TemplateSource with:
                    name as name
                    content as content
                    path as file_path
                    modified_time as modified_time
        
        Return null

    Process called "get_source_info" that takes name as String returns Optional[TemplateSourceInfo]:
        For each directory in self.directories:
            Let file_path be directory concatenated with "/" concatenated with name
            If OS.file_exists with path as file_path:
                Let modified_time be OS.file_modified_time with path as file_path
                Return TemplateSourceInfo with:
                    name as name
                    path as file_path
                    modified_time as modified_time
        
        Return null

Type called "TemplateSource":
    name as String
    content as String
    path as String
    modified_time as Float

Type called "TemplateSourceInfo":
    name as String
    path as String
    modified_time as Float

Note: Template Cache
Type called "TemplateCache":
    cache as Dictionary[String, Template]
    max_size as Integer

    Process called "create" that takes config as TemplateConfig returns TemplateCache:
        Return TemplateCache with:
            cache as dictionary containing
            max_size as config.cache_size

    Process called "get" that takes key as String returns Optional[Template]:
        Return self.cache.get with key as key

    Process called "put" that takes key as String and template as Template returns None:
        If length of self.cache is greater than or equal to self.max_size:
            self.evict_oldest()
        
        Set self.cache[key] to template

    Process called "evict_oldest" returns None:
        Note: Simple eviction - remove first item
        If length of self.cache is greater than 0:
            Let first_key be self.cache.keys()[0]
            self.cache.remove with key as first_key

Note: Template Compiler
Type called "TemplateCompiler":
    Process called "create" returns TemplateCompiler:
        Return TemplateCompiler with

    Process called "compile" that takes ast as TemplateAST and name as String returns Template:
        Return Template.create with name as name and source as "" and ast as ast

Type called "TemplateBlock":
    name as String
    nodes as List[TemplateNode]

Note: Built-in Filters and Functions
Process called "create_builtin_filters" returns Dictionary[String, TemplateFilter]:
    Return dictionary with:
        "upper" as TemplateFilter with:
            name as "upper"
            function as Process that takes value: Return value.to_string().to_uppercase()
        "lower" as TemplateFilter with:
            name as "lower"
            function as Process that takes value: Return value.to_string().to_lowercase()
        "length" as TemplateFilter with:
            name as "length"
            function as Process that takes value: Return length of value
        "default" as TemplateFilter with:
            name as "default"
            function as Process that takes value and default_value: Return if value is null then default_value otherwise value

Process called "create_builtin_functions" returns Dictionary[String, TemplateFunction]:
    Return dictionary with:
        "range" as TemplateFunction with:
            name as "range"
            function as Process that takes start and end: Return create_range with start as start and end as end

Note: Utility Functions
Process called "create_template_engine" that takes config as TemplateConfig returns TemplateEngine:
    Return TemplateEngine.create with config as config

Process called "create_default_template_config" returns TemplateConfig:
    Return TemplateConfig with:
        template_directories as list containing "templates"
        auto_reload as true
        cache_size as 100
        strict_mode as false
        auto_escape as true
        block_start_string as "{%"
        block_end_string as "%}"
        variable_start_string as "{{"
        variable_end_string as "}}"
        comment_start_string as "{#"
        comment_end_string as "#}"
        line_statement_prefix as ""
        line_comment_prefix as ""
        trim_blocks as true
        lstrip_blocks as true
        enable_includes as true
        enable_extends as true
        enable_macros as true
        enable_filters as true
        max_recursion_depth as 100
        security_policy as SecurityPolicy with:
            allowed_functions as list containing
            allowed_attributes as list containing
            allow_eval as false
            allow_exec as false
            allow_file_access as false
            sandbox_mode as true

Process called "parse_number" that takes str as String returns Float:
    Return 0.0

Process called "create_range" that takes start as Integer and end as Integer returns List[Integer]:
    Let result be list containing
    For i from start to end - 1:
        Add i to result
    Return result

