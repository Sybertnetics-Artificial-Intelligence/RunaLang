Note: Utility Functions
Process called "create_application" that takes config as Optional[ApplicationConfig] returns WebApplication:
    Let app_config be config or create_default_config()
    Return WebApplication.create with config as app_config

Process called "create_default_config" returns ApplicationConfig:
    Return ApplicationConfig with:
        environment as OS.environment_variable with name as "RUNA_ENV" or "development"
        debug as OS.environment_variable with name as "RUNA_DEBUG" or "true" is equal to "true"
        server_config as ServerConfig with:
            host as "127.0.0.1"
            port as parse_integer with value as OS.environment_variable with name as "PORT" or "8000"
            worker_threads as OS.cpu_count()
            max_connections as 1000
            read_timeout as 30
            write_timeout as 30
            keep_alive as true
        security_config as create_default_security_config()
        session_config as create_default_session_config()
        template_config as create_default_template_config()
        static_config as create_default_static_config()
        cors_config as create_default_cors_config()
        database_config as create_default_database_config()

Process called "create_default_security_config" returns SecurityConfig:
    Return SecurityConfig with:
        csrf_protection as true
        xss_protection as true
        sql_injection_protection as true
        rate_limiting as RateLimitConfig with:
            enabled as true
            requests_per_minute as 60
            burst_size as 10
            key_function as Process that takes request as HTTPRequest: Return request.remote_addr
        auth_required as false
        permissions as list containing

Process called "create_default_session_config" returns SessionConfig:
    Return SessionConfig with:
        enabled as true
        cookie_name as "runa_session"
        secret_key as generate_secret_key()
        max_age as 86400
        secure as false
        http_only as true
        same_site as Lax

Process called "create_default_template_config" returns TemplateConfig:
    Return TemplateConfig with:
        enabled as true
        template_dir as "templates"
        auto_reload as true
        cache_size as 100

Process called "create_default_static_config" returns StaticConfig:
    Return StaticConfig with:
        enabled as true
        static_dir as "static"
        url_prefix as "/static"
        cache_control as "public, max-age=3600"
        max_age as 3600

Process called "create_default_cors_config" returns CORSConfig:
    Return CORSConfig with:
        enabled as false
        allowed_origins as list containing "*"
        allowed_methods as list containing GET, POST, PUT, DELETE, OPTIONS
        allowed_headers as list containing "Content-Type", "Authorization"
        allow_credentials as false
        max_age as 86400

Process called "create_default_database_config" returns DatabaseConfig:
    Return DatabaseConfig with:
        enabled as false
        driver as "sqlite"
        connection_string as "sqlite://database.db"
        pool_size as 10
        max_idle as 5

Process called "generate_secret_key" returns String:
    Return Hash.random_string with length as 32

Process called "generate_request_id" returns String:
    Return Hash.random_string with length as 16

Process called "create_request_context" that takes request as HTTPRequest returns Dictionary[String, Any]:
    Return dictionary with:
        "request" as request
        "user" as null
        "session" as null
        "flash_messages" as list containing
        "csrf_token" as generate_csrf_token()
        "template_vars" as dictionary containing

Process called "generate_csrf_token" returns String:
    Return Hash.random_string with length as 32

Note: HTTP Request Parsing Functions
Process called "extract_method" that takes raw_request as Any returns HTTPMethod:
    Note: Parse HTTP method from raw request
    If raw_request is none:
        Return GET
    Let method_str be raw_request.method if raw_request has "method" else "GET"
    Match method_str:
        When "GET": Return GET
        When "POST": Return POST
        When "PUT": Return PUT
        When "DELETE": Return DELETE
        When "PATCH": Return PATCH
        When "HEAD": Return HEAD
        When "OPTIONS": Return OPTIONS
        Otherwise: Return GET

Process called "extract_path" that takes raw_request as Any returns String:
    Note: Extract request path from raw request
    If raw_request is none:
        Return "/"
    Let path be raw_request.path if raw_request has "path" else "/"
    If path is empty or path is none:
        Return "/"
    Return path

Process called "extract_headers" that takes raw_request as Any returns Dictionary[String, String]:
    Note: Extract HTTP headers from raw request
    Let headers be dictionary containing
    If raw_request is not none and raw_request has "headers":
        For each key, value in raw_request.headers:
            Set headers[key] to value
    Return headers

Process called "extract_query_params" that takes raw_request as Any returns Dictionary[String, String]:
    Note: Parse query parameters from request
    Let params be dictionary containing
    If raw_request is not none and raw_request has "query":
        Let query_string be raw_request.query
        Let pairs be split_string with string as query_string and delimiter as "&"
        For each pair in pairs:
            Let parts be split_string with string as pair and delimiter as "="
            If length of parts is equal to 2:
                Set params[parts[0]] to url_decode with value as parts[1]
    Return params

Process called "extract_body" that takes raw_request as Any returns ByteArray:
    Note: Extract request body as byte array
    If raw_request is none or raw_request does not have "body":
        Return create_empty_byte_array with size as 0
    Let body_data be raw_request.body
    If body_data is string:
        Return string_to_byte_array with string as body_data
    Return body_data

Process called "extract_remote_addr" that takes raw_request as Any returns String:
    Note: Extract client IP address from request
    If raw_request is none:
        Return "127.0.0.1"
    If raw_request has "remote_addr":
        Return raw_request.remote_addr
    If raw_request has "headers":
        Note: Check for proxy headers
        If raw_request.headers has "X-Forwarded-For":
            Let forwarded be raw_request.headers["X-Forwarded-For"]
            Let ips be split_string with string as forwarded and delimiter as ","
            If length of ips is greater than 0:
                Return trim_string with string as ips[0]
        If raw_request.headers has "X-Real-IP":
            Return raw_request.headers["X-Real-IP"]
    Return "127.0.0.1"

Process called "extract_cookies" that takes headers as Dictionary[String, String] returns Dictionary[String, String]:
    Return dictionary containing

Process called "parse_form_data" that takes body as ByteArray and content_type as String returns Dictionary[String, Any]:
    Return dictionary containing

Process called "parse_uploaded_files" that takes body as ByteArray and content_type as String returns Dictionary[String, UploadedFile]:
    Return dictionary containing

Process called "parse_integer" that takes value as String returns Integer:
    Try:
        If value is empty:
            Return 0
        Return value as Integer
    Catch error:
        Return 0

Process called "compile_path_pattern" that takes path as String returns PathPattern:
    Let param_names be list containing
    Let regex_pattern be path
    
    Note: Convert path parameters like /users/:id to regex
    If path contains ":":
        Let parts be path.split with separator as "/"
        Let regex_parts be list containing
        For each part in parts:
            If part starts with ":":
                Add part.substring with start as 1 to param_names
                Add "([^/]+)" to regex_parts
            Otherwise:
                Add part to regex_parts
        Set regex_pattern to regex_parts.join with separator as "/"
    
    Return PathPattern with:
        regex as regex_pattern
        param_names as param_names

Process called "extract_path_params" that takes path as String returns List[String]:
    Return list containing

Process called "regex_match_pattern" that takes pattern as String and text as String returns Any:
    Note: Simple pattern matching implementation
    If pattern is equal to text:
        Return dictionary with "success" as true and "groups" as list containing
    
    Note: Handle parameter patterns like /users/([^/]+)
    If pattern contains "([^/]+)":
        Let pattern_parts be pattern.split with separator as "([^/]+)"
        If length of pattern_parts is greater than 1:
            Let groups be list containing
            Let remaining_text be text
            Let matched be true
            
            For i from 0 to length of pattern_parts - 2:
                Let prefix be pattern_parts[i]
                If not remaining_text starts with prefix:
                    Set matched to false
                    Break
                
                Set remaining_text to remaining_text.substring with start as length of prefix
                
                Note: Extract parameter value
                Let suffix be pattern_parts[i 1]
                Let param_end be if suffix is empty then length of remaining_text otherwise remaining_text.index_of with substring as suffix
                If param_end is greater than 0:
                    Add remaining_text.substring with start as 0 and end as param_end to groups
                    Set remaining_text to remaining_text.substring with start as param_end
            
            If matched:
                Return dictionary with "success" as true and "groups" as groups
    
    Return dictionary with "success" as false and "groups" as list containing

Process called "create_default_error_handlers" returns Dictionary[Integer, Process]:
    Return dictionary containing

Process called "create_error_response" that takes status as Integer and message as String and request as HTTPRequest returns HTTPResponse:
    Return HTTPResponse with:
        status as Custom with code as status and message as message
        headers as dictionary containing
        body as ByteArray.from_string with str as message
        cookies as list containing
        content_type as "text/plain"

