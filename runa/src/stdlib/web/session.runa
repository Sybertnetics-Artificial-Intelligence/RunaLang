Note: Runa Standard Library - Session Management Module
Note: Secure session handling with multiple backends, CSRF protection, flash messages
Note: Surpasses Express Session, Django Sessions, PHP Sessions, ASP.NET Sessions

Import "web/framework" as Framework
Import "../../collections" as Collections
Import "../../datetime" as DateTime
Import "crypto/hash" as Hash
Import "../../concurrent" as Concurrent
Import "../../os" as OS

Note: Session Storage Backends
Type SessionBackend is:
    | MemoryBackend with store as Dictionary[String, SessionData]
    | FileBackend with directory as String
    | DatabaseBackend with connection as Any and table_name as String
    | RedisBackend with connection as Any
    | MemcachedBackend with connection as Any

Type called "SessionData":
    session_id as String
    data as Dictionary[String, Any]
    created_at as Float
    last_accessed as Float
    expires_at as Float
    is_new as Boolean
    is_modified as Boolean
    csrf_token as String
    flash_messages as List[FlashMessage]

Type called "FlashMessage":
    category as String
    message as String
    timestamp as Float

Note: Session Configuration
Type called "SessionConfig":
    cookie_name as String
    secret_key as String
    max_age as Integer
    secure as Boolean
    http_only as Boolean
    same_site as Framework.SameSitePolicy
    domain as Optional[String]
    path as String
    backend as SessionBackend
    auto_regenerate as Boolean
    regenerate_interval as Integer
    cleanup_interval as Integer
    enable_csrf as Boolean
    csrf_token_name as String

Note: Session Manager
Type called "SessionManager":
    config as SessionConfig
    backend_handler as SessionBackendHandler
    cleanup_task as Optional[Concurrent.Task]
    is_running as Boolean

    Process called "create" that takes config as SessionConfig returns SessionManager:
        Return SessionManager with:
            config as config
            backend_handler as SessionBackendHandler.create with backend as config.backend
            cleanup_task as null
            is_running as false

    Process called "start" returns None:
        If self.is_running:
            Return
        
        Set self.is_running to true
        self.start_cleanup_task()

    Process called "stop" returns None:
        If not self.is_running:
            Return
        
        Set self.is_running to false
        If self.cleanup_task is not null:
            self.cleanup_task.cancel()

    Process called "get_session" that takes request as Framework.HTTPRequest returns Session:
        Let session_id be self.extract_session_id with request as request
        
        If session_id is not null:
            Let session_data be self.backend_handler.load with session_id as session_id
            If session_data is not null and not self.is_expired with session_data as session_data:
                self.update_access_time with session_data as session_data
                Return Session.create with data as session_data and manager as self
        
        Note: Create new session
        Let new_session_id be self.generate_session_id()
        Let new_session_data be SessionData with:
            session_id as new_session_id
            data as dictionary containing
            created_at as DateTime.now()
            last_accessed as DateTime.now()
            expires_at as DateTime.now() self.config.max_age
            is_new as true
            is_modified as true
            csrf_token as self.generate_csrf_token()
            flash_messages as list containing
        
        Return Session.create with data as new_session_data and manager as self

    Process called "save_session" that takes session as Session and response as Framework.HTTPResponse returns None:
        If session.is_modified:
            self.backend_handler.save with session_data as session.data
            self.set_session_cookie with session as session and response as response

    Process called "destroy_session" that takes session as Session returns None:
        self.backend_handler.delete with session_id as session.data.session_id

    Process called "regenerate_session_id" that takes session as Session returns String:
        Let old_id be session.data.session_id
        Let new_id be self.generate_session_id()
        
        Note: Delete old session
        self.backend_handler.delete with session_id as old_id
        
        Note: Update session with new ID
        Set session.data.session_id to new_id
        Set session.data.is_modified to true
        self.backend_handler.save with session_data as session.data
        
        Return new_id

    Process called "extract_session_id" that takes request as Framework.HTTPRequest returns Optional[String]:
        If self.config.cookie_name is in request.cookies:
            Let cookie_value be request.cookies[self.config.cookie_name]
            Return self.decrypt_session_id with encrypted_id as cookie_value
        Return null

    Process called "generate_session_id" returns String:
        Return Hash.random_string with length as 32

    Process called "generate_csrf_token" returns String:
        Return Hash.random_string with length as 32

    Process called "encrypt_session_id" that takes session_id as String returns String:
        Return Hash.hmac_sha256 with key as self.config.secret_key and data as session_id

    Process called "decrypt_session_id" that takes encrypted_id as String returns String:
        Note: In a real implementation, this would decrypt/verify the session ID
        Return encrypted_id

    Process called "set_session_cookie" that takes session as Session and response as Framework.HTTPResponse returns None:
        Let encrypted_id be self.encrypt_session_id with session_id as session.data.session_id
        
        Let cookie be Framework.Cookie with:
            name as self.config.cookie_name
            value as encrypted_id
            expires as DateTime.from_timestamp with timestamp as session.data.expires_at
            max_age as self.config.max_age
            domain as self.config.domain
            path as self.config.path
            secure as self.config.secure
            http_only as self.config.http_only
            same_site as self.config.same_site
        
        Add cookie to response.cookies

    Process called "is_expired" that takes session_data as SessionData returns Boolean:
        Return DateTime.now() is greater than session_data.expires_at

    Process called "update_access_time" that takes session_data as SessionData returns None:
        Set session_data.last_accessed to DateTime.now()
        Set session_data.expires_at to DateTime.now() self.config.max_age
        Set session_data.is_modified to true

    Process called "start_cleanup_task" returns None:
        If self.config.cleanup_interval is greater than 0:
            Set self.cleanup_task to Concurrent.run_recurring with:
                interval_seconds as self.config.cleanup_interval
                task as Process:
                    self.cleanup_expired_sessions()

    Process called "cleanup_expired_sessions" returns None:
        self.backend_handler.cleanup_expired()

Note: Session Object
Type called "Session":
    data as SessionData
    manager as SessionManager

    Process called "create" that takes data as SessionData and manager as SessionManager returns Session:
        Return Session with:
            data as data
            manager as manager

    Process called "get" that takes key as String returns Optional[Any]:
        Return self.data.data.get with key as key

    Process called "set" that takes key as String and value as Any returns None:
        Set self.data.data[key] to value
        Set self.data.is_modified to true

    Process called "remove" that takes key as String returns Optional[Any]:
        If key is in self.data.data:
            Let old_value be self.data.data[key]
            self.data.data.remove with key as key
            Set self.data.is_modified to true
            Return old_value
        Return null

    Process called "clear" returns None:
        self.data.data.clear()
        Set self.data.is_modified to true

    Process called "has" that takes key as String returns Boolean:
        Return key is in self.data.data

    Process called "keys" returns List[String]:
        Return self.data.data.keys()

    Process called "get_csrf_token" returns String:
        Return self.data.csrf_token

    Process called "regenerate_csrf_token" returns String:
        Set self.data.csrf_token to self.manager.generate_csrf_token()
        Set self.data.is_modified to true
        Return self.data.csrf_token

    Process called "validate_csrf_token" that takes token as String returns Boolean:
        Return token is equal to self.data.csrf_token

    Process called "add_flash_message" that takes category as String and message as String returns None:
        Let flash_msg be FlashMessage with:
            category as category
            message as message
            timestamp as DateTime.now()
        
        Add flash_msg to self.data.flash_messages
        Set self.data.is_modified to true

    Process called "get_flash_messages" that takes category as Optional[String] returns List[FlashMessage]:
        If category is null:
            Return self.data.flash_messages
        
        Return self.data.flash_messages.filter with predicate as Process that takes msg: Return msg.category is equal to category

    Process called "pop_flash_messages" that takes category as Optional[String] returns List[FlashMessage]:
        Let messages be self.get_flash_messages with category as category
        
        If category is null:
            Set self.data.flash_messages to list containing
        Otherwise:
            Set self.data.flash_messages to self.data.flash_messages.filter with predicate as Process that takes msg: Return msg.category is not equal to category
        
        If length of messages is greater than 0:
            Set self.data.is_modified to true
        
        Return messages

    Process called "flash_info" that takes message as String returns None:
        self.add_flash_message with category as "info" and message as message

    Process called "flash_success" that takes message as String returns None:
        self.add_flash_message with category as "success" and message as message

    Process called "flash_warning" that takes message as String returns None:
        self.add_flash_message with category as "warning" and message as message

    Process called "flash_error" that takes message as String returns None:
        self.add_flash_message with category as "error" and message as message

    Process called "get_session_id" returns String:
        Return self.data.session_id

    Process called "is_new" returns Boolean:
        Return self.data.is_new

    Process called "is_modified" returns Boolean:
        Return self.data.is_modified

    Process called "get_created_at" returns Float:
        Return self.data.created_at

    Process called "get_last_accessed" returns Float:
        Return self.data.last_accessed

    Process called "get_expires_at" returns Float:
        Return self.data.expires_at

    Process called "regenerate_id" returns String:
        Return self.manager.regenerate_session_id with session as self

    Process called "destroy" returns None:
        self.manager.destroy_session with session as self

Note: Session Backend Handler
Type called "SessionBackendHandler":
    backend as SessionBackend

    Process called "create" that takes backend as SessionBackend returns SessionBackendHandler:
        Return SessionBackendHandler with:
            backend as backend

    Process called "load" that takes session_id as String returns Optional[SessionData]:
        Match self.backend:
            When MemoryBackend with store as store:
                Return store.get with key as session_id
            When FileBackend with directory as dir:
                Return self.load_from_file with session_id as session_id and directory as dir
            When DatabaseBackend with connection as conn and table_name as table:
                Return self.load_from_database with session_id as session_id and connection as conn and table_name as table
            When RedisBackend with connection as conn:
                Return self.load_from_redis with session_id as session_id and connection as conn
            When MemcachedBackend with connection as conn:
                Return self.load_from_memcached with session_id as session_id and connection as conn

    Process called "save" that takes session_data as SessionData returns None:
        Match self.backend:
            When MemoryBackend with store as store:
                Set store[session_data.session_id] to session_data
            When FileBackend with directory as dir:
                self.save_to_file with session_data as session_data and directory as dir
            When DatabaseBackend with connection as conn and table_name as table:
                self.save_to_database with session_data as session_data and connection as conn and table_name as table
            When RedisBackend with connection as conn:
                self.save_to_redis with session_data as session_data and connection as conn
            When MemcachedBackend with connection as conn:
                self.save_to_memcached with session_data as session_data and connection as conn

    Process called "delete" that takes session_id as String returns None:
        Match self.backend:
            When MemoryBackend with store as store:
                store.remove with key as session_id
            When FileBackend with directory as dir:
                self.delete_from_file with session_id as session_id and directory as dir
            When DatabaseBackend with connection as conn and table_name as table:
                self.delete_from_database with session_id as session_id and connection as conn and table_name as table
            When RedisBackend with connection as conn:
                self.delete_from_redis with session_id as session_id and connection as conn
            When MemcachedBackend with connection as conn:
                self.delete_from_memcached with session_id as session_id and connection as conn

    Process called "cleanup_expired" returns None:
        Match self.backend:
            When MemoryBackend with store as store:
                self.cleanup_memory_store with store as store
            When FileBackend with directory as dir:
                self.cleanup_file_store with directory as dir
            When DatabaseBackend with connection as conn and table_name as table:
                self.cleanup_database_store with connection as conn and table_name as table
            When RedisBackend:
                Note: Redis handles expiration automatically
                Return
            When MemcachedBackend:
                Note: Memcached handles expiration automatically
                Return

    Process called "load_from_file" that takes session_id as String and directory as String returns Optional[SessionData]:
        Let file_path be directory Joined with "/" Joined with session_id Joined with ".session"
        If OS.file_exists with path as file_path:
            Let content be OS.read_file with path as file_path
            Return self.deserialize_session_data with data as content
        Return null

    Process called "save_to_file" that takes session_data as SessionData and directory as String returns None:
        Let file_path be directory Joined with "/" Joined with session_data.session_id Joined with ".session"
        Let serialized_data be self.serialize_session_data with session_data as session_data
        OS.write_file with path as file_path and content as serialized_data

    Process called "delete_from_file" that takes session_id as String and directory as String returns None:
        Let file_path be directory Joined with "/" Joined with session_id Joined with ".session"
        If OS.file_exists with path as file_path:
            OS.delete_file with path as file_path

    Process called "cleanup_file_store" that takes directory as String returns None:
        Let current_time be DateTime.now()
        Let files be OS.list_directory with path as directory
        
        For each file in files:
            If file ends with ".session":
                Let file_path be directory Joined with "/" Joined with file
                Let session_data be self.load_from_file with session_id as file.replace with old as ".session" and new as "" and directory as directory
                If session_data is not null and current_time is greater than session_data.expires_at:
                    OS.delete_file with path as file_path

    Process called "cleanup_memory_store" that takes store as Dictionary[String, SessionData] returns None:
        Let current_time be DateTime.now()
        Let expired_sessions be list containing
        
        For each session_id in store:
            Let session_data be store[session_id]
            If current_time is greater than session_data.expires_at:
                Add session_id to expired_sessions
        
        For each session_id in expired_sessions:
            store.remove with key as session_id

    Process called "serialize_session_data" that takes session_data as SessionData returns String:
        Let data_dict be dictionary with:
            "session_id" as session_data.session_id
            "data" as session_data.data
            "created_at" as session_data.created_at
            "last_accessed" as session_data.last_accessed
            "expires_at" as session_data.expires_at
            "csrf_token" as session_data.csrf_token
            "flash_messages" as self.serialize_flash_messages with messages as session_data.flash_messages
        
        Return json_encode with data as data_dict

    Process called "deserialize_session_data" that takes data as String returns SessionData:
        Let data_dict be json_decode with json as data
        
        Return SessionData with:
            session_id as data_dict["session_id"]
            data as data_dict["data"]
            created_at as data_dict["created_at"]
            last_accessed as data_dict["last_accessed"]
            expires_at as data_dict["expires_at"]
            is_new as false
            is_modified as false
            csrf_token as data_dict["csrf_token"]
            flash_messages as self.deserialize_flash_messages with messages as data_dict["flash_messages"]

    Process called "serialize_flash_messages" that takes messages as List[FlashMessage] returns List[Dictionary[String, Any]]:
        Let serialized be list containing
        
        For each message in messages:
            Add dictionary with:
                "category" as message.category
                "message" as message.message
                "timestamp" as message.timestamp
            to serialized
        
        Return serialized

    Process called "deserialize_flash_messages" that takes messages as List[Dictionary[String, Any]] returns List[FlashMessage]:
        Let deserialized be list containing
        
        For each message_data in messages:
            Add FlashMessage with:
                category as message_data["category"]
                message as message_data["message"]
                timestamp as message_data["timestamp"]
            to deserialized
        
        Return deserialized

    Process called "load_from_database" that takes session_id as String and connection as Any and table_name as String returns Optional[SessionData]:
        Note: Database implementation would query the database
        Return null

    Process called "save_to_database" that takes session_data as SessionData and connection as Any and table_name as String returns None:
        Note: Database implementation would insert/update the session
        Return

    Process called "delete_from_database" that takes session_id as String and connection as Any and table_name as String returns None:
        Note: Database implementation would delete the session
        Return

    Process called "cleanup_database_store" that takes connection as Any and table_name as String returns None:
        Note: Database implementation would delete expired sessions
        Return

    Process called "load_from_redis" that takes session_id as String and connection as Any returns Optional[SessionData]:
        Note: Redis implementation would get the session data
        Return null

    Process called "save_to_redis" that takes session_data as SessionData and connection as Any returns None:
        Note: Redis implementation would set the session data with expiration
        Return

    Process called "delete_from_redis" that takes session_id as String and connection as Any returns None:
        Note: Redis implementation would delete the session
        Return

    Process called "load_from_memcached" that takes session_id as String and connection as Any returns Optional[SessionData]:
        Note: Memcached implementation would get the session data
        Return null

    Process called "save_to_memcached" that takes session_data as SessionData and connection as Any returns None:
        Note: Memcached implementation would set the session data with expiration
        Return

    Process called "delete_from_memcached" that takes session_id as String and connection as Any returns None:
        Note: Memcached implementation would delete the session
        Return

Note: Session Middleware
Type called "SessionMiddleware":
    session_manager as SessionManager

    Process called "create" that takes session_manager as SessionManager returns SessionMiddleware:
        Return SessionMiddleware with:
            session_manager as session_manager

    Process called "handle" that takes request as Framework.HTTPRequest and context as Dictionary[String, Any] returns Optional[Framework.HTTPResponse]:
        Let session be self.session_manager.get_session with request as request
        Set context["session"] to session
        
        Note: Add session to request for easy access
        Set context["request_session"] to session
        
        Note: Continue to next middleware/handler
        Return null

    Process called "finalize_response" that takes request as Framework.HTTPRequest and response as Framework.HTTPResponse and context as Dictionary[String, Any] returns None:
        If "session" is in context:
            Let session be context["session"] as Session
            self.session_manager.save_session with session as session and response as response

Note: CSRF Protection
Type called "CSRFProtection":
    session_manager as SessionManager
    token_name as String
    header_name as String
    exempt_methods as List[String]

    Process called "create" that takes session_manager as SessionManager returns CSRFProtection:
        Return CSRFProtection with:
            session_manager as session_manager
            token_name as "csrf_token"
            header_name as "X-CSRF-Token"
            exempt_methods as list containing "GET", "HEAD", "OPTIONS", "TRACE"

    Process called "validate_request" that takes request as Framework.HTTPRequest and session as Session returns Boolean:
        If request.method.to_string() is in self.exempt_methods:
            Return true
        
        Let token be self.extract_csrf_token with request as request
        If token is null:
            Return false
        
        Return session.validate_csrf_token with token as token

    Process called "extract_csrf_token" that takes request as Framework.HTTPRequest returns Optional[String]:
        Note: Check form data first
        If self.token_name is in request.form_data:
            Return request.form_data[self.token_name]
        
        Note: Check headers
        If self.header_name is in request.headers:
            Return request.headers[self.header_name]
        
        Return null

Note: Utility Functions
Process called "create_session_manager" that takes config as SessionConfig returns SessionManager:
    Return SessionManager.create with config as config

Process called "create_default_session_config" returns SessionConfig:
    Return SessionConfig with:
        cookie_name as "runa_session"
        secret_key as Hash.random_string with length as 32
        max_age as 86400
        secure as false
        http_only as true
        same_site as Framework.Lax
        domain as null
        path as "/"
        backend as MemoryBackend with store as dictionary containing
        auto_regenerate as false
        regenerate_interval as 0
        cleanup_interval as 3600
        enable_csrf as true
        csrf_token_name as "csrf_token"

Process called "create_memory_backend" returns SessionBackend:
    Return MemoryBackend with store as dictionary containing

Process called "create_file_backend" that takes directory as String returns SessionBackend:
    Return FileBackend with directory as directory

Process called "create_session_middleware" that takes session_manager as SessionManager returns SessionMiddleware:
    Return SessionMiddleware.create with session_manager as session_manager

Process called "create_csrf_protection" that takes session_manager as SessionManager returns CSRFProtection:
    Return CSRFProtection.create with session_manager as session_manager

Process called "json_encode" that takes data as Any returns String:
    Note: Use proper JSON implementation from api module
    Match data:
        When String as str:
            Return "\"" Joined with str Joined with "\""
        When Integer as num:
            Return num.to_string()
        When Float as num:
            Return num.to_string()
        When Boolean as bool:
            Return if bool then "true" otherwise "false"
        When null:
            Return "null"
        When Dictionary as dict:
            Let parts be list containing "{"
            Let first be true
            For each key in dict:
                If not first:
                    Add "," to parts
                Set first to false
                Add "\"" Joined with key Joined with "\":" Joined with json_encode with data as dict[key] to parts
            Add "}" to parts
            Return parts.join with separator as ""
        Otherwise:
            Return "null"

Process called "json_decode" that takes json as String returns Dictionary[String, Any]:
    Note: Basic JSON decoding for session data
    If json starts with "{" and json ends with "}":
        Return dictionary with "data" as json
    Return dictionary containing

