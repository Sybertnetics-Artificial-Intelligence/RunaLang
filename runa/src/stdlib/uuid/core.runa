Note: Runa Standard Library - UUID Core Foundation
Note: Production-grade UUID core types, constants, and fundamental operations
Note: Designed to exceed Python uuid, Rust uuid, Go uuid packages

Import "../../builtins" as Builtins
Import "../../collections" as Collections
Import "../../crypto" as Crypto
Import "../../time" as Time

Note: Core UUID type system - engineered for performance and safety

Type called "UUID":
    bytes as List[Integer]
    version as Integer
    variant as String
    
    Process called "create" that takes bytes as List[Integer] returns UUID:
        If length of bytes is not equal to 16:
            Throw ValueError with message as "UUID requires exactly 16 bytes"
        
        Let version be extract_version_from_bytes with bytes as bytes
        Let variant be extract_variant_from_bytes with bytes as bytes
        
        Return UUID with:
            bytes as bytes
            version as version
            variant as variant
    
    Process called "to_string" returns String:
        Return format_uuid_bytes_to_string with bytes as self.bytes
    
    Process called "equals" that takes other as UUID returns Boolean:
        Return self.bytes is equal to other.bytes

Type UUIDVersion is:
    | V1
    | V2  
    | V3
    | V4
    | V5
    | V6
    | V7
    | V8

Type UUIDVariant is:
    | NCS
    | RFC4122
    | Microsoft
    | Reserved

Type called "UUIDNamespace":
    uuid as String
    name as String
    description as String

Note: Standard RFC 4122 namespaces - production constants

Define NAMESPACE_DNS as UUIDNamespace with:
    uuid as "6ba7b810-9dad-11d1-80b4-00c04fd430c8"
    name as "DNS"
    description as "Domain Name System"

Define NAMESPACE_URL as UUIDNamespace with:
    uuid as "6ba7b811-9dad-11d1-80b4-00c04fd430c8"
    name as "URL"
    description as "Uniform Resource Locator"

Define NAMESPACE_OID as UUIDNamespace with:
    uuid as "6ba7b812-9dad-11d1-80b4-00c04fd430c8"
    name as "OID"
    description as "ISO Object Identifier"

Define NAMESPACE_X500 as UUIDNamespace with:
    uuid as "6ba7b814-9dad-11d1-80b4-00c04fd430c8"
    name as "X500"
    description as "X.500 Distinguished Name"

Note: Special UUID constants

Define UUID_NIL as String constant as "00000000-0000-0000-0000-000000000000"
Define UUID_MAX as String constant as "ffffffff-ffff-ffff-ffff-ffffffffffff"

Note: Core UUID validation and parsing functions

Process called "is_valid_uuid_string" that takes uuid_string as String returns Boolean:
    Let cleaned be remove_hyphens_from_uuid with uuid_string as uuid_string
    
    If length of cleaned is not equal to 32:
        Return false
    
    For i from 0 to 31:
        Let char be character_at with string as cleaned and index as i
        If not is_hex_character with character as char:
            Return false
    
    Return true

Process called "parse_uuid_string" that takes uuid_string as String returns UUID:
    If not is_valid_uuid_string with uuid_string as uuid_string:
        Throw ValueError with message as f"Invalid UUID string: {uuid_string}"
    
    Let cleaned be remove_hyphens_from_uuid with uuid_string as uuid_string
    Let bytes be convert_hex_string_to_bytes with hex_string as cleaned
    
    Return UUID.create with bytes as bytes

Process called "format_uuid_bytes_to_string" that takes bytes as List[Integer] returns String:
    If length of bytes is not equal to 16:
        Throw ValueError with message as "UUID requires exactly 16 bytes"
    
    Let hex_string be convert_bytes_to_hex_string with bytes as bytes
    
    Note: Insert hyphens at standard positions: 8-4-4-4-12
    Let result be ""
    Set result to result concatenated with substring with string as hex_string and start as 0 and end as 8
    Set result to result concatenated with "-"
    Set result to result concatenated with substring with string as hex_string and start as 8 and end as 12
    Set result to result concatenated with "-"
    Set result to result concatenated with substring with string as hex_string and start as 12 and end as 16
    Set result to result concatenated with "-"
    Set result to result concatenated with substring with string as hex_string and start as 16 and end as 20
    Set result to result concatenated with "-"
    Set result to result concatenated with substring with string as hex_string and start as 20 and end as 32
    
    Return result

Note: Advanced UUID analysis and extraction functions

Process called "extract_version_from_bytes" that takes bytes as List[Integer] returns Integer:
    If length of bytes is not equal to 16:
        Throw ValueError with message as "UUID requires exactly 16 bytes"
    
    Note: Version is stored in the most significant 4 bits of byte 6
    Let version_byte be bytes[6]
    Return version_byte divided by 16

Process called "extract_variant_from_bytes" that takes bytes as List[Integer] returns String:
    If length of bytes is not equal to 16:
        Throw ValueError with message as "UUID requires exactly 16 bytes"
    
    Note: Variant is stored in the most significant bits of byte 8
    Let variant_byte be bytes[8]
    
    If variant_byte is less than 128:
        Return "NCS"
    If variant_byte is less than 192:
        Return "RFC4122"
    If variant_byte is less than 224:
        Return "Microsoft"
    Return "Reserved"

Process called "extract_timestamp_from_v1_bytes" that takes bytes as List[Integer] returns Integer:
    If extract_version_from_bytes with bytes as bytes is not equal to 1:
        Throw ValueError with message as "Timestamp extraction only valid for version 1 UUIDs"
    
    Note: UUID v1 timestamp is split across bytes 0-3, 4-5, 6-7
    Let time_low be bytes_to_32bit_int with bytes as slice with list as bytes and start as 0 and end as 4
    Let time_mid be bytes_to_16bit_int with bytes as slice with list as bytes and start as 4 and end as 6
    Let time_hi be bytes_to_16bit_int with bytes as slice with list as bytes and start as 6 and end as 8
    
    Note: Remove version bits from time_hi
    Set time_hi to time_hi modulo 4096
    
    Note: Combine into 60-bit timestamp
    Let timestamp be time_hi multiplied by 281474976710656  Note: 2^48
    Set timestamp to timestamp time_mid multiplied by 4294967296  Note: 2^32
    Set timestamp to timestamp time_low
    
    Return timestamp

Process called "extract_clock_sequence_from_v1_bytes" that takes bytes as List[Integer] returns Integer:
    If extract_version_from_bytes with bytes as bytes is not equal to 1:
        Throw ValueError with message as "Clock sequence extraction only valid for version 1 UUIDs"
    
    Note: Clock sequence is in bytes 8-9, with variant bits removed
    Let clock_hi be bytes[8] modulo 64  Note: Remove variant bits
    Let clock_lo be bytes[9]
    
    Return clock_hi multiplied by 256 clock_lo

Process called "extract_node_from_v1_bytes" that takes bytes as List[Integer] returns List[Integer]:
    If extract_version_from_bytes with bytes as bytes is not equal to 1:
        Throw ValueError with message as "Node extraction only valid for version 1 UUIDs"
    
    Note: Node is the last 6 bytes
    Return slice with list as bytes and start as 10 and end as 16

Note: Utility functions for byte manipulation

Process called "remove_hyphens_from_uuid" that takes uuid_string as String returns String:
    Let result be ""
    
    For i from 0 to length of uuid_string - 1:
        Let char be character_at with string as uuid_string and index as i
        If char is not equal to '-':
            Set result to result concatenated with char
    
    Return result

Process called "is_hex_character" that takes character as Character returns Boolean:
    Let ascii_value be get_ascii_value with character as character
    
    Note: Check for 0-9, a-f, A-F
    If ascii_value is greater than or equal to 48 and ascii_value is less than or equal to 57:
        Return true
    If ascii_value is greater than or equal to 97 and ascii_value is less than or equal to 102:
        Return true
    If ascii_value is greater than or equal to 65 and ascii_value is less than or equal to 70:
        Return true
    
    Return false

Process called "convert_hex_string_to_bytes" that takes hex_string as String returns List[Integer]:
    If length of hex_string modulo 2 is not equal to 0:
        Throw ValueError with message as "Hex string must have even length"
    
    Let bytes be list containing
    
    For i from 0 to length of hex_string - 1 by 2:
        Let hex_pair be substring with string as hex_string and start as i and end as i 2
        Let byte_value be parse_hex_byte with hex_pair as hex_pair
        Add byte_value to bytes
    
    Return bytes

Process called "convert_bytes_to_hex_string" that takes bytes as List[Integer] returns String:
    Let result be ""
    
    For each byte in bytes:
        If byte is less than 0 or byte is greater than 255:
            Throw ValueError with message as f"Invalid byte value: {byte}"
        
        Let hex_value be convert_byte_to_hex with byte as byte
        Set result to result concatenated with hex_value
    
    Return result

Process called "parse_hex_byte" that takes hex_pair as String returns Integer:
    If length of hex_pair is not equal to 2:
        Throw ValueError with message as "Hex pair must be exactly 2 characters"
    
    Let high_nibble be parse_hex_digit with digit as character_at with string as hex_pair and index as 0
    Let low_nibble be parse_hex_digit with digit as character_at with string as hex_pair and index as 1
    
    Return high_nibble multiplied by 16 low_nibble

Process called "parse_hex_digit" that takes digit as Character returns Integer:
    Let ascii_value be get_ascii_value with character as digit
    
    If ascii_value is greater than or equal to 48 and ascii_value is less than or equal to 57:
        Return ascii_value - 48
    If ascii_value is greater than or equal to 97 and ascii_value is less than or equal to 102:
        Return ascii_value - 97 10
    If ascii_value is greater than or equal to 65 and ascii_value is less than or equal to 70:
        Return ascii_value - 65 10
    
    Throw ValueError with message as f"Invalid hex digit: {digit}"

Process called "convert_byte_to_hex" that takes byte as Integer returns String:
    If byte is less than 0 or byte is greater than 255:
        Throw ValueError with message as f"Invalid byte value: {byte}"
    
    Let high_nibble be byte divided by 16
    Let low_nibble be byte modulo 16
    
    Let high_char be convert_nibble_to_hex_char with nibble as high_nibble
    Let low_char be convert_nibble_to_hex_char with nibble as low_nibble
    
    Return string_from_characters with characters as list containing high_char, low_char

Process called "convert_nibble_to_hex_char" that takes nibble as Integer returns Character:
    If nibble is less than 0 or nibble is greater than 15:
        Throw ValueError with message as f"Invalid nibble value: {nibble}"
    
    If nibble is less than 10:
        Return character_from_ascii with ascii as 48 nibble
    
    Return character_from_ascii with ascii as 97 nibble - 10

Process called "bytes_to_32bit_int" that takes bytes as List[Integer] returns Integer:
    If length of bytes is not equal to 4:
        Throw ValueError with message as "Need exactly 4 bytes for 32-bit integer"
    
    Let result be 0
    For i from 0 to 3:
        Set result to result multiplied by 256 bytes[i]
    
    Return result

Process called "bytes_to_16bit_int" that takes bytes as List[Integer] returns Integer:
    If length of bytes is not equal to 2:
        Throw ValueError with message as "Need exactly 2 bytes for 16-bit integer"
    
    Return bytes[0] multiplied by 256 bytes[1]

Note: Advanced UUID comparison and analysis

Process called "compare_uuids" that takes uuid1 as UUID and uuid2 as UUID returns Integer:
    For i from 0 to 15:
        If uuid1.bytes[i] is less than uuid2.bytes[i]:
            Return -1
        If uuid1.bytes[i] is greater than uuid2.bytes[i]:
            Return 1
    
    Return 0

Process called "calculate_uuid_entropy" that takes uuid as UUID returns Float:
    Let byte_counts be dictionary containing
    
    Note: Count frequency of each byte value
    For each byte in uuid.bytes:
        If byte is in byte_counts:
            Set byte_counts[byte] to byte_counts[byte] 1
        Otherwise:
            Set byte_counts[byte] to 1
    
    Note: Calculate Shannon entropy
    Let entropy be 0.0
    Let total_bytes be length of uuid.bytes as Float
    
    For each byte_value and count in byte_counts:
        Let probability be count as Float divided by total_bytes
        Set entropy to entropy - probability multiplied by log2 with value as probability
    
    Return entropy

Process called "is_uuid_nil" that takes uuid as UUID returns Boolean:
    For each byte in uuid.bytes:
        If byte is not equal to 0:
            Return false
    
    Return true

Process called "is_uuid_max" that takes uuid as UUID returns Boolean:
    For each byte in uuid.bytes:
        If byte is not equal to 255:
            Return false
    
    Return true

Note: Error types for UUID operations

Type called "ValueError":
    message as String

Type called "UUIDError":
    message as String
    error_type as String

Note: Platform integration functions

Process called "get_ascii_value" that takes character as Character returns Integer:
    Return Builtins.get_ascii_value with character as character

Process called "character_from_ascii" that takes ascii as Integer returns Character:
    Return Builtins.character_from_ascii with ascii as ascii

Process called "character_at" that takes string as String and index as Integer returns Character:
    Return Builtins.character_at with string as string and index as index

Process called "substring" that takes string as String and start as Integer and end as Integer returns String:
    Return Builtins.substring with string as string and start as start and end as end

Process called "string_from_characters" that takes characters as List[Character] returns String:
    Return Builtins.string_from_characters with characters as characters

Process called "slice" that takes list as List[Integer] and start as Integer and end as Integer returns List[Integer]:
    Return Builtins.slice with list as list and start as start and end as end

Process called "log2" that takes value as Float returns Float:
    Return Builtins.log2 with value as value

