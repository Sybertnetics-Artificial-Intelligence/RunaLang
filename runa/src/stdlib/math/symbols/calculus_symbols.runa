        "mathematical_domain": "real_analysis",
        "notation_variants": ["min", "min_{x∈S}", "minimum value"],
        "usage_examples": ["min{1,2,3} = 1", "min[0,1] = 0", "min f(x) on closed interval"]
    }
    Let symbols be List.append(symbols, minimum_sym)
    
    Return symbols

