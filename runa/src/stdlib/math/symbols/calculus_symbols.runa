        "symbol_name": "epsilon",
        "symbol_type": "limit_parameter",
        "mathematical_domain": "real_analysis",
        "notation_variants": ["ε", "eps", "ε > 0", "for all ε > 0"],
        "usage_examples": ["for all ε > 0, there exists δ > 0", "|f(x) - L| < ε", "ε-δ definition of limit"]
    }
    Let symbols be List.append(symbols, epsilon_sym)
    
    Note: Delta symbol for limits
    Let delta_sym be {
        "symbol": "δ",
        "symbol_name": "delta",
        "symbol_type": "limit_parameter",
        "mathematical_domain": "real_analysis",
        "notation_variants": ["δ", "delta", "δ > 0", "there exists δ > 0"],
        "usage_examples": ["there exists δ > 0 such that", "0 < |x - a| < δ", "ε-δ proof"]
    }
    Let symbols be List.append(symbols, delta_sym)
    
