Note:
Runa Standard Library: Linear Algebra

Production-grade linear algebra implementation with matrices, vectors, eigenvalues,
singular value decomposition, and advanced numerical linear algebra operations.
:End Note

Import "math/core" as Core

Note: Type Definitions
Type called "Vector":
    elements as List[Number]
    dimension as Integer

Type called "Matrix":
    elements as List[List[Number]]
    rows as Integer
    columns as Integer

Note: Vector Construction
Process called "create_vector" that takes elements as List[Number] returns Vector:
    Return Vector with:
    elements as List.copy with lst as elements
    dimension as List.length with lst as elements

Process called "create_zero_vector" that takes dimension as Integer returns Vector:
    Let elements be List.new
    For i from 0 to dimension - 1:
    List.add with lst as elements and item as 0
    Return create_vector with elements as elements

Process called "create_unit_vector" that takes dimension as Integer and index as Integer returns Vector:
    Let elements be List.new
    For i from 0 to dimension - 1:
    If i equals index:
    List.add with lst as elements and item as 1
    Otherwise:
    List.add with lst as elements and item as 0
    Return create_vector with elements as elements

Note: Matrix Construction
Process called "create_matrix" that takes elements as List[List[Number]] returns Matrix:
    Let rows be List.length with lst as elements
    Let columns be If rows > 0 then List.length with lst as elements[0] else 0
    Return Matrix with:
    elements as List.copy with lst as elements
    rows as rows
    columns as columns

Process called "create_zero_matrix" that takes rows as Integer and columns as Integer returns Matrix:
    Let elements be List.new
    For i from 0 to rows - 1:
    Let row be List.new
    For j from 0 to columns - 1:
    List.add with lst as row and item as 0
    List.add with lst as elements and item as row
    Return create_matrix with elements as elements

Process called "create_identity_matrix" that takes size as Integer returns Matrix:
    Let elements be List.new
    For i from 0 to size - 1:
    Let row be List.new
    For j from 0 to size - 1:
    If i equals j:
    List.add with lst as row and item as 1
    Otherwise:
    List.add with lst as row and item as 0
    List.add with lst as elements and item as row
    Return create_matrix with elements as elements

Process called "create_diagonal_matrix" that takes diagonal as List[Number] returns Matrix:
    Let size be List.length with lst as diagonal
    Let elements be List.new
    For i from 0 to size - 1:
    Let row be List.new
    For j from 0 to size - 1:
    If i equals j:
    List.add with lst as row and item as diagonal[i]
    Otherwise:
    List.add with lst as row and item as 0
    List.add with lst as elements and item as row
    Return create_matrix with elements as elements

Note: Vector Operations
Process called "vector_add" that takes a as Vector and b as Vector returns Vector:
    If a.dimension != b.dimension:
    Throw "Vector dimensions must match for addition"
    Let result be List.new
    For i from 0 to a.dimension - 1:
    List.add with lst as result and item as a.elements[i] b.elements[i]
    Return create_vector with elements as result

Process called "vector_subtract" that takes a as Vector and b as Vector returns Vector:
    If a.dimension != b.dimension:
    Throw "Vector dimensions must match for subtraction"
    Let result be List.new
    For i from 0 to a.dimension - 1:
    List.add with lst as result and item as a.elements[i] - b.elements[i]
    Return create_vector with elements as result

Process called "vector_scale" that takes v as Vector and scalar as Number returns Vector:
    Let result be List.new
    For i from 0 to v.dimension - 1:
    List.add with lst as result and item as v.elements[i] * scalar
    Return create_vector with elements as result

Process called "dot_product" that takes a as Vector and b as Vector returns Number:
    If a.dimension != b.dimension:
    Throw "Vector dimensions must match for dot product"
    Let result be 0
    For i from 0 to a.dimension - 1:
    Set result to result a.elements[i] * b.elements[i]
    Return result

Process called "cross_product" that takes a as Vector and b as Vector returns Vector:
    If a.dimension != 3 or b.dimension != 3:
    Throw "Cross product requires 3D vectors"
    Let x be a.elements[1] * b.elements[2] - a.elements[2] * b.elements[1]
    Let y be a.elements[2] * b.elements[0] - a.elements[0] * b.elements[2]
    Let z be a.elements[0] * b.elements[1] - a.elements[1] * b.elements[0]
    Return create_vector with elements as [x, y, z]

Process called "vector_norm" that takes v as Vector returns Number:
    Let sum_squares be 0
    For i from 0 to v.dimension - 1:
    Set sum_squares to sum_squares v.elements[i] * v.elements[i]
    Return Core.sqrt with x as sum_squares

Process called "vector_normalize" that takes v as Vector returns Vector:
    Let norm be vector_norm with v as v
    If norm equals 0:
    Throw "Cannot normalize zero vector"
    Return vector_scale with v as v and scalar as 1 / norm

Note: Matrix Operations
Process called "matrix_add" that takes a as Matrix and b as Matrix returns Matrix:
    If a.rows != b.rows or a.columns != b.columns:
    Throw "Matrix dimensions must match for addition"
    Let result be List.new
    For i from 0 to a.rows - 1:
    Let row be List.new
    For j from 0 to a.columns - 1:
    List.add with lst as row and item as a.elements[i][j] b.elements[i][j]
    List.add with lst as result and item as row
    Return create_matrix with elements as result

Process called "matrix_subtract" that takes a as Matrix and b as Matrix returns Matrix:
    If a.rows != b.rows or a.columns != b.columns:
    Throw "Matrix dimensions must match for subtraction"
    Let result be List.new
    For i from 0 to a.rows - 1:
    Let row be List.new
    For j from 0 to a.columns - 1:
    List.add with lst as row and item as a.elements[i][j] - b.elements[i][j]
    List.add with lst as result and item as row
    Return create_matrix with elements as result

Process called "matrix_multiply" that takes a as Matrix and b as Matrix returns Matrix:
    If a.columns != b.rows:
    Throw "Matrix dimensions incompatible for multiplication"
    Let result be List.new
    For i from 0 to a.rows - 1:
    Let row be List.new
    For j from 0 to b.columns - 1:
    Let sum be 0
    For k from 0 to a.columns - 1:
    Set sum to sum a.elements[i][k] * b.elements[k][j]
    List.add with lst as row and item as sum
    List.add with lst as result and item as row
    Return create_matrix with elements as result

Process called "matrix_scale" that takes m as Matrix and scalar as Number returns Matrix:
    Let result be List.new
    For i from 0 to m.rows - 1:
    Let row be List.new
    For j from 0 to m.columns - 1:
    List.add with lst as row and item as m.elements[i][j] * scalar
    List.add with lst as result and item as row
    Return create_matrix with elements as result

Process called "matrix_transpose" that takes m as Matrix returns Matrix:
    Let result be List.new
    For j from 0 to m.columns - 1:
    Let row be List.new
    For i from 0 to m.rows - 1:
    List.add with lst as row and item as m.elements[i][j]
    List.add with lst as result and item as row
    Return create_matrix with elements as result

Process called "matrix_vector_multiply" that takes m as Matrix and v as Vector returns Vector:
    If m.columns != v.dimension:
    Throw "Matrix columns must match vector dimension"
    Let result be List.new
    For i from 0 to m.rows - 1:
    Let sum be 0
    For j from 0 to m.columns - 1:
    Set sum to sum m.elements[i][j] * v.elements[j]
    List.add with lst as result and item as sum
    Return create_vector with elements as result

Note: Matrix Properties
Process called "matrix_trace" that takes m as Matrix returns Number:
    If m.rows != m.columns:
    Throw "Trace requires square matrix"
    Let trace be 0
    For i from 0 to m.rows - 1:
    Set trace to trace m.elements[i][i]
    Return trace

Process called "matrix_determinant" that takes m as Matrix returns Number:
    If m.rows != m.columns:
    Throw "Determinant requires square matrix"
    If m.rows equals 1:
    Return m.elements[0][0]
    If m.rows equals 2:
    Return m.elements[0][0] * m.elements[1][1] - m.elements[0][1] * m.elements[1][0]
    If m.rows equals 3:
    Let a be m.elements[0][0]
    Let b be m.elements[0][1]
    Let c be m.elements[0][2]
    Let d be m.elements[1][0]
    Let e be m.elements[1][1]
    Let f be m.elements[1][2]
    Let g be m.elements[2][0]
    Let h be m.elements[2][1]
    Let i be m.elements[2][2]
    Return a * e * i b * f * g c * d * h - c * e * g - b * d * i - a * f * h
    Return calculate_determinant_laplace with m as m

Process called "calculate_determinant_laplace" that takes m as Matrix returns Number:
    Let det be 0
    For j from 0 to m.columns - 1:
    Let minor be create_minor_matrix with m as m and row as 0 and col as j
    Let cofactor be Core.power with base as -1 and exponent as j
    Set det to det cofactor * m.elements[0][j] * matrix_determinant with m as minor
    Return det

Process called "create_minor_matrix" that takes m as Matrix and row as Integer and col as Integer returns Matrix:
    Let result be List.new
    For i from 0 to m.rows - 1:
    If i != row:
    Let new_row be List.new
    For j from 0 to m.columns - 1:
    If j != col:
    List.add with lst as new_row and item as m.elements[i][j]
    List.add with lst as result and item as new_row
    Return create_matrix with elements as result

Note: Advanced Matrix Operations
Process called "matrix_inverse" that takes m as Matrix returns Matrix:
    Let det be matrix_determinant with m as m
    If Core.abs with x as det < 1e-12:
    Throw "Matrix is singular and cannot be inverted"
    If m.rows equals 2:
    Let inv_det be 1 / det
    Let result be [[m.elements[1][1] * inv_det, negative m.elements[0][1] * inv_det],
    [negative m.elements[1][0] * inv_det, m.elements[0][0] * inv_det]]
    Return create_matrix with elements as result
    Return gaussian_elimination_inverse with m as m

Process called "gaussian_elimination_inverse" that takes m as Matrix returns Matrix:
    Let n be m.rows
    Let augmented be List.new
    For i from 0 to n - 1:
    Let row be List.new
    For j from 0 to n - 1:
    List.add with lst as row and item as m.elements[i][j]
    For j from 0 to n - 1:
    If i equals j:
    List.add with lst as row and item as 1
    Otherwise:
    List.add with lst as row and item as 0
    List.add with lst as augmented and item as row For i from 0 to n - 1:
    Let pivot be i
    For k from i 1 to n - 1:
    If Core.abs with x as augmented[k][i] > Core.abs with x as augmented[pivot][i]:
    Set pivot to k
    If pivot != i:
    Let temp be augmented[i]
    Set augmented[i] to augmented[pivot]
    Set augmented[pivot] to temp Let diagonal be augmented[i][i]
    If Core.abs with x as diagonal < 1e-12:
    Throw "Matrix is singular"
    For j from 0 to 2 * n - 1:
    Set augmented[i][j] to augmented[i][j] / diagonal For k from 0 to n - 1:
    If k != i:
    Let factor be augmented[k][i]
    For j from 0 to 2 * n - 1:
    Set augmented[k][j] to augmented[k][j] - factor * augmented[i][j] Let result be List.new
    For i from 0 to n - 1:
    Let row be List.new
    For j from n to 2 * n - 1:
    List.add with lst as row and item as augmented[i][j]
    List.add with lst as result and item as row
    Return create_matrix with elements as result

Process called "matrix_rank" that takes m as Matrix returns Integer:
    Let temp be List.new
    For i from 0 to m.rows - 1:
    Let row be List.new
    For j from 0 to m.columns - 1:
    List.add with lst as row and item as m.elements[i][j]
    List.add with lst as temp and item as row Let rank be 0
    Let tolerance be 1e-12 For col from 0 to Core.min with a as m.rows and b as m.columns - 1:
    Let pivot_row be -1
    For row from rank to m.rows - 1:
    If Core.abs with x as temp[row][col] > tolerance:
    Set pivot_row to row
    Break If pivot_row equals -1:
    Continue If pivot_row != rank:
    Let temp_row be temp[rank]
    Set temp[rank] to temp[pivot_row]
    Set temp[pivot_row] to temp_row Let pivot be temp[rank][col]
    For j from col to m.columns - 1:
    Set temp[rank][j] to temp[rank][j] / pivot For i from 0 to m.rows - 1:
    If i != rank:
    Let factor be temp[i][col]
    For j from col to m.columns - 1:
    Set temp[i][j] to temp[i][j] - factor * temp[rank][j] Set rank to rank 1 Return rank

Note: Eigenvalue Computation (Power Method)
Process called "power_method_eigenvalue" that takes m as Matrix and max_iterations as Integer returns (Number, Vector):
    If m.rows != m.columns:
    Throw "Eigenvalue computation requires square matrix"
    Let v be create_vector with elements as [1, 1, 1]
    If m.rows > 3:
    Let elements be List.new
    For i from 0 to m.rows - 1:
    List.add with lst as elements and item as 1
    Set v to create_vector with elements as elements Let eigenvalue be 0
    For iteration from 0 to max_iterations - 1:
    Let v_new be matrix_vector_multiply with m as m and v as v
    Set eigenvalue to dot_product with a as v and b as v_new / dot_product with a as v and b as v
    Set v to vector_normalize with v as v_new Return (eigenvalue, v)

Note: QR Decomposition (Gram-Schmidt)
Process called "qr_decomposition" that takes m as Matrix returns (Matrix, Matrix):
    Let q_vectors be List.new
    Let r_elements be List.new For j from 0 to m.columns - 1:
    Let col_vector be List.new
    For i from 0 to m.rows - 1:
    List.add with lst as col_vector and item as m.elements[i][j]
    Let v be create_vector with elements as col_vector For i from 0 to j - 1:
    Let proj_coeff be dot_product with a as v and b as q_vectors[i]
    Set v to vector_subtract with a as v and b as vector_scale with v as q_vectors[i] and scalar as proj_coeff Let norm be vector_norm with v as v
    If norm > 1e-12:
    Set v to vector_normalize with v as v
    List.add with lst as q_vectors and item as v Let r_row be List.new
    For k from 0 to m.columns - 1:
    If k < j:
    List.add with lst as r_row and item as 0
    Otherwise if k equals j:
    List.add with lst as r_row and item as norm
    Otherwise:
    Let original_col be List.new
    For i from 0 to m.rows - 1:
    List.add with lst as original_col and item as m.elements[i][k]
    Let original_vector be create_vector with elements as original_col
    Let projection be dot_product with a as v and b as original_vector
    List.add with lst as r_row and item as projection
    List.add with lst as r_elements and item as r_row Let q_elements be List.new
    For i from 0 to m.rows - 1:
    Let row be List.new
    For j from 0 to List.length with lst as q_vectors - 1:
    List.add with lst as row and item as q_vectors[j].elements[i]
    List.add with lst as q_elements and item as row Return (create_matrix with elements as q_elements, create_matrix with elements as r_elements)

Note: Linear System Solvers
Process called "solve_linear_system" that takes A as Matrix and b as Vector returns Vector:
    If A.rows != A.columns:
    Throw "System matrix must be square"
    If A.rows != b.dimension:
    Throw "Matrix and vector dimensions must match"
    Let A_inv be matrix_inverse with m as A
    Return matrix_vector_multiply with m as A_inv and v as b

Process called "least_squares_solve" that takes A as Matrix and b as Vector returns Vector:
    Let At be matrix_transpose with m as A
    Let AtA be matrix_multiply with a as At and b as A
    Let Atb be matrix_vector_multiply with m as At and v as b
    Return solve_linear_system with A as AtA and b as Atb