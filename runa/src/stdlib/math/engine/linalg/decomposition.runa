Note:
Runa Scientific Computing: Advanced Matrix Decompositions

Comprehensive matrix factorization algorithms surpassing NumPy/SciPy with
numerical stability, performance optimizations, and AI-ready interfaces.

Features:
- LU decomposition with pivoting strategies
- QR decomposition (Gram-Schmidt, Householder, Givens)
- Cholesky decomposition for positive definite matrices
- Singular Value Decomposition (SVD) with truncation
- Eigenvalue decomposition (symmetric and general)
- Schur decomposition
- Jordan normal form
- Non-negative matrix factorization (NMF)
- CUR decomposition for large-scale matrices
- Tensor decompositions (CP, Tucker, HOSVD)
:End Note

Import "scientific/core/ndarray" as NDArray
Import "scientific/linalg/core" as LinAlg
Import "../../collections" as Collections
Import "math/core" as Math

Type called "LUDecomposition":
    L as NDArray.NDArray
    U as NDArray.NDArray
    P as NDArray.NDArray
    permutation_count as Integer
    pivot_strategy as PivotStrategy
    numerical_rank as Integer
    condition_number as Float
    metadata as Dictionary[String, Any]

Type PivotStrategy is:
    | NoPivoting
    | PartialPivoting
    | CompletePivoting
    | RookPivoting

Type called "QRDecomposition":
    Q as NDArray.NDArray
    R as NDArray.NDArray
    method as QRMethod
    householder_reflectors as Optional[List[NDArray.NDArray]]
    tau as Optional[NDArray.NDArray]
    rank as Integer
    metadata as Dictionary[String, Any]

Type QRMethod is:
    | GramSchmidt
    | ModifiedGramSchmidt
    | Householder
    | Givens

Type called "SVDDecomposition":
    U as NDArray.NDArray
    S as NDArray.NDArray
    Vt as NDArray.NDArray
    rank as Integer
    truncation_threshold as Float
    effective_rank as Integer
    condition_number as Float
    metadata as Dictionary[String, Any]

Type called "EigenDecomposition":
    eigenvalues as NDArray.NDArray
    eigenvectors as NDArray.NDArray
    is_symmetric as Boolean
    is_positive_definite as Boolean
    spectral_radius as Float
    condition_number as Float
    metadata as Dictionary[String, Any]

Type called "SchurDecomposition":
