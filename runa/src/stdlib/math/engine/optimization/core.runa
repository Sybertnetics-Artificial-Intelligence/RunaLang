    mutation_factor as Float
    crossover_probability as Float
    tolerance_diversity as Float
    selection_pressure as Float
    metadata as Dictionary[String, Any]

Process called "backtracking_line_search" that takes func as Function[NDArray.NDArray, Float] and x as NDArray.NDArray and direction as NDArray.NDArray and grad as NDArray.NDArray and f_current as Float returns LineSearchResult:
    Let c1 be 1e-4
    Let rho be 0.5
    Let alpha be 1.0
    Let max_iter be 50
    Let n_iter be 0 Let grad_dot_dir be vector_dot_product with a as grad and b as direction While n_iter is less than max_iter:
    Let x_new be vector_add with a as x and b as vector_scale with vector as direction and scalar as alpha
    Let f_new be func with x_new Note: Armijo condition
    Let armijo_rhs be f_current c1 multiplied by alpha multiplied by grad_dot_dir
    If f_new is less than or equal to armijo_rhs:
    Return LineSearchResult with:
    step_size as alpha
    function_value as f_new
    gradient_dot_direction as grad_dot_dir
    n_function_evaluations as n_iter 1
    success as true
    termination_condition as "Armijo satisfied"
    metadata as dictionary containing Set alpha to alpha multiplied by rho
    Set n_iter to n_iter 1 Return LineSearchResult with:
    step_size as alpha
    function_value as f_current
    gradient_dot_direction as grad_dot_dir
    n_function_evaluations as n_iter
    success as false
    termination_condition as "Maximum iterations exceeded"
    metadata as dictionary containing

Process called "compute_finite_difference_gradient" that takes func as Function[NDArray.NDArray, Float] and x as NDArray.NDArray returns NDArray.NDArray:
    Let h be 1e-8
    Let n_vars be x.size
    Let gradient be NDArray.zeros with shape as list containing n_vars
    Let f_x be func with x For i from 0 to n_vars - 1:
    Let x_plus_h be NDArray.copy_array with arr as x
    Set x_plus_h.data at index i to x_plus_h.data at index i h
    Let f_plus_h be func with x_plus_h Let derivative be (f_plus_h - f_x) divided by h
    Set gradient.data at index i to derivative Return gradient

Note: Vector and matrix operations
Process called "vector_add" that takes a as NDArray.NDArray and b as NDArray.NDArray returns NDArray.NDArray:
    Return NDArray.add with a as a and b as b

Process called "vector_subtract" that takes a as NDArray.NDArray and b as NDArray.NDArray returns NDArray.NDArray:
    Let result be NDArray.zeros with shape as list containing a.size
    For i from 0 to a.size - 1:
    Set result.data at index i to a.data at index i - b.data at index i
    Return result

Process called "vector_scale" that takes vector as NDArray.NDArray and scalar as Float returns NDArray.NDArray:
    Let result be NDArray.zeros with shape as list containing vector.size
    For i from 0 to vector.size - 1:
    Set result.data at index i to vector.data at index i multiplied by scalar
    Return result

Process called "negate_vector" that takes vector as NDArray.NDArray returns NDArray.NDArray:
    Return vector_scale with vector as vector and scalar as -1.0

Process called "vector_dot_product" that takes a as NDArray.NDArray and b as NDArray.NDArray returns Float:
    Let result be 0.0
    For i from 0 to a.size - 1:
    Set result to result a.data at index i multiplied by b.data at index i
    Return result

Process called "calculate_vector_norm" that takes vector as NDArray.NDArray returns Float:
    Let sum_squares be 0.0
    For i from 0 to vector.size - 1:
    Let val be Float.from with value as vector.data at index i
    Set sum_squares to sum_squares val multiplied by val
    Return Math.sqrt with x as sum_squares

Process called "create_identity_matrix" that takes size as Integer returns NDArray.NDArray:
    Let matrix be NDArray.zeros with shape as list containing size, size
    For i from 0 to size - 1:
    Set matrix.data at index (i multiplied by size i) to 1.0
    Return matrix

Process called "matrix_vector_multiply" that takes matrix as NDArray.NDArray and vector as NDArray.NDArray returns NDArray.NDArray:
    Let n_rows be matrix.shape at index 0
    Let n_cols be matrix.shape at index 1
    Let result be NDArray.zeros with shape as list containing n_rows For i from 0 to n_rows - 1:
    Let sum be 0.0
    For j from 0 to n_cols - 1:
    Let matrix_val be Float.from with value as matrix.data at index (i multiplied by n_cols j)
    Let vector_val be Float.from with value as vector.data at index j
    Set sum to sum matrix_val multiplied by vector_val
    Set result.data at index i to sum Return result

Note: BFGS update
Process called "update_bfgs_hessian" that takes hessian_inv as NDArray.NDArray and s as NDArray.NDArray and y as NDArray.NDArray:
    Let s_dot_y be vector_dot_product with a as s and b as y
    If Math.abs with x as s_dot_y is less than 1e-10:
    Return Let n be s.size
    Let rho be 1.0 divided by s_dot_y Note: Simplified BFGS update (should use proper matrix operations)
    For i from 0 to n - 1:
    For j from 0 to n - 1:
    Let h_ij be Float.from with value as hessian_inv.data at index (i multiplied by n j)
    Let correction be rho multiplied by s.data at index i multiplied by s.data at index j
    Set hessian_inv.data at index (i multiplied by n j) to h_ij correction

Note: Result constructors
Process called "create_success_result" that takes x as NDArray.NDArray and fun as Float and iterations as Integer and func_evals as Integer and grad_evals as Integer and grad_norm as Float and time as Float returns OptimizationResult:
    Return OptimizationResult with:
    x as x
    fun as fun
    success as true
    message as "Optimization terminated successfully"
    n_iterations as iterations
    n_function_evaluations as func_evals
    n_gradient_evaluations as grad_evals
    n_hessian_evaluations as 0
    final_gradient_norm as grad_norm
    step_size as 0.0
