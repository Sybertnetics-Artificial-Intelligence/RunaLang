Note:
Runa Scientific Computing: Optimization Core

Comprehensive optimization algorithms surpassing SciPy.optimize with
advanced solvers, global optimization, constraint handling, and AI-optimized methods.
Production-ready implementations for scientific computing and machine learning.

Features:
- Unconstrained optimization (BFGS, L-BFGS-B, CG, Newton methods)
- Constrained optimization (SQP, Interior Point, Trust Region)
- Global optimization (Differential Evolution, Genetic Algorithms, Simulated Annealing)
- Multi-objective optimization (NSGA-II, MOEA/D, SPEA2)
- Linear programming (Simplex, Interior Point)
- Nonlinear programming with constraints
- Root finding (Newton-Raphson, Secant, Brent's method)
- Least squares fitting (Levenberg-Marquardt)
- Bayesian optimization for hyperparameter tuning
- Robust optimization under uncertainty
:End Note

Import "scientific/core/ndarray" as NDArray
Import "../../collections" as Collections
Import "math/core" as Math
Import "../../datetime" as DateTime

Note: Core optimization types
Type called "OptimizationResult":
    x as NDArray.NDArray
    fun as Float
    success as Boolean
    message as String
    n_iterations as Integer
    n_function_evaluations as Integer
    n_gradient_evaluations as Integer
    n_hessian_evaluations as Integer
    final_gradient_norm as Float
    step_size as Float
    convergence_criteria as ConvergenceCriteria
    optimization_time as Float
    metadata as Dictionary[String, Any]

Type called "ConvergenceCriteria":
    tolerance_fun as Float
    tolerance_grad as Float
    tolerance_x as Float
    max_iterations as Integer
    max_function_evaluations as Integer
    check_gradient as Boolean
    check_step_size as Boolean
    metadata as Dictionary[String, Any]

Type called "ObjectiveFunction":
    function as Function[NDArray.NDArray, Float]
    gradient as Optional[Function[NDArray.NDArray, NDArray.NDArray]]
    hessian as Optional[Function[NDArray.NDArray, NDArray.NDArray]]
    bounds as Optional[List[Tuple[Float, Float]]]
    constraints as List[ConstraintFunction]
    metadata as Dictionary[String, Any]

Type called "ConstraintFunction":
    function as Function[NDArray.NDArray, Float]
    gradient as Optional[Function[NDArray.NDArray, NDArray.NDArray]]
    constraint_type as ConstraintType
    tolerance as Float
    active as Boolean
    metadata as Dictionary[String, Any]

Type ConstraintType is:
    | Equality
    | Inequality
    | BoundConstraint

Type called "LineSearchResult":
    step_size as Float
    function_value as Float
    gradient_dot_direction as Float
    n_function_evaluations as Integer
    success as Boolean
    termination_condition as String
    metadata as Dictionary[String, Any]

Type called "TrustRegionResult":
    step as NDArray.NDArray
    radius as Float
    predicted_reduction as Float
    actual_reduction as Float
    ratio as Float
    accept_step as Boolean
    update_radius as Boolean
    metadata as Dictionary[String, Any]

Note: Unconstrained optimization methods
Process called "minimize_bfgs" that takes objective as ObjectiveFunction and x0 as NDArray.NDArray and options as Optional[OptimizationOptions] returns OptimizationResult:
    Let opts be options or create_default_options()
    Let x_current be NDArray.copy_array with arr as x0
    Let n_vars be x_current.size
    Note: Initialize BFGS approximation to identity
    Let hessian_inv be create_identity_matrix with size as n_vars
    Let f_current be objective.function with x_current
    Let grad_current be if objective.gradient is not None then objective.gradient with x_current otherwise compute_finite_difference_gradient with func as objective.function and x as x_current
    Let n_iter be 0
    Let n_func_evals be 1
    Let n_grad_evals be 1
    Let start_time be DateTime.now().timestamp
    While n_iter < opts.max_iterations:
        Note: Check convergence criteria
        Let grad_norm be calculate_vector_norm with vector as grad_current
        If grad_norm < opts.tolerance_grad:
            Let end_time be DateTime.now().timestamp
            Return create_success_result with x as x_current and fun as f_current and iterations as n_iter and func_evals as n_func_evals and grad_evals as n_grad_evals and grad_norm as grad_norm and time as (end_time - start_time)
        Note: Compute search direction
        Let search_direction be matrix_vector_multiply with matrix as hessian_inv and vector as negate_vector with vector as grad_current
        Note: Perform line search
        Let line_search be backtracking_line_search with func as objective.function and x as x_current and direction as search_direction and grad as grad_current and f_current as f_current
        Set n_func_evals to n_func_evals + line_search.n_function_evaluations
        If not line_search.success:
            Let end_time be DateTime.now().timestamp
            Return create_failure_result with x as x_current and fun as f_current and message as "Line search failed" and iterations as n_iter and func_evals as n_func_evals and time as (end_time - start_time)
        Note: Update position
        Let x_new be vector_add with a as x_current and b as vector_scale with vector as search_direction and scalar as line_search.step_size
        Let f_new be line_search.function_value
        Let grad_new be if objective.gradient is not None then objective.gradient with x_new otherwise compute_finite_difference_gradient with func as objective.function and x as x_new
        Set n_grad_evals to n_grad_evals + 1
        Note: BFGS update
        Let s_k be vector_subtract with a as x_new and b as x_current
        Let y_k be vector_subtract with a as grad_new and b as grad_current
        Call update_bfgs_hessian with hessian_inv as hessian_inv and s as s_k and y as y_k
        Note: Update for next iteration
        Set x_current to x_new
        Set f_current to f_new
        Set grad_current to grad_new
        Set n_iter to n_iter + 1
    Let end_time be DateTime.now().timestamp
    Return create_failure_result with x as x_current and fun as f_current and message as "Maximum iterations exceeded" and iterations as n_iter and func_evals as n_func_evals and time as (end_time - start_time)

Process called "minimize_nelder_mead" that takes objective as ObjectiveFunction and x0 as NDArray.NDArray and options as Optional[OptimizationOptions] returns OptimizationResult:
    Let opts be options or create_default_options()
    Let n_vars be x0.size
    Note: Create initial simplex
    Let simplex be create_initial_simplex with x0 as x0
    Let function_values be evaluate_simplex with simplex as simplex and func as objective.function
    Let n_func_evals be n_vars + 1
    Let n_iter be 0
    Let start_time be DateTime.now().timestamp
    While n_iter < opts.max_iterations:
        Note: Sort simplex by function values
        Call sort_simplex with simplex as simplex and values as function_values
        Note: Check convergence
        Let f_best be function_values at index 0
        Let f_worst be function_values at index n_vars
        If Math.abs with x as (f_worst - f_best) < opts.tolerance_fun:
            Let end_time be DateTime.now().timestamp
            Return create_success_result with x as simplex at index 0 and fun as f_best and iterations as n_iter and func_evals as n_func_evals and grad_evals as 0 and grad_norm as 0.0 and time as (end_time - start_time)
        Note: Compute centroid of best n points
        Let centroid be compute_simplex_centroid with simplex as simplex and n_points as n_vars
        Note: Reflection
        Let x_reflected be reflect_point with point as simplex at index n_vars and centroid as centroid and alpha as 1.0
        Let f_reflected be objective.function with x_reflected
        Set n_func_evals to n_func_evals + 1
        Let f_second_worst be function_values at index (n_vars - 1)
        If f_reflected < function_values at index 0:
            Note: Expansion
            Let x_expanded be reflect_point with point as simplex at index n_vars and centroid as centroid and alpha as 2.0
            Let f_expanded be objective.function with x_expanded
            Set n_func_evals to n_func_evals + 1
            If f_expanded < f_reflected:
                Set simplex at index n_vars to x_expanded
                Set function_values at index n_vars to f_expanded
            Otherwise:
                Set simplex at index n_vars to x_reflected
                Set function_values at index n_vars to f_reflected
        Otherwise If f_reflected >= f_second_worst:
            Note: Contraction
            Let use_outside be f_reflected < function_values at index n_vars
            Let contract_point be if use_outside then x_reflected otherwise simplex at index n_vars
            Let x_contracted be vector_add with a as centroid and b as vector_scale with vector as vector_subtract with a as contract_point and b as centroid and scalar as 0.5
            Let f_contracted be objective.function with x_contracted
            Set n_func_evals to n_func_evals + 1
            Let compare_value be if use_outside then f_reflected otherwise function_values at index n_vars
            If f_contracted < compare_value:
                Set simplex at index n_vars to x_contracted
                Set function_values at index n_vars to f_contracted
            Otherwise:
                Note: Shrink simplex
                Call shrink_simplex with simplex as simplex and values as function_values and func as objective.function
                Set n_func_evals to n_func_evals + n_vars
        Otherwise:
            Set simplex at index n_vars to x_reflected
            Set function_values at index n_vars to f_reflected
        Set n_iter to n_iter + 1
    Let end_time be DateTime.now().timestamp
    Let best_x be simplex at index 0
    Let best_f be function_values at index 0
    Return create_failure_result with x as best_x and fun as best_f and message as "Maximum iterations exceeded" and iterations as n_iter and func_evals as n_func_evals and time as (end_time - start_time)

Note: Constrained optimization
Process called "minimize_constrained_sqp" that takes objective as ObjectiveFunction and x0 as NDArray.NDArray and constraints as List[ConstraintFunction] and options as Optional[OptimizationOptions] returns OptimizationResult:
    Let opts be options or create_default_options()
    Let x_current be NDArray.copy_array with arr as x0
    Let n_vars be x_current.size
    Let n_constraints be Collections.List.length with lst as constraints
    Let lagrange_multipliers be NDArray.zeros with shape as list containing n_constraints
    Let penalty_parameter be 1.0
    Let n_iter be 0
    Let n_func_evals be 0
    Let n_grad_evals be 0
    Let start_time be DateTime.now().timestamp
    While n_iter < opts.max_iterations:
        Note: Evaluate objective and constraints
        Let f_current be objective.function with x_current
        Let grad_f be if objective.gradient is not None then objective.gradient with x_current otherwise compute_finite_difference_gradient with func as objective.function and x as x_current
        Set n_func_evals to n_func_evals + 1
        Set n_grad_evals to n_grad_evals + 1
        Let constraint_values be evaluate_constraints with constraints as constraints and x as x_current
        Let constraint_gradients be evaluate_constraint_gradients with constraints as constraints and x as x_current
        Set n_func_evals to n_func_evals + n_constraints
        Set n_grad_evals to n_grad_evals + n_constraints
        Note: Check KKT conditions
        Let kkt_residual be compute_kkt_residual with grad_f as grad_f and constraint_gradients as constraint_gradients and multipliers as lagrange_multipliers
        Let kkt_norm be calculate_vector_norm with vector as kkt_residual
        Let constraint_violation be calculate_constraint_violation with values as constraint_values
        If kkt_norm < opts.tolerance_grad and constraint_violation < opts.tolerance_fun:
            Let end_time be DateTime.now().timestamp
            Return create_success_result with x as x_current and fun as f_current and iterations as n_iter and func_evals as n_func_evals and grad_evals as n_grad_evals and grad_norm as kkt_norm and time as (end_time - start_time)
        Note: Solve QP subproblem
        Let hessian_approx be approximate_hessian_bfgs with x as x_current and n as n_vars
        Let qp_solution be solve_quadratic_subproblem with hessian as hessian_approx and grad as grad_f and constraints as constraint_gradients and constraint_values as constraint_values
        Note: Line search on merit function
        Let merit_func be create_merit_function with objective as objective and constraints as constraints and penalty as penalty_parameter
        Let line_search be backtracking_line_search with func as merit_func and x as x_current and direction as qp_solution.direction and grad as grad_f and f_current as f_current
        Set n_func_evals to n_func_evals + line_search.n_function_evaluations
        If not line_search.success:
            Set penalty_parameter to penalty_parameter * 2.0
            Continue
        Note: Update variables and multipliers
        Set x_current to vector_add with a as x_current and b as vector_scale with vector as qp_solution.direction and scalar as line_search.step_size
        Set lagrange_multipliers to qp_solution.multipliers
        Set n_iter to n_iter + 1
    Let end_time be DateTime.now().timestamp
    Return create_failure_result with x as x_current and fun as f_current and message as "Maximum iterations exceeded" and iterations as n_iter and func_evals as n_func_evals and time as (end_time - start_time)

Note: Global optimization
Process called "minimize_differential_evolution" that takes objective as ObjectiveFunction and bounds as List[Tuple[Float, Float]] and options as Optional[GlobalOptimizationOptions] returns OptimizationResult:
    Let opts be options or create_default_global_options()
    Let n_vars be Collections.List.length with lst as bounds
    Let pop_size be opts.population_size
    Note: Initialize population
    Let population be initialize_random_population with bounds as bounds and size as pop_size
    Let fitness be evaluate_population with population as population and func as objective.function
    Let n_func_evals be pop_size
    Let best_individual be get_best_individual with population as population and fitness as fitness
    Let best_fitness be get_best_fitness with fitness as fitness
    Let generation be 0
    Let start_time be DateTime.now().timestamp
    While generation < opts.max_generations:
        Let new_population be list containing
        Let new_fitness be list containing
        For i from 0 to pop_size - 1:
            Note: Mutation and crossover
            Let target be population at index i
            Let mutant be create_mutant_vector with population as population and target_index as i and F as opts.mutation_factor
            Let trial be crossover_vectors with target as target and mutant as mutant and CR as opts.crossover_probability
            Note: Apply bounds
            Let bounded_trial be apply_bounds_to_vector with vector as trial and bounds as bounds
            Note: Selection
            Let trial_fitness be objective.function with bounded_trial
            Set n_func_evals to n_func_evals + 1
            If trial_fitness < fitness at index i:
                Add bounded_trial to new_population
                Add trial_fitness to new_fitness
                If trial_fitness < best_fitness:
                    Set best_individual to bounded_trial
                    Set best_fitness to trial_fitness
            Otherwise:
                Add population at index i to new_population
                Add fitness at index i to new_fitness
        Set population to new_population
        Set fitness to new_fitness
        Set generation to generation + 1
        Note: Check convergence
        If generation % 10 equals 0:
            Let diversity be calculate_population_diversity with population as population
            If diversity < opts.tolerance_diversity:
                Break
    Let end_time be DateTime.now().timestamp
    Return create_success_result with x as best_individual and fun as best_fitness and iterations as generation and func_evals as n_func_evals and grad_evals as 0 and grad_norm as 0.0 and time as (end_time - start_time)

Note: Root finding
Process called "find_root_brent" that takes func as Function[Float, Float] and a as Float and b as Float and tolerance as Optional[Float] returns RootResult:
    Let tol be tolerance or 1e-8
    Let fa be func with a
    Let fb be func with b
    If fa * fb > 0.0:
        Return create_root_failure with message as "Root not bracketed"
    If Math.abs with x as fa < Math.abs with x as fb:
        Let temp_a be a
        Set a to b
        Set b to temp_a
        Let temp_fa be fa
        Set fa to fb
        Set fb to temp_fa
    Let c be a
    Let fc be fa
    Let s be b
    Let fs be fb
    Let mflag be true
    Let n_iter be 0
    Let max_iter be 100
    While Math.abs with x as (b - a) > tol and n_iter < max_iter:
        If fc != fa and fc != fb:
            Note: Inverse quadratic interpolation
            Set s to a * fb * fc / ((fa - fb) * (fa - fc)) + b * fa * fc / ((fb - fa) * (fb - fc)) + c * fa * fb / ((fc - fa) * (fc - fb))
        Otherwise:
            Note: Secant method
            Set s to b - fb * (b - a) / (fb - fa)
        Note: Check conditions for bisection
        Let condition1 be (s < (3.0 * a + b) / 4.0 or s > b)
        Let condition2 be (mflag and Math.abs with x as (s - b) >= Math.abs with x as (b - c) / 2.0)
        Let condition3 be (not mflag and Math.abs with x as (s - b) >= Math.abs with x as (c - a) / 2.0)
        If condition1 or condition2 or condition3:
            Set s to (a + b) / 2.0
            Set mflag to true
        Otherwise:
            Set mflag to false
        Set fs to func with s
        Set c to b
        Set fc to fb
        If fa * fs < 0.0:
            Set b to s
            Set fb to fs
        Otherwise:
            Set a to s
            Set fa to fs
        If Math.abs with x as fa < Math.abs with x as fb:
            Let temp_a be a
            Set a to b
            Set b to temp_a
            Let temp_fa be fa
            Set fa to fb
            Set fb to temp_fa
        Set n_iter to n_iter + 1
    Return create_root_success with root as b and function_value as fb and iterations as n_iter

Note: Least squares optimization
Process called "minimize_levenberg_marquardt" that takes residual_func as Function[NDArray.NDArray, NDArray.NDArray] and jacobian_func as Function[NDArray.NDArray, NDArray.NDArray] and x0 as NDArray.NDArray and options as Optional[OptimizationOptions] returns OptimizationResult:
    Let opts be options or create_default_options()
    Let x_current be NDArray.copy_array with arr as x0
    Let lambda_lm be 0.01
    Let lambda_up be 10.0
    Let lambda_down be 0.1
    Let residuals be residual_func with x_current
    Let jacobian be jacobian_func with x_current
    Let f_current be calculate_sum_of_squares with residuals as residuals
    Let n_iter be 0
    Let n_func_evals be 1
    Let n_jac_evals be 1
    Let start_time be DateTime.now().timestamp
    While n_iter < opts.max_iterations:
        Note: Compute gradient and approximate Hessian
        Let gradient be compute_least_squares_gradient with jacobian as jacobian and residuals as residuals
        Let hessian_approx be compute_gauss_newton_hessian with jacobian as jacobian
        Note: Check convergence
        Let grad_norm be calculate_vector_norm with vector as gradient
        If grad_norm < opts.tolerance_grad:
            Let end_time be DateTime.now().timestamp
            Return create_success_result with x as x_current and fun as f_current and iterations as n_iter and func_evals as n_func_evals and grad_evals as n_jac_evals and grad_norm as grad_norm and time as (end_time - start_time)
        Note: Solve Levenberg-Marquardt system
        Let augmented_hessian be add_diagonal_damping with matrix as hessian_approx and damping as lambda_lm
        Let step be solve_linear_system with A as augmented_hessian and b as negate_vector with vector as gradient
        Note: Trial step
        Let x_trial be vector_add with a as x_current and b as step
        Let residuals_trial be residual_func with x_trial
        Let f_trial be calculate_sum_of_squares with residuals as residuals_trial
        Set n_func_evals to n_func_evals + 1
        Note: Compute gain ratio
        Let predicted_reduction be compute_predicted_reduction with gradient as gradient and hessian as hessian_approx and step as step
        Let actual_reduction be f_current - f_trial
        Let gain_ratio be if predicted_reduction > 0.0 then actual_reduction / predicted_reduction otherwise -1.0
        If gain_ratio > 0.25:
            Set x_current to x_trial
            Set residuals to residuals_trial
            Set f_current to f_trial
            Set jacobian to jacobian_func with x_current
            Set n_jac_evals to n_jac_evals + 1
        If gain_ratio > 0.75:
            Set lambda_lm to lambda_lm * lambda_down
        Otherwise:
            Set lambda_lm to lambda_lm * lambda_up
        Set n_iter to n_iter + 1
    Let end_time be DateTime.now().timestamp
    Return create_failure_result with x as x_current and fun as f_current and message as "Maximum iterations exceeded" and iterations as n_iter and func_evals as n_func_evals and time as (end_time - start_time)

Note: Utility functions
Process called "create_default_options" returns OptimizationOptions:
    Return OptimizationOptions with:
        tolerance_fun as 1e-8
        tolerance_grad as 1e-6
        tolerance_x as 1e-8
        max_iterations as 1000
        max_function_evaluations as 10000
        line_search_method as "backtracking"
        trust_region_radius as 1.0
        metadata as dictionary containing

Type called "OptimizationOptions":
    tolerance_fun as Float
    tolerance_grad as Float
    tolerance_x as Float
    max_iterations as Integer
    max_function_evaluations as Integer
    line_search_method as String
    trust_region_radius as Float
    metadata as Dictionary[String, Any]

Process called "create_default_global_options" returns GlobalOptimizationOptions:
