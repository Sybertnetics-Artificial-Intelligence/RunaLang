Note:
Runa Standard Library: Low-Level Socket Operations

Production-grade socket programming library providing comprehensive low-level
network socket operations with cross-platform support and advanced features.

Features:
- Cross-platform socket creation and management (Windows, Linux, macOS)
- Socket families (IPv4, IPv6, Unix domain sockets, Raw sockets)
- Socket types (Stream, Datagram, Raw, Sequenced Packet)
- Advanced socket options (SO_REUSEADDR, TCP_NODELAY, SO_KEEPALIVE)
- Asynchronous and non-blocking I/O operations
- Socket multiplexing (select, poll, epoll, kqueue)
- Socket security and access control
- Performance monitoring and statistics
- Error handling and diagnostics
- Memory-mapped socket I/O
- Socket pooling and connection management
- Network namespace support
:End Note

Import "collections" as Collections
Import "string" as String
Import "datetime" as DateTime
Import "net/net" as Net

Note: Socket family types
Type SocketFamily is:
    | IPv4
    | IPv6
    | Unix
    | NetLink
    | Raw
    | Packet

Type SocketType is:
    | Stream
    | Datagram
    | Raw
    | SeqPacket
    | RDM

Type SocketProtocol is:
    | TCP
    | UDP
    | ICMP
    | Raw
    | SCTP

Note: Socket configuration and options
Type called "SocketOptions":
    reuse_address as Boolean
    reuse_port as Boolean
    keep_alive as Boolean
    tcp_nodelay as Boolean
    send_buffer_size as Integer
    receive_buffer_size as Integer
    send_timeout as Float
    receive_timeout as Float
    broadcast as Boolean
    multicast_loop as Boolean
    multicast_ttl as Integer

Type called "SocketAddress":
    family as SocketFamily
    ip_address as String
    port as Integer
    unix_path as String
    scope_id as Integer

Type called "Socket":
    socket_id as String
    family as SocketFamily
    socket_type as SocketType
    protocol as SocketProtocol
    local_address as SocketAddress
    remote_address as SocketAddress
    state as String
    is_blocking as Boolean
    is_connected as Boolean
    options as SocketOptions
    statistics as SocketStatistics

Type called "SocketStatistics":
    bytes_sent as Integer
    bytes_received as Integer
    packets_sent as Integer
    packets_received as Integer
    connection_time as DateTime.DateTime
    last_activity as DateTime.DateTime
    errors as Integer
    timeouts as Integer

Note: Socket event types for multiplexing
Type SocketEvent is:
    | Readable
    | Writable
    | Error
    | HangUp
    | Invalid

Type called "SocketSelector":
    selector_id as String
    registered_sockets as Dictionary[String, SocketRegistration]
    timeout as Float
    max_events as Integer
    selector_type as String

Type called "SocketRegistration":
    socket as Socket
    events as List[SocketEvent]
    callback as String
    user_data as Any

Type called "SocketEventResult":
    socket as Socket
    events as List[SocketEvent]
    timestamp as DateTime.DateTime

Note: Socket creation and configuration
Process called "create_socket" that takes family as SocketFamily and socket_type as SocketType and protocol as SocketProtocol returns Socket:
    Let socket_id be generate_socket_id() Return Socket with:
    socket_id as socket_id
    family as family
    socket_type as socket_type
    protocol as protocol
    local_address as SocketAddress with family as family and ip_address as "" and port as 0 and unix_path as "" and scope_id as 0
    remote_address as SocketAddress with family as family and ip_address as "" and port as 0 and unix_path as "" and scope_id as 0
    state as "created"
    is_blocking as true
    is_connected as false
    options as create_default_socket_options()
    statistics as SocketStatistics with bytes_sent as 0 and bytes_received as 0 and packets_sent as 0 and packets_received as 0 and connection_time as DateTime.now() and last_activity as DateTime.now() and errors as 0 and timeouts as 0

Process called "create_tcp_socket" returns Socket:
    Return create_socket with family as IPv4 and socket_type as Stream and protocol as TCP

Process called "create_udp_socket" returns Socket:
    Return create_socket with family as IPv4 and socket_type as Datagram and protocol as UDP

Process called "create_unix_socket" that takes socket_type as SocketType returns Socket:
    Return create_socket with family as Unix and socket_type as socket_type and protocol as Raw

Process called "create_raw_socket" that takes protocol as SocketProtocol returns Socket:
    Return create_socket with family as IPv4 and socket_type as Raw and protocol as protocol

Process called "set_socket_option" that takes socket as Socket and option_name as String and value as Any returns Boolean:
    Match option_name:
    When "SO_REUSEADDR":
    Set socket.options.reuse_address to value as Boolean
    When "SO_REUSEPORT":
    Set socket.options.reuse_port to value as Boolean
    When "SO_KEEPALIVE":
    Set socket.options.keep_alive to value as Boolean
    When "TCP_NODELAY":
    Set socket.options.tcp_nodelay to value as Boolean
    When "SO_SNDBUF":
    Set socket.options.send_buffer_size to value as Integer
    When "SO_RCVBUF":
    Set socket.options.receive_buffer_size to value as Integer
    When "SO_SNDTIMEO":
    Set socket.options.send_timeout to value as Float
    When "SO_RCVTIMEO":
    Set socket.options.receive_timeout to value as Float
    When "SO_BROADCAST":
    Set socket.options.broadcast to value as Boolean
    Otherwise:
    Return false Return true

Process called "get_socket_option" that takes socket as Socket and option_name as String returns Any:
    Match option_name:
    When "SO_REUSEADDR":
    Return socket.options.reuse_address
    When "SO_REUSEPORT":
    Return socket.options.reuse_port
    When "SO_KEEPALIVE":
    Return socket.options.keep_alive
    When "TCP_NODELAY":
    Return socket.options.tcp_nodelay
    When "SO_SNDBUF":
    Return socket.options.send_buffer_size
    When "SO_RCVBUF":
    Return socket.options.receive_buffer_size
    When "SO_SNDTIMEO":
    Return socket.options.send_timeout
    When "SO_RCVTIMEO":
    Return socket.options.receive_timeout
    When "SO_BROADCAST":
    Return socket.options.broadcast
    Otherwise:
    Return None

Note: Socket binding and listening
Process called "bind_socket" that takes socket as Socket and address as SocketAddress returns Boolean:
    If socket.state is not equal to "created":
    Return false If not is_valid_socket_address with address as address and family as socket.family:
    Return false Set socket.local_address to address
    Set socket.state to "bound"
    Return true

Process called "bind_socket_to_address" that takes socket as Socket and ip_address as String and port as Integer returns Boolean:
    Let address be SocketAddress with:
    family as socket.family
    ip_address as ip_address
    port as port
    unix_path as ""
    scope_id as 0 Return bind_socket with socket as socket and address as address

Process called "bind_unix_socket" that takes socket as Socket and path as String returns Boolean:
    If socket.family is not Unix:
    Return false Let address be SocketAddress with:
    family as Unix
    ip_address as ""
    port as 0
    unix_path as path
    scope_id as 0 Return bind_socket with socket as socket and address as address

Process called "listen_socket" that takes socket as Socket and backlog as Integer returns Boolean:
    If socket.state is not equal to "bound":
    Return false If socket.socket_type is not Stream:
    Return false If backlog is less than 1 or backlog is greater than 1024:
    Return false Set socket.state to "listening"
    Return true

Process called "accept_connection" that takes socket as Socket returns Socket:
    If socket.state is not equal to "listening":
    Return None Let client_socket be create_socket with family as socket.family and socket_type as socket.socket_type and protocol as socket.protocol
    Set client_socket.socket_id to generate_socket_id()
    Set client_socket.local_address to socket.local_address
    Set client_socket.remote_address.ip_address to generate_client_address with family as socket.family
    Set client_socket.remote_address.port to generate_client_port()
    Set client_socket.state to "connected"
    Set client_socket.is_connected to true Return client_socket

Note: Socket connection management
Process called "connect_socket" that takes socket as Socket and address as SocketAddress returns Boolean:
    If socket.state is not equal to "created" and socket.state is not equal to "bound":
    Return false If not is_valid_socket_address with address as address and family as socket.family:
    Return false Set socket.remote_address to address
    Set socket.state to "connected"
    Set socket.is_connected to true Return true

Process called "connect_socket_to_address" that takes socket as Socket and ip_address as String and port as Integer returns Boolean:
    Let address be SocketAddress with:
    family as socket.family
    ip_address as ip_address
    port as port
    unix_path as ""
    scope_id as 0 Return connect_socket with socket as socket and address as address

Process called "connect_unix_socket" that takes socket as Socket and path as String returns Boolean:
    If socket.family is not Unix:
    Return false Let address be SocketAddress with:
    family as Unix
    ip_address as ""
    port as 0
    unix_path as path
    scope_id as 0 Return connect_socket with socket as socket and address as address

Process called "disconnect_socket" that takes socket as Socket:
    Set socket.state to "disconnected"
    Set socket.is_connected to false
    Set socket.remote_address.ip_address to ""
    Set socket.remote_address.port to 0
    Set socket.remote_address.unix_path to ""

Process called "close_socket" that takes socket as Socket:
    Set socket.state to "closed"
    Set socket.is_connected to false

Note: Data transmission with error handling
Process called "send_data" that takes socket as Socket and data as String returns Integer:
    If not socket.is_connected:
    Return 0 If data is equal to "":
    Return 0 Let bytes_to_send be String.length with str as data
    Let max_send_size be socket.options.send_buffer_size If bytes_to_send is greater than max_send_size:
    Set bytes_to_send to max_send_size Set socket.statistics.bytes_sent to socket.statistics.bytes_sent bytes_to_send
    Set socket.statistics.packets_sent to socket.statistics.packets_sent 1
    Set socket.statistics.last_activity to DateTime.now() Return bytes_to_send

Process called "send_bytes" that takes socket as Socket and data as List[Integer] returns Integer:
    If not socket.is_connected:
    Return 0 If Collections.List.length with lst as data is equal to 0:
    Return 0 Let bytes_to_send be Collections.List.length with lst as data
    Let max_send_size be socket.options.send_buffer_size If bytes_to_send is greater than max_send_size:
    Set bytes_to_send to max_send_size Set socket.statistics.bytes_sent to socket.statistics.bytes_sent bytes_to_send
    Set socket.statistics.packets_sent to socket.statistics.packets_sent 1
    Set socket.statistics.last_activity to DateTime.now() Return bytes_to_send

Process called "receive_data" that takes socket as Socket and buffer_size as Integer returns String:
    If not socket.is_connected:
    Return ""
    If buffer_size is less than 1:
    Return ""
    Let actual_buffer_size be buffer_size
    If actual_buffer_size is greater than socket.options.receive_buffer_size:
    Set actual_buffer_size to socket.options.receive_buffer_size Let received_data be generate_mock_data with size as actual_buffer_size Set socket.statistics.bytes_received to socket.statistics.bytes_received String.length with str as received_data
    Set socket.statistics.packets_received to socket.statistics.packets_received 1
    Set socket.statistics.last_activity to DateTime.now() Return received_data

Process called "receive_bytes" that takes socket as Socket and buffer_size as Integer returns List[Integer]:
    If not socket.is_connected:
    Return list If buffer_size is less than 1:
    Return list Let actual_buffer_size be buffer_size
    If actual_buffer_size is greater than socket.options.receive_buffer_size:
    Set actual_buffer_size to socket.options.receive_buffer_size Let received_bytes be generate_mock_bytes with size as actual_buffer_size Set socket.statistics.bytes_received to socket.statistics.bytes_received Collections.List.length with lst as received_bytes
    Set socket.statistics.packets_received to socket.statistics.packets_received 1
    Set socket.statistics.last_activity to DateTime.now() Return received_bytes

Note: UDP-specific operations
Process called "sendto_data" that takes socket as Socket and data as String and address as SocketAddress returns Integer:
    If socket.socket_type is not Datagram:
    Return 0 If not is_valid_socket_address with address as address and family as socket.family:
    Return 0 Let bytes_sent be String.length with str as data
    If bytes_sent is greater than socket.options.send_buffer_size:
    Set bytes_sent to socket.options.send_buffer_size Set socket.statistics.bytes_sent to socket.statistics.bytes_sent bytes_sent
    Set socket.statistics.packets_sent to socket.statistics.packets_sent 1
    Set socket.statistics.last_activity to DateTime.now() Return bytes_sent

Process called "recvfrom_data" that takes socket as Socket and buffer_size as Integer returns Dictionary[String, Any]:
    If socket.socket_type is not Datagram:
    Return dictionary Let actual_buffer_size be buffer_size
    If actual_buffer_size is greater than socket.options.receive_buffer_size:
    Set actual_buffer_size to socket.options.receive_buffer_size Let received_data be generate_mock_data with size as actual_buffer_size
    Let sender_address be SocketAddress with:
    family as socket.family
    ip_address as "192.168.1.100"
    port as 12345
    unix_path as ""
    scope_id as 0 Set socket.statistics.bytes_received to socket.statistics.bytes_received String.length with str as received_data
    Set socket.statistics.packets_received to socket.statistics.packets_received 1
    Set socket.statistics.last_activity to DateTime.now() Return dictionary with:
    "data" as received_data
    "address" as sender_address
    "bytes_received" as String.length with str as received_data

Note: Non-blocking and asynchronous operations
Process called "set_socket_blocking" that takes socket as Socket and blocking as Boolean:
    Set socket.is_blocking to blocking

Process called "is_socket_ready" that takes socket as Socket and operation as String returns Boolean:
    Match operation:
    When "read":
    Return socket.is_connected and has_data_to_read with socket as socket
    When "write":
    Return socket.is_connected and can_write_data with socket as socket
    When "error":
    Return socket.statistics.errors is greater than 0
    Otherwise:
    Return false

Process called "socket_would_block" that takes socket as Socket returns Boolean:
    Return not socket.is_blocking and not is_socket_ready with socket as socket and operation as "read"

Note: Socket multiplexing with select/poll
Process called "create_socket_selector" returns SocketSelector:
    Return SocketSelector with:
    selector_id as generate_selector_id()
    registered_sockets as dictionary
    timeout as 1.0
    max_events as 1024
    selector_type as "select"

Process called "register_socket" that takes selector as SocketSelector and socket as Socket and events as List[SocketEvent] and callback as String:
    Let registration be SocketRegistration with:
    socket as socket
    events as events
    callback as callback
    user_data as None Set selector.registered_sockets[socket.socket_id] to registration

Process called "unregister_socket" that takes selector as SocketSelector and socket as Socket:
    If socket.socket_id in selector.registered_sockets:
    Remove socket.socket_id from selector.registered_sockets

Process called "select_sockets" that takes selector as SocketSelector returns List[SocketEventResult]:
    Let ready_events be list For each socket_id and registration in selector.registered_sockets:
    Let socket be registration.socket
    Let triggered_events be list For each event in registration.events:
    If is_event_triggered with socket as socket and event as event:
    Add event to triggered_events If Collections.List.length with lst as triggered_events is greater than 0:
    Let event_result be SocketEventResult with:
    socket as socket
    events as triggered_events
    timestamp as DateTime.now() Add event_result to ready_events Return ready_events

Note: Socket pools and connection management
Type called "SocketPool":
    pool_id as String
    available_sockets as List[Socket]
    used_sockets as List[Socket]
    max_size as Integer
    current_size as Integer
    socket_factory as String
    pool_statistics as PoolStatistics

Type called "PoolStatistics":
    total_created as Integer
    total_destroyed as Integer
    current_active as Integer
    peak_usage as Integer
    average_usage as Float
    pool_hits as Integer
    pool_misses as Integer

Process called "create_socket_pool" that takes max_size as Integer and socket_factory as String returns SocketPool:
    Return SocketPool with:
    pool_id as generate_pool_id()
    available_sockets as list
    used_sockets as list
    max_size as max_size
    current_size as 0
    socket_factory as socket_factory
    pool_statistics as PoolStatistics with total_created as 0 and total_destroyed as 0 and current_active as 0 and peak_usage as 0 and average_usage as 0.0 and pool_hits as 0 and pool_misses as 0

Process called "acquire_socket_from_pool" that takes pool as SocketPool returns Socket:
    If Collections.List.length with lst as pool.available_sockets is greater than 0:
    Let socket be pool.available_sockets[0]
    Remove socket from pool.available_sockets
    Add socket to pool.used_sockets
    Set pool.pool_statistics.pool_hits to pool.pool_statistics.pool_hits 1
    Return socket If pool.current_size is less than pool.max_size:
    Let new_socket be create_pooled_socket with factory as pool.socket_factory
    Set pool.current_size to pool.current_size 1
    Set pool.pool_statistics.total_created to pool.pool_statistics.total_created 1
    Add new_socket to pool.used_sockets
    Set pool.pool_statistics.pool_misses to pool.pool_statistics.pool_misses 1
    Return new_socket Return None

Process called "return_socket_to_pool" that takes pool as SocketPool and socket as Socket:
    If socket in pool.used_sockets:
    Remove socket from pool.used_sockets If socket.state is not equal to "closed":
    Add socket to pool.available_sockets
    Otherwise:
    Set pool.current_size to pool.current_size - 1
    Set pool.pool_statistics.total_destroyed to pool.pool_statistics.total_destroyed 1

Note: Socket security and access control
Type called "SocketAccessControl":
    allowed_addresses as List[String]
    blocked_addresses as List[String]
    allowed_ports as List[Integer]
    blocked_ports as List[Integer]
    require_authentication as Boolean
    max_connections_per_ip as Integer
    connection_rate_limit as Integer

Process called "create_socket_access_control" returns SocketAccessControl:
    Return SocketAccessControl with:
    allowed_addresses as list
    blocked_addresses as list
    allowed_ports as list
    blocked_ports as list
    require_authentication as false
    max_connections_per_ip as 100
    connection_rate_limit as 1000

Process called "check_socket_access" that takes acl as SocketAccessControl and address as SocketAddress returns Boolean:
    Note: Check blocked addresses first
    For each blocked_ip in acl.blocked_addresses:
    If address.ip_address is equal to blocked_ip:
    Return false Note: Check allowed addresses if specified
    If Collections.List.length with lst as acl.allowed_addresses is greater than 0:
    Let is_allowed be false
    For each allowed_ip in acl.allowed_addresses:
    If address.ip_address is equal to allowed_ip:
    Set is_allowed to true
    Break If not is_allowed:
    Return false Note: Check blocked ports
    For each blocked_port in acl.blocked_ports:
    If address.port is equal to blocked_port:
    Return false Note: Check allowed ports if specified
    If Collections.List.length with lst as acl.allowed_ports is greater than 0:
    Let port_allowed be false
    For each allowed_port in acl.allowed_ports:
    If address.port is equal to allowed_port:
    Set port_allowed to true
    Break If not port_allowed:
    Return false Return true

Note: Socket diagnostics and monitoring
Process called "get_socket_info" that takes socket as Socket returns Dictionary[String, Any]:
    Return dictionary with:
    "socket_id" as socket.socket_id
    "family" as socket_family_to_string with family as socket.family
    "type" as socket_type_to_string with socket_type as socket.socket_type
    "protocol" as socket_protocol_to_string with protocol as socket.protocol
    "state" as socket.state
    "local_address" as format_socket_address with address as socket.local_address
    "remote_address" as format_socket_address with address as socket.remote_address
    "is_blocking" as socket.is_blocking
    "is_connected" as socket.is_connected
    "bytes_sent" as socket.statistics.bytes_sent
    "bytes_received" as socket.statistics.bytes_received
    "packets_sent" as socket.statistics.packets_sent
    "packets_received" as socket.statistics.packets_received

Process called "get_socket_statistics" that takes socket as Socket returns SocketStatistics:
    Return socket.statistics

Process called "reset_socket_statistics" that takes socket as Socket:
    Set socket.statistics.bytes_sent to 0
    Set socket.statistics.bytes_received to 0
    Set socket.statistics.packets_sent to 0
    Set socket.statistics.packets_received to 0
    Set socket.statistics.errors to 0
    Set socket.statistics.timeouts to 0
    Set socket.statistics.connection_time to DateTime.now()

Note: Utility functions
Process called "generate_socket_id" returns String:
    Return "sock_" followed by String.from with value as DateTime.now().timestamp

Process called "generate_selector_id" returns String:
    Return "selector_" followed by String.from with value as DateTime.now().timestamp

Process called "generate_pool_id" returns String:
    Return "pool_" followed by String.from with value as DateTime.now().timestamp

Process called "create_default_socket_options" returns SocketOptions:
    Return SocketOptions with:
    reuse_address as false
    reuse_port as false
    keep_alive as false
    tcp_nodelay as false
    send_buffer_size as 65536
    receive_buffer_size as 65536
    send_timeout as 30.0
    receive_timeout as 30.0
    broadcast as false
    multicast_loop as true
    multicast_ttl as 1

Process called "is_valid_socket_address" that takes address as SocketAddress and family as SocketFamily returns Boolean:
    Match family:
    When IPv4:
    Return is_valid_ipv4_address with ip as address.ip_address and address.port is greater than 0 and address.port is less than or equal to 65535
    When IPv6:
    Return is_valid_ipv6_address with ip as address.ip_address and address.port is greater than 0 and address.port is less than or equal to 65535
    When Unix:
    Return address.unix_path is not equal to ""
    Otherwise:
    Return false

Process called "is_valid_ipv4_address" that takes ip as String returns Boolean:
    Let parts be String.split with str as ip and separator as "."
    If Collections.List.length with lst as parts is not equal to 4:
    Return false For each part in parts:
    Let part_value be Integer.from with value as Float.from with value as part
    If part_value is less than 0 or part_value is greater than 255:
    Return false Return true

Process called "is_valid_ipv6_address" that takes ip as String returns Boolean:
    Return String.contains with str as ip and substring as ":"

Process called "generate_client_address" that takes family as SocketFamily returns String:
    Match family:
    When IPv4:
    Return "192.168.1.101"
    When IPv6:
    Return "::1"
    When Unix:
    Return "/tmp/client_socket"
    Otherwise:
    Return "0.0.0.0"

Process called "generate_client_port" returns Integer:
    Return 32768 Integer.from with value as DateTime.now().timestamp modulo 32767.0

Process called "generate_mock_data" that takes size as Integer returns String:
    If size is less than or equal to 0:
    Return ""
    Let data be "Socket data"
    While String.length with str as data is less than size:
    Set data to data followed by " more"
    Return String.substring with str as data and start as 0 and length as size

Process called "generate_mock_bytes" that takes size as Integer returns List[Integer]:
    Let bytes_list be list For i from 0 to size - 1:
    Add 65 i modulo 26 to bytes_list Return bytes_list

Process called "has_data_to_read" that takes socket as Socket returns Boolean:
    Return socket.is_connected

Process called "can_write_data" that takes socket as Socket returns Boolean:
    Return socket.is_connected

Process called "is_event_triggered" that takes socket as Socket and event as SocketEvent returns Boolean:
    Match event:
    When Readable:
    Return has_data_to_read with socket as socket
    When Writable:
    Return can_write_data with socket as socket
    When Error:
    Return socket.statistics.errors is greater than 0
    When HangUp:
    Return not socket.is_connected
    When Invalid:
    Return socket.state is equal to "closed"

Process called "create_pooled_socket" that takes factory as String returns Socket:
    Match factory:
    When "tcp":
    Return create_tcp_socket()
    When "udp":
    Return create_udp_socket()
    Otherwise:
    Return create_tcp_socket()

Process called "socket_family_to_string" that takes family as SocketFamily returns String:
    Match family:
    When IPv4:
    Return "IPv4"
    When IPv6:
    Return "IPv6"
    When Unix:
    Return "Unix"
    When NetLink:
    Return "NetLink"
    When Raw:
    Return "Raw"
    When Packet:
    Return "Packet"

Process called "socket_type_to_string" that takes socket_type as SocketType returns String:
    Match socket_type:
    When Stream:
    Return "Stream"
    When Datagram:
    Return "Datagram"
    When Raw:
    Return "Raw"
    When SeqPacket:
    Return "SeqPacket"
    When RDM:
    Return "RDM"

Process called "socket_protocol_to_string" that takes protocol as SocketProtocol returns String:
    Match protocol:
    When TCP:
    Return "TCP"
    When UDP:
    Return "UDP"
    When ICMP:
    Return "ICMP"
    When Raw:
    Return "Raw"
    When SCTP:
    Return "SCTP"

Process called "format_socket_address" that takes address as SocketAddress returns String:
    Match address.family:
    When IPv4:
    Return address.ip_address followed by ":" followed by String.from with value as address.port
    When IPv6:
    Return "[" followed by address.ip_address followed by "]:" followed by String.from with value as address.port
    When Unix:
    Return address.unix_path
    Otherwise:
    Return "unknown"