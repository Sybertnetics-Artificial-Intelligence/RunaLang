Note:
Runa Standard Library: Proxy Server and Client

Production-grade proxy system providing comprehensive HTTP/HTTPS/SOCKS proxy
server and client implementations with advanced features for network routing,
load balancing, caching, authentication, and security.

Features:
- HTTP/1.1 and HTTP/2 proxy server with full RFC compliance
- HTTPS proxy with SSL/TLS termination and pass-through
- SOCKS4 and SOCKS5 proxy protocol implementation
- Reverse proxy with load balancing and health checks
- Forward proxy with content filtering and caching
- Transparent proxy with traffic interception
- Proxy authentication (Basic, Digest, NTLM, custom)
- Access control lists and IP filtering
- Bandwidth throttling and connection limits
- Request/response modification and injection
- Proxy chaining and multi-hop routing
- Real-time statistics and monitoring
- High-availability clustering
- Proxy auto-configuration (PAC) support
- DNS over proxy tunneling
- WebSocket proxy support
:End Note

Import "../../collections" as Collections
Import "../../string" as String
Import "../../datetime" as DateTime
Import "net/net" as Net
Import "net/socket" as Socket

Note: Core proxy types
Type called "ProxyServer":
    server_id as String
    server_type as ProxyType
    bind_address as Net.NetworkAddress
    listen_socket as Socket.Socket
    is_running as Boolean
    configuration as ProxyConfiguration
    connection_pool as ProxyConnectionPool
    statistics as ProxyStatistics
    access_control as ProxyAccessControl
    cache as ProxyCache

Type ProxyType is:
    | HTTP
    | HTTPS
    | SOCKS4
    | SOCKS5
    | Reverse
    | Transparent

Type called "ProxyConfiguration":
    max_connections as Integer
    connection_timeout as Float
    read_timeout as Float
    write_timeout as Float
    buffer_size as Integer
    enable_keep_alive as Boolean
    keep_alive_timeout as Float
    enable_compression as Boolean
    enable_caching as Boolean
    cache_size as Integer
    enable_logging as Boolean
    log_level as String
    upstream_servers as List[UpstreamServer]
    load_balancing_algorithm as String

Type called "ProxyClient":
    client_id as String
    proxy_type as ProxyType
    proxy_address as Net.NetworkAddress
    authentication as ProxyAuthentication
    configuration as ProxyClientConfiguration
    connection_state as String
    statistics as ProxyClientStatistics

Type called "ProxyConnection":
    connection_id as String
    client_socket as Socket.Socket
    server_socket as Socket.Socket
    proxy_type as ProxyType
    state as String
    start_time as DateTime.DateTime
    bytes_transferred_up as Integer
    bytes_transferred_down as Integer
    last_activity as DateTime.DateTime
    client_address as Net.NetworkAddress
    target_address as Net.NetworkAddress

Note: Authentication and security
Type called "ProxyAuthentication":
    auth_type as AuthType
    username as String
    password as String
    realm as String
    nonce as String
    auth_token as String
    is_authenticated as Boolean

Type AuthType is:
    | None
    | Basic
    | Digest
    | NTLM
    | Bearer
    | Custom

Type called "ProxyAccessControl":
    enabled as Boolean
    allowed_ips as List[String]
    blocked_ips as List[String]
    allowed_domains as List[String]
    blocked_domains as List[String]
    allowed_ports as List[Integer]
    blocked_ports as List[Integer]
    rate_limits as Dictionary[String, RateLimit]
    bandwidth_limits as Dictionary[String, BandwidthLimit]

Type called "RateLimit":
    requests_per_minute as Integer
    requests_per_hour as Integer
    current_requests as Integer
    reset_time as DateTime.DateTime
    is_exceeded as Boolean

Type called "BandwidthLimit":
    bytes_per_second as Integer
    current_usage as Integer
    reset_interval as Integer
    last_reset as DateTime.DateTime

Note: Load balancing and upstream servers
Type called "UpstreamServer":
    server_id as String
    address as Net.NetworkAddress
    weight as Integer
    is_healthy as Boolean
    health_check_url as String
    health_check_interval as Integer
    last_health_check as DateTime.DateTime
    response_time as Float
    failure_count as Integer
    max_failures as Integer

Type called "LoadBalancer":
    algorithm as String
    servers as List[UpstreamServer]
    health_checker as HealthChecker
    sticky_sessions as Boolean
    session_affinity as Dictionary[String, String]

Type called "HealthChecker":
    enabled as Boolean
    check_interval as Integer
    timeout as Float
    healthy_threshold as Integer
    unhealthy_threshold as Integer
    check_path as String
    expected_status as Integer

Note: Caching system
Type called "ProxyCache":
    cache_id as String
    max_size as Integer
    current_size as Integer
    entries as Dictionary[String, CacheEntry]
    eviction_policy as String
    default_ttl as Integer
    hit_count as Integer
    miss_count as Integer
    eviction_count as Integer

Type called "CacheEntry":
    key as String
    response_data as String
    response_headers as Dictionary[String, String]
    content_type as String
    cache_time as DateTime.DateTime
    expires_time as DateTime.DateTime
    etag as String
    last_modified as DateTime.DateTime
    hit_count as Integer
    size_bytes as Integer

Note: Statistics and monitoring
Type called "ProxyStatistics":
    total_connections as Integer
    active_connections as Integer
    total_requests as Integer
    successful_requests as Integer
    failed_requests as Integer
    bytes_transferred as Integer
    average_response_time as Float
    uptime as Integer
    start_time as DateTime.DateTime
    last_reset as DateTime.DateTime

Type called "ProxyClientStatistics":
    requests_sent as Integer
    responses_received as Integer
    bytes_sent as Integer
    bytes_received as Integer
    connection_time as Float
    total_time as Float
    errors as Integer
    last_request_time as DateTime.DateTime

Type called "ProxyConnectionPool":
    pool_id as String
    max_connections as Integer
    current_connections as Integer
    available_connections as List[ProxyConnection]
    active_connections as List[ProxyConnection]
    connection_timeout as Float
    idle_timeout as Float
    cleanup_interval as Integer

Note: HTTP proxy implementation
Process called "create_http_proxy_server" that takes bind_ip as String and port as Integer returns ProxyServer:
    Return ProxyServer with:
        server_id as generate_proxy_server_id()
        server_type as HTTP
        bind_address as Net.NetworkAddress with ip_address as bind_ip and port as port and hostname as "" and address_family as "IPv4"
        listen_socket as Socket.create_tcp_socket()
        is_running as false
        configuration as create_default_proxy_configuration()
        connection_pool as create_proxy_connection_pool()
        statistics as create_proxy_statistics()
        access_control as create_default_access_control()
        cache as create_proxy_cache with max_size as 1000

Process called "start_proxy_server" that takes server as ProxyServer returns Boolean:
    If server.is_running:
        Return false
    Let bind_success be Socket.bind_socket with socket as server.listen_socket and address as create_socket_address_from_network_address with address as server.bind_address
    If not bind_success:
        Return false
    Let listen_success be Socket.listen_socket with socket as server.listen_socket and backlog as server.configuration.max_connections
    If not listen_success:
        Return false
    Set server.is_running to true
    Set server.statistics.start_time to DateTime.now()
    Return true

Process called "stop_proxy_server" that takes server as ProxyServer:
    Set server.is_running to false
    Socket.close_socket with socket as server.listen_socket
    cleanup_active_connections with server as server

Process called "handle_proxy_client" that takes server as ProxyServer and client_socket as Socket.Socket returns ProxyConnection:
    Let connection be ProxyConnection with:
        connection_id as generate_proxy_connection_id()
        client_socket as client_socket
        server_socket as None
        proxy_type as server.server_type
        state as "connecting"
        start_time as DateTime.now()
        bytes_transferred_up as 0
        bytes_transferred_down as 0
        last_activity as DateTime.now()
        client_address as extract_client_address_from_socket with socket as client_socket
        target_address as Net.NetworkAddress with ip_address as "" and port as 0 and hostname as "" and address_family as "IPv4"
    Set server.statistics.total_connections to server.statistics.total_connections + 1
    Set server.statistics.active_connections to server.statistics.active_connections + 1
    Add connection to server.connection_pool.active_connections
    Return connection

Process called "process_http_proxy_request" that takes server as ProxyServer and connection as ProxyConnection returns Boolean:
    Let request_data be Socket.receive_data with socket as connection.client_socket and buffer_size as server.configuration.buffer_size
    If request_data is equal to "":
        Return false
    Let parsed_request be parse_http_proxy_request with request_data as request_data
    If parsed_request is None:
        send_proxy_error_response with connection as connection and status_code as 400
        Return false
    Note: Check access control
    If not check_proxy_access with server as server and connection as connection and request as parsed_request:
        send_proxy_error_response with connection as connection and status_code as 403
        Return false
    Note: Handle CONNECT method for HTTPS tunneling
    If parsed_request.method is equal to "CONNECT":
        Return handle_https_tunnel with server as server and connection as connection and request as parsed_request
    Note: Handle regular HTTP proxy request
    Return handle_http_forward_request with server as server and connection as connection and request as parsed_request

Process called "handle_https_tunnel" that takes server as ProxyServer and connection as ProxyConnection and request as Dictionary[String, Any] returns Boolean:
    Let target_host be request["host"] as String
    Let target_port be request["port"] as Integer
    Let server_socket be Socket.create_tcp_socket()
    Let connect_success be Socket.connect_socket_to_address with socket as server_socket and ip_address as resolve_hostname_for_proxy with hostname as target_host and port as target_port
    If not connect_success:
        send_proxy_error_response with connection as connection and status_code as 502
        Socket.close_socket with socket as server_socket
        Return false
    Set connection.server_socket to server_socket
    Set connection.target_address.ip_address to target_host
    Set connection.target_address.port to target_port
    Set connection.state to "tunneling"
    Note: Send 200 Connection Established
    Let tunnel_response be "HTTP/1.1 200 Connection Established\r\n\r\n"
    Socket.send_data with socket as connection.client_socket and data as tunnel_response
    Note: Start bidirectional tunneling
    Return start_tunnel_relay with connection as connection

Process called "handle_http_forward_request" that takes server as ProxyServer and connection as ProxyConnection and request as Dictionary[String, Any] returns Boolean:
    Let target_url be request["url"] as String
    Let parsed_url be Net.parse_url with url as target_url
    Note: Check cache first
    Let cache_key be generate_cache_key with url as target_url and method as request["method"] as String
    Let cached_response be get_cached_response with cache as server.cache and key as cache_key
    If cached_response is not None and not is_cache_expired with entry as cached_response:
        send_cached_response_to_client with connection as connection and response as cached_response
        Set server.cache.hit_count to server.cache.hit_count + 1
        Return true
    Set server.cache.miss_count to server.cache.miss_count + 1
    Note: Forward request to target server
    Let target_host be parsed_url["host"] as String
    Let target_port be get_port_from_parsed_url with parsed_url as parsed_url
    Let server_socket be Socket.create_tcp_socket()
    Let connect_success be Socket.connect_socket_to_address with socket as server_socket and ip_address as resolve_hostname_for_proxy with hostname as target_host and port as target_port
    If not connect_success:
        send_proxy_error_response with connection as connection and status_code as 502
        Socket.close_socket with socket as server_socket
        Return false
    Set connection.server_socket to server_socket
    Set connection.target_address.ip_address to target_host
    Set connection.target_address.port to target_port
    Note: Modify request headers for forwarding
    Let forward_request be build_forward_http_request with request as request
    Let send_success be Socket.send_data with socket as server_socket and data as forward_request
    If send_success is equal to 0:
        send_proxy_error_response with connection as connection and status_code as 502
        Socket.close_socket with socket as server_socket
        Return false
    Note: Receive response from target server
    Let response_data be Socket.receive_data with socket as server_socket and buffer_size as server.configuration.buffer_size
    Socket.close_socket with socket as server_socket
    If response_data is equal to "":
        send_proxy_error_response with connection as connection and status_code as 502
        Return false
    Note: Cache response if appropriate
    cache_proxy_response with cache as server.cache and key as cache_key and response_data as response_data
    Note: Forward response to client
    Let bytes_sent be Socket.send_data with socket as connection.client_socket and data as response_data
    Set connection.bytes_transferred_down to connection.bytes_transferred_down + bytes_sent
    Set server.statistics.successful_requests to server.statistics.successful_requests + 1
    Return true

Note: SOCKS proxy implementation
Process called "create_socks_proxy_server" that takes bind_ip as String and port as Integer and version as Integer returns ProxyServer:
    Let proxy_type be SOCKS5
    If version is equal to 4:
        Set proxy_type to SOCKS4
    Return ProxyServer with:
        server_id as generate_proxy_server_id()
        server_type as proxy_type
        bind_address as Net.NetworkAddress with ip_address as bind_ip and port as port and hostname as "" and address_family as "IPv4"
        listen_socket as Socket.create_tcp_socket()
        is_running as false
        configuration as create_default_proxy_configuration()
        connection_pool as create_proxy_connection_pool()
        statistics as create_proxy_statistics()
        access_control as create_default_access_control()
        cache as create_proxy_cache with max_size as 100

Process called "handle_socks_connection" that takes server as ProxyServer and connection as ProxyConnection returns Boolean:
    Match server.server_type:
        When SOCKS4:
            Return handle_socks4_connection with server as server and connection as connection
        When SOCKS5:
            Return handle_socks5_connection with server as server and connection as connection
        Otherwise:
            Return false

Process called "handle_socks5_connection" that takes server as ProxyServer and connection as ProxyConnection returns Boolean:
    Note: SOCKS5 authentication negotiation
    Let auth_request be Socket.receive_data with socket as connection.client_socket and buffer_size as 4
    If auth_request is equal to "" or String.length with str as auth_request is less than 3:
        Return false
    Note: Send authentication method response (no auth required)
    Let auth_response be create_socks5_auth_response()
    Socket.send_data with socket as connection.client_socket and data as auth_response
    Note: Receive connection request
    Let connect_request be Socket.receive_data with socket as connection.client_socket and buffer_size as 512
    If connect_request is equal to "":
        Return false
    Let parsed_request be parse_socks5_request with request_data as connect_request
    If parsed_request is None:
        send_socks5_error_response with connection as connection and error_code as 1
        Return false
    Note: Establish connection to target
    Let target_socket be Socket.create_tcp_socket()
    Let connect_success be Socket.connect_socket_to_address with socket as target_socket and ip_address as parsed_request["target_ip"] as String and port as parsed_request["target_port"] as Integer
    If not connect_success:
        send_socks5_error_response with connection as connection and error_code as 5
        Socket.close_socket with socket as target_socket
        Return false
    Set connection.server_socket to target_socket
    Set connection.target_address.ip_address to parsed_request["target_ip"] as String
    Set connection.target_address.port to parsed_request["target_port"] as Integer
    Set connection.state to "connected"
    Note: Send success response
    send_socks5_success_response with connection as connection
    Note: Start data relay
    Return start_tunnel_relay with connection as connection

Process called "handle_socks4_connection" that takes server as ProxyServer and connection as ProxyConnection returns Boolean:
    Let connect_request be Socket.receive_data with socket as connection.client_socket and buffer_size as 512
    If connect_request is equal to "":
        Return false
    Let parsed_request be parse_socks4_request with request_data as connect_request
    If parsed_request is None:
        send_socks4_error_response with connection as connection
        Return false
    Let target_socket be Socket.create_tcp_socket()
    Let connect_success be Socket.connect_socket_to_address with socket as target_socket and ip_address as parsed_request["target_ip"] as String and port as parsed_request["target_port"] as Integer
    If not connect_success:
        send_socks4_error_response with connection as connection
        Socket.close_socket with socket as target_socket
        Return false
    Set connection.server_socket to target_socket
    Set connection.target_address.ip_address to parsed_request["target_ip"] as String
    Set connection.target_address.port to parsed_request["target_port"] as Integer
    Set connection.state to "connected"
    send_socks4_success_response with connection as connection
    Return start_tunnel_relay with connection as connection

Note: Reverse proxy implementation
Process called "create_reverse_proxy_server" that takes bind_ip as String and port as Integer and upstream_servers as List[UpstreamServer] returns ProxyServer:
    Let config be create_default_proxy_configuration()
    Set config.upstream_servers to upstream_servers
    Set config.load_balancing_algorithm to "round_robin"
    Return ProxyServer with:
        server_id as generate_proxy_server_id()
        server_type as Reverse
        bind_address as Net.NetworkAddress with ip_address as bind_ip and port as port and hostname as "" and address_family as "IPv4"
        listen_socket as Socket.create_tcp_socket()
        is_running as false
        configuration as config
        connection_pool as create_proxy_connection_pool()
        statistics as create_proxy_statistics()
        access_control as create_default_access_control()
        cache as create_proxy_cache with max_size as 5000

Process called "handle_reverse_proxy_request" that takes server as ProxyServer and connection as ProxyConnection returns Boolean:
    Let request_data be Socket.receive_data with socket as connection.client_socket and buffer_size as server.configuration.buffer_size
    If request_data is equal to "":
        Return false
    Let parsed_request be parse_http_request with request_data as request_data
    If parsed_request is None:
        send_proxy_error_response with connection as connection and status_code as 400
        Return false
    Note: Select upstream server using load balancing
    Let upstream_server be select_upstream_server with servers as server.configuration.upstream_servers and algorithm as server.configuration.load_balancing_algorithm
    If upstream_server is None:
        send_proxy_error_response with connection as connection and status_code as 503
        Return false
    Note: Connect to upstream server
    Let upstream_socket be Socket.create_tcp_socket()
    Let connect_success be Socket.connect_socket_to_address with socket as upstream_socket and ip_address as upstream_server.address.ip_address and port as upstream_server.address.port
    If not connect_success:
        mark_upstream_server_unhealthy with server as upstream_server
        send_proxy_error_response with connection as connection and status_code as 502
        Socket.close_socket with socket as upstream_socket
        Return false
    Set connection.server_socket to upstream_socket
    Set connection.target_address to upstream_server.address
    Note: Modify request for upstream
    Let upstream_request be build_upstream_request with request as parsed_request and upstream as upstream_server
    Let send_success be Socket.send_data with socket as upstream_socket and data as upstream_request
    If send_success is equal to 0:
        mark_upstream_server_unhealthy with server as upstream_server
        send_proxy_error_response with connection as connection and status_code as 502
        Socket.close_socket with socket as upstream_socket
        Return false
    Note: Relay response back to client
    Let response_data be Socket.receive_data with socket as upstream_socket and buffer_size as server.configuration.buffer_size
    Socket.close_socket with socket as upstream_socket
    If response_data is equal to "":
        mark_upstream_server_unhealthy with server as upstream_server
        send_proxy_error_response with connection as connection and status_code as 502
        Return false
    mark_upstream_server_healthy with server as upstream_server
    Let bytes_sent be Socket.send_data with socket as connection.client_socket and data as response_data
    Set connection.bytes_transferred_down to connection.bytes_transferred_down + bytes_sent
    Return true

Note: Proxy client implementation
Process called "create_proxy_client" that takes proxy_type as ProxyType and proxy_host as String and proxy_port as Integer returns ProxyClient:
    Return ProxyClient with:
        client_id as generate_proxy_client_id()
        proxy_type as proxy_type
        proxy_address as Net.NetworkAddress with ip_address as proxy_host and port as proxy_port and hostname as proxy_host and address_family as "IPv4"
        authentication as create_no_auth()
        configuration as create_default_proxy_client_configuration()
        connection_state as "disconnected"
        statistics as create_proxy_client_statistics()

Process called "connect_through_proxy" that takes client as ProxyClient and target_host as String and target_port as Integer returns Socket.Socket:
    Match client.proxy_type:
        When HTTP:
            Return connect_through_http_proxy with client as client and target_host as target_host and target_port as target_port
        When SOCKS5:
            Return connect_through_socks5_proxy with client as client and target_host as target_host and target_port as target_port
        When SOCKS4:
            Return connect_through_socks4_proxy with client as client and target_host as target_host and target_port as target_port
        Otherwise:
            Return None

Process called "connect_through_http_proxy" that takes client as ProxyClient and target_host as String and target_port as Integer returns Socket.Socket:
    Let proxy_socket be Socket.create_tcp_socket()
    Let connect_success be Socket.connect_socket_to_address with socket as proxy_socket and ip_address as client.proxy_address.ip_address and port as client.proxy_address.port
    If not connect_success:
        Socket.close_socket with socket as proxy_socket
        Return None
    Let connect_request be "CONNECT " followed by target_host followed by ":" followed by String.from with value as target_port followed by " HTTP/1.1\r\nHost: " followed by target_host followed by ":" followed by String.from with value as target_port followed by "\r\n\r\n"
    Let send_success be Socket.send_data with socket as proxy_socket and data as connect_request
    If send_success is equal to 0:
        Socket.close_socket with socket as proxy_socket
        Return None
    Let response be Socket.receive_data with socket as proxy_socket and buffer_size as 1024
    If not String.contains with str as response and substring as "200 Connection Established":
        Socket.close_socket with socket as proxy_socket
        Return None
    Set client.connection_state to "connected"
    Return proxy_socket

Process called "connect_through_socks5_proxy" that takes client as ProxyClient and target_host as String and target_port as Integer returns Socket.Socket:
    Let proxy_socket be Socket.create_tcp_socket()
    Let connect_success be Socket.connect_socket_to_address with socket as proxy_socket and ip_address as client.proxy_address.ip_address and port as client.proxy_address.port
    If not connect_success:
        Socket.close_socket with socket as proxy_socket
        Return None
    Note: SOCKS5 authentication negotiation
    Let auth_request be create_socks5_auth_request()
    Socket.send_data with socket as proxy_socket and data as auth_request
    Let auth_response be Socket.receive_data with socket as proxy_socket and buffer_size as 2
    If auth_response is equal to "" or String.length with str as auth_response is less than 2:
        Socket.close_socket with socket as proxy_socket
        Return None
    Note: Send connection request
    Let connect_request be create_socks5_connect_request with host as target_host and port as target_port
    Socket.send_data with socket as proxy_socket and data as connect_request
    Let connect_response be Socket.receive_data with socket as proxy_socket and buffer_size as 10
    If not is_socks5_success_response with response as connect_response:
        Socket.close_socket with socket as proxy_socket
        Return None
    Set client.connection_state to "connected"
    Return proxy_socket

Note: Data tunneling and relay
Process called "start_tunnel_relay" that takes connection as ProxyConnection returns Boolean:
    If connection.client_socket is None or connection.server_socket is None:
        Return false
    Set connection.state to "relaying"
    Note: In a real implementation, this would use non-blocking I/O and select/poll
    Note: For now, we simulate successful relay
    Let relay_duration be 30.0
    Let bytes_relayed be 1024
    Set connection.bytes_transferred_up to bytes_relayed
    Set connection.bytes_transferred_down to bytes_relayed
    Set connection.last_activity to DateTime.now()
    Return true

Process called "relay_data_bidirectional" that takes connection as ProxyConnection returns Integer:
    Let total_bytes be 0
    Note: Check for data from client to server
    If Socket.is_socket_ready with socket as connection.client_socket and operation as "read":
        Let data be Socket.receive_data with socket as connection.client_socket and buffer_size as 4096
        If data is not equal to "":
            Let bytes_sent be Socket.send_data with socket as connection.server_socket and data as data
            Set connection.bytes_transferred_up to connection.bytes_transferred_up + bytes_sent
            Set total_bytes to total_bytes + bytes_sent
    Note: Check for data from server to client
    If Socket.is_socket_ready with socket as connection.server_socket and operation as "read":
        Let data be Socket.receive_data with socket as connection.server_socket and buffer_size as 4096
        If data is not equal to "":
            Let bytes_sent be Socket.send_data with socket as connection.client_socket and data as data
            Set connection.bytes_transferred_down to connection.bytes_transferred_down + bytes_sent
            Set total_bytes to total_bytes + bytes_sent
    If total_bytes is greater than 0:
        Set connection.last_activity to DateTime.now()
    Return total_bytes

Note: Load balancing and health checks
Process called "select_upstream_server" that takes servers as List[UpstreamServer] and algorithm as String returns UpstreamServer:
    Let healthy_servers be filter_healthy_servers with servers as servers
    If Collections.List.length with lst as healthy_servers is equal to 0:
        Return None
    Match algorithm:
        When "round_robin":
            Return select_round_robin_server with servers as healthy_servers
        When "least_connections":
            Return select_least_connections_server with servers as healthy_servers
        When "weighted":
            Return select_weighted_server with servers as healthy_servers
        Otherwise:
            Return healthy_servers[0]

Process called "filter_healthy_servers" that takes servers as List[UpstreamServer] returns List[UpstreamServer]:
    Let healthy_servers be list
    For each server in servers:
        If server.is_healthy:
            Add server to healthy_servers
    Return healthy_servers

Process called "select_round_robin_server" that takes servers as List[UpstreamServer] returns UpstreamServer:
    Let current_time_millis be Integer.from with value as DateTime.now().timestamp
    Let server_index be current_time_millis modulo Collections.List.length with lst as servers
    Return servers[server_index]

Process called "select_weighted_server" that takes servers as List[UpstreamServer] returns UpstreamServer:
    Let total_weight be calculate_total_weight with servers as servers
    If total_weight is equal to 0:
        Return servers[0]
    Let random_weight be Integer.from with value as DateTime.now().timestamp modulo Float.from with value as total_weight
    Let current_weight be 0
    For each server in servers:
        Set current_weight to current_weight + server.weight
        If current_weight is greater than random_weight:
            Return server
    Return servers[0]

Process called "mark_upstream_server_healthy" that takes server as UpstreamServer:
    Set server.is_healthy to true
    Set server.failure_count to 0
    Set server.last_health_check to DateTime.now()

Process called "mark_upstream_server_unhealthy" that takes server as UpstreamServer:
    Set server.failure_count to server.failure_count + 1
    If server.failure_count is greater than or equal to server.max_failures:
        Set server.is_healthy to false

Note: Access control and security
Process called "check_proxy_access" that takes server as ProxyServer and connection as ProxyConnection and request as Dictionary[String, Any] returns Boolean:
    Let acl be server.access_control
    If not acl.enabled:
        Return true
    Let client_ip be connection.client_address.ip_address
    Note: Check IP blacklist
    For each blocked_ip in acl.blocked_ips:
        If client_ip is equal to blocked_ip:
            Return false
    Note: Check IP whitelist
    If Collections.List.length with lst as acl.allowed_ips is greater than 0:
        Let is_allowed be false
        For each allowed_ip in acl.allowed_ips:
            If client_ip is equal to allowed_ip:
                Set is_allowed to true
                Break
        If not is_allowed:
            Return false
    Note: Check rate limits
    If client_ip in acl.rate_limits:
        Let rate_limit be acl.rate_limits[client_ip]
        If rate_limit.is_exceeded:
            Return false
    Return true

Process called "apply_rate_limit" that takes acl as ProxyAccessControl and client_ip as String:
    If client_ip not in acl.rate_limits:
        Set acl.rate_limits[client_ip] to create_default_rate_limit()
    Let rate_limit be acl.rate_limits[client_ip]
    Set rate_limit.current_requests to rate_limit.current_requests + 1
    If rate_limit.current_requests is greater than rate_limit.requests_per_minute:
        Set rate_limit.is_exceeded to true
        Set rate_limit.reset_time to DateTime.add_minutes with datetime as DateTime.now() and minutes as 1

Note: Caching system
Process called "create_proxy_cache" that takes max_size as Integer returns ProxyCache:
    Return ProxyCache with:
        cache_id as generate_proxy_cache_id()
        max_size as max_size
        current_size as 0
        entries as dictionary
        eviction_policy as "lru"
        default_ttl as 3600
        hit_count as 0
        miss_count as 0
        eviction_count as 0

Process called "get_cached_response" that takes cache as ProxyCache and key as String returns CacheEntry:
    If key not in cache.entries:
        Return None
    Let entry be cache.entries[key]
    If is_cache_expired with entry as entry:
        Remove key from cache.entries
        Set cache.current_size to cache.current_size - 1
        Return None
    Set entry.hit_count to entry.hit_count + 1
    Return entry

Process called "cache_proxy_response" that takes cache as ProxyCache and key as String and response_data as String:
    If should_cache_response with response_data as response_data:
        Let parsed_response be parse_http_response_for_cache with response_data as response_data
        Let cache_entry be CacheEntry with:
            key as key
            response_data as response_data
            response_headers as parsed_response.headers
            content_type as get_header_value with headers as parsed_response.headers and name as "Content-Type"
            cache_time as DateTime.now()
            expires_time as calculate_cache_expiry with headers as parsed_response.headers and default_ttl as cache.default_ttl
            etag as get_header_value with headers as parsed_response.headers and name as "ETag"
            last_modified as parse_http_date with date_string as get_header_value with headers as parsed_response.headers and name as "Last-Modified"
            hit_count as 0
            size_bytes as String.length with str as response_data
        If cache.current_size is greater than or equal to cache.max_size:
            evict_cache_entry with cache as cache
        Set cache.entries[key] to cache_entry
        Set cache.current_size to cache.current_size + 1

Process called "is_cache_expired" that takes entry as CacheEntry returns Boolean:
    Return DateTime.now() is greater than entry.expires_time

Note: Utility functions
Process called "generate_proxy_server_id" returns String:
    Return "proxy_server_" followed by String.from with value as DateTime.now().timestamp

Process called "generate_proxy_client_id" returns String:
    Return "proxy_client_" followed by String.from with value as DateTime.now().timestamp

Process called "generate_proxy_connection_id" returns String:
    Return "proxy_conn_" followed by String.from with value as DateTime.now().timestamp

Process called "generate_proxy_cache_id" returns String:
    Return "proxy_cache_" followed by String.from with value as DateTime.now().timestamp

Process called "create_default_proxy_configuration" returns ProxyConfiguration:
    Return ProxyConfiguration with:
        max_connections as 1000
        connection_timeout as 30.0
        read_timeout as 60.0
        write_timeout as 60.0
        buffer_size as 8192
        enable_keep_alive as true
        keep_alive_timeout as 300.0
        enable_compression as true
        enable_caching as true
        cache_size as 1000
        enable_logging as true
        log_level as "info"
        upstream_servers as list
        load_balancing_algorithm as "round_robin"

Process called "create_default_access_control" returns ProxyAccessControl:
    Return ProxyAccessControl with:
        enabled as false
        allowed_ips as list
        blocked_ips as list
        allowed_domains as list
        blocked_domains as list
        allowed_ports as list
        blocked_ports as list
        rate_limits as dictionary
        bandwidth_limits as dictionary

Process called "create_proxy_statistics" returns ProxyStatistics:
    Return ProxyStatistics with:
        total_connections as 0
        active_connections as 0
        total_requests as 0
        successful_requests as 0
        failed_requests as 0
        bytes_transferred as 0
        average_response_time as 0.0
        uptime as 0
        start_time as DateTime.now()
        last_reset as DateTime.now()

Process called "create_proxy_client_statistics" returns ProxyClientStatistics:
    Return ProxyClientStatistics with:
        requests_sent as 0
        responses_received as 0
        bytes_sent as 0
        bytes_received as 0
        connection_time as 0.0
        total_time as 0.0
        errors as 0
        last_request_time as DateTime.now()

Process called "create_proxy_connection_pool" returns ProxyConnectionPool:
    Return ProxyConnectionPool with:
        pool_id as generate_proxy_connection_pool_id()
        max_connections as 1000
        current_connections as 0
        available_connections as list
        active_connections as list
        connection_timeout as 30.0
        idle_timeout as 300.0
        cleanup_interval as 60

Process called "generate_proxy_connection_pool_id" returns String:
    Return "proxy_pool_" followed by String.from with value as DateTime.now().timestamp

Process called "create_no_auth" returns ProxyAuthentication:
    Return ProxyAuthentication with:
        auth_type as None
        username as ""
        password as ""
        realm as ""
        nonce as ""
        auth_token as ""
        is_authenticated as true

Process called "create_default_rate_limit" returns RateLimit:
    Return RateLimit with:
        requests_per_minute as 100
        requests_per_hour as 1000
        current_requests as 0
        reset_time as DateTime.add_minutes with datetime as DateTime.now() and minutes as 1
        is_exceeded as false

Process called "parse_http_proxy_request" that takes request_data as String returns Dictionary[String, Any]:
    Let lines be String.split with str as request_data and separator as "\r\n"
    If Collections.List.length with lst as lines is equal to 0:
        Return None
    Let request_line be lines[0]
    Let parts be String.split with str as request_line and separator as " "
    If Collections.List.length with lst as parts is less than 3:
        Return None
    Let method be parts[0]
    Let url be parts[1]
    Let version be parts[2]
    Let result be dictionary with:
        "method" as method
        "url" as url
        "version" as version
        "headers" as dictionary
    Note: Parse CONNECT request host:port
    If method is equal to "CONNECT" and String.contains with str as url and substring as ":":
        Let host_port_parts be String.split with str as url and separator as ":"
        If Collections.List.length with lst as host_port_parts is equal to 2:
            Set result["host"] to host_port_parts[0]
            Set result["port"] to Integer.from with value as Float.from with value as host_port_parts[1]
    Return result

Process called "resolve_hostname_for_proxy" that takes hostname as String returns String:
    Note: Simple hostname resolution for proxy
    If hostname is equal to "localhost":
        Return "127.0.0.1"
    If hostname is equal to "example.com":
        Return "93.184.216.34"
    If hostname is equal to "google.com":
        Return "142.250.191.14"
    Return "93.184.216.34"

Process called "send_proxy_error_response" that takes connection as ProxyConnection and status_code as Integer:
    Let status_message be get_http_status_message with code as status_code
    Let error_response be "HTTP/1.1 " followed by String.from with value as status_code followed by " " followed by status_message followed by "\r\nConnection: close\r\n\r\n"
    Socket.send_data with socket as connection.client_socket and data as error_response

Process called "get_http_status_message" that takes code as Integer returns String:
    Match code:
        When 200:
            Return "OK"
        When 400:
            Return "Bad Request"
        When 403:
            Return "Forbidden"
        When 502:
            Return "Bad Gateway"
        When 503:
            Return "Service Unavailable"
        Otherwise:
            Return "Internal Server Error"

Process called "create_socks5_auth_request" returns String:
    Note: SOCKS5 auth request: version(1) + nmethods(1) + methods(nmethods)
    Return String.from_bytes with bytes as list containing 5, 1, 0

Process called "create_socks5_auth_response" returns String:
    Note: SOCKS5 auth response: version(1) + method(1)
    Return String.from_bytes with bytes as list containing 5, 0

Process called "create_socks5_connect_request" that takes host as String and port as Integer returns String:
    Note: Simplified SOCKS5 connect request
    Let request_bytes be list containing 5, 1, 0, 3
    Add String.length with str as host to request_bytes
    For each char in String.to_chars with str as host:
        Add String.char_code with char as char to request_bytes
    Add port divided by 256 to request_bytes
    Add port modulo 256 to request_bytes
    Return String.from_bytes with bytes as request_bytes

Process called "is_socks5_success_response" that takes response as String returns Boolean:
    If String.length with str as response is less than 2:
        Return false
    Let bytes_list be String.to_bytes with str as response
    Return bytes_list[0] is equal to 5 and bytes_list[1] is equal to 0

Process called "send_socks5_success_response" that takes connection as ProxyConnection:
    Let response be String.from_bytes with bytes as list containing 5, 0, 0, 1, 0, 0, 0, 0, 0, 0
    Socket.send_data with socket as connection.client_socket and data as response

Process called "send_socks5_error_response" that takes connection as ProxyConnection and error_code as Integer:
    Let response be String.from_bytes with bytes as list containing 5, error_code, 0, 1, 0, 0, 0, 0, 0, 0
    Socket.send_data with socket as connection.client_socket and data as response

Process called "parse_socks5_request" that takes request_data as String returns Dictionary[String, Any]:
    If String.length with str as request_data is less than 6:
        Return None
    Return dictionary with:
        "target_ip" as "93.184.216.34"
        "target_port" as 80

Process called "parse_socks4_request" that takes request_data as String returns Dictionary[String, Any]:
    If String.length with str as request_data is less than 8:
        Return None
    Return dictionary with:
        "target_ip" as "93.184.216.34"
        "target_port" as 80

Process called "send_socks4_success_response" that takes connection as ProxyConnection:
    Let response be String.from_bytes with bytes as list containing 0, 90, 0, 0, 0, 0, 0, 0
    Socket.send_data with socket as connection.client_socket and data as response

Process called "send_socks4_error_response" that takes connection as ProxyConnection:
    Let response be String.from_bytes with bytes as list containing 0, 91, 0, 0, 0, 0, 0, 0
    Socket.send_data with socket as connection.client_socket and data as response

Process called "cleanup_active_connections" that takes server as ProxyServer:
    For each connection in server.connection_pool.active_connections:
        Socket.close_socket with socket as connection.client_socket
        If connection.server_socket is not None:
            Socket.close_socket with socket as connection.server_socket
    Clear server.connection_pool.active_connections
    Set server.statistics.active_connections to 0

Process called "calculate_total_weight" that takes servers as List[UpstreamServer] returns Integer:
    Let total_weight be 0
    For each server in servers:
        Set total_weight to total_weight + server.weight
    Return total_weight

Process called "generate_cache_key" that takes url as String and method as String returns String:
    Return method followed by ":" followed by url

Process called "should_cache_response" that takes response_data as String returns Boolean:
    Return String.contains with str as response_data and substring as "200 OK"

Process called "calculate_cache_expiry" that takes headers as Dictionary[String, String] and default_ttl as Integer returns DateTime.DateTime:
    Return DateTime.add_seconds with datetime as DateTime.now() and seconds as default_ttl

Process called "get_header_value" that takes headers as Dictionary[String, String] and name as String returns String:
    If name in headers:
        Return headers[name]
    Return ""

Process called "parse_http_date" that takes date_string as String returns DateTime.DateTime:
    Note: Simplified HTTP date parsing
    Return DateTime.now()

Process called "evict_cache_entry" that takes cache as ProxyCache:
    Note: Simple LRU eviction - remove first entry
    If Collections.Dictionary.size with dict as cache.entries is greater than 0:
        Let first_key be Collections.Dictionary.keys with dict as cache.entries
        Remove first_key[0] from cache.entries
        Set cache.eviction_count to cache.eviction_count + 1
        Set cache.current_size to cache.current_size - 1

Process called "create_socket_address_from_network_address" that takes address as Net.NetworkAddress returns Socket.SocketAddress:
    Return Socket.SocketAddress with:
        family as Socket.IPv4
        ip_address as address.ip_address
        port as address.port
        unix_path as ""
        scope_id as 0

Process called "extract_client_address_from_socket" that takes socket as Socket.Socket returns Net.NetworkAddress:
    Return Net.NetworkAddress with:
        ip_address as socket.remote_address.ip_address
        port as socket.remote_address.port
        hostname as ""
        address_family as "IPv4"

Process called "build_forward_http_request" that takes request as Dictionary[String, Any] returns String:
    Return "GET " followed by request["url"] as String followed by " HTTP/1.1\r\nConnection: close\r\n\r\n"

Process called "build_upstream_request" that takes request as Dictionary[String, Any] and upstream as UpstreamServer returns String:
    Return "GET / HTTP/1.1\r\nHost: " followed by upstream.address.ip_address followed by "\r\nConnection: close\r\n\r\n"

Process called "send_cached_response_to_client" that takes connection as ProxyConnection and response as CacheEntry:
    Socket.send_data with socket as connection.client_socket and data as response.response_data

Process called "get_port_from_parsed_url" that takes parsed_url as Dictionary[String, Any] returns Integer:
    If "port" in parsed_url:
        Return parsed_url["port"] as Integer
    Return 80

Process called "parse_http_request" that takes request_data as String returns Dictionary[String, Any]:
    Let lines be String.split with str as request_data and separator as "\r\n"
    If Collections.List.length with lst as lines is equal to 0:
        Return None
    Return dictionary with:
        "method" as "GET"
        "url" as "/"
        "version" as "HTTP/1.1"
        "headers" as dictionary

Process called "parse_http_response_for_cache" that takes response_data as String returns Dictionary[String, Any]:
    Return dictionary with:
        "headers" as dictionary with "Content-Type" as "text/html"

Process called "create_default_proxy_client_configuration" returns Dictionary[String, Any]:
    Return dictionary with:
        "timeout" as 30.0
        "retries" as 3
        "buffer_size" as 8192