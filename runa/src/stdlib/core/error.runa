"""
Error handling utilities for Runa Standard Library.

This module provides the standard error types, error creation functions,
and error handling utilities for Runa programs.
"""

# Define standard error types
Process called "create_error" that takes message:
    Return runa.core.create_error(message)

Process called "create_type_error" that takes message, expected_type, actual_type:
    Return runa.core.create_type_error(message, expected_type, actual_type)

Process called "create_value_error" that takes message, invalid_value:
    Return runa.core.create_value_error(message, invalid_value)

Process called "create_reference_error" that takes message, reference_name:
    Return runa.core.create_reference_error(message, reference_name)

Process called "create_syntax_error" that takes message, source, line, column:
    Return runa.core.create_syntax_error(message, source, line, column)

Process called "create_range_error" that takes message, value, min, max:
    Return runa.core.create_range_error(message, value, min, max)

Process called "create_io_error" that takes message, operation, path:
    Return runa.core.create_io_error(message, operation, path)

Process called "create_import_error" that takes message, module_name:
    Return runa.core.create_import_error(message, module_name)

Process called "create_assertion_error" that takes message, expression:
    Return runa.core.create_assertion_error(message, expression)

Process called "create_not_implemented_error" that takes message, feature:
    Return runa.core.create_not_implemented_error(message, feature)

# Error handling utilities
Process called "throw" that takes error:
    runa.core.throw(error)

Process called "assert" that takes condition, message:
    If !message:
        message = "Assertion failed"
    runa.core.assert(condition, message)

Process called "error_to_string" that takes error:
    Return runa.core.error_to_string(error)

Process called "format_stack_trace" that takes error:
    Return runa.core.format_stack_trace(error)

# Helper functions for common error cases
Process called "assert_type" that takes value, expected_type, message:
    Let actual_type = runa.core.type(value)
    If actual_type != expected_type:
        If !message:
            message = "Expected " + expected_type + " but got " + actual_type
        throw(create_type_error(message, expected_type, actual_type))

Process called "assert_range" that takes value, min, max, message:
    If value < min || value > max:
        If !message:
            message = "Value " + value + " is outside of range [" + min + ", " + max + "]"
        throw(create_range_error(message, value, min, max))

Process called "assert_not_null" that takes value, message:
    If value == null:
        If !message:
            message = "Value cannot be null"
        throw(create_value_error(message, value))

# Export all functions
export {
    create_error,
    create_type_error,
    create_value_error,
    create_reference_error,
    create_syntax_error,
    create_range_error,
    create_io_error,
    create_import_error,
    create_assertion_error,
    create_not_implemented_error,
    
    throw,
    assert,
    error_to_string,
    format_stack_trace,
    
    assert_type,
    assert_range,
    assert_not_null
} 