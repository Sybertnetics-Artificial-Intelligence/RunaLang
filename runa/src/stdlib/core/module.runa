"""
Module system implementation for Runa Standard Library.

This module provides functionality for module loading, import/export operations,
and namespace management for Runa programs.
"""

# Module registry to keep track of loaded modules
Let module_registry = {}

# Package registry for package management
Let package_registry = {}

# Module loading functions
Process called "load_module" that takes module_path:
    # Check if module is already loaded
    If module_registry.has_key(module_path):
        Return module_registry[module_path]
    
    # Attempt to load the module
    Try:
        # Use built-in module loader
        Let module_contents = runa.io.read_file(module_path + ".runa")
        Let module = runa.core.compile_and_load_module(module_contents, module_path)
        
        # Register the module
        module_registry[module_path] = module
        
        Return module
    Catch error:
        throw(create_import_error("Failed to load module: " + module_path, module_path))

Process called "import_module" that takes module_path:
    # Load the module
    Let module = load_module(module_path)
    
    # Return the module's exports
    Return module.exports

Process called "import_from" that takes module_path, symbols:
    # Load the module
    Let module = load_module(module_path)
    
    # Create object with requested exports
    Let result = {}
    
    For symbol in symbols:
        If module.exports.has_key(symbol):
            result[symbol] = module.exports[symbol]
        Else:
            throw(create_reference_error("Symbol '" + symbol + "' not found in module: " + module_path, symbol))
    
    Return result

Process called "register_exports" that takes exports:
    # Get the current module
    Let current_module = runa.core.get_current_module()
    
    # Register exports
    For key, value in exports:
        current_module.exports[key] = value
    
    Return true

Process called "get_module_name" that takes:
    Return runa.core.get_current_module().name

Process called "get_module_path" that takes:
    Return runa.core.get_current_module().path

# Package management
Process called "register_package" that takes package_name, version, dependencies:
    package_registry[package_name] = {
        name: package_name,
        version: version,
        dependencies: dependencies
    }
    Return true

Process called "get_package" that takes package_name:
    If package_registry.has_key(package_name):
        Return package_registry[package_name]
    Return null

Process called "resolve_package_dependencies" that takes package_name:
    Let package = get_package(package_name)
    If package == null:
        throw(create_reference_error("Package not found: " + package_name, package_name))
    
    Let resolved = []
    Let dependencies = package.dependencies
    
    For dep_name in dependencies:
        Let dep = get_package(dep_name)
        If dep == null:
            throw(create_reference_error("Dependency not found: " + dep_name, dep_name))
        
        # Add this dependency
        resolved.append(dep_name)
        
        # Recursively resolve transitive dependencies
        Let dep_deps = resolve_package_dependencies(dep_name)
        For transitive_dep in dep_deps:
            If !resolved.includes(transitive_dep):
                resolved.append(transitive_dep)
    
    Return resolved

Process called "list_packages" that takes:
    Let result = []
    For name, pkg in package_registry:
        result.append({
            name: name,
            version: pkg.version,
            dependencies: pkg.dependencies
        })
    Return result

# Namespace management
Process called "create_namespace" that takes name, parent:
    Let namespace = {
        name: name,
        parent: parent,
        symbols: {}
    }
    
    Return namespace

Process called "add_to_namespace" that takes namespace, name, value:
    namespace.symbols[name] = value
    Return value

Process called "get_from_namespace" that takes namespace, name:
    # Check if symbol exists in this namespace
    If namespace.symbols.has_key(name):
        Return namespace.symbols[name]
    
    # Check parent namespace if it exists
    If namespace.parent:
        Return get_from_namespace(namespace.parent, name)
    
    # Symbol not found
    Return null

Process called "resolve_name" that takes name, namespace:
    # Split name by dots for nested access
    Let parts = name.split(".")
    Let current = namespace
    
    For part in parts:
        Let value = get_from_namespace(current, part)
        If value == null:
            Return null
        current = value
    
    Return current

# Module search path management
Process called "add_search_path" that takes path:
    runa.vm.add_module_search_path(path)
    Return true

Process called "get_search_paths" that takes:
    Return runa.vm.get_module_search_paths()

# Export functions
export {
    # Module loading
    load_module,
    import_module,
    import_from,
    register_exports,
    get_module_name,
    get_module_path,
    
    # Package management
    register_package,
    get_package,
    resolve_package_dependencies,
    list_packages,
    
    # Namespace management
    create_namespace,
    add_to_namespace,
    get_from_namespace,
    resolve_name,
    
    # Search path management
    add_search_path,
    get_search_paths
} 