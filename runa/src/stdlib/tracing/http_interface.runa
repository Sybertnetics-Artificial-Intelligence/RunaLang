Note: HTTP Interface for Tracing Library
Note: Simplified HTTP interface that wraps the complex HTTP client for tracing needs

Import "http/client" as HTTPClient
Import "http/http" as HTTPCore
Import "serialization/json" as JSON
Import "tracing/utils" as Utils

Note: Simple HTTP response type for tracing

Type called "SimpleHTTPResponse":
            status_code as Integer
            headers as Dictionary[String, String]
            body as String
            success as Boolean

Type called "SimpleHTTPClient":
            internal_client as HTTPClient.HTTPClient
    
    Process called "create_client" returns SimpleHTTPClient:
        Return SimpleHTTPClient with:
            internal_client as HTTPClient.create_http_client()
    
    Process called "post" that takes url as String and data as String and headers as Dictionary[String, String] and timeout as Integer returns SimpleHTTPResponse:
        Try:
            Note: Convert string data to JSON if needed
            Let json_data be parse_data_to_json with data as data
            
            Note: Merge headers with defaults
            Let final_headers be merge_headers with headers as headers
            
            Note: Create HTTP request
            Let request be HTTPCore.create_http_request with:
                method as HTTPCore.POST
                url as url
            
            Note: Set headers
            For each key and value in final_headers:
                HTTPCore.add_request_header with request as request and name as key and value as value
            
            Note: Set body
            HTTPCore.set_request_body with request as request and body as data
            
            Note: Set timeout
            HTTPCore.set_request_timeout with request as request and timeout as timeout
            
            Note: Send request
            Let response be HTTPClient.send_request with client as self.internal_client and request as request
            
            Note: Convert to simple response
            Return convert_to_simple_response with response as response
            
        Catch http_error:
            Return create_error_response with error as http_error.message and status_code as 500
    
    Process called "get" that takes url as String and headers as Dictionary[String, String] and timeout as Integer returns SimpleHTTPResponse:
        Try:
            Note: Merge headers with defaults
            Let final_headers be merge_headers with headers as headers
            
            Note: Create HTTP request
            Let request be HTTPCore.create_http_request with:
                method as HTTPCore.GET
                url as url
            
            Note: Set headers
            For each key and value in final_headers:
                HTTPCore.add_request_header with request as request and name as key and value as value
            
            Note: Set timeout
            HTTPCore.set_request_timeout with request as request and timeout as timeout
            
            Note: Send request
            Let response be HTTPClient.send_request with client as self.internal_client and request as request
            
            Note: Convert to simple response
            Return convert_to_simple_response with response as response
            
        Catch http_error:
            Return create_error_response with error as http_error.message and status_code as 500
    
    Process called "close" returns None:
        Note: Close the internal HTTP client
        Try:
            self.internal_client.close()
        Catch close_error:
            Note: Ignore close errors
            Return None

Note: Global HTTP client instance for simple usage

Let global_http_client be mutable Optional[SimpleHTTPClient] with value as None

Process called "get_global_client" returns SimpleHTTPClient:
    If global_http_client is None:
        Set global_http_client to Some with value as SimpleHTTPClient.create_client()
            Return global_http_client

Process called "post" that takes url as String and data as String and headers as Dictionary[String, String] and timeout as Integer returns SimpleHTTPResponse:
            Let client be get_global_client()
            Return client.post with url as url and data as data and headers as headers and timeout as timeout

Process called "get" that takes url as String and headers as Dictionary[String, String] and timeout as Integer returns SimpleHTTPResponse:
            Let client be get_global_client()
            Return client.get with url as url and headers as headers and timeout as timeout

Note: Convenience functions with defaults

Process called "simple_post" that takes url as String and data as String returns SimpleHTTPResponse:
            Let default_headers be Utils.create_default_headers()
            Return post with url as url and data as data and headers as default_headers and timeout as 30

Process called "simple_get" that takes url as String returns SimpleHTTPResponse:
            Let default_headers be Utils.create_default_headers()
            Return get with url as url and headers as default_headers and timeout as 30

Note: Helper functions for HTTP operations

Process called "merge_headers" that takes headers as Dictionary[String, String] returns Dictionary[String, String]:
            Let merged be Utils.create_default_headers()
    For each key and value in headers:
        Set merged[key] to value
            Return merged

Process called "parse_data_to_json" that takes data as String returns Dictionary[String, Any]:
    Try:
        Return Utils.decode_json with json_string as data
    Catch parse_error:
        Note: If not valid JSON, wrap in a simple structure
        Return dictionary with:
            "data" as data
            "content_type" as "text/plain"

Process called "convert_to_simple_response" that takes response as HTTPCore.HTTPResponse returns SimpleHTTPResponse:
            Let status_code be HTTPCore.get_response_status_code with response as response
            Let headers be HTTPCore.get_response_headers with response as response
            Let body be HTTPCore.get_response_body with response as response
            Let success be status_code > or equal to 200 and status_code < 300
    
    Return SimpleHTTPResponse with:
        status_code as status_code
        headers as headers
        body as body
        success as success

Process called "create_error_response" that takes error as String and status_code as Integer returns SimpleHTTPResponse:
    Let error_body be Utils.encode_json with data as dictionary with:
        "error" as error
        "timestamp" as Utils.get_current_timestamp()
    
    Return SimpleHTTPResponse with:
        status_code as status_code
        headers as Utils.create_default_headers()
        body as error_body
        success as false

Note: HTTP client creation functions

Process called "create_client" returns SimpleHTTPClient:
            Return SimpleHTTPClient.create_client()

Process called "create_connection_pool" returns HTTPClient.ConnectionPool:
            Return HTTPClient.create_connection_pool()

Note: Response type creation for compatibility

Type called "Response":
            status_code as Integer
            headers as Dictionary[String, String]
            body as String
    
    Process called "create_response" that takes status_code as Integer and body as String and headers as Dictionary[String, String] returns Response:
        Return Response with:
            status_code as status_code
            body as body
            headers as headers

Note: Export simplified HTTP interface
Export SimpleHTTPResponse
Export SimpleHTTPClient
Export Response
Export post
Export get
Export simple_post
Export simple_get
Export create_client
Export create_connection_pool