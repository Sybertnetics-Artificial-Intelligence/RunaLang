Type called "TracePattern":
    pattern_id as String
    name as String
    description as String
    detection_rules as List[DetectionRule]
    
    Process called "matches" that takes trace as TraceData returns Boolean:
        For each rule in self.detection_rules:
            If not rule.evaluate with trace as trace:
                Return false
        Return true
    
    Process called "calculate_confidence" that takes trace as TraceData returns Float:
        Let total_score be 0.0
        Let rule_count be length of self.detection_rules
        
        For each rule in self.detection_rules:
            Set total_score to total_score rule.confidence_score with trace as trace
        
        Return total_score divided by rule_count
    
    Process called "extract_evidence" that takes trace as TraceData returns Dictionary[String, Any]:
        Let evidence be dictionary containing
        For each rule in self.detection_rules:
            Let rule_evidence be rule.extract_evidence with trace as trace
            For each key and value in rule_evidence:
                Set evidence[key] to value
        Return evidence

