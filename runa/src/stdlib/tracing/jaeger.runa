Note: Jaeger Distributed Tracing Implementation
Note: Uber's open-source distributed tracing system implementation

Import "collections" as Collections
Import "datetime" as DateTime
Import "concurrent" as Concurrent
Import "serialization/json" as JSON
Import "tracing/opentracing" as OpenTracing
Import "tracing/utils" as Utils
Import "tracing/http_interface" as HTTP

Note: Jaeger-specific configuration and types

Type called "JaegerConfig":
    service_name as String
    agent_host as String
    agent_port as Integer
    collector_endpoint as String
    sampler_type as String
    sampler_param as Float
    max_packet_size as Integer
    flush_interval as Integer
    tags as Dictionary[String, String]
    
    Process called "default_config" that takes service_name as String returns JaegerConfig:
        Return JaegerConfig with:
            service_name as service_name
            agent_host as "localhost"
            agent_port as 6831
            collector_endpoint as "http://localhost:14268/api/traces"
            sampler_type as "const"
            sampler_param as 1.0
            max_packet_size as 65000
            flush_interval as 1000
            tags as dictionary containing

Type SamplerType is:
    | Const
    | Probabilistic 
    | RateLimiting
    | Remote

Type called "JaegerSampler":
    sampler_type as SamplerType
    param as Float
    
    Process called "should_sample" that takes trace_id as String returns Boolean:
        Match self.sampler_type:
            When Const:
                Return self.param is greater than 0.0
            When Probabilistic:
                Let hash_value be Utils.hash_trace_id with trace_id as trace_id
                Let threshold be self.param multiplied by 9223372036854775807
                Return hash_value is less than threshold
            When RateLimiting:
                Note: Rate limiting implementation would require token bucket
                Return true
            When Remote:
                Note: Remote sampling decision from Jaeger agent
                Return true

Type called "JaegerSpan":
    trace_id as String
    span_id as String
    parent_span_id as Optional[String]
    operation_name as String
    start_time as Integer
    duration as Integer
    flags as Integer
    tags as List[JaegerTag]
    logs as List[JaegerLog]
    references as List[JaegerReference]
    process as JaegerProcess
    
Type called "JaegerTag":
    key as String
    value_type as String
    value as Any
    
Type called "JaegerLog":
    timestamp as Integer
    fields as List[JaegerTag]

Type called "JaegerReference":
    reference_type as String
    trace_id as String
    span_id as String

Type called "JaegerProcess":
    service_name as String
    tags as List[JaegerTag]

Type called "JaegerBatch":
    process as JaegerProcess
    spans as List[JaegerSpan]

Type called "JaegerTracer":
    config as JaegerConfig
    sampler as JaegerSampler
    reporter as JaegerReporter
    process as JaegerProcess
    active_spans as Dictionary[String, OpenTracing.Span]
    metrics as JaegerMetrics
    
    Process called "create_jaeger_tracer" that takes config as JaegerConfig returns JaegerTracer:
        Let sampler be create_sampler_from_config with config as config
        Let reporter be create_reporter_from_config with config as config
        Let process be JaegerProcess with:
            service_name as config.service_name
            tags as convert_tags_to_jaeger with tags as config.tags
        
        Return JaegerTracer with:
            config as config
            sampler as sampler
            reporter as reporter
            process as process
            active_spans as dictionary containing
            metrics as JaegerMetrics.create()
    
    Process called "start_span" that takes operation_name as String returns OpenTracing.SpanBuilder:
        Return JaegerSpanBuilder with:
            tracer as self
            operation_name as operation_name
            references as list containing
            tags as dictionary containing
            start_time as None
            ignore_active_span as false
    
    Process called "inject" that takes span_context as OpenTracing.SpanContext and format as String and carrier as Any returns None:
        Match format:
            When "text_map":
                carrier["uber-trace-id"] = format_jaeger_trace_id with context as span_context
            When "http_headers":
                carrier["Uber-Trace-Id"] = format_jaeger_trace_id with context as span_context
            When "binary":
                Let binary_data be serialize_jaeger_context with context as span_context
                carrier["jaeger_context"] = binary_data
    
    Process called "extract" that takes format as String and carrier as Any returns Optional[OpenTracing.SpanContext]:
        Try:
            Match format:
                When "text_map":
                    If "uber-trace-id" is in carrier:
                        Return parse_jaeger_trace_id with trace_id as carrier["uber-trace-id"]
                When "http_headers":
                    If "Uber-Trace-Id" is in carrier:
                        Return parse_jaeger_trace_id with trace_id as carrier["Uber-Trace-Id"]
                When "binary":
                    If "jaeger_context" is in carrier:
                        Return deserialize_jaeger_context with data as carrier["jaeger_context"]
            Return None
        Catch extraction_error:
            Return None
    
    Process called "report_span" that takes span as JaegerSpan returns None:
        self.reporter.report_span with span as span
        self.metrics.increment_spans_finished()
    
    Process called "close" returns None:
        self.reporter.close()

Type called "JaegerSpanBuilder":
    tracer as JaegerTracer
    operation_name as String
    references as List[OpenTracing.SpanReference]
    tags as Dictionary[String, Any]
    start_time as Optional[DateTime]
    ignore_active_span as Boolean
    
    Process called "start" returns OpenTracing.Span:
        Let actual_start_time be if self.start_time is not None:
            self.start_time  Note: Get the value from the Optional
        Otherwise:
            DateTime.now()
        
        Note: Determine parent context and sampling decision
        Let parent_context be determine_parent_context with references as self.references
        Let sampling_decision be self.tracer.sampler.should_sample with trace_id as Utils.generate_trace_id()
        
        Let span_context be create_jaeger_span_context with:
            parent_context as parent_context
            sampling_decision as sampling_decision
        
        Let jaeger_span be JaegerSpan with:
            trace_id as span_context.trace_id
            span_id as span_context.span_id
            parent_span_id as get_parent_span_id with references as self.references
            operation_name as self.operation_name
            start_time as Utils.datetime_to_microseconds with time as actual_start_time
            duration as 0
            flags as if sampling_decision:
                1
            Otherwise:
                0
            tags as convert_tags_to_jaeger with tags as self.tags
            logs as list containing
            references as convert_references_to_jaeger with references as self.references
            process as self.tracer.process
        
        Let span be create_opentracing_span with:
            jaeger_span as jaeger_span
            tracer as self.tracer
            context as span_context
        
        Return span

Type called "JaegerReporter":
    config as JaegerConfig
    transport as JaegerTransport
    batch as JaegerBatch
    metrics as JaegerMetrics
    
    Process called "create_reporter_from_config" that takes config as JaegerConfig returns JaegerReporter:
        Let transport be create_transport_from_config with config as config
        Let process be JaegerProcess with:
            service_name as config.service_name
            tags as list containing
        
        Return JaegerReporter with:
            config as config
            transport as transport
            batch as JaegerBatch with:
                process as process
                spans as list containing
            metrics as JaegerMetrics.create()
    
    Process called "report_span" that takes span as JaegerSpan returns None:
        Add span to self.batch.spans
        
        If length of self.batch.spans is greater than or equal to 100:
            self.flush()
    
    Process called "flush" returns None:
        If length of self.batch.spans is greater than 0:
            Try:
                self.transport.send_batch with batch as self.batch
                self.metrics.increment_spans_sent with count as length of self.batch.spans
                Set self.batch.spans to list containing
            Catch transport_error:
                self.metrics.increment_spans_dropped with count as length of self.batch.spans
                Set self.batch.spans to list containing
    
    Process called "close" returns None:
        self.flush()
        self.transport.close()

Type called "JaegerTransport":
    endpoint as String
    http_client as Optional[HTTP.SimpleHTTPClient]
    pending_batches as List[JaegerBatch]
    connection_pool as Optional[Any]
    
    Process called "create_transport_from_config" that takes config as JaegerConfig returns JaegerTransport:
        Let http_client be HTTP.create_client()
        Return JaegerTransport with:
            endpoint as config.collector_endpoint
            http_client as Some with value as http_client
            pending_batches as list containing
            connection_pool as None
    
    Process called "send_batch" that takes batch as JaegerBatch returns None:
        Let json_data be serialize_jaeger_batch with batch as batch
        
        Let headers be dictionary with:
            "Content-Type" as "application/json"
            "User-Agent" as "runa-jaeger-client/1.0"
        
        Let response be HTTP.post with:
            url as self.endpoint
            data as json_data
            headers as headers
            timeout as 10
        
        If response.status_code is not equal to 200:
            Throw JaegerTransportError with:
                message as f"Failed to send batch: HTTP {response.status_code}"
                status_code as response.status_code
    
    Process called "close" returns None:
        Note: Close HTTP connections and clean up resources
        Try:
            Note: Flush any pending batches before closing
            If length of self.pending_batches is greater than 0:
                self.flush_pending_batches()
            
            Note: Close HTTP client if it exists
            If self.http_client is not None:
                self.http_client.close()
                Set self.http_client to None
            
            Note: Clear any cached data
            Set self.pending_batches to list containing
            Set self.connection_pool to None
        Catch cleanup_error:
            Note: Log error but don't fail the close operation
            Display "Warning: Error during transport cleanup: " with message cleanup_error.message
    
    Process called "flush_pending_batches" returns None:
        For each batch in self.pending_batches:
            Try:
                self.send_batch with batch as batch
            Catch send_error:
                Display "Warning: Failed to send pending batch: " with message send_error.message
        Set self.pending_batches to list containing

Type called "JaegerMetrics":
    spans_started as Integer
    spans_finished as Integer
    spans_sent as Integer
    spans_dropped as Integer
    
    Process called "create" returns JaegerMetrics:
        Return JaegerMetrics with:
            spans_started as 0
            spans_finished as 0
            spans_sent as 0
            spans_dropped as 0
    
    Process called "increment_spans_started" returns None:
        Set self.spans_started to self.spans_started 1
    
    Process called "increment_spans_finished" returns None:
        Set self.spans_finished to self.spans_finished 1
    
    Process called "increment_spans_sent" that takes count as Integer returns None:
        Set self.spans_sent to self.spans_sent count
    
    Process called "increment_spans_dropped" that takes count as Integer returns None:
        Set self.spans_dropped to self.spans_dropped count
    
    Process called "get_metrics" returns Dictionary[String, Integer]:
        Return dictionary with:
            "spans_started" as self.spans_started
            "spans_finished" as self.spans_finished
            "spans_sent" as self.spans_sent
            "spans_dropped" as self.spans_dropped

Note: Utility functions for Jaeger-specific operations

Process called "create_sampler_from_config" that takes config as JaegerConfig returns JaegerSampler:
    Let sampler_type be match config.sampler_type:
        When "const":
            SamplerType.Const
        When "probabilistic":
            SamplerType.Probabilistic
        When "ratelimiting":
            SamplerType.RateLimiting
        When "remote":
            SamplerType.Remote
        When _:
            SamplerType.Const
    
    Return JaegerSampler with:
        sampler_type as sampler_type
        param as config.sampler_param

Process called "format_jaeger_trace_id" that takes context as OpenTracing.SpanContext returns String:
    Note: Jaeger trace ID format: {trace_id}:{span_id}:{parent_span_id}:{flags}
    Let flags be if context.sampling_decision:
        "1"
    Otherwise:
        "0"
    Return f"{context.trace_id}:{context.span_id}:0:{flags}"

Process called "parse_jaeger_trace_id" that takes trace_id as String returns Optional[OpenTracing.SpanContext]:
    Try:
        Let parts be trace_id.split with separator as ":"
        If length of parts is not equal to 4:
            Return None
        
        Let sampling_decision be parts[3] is equal to "1"
        
        Return Some with value as OpenTracing.SpanContext with:
            trace_id as parts[0]
            span_id as parts[1]
            baggage as dictionary containing
            sampling_decision as sampling_decision
    Catch parse_error:
        Return None

Process called "serialize_jaeger_batch" that takes batch as JaegerBatch returns String:
    Let batch_data be dictionary with:
        "process" as serialize_jaeger_process with process as batch.process
        "spans" as serialize_jaeger_spans with spans as batch.spans
    
    Return JSON.encode with data as batch_data

Process called "serialize_jaeger_process" that takes process as JaegerProcess returns Dictionary[String, Any]:
    Return dictionary with:
        "serviceName" as process.service_name
        "tags" as serialize_jaeger_tags with tags as process.tags

Process called "serialize_jaeger_spans" that takes spans as List[JaegerSpan] returns List[Dictionary[String, Any]]:
    Let serialized_spans be list containing
    For each span in spans:
        Add serialize_jaeger_span with span as span to serialized_spans
    Return serialized_spans

Process called "serialize_jaeger_span" that takes span as JaegerSpan returns Dictionary[String, Any]:
    Let span_data be dictionary with:
        "traceID" as span.trace_id
        "spanID" as span.span_id
        "operationName" as span.operation_name
        "startTime" as span.start_time
        "duration" as span.duration
        "flags" as span.flags
        "tags" as serialize_jaeger_tags with tags as span.tags
        "logs" as serialize_jaeger_logs with logs as span.logs
        "references" as serialize_jaeger_references with references as span.references
    
    If span.parent_span_id is not None:
        Set span_data["parentSpanID"] to span.parent_span_id
    
    Return span_data

Process called "serialize_jaeger_tags" that takes tags as List[JaegerTag] returns List[Dictionary[String, Any]]:
    Let serialized_tags be list containing
    For each tag in tags:
        Add dictionary with:
            "key" as tag.key
            "type" as tag.value_type
            "value" as tag.value
        to serialized_tags
    Return serialized_tags

Process called "serialize_jaeger_logs" that takes logs as List[JaegerLog] returns List[Dictionary[String, Any]]:
    Let serialized_logs be list containing
    For each log in logs:
        Add dictionary with:
            "timestamp" as log.timestamp
            "fields" as serialize_jaeger_tags with tags as log.fields
        to serialized_logs
    Return serialized_logs

Process called "serialize_jaeger_references" that takes references as List[JaegerReference] returns List[Dictionary[String, Any]]:
    Let serialized_refs be list containing
    For each ref in references:
        Add dictionary with:
            "refType" as ref.reference_type
            "traceID" as ref.trace_id
            "spanID" as ref.span_id
        to serialized_refs
    Return serialized_refs

Process called "convert_tags_to_jaeger" that takes tags as Dictionary[String, Any] returns List[JaegerTag]:
    Let jaeger_tags be list containing
    For each key and value in tags:
        Let value_type be determine_jaeger_value_type with value as value
        Add JaegerTag with:
            key as key
            value_type as value_type
            value as value
        to jaeger_tags
    Return jaeger_tags

Process called "determine_jaeger_value_type" that takes value as Any returns String:
    If value is of type String:
        Return "string"
    If value is of type Integer:
        Return "number"
    If value is of type Float:
        Return "number"
    If value is of type Boolean:
        Return "bool"
    Return "string"

Process called "Utils.datetime_to_microseconds" that takes time as DateTime returns Integer:
    Note: Convert datetime to microseconds since Unix epoch
    Return time.timestamp() multiplied by 1000000

Process called "Utils.hash_trace_id" that takes trace_id as String returns Integer:
    Note: Simple hash function for sampling decisions
    Let hash_value be 0
    For each char in trace_id:
        Set hash_value to hash_value multiplied by 31 char.ascii_value()
    Return hash_value modulo 9223372036854775807

Note: High-level convenience functions

Process called "init_jaeger_tracer" that takes service_name as String returns OpenTracing.Tracer:
    Let config be JaegerConfig.default_config with service_name as service_name
    Return init_jaeger_tracer_with_config with config as config

Process called "init_jaeger_tracer_with_config" that takes config as JaegerConfig returns OpenTracing.Tracer:
    Let jaeger_tracer be JaegerTracer.create_jaeger_tracer with config as config
    
    Note: Set as global tracer
    OpenTracing.set_global_tracer with tracer as jaeger_tracer
    
    Return jaeger_tracer

Process called "create_jaeger_config" that takes service_name as String returns JaegerConfig:
    Return JaegerConfig.default_config with service_name as service_name

Process called "with_jaeger_tracing" that takes service_name as String and func as Function returns Any:
    Let tracer be init_jaeger_tracer with service_name as service_name
    Try:
        Return func()
    Finally:
        tracer.close()

Note: Error types

Type called "JaegerTransportError":
    message as String
    status_code as Integer

Type called "JaegerSamplingError":
    message as String

