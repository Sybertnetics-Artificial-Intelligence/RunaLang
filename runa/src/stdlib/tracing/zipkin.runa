Note: Zipkin Distributed Tracing Implementation
Note: Twitter's open-source distributed tracing system implementation

Import "../../collections" as Collections
Import "../../datetime" as DateTime
Import "../../concurrent" as Concurrent
Import "serialization/json" as JSON
Import "tracing/opentracing" as OpenTracing
Import "tracing/utils" as Utils
Import "tracing/http_interface" as HTTP

Note: Zipkin-specific configuration and types

Type called "ZipkinConfig":
            service_name as String
            endpoint as String
            local_endpoint as ZipkinEndpoint
            sample_rate as Float
            flush_interval as Integer
            max_batch_size as Integer
            timeout as Integer
            compression as Boolean
    
    Process called "default_config" that takes service_name as String returns ZipkinConfig:
        Return ZipkinConfig with:
            service_name as service_name
            endpoint as "http://localhost:9411/api/v2/spans"
            local_endpoint as ZipkinEndpoint with:
                service_name as service_name
                ipv4 as Utils.get_local_ip()
                port as Utils.get_local_port()
            sample_rate as 1.0
            flush_interval as 1000
            max_batch_size as 100
            timeout as 10
            compression as true

