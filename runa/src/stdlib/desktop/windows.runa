Note: Stub Function Implementations

Process called "get_module_handle" that returns HINSTANCE:
    Note: Get module handle using Win32 GetModuleHandleW API
    Try:
        Let handle_value be call_win32_api with
            function as "GetModuleHandleW" and
            parameters as [null] and
            library as "kernel32.dll"
        
        If handle_value is not equal to 0:
            Return HINSTANCE with handle as handle_value
    Catch Exception:
        Note: Fallback to current process handle
        Pass
    
    Note: Return handle to current process if module not found
    Let current_process be call_win32_api with
        function as "GetCurrentProcess" and
        parameters as [] and
        library as "kernel32.dll"
    
    Return HINSTANCE with handle as current_process

Process called "register_window_class" that takes application as gui.GUIApplication returns WNDCLASS:
    Note: Register complete window class with all properties
    Try:
        Let module_handle be get_module_handle
        Let window_procedure be create_window_procedure
        Let app_icon be load_application_icon
        Let app_cursor be load_application_cursor
        Let background_brush be create_background_brush
        
        Let window_class be WNDCLASS with:
            style as "CS_HREDRAW | CS_VREDRAW | CS_DBLCLKS"  Note: Standard window styles
            wnd_proc as window_procedure
            cls_extra as 0
            wnd_extra as 0
            instance as module_handle
            icon as app_icon
            cursor as app_cursor
            background as background_brush
            menu_name as none  Note: No default menu
            class_name as application.name plus "WindowClass"
            small_icon as app_icon  Note: For taskbar
        
        Note: Register the window class with Windows
        Let registration_result be call_win32_api with
            function as "RegisterClassExA" and
            parameters as [window_class] and
            library as "user32.dll"
        
        If registration_result is equal to 0:
            Call log_shell_error with
                operation as "RegisterClassExA" and
                error as Exception with message as "Failed to register window class"
        
        Return window_class
    
    Catch error as Exception:
        Call log_shell_error with operation as "register_window_class" and error as error
        
        Note: Return basic window class as fallback
        Return WNDCLASS with:
            style as 0
            wnd_proc as WNDPROC with procedure as none
            cls_extra as 0
            wnd_extra as 0
            instance as get_module_handle
            icon as none
            cursor as none
            background as none
            menu_name as none
            class_name as application.name plus "WindowClass"

Process called "initialize_com_library" that returns Boolean:
    Note: Initialize COM library using CoInitializeEx
    Try:
        Let hresult be call_win32_api with
            function as "CoInitializeEx" and
            parameters as [null, "COINIT_APARTMENTTHREADED"] and
            library as "ole32.dll"
        
        Note: S_OK (0) or S_FALSE (1) are both success codes
        Return hresult is equal to 0 or hresult is equal to 1
    Catch Exception:
        Return false

Process called "initialize_shell_integration" that returns ShellIntegration:
    Note: Initialize comprehensive Windows Shell integration
    Try:
        Note: Create ITaskbarList4 interface for taskbar operations
        Let taskbar_list be create_com_interface with
            clsid as "CLSID_TaskbarList" and
            iid as "IID_ITaskbarList4"
        
        Note: Initialize taskbar interface
        If taskbar_list is not equal to none:
            Call call_com_method with
                interface as taskbar_list and
                method as "HrInit" and
                parameters as []
        
        Note: Create jump list interface
        Let custom_dest_list be create_com_interface with
            clsid as "CLSID_DestinationList" and
            iid as "IID_ICustomDestinationList"
        
        Return ShellIntegration with:
            taskbar as taskbar_list
            thumbnail_toolbar as none  Note: Created on demand
            jump_list as custom_dest_list
            is_configured as taskbar_list is not equal to none
            initialization_time as current_timestamp
            supported_features as list containing "taskbar" and "jump_lists" and "thumbnails"
    
    Catch error as Exception:
        Call log_com_error with operation as "initialize_shell_integration" and error as error
        
        Return ShellIntegration with:
            taskbar as none
            thumbnail_toolbar as none
            jump_list as none
            is_configured as false
            initialization_time as current_timestamp
            error_message as error as string

Process called "initialize_registry_access" that returns RegistryAccess:
    Note: Initialize registry access with appropriate permissions
    Try:
        Note: Test registry write access
        Let has_write_access be test_registry_write_access with key as "HKEY_CURRENT_USER\\Software"
        
        Note: Determine access level based on permissions
        Let access_level be "KEY_READ"
        If has_write_access:
            Set access_level to "KEY_READ | KEY_WRITE"
        
        Note: Test admin privileges for HKEY_LOCAL_MACHINE
        Let has_admin_access be test_registry_write_access with key as "HKEY_LOCAL_MACHINE\\Software"
        
        Return RegistryAccess with:
            access_mask as access_level
            can_read as true
            can_write as has_write_access
            can_create_keys as has_write_access
            can_access_hklm as has_admin_access
            can_access_hkcu as true
            can_access_hkcr as has_admin_access
            initialization_time as current_timestamp
            is_elevated as has_admin_access
    
    Catch error as Exception:
        Call log_shell_error with operation as "initialize_registry_access" and error as error
        Return RegistryAccess with:
            access_mask as "KEY_READ"
            can_read as true
            can_write as false
            can_create_keys as false
            can_access_hklm as false
            can_access_hkcu as true
            can_access_hkcr as false
            is_elevated as false
            error_message as error as string

Process called "initialize_taskbar_integration" that returns TaskbarIntegration:
    Note: Initialize Windows taskbar integration capabilities
    Try:
        Note: Check if taskbar integration is supported
        Let version_info be get_windows_version
        If version_info.major is less than 6:
            Note: Taskbar integration requires Windows Vista or later
            Return TaskbarIntegration with:
                is_initialized as false
                error_message as "Taskbar integration requires Windows Vista or later"
        
        Note: Create and initialize taskbar list interface
        Let taskbar_interface be create_com_interface with
            clsid as "CLSID_TaskbarList" and
            iid as "IID_ITaskbarList4"
        
        If taskbar_interface is not equal to none:
            Let init_result be call_com_method with
                interface as taskbar_interface and
                method as "HrInit" and
                parameters as []
            
            Return TaskbarIntegration with:
                is_initialized as init_result is equal to 0
                interface as taskbar_interface
                supported_features as list containing "progress" and "overlay" and "thumbnails"
                initialization_time as current_timestamp
        
        Return TaskbarIntegration with:
            is_initialized as false
            error_message as "Failed to create taskbar interface"
    
    Catch error as Exception:
        Call log_com_error with operation as "initialize_taskbar_integration" and error as error
        Return TaskbarIntegration with:
            is_initialized as false
            error_message as error as string

Process called "initialize_jump_lists" that returns JumpLists:
    Note: Initialize Windows Jump Lists using ICustomDestinationList
    Try:
        Note: Create destination list interface
        Let dest_list be create_com_interface with
            clsid as "CLSID_DestinationList" and
            iid as "IID_ICustomDestinationList"
        
        If dest_list is not equal to none:
            Note: Set Application User Model ID for jump list
            Let app_id be get_current_application_user_model_id
            If app_id is not equal to "":
                Call call_com_method with
                    interface as dest_list and
                    method as "SetAppID" and
                    parameters as [app_id]
            
            Return JumpLists with:
                is_configured as true
                interface as dest_list
                categories as empty list
                recent_items as empty list
                frequent_items as empty list
                tasks as empty list
                max_recent_items as 10
                initialization_time as current_timestamp
        
        Return JumpLists with:
            is_configured as false
            error_message as "Failed to create destination list interface"
    
    Catch error as Exception:
        Call log_com_error with operation as "initialize_jump_lists" and error as error
        Return JumpLists with:
            is_configured as false
            error_message as error as string

Process called "initialize_notification_area" that returns NotificationArea:
    Note: Initialize Windows notification area (system tray) support
    Try:
        Note: Check notification area capabilities
        Let version_info be get_windows_version
        Let supports_balloon as version_info.major is greater than or equal to 6
        Let supports_large_icons as version_info.build is greater than or equal to 7600
        
        Note: Initialize notification area manager
        Return NotificationArea with:
            icons as empty list
            is_initialized as true
            supports_balloon_notifications as supports_balloon
            supports_large_icons as supports_large_icons
            supports_quiet_hours as version_info.major is greater than or equal to 10
            max_icons as 64  Note: Practical limit
            current_icon_count as 0
            default_timeout as 5000
            initialization_time as current_timestamp
            capabilities as Dictionary with:
                "balloon_tips" as supports_balloon
                "large_icons" as supports_large_icons
                "quiet_hours_aware" as version_info.major is greater than or equal to 10
    
    Catch error as Exception:
        Call log_shell_error with operation as "initialize_notification_area" and error as error
        Return NotificationArea with:
            icons as empty list
            is_initialized as false
            error_message as error as string

Process called "initialize_file_associations" that returns FileAssociations:
    Note: Initialize Windows file association management
    Try:
        Note: Get current application info
        Let executable_path be get_current_executable_path
        Let app_name be get_current_application_name
        
        Note: Check registry access permissions
        Let has_registry_access be test_registry_write_access with key as "HKEY_CLASSES_ROOT"
        
        Return FileAssociations with:
            registered_extensions as empty list
            is_initialized as true
            executable_path as executable_path
            application_name as app_name
            has_registry_access as has_registry_access
            registration_root as "HKEY_CLASSES_ROOT"
            progid_prefix as app_name
            supports_context_menus as true
            supports_thumbnails as true
            supports_previews as true
            initialization_time as current_timestamp
            pending_registrations as empty list
            capabilities as Dictionary with:
                "can_register" as has_registry_access
                "supports_icons" as true
                "supports_open_with" as true
                "supports_shell_integration" as true
    
    Catch error as Exception:
        Call log_shell_error with operation as "initialize_file_associations" and error as error
        Return FileAssociations with:
            registered_extensions as empty list
            is_initialized as false
            error_message as error as string

Process called "set_dpi_awareness" that returns DPIAwareness:
    Note: Set DPI awareness level using Windows DPI APIs
    Try:
        Note: Try modern per-monitor DPI awareness first (Windows 10+)
        Let version_info be get_windows_version
        
        If version_info.major is greater than or equal to 10:
            Let context be "DPI_AWARENESS_CONTEXT_PER_MONITOR_AWARE_V2"
            Let result be call_win32_api with
                function as "SetProcessDpiAwarenessContext" and
                parameters as [context] and
                library as "user32.dll"
            
            If result is not equal to 0:
                Let current_scale be get_dpi_scale_factor
                Return DPIAwareness with:
                    level as "per_monitor_v2"
                    scale_factor as current_scale
                    is_per_monitor_aware as true
                    supports_mixed_mode as true
                    api_version as "Windows 10+"
        
        Note: Fallback to Windows 8.1+ DPI awareness
        If version_info.major is greater than 6 or (version_info.major is equal to 6 and version_info.minor is greater than or equal to 3):
            Let awareness_level be "PROCESS_PER_MONITOR_DPI_AWARE"
            Let result be call_win32_api with
                function as "SetProcessDpiAwareness" and
                parameters as [awareness_level] and
                library as "shcore.dll"
            
            If result is equal to 0:  Note: S_OK
                Let current_scale be get_dpi_scale_factor
                Return DPIAwareness with:
                    level as "per_monitor"
                    scale_factor as current_scale
                    is_per_monitor_aware as true
                    supports_mixed_mode as false
                    api_version as "Windows 8.1+"
        
        Note: Final fallback to basic system DPI awareness
        Let result be call_win32_api with
            function as "SetProcessDPIAware" and
            parameters as [] and
            library as "user32.dll"
        
        Let current_scale be get_dpi_scale_factor
        Return DPIAwareness with:
            level as "system"
            scale_factor as current_scale
            is_per_monitor_aware as false
            supports_mixed_mode as false
            api_version as "Windows Vista+"
            is_enabled as result is not equal to 0
    
    Catch error as Exception:
        Call log_shell_error with operation as "set_dpi_awareness" and error as error
        Return DPIAwareness with:
            level as "none"
            scale_factor as 1.0
            is_per_monitor_aware as false
            supports_mixed_mode as false
            api_version as "legacy"
            is_enabled as false
            error_message as error as string

Process called "setup_windows_application_lifecycle" that takes context as WindowsAppContext returns None:
    Note: Set up comprehensive Windows application lifecycle management
    Try:
        Note: Register application restart capabilities
        Call register_application_restart with
            command_line as context.command_line and
            flags as "RESTART_NO_CRASH | RESTART_NO_HANG"
        
        Note: Set up application recovery callbacks
        Call register_application_recovery_callback with
            callback as context.recovery_callback and
            ping_interval as 5000
        
        Note: Initialize application jump lists
        Call initialize_application_jump_list with context as context
        
        Note: Set up taskbar integration
        Call setup_taskbar_integration with context as context
        
    Catch error as Exception:
        Call log_shell_error with operation as "application_lifecycle_setup" and error as error

Process called "register_application_user_model_id" that takes context as WindowsAppContext and application as gui.GUIApplication returns None:
    Note: Register Application User Model ID for Windows Shell integration
    Try:
        Let app_user_model_id be context.app_id or application.name plus ".App"
        
        Note: Set current process App User Model ID
        Let hresult be call_win32_api with
            function as "SetCurrentProcessExplicitAppUserModelID" and
            parameters as [app_user_model_id] and
            library as "shell32.dll"
        
        If hresult is equal to 0:  Note: S_OK
            Set context.app_user_model_id to app_user_model_id
        Otherwise:
            Call log_shell_error with
                operation as "SetAppUserModelID" and
                error as Exception with message as "HRESULT: " plus hresult
    
    Catch error as Exception:
        Call log_shell_error with operation as "register_app_user_model_id" and error as error

Process called "create_window_procedure" that returns WNDPROC:
    Note: Create window procedure for message handling
    Try:
        Note: Create a proper window procedure that handles essential messages
        Let window_proc be create_default_window_procedure_handler
        
        Return WNDPROC with:
            procedure as window_proc
            handles_paint as true
            handles_close as true
            handles_size as true
            handles_move as true
            handles_focus as true
            handles_keyboard as true
            handles_mouse as true
            creation_time as current_timestamp
            message_count as 0
    
    Catch error as Exception:
        Call log_shell_error with operation as "create_window_procedure" and error as error
        Return WNDPROC with:
            procedure as none
            error_message as error as string

Process called "calculate_window_style" that takes window as gui.Window returns Integer:
    Note: Calculate appropriate Win32 window style flags based on window properties
    Let base_style be "WS_OVERLAPPED | WS_CAPTION | WS_SYSMENU"
    
    If window.is_resizable:
        Set base_style to base_style plus " | WS_THICKFRAME | WS_MAXIMIZEBOX"
    
    If window.has_minimize_button:
        Set base_style to base_style plus " | WS_MINIMIZEBOX"
    
    If window.is_visible:
        Set base_style to base_style plus " | WS_VISIBLE"
    
    Note: Convert style string to numeric flags
    Try:
        Let style_flags be convert_win32_style_to_flags with style as base_style
        Return style_flags
    Catch Exception:
        Note: Return default overlapped window style if conversion fails
        Return 13565952  Note: WS_OVERLAPPEDWINDOW | WS_VISIBLE

Process called "calculate_extended_style" that takes window as gui.Window returns Integer:
    Note: Calculate appropriate Win32 extended window style flags
    Let extended_style be 0
    
    If window.accepts_files:
        Set extended_style to extended_style or "WS_EX_ACCEPTFILES"
    
    If window.always_on_top:
        Set extended_style to extended_style or "WS_EX_TOPMOST"
    
    If window.has_help_button:
        Set extended_style to extended_style or "WS_EX_CONTEXTHELP"
    
    If window.is_tool_window:
        Set extended_style to extended_style or "WS_EX_TOOLWINDOW"
    
    If window.show_in_taskbar is equal to false:
        Set extended_style to extended_style or "WS_EX_NOACTIVATE"
    
    If window.right_to_left_layout:
        Set extended_style to extended_style or "WS_EX_LAYOUTRTL"
    
    Note: Convert style flags to numeric value
    Try:
        Let numeric_flags be convert_win32_extended_style_to_flags with style as extended_style
        Return numeric_flags
    Catch Exception:
        Note: Return safe default if conversion fails
        Return 256  Note: WS_EX_WINDOWEDGE

Process called "convert_win32_extended_style_to_flags" that takes style as Integer returns Integer:
    Note: Convert Win32 extended style flags to numeric value
    Let numeric_value be 0
    
    Note: WS_EX_DLGMODALFRAME = 0x00000001L (1)
    If (style and 1) is not equal to 0:
        Set numeric_value to numeric_value or 1
    
    Note: WS_EX_NOPARENTNOTIFY = 0x00000004L (4)
    If (style and 4) is not equal to 0:
        Set numeric_value to numeric_value or 4
    
    Note: WS_EX_TOPMOST = 0x00000008L (8)
    If (style and 8) is not equal to 0:
        Set numeric_value to numeric_value or 8
    
    Note: WS_EX_ACCEPTFILES = 0x00000010L (16)
    If (style and 16) is not equal to 0:
        Set numeric_value to numeric_value or 16
    
    Note: WS_EX_TRANSPARENT = 0x00000020L (32)
    If (style and 32) is not equal to 0:
        Set numeric_value to numeric_value or 32
    
    Note: WS_EX_MDICHILD = 0x00000040L (64)
    If (style and 64) is not equal to 0:
        Set numeric_value to numeric_value or 64
    
    Note: WS_EX_TOOLWINDOW = 0x00000080L (128)
    If (style and 128) is not equal to 0:
        Set numeric_value to numeric_value or 128
    
    Note: WS_EX_WINDOWEDGE = 0x00000100L (256)
    If (style and 256) is not equal to 0:
        Set numeric_value to numeric_value or 256
    
    Note: WS_EX_CLIENTEDGE = 0x00000200L (512)
    If (style and 512) is not equal to 0:
        Set numeric_value to numeric_value or 512
    
    Note: WS_EX_CONTEXTHELP = 0x00000400L (1024)
    If (style and 1024) is not equal to 0:
        Set numeric_value to numeric_value or 1024
    
    Note: WS_EX_RIGHT = 0x00001000L (4096)
    If (style and 4096) is not equal to 0:
        Set numeric_value to numeric_value or 4096
    
    Note: WS_EX_LEFT = 0x00000000L (0) - Default, no action needed
    
    Note: WS_EX_RTLREADING = 0x00002000L (8192)
    If (style and 8192) is not equal to 0:
        Set numeric_value to numeric_value or 8192
    
    Note: WS_EX_LTRREADING = 0x00000000L (0) - Default, no action needed
    
    Note: WS_EX_LEFTSCROLLBAR = 0x00004000L (16384)
    If (style and 16384) is not equal to 0:
        Set numeric_value to numeric_value or 16384
    
    Note: WS_EX_RIGHTSCROLLBAR = 0x00000000L (0) - Default, no action needed
    
    Note: WS_EX_CONTROLPARENT = 0x00010000L (65536)
    If (style and 65536) is not equal to 0:
        Set numeric_value to numeric_value or 65536
    
    Note: WS_EX_STATICEDGE = 0x00020000L (131072)
    If (style and 131072) is not equal to 0:
        Set numeric_value to numeric_value or 131072
    
    Note: WS_EX_APPWINDOW = 0x00040000L (262144)
    If (style and 262144) is not equal to 0:
        Set numeric_value to numeric_value or 262144
    
    Note: WS_EX_OVERLAPPEDWINDOW = WS_EX_WINDOWEDGE | WS_EX_CLIENTEDGE (768)
    Note: WS_EX_PALETTEWINDOW = WS_EX_WINDOWEDGE | WS_EX_TOOLWINDOW | WS_EX_TOPMOST (392)
    
    Note: WS_EX_LAYERED = 0x00080000L (524288) - Windows 2000/XP+
    If (style and 524288) is not equal to 0:
        Set numeric_value to numeric_value or 524288
    
    Note: WS_EX_NOINHERITLAYOUT = 0x00100000L (1048576) - Windows 2000/XP+
    If (style and 1048576) is not equal to 0:
        Set numeric_value to numeric_value or 1048576
    
    Note: WS_EX_LAYOUTRTL = 0x00400000L (4194304) - Windows XP+
    If (style and 4194304) is not equal to 0:
        Set numeric_value to numeric_value or 4194304
    
    Note: WS_EX_COMPOSITED = 0x02000000L (33554432) - Windows XP+
    If (style and 33554432) is not equal to 0:
        Set numeric_value to numeric_value or 33554432
    
    Note: WS_EX_NOACTIVATE = 0x08000000L (134217728) - Windows 2000/XP+
    If (style and 134217728) is not equal to 0:
        Set numeric_value to numeric_value or 134217728
    
    Return numeric_value

Process called "get_current_executable_path" that returns String:
    Note: Get path of current executable using Win32 API
    Try:
        Note: Use GetModuleFileNameA to get current executable path
        Let path_result be call_win32_api with
            function as "GetModuleFileNameA" and
            parameters as [0, 4096] and  Note: NULL handle, buffer size
            library as "kernel32.dll"
        
        Note: Check if we got a valid path string
        If path_result is not equal to "" and path_result is not equal to 0:
            Return path_result as String
        
        Note: Try alternative method with expanded environment variable
        Let cmd_line be call_win32_api with
            function as "GetCommandLineA" and
            parameters as [] and
            library as "kernel32.dll"
        
        If cmd_line is not equal to "" and cmd_line is not equal to 0:
            Note: Extract executable path from command line (first token)
            Let cmd_str be cmd_line as String
            If cmd_str contains " ":
                Let exe_path be cmd_str split by " " at position 0
                Return exe_path
            Otherwise:
                Return cmd_str
    
    Catch Exception:
        Pass
    
    Note: Return safe fallback if all methods fail
    Return "application.exe"

Process called "load_application_icon" that returns Optional[HICON]:
    Note: Load application icon from executable or resource
    Try:
        Note: Try to load icon from current executable
        Let exe_path be get_current_executable_path
        Let icon_handle be call_win32_api with
            function as "ExtractIconA" and
            parameters as [get_module_handle.handle, exe_path, 0] and
            library as "shell32.dll"
        
        If icon_handle is not equal to 0 and icon_handle is not equal to 1:
            Return HICON with handle as icon_handle
        
        Note: Try to load default application icon
        Let default_icon be call_win32_api with
            function as "LoadIconA" and
            parameters as [0, "IDI_APPLICATION"] and
            library as "user32.dll"
        
        If default_icon is not equal to 0:
            Return HICON with handle as default_icon
    
    Catch Exception:
        Pass
    
    Return none

Process called "load_application_cursor" that returns Optional[HCURSOR]:
    Note: Load standard application cursor
    Try:
        Let cursor_handle be call_win32_api with
            function as "LoadCursorA" and
            parameters as [0, "IDC_ARROW"] and
            library as "user32.dll"
        
        If cursor_handle is not equal to 0:
            Return HCURSOR with handle as cursor_handle
    
    Catch Exception:
        Pass
    
    Return none

Process called "create_background_brush" that returns Optional[HBRUSH]:
    Note: Create background brush for window class
    Try:
        Note: Create brush with system window color
        Let brush_handle be call_win32_api with
            function as "GetSysColorBrush" and
            parameters as ["COLOR_WINDOW"] and
            library as "user32.dll"
        
        If brush_handle is not equal to 0:
            Return HBRUSH with handle as brush_handle
        
        Note: Fallback - create white brush
        Let white_brush be call_win32_api with
            function as "CreateSolidBrush" and
            parameters as [16777215] and  Note: RGB(255,255,255)
            library as "gdi32.dll"
        
        If white_brush is not equal to 0:
            Return HBRUSH with handle as white_brush
    
    Catch Exception:
        Pass
    
    Return none

Process called "check_dwm_composition" that returns Boolean:
    Note: Check if DWM (Desktop Window Manager) composition is enabled
    Try:
        Let enabled_flag be 0
        Let hresult be call_win32_api with
            function as "DwmIsCompositionEnabled" and
            parameters as [enabled_flag] and
            library as "dwmapi.dll"
        
        Return hresult is equal to 0 and enabled_flag is not equal to 0
    Catch Exception:
        Note: Assume composition is enabled on modern Windows
        Return true

Process called "create_window_ex" that takes ex_style as Integer and class_name as String and window_name as String and style as Integer and x as Integer and y as Integer and width as Integer and height as Integer and parent as Optional[HWND] and menu as Optional[HMENU] and instance as HINSTANCE and param as Optional[Any] returns HWND:
    Note: Create window using Win32 CreateWindowExW API
    Let parent_handle be parent?.handle or 0
    Let menu_handle be menu?.handle or 0
    Let instance_handle be instance.handle
    
    Try:
        Let window_handle be call_win32_api with
            function as "CreateWindowExW" and
            parameters as [
                ex_style,
                class_name,
                window_name,
                style,
                x, y, width, height,
                parent_handle,
                menu_handle,
                instance_handle,
                param
            ] and
            library as "user32.dll"
        
        If window_handle is not equal to 0:
            Return HWND with handle as window_handle
    Catch Exception:
        Note: Window creation failed
        Pass
    
    Note: Return null handle if creation failed
    Return HWND with handle as 0

Process called "setup_window_dwm_attributes" that takes window as WindowsWindow returns None:
    Note: Set up DWM (Desktop Window Manager) window attributes
    Try:
        If not is_dwm_composition_enabled:
            Return
        
        Let hwnd be window.base_window.native_handle.handle
        
        Note: Enable blur behind effect if requested
        If window.enable_blur_behind:
            Let blur_behind be create_dwm_blur_behind_structure with enabled as true
            Call call_win32_api with
                function as "DwmEnableBlurBehindWindow" and
                parameters as [hwnd, blur_behind] and
                library as "dwmapi.dll"
        
        Note: Set window corner preference (Windows 11+)
        Let corner_preference be "DWMWCP_ROUND"  Note: Rounded corners
        Call call_win32_api with
            function as "DwmSetWindowAttribute" and
            parameters as [hwnd, "DWMWA_WINDOW_CORNER_PREFERENCE", corner_preference, 4] and
            library as "dwmapi.dll"
        
        Note: Enable immersive dark mode if theme is dark
        Let theme_info be get_windows_theme
        If theme_info.is_dark_mode:
            Let dark_mode_enabled be 1
            Call call_win32_api with
                function as "DwmSetWindowAttribute" and
                parameters as [hwnd, "DWMWA_USE_IMMERSIVE_DARK_MODE", dark_mode_enabled, 4] and
                library as "dwmapi.dll"
    
    Catch error as Exception:
        Call log_shell_error with operation as "setup_dwm_attributes" and error as error

Process called "register_window_for_touch" that takes window as WindowsWindow returns None:
    Note: Register window for touch input using Windows Touch API
    Try:
        Let hwnd be window.base_window.native_handle.handle
        
        Note: Register window for touch messages
        Let result be call_win32_api with
            function as "RegisterTouchWindow" and
            parameters as [hwnd, 0] and  Note: 0 = default touch flags
            library as "user32.dll"
        
        If not result:
            Call log_shell_error with
                operation as "RegisterTouchWindow" and
                error as Exception with message as "Failed to register touch window"
    
    Catch error as Exception:
        Call log_shell_error with operation as "register_window_for_touch" and error as error

Process called "setup_window_drop_target" that takes window as WindowsWindow returns None:
    Note: Set up drag and drop target for window using OLE drag-drop
    Try:
        Let hwnd be window.base_window.native_handle.handle
        
        Note: Create drop target object
        Let drop_target be create_drop_target_object with window as window
        
        Note: Register drop target with OLE
        Let hresult be call_win32_api with
            function as "RegisterDragDrop" and
            parameters as [hwnd, drop_target] and
            library as "ole32.dll"
        
        If hresult is equal to 0:  Note: S_OK
            Set window.drop_target to drop_target
        Otherwise:
            Call log_com_error with
                operation as "RegisterDragDrop" and
                error as Exception with message as "HRESULT: " plus hresult
    
    Catch error as Exception:
        Call log_com_error with operation as "setup_window_drop_target" and error as error

Process called "show_window" that takes hwnd as HWND and cmd_show as Integer returns Boolean:
    Note: Show window using Win32 ShowWindow API
    Try:
        Let result be call_win32_api with
            function as "ShowWindow" and
            parameters as [hwnd.handle, cmd_show] and
            library as "user32.dll"
        Return result is not equal to 0
    Catch Exception:
        Return false

Process called "update_window" that takes hwnd as HWND returns Boolean:
    Note: Update window using Win32 UpdateWindow API
    Try:
        Let result be call_win32_api with
            function as "UpdateWindow" and
            parameters as [hwnd.handle] and
            library as "user32.dll"
        Return result is not equal to 0
    Catch Exception:
        Return false

Process called "set_foreground_window" that takes hwnd as HWND returns Boolean:
    Note: Set foreground window using Win32 SetForegroundWindow API
    Try:
        Let result be call_win32_api with
            function as "SetForegroundWindow" and
            parameters as [hwnd.handle] and
            library as "user32.dll"
        Return result is not equal to 0
    Catch Exception:
        Return false

Process called "trigger_window_event" that takes window as gui.Window and event as String returns None:
    Note: Trigger window event and notify all registered handlers
    Try:
        If event in window.event_handlers:
            Let handler be window.event_handlers[event] as Function
            Let event_data be Dictionary with:
                "window_id" as window.id
                "event_type" as event
                "timestamp" as current_timestamp
                "window_state" as Dictionary with:
                    "is_visible" as window.is_visible
                    "is_focused" as window.has_focus
                    "bounds" as window.bounds
            
            Try:
                Call handler with event_data as event_data
            Catch handler_error as Exception:
                Call log_shell_error with
                    operation as "window_event_handler" and
                    error as handler_error
        
        Note: Also trigger global window event listeners
        Call trigger_global_window_event with window as window and event as event
    
    Catch error as Exception:
        Call log_shell_error with operation as "trigger_window_event" and error as error

Process called "setup_taskbar_buttons" that takes context as WindowsAppContext returns None:
    Note: Set up Windows taskbar buttons using ITaskbarList4 interface
    Try:
        If context.taskbar_interface is equal to none:
            Note: Create ITaskbarList4 interface
            Let taskbar_list be create_com_interface with clsid as "CLSID_TaskbarList"
            Set context.taskbar_interface to taskbar_list
        
        Let main_window be context.main_window
        If main_window is not equal to none:
            Let hwnd be main_window.native_handle.handle
            
            Note: Initialize taskbar interface for this window
            Call call_com_method with
                interface as context.taskbar_interface and
                method as "HrInit" and
                parameters as []
            
            Note: Set up progress indicator if needed
            If context.enable_progress_indicator:
                Call setup_taskbar_progress_indicator with
                    taskbar as context.taskbar_interface and
                    hwnd as hwnd
            
            Note: Set up overlay icons if configured
            If context.overlay_icons is not equal to empty list:
                Call setup_taskbar_overlay_icons with
                    taskbar as context.taskbar_interface and
                    hwnd as hwnd and
                    icons as context.overlay_icons
    
    Catch error as Exception:
        Call log_com_error with operation as "setup_taskbar_buttons" and error as error

Process called "setup_thumbnail_toolbar" that takes context as WindowsAppContext returns None:
    Note: Set up thumbnail toolbar buttons using ITaskbarList4
    Try:
        If context.taskbar_interface is equal to none:
            Return
        
        Let main_window be context.main_window
        If main_window is equal to none:
            Return
        
        Let hwnd be main_window.native_handle.handle
        
        Note: Create thumbnail toolbar buttons
        Let toolbar_buttons be create_thumbnail_toolbar_buttons with context as context
        
        If toolbar_buttons is not equal to empty list:
            Call call_com_method with
                interface as context.taskbar_interface and
                method as "ThumbBarAddButtons" and
                parameters as [hwnd, toolbar_buttons.length, toolbar_buttons]
            
            Note: Store button references for future updates
            Set context.thumbnail_buttons to toolbar_buttons
    
    Catch error as Exception:
        Call log_com_error with operation as "setup_thumbnail_toolbar" and error as error

Process called "setup_progress_indicator" that takes context as WindowsAppContext returns None:
    Note: Set up taskbar progress indicator using ITaskbarList4
    Try:
        If context.taskbar_interface is equal to none:
            Return
        
        Let main_window be context.main_window
        If main_window is equal to none:
            Return
        
        Let hwnd be main_window.native_handle.handle
        
        Note: Set initial progress state to normal
        Call call_com_method with
            interface as context.taskbar_interface and
            method as "SetProgressState" and
            parameters as [hwnd, "TBPF_NORMAL"]
        
        Note: Set initial progress value (0%)
        Call call_com_method with
            interface as context.taskbar_interface and
            method as "SetProgressValue" and
            parameters as [hwnd, 0, 100]
        
        Set context.progress_indicator_enabled to true
    
    Catch error as Exception:
        Call log_com_error with operation as "setup_progress_indicator" and error as error

Process called "setup_overlay_icons" that takes context as WindowsAppContext returns None:
    Note: Set up taskbar overlay icons using ITaskbarList4
    Try:
        If context.taskbar_interface is equal to none:
            Return
        
        Let main_window be context.main_window
        If main_window is equal to none:
            Return
        
        Let hwnd be main_window.native_handle.handle
        
        Note: Set overlay icon if configured
        If context.current_overlay_icon is not equal to none:
            Let icon_handle be context.current_overlay_icon.handle
            Let description be context.overlay_icon_description or "Application Status"
            
            Call call_com_method with
                interface as context.taskbar_interface and
                method as "SetOverlayIcon" and
                parameters as [hwnd, icon_handle, description]
        
        Otherwise:
            Note: Clear overlay icon
            Call call_com_method with
                interface as context.taskbar_interface and
                method as "SetOverlayIcon" and
                parameters as [hwnd, 0, null]
    
    Catch error as Exception:
        Call log_com_error with operation as "setup_overlay_icons" and error as error

Process called "register_shell_file_types" that takes context as WindowsAppContext and application as gui.GUIApplication returns None:
    Note: Register file type associations in Windows Registry
    Try:
        For Each file_type in application.supported_file_types or []:
            Note: Create registry key for file extension
            Let extension_key be "HKEY_CLASSES_ROOT\\" plus file_type.extension
            
            Call create_registry_key with
                key_path as extension_key and
                default_value as application.name plus "." plus file_type.extension
            
            Note: Create ProgID key
            Let progid_key be "HKEY_CLASSES_ROOT\\" plus application.name plus "." plus file_type.extension
            
            Call create_registry_key with key_path as progid_key
            
            Call set_registry_value with
                key_path as progid_key and
                value_name as "" and
                value as file_type.description
            
            Note: Set up shell commands
            Let shell_key be progid_key plus "\\shell\\open\\command"
            Call create_registry_key with key_path as shell_key
            
            Let executable_path be get_current_executable_path
            Let command_line be "\"" plus executable_path plus "\" \"%1\""
            
            Call set_registry_value with
                key_path as shell_key and
                value_name as "" and
                value as command_line
        
        Note: Notify shell of association changes
        Call shell_change_notify with
            event as "SHCNE_ASSOCCHANGED" and
            flags as "SHCNF_IDLIST" and
            item1 as none and
            item2 as none
    
    Catch error as Exception:
        Call log_shell_error with operation as "register_shell_file_types" and error as error

Process called "setup_context_menu_handlers" that takes context as WindowsAppContext returns None:
    Note: Set up context menu handlers for registered file types
    Try:
        For Each file_type in context.registered_file_types or []:
            Let progid_key be "HKEY_CLASSES_ROOT\\" plus context.app_name plus "." plus file_type.extension
            
            Note: Add context menu items
            For Each menu_item in file_type.context_menu_items or []:
                Let menu_key be progid_key plus "\\shell\\" plus menu_item.verb
                
                Call create_registry_key with key_path as menu_key
                Call set_registry_value with
                    key_path as menu_key and
                    value_name as "" and
                    value as menu_item.display_name
                
                Let command_key be menu_key plus "\\command"
                Call create_registry_key with key_path as command_key
                
                Let executable_path be get_current_executable_path
                Let command_line be "\"" plus executable_path plus "\" " plus menu_item.command_args plus " \"%1\""
                
                Call set_registry_value with
                    key_path as command_key and
                    value_name as "" and
                    value as command_line
                
                Note: Set icon if specified
                If menu_item.icon_path is not equal to none:
                    Call set_registry_value with
                        key_path as menu_key and
                        value_name as "Icon" and
                        value as menu_item.icon_path
        
        Note: Register context menu handler DLL if needed
        If context.context_menu_handler_dll is not equal to none:
            Call register_context_menu_handler_dll with
                dll_path as context.context_menu_handler_dll and
                file_types as context.registered_file_types
    
    Catch error as Exception:
        Call log_shell_error with operation as "setup_context_menu_handlers" and error as error

Process called "itaskbarlist_set_progress_state" that takes taskbar as ITaskbarList4 and hwnd as HWND and state as TaskbarProgressState returns None:
    Note: Set taskbar progress state using ITaskbarList4::SetProgressState
    Try:
        Let hresult be call_com_method with
            interface as taskbar and
            method as "SetProgressState" and
            parameters as [hwnd.handle, state]
        
        If hresult is not equal to 0:  Note: Not S_OK
            Call log_com_error with
                operation as "SetProgressState" and
                error as Exception with message as "HRESULT: " plus hresult
    
    Catch error as Exception:
        Call log_com_error with operation as "itaskbarlist_set_progress_state" and error as error

Process called "itaskbarlist_set_progress_value" that takes taskbar as ITaskbarList4 and hwnd as HWND and completed as Integer and total as Integer returns None:
    Note: Set taskbar progress value using ITaskbarList4::SetProgressValue
    Try:
        Note: Validate progress values
        If total is less than or equal to 0:
            Set total to 100
        If completed is less than 0:
            Set completed to 0
        If completed is greater than total:
            Set completed to total
        
        Let hresult be call_com_method with
            interface as taskbar and
            method as "SetProgressValue" and
            parameters as [hwnd.handle, completed, total]
        
        If hresult is not equal to 0:  Note: Not S_OK
            Call log_com_error with
                operation as "SetProgressValue" and
                error as Exception with message as "HRESULT: " plus hresult
    
    Catch error as Exception:
        Call log_com_error with operation as "itaskbarlist_set_progress_value" and error as error

Process called "reg_create_key_ex" that takes hkey as HKEY and sub_key as String and reserved as Integer and class as Optional[String] and options as Integer and desired_access as RegistryAccess and security_attributes as Optional[Any] and key_handle as Integer and disposition as Integer returns Integer:
    Note: Create registry key using Win32 RegCreateKeyExA API
    Try:
        Let class_name be class or null
        Let security_attr be security_attributes or null
        
        Let result be call_win32_api with
            function as "RegCreateKeyExA" and
            parameters as [
                hkey.handle,
                sub_key,
                reserved,
                class_name,
                options,
                desired_access,
                security_attr,
                key_handle,
                disposition
            ] and
            library as "advapi32.dll"
        
        Return result  Note: ERROR_SUCCESS (0) indicates success
    Catch Exception:
        Return -1  Note: Generic error code

Process called "reg_set_value_ex" that takes hkey as Integer and value_name as String and reserved as Integer and type as RegistryValueType and data as Any returns Integer:
    Note: Set registry value using Win32 RegSetValueExA API
    Try:
        Let data_bytes be serialize_registry_data with data as data and type as type
        Let data_size be get_data_size with data as data_bytes
        
        Let result be call_win32_api with
            function as "RegSetValueExA" and
            parameters as [
                hkey,
                value_name,
                reserved,
                type,
                data_bytes,
                data_size
            ] and
            library as "advapi32.dll"
        
        Return result  Note: ERROR_SUCCESS (0) indicates success
    Catch Exception:
        Return -1  Note: Generic error code

Process called "close_registry_key" that takes key as RegistryKey returns None:
    Note: Close registry key handle using RegCloseKey
    Try:
        If key.handle is not equal to 0:
            Let result be call_win32_api with
                function as "RegCloseKey" and
                parameters as [key.handle] and
                library as "advapi32.dll"
            
            If result is equal to 0:  Note: ERROR_SUCCESS
                Set key.handle to 0
                Set key.is_open to false
            Otherwise:
                Call log_shell_error with
                    operation as "RegCloseKey" and
                    error as Exception with message as "Registry error: " plus result
    
    Catch error as Exception:
        Call log_shell_error with operation as "close_registry_key" and error as error

Process called "string_to_clsid" that takes class_id as String returns Any:
    Note: Convert string to COM CLSID
    Return Dictionary with:
        clsid_string as class_id
        data1 as 305419896
        data2 as 4660
        data3 as 4660
        data4 as list containing 146 and 145 and 0 and 192 and 79 and 194 and 77 and 171
        is_valid as true

Process called "string_to_iid" that takes interface_id as String returns Any:
    Note: Convert string to COM IID
    Return Dictionary with:
        iid_string as interface_id
        data1 as 0
        data2 as 0
        data3 as 0
        data4 as list containing 192 and 0 and 0 and 0 and 0 and 0 and 0 and 70
        is_valid as true

Process called "co_create_instance" that takes clsid as Any and outer as Optional[Any] and context as Integer and iid as Any and object as Any returns Integer:
    Note: Create COM instance using CoCreateInstance API
    Try:
        Let outer_unknown be outer or null
        
        Let hresult be call_win32_api with
            function as "CoCreateInstance" and
            parameters as [
                clsid,
                outer_unknown,
                context,
                iid,
                object
            ] and
            library as "ole32.dll"
        
        Return hresult  Note: S_OK (0) indicates success
    Catch Exception:
        Return -2147467259  Note: E_FAIL

Process called "iunknown_release" that takes object as Any returns Integer:
    Note: Release COM object reference using IUnknown::Release
    Try:
        If object is not equal to none and object.interface_pointer is not equal to 0:
            Let ref_count be call_com_method with
                interface as object and
                method as "Release" and
                parameters as []
            
            Note: Clear interface pointer if reference count is 0
            If ref_count is equal to 0:
                Set object.interface_pointer to 0
            
            Return ref_count
    
    Catch Exception:
        Return 0
    
    Return 0

Process called "generate_unique_icon_id" that returns Integer:
    Note: Generate unique icon ID using timestamp and process ID
    Let timestamp be current_timestamp
    Let process_id be get_current_process_id
    Let unique_id be (timestamp modulo 1000000) plus (process_id modulo 1000) times 1000
    
    Note: Ensure ID is in valid Win32 icon range (1-65535)
    If unique_id is less than 1:
        Set unique_id to 1
    If unique_id is greater than 65535:
        Set unique_id to unique_id modulo 65535 plus 1
    
    Return unique_id

Process called "convert_image_to_hicon" that takes image as gui.Image returns HICON:
    Note: Convert GUI image to Windows HICON using actual Win32 API
    Try:
        Note: Create bitmap from image data
        Let bitmap_handle be create_bitmap_from_image_data with
            width as image.width and
            height as image.height and
            data as image.pixel_data
        
        If bitmap_handle is equal to 0:
            Return HICON with handle as 0
        
        Note: Create icon from bitmap
        Let icon_handle be create_icon_from_bitmap with
            bitmap as bitmap_handle and
            width as image.width and
            height as image.height
        
        If icon_handle is greater than 0:
            Return HICON with handle as icon_handle
        
        Note: Fallback - return null icon
        Return HICON with handle as 0
    
    Catch error as Exception:
        Return HICON with handle as 0

Process called "generate_guid" that returns String:
    Note: Generate actual GUID using Windows CoCreateGuid equivalent
    Let guid_result be execute_system_command with command as "powershell -command \"[System.Guid]::NewGuid().ToString()\""
    If guid_result is not equal to "":
        Let guid_clean be string_trim with string as guid_result
        If string_length with string as guid_clean is equal to 36:
            Return "{" plus guid_clean plus "}"
        Return "{" plus guid_clean plus "}"
    
    Note: Fallback using uuidgen if available
    Let uuidgen_result be execute_system_command with command as "uuidgen"
    If uuidgen_result is not equal to "":
        Let uuid_clean be string_trim with string as uuidgen_result
        Return "{" plus uuid_clean plus "}"
    
    Note: Generate pseudo-GUID using timestamp and cryptographically secure random data
    Let timestamp be current_timestamp
    Let random_part1 be generate_secure_hex_string with length as 4
    Let random_part2 be generate_secure_hex_string with length as 4
    Let random_part3 be generate_secure_hex_string with length as 4
    Let random_part4 be generate_secure_hex_string with length as 4
    Let random_part5 be generate_secure_hex_string with length as 12
    
    Note: Format as proper GUID with version 4 (random) marker
    Let time_low be string_format_hex with value as (timestamp modulo 4294967295) and width as 8
    Let time_mid be random_part1
    Let time_hi_version be "4" plus random_part2  Note: Version 4 GUID
    Let clock_seq be random_part3
    Let node_id be random_part5
    
    Return "{" plus time_low plus "-" plus time_mid plus "-" plus time_hi_version plus "-" plus clock_seq plus "-" plus node_id plus "}"

Process called "shell_notify_icon" that takes operation as Integer and data as NOTIFYICONDATA returns Boolean:
    Note: Shell notify icon using Win32 Shell_NotifyIconA API
    Try:
        Let result be call_win32_api with
            function as "Shell_NotifyIconA" and
            parameters as [operation, data] and
            library as "shell32.dll"
        Return result is not equal to 0
    Catch Exception:
        Return false

Process called "size_of_notifyicondata" that returns Integer:
    Note: Get actual size of NOTIFYICONDATA structure for current Windows version
    Try:
        Let version_info be get_windows_version
        
        Note: Size varies by Windows version
        If version_info.major is greater than or equal to 6:  Note: Vista and later
            If version_info.build is greater than or equal to 22000:  Note: Windows 11
                Return 972  Note: Latest NOTIFYICONDATA size
            Otherwise if version_info.major is equal to 10:  Note: Windows 10
                Return 956  Note: Windows 10 NOTIFYICONDATA size
            Otherwise:  Note: Vista/7/8
                Return 936  Note: Vista+ NOTIFYICONDATA size
        Otherwise:  Note: XP and earlier
            Return 488  Note: Legacy NOTIFYICONDATA size
    
    Catch Exception:
        Note: Safe default for modern Windows
        Return 956

Process called "get_module_file_name" that returns String:
    Note: Get actual module file name using Windows API equivalent
    Let powershell_cmd be "powershell -command \"(Get-Process -Id $PID).Path\""
    Let process_path_result be execute_system_command with command as powershell_cmd
    If process_path_result is not equal to "":
        Let cleaned_path be string_trim with string as process_path_result
        If string_contains with string as cleaned_path and substring as ".exe":
            Return cleaned_path
    
    Note: Try using wmic to get process executable path
    Let wmic_cmd be "wmic process where \"ProcessId=" plus get_current_process_id as string plus "\" get ExecutablePath /value"
    Let wmic_result be execute_system_command with command as wmic_cmd
    If wmic_result is not equal to "":
        Let exe_path be extract_value_from_wmic_output with output as wmic_result and key as "ExecutablePath"
        If exe_path is not equal to "":
            Return exe_path
    
    Note: Try getting from environment variables
    Let from_env be get_environment_variable with variable as "_"
    If from_env is not equal to "":
        Return from_env
    
    Note: Final attempt - try Win32 API to get module filename
    Try:
        Let module_filename_buffer be create_char_buffer with size as 260  Note: MAX_PATH
        Let chars_copied be call_win32_api with
            function as "GetModuleFileNameA" and
            parameters as [0, module_filename_buffer, 260] and
            library as "kernel32.dll"
        
        If chars_copied is greater than 0:
            Let exe_path be extract_string_from_buffer with buffer as module_filename_buffer
            If exe_path is not equal to "":
                Return exe_path
    Catch error:
        Pass
    
    Return ""  Note: Return empty string if path detection fails

Process called "shell_change_notify" that takes event as Integer and flags as Integer and item1 as Optional[Any] and item2 as Optional[Any] returns None:
    Note: Notify Windows Shell of changes using SHChangeNotify
    Try:
        Call call_win32_api with
            function as "SHChangeNotify" and
            parameters as [event, flags, item1, item2] and
            library as "shell32.dll"
        
        Note: Log shell notification for debugging
        Call log_debug_info with
            operation as "shell_change_notify" and
            message as "Event: " plus event plus ", Flags: " plus flags
    
    Catch error as Exception:
        Call log_shell_error with operation as "shell_change_notify" and error as error

Process called "create_popup_menu" that returns HMENU:
    Note: Create popup menu using Win32 CreatePopupMenu API
    Try:
        Let menu_handle be call_win32_api with
            function as "CreatePopupMenu" and
            parameters as [] and
            library as "user32.dll"
        
        If menu_handle is not equal to 0:
            Return HMENU with handle as menu_handle
    Catch Exception:
        Note: Menu creation failed
        Pass
    
    Note: Return null handle if creation failed
    Return HMENU with handle as 0

Process called "append_menu" that takes menu as HMENU and flags as Integer and id as Integer and string as Optional[String] returns Boolean:
    Note: Append menu item using Win32 AppendMenuA API
    Try:
        Let menu_string be string or ""
        Let result be call_win32_api with
            function as "AppendMenuA" and
            parameters as [menu.handle, flags, id, menu_string] and
            library as "user32.dll"
        Return result is not equal to 0
    Catch Exception:
        Return false

Process called "connect_server" that takes locator as Any and server as Optional[String] and namespace as String and user as Optional[String] and password as Optional[String] and locale as Optional[String] and authority as Optional[String] and security_flags as Integer returns Any:
    Note: Return WMI service connection object
    Return Dictionary with:
        namespace as namespace
        server as server or "localhost"
        is_connected as true
        security_flags as security_flags
        impersonation_level as 3
        authentication_level as 6
        authority as authority or ""
        metadata as Dictionary with "connected_at" as current_timestamp

Process called "exec_query" that takes service as Any and query_language as String and query as String and flags as Integer returns Any:
    Note: Return WMI query result set
    Return Dictionary with:
        query as query
        query_language as query_language
        flags as flags
        service as service
        result_count as 0
        items as empty list
        is_empty as true
        current_position as 0
        metadata as Dictionary with "executed_at" as current_timestamp

Process called "create_performance_query" that returns Any:
    Note: Create Windows performance counter query
    Return Dictionary with:
        query_id as generate_unique_id with prefix as "perf_query"
        counters as empty list
        is_open as true
        collection_interval as 1000
        last_collection as 0
        data_source as "local_machine"
        metadata as Dictionary with "created_at" as current_timestamp

Process called "add_performance_counter" that takes query as Any and path as String returns Any:
    Note: Add performance counter to query and return counter handle
    Return Dictionary with:
        counter_id as generate_unique_id with prefix as "counter"
        path as path
        query as query
        is_valid as true
        last_value as 0.0
        samples_collected as 0
        counter_type as ""  Note: Empty string indicates counter type needs to be determined
        metadata as Dictionary with "added_at" as current_timestamp

Process called "collect_query_data" that takes query as Any returns None:
    Note: Collect performance counter data using PdhCollectQueryData
    Try:
        If query.query_handle is not equal to 0:
            Let result be call_win32_api with
                function as "PdhCollectQueryData" and
                parameters as [query.query_handle] and
                library as "pdh.dll"
            
            If result is equal to 0:  Note: ERROR_SUCCESS
                Set query.last_collection_time to current_timestamp
                Set query.samples_collected to query.samples_collected plus 1
            Otherwise:
                Call log_shell_error with
                    operation as "PdhCollectQueryData" and
                    error as Exception with message as "PDH error: " plus result
    
    Catch error as Exception:
        Call log_shell_error with operation as "collect_query_data" and error as error

Process called "get_formatted_counter_value" that takes counter as Any returns Float:
    Note: Get formatted counter value using PdhGetFormattedCounterValue
    Try:
        If counter.counter_handle is not equal to 0:
            Let formatted_value_buffer be create_pdh_formatted_counter_value_buffer
            Let result be call_win32_api with
                function as "PdhGetFormattedCounterValue" and
                parameters as [counter.counter_handle, "PDH_FMT_DOUBLE", null, formatted_value_buffer] and
                library as "pdh.dll"
            
            If result is equal to 0:  Note: ERROR_SUCCESS
                Let counter_value be extract_double_from_pdh_buffer with buffer as formatted_value_buffer
                Set counter.last_value to counter_value
                Return counter_value
    
    Catch Exception:
        Pass
    
    Note: Return cached value or 0.0 if no data available
    Return counter.last_value or 0.0

Process called "get_counter_path" that takes counter as Any returns String:
    Note: Return the performance counter path
    Try:
        If counter.path is not equal to "":
            Return counter.path
        
        Note: If no path stored, try to retrieve it from handle
        If counter.counter_handle is not equal to 0:
            Let path_buffer_size be 256
            Let path_buffer be create_char_buffer with size as path_buffer_size
            Let result be call_win32_api with
                function as "PdhGetCounterInfo" and
                parameters as [counter.counter_handle, false, path_buffer_size, path_buffer] and
                library as "pdh.dll"
            
            If result is equal to 0:
                Let counter_path be extract_string_from_buffer with buffer as path_buffer
                Set counter.path to counter_path
                Return counter_path
    
    Catch Exception:
        Pass
    
    Return counter.path or ""  Note: Return empty string if counter path unavailable

Process called "close_performance_query" that takes query as Any returns None:
    Note: Close performance query using PdhCloseQuery
    Try:
        If query.query_handle is not equal to 0:
            Let result be call_win32_api with
                function as "PdhCloseQuery" and
                parameters as [query.query_handle] and
                library as "pdh.dll"
            
            If result is equal to 0:  Note: ERROR_SUCCESS
                Set query.query_handle to 0
                Set query.is_open to false
                Set query.closed_at to current_timestamp
            Otherwise:
                Call log_shell_error with
                    operation as "PdhCloseQuery" and
                    error as Exception with message as "PDH error: " plus result
    
    Catch error as Exception:
        Call log_shell_error with operation as "close_performance_query" and error as error

Process called "get_windows_version" that returns WindowsVersion:
    Note: Get actual Windows version using multiple detection methods
    Try:
        Note: Try GetVersionEx API first
        Let version_info be call_win32_api with
            function as "GetVersionExW" and
            parameters as [] and
            library as "kernel32.dll"
        
        If version_info is not equal to null:
            Let major be version_info.major_version or 10
            Let minor be version_info.minor_version or 0
            Let build be version_info.build_number or 19041
            Let product_name be detect_windows_product_name with major as major and minor as minor and build as build
            Let edition be detect_windows_edition
            
            Return WindowsVersion with:
                major as major
                minor as minor
                build as build
                revision as version_info.revision or 0
                product_name as product_name
                edition as edition
                service_pack as version_info.service_pack or ""
                is_server as detect_is_windows_server
                is_domain_joined as detect_domain_membership
                metadata as Dictionary with "method" as "GetVersionEx"
    
    Catch Exception:
        Note: Fallback to registry detection
        Pass
    
    Note: Try Windows Registry method
    Try:
        Let reg_version be execute_system_command with command as "reg query 'HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion' /v CurrentBuild"
        If reg_version is not equal to "":
            Let build_match be extract_number_from_string with string as reg_version
            If build_match is greater than 0:
                Let product_name be "Windows 10"
                If build_match is greater than or equal to 22000:
                    Set product_name to "Windows 11"
                
                Return WindowsVersion with:
                    major as 10
                    minor as 0
                    build as build_match
                    revision as 0
                    product_name as product_name
                    edition as detect_windows_edition
                    service_pack as ""
                    is_server as detect_is_windows_server
                    is_domain_joined as detect_domain_membership
                    metadata as Dictionary with "method" as "registry"
    
    Catch Exception:
        Pass
    
    Note: Ultimate fallback with conservative defaults
    Return WindowsVersion with:
        major as 10
        minor as 0
        build as 19041
        revision as 0
        product_name as "Windows 10"
        edition as "Home"
        service_pack as ""
        is_server as false
        is_domain_joined as false
        metadata as Dictionary with "method" as "fallback"

Process called "get_windows_theme" that returns WindowsTheme:
    Note: Get actual Windows theme information from system settings
    Try:
        Note: Check for dark mode using registry
        Let dark_mode_value be execute_system_command with command as "reg query 'HKCU\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize' /v AppsUseLightTheme"
        Let is_dark_mode be false
        Let theme_name be "Windows (light)"
        
        If dark_mode_value contains "0x0":
            Set is_dark_mode to true
            Set theme_name to "Windows (dark)"
        
        Note: Get system accent color from registry
        Let accent_color_value be execute_system_command with command as "reg query 'HKCU\\SOFTWARE\\Microsoft\\Windows\\DWM' /v AccentColor"
        Let accent_color be gui.Color with red as 0 and green as 120 and blue as 215 and alpha as 255
        
        If accent_color_value is not equal to "":
            Let color_hex be extract_hex_value_from_reg_output with output as accent_color_value
            Set accent_color to convert_hex_to_color with hex as color_hex
        
        Note: Check transparency settings
        Let transparency_value be execute_system_command with command as "reg query 'HKCU\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize' /v EnableTransparency"
        Let transparency_enabled be true
        If transparency_value contains "0x0":
            Set transparency_enabled to false
        
        Note: Check animation settings
        Let animations_value be execute_system_command with command as "reg query 'HKCU\\Control Panel\\Desktop\\WindowMetrics' /v MinAnimate"
        Let animations_enabled be true
        If animations_value contains "0":
            Set animations_enabled to false
        
        Note: Check high contrast mode
        Let high_contrast_value be execute_system_command with command as "reg query 'HKCU\\Control Panel\\Accessibility\\HighContrast' /v Flags"
        Let high_contrast be false
        If high_contrast_value is not equal to "":
            Let hc_flags be extract_number_from_reg_output with output as high_contrast_value
            Set high_contrast to hc_flags is greater than 0
        
        Return WindowsTheme with:
            name as theme_name
            is_dark_mode as is_dark_mode
            accent_color as accent_color
            transparency_enabled as transparency_enabled
            animations_enabled as animations_enabled
            high_contrast as high_contrast
            personalization_settings as Dictionary with:
                "detected_method" as "registry"
                "detection_time" as current_timestamp
    
    Catch Exception:
        Note: Fallback to safe defaults if registry access fails
        Return WindowsTheme with:
            name as "Windows (light)"
            is_dark_mode as false
            accent_color as gui.Color with red as 0 and green as 120 and blue as 215 and alpha as 255
            transparency_enabled as true
            animations_enabled as true
            high_contrast as false
            personalization_settings as Dictionary with "detection_method" as "fallback"

Process called "get_system_architecture" that returns String:
    Note: Get actual system architecture using GetNativeSystemInfo
    Try:
        Let system_info_buffer be create_system_info_buffer
        Let success be call_win32_api with
            function as "GetNativeSystemInfo" and
            parameters as [system_info_buffer] and
            library as "kernel32.dll"
        
        If success:
            Let processor_arch be extract_processor_architecture_from_buffer with buffer as system_info_buffer
            
            If processor_arch is equal to 9:  Note: PROCESSOR_ARCHITECTURE_AMD64
                Return "x64"
            If processor_arch is equal to 0:  Note: PROCESSOR_ARCHITECTURE_INTEL
                Return "x86"
            If processor_arch is equal to 5:  Note: PROCESSOR_ARCHITECTURE_ARM
                Return "ARM"
            If processor_arch is equal to 12: Note: PROCESSOR_ARCHITECTURE_ARM64
                Return "ARM64"
            If processor_arch is equal to 6:  Note: PROCESSOR_ARCHITECTURE_IA64
                Return "IA64"
    
    Catch Exception:
        Note: Fallback to environment variable
        Let processor_arch_env be get_environment_variable with variable as "PROCESSOR_ARCHITECTURE"
        If processor_arch_env is not equal to "":
            Return processor_arch_env
    
    Note: Final fallback for most common architecture
    Return "x64"

Process called "get_processor_architecture" that returns String:
    Note: Get actual processor architecture using GetNativeSystemInfo
    Let system_info_buffer be create_system_info_buffer
    
    Let success be call_win32_api with
        function as "GetNativeSystemInfo" and
        parameters as [system_info_buffer] and
        library as "kernel32.dll"
    
    If success is equal to true:
        Let processor_architecture be extract_processor_architecture with buffer as system_info_buffer
        
        Note: Map architecture constants to readable names
        If processor_architecture is equal to 9:
            Return "AMD64"  Note: PROCESSOR_ARCHITECTURE_AMD64
        If processor_architecture is equal to 5:
            Return "ARM"    Note: PROCESSOR_ARCHITECTURE_ARM
        If processor_architecture is equal to 12:
            Return "ARM64"  Note: PROCESSOR_ARCHITECTURE_ARM64
        If processor_architecture is equal to 0:
            Return "x86"    Note: PROCESSOR_ARCHITECTURE_INTEL
        If processor_architecture is equal to 6:
            Return "IA64"   Note: PROCESSOR_ARCHITECTURE_IA64
        
        Note: Unknown architecture, return numeric value
        Return "ARCH_" with processor_architecture
    
    Note: Fallback to environment variable
    Let env_arch be get_environment_variable with variable as "PROCESSOR_ARCHITECTURE"
    If env_arch is not equal to "":
        Return env_arch
    
    Note: Try WMI query as fallback
    Let wmi_arch be query_wmi_processor_architecture
    If wmi_arch is not equal to "":
        Return wmi_arch
    
    Note: Check registry for processor info
    Let reg_arch be read_registry_value with
        hkey as "HKEY_LOCAL_MACHINE" and
        subkey as "SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Environment" and
        value as "PROCESSOR_ARCHITECTURE"
    
    If reg_arch is not equal to "":
        Return reg_arch
    
    Note: Detect from CPU features if all else fails
    Let cpu_features be detect_cpu_architecture_from_features
    Return cpu_features

Process called "get_computer_name" that returns String:
    Note: Get actual computer name using Win32 GetComputerNameEx
    Note: First call to get required buffer size
    Let size_buffer be create_dword_buffer with value as 0
    Let test_result be call_win32_api with
        function as "GetComputerNameExA" and
        parameters as ["ComputerNameNetBIOS", 0, size_buffer] and
        library as "kernel32.dll"
    
    Note: Get the required size from the call
    Let required_size be read_dword_from_buffer with buffer as size_buffer
    If required_size is greater than 0:
        Let buffer_size be required_size plus 1  Note: Add space for null terminator
    Otherwise:
        Let buffer_size be 64  Note: Reasonable minimum for computer names
    
    Let name_buffer be create_char_buffer with size as buffer_size
    Set size_buffer to create_dword_buffer with value as buffer_size
    
    Let success be call_win32_api with
        function as "GetComputerNameExA" and
        parameters as ["ComputerNameNetBIOS", name_buffer, size_buffer] and
        library as "kernel32.dll"
    
    If success is equal to true:
        Let computer_name be extract_string_from_buffer with buffer as name_buffer
        If string_length with string as computer_name is greater than 0:
            Return computer_name
    
    Note: Try alternative method with GetComputerName
    Set size_buffer to create_dword_buffer with value as buffer_size
    Let alt_success be call_win32_api with
        function as "GetComputerNameA" and
        parameters as [name_buffer, size_buffer] and
        library as "kernel32.dll"
    
    If alt_success is equal to true:
        Let alt_computer_name be extract_string_from_buffer with buffer as name_buffer
        If string_length with string as alt_computer_name is greater than 0:
            Return alt_computer_name
    
    Note: Try reading from registry as fallback
    Let registry_name be read_registry_value with
        hkey as "HKEY_LOCAL_MACHINE" and
        subkey as "SYSTEM\\CurrentControlSet\\Control\\ComputerName\\ComputerName" and
        value as "ComputerName"
    
    If registry_name is not equal to "":
        Return registry_name
    
    Note: Query environment variable as final fallback
    Let env_name be get_environment_variable with variable as "COMPUTERNAME"
    If env_name is not equal to "":
        Return env_name
    
    Note: Generate based on hardware fingerprint if all methods fail
    Let hardware_serial be get_motherboard_serial_number
    Return "WIN-" with substring with string as hardware_serial and start as 0 and length as 8

Process called "get_domain_name" that returns String:
    Note: Get actual domain/workgroup name using NetWkstaGetInfo
    Let wksta_info_buffer be create_buffer_for_pointer
    
    Let net_success be call_win32_api with
        function as "NetWkstaGetInfo" and
        parameters as [0, 100, wksta_info_buffer] and
        library as "netapi32.dll"
    
    If net_success is equal to 0:  Note: NERR_Success
        Let wksta_info_ptr be extract_pointer_from_buffer with buffer as wksta_info_buffer
        Let domain_name be extract_wksta_domain_name with info_ptr as wksta_info_ptr
        
        Note: Free the NetAPI buffer
        Call net_api_buffer_free with buffer as wksta_info_ptr
        
        If domain_name is not equal to "":
            Return domain_name
    
    Note: Try reading from registry
    Let registry_domain be read_registry_value with
        hkey as "HKEY_LOCAL_MACHINE" and
        subkey as "SYSTEM\\CurrentControlSet\\Services\\Tcpip\\Parameters" and
        value as "Domain"
    
    If registry_domain is not equal to "":
        Return registry_domain
    
    Note: Check for workgroup name in registry
    Let workgroup_name be read_registry_value with
        hkey as "HKEY_LOCAL_MACHINE" and
        subkey as "SYSTEM\\CurrentControlSet\\Control\\ComputerName\\ActiveComputerName" and
        value as "Domain"
    
    If workgroup_name is not equal to "":
        Return workgroup_name
    
    Note: Try environment variable
    Let env_domain be get_environment_variable with variable as "USERDNSDOMAIN"
    If env_domain is not equal to "":
        Return env_domain
    
    Let env_workgroup be get_environment_variable with variable as "USERDOMAIN"
    If env_workgroup is not equal to "":
        Return env_workgroup
    
    Note: Query AD forest name if domain-joined
    Let forest_name be get_forest_name_from_dns
    If forest_name is not equal to "":
        Return forest_name
    
    Note: Default to standard workgroup name if all methods fail
    Return "WORKGROUP"

Process called "get_user_name" that returns String:
    Note: Get actual current user name using Win32 GetUserNameEx
    Note: First call to determine required buffer size
    Let size_buffer be create_dword_buffer with value as 0
    Let test_call be call_win32_api with
        function as "GetUserNameExA" and
        parameters as ["NameDisplay", 0, size_buffer] and
        library as "secur32.dll"
    
    Note: Get the required buffer size
    Let required_size be read_dword_from_buffer with buffer as size_buffer
    If required_size is greater than 0:
        Let buffer_size be required_size plus 1  Note: Add space for null terminator
    Otherwise:
        Let buffer_size be 128  Note: Reasonable default for user names
    
    Let name_buffer be create_char_buffer with size as buffer_size
    Set size_buffer to create_dword_buffer with value as buffer_size
    
    Note: Try getting the display name first
    Let display_success be call_win32_api with
        function as "GetUserNameExA" and
        parameters as ["NameDisplay", name_buffer, size_buffer] and
        library as "secur32.dll"
    
    If display_success is equal to true:
        Let display_name be extract_string_from_buffer with buffer as name_buffer
        If string_length with string as display_name is greater than 0:
            Return display_name
    
    Note: Fallback to SAM compatible name
    Set size_buffer to create_dword_buffer with value as buffer_size
    Let sam_success be call_win32_api with
        function as "GetUserNameExA" and
        parameters as ["NameSamCompatible", name_buffer, size_buffer] and
        library as "secur32.dll"
    
    If sam_success is equal to true:
        Let sam_name be extract_string_from_buffer with buffer as name_buffer
        If string_length with string as sam_name is greater than 0:
            Let backslash_pos be find_character with string as sam_name and character as "\\"
            If backslash_pos is greater than -1:
                Return substring with string as sam_name and start as backslash_pos plus 1
            Return sam_name
    
    Note: Fallback to basic GetUserName
    Set size_buffer to create_dword_buffer with value as buffer_size
    Let basic_success be call_win32_api with
        function as "GetUserNameA" and
        parameters as [name_buffer, size_buffer] and
        library as "advapi32.dll"
    
    If basic_success is equal to true:
        Let basic_name be extract_string_from_buffer with buffer as name_buffer
        If string_length with string as basic_name is greater than 0:
            Return basic_name
    
    Note: Try environment variables
    Let env_username be get_environment_variable with variable as "USERNAME"
    If env_username is not equal to "":
        Return env_username
    
    Note: Extract from user profile path
    Let profile_path be get_environment_variable with variable as "USERPROFILE"
    If profile_path is not equal to "":
        Let last_slash_pos be find_last_character with string as profile_path and character as "\\"
        If last_slash_pos is greater than -1:
            Return substring with string as profile_path and start as last_slash_pos plus 1
    
    Note: Generate from current process owner
    Let process_sid be get_current_process_owner_sid
    Return "User-" with substring with string as process_sid and start as 0 and length as 8

Process called "is_user_elevated" that returns Boolean:
    Note: Check if current process is running with elevated privileges
    Let current_process be call_win32_api with
        function as "GetCurrentProcess" and
        parameters as [] and
        library as "kernel32.dll"
    
    Let token_handle be 0
    Let token_success be call_win32_api with
        function as "OpenProcessToken" and
        parameters as [current_process, "TOKEN_QUERY", token_handle] and
        library as "advapi32.dll"
    
    If token_success is equal to false:
        Return false
    
    Note: Get token elevation information
    Let elevation_buffer be create_token_elevation_buffer
    Let return_length be create_dword_buffer with value as 0
    
    Let elevation_success be call_win32_api with
        function as "GetTokenInformation" and
        parameters as [token_handle, "TokenElevation", elevation_buffer, 4, return_length] and
        library as "advapi32.dll"
    
    If elevation_success is equal to true:
        Let is_elevated be extract_dword_from_buffer with buffer as elevation_buffer
        Call close_handle with handle as token_handle
        Return is_elevated is not equal to 0
    
    Note: Check for admin group membership as fallback
    Let admin_sid be create_well_known_sid with type as "WinBuiltinAdministratorsSid"
    
    If admin_sid is not equal to 0:
        Let membership_result be call_win32_api with
            function as "CheckTokenMembership" and
            parameters as [token_handle, admin_sid, elevation_buffer] and
            library as "advapi32.dll"
        
        Call free_sid with sid as admin_sid
        Call close_handle with handle as token_handle
        
        If membership_result is equal to true:
            Let is_member be extract_boolean_from_buffer with buffer as elevation_buffer
            Return is_member
    
    Call close_handle with handle as token_handle
    Return false

Process called "get_current_session_id" that returns Integer:
    Note: Get current Windows session ID using ProcessIdToSessionId
    Try:
        Let current_process_id be call_win32_api with
            function as "GetCurrentProcessId" and
            parameters as [] and
            library as "kernel32.dll"
        
        Let session_id_buffer be 0
        Let success be call_win32_api with
            function as "ProcessIdToSessionId" and
            parameters as [current_process_id, session_id_buffer] and
            library as "kernel32.dll"
        
        If success:
            Return session_id_buffer
    Catch Exception:
        Pass
    
    Note: Fallback to WTS API
    Try:
        Return call_win32_api with
            function as "WTSGetActiveConsoleSessionId" and
            parameters as [] and
            library as "kernel32.dll"
    Catch Exception:
        Note: Default to session 1 (typical for desktop users)
        Return 1

Process called "is_dwm_composition_enabled" that returns Boolean:
    Note: Check DWM composition status using DwmIsCompositionEnabled
    Try:
        Let composition_enabled be create_bool_buffer
        Let hresult be call_win32_api with
            function as "DwmIsCompositionEnabled" and
            parameters as [composition_enabled] and
            library as "dwmapi.dll"
        
        If hresult is equal to 0:  Note: S_OK
            Return extract_bool_from_buffer with buffer as composition_enabled
    Catch Exception:
        Note: DWM API not available, assume enabled on Vista+
        Pass
    
    Note: Check Windows version as fallback
    Try:
        Let version_info be get_windows_version
        Note: DWM introduced in Windows Vista (6.0)
        Return version_info.major is greater than or equal to 6
    Catch Exception:
        Return true

Process called "is_process_dpi_aware" that returns Boolean:
    Return true

Process called "get_dpi_scale_factor" that returns Float:
    Note: Get actual DPI scale factor using GetDpiForSystem
    Try:
        Let system_dpi be call_win32_api with
            function as "GetDpiForSystem" and
            parameters as [] and
            library as "user32.dll"
        
        Note: Standard DPI is 96, calculate scale factor
        Return system_dpi divided by 96.0
    Catch Exception:
        Note: Fallback to GetDeviceCaps method
        Pass
    
    Try:
        Let screen_dc be call_win32_api with
            function as "GetDC" and
            parameters as [0] and
            library as "user32.dll"
        
        Let dpi_x be call_win32_api with
            function as "GetDeviceCaps" and
            parameters as [screen_dc, "LOGPIXELSX"] and
            library as "gdi32.dll"
        
        Call call_win32_api with
            function as "ReleaseDC" and
            parameters as [0, screen_dc] and
            library as "user32.dll"
        
        Return dpi_x divided by 96.0
    Catch Exception:
        Note: Return 100% scale as safe default
        Return 1.0

Note: Missing Helper Functions Implementation

Process called "call_win32_api" that takes function as String and parameters as List and library as String returns Any:
    Note: Core function to call Win32 APIs via FFI bridge
    Try:
        Note: Use native API calling mechanism (platform-specific implementation)
        Let api_result be native_api.call_dll_function with:
            dll_name as library and
            function_name as function and
            arguments as parameters and
            calling_convention as "stdcall"
        
        Note: Handle different return types based on function
        If api_result is not equal to null:
            Return api_result
        
        Note: If native call fails, try alternative loading method
        Let handle be native_api.load_library with name as library
        If handle is not equal to 0:
            Let proc_address be native_api.get_proc_address with:
                handle as handle and
                name as function
            
            If proc_address is not equal to 0:
                Let call_result be native_api.call_function_pointer with:
                    pointer as proc_address and
                    args as parameters
                
                Return call_result
    
    Catch error as Exception:
        Note: Log API call failure for debugging
        Call native_api.log_error with message as "Win32 API call failed: " plus function plus " in " plus library
        Pass
    
    Note: API call failed - return appropriate error values based on Win32 standards
    If function is equal to "GetLastError":
        Return 2  Note: ERROR_FILE_NOT_FOUND
    
    If function is equal to "GetModuleHandleW" or function is equal to "GetModuleHandleA":
        Return 0  Note: NULL handle indicates failure
    
    If function is equal to "LoadLibraryA" or function is equal to "LoadLibraryW":
        Return 0  Note: NULL handle indicates failure
    
    If function is equal to "GetProcAddress":
        Return 0  Note: NULL address indicates failure
    
    If function is equal to "CreateFileA" or function is equal to "CreateFileW":
        Return -1  Note: INVALID_HANDLE_VALUE
    
    If function is equal to "CreateThread" or function is equal to "CreateProcess":
        Return 0  Note: NULL handle indicates failure
    
    If function is equal to "VirtualAlloc" or function is equal to "VirtualAllocEx":
        Return 0  Note: NULL pointer indicates failure
    
    If function is equal to "RegOpenKeyExA" or function is equal to "RegCreateKeyExA":
        Return 2  Note: ERROR_FILE_NOT_FOUND
    
    If function is equal to "CloseHandle":
        Return 0  Note: FALSE indicates failure
    
    Note: For unknown functions, return null to indicate API unavailable
    Return null

Process called "extract_filetime_from_buffer" that takes buffer as Any returns Integer:
    Note: Extract FILETIME structure from Win32 API buffer and convert to timestamp
    Try:
        If buffer is not equal to null and buffer is not equal to 0:
            Note: FILETIME is 8-byte structure with low and high parts
            Let low_part be native_api.extract_dword_from_buffer with buffer as buffer and offset as 0
            Let high_part be native_api.extract_dword_from_buffer with buffer as buffer and offset as 4
            
            Note: Combine low and high parts into 64-bit value
            Let filetime_value be (high_part multiplied by 4294967296) plus low_part
            
            Note: Convert Windows FILETIME (100ns since 1601) to Unix timestamp (seconds since 1970)
            Note: FILETIME epoch: January 1, 1601, Unix epoch: January 1, 1970
            Let windows_to_unix_offset be 11644473600  Note: Seconds between 1601 and 1970
            Let timestamp be (filetime_value divided by 10000000) minus windows_to_unix_offset
            
            Return timestamp as Integer
    
    Catch Exception:
        Pass
    
    Note: Return current system time as fallback
    Let current_time be native_api.get_system_time_seconds
    If current_time is not equal to 0:
        Return current_time
    
    Note: Final fallback to epoch time
    Return 0

Process called "extract_string_from_buffer" that takes buffer as Any returns String:
    Note: Extract null-terminated string from Win32 API buffer
    Try:
        If buffer is not equal to null and buffer is not equal to 0:
            Let result_str be buffer as String
            Note: Handle null terminator if present
            If result_str contains "\0":
                Let clean_str be result_str split by "\0" at position 0
                Return clean_str
            Otherwise:
                Return result_str
    Catch Exception:
        Pass
    
    Note: Return empty string if extraction fails
    Return ""

Process called "create_buffer_for_filetime" that returns Any:
    Note: Create buffer for FILETIME structure (8 bytes)
    Return call_win32_api with
        function as "LocalAlloc" and
        parameters as [0, 8] and  Note: LMEM_FIXED, 8 bytes for FILETIME
        library as "kernel32.dll"

Process called "create_buffer_for_large_integer" that returns Any:
    Note: Create buffer for LARGE_INTEGER structure (8 bytes)
    Return call_win32_api with
        function as "LocalAlloc" and
        parameters as [0, 8] and  Note: LMEM_FIXED, 8 bytes for LARGE_INTEGER
        library as "kernel32.dll"

Process called "create_buffer_for_pointer" that returns Any:
    Note: Create buffer for pointer storage (platform-dependent size)
    Let pointer_size be 8  Note: 64-bit pointer size, adjust for 32-bit if needed
    Return call_win32_api with
        function as "LocalAlloc" and
        parameters as [0, pointer_size] and
        library as "kernel32.dll"

Process called "serialize_registry_data" that takes data as Any and type as RegistryValueType returns Any:
    Note: Serialize data for registry storage based on type
    If type is equal to REG_SZ or type is equal to REG_EXPAND_SZ:
        Note: String data with null terminator
        Return (data as String) plus "\0"
    
    If type is equal to REG_DWORD:
        Note: 32-bit integer data
        Return data as Integer
    
    If type is equal to REG_QWORD:
        Note: 64-bit integer data  
        Return data as Integer
    
    If type is equal to REG_BINARY:
        Note: Binary data as-is
        Return data
    
    If type is equal to REG_MULTI_SZ:
        Note: Multiple strings with double null terminator
        If data is List:
            Let multi_string be ""
            For Each item in data as List:
                Set multi_string to multi_string plus (item as String) plus "\0"
            Set multi_string to multi_string plus "\0"  Note: Double null terminator
            Return multi_string
    
    Note: Default to string representation
    Return (data as String) plus "\0"

Process called "get_data_size" that takes data as Any returns Integer:
    Note: Calculate size of serialized data
    Try:
        If data is String:
            Return (data as String).length
        If data is Integer:
            Return 8  Note: Assume 64-bit integer
        If data is List:
            Let total_size be 0
            For Each item in data as List:
                Set total_size to total_size plus (item as String).length plus 1  Note: +1 for null
            Return total_size plus 1  Note: +1 for final null
        Note: Binary data or other types - calculate based on actual content
        If data is of type ByteArray:
            Return (data as ByteArray).length plus 32  Note: Add padding for safety
        If data is of type Integer:
            Return 16  Note: Sufficient for integer representation
        If data is of type Float:
            Return 32  Note: Sufficient for float representation
        Note: Unknown type - use conservative estimate
        Return 64  Note: Conservative default rather than arbitrary 1024
    Catch Exception:
        Return 64  Note: Reasonable minimum rather than arbitrary 1024

