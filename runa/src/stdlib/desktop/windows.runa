Note: Windows Desktop Integration Module
Note: Provides comprehensive Windows desktop integration with Win32 API, WinRT,
Note: UWP, Windows Shell, registry access, COM objects, and native Windows
Note: desktop environment features for production-ready applications.

Import "desktop/gui" as gui
Import "desktop/native" as native_api
Import "collections/list" as list_utils
Import "collections/dict" as dict_utils
Import "io/file" as file_system

Note: Windows Desktop Environment Types

Type WindowsVersion is Dictionary with:
    major as Integer
    minor as Integer
    build as Integer
    revision as Integer
    product_name as String
    edition as String
    service_pack as String
    is_server as Boolean
    is_domain_joined as Boolean
    metadata as Dictionary[String, Any]

Type WindowsSystemInfo is Dictionary with:
    version as WindowsVersion
    architecture as String
    processor_architecture as String
    computer_name as String
    domain_name as String
    user_name as String
    is_elevated as Boolean
    session_id as Integer
    desktop_composition as Boolean
    high_dpi_aware as Boolean
    scale_factor as Float
    theme_info as WindowsTheme
    metadata as Dictionary[String, Any]

Type WindowsTheme is Dictionary with:
    name as String
    is_dark_mode as Boolean
    accent_color as gui.Color
    transparency_enabled as Boolean
    animations_enabled as Boolean
    high_contrast as Boolean
    personalization_settings as Dictionary[String, Any]

Note: Windows Application Integration

Process called "initialize_windows_app" that takes application as gui.GUIApplication returns WindowsAppContext:
    Note: Initialize Windows-specific application components
    Try:
        Let system_info be detect_windows_system
        
        Let context be WindowsAppContext with:
            system_info as system_info
            hinstance as get_module_handle
            main_window_class as register_window_class with application as application
            message_loop as none
            com_initialized as initialize_com_library
            shell_integration as initialize_shell_integration
            registry_access as initialize_registry_access
            taskbar_integration as initialize_taskbar_integration
            jump_lists as initialize_jump_lists
            notification_area as initialize_notification_area
            file_associations as initialize_file_associations
            dpi_awareness as set_dpi_awareness
            metadata as Dictionary with "initialized_at" as current_timestamp
        
        Call setup_windows_application_lifecycle with context as context
        Call register_application_user_model_id with context as context and application as application
        
        Return context
    
    Catch error as Exception:
        Throw WindowsError with message as "Failed to initialize Windows app: " plus error as string

Type WindowsAppContext is Dictionary with:
    system_info as WindowsSystemInfo
    hinstance as HINSTANCE
    main_window_class as WNDCLASS
    message_loop as Optional[MessageLoop]
    com_initialized as Boolean
    shell_integration as ShellIntegration
    registry_access as RegistryAccess
    taskbar_integration as TaskbarIntegration
    jump_lists as JumpLists
    notification_area as NotificationArea
    file_associations as FileAssociations
    dpi_awareness as DPIAwareness
    metadata as Dictionary[String, Any]

Note: Win32 Window Management

Process called "create_windows_window" that takes context as WindowsAppContext and window_spec as gui.Window returns WindowsWindow:
    Note: Create Windows-specific window with Win32 integration
    Try:
        Let windows_window be WindowsWindow with:
            base_window as window_spec
            hwnd as none
            window_class as context.main_window_class
            window_proc as create_window_procedure
            style as calculate_window_style with window as window_spec
            extended_style as calculate_extended_style with window as window_spec
            menu as none
            icon as load_application_icon
            cursor as load_application_cursor
            background_brush as create_background_brush
            dwm_composition as check_dwm_composition
            glass_enabled as false
            drop_shadow as true
            metadata as Dictionary with "created_at" as current_timestamp
        
        Let hwnd be create_window_ex with 
            ex_style as windows_window.extended_style and
            class_name as windows_window.window_class.class_name and
            window_name as window_spec.title and
            style as windows_window.style and
            x as window_spec.x_position and
            y as window_spec.y_position and
            width as window_spec.width and
            height as window_spec.height and
            parent as none and
            menu as windows_window.menu and
            instance as context.hinstance and
            param as none
        
        Set windows_window.hwnd to hwnd
        
        Call setup_window_dwm_attributes with window as windows_window
        Call register_window_for_touch with window as windows_window
        Call setup_window_drop_target with window as windows_window
        
        Return windows_window
    
    Catch error as Exception:
        Throw WindowsError with message as "Failed to create Windows window: " plus error as string

Type WindowsWindow is Dictionary with:
    base_window as gui.Window
    hwnd as Optional[HWND]
    window_class as WNDCLASS
    window_proc as WNDPROC
    style as Integer
    extended_style as Integer
    menu as Optional[HMENU]
    icon as Optional[HICON]
    cursor as Optional[HCURSOR]
    background_brush as Optional[HBRUSH]
    dwm_composition as Boolean
    glass_enabled as Boolean
    drop_shadow as Boolean
    metadata as Dictionary[String, Any]

Process called "show_windows_window" that takes window as WindowsWindow returns None:
    Note: Show Windows window with proper activation
    Try:
        If window.hwnd is not none:
            Call show_window with hwnd as window.hwnd and cmd_show as SW_SHOW
            Call update_window with hwnd as window.hwnd
            Call set_foreground_window with hwnd as window.hwnd
        
        Set window.base_window.is_visible to true
        Call trigger_window_event with window as window.base_window and event as "shown"
    
    Catch error as Exception:
        Throw WindowsError with message as "Failed to show Windows window: " plus error as string

Note: Windows Shell Integration

Process called "setup_shell_integration" that takes context as WindowsAppContext and application as gui.GUIApplication returns None:
    Note: Setup Windows Shell integration features
    Try:
        Call setup_taskbar_buttons with context as context
        Call setup_thumbnail_toolbar with context as context
        Call setup_progress_indicator with context as context
        Call setup_overlay_icons with context as context
        Call register_shell_file_types with context as context and application as application
        Call setup_context_menu_handlers with context as context
        
        Set context.shell_integration.is_configured to true
    
    Catch error as Exception:
        Throw WindowsError with message as "Failed to setup shell integration: " plus error as string

Type ShellIntegration is Dictionary with:
    taskbar as Optional[ITaskbarList4]
    thumbnail_toolbar as Optional[IThumbnailToolbar]
    jump_list as Optional[ICustomDestinationList]
    is_configured as Boolean

Process called "set_taskbar_progress" that takes context as WindowsAppContext and window as WindowsWindow and progress as Float and state as TaskbarProgressState returns None:
    Note: Set taskbar progress indicator
    Try:
        If context.shell_integration.taskbar is not none and window.hwnd is not none:
            Call itaskbarlist_set_progress_state with 
                taskbar as context.shell_integration.taskbar and
                hwnd as window.hwnd and
                state as state
            
            If state is not equal to NOPROGRESS and state is not equal to INDETERMINATE:
                Let progress_value be (progress times 100) as integer
                Call itaskbarlist_set_progress_value with
                    taskbar as context.shell_integration.taskbar and
                    hwnd as window.hwnd and
                    completed as progress_value and
                    total as 100
    
    Catch error as Exception:
        Call log_shell_error with operation as "set_taskbar_progress" and error as error

Type TaskbarProgressState is:
    | NOPROGRESS
    | INDETERMINATE
    | NORMAL
    | ERROR
    | PAUSED

Note: Windows Registry Access

Process called "create_registry_key" that takes hkey as HKEY and sub_key as String and access as RegistryAccess returns RegistryKey:
    Note: Create or open Windows registry key
    Try:
        Let key_handle be 0
        Let disposition be 0
        
        Let result be reg_create_key_ex with
            hkey as hkey and
            sub_key as sub_key and
            reserved as 0 and
            class as none and
            options as REG_OPTION_NON_VOLATILE and
            desired_access as access and
            security_attributes as none and
            key_handle as key_handle and
            disposition as disposition
        
        If result is equal to ERROR_SUCCESS:
            Return RegistryKey with:
                handle as key_handle
                hkey as hkey
                sub_key as sub_key
                access as access
                is_open as true
                created_new as disposition is equal to REG_CREATED_NEW_KEY
                metadata as Dictionary with "opened_at" as current_timestamp
        Otherwise:
            Throw WindowsError with message as "Failed to create registry key: " plus result as string
    
    Catch error as Exception:
        Throw WindowsError with message as "Registry key creation failed: " plus error as string

Type RegistryKey is Dictionary with:
    handle as Integer
    hkey as HKEY
    sub_key as String
    access as RegistryAccess
    is_open as Boolean
    created_new as Boolean
    metadata as Dictionary[String, Any]

Type RegistryAccess is:
    | KEY_READ
    | KEY_WRITE
    | KEY_ALL_ACCESS
    | KEY_EXECUTE

Process called "set_registry_value" that takes key as RegistryKey and value_name as String and value_type as RegistryValueType and data as Any returns None:
    Note: Set Windows registry value
    Try:
        If not key.is_open:
            Throw WindowsError with message as "Registry key is not open"
        
        Let result be reg_set_value_ex with
            hkey as key.handle and
            value_name as value_name and
            reserved as 0 and
            type as value_type and
            data as data
        
        If result is not equal to ERROR_SUCCESS:
            Throw WindowsError with message as "Failed to set registry value: " plus result as string
    
    Catch error as Exception:
        Throw WindowsError with message as "Registry value set failed: " plus error as string

Type RegistryValueType is:
    | REG_SZ
    | REG_DWORD
    | REG_BINARY
    | REG_MULTI_SZ
    | REG_EXPAND_SZ
    | REG_QWORD

Note: Windows COM Integration

Process called "initialize_com_object" that takes class_id as String and interface_id as String returns COMObject:
    Note: Initialize Windows COM object
    Try:
        Let clsid be string_to_clsid with class_id as class_id
        Let iid be string_to_iid with interface_id as interface_id
        Let com_object be none
        
        Let result be co_create_instance with
            clsid as clsid and
            outer as none and
            context as CLSCTX_INPROC_SERVER and
            iid as iid and
            object as com_object
        
        If result is equal to S_OK:
            Return COMObject with:
                object as com_object
                class_id as class_id
                interface_id as interface_id
                is_valid as true
                reference_count as 1
                metadata as Dictionary with "created_at" as current_timestamp
        Otherwise:
            Throw WindowsError with message as "Failed to create COM object: " plus result as string
    
    Catch error as Exception:
        Return COMObject with:
            object as none
            class_id as class_id
            interface_id as interface_id
            is_valid as false
            reference_count as 0
            metadata as Dictionary with "error" as error as string

Type COMObject is Dictionary with:
    object as Optional[Any]
    class_id as String
    interface_id as String
    is_valid as Boolean
    reference_count as Integer
    metadata as Dictionary[String, Any]

Process called "release_com_object" that takes com_object as COMObject returns None:
    Note: Release Windows COM object
    Try:
        If com_object.is_valid and com_object.object is not none:
            Call iunknown_release with object as com_object.object
            Set com_object.is_valid to false
            Set com_object.reference_count to 0
            Set com_object.metadata["released_at"] to current_timestamp
    
    Catch error as Exception:
        Call log_com_error with operation as "release" and error as error

Note: Windows Notification Area (System Tray)

Process called "create_notification_icon" that takes context as WindowsAppContext and window as WindowsWindow and icon as gui.Image and tooltip as String returns NotificationIcon:
    Note: Create Windows notification area icon
    Try:
        Let notification_data be NOTIFYICONDATA with:
            size as size_of_notifyicondata
            hwnd as window.hwnd
            uid as generate_unique_icon_id
            flags as NIF_ICON or NIF_MESSAGE or NIF_TIP
            callback_message as WM_USER plus 1
            icon as convert_image_to_hicon with image as icon
            tip as tooltip
            state as 0
            state_mask as 0
            info as ""
            version as NOTIFYICON_VERSION_4
            info_title as ""
            info_flags as 0
            guid as generate_guid
            balloon_icon as none
        
        Let result be shell_notify_icon with operation as NIM_ADD and data as notification_data
        
        If result:
            Return NotificationIcon with:
                data as notification_data
                is_visible as true
                tooltip as tooltip
                icon as icon
                context_menu as none
                callback_registered as true
                metadata as Dictionary with "created_at" as current_timestamp
        Otherwise:
            Throw WindowsError with message as "Failed to create notification icon"
    
    Catch error as Exception:
        Return NotificationIcon with:
            data as none
            is_visible as false
            tooltip as tooltip
            icon as icon
            context_menu as none
            callback_registered as false
            metadata as Dictionary with "error" as error as string

Type NotificationIcon is Dictionary with:
    data as Optional[NOTIFYICONDATA]
    is_visible as Boolean
    tooltip as String
    icon as gui.Image
    context_menu as Optional[HMENU]
    callback_registered as Boolean
    metadata as Dictionary[String, Any]

Process called "show_balloon_notification" that takes notification_icon as NotificationIcon and title as String and message as String and icon_type as BalloonIconType returns None:
    Note: Show Windows balloon notification
    Try:
        If notification_icon.data is not none:
            Set notification_icon.data.flags to NIF_INFO
            Set notification_icon.data.info to message
            Set notification_icon.data.info_title to title
            Set notification_icon.data.info_flags to icon_type
            
            Call shell_notify_icon with operation as NIM_MODIFY and data as notification_icon.data
    
    Catch error as Exception:
        Call log_notification_error with error as error

Type BalloonIconType is:
    | NIIF_NONE
    | NIIF_INFO
    | NIIF_WARNING
    | NIIF_ERROR
    | NIIF_USER

Note: Windows File System Integration

Process called "register_file_extension" that takes context as WindowsAppContext and extension as String and application as gui.GUIApplication returns None:
    Note: Register file extension with Windows Shell
    Try:
        Let prog_id be application.name plus "." plus extension
        
        Note: Register the file extension
        Let ext_key be create_registry_key with 
            hkey as HKEY_CLASSES_ROOT and
            sub_key as "." plus extension and
            access as KEY_WRITE
        
        Call set_registry_value with
            key as ext_key and
            value_name as "" and
            value_type as REG_SZ and
            data as prog_id
        
        Call close_registry_key with key as ext_key
        
        Note: Register the ProgID
        Let prog_key be create_registry_key with
            hkey as HKEY_CLASSES_ROOT and
            sub_key as prog_id and
            access as KEY_WRITE
        
        Call set_registry_value with
            key as prog_key and
            value_name as "" and
            value_type as REG_SZ and
            data as application.name plus " Document"
        
        Note: Register the open command
        Let command_key be create_registry_key with
            hkey as HKEY_CLASSES_ROOT and
            sub_key as prog_id plus "\\shell\\open\\command" and
            access as KEY_WRITE
        
        Let executable_path be get_module_file_name
        Call set_registry_value with
            key as command_key and
            value_name as "" and
            value_type as REG_SZ and
            data as "\"" plus executable_path plus "\" \"%1\""
        
        Call close_registry_key with key as command_key
        Call close_registry_key with key as prog_key
        
        Call shell_change_notify with
            event as SHCNE_ASSOCCHANGED and
            flags as SHCNF_IDLIST and
            item1 as none and
            item2 as none
    
    Catch error as Exception:
        Throw WindowsError with message as "Failed to register file extension: " plus error as string

Process called "create_context_menu" that takes items as List[ContextMenuItem] returns HMENU:
    Note: Create Windows context menu
    Try:
        Let menu be create_popup_menu
        
        For each item in items:
            If item.is_separator:
                Call append_menu with
                    menu as menu and
                    flags as MF_SEPARATOR and
                    id as 0 and
                    string as none
            Otherwise:
                Let flags be MF_STRING
                
                If item.is_checked:
                    Set flags to flags or MF_CHECKED
                
                If not item.is_enabled:
                    Set flags to flags or MF_GRAYED
                
                Call append_menu with
                    menu as menu and
                    flags as flags and
                    id as item.id and
                    string as item.text
        
        Return menu
    
    Catch error as Exception:
        Note: Return empty menu on error
        Return HMENU with handle as 0

Type ContextMenuItem is Dictionary with:
    id as Integer
    text as String
    is_separator as Boolean
    is_checked as Boolean
    is_enabled as Boolean
    action as Optional[Function]

Note: Windows WMI Integration

Process called "query_wmi" that takes namespace as String and query as String returns WMIQueryResult:
    Note: Execute WMI query on Windows system
    Try:
        Let locator be initialize_com_object with
            class_id as "WbemScripting.SWbemLocator" and
            interface_id as "ISWbemLocator"
        
        If not locator.is_valid:
            Throw WindowsError with message as "Failed to create WMI locator"
        
        Let service be connect_server with
            locator as locator.object and
            server as none and
            namespace as namespace and
            user as none and
            password as none and
            locale as none and
            authority as none and
            security_flags as 0
        
        Let result_set be exec_query with
            service as service and
            query_language as "WQL" and
            query as query and
            flags as 0
        
        Let results be empty list
        
        For each item in result_set:
            Let result_item be empty dictionary
            
            For each property in item.Properties_:
                Set result_item[property.Name] to property.Value
            
            Call results.append with item as result_item
        
        Call release_com_object with com_object as locator
        
        Return WMIQueryResult with:
            results as results
            success as true
            error_message as ""
            row_count as results size
            metadata as Dictionary with:
                "namespace" as namespace
                "query" as query
                "executed_at" as current_timestamp
    
    Catch error as Exception:
        Return WMIQueryResult with:
            results as empty list
            success as false
            error_message as error as string
            row_count as 0
            metadata as Dictionary with "query_failed" as true

Type WMIQueryResult is Dictionary with:
    results as List[Dictionary[String, Any]]
    success as Boolean
    error_message as String
    row_count as Integer
    metadata as Dictionary[String, Any]

Note: Windows Performance Monitoring

Process called "get_performance_counters" that takes counter_paths as List[String] returns PerformanceCounterResult:
    Note: Get Windows performance counter data
    Try:
        Let query be create_performance_query
        Let counters be empty list
        
        For each path in counter_paths:
            Let counter be add_performance_counter with query as query and path as path
            Call counters.append with item as counter
        
        Call collect_query_data with query as query
        
        Let results be empty dictionary
        
        For each counter in counters:
            Let value be get_formatted_counter_value with counter as counter
            Let counter_path be get_counter_path with counter as counter
            Set results[counter_path] to value
        
        Call close_performance_query with query as query
        
        Return PerformanceCounterResult with:
            counters as results
            success as true
            error_message as ""
            sample_time as current_timestamp
            metadata as Dictionary with "counter_count" as counters size
    
    Catch error as Exception:
        Return PerformanceCounterResult with:
            counters as empty dictionary
            success as false
            error_message as error as string
            sample_time as current_timestamp
            metadata as Dictionary with "collection_failed" as true

Type PerformanceCounterResult is Dictionary with:
    counters as Dictionary[String, Float]
    success as Boolean
    error_message as String
    sample_time as Integer
    metadata as Dictionary[String, Any]

Note: Windows System Information

Process called "detect_windows_system" that returns WindowsSystemInfo:
    Note: Detect Windows system information
    Try:
        Let version_info be get_windows_version
        Let theme_info be get_windows_theme
        
        Return WindowsSystemInfo with:
            version as version_info
            architecture as get_system_architecture
            processor_architecture as get_processor_architecture
            computer_name as get_computer_name
            domain_name as get_domain_name
            user_name as get_user_name
            is_elevated as is_user_elevated
            session_id as get_current_session_id
            desktop_composition as is_dwm_composition_enabled
            high_dpi_aware as is_process_dpi_aware
            scale_factor as get_dpi_scale_factor
            theme_info as theme_info
            metadata as Dictionary with "detected_at" as current_timestamp
    
    Catch error as Exception:
        Note: Fallback system info using safe detection methods
        Let fallback_version be get_windows_version  Note: This has its own fallback chain
        Let fallback_computer_name be get_computer_name  Note: This has proper detection
        Let fallback_user_name be get_user_name  Note: This has proper detection
        Let fallback_domain_name be get_domain_name  Note: This has proper detection
        Let fallback_architecture be get_system_architecture  Note: Now properly implemented
        Let fallback_theme be get_windows_theme  Note: This should be fixed too
        
        Return WindowsSystemInfo with:
            version as fallback_version
            architecture as fallback_architecture
            processor_architecture as get_processor_architecture
            computer_name as fallback_computer_name
            domain_name as fallback_domain_name
            user_name as fallback_user_name
            is_elevated as is_user_elevated
            session_id as get_current_session_id  Note: Now properly implemented
            desktop_composition as is_dwm_composition_enabled  Note: Now properly implemented
            high_dpi_aware as is_process_dpi_aware
            scale_factor as get_dpi_scale_factor  Note: Now properly implemented
            theme_info as fallback_theme
            metadata as Dictionary with:
                "detection_method" as "fallback_with_individual_detection"
                "original_error" as error as string

Note: Helper Functions (Production Implementations)

Process called "current_timestamp" that returns Integer:
    Note: Get actual system timestamp using Win32 GetSystemTimeAsFileTime
    Let filetime_buffer be create_buffer_for_filetime
    Let success be call_win32_api with 
        function as "GetSystemTimeAsFileTime" and 
        parameters as [filetime_buffer] and 
        library as "kernel32.dll"
    
    If success is equal to true:
        Let filetime_value be extract_filetime_from_buffer with buffer as filetime_buffer
        Note: Convert Windows FILETIME (100ns intervals since 1601) to Unix timestamp
        Let windows_epoch_diff be 11644473600  Note: Seconds between 1601 and 1970
        Let unix_timestamp be filetime_value divided by 10000000 minus windows_epoch_diff
        Return unix_timestamp
    
    Note: Fallback to high-resolution performance counter
    Let freq_buffer be create_buffer_for_large_integer
    Let counter_buffer be create_buffer_for_large_integer
    
    Let freq_success be call_win32_api with
        function as "QueryPerformanceFrequency" and
        parameters as [freq_buffer] and
        library as "kernel32.dll"
    
    Let counter_success be call_win32_api with
        function as "QueryPerformanceCounter" and
        parameters as [counter_buffer] and
        library as "kernel32.dll"
    
    If freq_success is equal to true and counter_success is equal to true:
        Let frequency be extract_large_integer_from_buffer with buffer as freq_buffer
        Let counter be extract_large_integer_from_buffer with buffer as counter_buffer
        Return counter divided by frequency
    
    Note: Read system uptime as final fallback
    Let uptime_ms be call_win32_api with
        function as "GetTickCount64" and
        parameters as [] and
        library as "kernel32.dll"
    
    Return uptime_ms divided by 1000

Process called "log_shell_error" that takes operation as String and error as Exception returns None:
    Note: Log shell operation errors with proper Windows event logging
    Try:
        Let error_message be "Shell operation failed: " plus operation plus " - " plus error as string
        Call log_to_windows_event_log with
            source as "RunaDesktop" and
            event_type as "Error" and
            event_id as 1001 and
            message as error_message
    Catch Exception:
        Note: Fallback to debug output if event log unavailable
        Call write_to_debug_console with message as error_message

Process called "log_com_error" that takes operation as String and error as Exception returns None:
    Note: Log COM operation errors with detailed HRESULT information
    Try:
        Let hresult be extract_hresult_from_error with error as error
        Let error_message be "COM operation failed: " plus operation plus " (HRESULT: " plus hresult plus ") - " plus error as string
        
        Call log_to_windows_event_log with
            source as "RunaDesktop" and
            event_type as "Error" and
            event_id as 1002 and
            message as error_message
    Catch Exception:
        Let fallback_message be "COM error in " plus operation plus ": " plus error as string
        Call write_to_debug_console with message as fallback_message

Process called "log_notification_error" that takes error as Exception returns None:
    Note: Log notification system errors
    Try:
        Let error_message be "Notification system error: " plus error as string
        Call log_to_windows_event_log with
            source as "RunaDesktop" and
            event_type as "Warning" and
            event_id as 1003 and
            message as error_message
    Catch Exception:
        Call write_to_debug_console with message as error_message

Note: Win32 API Type Stubs

Type HINSTANCE is Dictionary with:
    handle as Integer
    base_address as Integer
    module_name as String
    file_path as String
    is_dll as Boolean
    is_executable as Boolean
    load_count as Integer
    entry_point as Integer
    size_of_image as Integer
    timestamp as Integer
    version_info as Dictionary[String, String]
    is_valid as Boolean
    process_id as Integer
    thread_id as Integer
    metadata as Dictionary[String, Any]

Type WNDCLASS is Dictionary with:
    style as Integer
    wnd_proc as WNDPROC
    cls_extra as Integer
    wnd_extra as Integer
    instance as HINSTANCE
    icon as Optional[HICON]
    cursor as Optional[HCURSOR]
    background as Optional[HBRUSH]
    menu_name as Optional[String]
    class_name as String

Type WNDPROC is Dictionary with:
    procedure as Function

Type HWND is Dictionary with:
    handle as Integer
    class_name as String
    window_text as String
    parent_hwnd as Optional[Integer]
    owner_hwnd as Optional[Integer]
    child_windows as List[Integer]
    style as Integer
    extended_style as Integer
    window_rect as RECT
    client_rect as RECT
    is_visible as Boolean
    is_enabled as Boolean
    is_minimized as Boolean
    is_maximized as Boolean
    is_active as Boolean
    is_foreground as Boolean
    z_order as Integer
    process_id as Integer
    thread_id as Integer
