    Try:
        Let voiceover_running be execute_system_command with command as "ps aux | grep -i voiceover | grep -v grep"
        If voiceover_running is not equal to "":
            Return true
        
        Note: Check system preferences
        Let voiceover_pref be execute_system_command with command as "defaults read com.apple.universalaccess voiceOverOnOffKey"
        Return voiceover_pref is equal to "1"
    Catch Exception:
        Return false

Process called "update_accessibility_info" that takes element as gui.Widget returns None:
    Return

Process called "get_effective_appearance" that returns String:
    Return "NSAppearanceNameAqua"

Process called "check_increase_contrast_enabled" that returns Boolean:
    Note: Check if Increase Contrast accessibility feature is enabled
    Try:
        Let contrast_setting be execute_system_command with command as "defaults read com.apple.universalaccess increaseContrast"
        Return contrast_setting is equal to "1"
    Catch Exception:
        Note: Fallback using NSAccessibility API
        Try:
            Let contrast_enabled be call_objc_runtime with
                class as "NSWorkspace" and
                method as "accessibilityDisplayShouldIncreaseContrast" and
                parameters as []
            Return contrast_enabled is equal to true
        Catch Exception:
            Return false

Process called "check_reduce_transparency_enabled" that returns Boolean:
    Note: Check if Reduce Transparency accessibility feature is enabled
    Try:
        Let transparency_setting be execute_system_command with command as "defaults read com.apple.universalaccess reduceTransparency"
        Return transparency_setting is equal to "1"
    Catch Exception:
        Note: Fallback using NSAccessibility API
        Try:
            Let transparency_reduced be call_objc_runtime with
                class as "NSWorkspace" and
                method as "accessibilityDisplayShouldReduceTransparency" and
                parameters as []
            Return transparency_reduced is equal to true
        Catch Exception:
            Return false

Process called "get_system_accent_color" that returns AccentColor:
    Note: Get actual system accent color from macOS preferences
    Let accent_color_result be execute_system_command with command as "defaults read -g AppleAccentColor 2>/dev/null"
    
    If accent_color_result is not equal to "":
        Let accent_number be convert_string_to_integer with string as string_trim with string as accent_color_result
        
        Note: Map macOS accent color numbers to enum values
        If accent_number is equal to -1:
            Return GRAPHITE
        If accent_number is equal to 0:
            Return RED
        If accent_number is equal to 1:
            Return ORANGE
        If accent_number is equal to 2:
            Return YELLOW
        If accent_number is equal to 3:
            Return GREEN
        If accent_number is equal to 4:
            Return BLUE
        If accent_number is equal to 5:
            Return PURPLE
        If accent_number is equal to 6:
            Return PINK
    
    Note: Check for system default (multicolor)
    Let highlight_color_result be execute_system_command with command as "defaults read -g AppleHighlightColor 2>/dev/null"
    If highlight_color_result is equal to "":
        Return SYSTEM_DEFAULT
    
    Note: Default to blue if detection fails
    Return BLUE

Process called "get_current_appearance" that returns String:
    Note: Get current macOS appearance (Light/Dark mode)
    Let dark_mode_check be execute_system_command with command as "defaults read -g AppleInterfaceStyle 2>/dev/null"
    
    If dark_mode_check is not equal to "":
        Let interface_style be string_trim with string as dark_mode_check
        If interface_style is equal to "Dark":
            Return "dark"
    
    Note: Check system appearance using osascript
    Let appearance_script be "osascript -e 'tell app \"System Events\" to tell appearance preferences to get dark mode'"
    Let script_result be execute_system_command with command as appearance_script
    
    If script_result is not equal to "":
        Let dark_mode_result be string_trim with string as script_result
        If dark_mode_result is equal to "true":
            Return "dark"
    
    Note: Default to light appearance
    Return "light"

Process called "is_dark_mode_enabled" that returns Boolean:
    Note: Check if Dark Mode is currently enabled
    Let current_appearance be get_current_appearance
    Return current_appearance is equal to "dark"

Process called "nsnotification_center_default_center" that returns Any:
    Note: Return default NSNotificationCenter
    Return Dictionary with:
        identifier as "NSNotificationCenter.defaultCenter"
        observers as empty list
        posted_notifications as empty list
        suspended_delivery as false
        metadata as Dictionary with "created_at" as current_timestamp

Process called "add_notification_observer" that takes center as Any and name as String and callback as Function returns Any:
    Note: Return observer token for notification registration
    Return Dictionary with:
        token_id as generate_unique_id with prefix as "observer"
        notification_name as name
        callback as callback
        center as center
        is_active as true
        registered_at as current_timestamp

Process called "check_touch_bar_availability" that returns Boolean:
    Note: Check if Touch Bar is available on this Mac
    Try:
        Let system_profiler_result be execute_system_command with command as "system_profiler SPHardwareDataType | grep 'Model Identifier'"
        If system_profiler_result contains "MacBookPro":
            Note: Check model year for Touch Bar support (2016-2020)
            Let model_year be extract_year_from_model_identifier with identifier as system_profiler_result
            If model_year is greater than or equal to 2016 and model_year is less than or equal to 2020:
                Return true
        
        Note: Alternative check using Touch Bar framework availability
        Let touch_bar_available be call_objc_runtime with
            class as "NSTouchBar" and
            method as "isAutomaticCustomizeTouchBarMenuItemEnabled" and
            parameters as []
        
        Return touch_bar_available is not equal to null
    
    Catch Exception:
        Return false

Process called "setup_default_touch_bar_items" that takes touch_bar as NSTouchBar returns None:
    Return

Process called "nswindow_set_touch_bar" that takes window as NSWindow and touch_bar as NSTouchBar returns None:
    Return

Process called "create_services_provider" that takes application as gui.GUIApplication returns Any:
    Note: Create services provider for macOS system services
    Return Dictionary with:
        application as application
        provided_services as list containing "TextProcessing" and "ImageProcessing"
        service_menu as Dictionary with:
            "items" as empty list
            "enabled" as true
        delegate as none
        metadata as Dictionary with "created_at" as current_timestamp

Process called "nsapplication_set_services_provider" that takes app as NSApplication and provider as Any returns None:
    Return

Process called "nsapplication_register_services_menu_send_types" that takes app as NSApplication and send_types as List[String] and return_types as List[String] returns None:
    Return

Process called "update_services_menu" that returns None:
    Note: Update macOS Services menu with application-specific services
    Try:
        Note: Get current application services
        Let app_services be get_application_services
        If app_services is equal to none:
            Return
        
        Note: Update Services menu in main menu bar
        Let services_menu be find_services_menu_in_main_menu
        If services_menu is not equal to none:
            Note: Clear existing service items
            Call clear_services_menu_items with menu as services_menu
            
            Note: Add current application services
            For each service in app_services:
                Let service_item be create_service_menu_item with service as service
                Call nsmenu_add_item with menu as services_menu and item as service_item
            
            Note: Update menu timestamp
            Set services_menu.metadata["last_updated"] to current_timestamp
    
    Catch error as Exception:
        Call log_services_error with error as error

Process called "get_activity_options" that takes activity_type as ActivityType returns Integer:
    Note: Get NSProcessInfo activity options based on activity type
    If activity_type is equal to USER_INITIATED:
        Return 16777215  # NSActivityUserInitiated
    
    If activity_type is equal to USER_INTERACTIVE:
        Return 16777471  # NSActivityUserInitiated | NSActivityLatencyCritical
    
    If activity_type is equal to BACKGROUND:
        Return 1         # NSActivityBackground
    
    If activity_type is equal to UTILITY:
        Return 17        # NSActivityBackground | NSActivityUserInitiated
    
    If activity_type is equal to AUTOMATIC_TERMINATION_DISABLED:
        Return 32768     # NSActivityAutomaticTerminationDisabled
    
    If activity_type is equal to SUDDEN_TERMINATION_DISABLED:
        Return 16384     # NSActivitySuddenTerminationDisabled
    
    If activity_type is equal to IDLE_DISPLAY_SLEEP_DISABLED:
        Return 1048576   # NSActivityIdleDisplaySleepDisabled
    
    If activity_type is equal to IDLE_SYSTEM_SLEEP_DISABLED:
        Return 1048832   # NSActivityIdleSystemSleepDisabled
    
    Note: Default to user initiated
    Return 16777215

Process called "nsprocess_info_begin_activity" that takes options as Integer and reason as String returns Any:
    Note: Return activity token for power management
    Return Dictionary with:
        activity_id as generate_unique_id with prefix as "activity"
        options as options
        reason as reason
        start_time as current_timestamp
        is_active as true
        process_info as Dictionary with:
            "process_name" as "Runa Application"
            "identifier" as "com.runa.app"

Process called "nsprocess_info_end_activity" that takes token as Any returns None:
    Note: End NSProcessInfo activity to restore normal power management
    Try:
        If token is equal to none:
            Return
        
        Note: Validate activity token
        If token.activity_id is equal to "" or token.is_active is equal to false:
            Return
        
        Note: Mark activity as ended
        Set token.is_active to false
        Set token.end_time to current_timestamp
        
        Note: Calculate activity duration for logging
        Let duration be token.end_time minus token.start_time
        Set token.duration_ms to duration
        
        Note: Log activity completion
        Call log_power_management_activity with
            action as "end_activity" and
            activity_id as token.activity_id and
            duration as duration and
            reason as token.reason
    
    Catch error as Exception:
        Call log_activity_error with error as error

Process called "get_macos_version" that returns MacOSVersion:
    Note: Get actual macOS version using system commands
    Let sw_vers_result be execute_system_command with command as "sw_vers -productVersion"
    Let build_result be execute_system_command with command as "sw_vers -buildVersion"
    
    Let major as Integer be 12
    Let minor as Integer be 0
    Let patch as Integer be 0
    Let build_version be ""  Note: Empty string indicates build version detection failed
    
    If sw_vers_result is not equal to "":
        Let version_parts be split_string with string as string_trim with string as sw_vers_result and delimiter as "."
        If list_length with list as version_parts is greater than 0:
            Set major to convert_string_to_integer with string as version_parts[0]
        If list_length with list as version_parts is greater than 1:
            Set minor to convert_string_to_integer with string as version_parts[1]
        If list_length with list as version_parts is greater than 2:
            Set patch to convert_string_to_integer with string as version_parts[2]
    
    If build_result is not equal to "":
        Set build_version to string_trim with string as build_result
    
    Note: Determine codename and support status
    Let codename be determine_macos_codename with major as major and minor as minor
    Let is_supported_version be check_macos_support_status with major as major and minor as minor
    
    Return MacOSVersion with:
        major as major
        minor as minor
        patch as patch
        build as build_version
        codename as codename
        is_supported as is_supported_version
        metadata as Dictionary with "detected" as true and "detection_method" as "sw_vers"

Process called "get_system_architecture" that returns String:
    Note: Get actual system architecture using multiple detection methods
    Let uname_result be execute_system_command with command as "uname -m"
    If uname_result is not equal to "":
        Let arch be string_trim with string as uname_result
        If arch is equal to "arm64":
            Return "Apple Silicon (ARM64)"
        If arch is equal to "x86_64":
            Return "Intel x86_64"
        Return arch
    
    Note: Fallback using sysctl
    Let sysctl_arch be execute_system_command with command as "sysctl -n hw.machine"
    If sysctl_arch is not equal to "":
        Let machine_type be string_trim with string as sysctl_arch
        If machine_type is equal to "arm64":
            Return "Apple Silicon (ARM64)"
        If machine_type is equal to "x86_64":
            Return "Intel x86_64"
        Return machine_type
    
    Note: Check for Rosetta translation
    Let rosetta_check be execute_system_command with command as "sysctl -n sysctl.proc_translated 2>/dev/null"
    If rosetta_check is equal to "1":
        Return "Intel x86_64 (Rosetta 2)"
    
    Return ""  Note: Return empty string if architecture detection fails

Process called "get_model_identifier" that returns String:
    Note: Get actual Mac hardware model identifier
    Let sysctl_model be execute_system_command with command as "sysctl -n hw.model"
    If sysctl_model is not equal to "":
        Return string_trim with string as sysctl_model
    
    Note: Try system_profiler method
    Let profiler_result be execute_system_command with command as "system_profiler SPHardwareDataType | grep 'Model Identifier'"
    If profiler_result is not equal to "":
        Let model_from_profiler be extract_model_identifier_from_line with line as profiler_result
        If model_from_profiler is not equal to "":
            Return model_from_profiler
    
    Note: Try ioreg method for hardware info
    Let ioreg_result be execute_system_command with command as "ioreg -c IOPlatformExpertDevice -d 2 | grep model"
    If ioreg_result is not equal to "":
        Let model_from_ioreg be extract_model_from_ioreg_output with output as ioreg_result
        If model_from_ioreg is not equal to "":
            Return model_from_ioreg
    
    Return "Mac (Unknown Model)"

Process called "get_cpu_type" that returns String:
    Note: Get actual CPU type and architecture information
    Let sysctl_cpu be execute_system_command with command as "sysctl -n machdep.cpu.brand_string"
    If sysctl_cpu is not equal to "":
        Return string_trim with string as sysctl_cpu
    
    Note: Try system_profiler for detailed CPU info
    Let profiler_cpu be execute_system_command with command as "system_profiler SPHardwareDataType | grep 'Chip\|Processor Name'"
    If profiler_cpu is not equal to "":
        Let cpu_info be extract_cpu_info_from_profiler with output as profiler_cpu
        If cpu_info is not equal to "":
            Return cpu_info
    
    Note: Check architecture to determine CPU family
    Let arch_result be execute_system_command with command as "uname -m"
    If arch_result is not equal to "":
        Let arch_type be string_trim with string as arch_result
        If arch_type is equal to "arm64":
            Let silicon_detection be detect_specific_apple_silicon_chip
            Return silicon_detection
        If arch_type is equal to "x86_64":
            Let intel_cpu be execute_system_command with command as "sysctl -n machdep.cpu.brand_string"
            If intel_cpu is not equal to "":
                Return string_trim with string as intel_cpu
            Return "Intel x86_64"
    
    Return ""  Note: Return empty string if CPU type detection fails

Process called "get_physical_memory_size" that returns Integer:
    Note: Get actual physical memory size in bytes
    Let sysctl_mem be execute_system_command with command as "sysctl -n hw.memsize"
    If sysctl_mem is not equal to "":
        Let memory_bytes be convert_string_to_integer with string as string_trim with string as sysctl_mem
        If memory_bytes is greater than 0:
            Return memory_bytes
    
    Note: Fallback using system_profiler
    Let profiler_result be execute_system_command with command as "system_profiler SPHardwareDataType | grep 'Memory:'"
    If profiler_result is not equal to "":
        Let memory_from_profiler be extract_memory_size_from_profiler with line as profiler_result
        If memory_from_profiler is greater than 0:
            Return memory_from_profiler
    
    Note: Another fallback using vm_stat
    Let vm_stat_result be execute_system_command with command as "vm_stat | head -1"
    If vm_stat_result is not equal to "":
        Let page_size be extract_page_size_from_vm_stat with output as vm_stat_result
        Let free_pages_result be execute_system_command with command as "vm_stat | grep 'Pages free' | awk '{print $3}' | sed 's/\.//'"
        If free_pages_result is not equal to "" and page_size is greater than 0:
            Let total_memory_estimate be calculate_memory_from_vm_stats with page_size as page_size
            If total_memory_estimate is greater than 0:
                Return total_memory_estimate
    
    Note: Return -1 to indicate memory size detection failed
    Return -1

Process called "get_screen_count" that returns Integer:
    Note: Get actual number of connected displays
    Let system_profiler_result be execute_system_command with command as "system_profiler SPDisplaysDataType | grep -c 'Resolution:'"
    If system_profiler_result is not equal to "":
        Let display_count be convert_string_to_integer with string as string_trim with string as system_profiler_result
        If display_count is greater than 0:
            Return display_count
    
    Note: Fallback using screenresolution utility if available
    Let screenres_result be execute_system_command with command as "which screenresolution >/dev/null && screenresolution list | grep -c 'Display'"
    If screenres_result is not equal to "":
        Let display_count_fallback be convert_string_to_integer with string as string_trim with string as screenres_result
        If display_count_fallback is greater than 0:
            Return display_count_fallback
    
    Note: Basic fallback - at least one display must exist
    Return 1

Process called "get_primary_display_info" that returns DisplayInfo:
    Note: Get actual primary display information using system_profiler and other tools
    Let display_info_result be execute_system_command with command as "system_profiler SPDisplaysDataType"
    
    Let display_id be "main"
    Let display_name be "Built-in Display"
    Let display_width be 1920
    Let display_height be 1080
    Let scale_factor be 1.0
    Let refresh_rate be 60.0
    Let color_profile be "sRGB"
    Let is_builtin_display be true
    
    If display_info_result is not equal to "":
        Note: Parse display information from system_profiler output
        Let parsed_info be parse_macos_display_info with output as display_info_result
        If parsed_info is not equal to none:
            Set display_name to parsed_info.name
            Set display_width to parsed_info.width
            Set display_height to parsed_info.height
            Set scale_factor to parsed_info.scale_factor
            Set refresh_rate to parsed_info.refresh_rate
            Set color_profile to parsed_info.color_profile
            Set is_builtin_display to parsed_info.is_builtin
    
    Note: Try alternative method using screenresolution
    Let screenres_result be execute_system_command with command as "which screenresolution >/dev/null && screenresolution get"
    If screenres_result is not equal to "":
        Let resolution_info be parse_screen_resolution_output with output as screenres_result
        If resolution_info is not equal to none:
            Set display_width to resolution_info.width
            Set display_height to resolution_info.height
    
    Note: Calculate working area (subtract dock and menu bar space)
    Let working_width be display_width
    Let working_height be display_height minus 28  # menu bar height
    
    Return DisplayInfo with:
        id as display_id
        name as display_name
        bounds as gui.Rectangle with x as 0 and y as 0 and width as display_width and height as display_height
        working_area as gui.Rectangle with x as 0 and y as 0 and width as working_width and height as working_height
        scale_factor as scale_factor
        refresh_rate as refresh_rate
        color_profile as color_profile
        is_main as true
        is_builtin as is_builtin_display

Process called "get_all_display_info" that returns List[DisplayInfo]:
    Note: Get information for all connected displays using system_profiler
    Let display_list be empty list
    
    Note: Get comprehensive display information
    Let display_info_result be execute_system_command with command as "system_profiler SPDisplaysDataType"
    
    If display_info_result is not equal to "":
        Let parsed_displays be parse_all_macos_displays with output as display_info_result
        If parsed_displays is not equal to none and list_length with list as parsed_displays is greater than 0:
            Return parsed_displays
    
    Note: Fallback using screenresolution if available
    Let screenres_result be execute_system_command with command as "which screenresolution >/dev/null && screenresolution list"
    If screenres_result is not equal to "":
        Let screenres_displays be parse_screenresolution_list with output as screenres_result
        If screenres_displays is not equal to none and list_length with list as screenres_displays is greater than 0:
            Return screenres_displays
    
    Note: Ultimate fallback - return at least primary display
    Let primary_display be get_primary_display_info
    Call display_list.append with item as primary_display
    Return display_list

