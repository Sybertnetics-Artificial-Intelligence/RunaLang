        Let shared_app be objc_runtime with
            class as "NSApplication" and
            method as "sharedApplication" and
            parameters as []
        
        Note: Set the main menu
        Call objc_runtime with
            class as "NSApplication" and
            instance as shared_app and
            method as "setMainMenu:" and
            parameters as [main_menu]
        
        Note: Update menu bar display
        Call objc_runtime with
            class as "NSMenu" and
            instance as main_menu and
            method as "update" and
            parameters as []
        
        Note: Ensure menu bar is visible
        Call objc_runtime with
            class as "NSApplication" and
            instance as shared_app and
            method as "setPresentationOptions:" and
            parameters as ["NSApplicationPresentationDefault"]
        
        Note: Set up menu validation
        Call setup_menu_validation with menu as main_menu
        
    Catch error as Exception:
        Call log_integration_error with platform as "macos_assign_menu" and error as error

Process called "parse_shortcut_modifiers" that takes shortcut as Optional[String] returns Integer:
    Note: Parse macOS keyboard shortcut modifiers into NSEvent modifier mask
    If shortcut is equal to none or shortcut is equal to "":
        Return 0
    
    Let modifier_mask be 0
    Let shortcut_lower be string_to_lower with string as shortcut
    
    Note: Check for Command key (⌘)
    If string_contains with string as shortcut_lower and substring as "cmd" or string_contains with string as shortcut_lower and substring as "command":
        Set modifier_mask to modifier_mask plus 1048576  # NSEventModifierFlagCommand
    
    Note: Check for Option/Alt key (⌥)
    If string_contains with string as shortcut_lower and substring as "opt" or string_contains with string as shortcut_lower and substring as "alt":
        Set modifier_mask to modifier_mask plus 524288   # NSEventModifierFlagOption
    
    Note: Check for Control key (⌃)
    If string_contains with string as shortcut_lower and substring as "ctrl" or string_contains with string as shortcut_lower and substring as "control":
        Set modifier_mask to modifier_mask plus 262144   # NSEventModifierFlagControl
    
    Note: Check for Shift key (⇧)
    If string_contains with string as shortcut_lower and substring as "shift":
        Set modifier_mask to modifier_mask plus 131072   # NSEventModifierFlagShift
    
    Note: Check for Function key
    If string_contains with string as shortcut_lower and substring as "fn":
        Set modifier_mask to modifier_mask plus 8388608  # NSEventModifierFlagFunction
    
    Return modifier_mask

Process called "nsmenu_add_item" that takes menu as NSMenu and item as NSMenuItem returns None:
    Note: Add menu item to NSMenu with proper ordering and validation
    Try:
        Note: Validate menu item before adding
        If item.title is equal to "":
            Set item.title to "Untitled"
        
        Note: Set up menu item properties
        If item.tag is equal to 0:
            Set item.tag to list_length with list as menu.items plus 1
        
        Note: Add to menu's items list
        Call menu.items.append with item as item
        
        Note: Set up parent-child relationship
        If item.submenu is not equal to none:
            Set item.submenu.supermenu to menu
        
        Note: Update menu metadata
        Set menu.metadata["last_modified"] to current_timestamp
        Set menu.metadata["item_count"] to list_length with list as menu.items
    
    Catch error as Exception:
        Call log_services_error with error as error

