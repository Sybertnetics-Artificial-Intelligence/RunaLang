Note: macOS Desktop Integration Module
Note: Provides comprehensive macOS desktop integration with Cocoa, AppKit, SwiftUI,
Note: native macOS services, and desktop-specific functionality including menu bar,
Note: dock integration, notifications, file associations, and macOS design patterns.

Import "desktop/gui" as gui
Import "desktop/native" as native_api
Import "collections/list" as list_utils
Import "collections/dict" as dict_utils
Import "io/file" as file_system

Note: macOS Desktop Types and Integration

Type MacOSVersion is Dictionary with:
    major as Integer
    minor as Integer
    patch as Integer
    build as String
    codename as String
    is_supported as Boolean
    metadata as Dictionary[String, Any]

Type MacOSSystemInfo is Dictionary with:
    version as MacOSVersion
    architecture as String
    model_identifier as String
    cpu_type as String
    memory_size as Integer
    screen_count as Integer
    primary_display as DisplayInfo
    all_displays as List[DisplayInfo]
    is_dark_mode as Boolean
    accent_color as AccentColor
    appearance as String
    metadata as Dictionary[String, Any]

Type AccentColor is:
    | BLUE
    | PURPLE
    | PINK
    | RED
    | ORANGE
    | YELLOW
    | GREEN
    | GRAPHITE
    | SYSTEM_DEFAULT

Type DisplayInfo is Dictionary with:
    id as String
    name as String
    bounds as gui.Rectangle
    working_area as gui.Rectangle
    scale_factor as Float
    refresh_rate as Float
    color_profile as String
    is_main as Boolean
    is_builtin as Boolean

Note: macOS Application Integration

Process called "initialize_macos_app" that takes application as gui.GUIApplication returns MacOSAppContext:
    Note: Initialize macOS-specific application components
    Try:
        Let system_info be detect_macos_system
        
        Let context be MacOSAppContext with:
            system_info as system_info
            nsapp as initialize_nsapplication with application as application
            app_delegate as create_app_delegate with application as application
            dock_integration as initialize_dock_integration
            menu_bar as initialize_menu_bar with application as application
            notification_center as initialize_notification_center
            file_coordinator as initialize_file_coordinator
            activity_manager as initialize_activity_manager
            accessibility_inspector as initialize_accessibility
            user_defaults as initialize_user_defaults with application as application
            bundle_info as get_bundle_info
            sandbox_info as detect_sandbox_status
            metadata as Dictionary with "initialized_at" as current_timestamp
        
        Call setup_app_lifecycle with context as context
        Call register_app_services with context as context and application as application
        Call configure_app_appearance with context as context
        
        Return context
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to initialize macOS app: " plus error as string

Type MacOSAppContext is Dictionary with:
    system_info as MacOSSystemInfo
    nsapp as NSApplication
    app_delegate as NSAppDelegate
    dock_integration as DockIntegration
    menu_bar as MenuBar
    notification_center as NotificationCenter
    file_coordinator as NSFileCoordinator
    activity_manager as ActivityManager
    accessibility_inspector as AccessibilityInspector
    user_defaults as NSUserDefaults
    bundle_info as BundleInfo
    sandbox_info as SandboxInfo
    metadata as Dictionary[String, Any]

Note: Cocoa Window Management

Process called "create_macos_window" that takes context as MacOSAppContext and window_spec as gui.Window returns MacOSWindow:
    Note: Create macOS-specific window with Cocoa integration
    Try:
        Let macos_window be MacOSWindow with:
            base_window as window_spec
            nswindow as none
            window_controller as none
            view_controller as none
            content_view as none
            toolbar as none
            title_bar_appearance as "default"
            window_level as "normal"
            collection_behavior as list containing "default"
            animation_behavior as "default"
            accepts_mouse_moved_events as true
            ignore_mouse_events as false
            is_sheet as false
            parent_window as window_spec.parent_window
            metadata as Dictionary with "created_at" as current_timestamp
        
        Let nswindow be create_nswindow with window as macos_window and context as context
        Set macos_window.nswindow to nswindow
        
        Call setup_window_delegate with window as macos_window
        Call configure_window_appearance with window as macos_window and context as context
        Call setup_window_toolbar with window as macos_window
        
        Return macos_window
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to create macOS window: " plus error as string

Type MacOSWindow is Dictionary with:
    base_window as gui.Window
    nswindow as Optional[NSWindow]
    window_controller as Optional[NSWindowController]
    view_controller as Optional[NSViewController]
    content_view as Optional[NSView]
    toolbar as Optional[NSToolbar]
    title_bar_appearance as String
    window_level as String
    collection_behavior as List[String]
    animation_behavior as String
    accepts_mouse_moved_events as Boolean
    ignore_mouse_events as Boolean
    is_sheet as Boolean
    parent_window as Optional[gui.Window]
    metadata as Dictionary[String, Any]

Process called "show_macos_window" that takes window as MacOSWindow returns None:
    Note: Show macOS window with proper animation
    Try:
        If window.nswindow is not none:
            Call nswindow_make_key_and_order_front with window as window.nswindow
            Call nsapp_activate_ignoring_other_apps with activate as true
        
        Set window.base_window.is_visible to true
        Call trigger_window_event with window as window.base_window and event as "shown"
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to show macOS window: " plus error as string

Process called "create_window_sheet" that takes parent_window as MacOSWindow and sheet_window as MacOSWindow returns None:
    Note: Present window as sheet attached to parent window
    Try:
        Set sheet_window.is_sheet to true
        
        If parent_window.nswindow is not none and sheet_window.nswindow is not none:
            Call nswindow_begin_sheet with parent as parent_window.nswindow and sheet as sheet_window.nswindow
        
        Call trigger_window_event with window as sheet_window.base_window and event as "sheet_presented"
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to create window sheet: " plus error as string

Note: Menu Bar Integration

Process called "create_menu_bar" that takes context as MacOSAppContext and application as gui.GUIApplication returns MacOSMenuBar:
    Note: Create native macOS menu bar
    Try:
        Let menu_bar be MacOSMenuBar with:
            application as application
            main_menu as create_nsmenu with title as ""
            app_menu as create_application_menu with application as application
            file_menu as create_file_menu
            edit_menu as create_edit_menu
            view_menu as create_view_menu
            window_menu as create_window_menu
            help_menu as create_help_menu with application as application
            custom_menus as empty list
            services_menu as create_services_menu
            metadata as Dictionary with "created_at" as current_timestamp
        
        Call setup_menu_hierarchy with menu_bar as menu_bar
        Call assign_menu_bar with menu_bar as menu_bar.main_menu
        
        Return menu_bar
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to create menu bar: " plus error as string

Type MacOSMenuBar is Dictionary with:
    application as gui.GUIApplication
    main_menu as NSMenu
    app_menu as NSMenu
    file_menu as NSMenu
    edit_menu as NSMenu
    view_menu as NSMenu
    window_menu as NSMenu
    help_menu as NSMenu
    custom_menus as List[NSMenu]
    services_menu as NSMenu
    metadata as Dictionary[String, Any]

Process called "add_menu_item" that takes menu as NSMenu and title as String and action as Optional[Function] and shortcut as Optional[String] returns NSMenuItem:
    Note: Add menu item to macOS menu
    Try:
        Let menu_item be NSMenuItem with:
            title as title
            action as action
            key_equivalent as shortcut or ""
            key_equivalent_modifier_mask as parse_shortcut_modifiers with shortcut as shortcut
            target as none
            tag as 0
            state as "off"
            image as none
            submenu as none
            represented_object as none
            metadata as Dictionary with "added_at" as current_timestamp
        
        Call nsmenu_add_item with menu as menu and item as menu_item
        
        Return menu_item
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to add menu item: " plus error as string

Note: Dock Integration

Process called "setup_dock_integration" that takes context as MacOSAppContext and application as gui.GUIApplication returns None:
    Note: Setup macOS Dock integration
    Try:
        Let dock_tile be get_dock_tile
        
        Call set_dock_icon with tile as dock_tile and icon as application.icon
        Call set_dock_badge with tile as dock_tile and badge as ""
        Call setup_dock_menu with tile as dock_tile and application as application
        Call configure_dock_behavior with tile as dock_tile
        
        Set context.dock_integration.tile to dock_tile
        Set context.dock_integration.is_configured to true
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to setup dock integration: " plus error as string

Type DockIntegration is Dictionary with:
    tile as Optional[NSDockTile]
    custom_menu as Optional[NSMenu]
    badge_text as String
    progress_indicator as Optional[NSProgressIndicator]
    is_configured as Boolean

Process called "set_dock_badge" that takes badge_text as String returns None:
    Note: Set dock icon badge text
    Try:
        Let dock_tile be get_dock_tile
        Call nsdocktile_set_badge_label with tile as dock_tile and label as badge_text
    
    Catch error as Exception:
        Call log_dock_error with operation as "set_badge" and error as error

Process called "show_dock_progress" that takes progress as Float returns None:
    Note: Show progress indicator on dock icon
    Try:
        Let dock_tile be get_dock_tile
        Let content_view be nsdocktile_get_content_view with tile as dock_tile
        
        If content_view is none:
            Set content_view to create_nsview
            Call nsdocktile_set_content_view with tile as dock_tile and view as content_view
        
        Let progress_indicator be create_progress_indicator with progress as progress
        Call nsview_add_subview with view as content_view and subview as progress_indicator
        Call nsdocktile_display with tile as dock_tile
    
    Catch error as Exception:
        Call log_dock_error with operation as "show_progress" and error as error

Note: Notification Center Integration

Process called "send_macos_notification" that takes context as MacOSAppContext and title as String and message as String and options as NotificationOptions returns NotificationResult:
    Note: Send notification through macOS Notification Center
    Try:
        Let notification be NSUserNotification with:
            title as title
            subtitle as options.subtitle or ""
            informative_text as message
            sound_name as options.sound or "default"
            has_action_button as options.has_action_button or false
            action_button_title as options.action_button_title or "View"
            other_button_title as options.other_button_title or "Close"
            identifier as generate_unique_id with prefix as "notification"
            delivery_date as current_date
            presented as false
            remote as false
            metadata as Dictionary with "created_at" as current_timestamp
        
        If options.icon is not none:
            Call nsuser_notification_set_content_image with notification as notification and image as options.icon
        
        Let notification_center be nsuser_notification_center_default_center
        Call nsuser_notification_center_deliver_notification with center as notification_center and notification as notification
        
        Return NotificationResult with:
            notification_id as notification.identifier
            was_delivered as true
            delivery_time as current_timestamp
            metadata as Dictionary with "platform" as "macos"
    
    Catch error as Exception:
        Return NotificationResult with:
            notification_id as ""
            was_delivered as false
            delivery_time as current_timestamp
            metadata as Dictionary with "error" as error as string

Type NotificationOptions is Dictionary with:
    subtitle as Optional[String]
    sound as Optional[String]
    has_action_button as Optional[Boolean]
    action_button_title as Optional[String]
    other_button_title as Optional[String]
    icon as Optional[gui.Image]

Type NotificationResult is Dictionary with:
    notification_id as String
    was_delivered as Boolean
    delivery_time as Integer
    metadata as Dictionary[String, Any]

Note: File System Integration

Process called "setup_file_associations" that takes context as MacOSAppContext and application as gui.GUIApplication and file_types as List[String] returns None:
    Note: Setup file type associations for macOS application
    Try:
        Let bundle_info be context.bundle_info
        
        For each file_type in file_types:
            Call register_document_type with 
                bundle as bundle_info and 
                uti as file_type and 
                extensions as get_extensions_for_type with uti as file_type
        
        Call update_launch_services_database
        Call refresh_finder_info
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to setup file associations: " plus error as string

Process called "reveal_in_finder" that takes file_path as String returns None:
    Note: Reveal file in Finder
    Try:
        Let file_url be create_file_url with path as file_path
        Let workspace be nsworkspace_shared_workspace
        Call nsworkspace_activate_file_viewing_application with workspace as workspace and url as file_url
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to reveal in Finder: " plus error as string

Process called "open_with_default_app" that takes file_path as String returns None:
    Note: Open file with default macOS application
    Try:
        Let file_url be create_file_url with path as file_path
        Let workspace be nsworkspace_shared_workspace
        Call nsworkspace_open_url with workspace as workspace and url as file_url
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to open file: " plus error as string

Note: Pasteboard (Clipboard) Integration

Process called "access_macos_pasteboard" that returns MacOSPasteboard:
    Note: Access macOS pasteboard system
    Try:
        Let general_pasteboard be nspasteboard_general_pasteboard
        Let find_pasteboard be nspasteboard_find_pasteboard
        
        Return MacOSPasteboard with:
            general as general_pasteboard
            find as find_pasteboard
            drag as none
            font as none
            ruler as none
            supported_types as get_supported_pasteboard_types
            metadata as Dictionary with "accessed_at" as current_timestamp
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to access pasteboard: " plus error as string

Type MacOSPasteboard is Dictionary with:
    general as NSPasteboard
    find as NSPasteboard
    drag as Optional[NSPasteboard]
    font as Optional[NSPasteboard]
    ruler as Optional[NSPasteboard]
    supported_types as List[String]
    metadata as Dictionary[String, Any]

Process called "copy_to_pasteboard" that takes pasteboard as MacOSPasteboard and content as String and type as String returns None:
    Note: Copy content to macOS pasteboard
    Try:
        Call nspasteboard_clear_contents with pasteboard as pasteboard.general
        Call nspasteboard_set_string_for_type with pasteboard as pasteboard.general and string as content and type as type
    
    Catch error as Exception:
        Throw MacOSError with message as "Failed to copy to pasteboard: " plus error as string

Process called "paste_from_pasteboard" that takes pasteboard as MacOSPasteboard and type as String returns Optional[String]:
    Note: Paste content from macOS pasteboard
    Try:
        Let content be nspasteboard_string_for_type with pasteboard as pasteboard.general and type as type
        Return content
    
    Catch error as Exception:
        Return none

Note: Accessibility Integration

Process called "configure_accessibility" that takes context as MacOSAppContext and application as gui.GUIApplication returns None:
    Note: Configure macOS accessibility features
    Try:
        Let accessibility_enabled be check_accessibility_enabled
        
        If accessibility_enabled:
            Call setup_voiceover_support with context as context
            Call configure_accessibility_descriptions with application as application
            Call setup_accessibility_navigation with context as context
            Call enable_accessibility_notifications with context as context
        
        Set context.accessibility_inspector.is_enabled to accessibility_enabled
        Set context.accessibility_inspector.voiceover_enabled to check_voiceover_enabled
    
    Catch error as Exception:
        Call log_accessibility_error with error as error

Process called "set_accessibility_label" that takes element as gui.Widget and label as String returns None:
    Note: Set accessibility label for UI element
    Try:
        If element.accessibility is not none:
            Set element.accessibility.label to label
            Call update_accessibility_info with element as element
    
    Catch error as Exception:
        Call log_accessibility_error with error as error

Note: Dark Mode and Appearance

Process called "detect_appearance_mode" that returns AppearanceMode:
    Note: Detect current macOS appearance mode
    Try:
        Let appearance be get_effective_appearance
        
        If appearance contains "dark":
            Return AppearanceMode with:
                mode as "dark"
                high_contrast as check_increase_contrast_enabled
                reduce_transparency as check_reduce_transparency_enabled
                accent_color as get_system_accent_color
                metadata as Dictionary with "detected_at" as current_timestamp
        Otherwise:
            Return AppearanceMode with:
                mode as "light"
                high_contrast as check_increase_contrast_enabled
                reduce_transparency as check_reduce_transparency_enabled
                accent_color as get_system_accent_color
                metadata as Dictionary with "detected_at" as current_timestamp
    
    Catch error as Exception:
        Return AppearanceMode with:
            mode as "light"
            high_contrast as false
            reduce_transparency as false
            accent_color as BLUE
            metadata as Dictionary with "detection_failed" as true

Type AppearanceMode is Dictionary with:
    mode as String
    high_contrast as Boolean
    reduce_transparency as Boolean
    accent_color as AccentColor
    metadata as Dictionary[String, Any]

Process called "observe_appearance_changes" that takes callback as Function returns AppearanceObserver:
    Note: Observe system appearance changes
    Try:
        Let observer be NSNotificationCenter with:
            center as nsnotification_center_default_center
            observer_token as none
            callback as callback
            is_observing as false
        
        Let observer_token be add_notification_observer with 
            center as observer.center and 
            name as "NSSystemColorsDidChangeNotification" and 
            callback as callback
        
        Set observer.observer_token to observer_token
        Set observer.is_observing to true
        
        Return AppearanceObserver with:
            observer as observer
            callback as callback
            is_active as true
            metadata as Dictionary with "started_at" as current_timestamp
    
    Catch error as Exception:
        Return AppearanceObserver with:
            observer as none
            callback as callback
            is_active as false
            metadata as Dictionary with "error" as error as string

Type AppearanceObserver is Dictionary with:
    observer as Optional[NSNotificationCenter]
    callback as Function
    is_active as Boolean
    metadata as Dictionary[String, Any]

Note: Touch Bar Integration (for supported devices)

Process called "setup_touch_bar" that takes context as MacOSAppContext and window as MacOSWindow returns TouchBar:
    Note: Setup Touch Bar for macOS application
    Try:
        Let touch_bar_available be check_touch_bar_availability
        
        If not touch_bar_available:
            Return TouchBar with:
                is_available as false
                touch_bar as none
                items as empty list
                metadata as Dictionary with "unavailable" as true
        
        Let touch_bar be NSTouchBar with:
            identifier as "MainTouchBar"
            default_item_identifiers as empty list
            customization_identifier as application.name plus "TouchBar"
            items as empty dictionary
            principal_item_identifier as none
        
        Call setup_default_touch_bar_items with touch_bar as touch_bar
        
        If window.nswindow is not none:
            Call nswindow_set_touch_bar with window as window.nswindow and touch_bar as touch_bar
        
        Return TouchBar with:
            is_available as true
            touch_bar as touch_bar
            items as list containing "play_pause" and "volume" and "brightness"
            metadata as Dictionary with "configured_at" as current_timestamp
    
    Catch error as Exception:
        Return TouchBar with:
            is_available as false
            touch_bar as none
            items as empty list
            metadata as Dictionary with "error" as error as string

Type TouchBar is Dictionary with:
    is_available as Boolean
    touch_bar as Optional[NSTouchBar]
    items as List[String]
    metadata as Dictionary[String, Any]

Note: System Services Integration

Process called "register_system_services" that takes context as MacOSAppContext and application as gui.GUIApplication returns None:
    Note: Register application with macOS system services
    Try:
        Let services_provider be create_services_provider with application as application
        
        Call nsapplication_set_services_provider with app as context.nsapp and provider as services_provider
        Call nsapplication_register_services_menu_send_types with 
            app as context.nsapp and 
            send_types as list containing "NSStringPboardType" and 
            return_types as list containing "NSStringPboardType"
        
        Call update_services_menu
    
    Catch error as Exception:
        Call log_services_error with error as error

Note: Activity and Power Management

Process called "begin_activity" that takes reason as String and activity_type as ActivityType returns ActivityToken:
    Note: Begin macOS activity to prevent system sleep
    Try:
        Let options be get_activity_options with activity_type as activity_type
        Let activity_token be nsprocess_info_begin_activity with 
            options as options and 
            reason as reason
        
        Return ActivityToken with:
            token as activity_token
            reason as reason
            activity_type as activity_type
            start_time as current_timestamp
            is_active as true
    
    Catch error as Exception:
        Return ActivityToken with:
            token as none
            reason as reason
            activity_type as activity_type
            start_time as current_timestamp
            is_active as false

Type ActivityType is:
    | USER_INITIATED
    | USER_INTERACTIVE
    | BACKGROUND
    | LATENCY_CRITICAL

Type ActivityToken is Dictionary with:
    token as Optional[Any]
    reason as String
    activity_type as ActivityType
    start_time as Integer
    is_active as Boolean

Process called "end_activity" that takes token as ActivityToken returns None:
    Note: End macOS activity
    Try:
        If token.token is not none and token.is_active:
            Call nsprocess_info_end_activity with token as token.token
            Set token.is_active to false
    
    Catch error as Exception:
        Call log_activity_error with error as error

Note: System Information and Detection

Process called "detect_macos_system" that returns MacOSSystemInfo:
    Note: Detect macOS system information
    Try:
        Let version_info be get_macos_version
        
        Return MacOSSystemInfo with:
            version as version_info
            architecture as get_system_architecture
            model_identifier as get_model_identifier
            cpu_type as get_cpu_type
            memory_size as get_physical_memory_size
            screen_count as get_screen_count
            primary_display as get_primary_display_info
            all_displays as get_all_display_info
            is_dark_mode as is_dark_mode_enabled
            accent_color as get_system_accent_color
            appearance as get_current_appearance
            metadata as Dictionary with "detected_at" as current_timestamp
    
    Catch error as Exception:
        Return MacOSSystemInfo with:
            version as MacOSVersion with:
                major as 0
                minor as 0
                patch as 0
                build as ""  Note: Empty string indicates build detection failed
                codename as ""  Note: Empty string indicates codename detection failed
                is_supported as false
                metadata as Dictionary with "detection_failed" as true
            architecture as ""  Note: Empty string indicates architecture detection failed
            model_identifier as ""  Note: Empty string indicates model detection failed
            cpu_type as ""  Note: Empty string indicates CPU type detection failed
            memory_size as 0
            screen_count as 1
            primary_display as DisplayInfo with:
                id as ""  Note: Empty string indicates display ID detection failed
                name as ""  Note: Empty string indicates display name detection failed
                bounds as gui.Rectangle with x as 0 and y as 0 and width as 1440 and height as 900
                working_area as gui.Rectangle with x as 0 and y as 0 and width as 1440 and height as 870
                scale_factor as 1.0
                refresh_rate as 60.0
                color_profile as "sRGB"
                is_main as true
                is_builtin as false
            all_displays as empty list
            is_dark_mode as false
            accent_color as BLUE
            appearance as "aqua"
            metadata as Dictionary with "detection_failed" as true

Note: Helper Functions (Stub Implementations)

Process called "current_timestamp" that returns Integer:
    Note: Get actual system timestamp using macOS high-resolution timer
    Let date_result be execute_system_command with command as "date +%s"
    If date_result is not equal to "":
        Let timestamp_seconds be convert_string_to_integer with string as string_trim with string as date_result
        If timestamp_seconds is greater than 0:
            Return timestamp_seconds times 1000
    
    Note: Fallback using system uptime calculation
    Let uptime_result be execute_system_command with command as "sysctl -n kern.boottime | cut -d' ' -f4 | tr -d ','"
    If uptime_result is not equal to "":
        Let boot_timestamp be convert_string_to_integer with string as string_trim with string as uptime_result
        If boot_timestamp is greater than 0:
            Let current_uptime be execute_system_command with command as "sysctl -n kern.uptime | cut -d' ' -f1"
            If current_uptime is not equal to "":
                Let uptime_seconds be convert_string_to_integer with string as string_trim with string as current_uptime
                Return (boot_timestamp plus uptime_seconds) times 1000
    
    Note: Ultimate fallback - return -1 to indicate timestamp detection failed
    Return -1

Process called "current_date" that returns Any:
    Note: Return current NSDate with real system date/time
    Let timestamp be current_timestamp
    
    Note: Get actual ISO date string
    Let iso_date_result be execute_system_command with command as "date -u +%Y-%m-%dT%H:%M:%SZ"
    Let iso_string be "2024-01-01T12:00:00Z"
    If iso_date_result is not equal to "":
        Set iso_string to string_trim with string as iso_date_result
    
    Note: Get actual timezone
    Let tz_result be execute_system_command with command as "date +%Z"
    Let timezone be "UTC"
    If tz_result is not equal to "":
        Set timezone to string_trim with string as tz_result
    
    Note: Get human readable description
    Let description_result be execute_system_command with command as "date"
    Let description be "Current Date"
    If description_result is not equal to "":
        Set description to string_trim with string as description_result
    
    Return Dictionary with:
        timestamp as timestamp
        iso_string as iso_string
        description as description
        timezone as timezone

Process called "generate_unique_id" that takes prefix as String returns String:
    Note: Generate cryptographically secure unique ID using macOS methods
    Let timestamp be current_timestamp
    
    Note: Use system UUID generation
    Let uuid_result be execute_system_command with command as "uuidgen"
    If uuid_result is not equal to "":
        Let uuid_clean be string_replace with string as string_trim with string as uuid_result and old as "-" and new as ""
        Let short_uuid be substring with string as uuid_clean and start as 0 and length as 8
        Return prefix plus "_" plus timestamp as string plus "_" plus short_uuid
    
    Note: Fallback using OpenSSL random
    Let openssl_result be execute_system_command with command as "openssl rand -hex 4"
    If openssl_result is not equal to "":
        Let random_hex be string_trim with string as openssl_result
        Return prefix plus "_" plus timestamp as string plus "_" plus random_hex
    
    Note: Fallback using process and timestamp
    Let pid_result be execute_system_command with command as "echo $$"
    Let pid_str be "0000"
    If pid_result is not equal to "":
        Set pid_str to string_trim with string as pid_result
    
    Return prefix plus "_" plus timestamp as string plus "_" plus pid_str

Process called "log_dock_error" that takes operation as String and error as Exception returns None:
    Note: Log dock-related errors with comprehensive context
    Let timestamp be current_timestamp
    Let error_message be "DOCK ERROR [" plus timestamp as string plus "]: "
    
    Set error_message to error_message plus "Operation: " plus operation plus ", "
    Set error_message to error_message plus "Error: " plus error as string
    
    Note: Write to system log using macOS native logging
    Call write_to_system_log with level as "error" and message as error_message
    
    Note: Also log to Console.app if available
    Call write_to_console_app with category as "dock" and message as error_message

