Process called "create_default_accessibility_info" that returns AccessibilityInfo:
    Note: Create default accessibility information
    Return AccessibilityInfo with:
        role as "widget"
        label as ""
        description as ""
        keyboard_shortcut as none
        tab_index as 0

Type AccessibilityInfo is Dictionary with:
    role as String
    label as String
    description as String
    keyboard_shortcut as Optional[String]
    tab_index as Integer

Note: Stub implementations for platform-specific functions

Process called "initialize_platform_specific" that takes application as GUIApplication returns None:
    Note: Real platform-specific initialization with proper resource setup
    Let os_type be get_operating_system_type
    
    If os_type is equal to "WINDOWS":
        Note: Initialize Windows COM, GDI+, and Common Controls
        Let com_result be windows_initialize_com_library
        Let gdiplus_result be windows_initialize_gdiplus
        Let controls_result be windows_initialize_common_controls
        Call windows_set_process_dpi_aware
        
        Set application.platform_initialized to com_result and gdiplus_result and controls_result
        Return
    
    If os_type is equal to "LINUX":
        Note: Initialize X11/Wayland connection and GTK if available
        Let display_connection be linux_initialize_display_connection
        Let gtk_result be linux_initialize_gtk_if_available
        
        Set application.platform_initialized to display_connection is not equal to null
        Return
    
    If os_type is equal to "MACOS":
        Note: Initialize Cocoa application and autorelease pool
        Let cocoa_result be macos_initialize_cocoa_application
        Let pool_result be macos_create_autorelease_pool
        
        Set application.platform_initialized to cocoa_result and pool_result
        Return
    
    Note: Unsupported platform
    Set application.platform_initialized to false
    Return

Process called "create_native_window" that takes window as Window and application as GUIApplication returns NativeWindowHandle:
    Note: Create actual platform-specific native window with full functionality
    Let os_type be get_operating_system_type
    
    If os_type is equal to "WINDOWS":
        Let window_handle be windows_create_window_ex with
            class_name as "RunaGUIWindow" and
            window_name as window.title and
            style as windows_calculate_window_style with properties as window.properties and
            x as window.x and
            y as window.y and
            width as window.width and
            height as window.height and
            parent as null and
            menu as null and
            instance as windows_get_module_handle and
            param as null
        
        If window_handle is not equal to null:
            Call windows_show_window with handle as window_handle and command as "SW_SHOW"
            Call windows_update_window with handle as window_handle
            Return NativeWindowHandle with handle as window_handle
    
    If os_type is equal to "LINUX":
        Let display be linux_get_x11_display
        If display is not equal to null:
            Let x11_window be linux_create_x11_window with
                display as display and
                properties as window.properties
            
            If x11_window is not equal to 0:
                Call linux_set_x11_window_properties with
                    display as display and
                    window as x11_window and
                    title as window.title
                Call linux_map_x11_window with display as display and window as x11_window
                Return NativeWindowHandle with handle as x11_window
    
    If os_type is equal to "MACOS":
        Let ns_window be macos_create_nswindow with
            rect as macos_make_rect with x as window.x and y as window.y and width as window.width and height as window.height and
            style_mask as macos_calculate_window_style_mask with properties as window.properties and
            backing as "NSBackingStoreBuffered" and
            defer as false
        
        If ns_window is not equal to null:
            Call macos_set_nswindow_title with window as ns_window and title as window.title
            Call macos_make_key_and_order_front with window as ns_window
            Return NativeWindowHandle with handle as ns_window
    
    Note: Platform not supported or window creation failed
    Return NativeWindowHandle with handle as 0

Type NativeWindowHandle is Dictionary with:
    handle as Integer

Process called "update_native_window_visibility" that takes window as Window and visible as Boolean returns None:
    Note: Update native window visibility using platform-specific APIs
    If window.native_handle is equal to none:
        Return
    
    Let os_type be get_operating_system_name
    Let handle be window.native_handle.handle
    
    If os_type is equal to "Windows":
        If visible is equal to true:
            Call windows_show_window with handle as handle and command as "SW_SHOW"
        Otherwise:
            Call windows_show_window with handle as handle and command as "SW_HIDE"
        Call windows_update_window with handle as handle
        Return
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            If visible is equal to true:
                Call linux_map_x11_window with display as display and window as handle
            Otherwise:
                Call linux_unmap_x11_window with display as display and window as handle
        Return
    
    If os_type is equal to "macOS":
        If visible is equal to true:
            Call macos_make_key_and_order_front with window as handle
        Otherwise:
            Call macos_order_out with window as handle
        Return

Process called "update_native_window_title" that takes window as Window and title as String returns None:
    Note: Update native window title using platform-specific APIs
    If window.native_handle is equal to none:
        Return
    
    Let os_type be get_operating_system_name
    Let handle be window.native_handle.handle
    
    If os_type is equal to "Windows":
        Call windows_set_window_text with handle as handle and text as title
        Return
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            Call linux_set_x11_window_properties with display as display and window as handle and title as title
        Return
    
    If os_type is equal to "macOS":
        Call macos_set_nswindow_title with window as handle and title as title
        Return

Process called "update_native_window_size" that takes window as Window and width as Integer and height as Integer returns None:
    Note: Update native window size using platform-specific APIs
    If window.native_handle is equal to none:
        Return
    
    Let os_type be get_operating_system_name
    Let handle be window.native_handle.handle
    
    If os_type is equal to "Windows":
        Call windows_set_window_pos with handle as handle and x as window.x_position and y as window.y_position and width as width and height as height and flags as "SWP_NOMOVE | SWP_NOZORDER"
        Return
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            Call linux_resize_x11_window with display as display and window as handle and width as width and height as height
        Return
    
    If os_type is equal to "macOS":
        Let new_frame be macos_make_rect with x as window.x_position and y as window.y_position and width as width and height as height
        Call macos_set_nswindow_frame with window as handle and frame as new_frame
        Return

Process called "update_native_window_position" that takes window as Window and x as Integer and y as Integer returns None:
    Note: Update native window position using platform-specific APIs
    If window.native_handle is equal to none:
        Return
    
    Let os_type be get_operating_system_name
    Let handle be window.native_handle.handle
    
    If os_type is equal to "Windows":
        Call windows_set_window_pos with handle as handle and x as x and y as y and width as window.width and height as window.height and flags as "SWP_NOSIZE | SWP_NOZORDER"
        Return
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            Call linux_move_x11_window with display as display and window as handle and x as x and y as y
        Return
    
    If os_type is equal to "macOS":
        Let new_frame be macos_make_rect with x as x and y as y and width as window.width and height as window.height
        Call macos_set_nswindow_frame with window as handle and frame as new_frame
        Return

Process called "destroy_native_window" that takes window as Window returns None:
    Note: Properly destroy native window and clean up platform resources
    If window.native_handle is equal to none:
        Return
    
    Let os_type be get_operating_system_name
    Let handle be window.native_handle.handle
    
    If os_type is equal to "Windows":
        Call windows_destroy_window with handle as handle
        Return
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            Call linux_destroy_x11_window with display as display and window as handle
            Call linux_flush_display with display as display
        Return
    
    If os_type is equal to "macOS":
        Call macos_close_nswindow with window as handle
        Call macos_release_nswindow with window as handle
        Return
    
    Set window.native_handle to none

Process called "force_destroy_native_window" that takes window as Window returns None:
    Note: Force destroy native window even if cleanup fails
    Try:
        Call destroy_native_window with window as window
    Catch error as Exception:
        Note: Force cleanup regardless of errors
        If window.native_handle is not equal to none:
            Set window.native_handle to none
        
        Note: Additional platform-specific force cleanup
        Let os_type be get_operating_system_name
        
        If os_type is equal to "Windows":
            Note: Force terminate any remaining window processes
            Call windows_force_cleanup_window_resources
        
        If os_type is equal to "Linux":
            Note: Force cleanup X11 resources
            Call linux_force_cleanup_display_resources
        
        If os_type is equal to "macOS":
            Note: Force cleanup Cocoa resources
            Call macos_force_cleanup_window_resources

Process called "create_event_loop" that takes application as GUIApplication returns EventLoop:
    Note: Create platform-specific event loop for GUI message processing
    Let os_type be get_operating_system_name
    
    Let event_loop be EventLoop with:
        is_running as false
        platform_type as os_type
        message_queue as empty list
        event_handlers as empty dictionary
        timer_events as empty list
        last_event_time as current_timestamp
        max_events_per_cycle as 100
        idle_timeout_ms as 16
        application_ref as application
    
    If os_type is equal to "Windows":
        Call windows_initialize_message_loop with event_loop as event_loop
    
    If os_type is equal to "Linux":
        Call linux_initialize_event_loop with event_loop as event_loop
    
    If os_type is equal to "macOS":
        Call macos_initialize_run_loop with event_loop as event_loop
    
    Return event_loop

Type EventLoop is Dictionary with:
    is_running as Boolean
    platform_type as String
    message_queue as List[Event]
    event_handlers as Dictionary[String, Function]
    timer_events as List[TimerEvent]
    last_event_time as Integer
    max_events_per_cycle as Integer
    idle_timeout_ms as Integer
    application_ref as GUIApplication

Type TimerEvent is Dictionary with:
    id as String
    interval_ms as Integer
    callback as Function
    last_triggered as Integer
    is_repeating as Boolean

Process called "run_event_loop" that takes event_loop as EventLoop returns Integer:
    Note: Run the main event loop with platform-specific message processing
    Try:
        Set event_loop.is_running to true
        Let exit_code be 0
        
        While event_loop.is_running is equal to true:
            Let current_time be current_timestamp
            Let events_processed be 0
            
            Note: Process platform-specific messages
            Let os_type be event_loop.platform_type
            
            If os_type is equal to "Windows":
                Let processed_count be windows_process_messages with event_loop as event_loop and max_events as event_loop.max_events_per_cycle
                Set events_processed to processed_count
            
            If os_type is equal to "Linux":
                Let processed_count be linux_process_x11_events with event_loop as event_loop and max_events as event_loop.max_events_per_cycle
                Set events_processed to processed_count
            
            If os_type is equal to "macOS":
                Let processed_count be macos_process_run_loop_events with event_loop as event_loop and max_events as event_loop.max_events_per_cycle
                Set events_processed to processed_count
            
            Note: Process timer events
            Call process_timer_events with event_loop as event_loop and current_time as current_time
            
            Note: If no events, sleep briefly to avoid busy waiting
            If events_processed is equal to 0:
                Call platform_sleep_milliseconds with ms as event_loop.idle_timeout_ms
            
            Set event_loop.last_event_time to current_time
        
        Return exit_code
    
    Catch error as Exception:
        Set event_loop.is_running to false
        Return 1

Process called "stop_event_loop" that takes event_loop as EventLoop returns None:
    Note: Stop the event loop gracefully
    Set event_loop.is_running to false
    
    Note: Platform-specific cleanup
    Let os_type be event_loop.platform_type
    
    If os_type is equal to "Windows":
        Call windows_post_quit_message with exit_code as 0
    
    If os_type is equal to "Linux":
        Call linux_flush_display with display as linux_get_x11_display
    
    If os_type is equal to "macOS":
        Call macos_stop_run_loop

Process called "show_main_window" that takes application as GUIApplication returns None:
    Note: Show the main application window if it exists
    If application.main_window is not equal to none:
        Call show_window with window as application.main_window
        Return
    
    Note: If no main window set, show the first window
    If list_length with list as application.windows is greater than 0:
        Let first_window be application.windows[0]
        Call show_window with window as first_window
        Set application.main_window to first_window

Process called "cleanup_application" that takes application as GUIApplication returns None:
    Note: Clean up all application resources properly
    Try:
        Note: Close all windows
        For each window in application.windows:
            Try:
                Call close_window with window as window
            Catch window_error as Exception:
                Note: Continue cleanup even if individual window fails
                Continue
        
        Note: Clear window list
        Set application.windows to empty list
        Set application.main_window to none
        
        Note: Clean up resource managers
        Call cleanup_resource_manager with manager as application.resource_manager
        Call cleanup_theme_manager with manager as application.theme_manager
        Call cleanup_accessibility_manager with manager as application.accessibility_manager
        
        Note: Platform-specific cleanup
        Call cleanup_platform_specific with application as application
        
        Set application.is_running to false
    
    Catch error as Exception:
        Note: Force cleanup even if normal cleanup fails
        Set application.is_running to false
        Call force_quit_application with application as application

Process called "force_quit_application" that takes application as GUIApplication returns None:
    Note: Force quit application immediately without normal cleanup
    Set application.is_running to false
    
    Note: Force close all windows without cleanup
    For each window in application.windows:
        Try:
            Call force_destroy_native_window with window as window
        Catch error as Exception:
            Continue
    
    Set application.windows to empty list
    Set application.main_window to none
    
    Note: Platform-specific force quit
    Let os_type be get_operating_system_name
    
    If os_type is equal to "Windows":
        Call windows_terminate_process with exit_code as 1
    
    If os_type is equal to "Linux":
        Call linux_force_exit with exit_code as 1
    
    If os_type is equal to "macOS":
        Call macos_terminate_application with exit_code as 1

Process called "trigger_window_event" that takes window as Window and event_type as String returns None:
    Note: Trigger window event and notify all registered handlers
    Try:
        If event_type in window.event_handlers:
            Let handler be window.event_handlers[event_type] as Function
            
            Let event be Event with:
                id as generate_unique_id with prefix as "window_event"
                type as CUSTOM
                source as none
                target as none
                timestamp as current_timestamp
                data as Dictionary with "event_type" as event_type and "window_id" as window.id
                is_consumed as false
                metadata as Dictionary with "triggered_at" as current_timestamp
            
            Call handler with event as event
        
        Note: Also trigger global window event handlers if any exist
        Call trigger_global_window_event with window as window and event_type as event_type
    
    Catch error as Exception:
        Call log_window_event_error with window as window and event_type as event_type and error as error

Process called "trigger_widget_event" that takes widget as Widget and event_type as String returns None:
    Note: Trigger widget event and propagate through widget hierarchy
    Try:
        Let event be Event with:
            id as generate_unique_id with prefix as "widget_event"
            type as CUSTOM
            source as widget
            target as widget
            timestamp as current_timestamp
            data as Dictionary with "event_type" as event_type and "widget_id" as widget.id
            is_consumed as false
            metadata as Dictionary with "triggered_at" as current_timestamp
        
        Call trigger_event with event as event
        
        Note: Update widget state based on event if needed
        Call update_widget_state_from_event with widget as widget and event_type as event_type
    
    Catch error as Exception:
        Call log_widget_event_error with widget as widget and event_type as event_type and error as error

Process called "add_widget_to_native_window" that takes window as Window and widget as Widget returns None:
    Note: Add widget to native window's rendering system
    Try:
        If window.native_handle is equal to none:
            Return
        
        Let os_type be get_operating_system_name
        Let window_handle be window.native_handle.handle
        
        If os_type is equal to "Windows":
            Call windows_create_child_control with
                parent_handle as window_handle and
                widget as widget
        
        If os_type is equal to "Linux":
            Let display be linux_get_x11_display
            If display is not equal to null:
                Call linux_create_x11_child_window with
                    display as display and
                    parent as window_handle and
                    widget as widget
        
        If os_type is equal to "macOS":
            Call macos_add_subview_to_window with
                window as window_handle and
                widget as widget
        
        Note: Register widget for event handling
        Call register_widget_for_events with window as window and widget as widget
    
    Catch error as Exception:
        Throw GUIError with message as "Failed to add widget to native window: " plus error as string

Process called "invalidate_window_rendering" that takes window as Window returns None:
    Note: Mark window for redraw/repaint using platform-specific methods
    If window.native_handle is equal to none:
        Return
    
    Let os_type be get_operating_system_name
    Let handle be window.native_handle.handle
    
    If os_type is equal to "Windows":
        Call windows_invalidate_rect with handle as handle and rect as null and erase as true
        Call windows_update_window with handle as handle
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            Call linux_clear_x11_window with display as display and window as handle
            Call linux_flush_display with display as display
    
    If os_type is equal to "macOS":
        Call macos_set_needs_display with window as handle

Process called "cleanup_widget_resources" that takes widget as Widget returns None:
    Note: Clean up all widget resources including native handles and event handlers
    Try:
        Note: Remove from parent if still attached
        If widget.parent is not equal to none:
            Try:
                Call widget.parent.children.remove with item as widget
            Catch remove_error as Exception:
                Note: Continue cleanup even if removal fails
                Pass
        
        Note: Clean up all child widgets recursively
        For each child_widget in widget.children:
            Call cleanup_widget_resources with widget as child_widget
        
        Note: Clear event handlers
        Set widget.event_handlers to empty dictionary
        
        Note: Clean up native widget resources if any
        Call cleanup_native_widget_resources with widget as widget
        
        Note: Clear references
        Set widget.children to empty list
        Set widget.parent to none
        
        Note: Mark as cleaned up
        Set widget.metadata["cleaned_up"] to true
        Set widget.metadata["cleanup_timestamp"] to current_timestamp
    
    Catch error as Exception:
        Note: Force cleanup even if normal cleanup fails
        Call force_cleanup_widget with widget as widget

Process called "force_cleanup_widget" that takes widget as Widget returns None:
    Note: Force cleanup widget resources even if normal cleanup fails
    Try:
        Set widget.event_handlers to empty dictionary
        Set widget.children to empty list
        Set widget.parent to none
        Set widget.is_visible to false
        Set widget.is_enabled to false
        
        Note: Platform-specific force cleanup
        Let os_type be get_operating_system_name
        
        If os_type is equal to "Windows":
            Call windows_force_destroy_control with widget_id as widget.id
        
        If os_type is equal to "Linux":
            Call linux_force_destroy_widget with widget_id as widget.id
        
        If os_type is equal to "macOS":
            Call macos_force_remove_view with widget_id as widget.id
    
    Catch final_error as Exception:
        Note: Even force cleanup failed, mark as force cleaned
        Set widget.metadata["force_cleaned"] to true

Process called "update_widget_native_bounds" that takes widget as Widget returns None:
    Note: Update native widget bounds using platform-specific APIs
    Let os_type be get_operating_system_name
    
    If os_type is equal to "Windows":
        Call windows_set_widget_bounds with
            widget_id as widget.id and
            x as widget.bounds.x and
            y as widget.bounds.y and
            width as widget.bounds.width and
            height as widget.bounds.height
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            Call linux_configure_widget_geometry with
                display as display and
                widget_id as widget.id and
                bounds as widget.bounds
    
    If os_type is equal to "macOS":
        Let frame_rect be macos_make_rect with
            x as widget.bounds.x and
            y as widget.bounds.y and
            width as widget.bounds.width and
            height as widget.bounds.height
        Call macos_set_view_frame with widget_id as widget.id and frame as frame_rect

Process called "update_widget_native_visibility" that takes widget as Widget and visible as Boolean returns None:
    Note: Update native widget visibility using platform-specific APIs
    Let os_type be get_operating_system_name
    
    If os_type is equal to "Windows":
        If visible is equal to true:
            Call windows_show_widget with widget_id as widget.id and command as "SW_SHOW"
        Otherwise:
            Call windows_show_widget with widget_id as widget.id and command as "SW_HIDE"
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            If visible is equal to true:
                Call linux_map_widget with display as display and widget_id as widget.id
            Otherwise:
                Call linux_unmap_widget with display as display and widget_id as widget.id
    
    If os_type is equal to "macOS":
        Call macos_set_view_hidden with widget_id as widget.id and hidden as not visible

Process called "update_widget_native_enabled_state" that takes widget as Widget and enabled as Boolean returns None:
    Note: Update native widget enabled/disabled state using platform-specific APIs
    Let os_type be get_operating_system_name
    
    If os_type is equal to "Windows":
        Call windows_enable_widget with widget_id as widget.id and enabled as enabled
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            Call linux_set_widget_sensitive with display as display and widget_id as widget.id and sensitive as enabled
    
    If os_type is equal to "macOS":
        Call macos_set_view_enabled with widget_id as widget.id and enabled as enabled
    
    Note: Update widget visual state based on enabled status
    Call update_widget_enabled_appearance with widget as widget and enabled as enabled

Process called "initialize_widget_specific_properties" that takes widget as Widget returns None:
    Note: Initialize widget-specific properties based on widget type
    If widget.type is equal to BUTTON:
        Set widget.properties["text"] to "Button"
        Set widget.properties["clickable"] to true
        Set widget.properties["default_action"] to "click"
    
    If widget.type is equal to LABEL:
        Set widget.properties["text"] to "Label"
        Set widget.properties["word_wrap"] to false
        Set widget.properties["alignment"] to "left"
    
    If widget.type is equal to TEXT_INPUT:
        Set widget.properties["text"] to ""
        Set widget.properties["placeholder"] to ""
        Set widget.properties["max_length"] to 0
        Set widget.properties["is_password"] to false
        Set widget.properties["is_multiline"] to false
    
    If widget.type is equal to TEXT_AREA:
        Set widget.properties["text"] to ""
        Set widget.properties["placeholder"] to ""
        Set widget.properties["word_wrap"] to true
        Set widget.properties["scroll_bars"] to true
    
    If widget.type is equal to CHECKBOX:
        Set widget.properties["checked"] to false
        Set widget.properties["label"] to "Checkbox"
        Set widget.properties["tristate"] to false
    
    If widget.type is equal to RADIO_BUTTON:
        Set widget.properties["checked"] to false
        Set widget.properties["label"] to "Radio Button"
        Set widget.properties["group"] to "default"
    
    If widget.type is equal to DROPDOWN:
        Set widget.properties["items"] to empty list
        Set widget.properties["selected_index"] to -1
        Set widget.properties["editable"] to false
    
    If widget.type is equal to PROGRESS_BAR:
        Set widget.properties["minimum"] to 0
        Set widget.properties["maximum"] to 100
        Set widget.properties["value"] to 0
        Set widget.properties["show_text"] to true
    
    If widget.type is equal to SLIDER:
        Set widget.properties["minimum"] to 0
        Set widget.properties["maximum"] to 100
        Set widget.properties["value"] to 50
        Set widget.properties["orientation"] to "horizontal"
    
    Note: Initialize common properties for all widgets
    Set widget.properties["tooltip"] to ""
    Set widget.properties["context_menu"] to none
    Set widget.properties["cursor_type"] to "default"

Process called "log_event_error" that takes event as Event and error as Exception returns None:
    Note: Log event processing errors with detailed context information
    Let timestamp be current_timestamp
    Let error_message be "EVENT ERROR [" plus timestamp as string plus "]: "
    
    Set error_message to error_message plus "Event ID: " plus event.id plus ", "
    Set error_message to error_message plus "Type: " plus event.type as string plus ", "
    
    If event.source is not equal to none:
        Set error_message to error_message plus "Source: " plus event.source.id plus ", "
    
    If event.target is not equal to none:
        Set error_message to error_message plus "Target: " plus event.target.id plus ", "
    
    Set error_message to error_message plus "Error: " plus error as string
    
    Note: Write to system log/console
    Call write_to_system_log with level as "ERROR" and message as error_message
    
    Note: Also store in event metadata for debugging
    Set event.metadata["error_occurred"] to true
    Set event.metadata["error_message"] to error as string
    Set event.metadata["error_timestamp"] to timestamp

Process called "apply_absolute_layout" that takes layout as Layout returns None:
    Note: Apply absolute positioning layout - widgets positioned exactly as specified
    For each widget in layout.children:
        Note: Widgets keep their exact bounds as specified
        Let adjusted_x be widget.bounds.x plus layout.padding.left
        Let adjusted_y be widget.bounds.y plus layout.padding.top
        
        Call set_widget_bounds with
            widget as widget and
            x as adjusted_x and
            y as adjusted_y and
            width as widget.bounds.width and
            height as widget.bounds.height

Process called "apply_flow_layout" that takes layout as Layout returns None:
    Note: Apply flow layout - widgets flow left to right, wrapping to new line
    Let current_x be layout.padding.left
    Let current_y be layout.padding.top
    Let max_height_in_row be 0
    Let container_width be layout.container.bounds.width minus layout.padding.left minus layout.padding.right
    
    For each widget in layout.children:
        If widget.is_visible is equal to false:
            Continue
        
        Let widget_width be widget.bounds.width plus widget.style.margin.left plus widget.style.margin.right
        Let widget_height be widget.bounds.height plus widget.style.margin.top plus widget.style.margin.bottom
        
        Note: Check if widget fits in current row
        If current_x plus widget_width is greater than container_width and current_x is greater than layout.padding.left:
            Note: Move to next row
            Set current_x to layout.padding.left
            Set current_y to current_y plus max_height_in_row
            Set max_height_in_row to 0
        
        Note: Position widget
        Call set_widget_bounds with
            widget as widget and
            x as current_x plus widget.style.margin.left and
            y as current_y plus widget.style.margin.top and
            width as widget.bounds.width and
            height as widget.bounds.height
        
        Set current_x to current_x plus widget_width
        If widget_height is greater than max_height_in_row:
            Set max_height_in_row to widget_height

Process called "apply_grid_layout" that takes layout as Layout returns None:
    Note: Apply grid layout - widgets arranged in rows and columns
    Let grid_columns be layout.properties["columns"] or 3
    Let grid_rows be layout.properties["rows"] or 3
    Let cell_width be (layout.container.bounds.width minus layout.padding.left minus layout.padding.right) divided by grid_columns
    Let cell_height be (layout.container.bounds.height minus layout.padding.top minus layout.padding.bottom) divided by grid_rows
    
    Let widget_index be 0
    
    For each widget in layout.children:
        If widget.is_visible is equal to false:
            Continue
        
        Let column be widget_index modulo grid_columns
        Let row be widget_index divided by grid_columns
        
        Let cell_x be layout.padding.left plus (column times cell_width)
        Let cell_y be layout.padding.top plus (row times cell_height)
        
        Note: Center widget in cell with margins
        Let widget_x be cell_x plus widget.style.margin.left
        Let widget_y be cell_y plus widget.style.margin.top
        Let widget_width be cell_width minus widget.style.margin.left minus widget.style.margin.right
        Let widget_height be cell_height minus widget.style.margin.top minus widget.style.margin.bottom
        
        Call set_widget_bounds with
            widget as widget and
            x as widget_x and
            y as widget_y and
            width as widget_width and
            height as widget_height
        
        Set widget_index to widget_index plus 1

Process called "apply_border_layout" that takes layout as Layout returns None:
    Note: Apply border layout - widgets positioned at north, south, east, west, center
    Let container_bounds be layout.container.bounds
    Let north_height be 0
    Let south_height be 0
    Let east_width be 0
    Let west_width be 0
    
    Note: Find widgets by position
    Let north_widget be none
    Let south_widget be none
    Let east_widget be none
    Let west_widget be none
    Let center_widget be none
    
    For each widget in layout.children:
        Let position be widget.properties["border_position"] or "center"
        
        If position is equal to "north":
            Set north_widget to widget
            Set north_height to widget.bounds.height
        If position is equal to "south":
            Set south_widget to widget
            Set south_height to widget.bounds.height
        If position is equal to "east":
            Set east_widget to widget
            Set east_width to widget.bounds.width
        If position is equal to "west":
            Set west_widget to widget
            Set west_width to widget.bounds.width
        If position is equal to "center":
            Set center_widget to widget
    
    Note: Position widgets
    If north_widget is not equal to none:
        Call set_widget_bounds with
            widget as north_widget and
            x as layout.padding.left and
            y as layout.padding.top and
            width as container_bounds.width minus layout.padding.left minus layout.padding.right and
            height as north_height
    
    If south_widget is not equal to none:
        Call set_widget_bounds with
            widget as south_widget and
            x as layout.padding.left and
            y as container_bounds.height minus layout.padding.bottom minus south_height and
            width as container_bounds.width minus layout.padding.left minus layout.padding.right and
            height as south_height
    
    If west_widget is not equal to none:
        Call set_widget_bounds with
            widget as west_widget and
            x as layout.padding.left and
            y as layout.padding.top plus north_height and
            width as west_width and
            height as container_bounds.height minus layout.padding.top minus layout.padding.bottom minus north_height minus south_height
    
    If east_widget is not equal to none:
        Call set_widget_bounds with
            widget as east_widget and
            x as container_bounds.width minus layout.padding.right minus east_width and
            y as layout.padding.top plus north_height and
            width as east_width and
            height as container_bounds.height minus layout.padding.top minus layout.padding.bottom minus north_height minus south_height
    
    If center_widget is not equal to none:
        Call set_widget_bounds with
            widget as center_widget and
            x as layout.padding.left plus west_width and
            y as layout.padding.top plus north_height and
            width as container_bounds.width minus layout.padding.left minus layout.padding.right minus west_width minus east_width and
            height as container_bounds.height minus layout.padding.top minus layout.padding.bottom minus north_height minus south_height

Process called "apply_box_layout" that takes layout as Layout returns None:
    Note: Apply box layout - widgets arranged vertically or horizontally
    Let orientation be layout.properties["orientation"] or "vertical"
    Let current_x be layout.padding.left
    Let current_y be layout.padding.top
    
    For each widget in layout.children:
        If widget.is_visible is equal to false:
            Continue
        
        If orientation is equal to "vertical":
            Note: Stack widgets vertically
            Let widget_width be layout.container.bounds.width minus layout.padding.left minus layout.padding.right minus widget.style.margin.left minus widget.style.margin.right
            
            Call set_widget_bounds with
                widget as widget and
                x as current_x plus widget.style.margin.left and
                y as current_y plus widget.style.margin.top and
                width as widget_width and
                height as widget.bounds.height
            
            Set current_y to current_y plus widget.bounds.height plus widget.style.margin.top plus widget.style.margin.bottom
        
        Otherwise:
            Note: Stack widgets horizontally
            Let widget_height be layout.container.bounds.height minus layout.padding.top minus layout.padding.bottom minus widget.style.margin.top minus widget.style.margin.bottom
            
            Call set_widget_bounds with
                widget as widget and
                x as current_x plus widget.style.margin.left and
                y as current_y plus widget.style.margin.top and
                width as widget.bounds.width and
                height as widget_height
            
            Set current_x to current_x plus widget.bounds.width plus widget.style.margin.left plus widget.style.margin.right

Process called "apply_flex_layout" that takes layout as Layout returns None:
    Note: Apply flexible layout - widgets grow/shrink based on flex properties
    Let direction be layout.properties["flex_direction"] or "row"
    Let justify_content be layout.properties["justify_content"] or "flex_start"
    Let align_items be layout.properties["align_items"] or "stretch"
    
    Let container_width be layout.container.bounds.width minus layout.padding.left minus layout.padding.right
    Let container_height be layout.container.bounds.height minus layout.padding.top minus layout.padding.bottom
    
    Note: Calculate total flex values and fixed sizes
    Let total_flex be 0
    Let total_fixed_size be 0
    
    For each widget in layout.children:
        If widget.is_visible is equal to false:
            Continue
        
        Let flex_value be widget.properties["flex"] or 0
        Set total_flex to total_flex plus flex_value
        
        If direction is equal to "row":
            If flex_value is equal to 0:
                Set total_fixed_size to total_fixed_size plus widget.bounds.width
        Otherwise:
            If flex_value is equal to 0:
                Set total_fixed_size to total_fixed_size plus widget.bounds.height
    
    Note: Calculate available space for flexible items
    Let available_space be 0
    If direction is equal to "row":
        Set available_space to container_width minus total_fixed_size
    Otherwise:
        Set available_space to container_height minus total_fixed_size
    
    Note: Position widgets
    Let current_x be layout.padding.left
    Let current_y be layout.padding.top
    
    For each widget in layout.children:
        If widget.is_visible is equal to false:
            Continue
        
        Let flex_value be widget.properties["flex"] or 0
        Let widget_width be widget.bounds.width
        Let widget_height be widget.bounds.height
        
        If direction is equal to "row":
            If flex_value is greater than 0:
                Set widget_width to (available_space times flex_value) divided by total_flex
            
            If align_items is equal to "stretch":
                Set widget_height to container_height
            
            Call set_widget_bounds with
                widget as widget and
                x as current_x and
                y as current_y and
                width as widget_width and
                height as widget_height
            
            Set current_x to current_x plus widget_width
        
        Otherwise:
            If flex_value is greater than 0:
                Set widget_height to (available_space times flex_value) divided by total_flex
            
            If align_items is equal to "stretch":
                Set widget_width to container_width
            
            Call set_widget_bounds with
                widget as widget and
                x as current_x and
                y as current_y and
                width as widget_width and
                height as widget_height
            
            Set current_y to current_y plus widget_height

Process called "apply_stack_layout" that takes layout as Layout returns None:
    Note: Apply stack layout - widgets stacked on top of each other with z-ordering
    Let container_width be layout.container.bounds.width minus layout.padding.left minus layout.padding.right
    Let container_height be layout.container.bounds.height minus layout.padding.top minus layout.padding.bottom
    
    Note: Sort widgets by z-index to ensure proper stacking order
    Let sorted_widgets be sort_widgets_by_z_index with widgets as layout.children
    
    For each widget in sorted_widgets:
        If widget.is_visible is equal to false:
            Continue
        
        Let alignment be widget.properties["stack_alignment"] or "center"
        Let widget_x be layout.padding.left
        Let widget_y be layout.padding.top
        Let widget_width be widget.bounds.width
        Let widget_height be widget.bounds.height
        
        Note: Position based on alignment
        If alignment contains "left":
            Set widget_x to layout.padding.left
        Otherwise if alignment contains "right":
            Set widget_x to layout.padding.left plus container_width minus widget_width
        Otherwise if alignment contains "center":
            Set widget_x to layout.padding.left plus (container_width minus widget_width) divided by 2
        
        If alignment contains "top":
            Set widget_y to layout.padding.top
        Otherwise if alignment contains "bottom":
            Set widget_y to layout.padding.top plus container_height minus widget_height
        Otherwise if alignment contains "center":
            Set widget_y to layout.padding.top plus (container_height minus widget_height) divided by 2
        
        Call set_widget_bounds with
            widget as widget and
            x as widget_x and
            y as widget_y and
            width as widget_width and
            height as widget_height
        
        Note: Ensure z-index is applied for proper stacking
        Call update_widget_z_order with widget as widget

Process called "invalidate_container_rendering" that takes container as Widget returns None:
    Note: Mark container and all child widgets for redraw
    Call invalidate_widget_rendering with widget as container
    
    Note: Recursively invalidate all child widgets
    For each child_widget in container.children:
        Call invalidate_widget_rendering with widget as child_widget
        
        Note: If child is also a container, invalidate its children too
        If list_length with list as child_widget.children is greater than 0:
            Call invalidate_container_rendering with container as child_widget

Process called "update_widget_native_style" that takes widget as Widget and style as WidgetStyle returns None:
    Note: Update native widget style using platform-specific APIs
    Let os_type be get_operating_system_name
    
    If os_type is equal to "Windows":
        Note: Apply Windows-specific styling
        Call windows_set_widget_background_color with widget_id as widget.id and color as style.background_color
        Call windows_set_widget_foreground_color with widget_id as widget.id and color as style.foreground_color
        Call windows_set_widget_font with widget_id as widget.id and font as style.font
        Call windows_set_widget_border with widget_id as widget.id and border_width as style.border_width and border_color as style.border_color
    
    If os_type is equal to "Linux":
        Note: Apply GTK/X11-specific styling
        Let display be linux_get_x11_display
        If display is not equal to null:
            Call linux_set_widget_style with display as display and widget_id as widget.id and style as style
    
    If os_type is equal to "macOS":
        Note: Apply Cocoa-specific styling
        Call macos_set_view_appearance with widget_id as widget.id and style as style
    
    Note: Update widget's cached style reference
    Set widget.style to style

Process called "invalidate_widget_rendering" that takes widget as Widget returns None:
    Note: Mark widget for redraw using platform-specific invalidation
    Let os_type be get_operating_system_name
    
    If os_type is equal to "Windows":
        Call windows_invalidate_widget_rect with widget_id as widget.id
    
    If os_type is equal to "Linux":
        Let display be linux_get_x11_display
        If display is not equal to null:
            Call linux_expose_widget with display as display and widget_id as widget.id
    
    If os_type is equal to "macOS":
        Call macos_set_widget_needs_display with widget_id as widget.id
    
    Note: Update widget metadata to track invalidation
    Set widget.metadata["last_invalidated"] to current_timestamp
    Set widget.metadata["needs_redraw"] to true

Process called "create_default_color_palette" that returns Dictionary[String, Color]:
    Note: Create comprehensive default color palette for theming
    Let color_palette be empty dictionary
    
    Note: Primary colors
    Set color_palette["primary"] to Color with red as 0 and green as 123 and blue as 255 and alpha as 255
    Set color_palette["primary_light"] to Color with red as 66 and green as 165 and blue as 245 and alpha as 255
    Set color_palette["primary_dark"] to Color with red as 0 and green as 86 and blue as 179 and alpha as 255
    
    Note: Secondary colors
    Set color_palette["secondary"] to Color with red as 156 and green as 39 and blue as 176 and alpha as 255
    Set color_palette["secondary_light"] to Color with red as 186 and green as 104 and blue as 200 and alpha as 255
    Set color_palette["secondary_dark"] to Color with red as 123 and green as 31 and blue as 162 and alpha as 255
    
    Note: Background colors
    Set color_palette["background"] to Color with red as 255 and green as 255 and blue as 255 and alpha as 255
    Set color_palette["background_paper"] to Color with red as 250 and green as 250 and blue as 250 and alpha as 255
    Set color_palette["background_dark"] to Color with red as 48 and green as 48 and blue as 48 and alpha as 255
    
    Note: Text colors
    Set color_palette["text_primary"] to Color with red as 33 and green as 33 and blue as 33 and alpha as 255
    Set color_palette["text_secondary"] to Color with red as 117 and green as 117 and blue as 117 and alpha as 255
    Set color_palette["text_disabled"] to Color with red as 189 and green as 189 and blue as 189 and alpha as 255
    Set color_palette["text_hint"] to Color with red as 158 and green as 158 and blue as 158 and alpha as 255
    
    Note: Success, Warning, Error colors
    Set color_palette["success"] to Color with red as 76 and green as 175 and blue as 80 and alpha as 255
    Set color_palette["warning"] to Color with red as 255 and green as 152 and blue as 0 and alpha as 255
    Set color_palette["error"] to Color with red as 244 and green as 67 and blue as 54 and alpha as 255
    Set color_palette["info"] to Color with red as 33 and green as 150 and blue as 243 and alpha as 255
    
    Note: Border and divider colors
    Set color_palette["border"] to Color with red as 224 and green as 224 and blue as 224 and alpha as 255
    Set color_palette["divider"] to Color with red as 238 and green as 238 and blue as 238 and alpha as 255
    
    Return color_palette

Process called "create_default_font_set" that returns Dictionary[String, Font]:
    Note: Create comprehensive default font set for different use cases
    Let font_set be empty dictionary
    
    Note: Primary fonts
    Set font_set["default"] to Font with family as "System" and size as 14.0 and weight as REGULAR and style as NORMAL and stretch as NORMAL
    Set font_set["heading_large"] to Font with family as "System" and size as 24.0 and weight as BOLD and style as NORMAL and stretch as NORMAL
    Set font_set["heading_medium"] to Font with family as "System" and size as 20.0 and weight as SEMI_BOLD and style as NORMAL and stretch as NORMAL
    Set font_set["heading_small"] to Font with family as "System" and size as 16.0 and weight as SEMI_BOLD and style as NORMAL and stretch as NORMAL
    
    Note: Body text fonts
    Set font_set["body_large"] to Font with family as "System" and size as 16.0 and weight as REGULAR and style as NORMAL and stretch as NORMAL
    Set font_set["body_medium"] to Font with family as "System" and size as 14.0 and weight as REGULAR and style as NORMAL and stretch as NORMAL
    Set font_set["body_small"] to Font with family as "System" and size as 12.0 and weight as REGULAR and style as NORMAL and stretch as NORMAL
    
    Note: UI element fonts
    Set font_set["button"] to Font with family as "System" and size as 14.0 and weight as MEDIUM and style as NORMAL and stretch as NORMAL
    Set font_set["caption"] to Font with family as "System" and size as 12.0 and weight as REGULAR and style as NORMAL and stretch as NORMAL
    Set font_set["label"] to Font with family as "System" and size as 11.0 and weight as MEDIUM and style as NORMAL and stretch as NORMAL
    
    Note: Monospace fonts for code
    Set font_set["monospace"] to Font with family as "Courier New" and size as 13.0 and weight as REGULAR and style as NORMAL and stretch as NORMAL
    Set font_set["code"] to Font with family as "Consolas" and size as 13.0 and weight as REGULAR and style as NORMAL and stretch as NORMAL
    
    Return font_set

Process called "create_default_widget_styles" that returns Dictionary[String, WidgetStyle]:
    Note: Create comprehensive default widget styles for all widget types
    Let widget_styles be empty dictionary
    Let default_colors be create_default_color_palette
    Let default_fonts be create_default_font_set
    
    Note: Button styles
    Set widget_styles["button"] to WidgetStyle with:
        background_color as default_colors["primary"]
        foreground_color as Color with red as 255 and green as 255 and blue as 255 and alpha as 255
        border_color as default_colors["primary_dark"]
        border_width as 1
        border_radius as 4
        font as default_fonts["button"]
        padding as Padding with top as 8 and right as 16 and bottom as 8 and left as 16
        margin as Margins with top as 4 and right as 4 and bottom as 4 and left as 4
        opacity as 1.0
        shadow as Shadow with color as Color with red as 0 and green as 0 and blue as 0 and alpha as 64 and offset_x as 0 and offset_y as 2 and blur_radius as 4 and spread_radius as 0
        animation as none
        custom_properties as empty dictionary
    
    Note: Label styles
    Set widget_styles["label"] to WidgetStyle with:
        background_color as none
        foreground_color as default_colors["text_primary"]
        border_color as none
        border_width as 0
        border_radius as 0
        font as default_fonts["body_medium"]
        padding as Padding with top as 2 and right as 2 and bottom as 2 and left as 2
        margin as Margins with top as 2 and right as 2 and bottom as 2 and left as 2
        opacity as 1.0
        shadow as none
        animation as none
        custom_properties as empty dictionary
    
    Note: Text input styles
    Set widget_styles["text_input"] to WidgetStyle with:
        background_color as Color with red as 255 and green as 255 and blue as 255 and alpha as 255
        foreground_color as default_colors["text_primary"]
        border_color as default_colors["border"]
        border_width as 1
        border_radius as 4
        font as default_fonts["body_medium"]
        padding as Padding with top as 8 and right as 12 and bottom as 8 and left as 12
        margin as Margins with top as 4 and right as 4 and bottom as 4 and left as 4
        opacity as 1.0
        shadow as none
        animation as none
        custom_properties as empty dictionary
    
    Note: Panel/container styles
    Set widget_styles["panel"] to WidgetStyle with:
        background_color as default_colors["background_paper"]
        foreground_color as default_colors["text_primary"]
        border_color as default_colors["border"]
        border_width as 1
        border_radius as 4
        font as default_fonts["default"]
        padding as Padding with top as 12 and right as 12 and bottom as 12 and left as 12
        margin as Margins with top as 4 and right as 4 and bottom as 4 and left as 4
        opacity as 1.0
        shadow as Shadow with color as Color with red as 0 and green as 0 and blue as 0 and alpha as 32 and offset_x as 0 and offset_y as 1 and blur_radius as 3 and spread_radius as 0
        animation as none
        custom_properties as empty dictionary
    
    Return widget_styles

Process called "create_default_animations" that returns Dictionary[String, Animation]:
    Note: Create default animations for common UI transitions
    Let animations be empty dictionary
    
    Note: Fade animations
    Set animations["fade_in"] to Animation with:
        duration as 0.3
        timing_function as EASE_OUT
        delay as 0.0
        iteration_count as 1
        direction as NORMAL
        fill_mode as FORWARDS
    
    Set animations["fade_out"] to Animation with:
        duration as 0.2
        timing_function as EASE_IN
        delay as 0.0
        iteration_count as 1
        direction as NORMAL
        fill_mode as FORWARDS
    
    Note: Scale animations
    Set animations["scale_up"] to Animation with:
        duration as 0.2
        timing_function as EASE_OUT
        delay as 0.0
        iteration_count as 1
        direction as NORMAL
        fill_mode as FORWARDS
    
    Set animations["scale_down"] to Animation with:
        duration as 0.15
        timing_function as EASE_IN
        delay as 0.0
        iteration_count as 1
        direction as NORMAL
        fill_mode as FORWARDS
    
    Note: Slide animations
    Set animations["slide_in_left"] to Animation with:
        duration as 0.3
        timing_function as EASE_OUT
        delay as 0.0
        iteration_count as 1
        direction as NORMAL
        fill_mode as FORWARDS
    
    Set animations["slide_out_right"] to Animation with:
        duration as 0.3
        timing_function as EASE_IN
        delay as 0.0
        iteration_count as 1
        direction as NORMAL
        fill_mode as FORWARDS
    
    Note: Button hover animation
    Set animations["button_hover"] to Animation with:
        duration as 0.15
        timing_function as EASE
        delay as 0.0
        iteration_count as 1
        direction as NORMAL
        fill_mode as FORWARDS
    
    Return animations

Process called "create_default_theme" that returns Theme:
    Return create_theme with theme_name as "Default"

Process called "get_primary_screen_info" that returns ScreenInfo:
    Note: Get actual primary screen information using platform-specific APIs
    Let os_type be get_operating_system_name
    
    If os_type is equal to "Windows":
        Let screen_info be windows_get_primary_monitor_info
        If screen_info is not equal to null:
            Return screen_info
    
    If os_type is equal to "Linux":
        Let xrandr_output be execute_system_command with command as "xrandr --query --current"
        If xrandr_output is not equal to "":
            Let primary_screen_info be parse_linux_primary_screen_info with output as xrandr_output
            If primary_screen_info is not equal to null:
                Return primary_screen_info
    
    If os_type is equal to "macOS":
        Let screen_info be execute_system_command with command as "system_profiler SPDisplaysDataType"
        If screen_info is not equal to "":
            Let parsed_info be parse_macos_primary_screen_info with output as screen_info
            If parsed_info is not equal to null:
                Return parsed_info
    
    Note: Fallback to detected screen resolution
    Let detected_resolution be detect_screen_resolution_fallback
    Return ScreenInfo with:
        id as "primary_detected"
        bounds as Rectangle with x as 0 and y as 0 and width as detected_resolution.width and height as detected_resolution.height
        working_area as Rectangle with x as 0 and y as 0 and width as detected_resolution.width and height as detected_resolution.height minus 40
        scale_factor as detect_system_display_scaling
        refresh_rate as detect_screen_refresh_rate
        color_depth as detect_screen_color_depth
        is_primary as true

Process called "get_all_screen_info" that returns List[ScreenInfo]:
    Note: Get information for all connected screens/monitors
    Let screen_list be empty list
    Let os_type be get_operating_system_name
    
    If os_type is equal to "Windows":
        Let monitors_output be execute_system_command with command as "wmic desktopmonitor get ScreenWidth,ScreenHeight,Name /format:csv"
        If monitors_output is not equal to "":
            Let parsed_screens be parse_windows_all_screens with output as monitors_output
            If parsed_screens is not equal to null and list_length with list as parsed_screens is greater than 0:
                Return parsed_screens
    
    If os_type is equal to "Linux":
        Let xrandr_output be execute_system_command with command as "xrandr --query --current"
        If xrandr_output is not equal to "":
            Let parsed_screens be parse_linux_all_screens with output as xrandr_output
            If parsed_screens is not equal to null and list_length with list as parsed_screens is greater than 0:
                Return parsed_screens
    
    If os_type is equal to "macOS":
        Let screen_info be execute_system_command with command as "system_profiler SPDisplaysDataType"
        If screen_info is not equal to "":
            Let parsed_screens be parse_macos_all_screens with output as screen_info
            If parsed_screens is not equal to null and list_length with list as parsed_screens is greater than 0:
                Return parsed_screens
    
    Note: Fallback to primary screen only
    Let primary_screen be get_primary_screen_info
    Call screen_list.append with item as primary_screen
    Return screen_list

Note: Custom GUI Exceptions
Type GUIError as Exception