Note: Native System Access Module
Note: Provides low-level native system access for desktop applications including
Note: FFI bindings, system calls, hardware access, and platform-specific APIs
Note: with safe abstractions for cross-platform desktop development.

Import "desktop/gui" as gui
Import "collections/list" as list_utils
Import "collections/dict" as dict_utils
Import "io/file" as file_system

Note: Native System Types

Type NativeHandle is Dictionary with:
    handle_type as HandleType
    value as Integer
    is_valid as Boolean
    platform as Platform
    metadata as Dictionary[String, Any]

Type HandleType is:
    | WINDOW_HANDLE
    | PROCESS_HANDLE
    | THREAD_HANDLE
    | FILE_HANDLE
    | REGISTRY_KEY
    | SOCKET_HANDLE
    | MEMORY_HANDLE
    | DEVICE_HANDLE
    | EVENT_HANDLE
    | MUTEX_HANDLE

Type Platform is:
    | WINDOWS
    | MACOS
    | LINUX
    | FREEBSD
    | OPENBSD
    | UNKNOWN

Type SystemInfo is Dictionary with:
    platform as Platform
    architecture as String
    endianness as String
    pointer_size as Integer
    page_size as Integer
    cpu_count as Integer
    total_memory as Integer
    available_memory as Integer
    os_version as String
    kernel_version as String
    hostname as String
    username as String
    metadata as Dictionary[String, Any]

Type ProcessInfo is Dictionary with:
    process_id as Integer
    parent_process_id as Integer
    executable_path as String
    command_line as String
    working_directory as String
    environment_variables as Dictionary[String, String]
    cpu_usage as Float
    memory_usage as Integer
    thread_count as Integer
    start_time as Integer
    is_running as Boolean
    metadata as Dictionary[String, Any]

Note: Native API Interface

Process called "get_native_system_info" that returns SystemInfo:
    Note: Get comprehensive native system information
    Try:
        Let platform be detect_current_platform
        
        Return SystemInfo with:
            platform as platform
            architecture as get_system_architecture
            endianness as get_system_endianness
            pointer_size as get_pointer_size
            page_size as get_memory_page_size
            cpu_count as get_cpu_count
            total_memory as get_total_memory
            available_memory as get_available_memory
            os_version as get_os_version
            kernel_version as get_kernel_version
            hostname as get_hostname
            username as get_current_username
            metadata as Dictionary with "retrieved_at" as current_timestamp
    
    Catch error as Exception:
        Note: On complete failure, return basic detectable system info
        Let fallback_platform be detect_current_platform_basic
        Let fallback_arch be detect_basic_architecture
        
        Return SystemInfo with:
            platform as fallback_platform
            architecture as fallback_arch
            endianness as get_system_endianness
            pointer_size as get_pointer_size
            page_size as get_memory_page_size
            cpu_count as get_cpu_count
            total_memory as get_total_physical_memory
            available_memory as get_available_physical_memory
            os_version as get_os_version
            kernel_version as get_kernel_version
            hostname as get_hostname
            username as get_current_username
            metadata as Dictionary with "error" as error as string and "fallback_detection" as true

Process called "create_native_window_handle" that takes window as gui.Window returns NativeHandle:
    Note: Create native window handle for platform-specific operations
    Try:
        Let platform be detect_current_platform
        Let native_value be 0
        
        If platform is equal to WINDOWS:
            Set native_value to create_windows_window_handle with window as window
        Otherwise if platform is equal to MACOS:
            Set native_value to create_macos_window_handle with window as window
        Otherwise if platform is equal to LINUX:
            Set native_value to create_linux_window_handle with window as window
        
        Return NativeHandle with:
            handle_type as WINDOW_HANDLE
            value as native_value
            is_valid as native_value is not equal to 0
            platform as platform
            metadata as Dictionary with:
                "window_id" as window.id
                "created_at" as current_timestamp
    
    Catch error as Exception:
        Return NativeHandle with:
            handle_type as WINDOW_HANDLE
            value as 0
            is_valid as false
            platform as UNKNOWN
            metadata as Dictionary with "error" as error as string

Note: Process and Thread Management

Process called "get_current_process_info" that returns ProcessInfo:
    Note: Get information about the current process
    Try:
        Let process_id be get_current_process_id
        
        Return ProcessInfo with:
            process_id as process_id
            parent_process_id as get_parent_process_id with pid as process_id
            executable_path as get_executable_path
            command_line as get_command_line
            working_directory as get_current_working_directory
            environment_variables as get_environment_variables
            cpu_usage as get_process_cpu_usage with pid as process_id
            memory_usage as get_process_memory_usage with pid as process_id
            thread_count as get_process_thread_count with pid as process_id
            start_time as get_process_start_time with pid as process_id
            is_running as true
            metadata as Dictionary with "retrieved_at" as current_timestamp
    
    Catch error as Exception:
        Throw NativeSystemError with message as "Failed to get process info: " plus error as string

Process called "enumerate_processes" that returns List[ProcessInfo]:
    Note: Enumerate all running processes
    Try:
        Let process_list be empty list
        Let process_ids be get_all_process_ids
        
        For each pid in process_ids:
            Try:
                Let process_info be get_process_info with pid as pid
                Call process_list.append with item as process_info
            Catch process_error as Exception:
                Note: Skip processes we cannot access
                Continue
        
        Return process_list
    
    Catch error as Exception:
        Throw NativeSystemError with message as "Failed to enumerate processes: " plus error as string

Process called "create_native_thread" that takes function as Function and arguments as List[Any] returns ThreadHandle:
    Note: Create native thread with platform-specific implementation
    Try:
        Let platform be detect_current_platform
        Let thread_handle be 0
        
        If platform is equal to WINDOWS:
            Set thread_handle to create_windows_thread with function as function and args as arguments
        Otherwise if platform is equal to MACOS or platform is equal to LINUX:
            Set thread_handle to create_pthread with function as function and args as arguments
        
        Return ThreadHandle with:
            handle as thread_handle
            is_running as thread_handle is not equal to 0
            platform as platform
            start_time as current_timestamp
            metadata as Dictionary with "created_with_native_api" as true
    
    Catch error as Exception:
        Return ThreadHandle with:
            handle as 0
            is_running as false
            platform as UNKNOWN
            start_time as current_timestamp
            metadata as Dictionary with "error" as error as string

Type ThreadHandle is Dictionary with:
    handle as Integer
    is_running as Boolean
    platform as Platform
    start_time as Integer
    metadata as Dictionary[String, Any]

Note: Memory Management

Process called "allocate_native_memory" that takes size as Integer and alignment as Optional[Integer] returns MemoryBlock:
    Note: Allocate native memory with platform-specific alignment
    Try:
        If size is less than or equal to 0:
            Throw NativeSystemError with message as "Invalid memory size"
        
        Let final_alignment be alignment or get_default_alignment
        Let platform be detect_current_platform
        Let memory_address be 0
        
        If platform is equal to WINDOWS:
            Set memory_address to windows_virtual_alloc with size as size and alignment as final_alignment
        Otherwise if platform is equal to MACOS or platform is equal to LINUX:
            Set memory_address to posix_aligned_alloc with size as size and alignment as final_alignment
        
        Return MemoryBlock with:
            address as memory_address
            size as size
            alignment as final_alignment
            is_allocated as memory_address is not equal to 0
            platform as platform
            allocation_time as current_timestamp
            metadata as Dictionary with "allocator" as "native_api"
    
    Catch error as Exception:
        Return MemoryBlock with:
            address as 0
            size as 0
            alignment as 0
            is_allocated as false
            platform as UNKNOWN
            allocation_time as current_timestamp
            metadata as Dictionary with "error" as error as string

Type MemoryBlock is Dictionary with:
    address as Integer
    size as Integer
    alignment as Integer
    is_allocated as Boolean
    platform as Platform
    allocation_time as Integer
    metadata as Dictionary[String, Any]

Process called "free_native_memory" that takes memory_block as MemoryBlock returns None:
    Note: Free native memory using platform-specific API
    Try:
        If not memory_block.is_allocated:
            Return
        
        If memory_block.platform is equal to WINDOWS:
            Call windows_virtual_free with address as memory_block.address
        Otherwise if memory_block.platform is equal to MACOS or memory_block.platform is equal to LINUX:
            Call posix_free with address as memory_block.address
        
        Set memory_block.is_allocated to false
        Set memory_block.metadata["freed_at"] to current_timestamp
    
    Catch error as Exception:
        Throw NativeSystemError with message as "Failed to free native memory: " plus error as string

Process called "get_memory_info" that returns MemoryInfo:
    Note: Get system memory information
    Try:
        Let platform be detect_current_platform
        
        Return MemoryInfo with:
            total_physical as get_total_physical_memory
            available_physical as get_available_physical_memory
            total_virtual as get_total_virtual_memory
            available_virtual as get_available_virtual_memory
            page_size as get_memory_page_size
            allocation_granularity as get_allocation_granularity
            platform as platform
            metadata as Dictionary with "retrieved_at" as current_timestamp
    
    Catch error as Exception:
        Throw NativeSystemError with message as "Failed to get memory info: " plus error as string

Type MemoryInfo is Dictionary with:
    total_physical as Integer
    available_physical as Integer
    total_virtual as Integer
    available_virtual as Integer
    page_size as Integer
    allocation_granularity as Integer
    platform as Platform
    metadata as Dictionary[String, Any]

Note: File System Access

Process called "get_native_file_handle" that takes file_path as String and access_mode as FileAccessMode returns NativeFileHandle:
    Note: Get native file handle with platform-specific access
    Try:
        Let platform be detect_current_platform
        Let native_handle be 0
        
        If platform is equal to WINDOWS:
            Set native_handle to create_windows_file_handle with path as file_path and mode as access_mode
        Otherwise if platform is equal to MACOS or platform is equal to LINUX:
            Set native_handle to create_posix_file_handle with path as file_path and mode as access_mode
        
        Return NativeFileHandle with:
            handle as native_handle
            file_path as file_path
            access_mode as access_mode
            is_valid as native_handle is not equal to 0
            platform as platform
            opened_at as current_timestamp
            metadata as Dictionary with "native_api_used" as true
    
    Catch error as Exception:
        Return NativeFileHandle with:
            handle as 0
            file_path as file_path
            access_mode as access_mode
            is_valid as false
            platform as UNKNOWN
            opened_at as current_timestamp
            metadata as Dictionary with "error" as error as string

Type FileAccessMode is:
    | READ_ONLY
    | WRITE_ONLY
    | READ_WRITE
    | APPEND
    | CREATE_NEW
    | CREATE_ALWAYS

Type NativeFileHandle is Dictionary with:
    handle as Integer
    file_path as String
    access_mode as FileAccessMode
    is_valid as Boolean
    platform as Platform
    opened_at as Integer
    metadata as Dictionary[String, Any]

Process called "read_native_file" that takes file_handle as NativeFileHandle and buffer_size as Integer returns FileReadResult:
    Note: Read from native file handle
    Try:
        If not file_handle.is_valid:
            Return FileReadResult with:
                data as empty list
                bytes_read as 0
                success as false
                error_message as "Invalid file handle"
        
        Let data be empty list
        Let bytes_read be 0
        
        If file_handle.platform is equal to WINDOWS:
            Let result be windows_read_file with handle as file_handle.handle and size as buffer_size
            Set data to result.data
            Set bytes_read to result.bytes_read
        Otherwise if file_handle.platform is equal to MACOS or file_handle.platform is equal to LINUX:
            Let result be posix_read_file with handle as file_handle.handle and size as buffer_size
            Set data to result.data
            Set bytes_read to result.bytes_read
        
        Return FileReadResult with:
            data as data
            bytes_read as bytes_read
            success as true
            error_message as ""
    
    Catch error as Exception:
        Return FileReadResult with:
            data as empty list
            bytes_read as 0
            success as false
            error_message as error as string

Type FileReadResult is Dictionary with:
    data as List[Integer]
    bytes_read as Integer
    success as Boolean
    error_message as String

Note: Hardware Access

Process called "get_cpu_info" that returns CPUInfo:
    Note: Get detailed CPU information
    Try:
        Return CPUInfo with:
            brand as get_cpu_brand
            architecture as get_cpu_architecture
            core_count as get_physical_core_count
            thread_count as get_logical_core_count
            base_frequency as get_cpu_base_frequency
            max_frequency as get_cpu_max_frequency
            cache_sizes as get_cpu_cache_sizes
            features as get_cpu_features
            vendor as get_cpu_vendor
            model as get_cpu_model
            stepping as get_cpu_stepping
            metadata as Dictionary with "retrieved_at" as current_timestamp
    
    Catch error as Exception:
        Return CPUInfo with:
            brand as ""
            architecture as ""
            core_count as -1
            thread_count as -1
            base_frequency as -1
            max_frequency as -1
            cache_sizes as empty dictionary
            features as empty list
            vendor as ""
            model as -1
            stepping as -1
            metadata as Dictionary with "detection_failed" as true

Type CPUInfo is Dictionary with:
    brand as String
    architecture as String
    core_count as Integer
    thread_count as Integer
    base_frequency as Integer
    max_frequency as Integer
    cache_sizes as Dictionary[String, Integer]
    features as List[String]
    vendor as String
    model as Integer
    stepping as Integer
    metadata as Dictionary[String, Any]

Process called "get_gpu_info" that returns List[GPUInfo]:
    Note: Get information about available graphics cards
    Try:
        Let gpu_list be empty list
        Let platform be detect_current_platform
        
        If platform is equal to WINDOWS:
            Set gpu_list to enumerate_windows_gpus
        Otherwise if platform is equal to MACOS:
            Set gpu_list to enumerate_macos_gpus
        Otherwise if platform is equal to LINUX:
            Set gpu_list to enumerate_linux_gpus
        
        Return gpu_list
    
    Catch error as Exception:
        Return list containing GPUInfo with:
            name as ""
            vendor as ""
            device_id as -1
            memory_size as -1
            driver_version as ""
            is_integrated as false
            compute_units as -1
            metadata as Dictionary with "detection_failed" as true

Type GPUInfo is Dictionary with:
    name as String
    vendor as String
    device_id as Integer
    memory_size as Integer
    driver_version as String
    is_integrated as Boolean
    compute_units as Integer
    metadata as Dictionary[String, Any]

Note: Network Interface Access

Process called "get_network_interfaces" that returns List[NetworkInterface]:
    Note: Get information about network interfaces
    Try:
        Let interface_list be empty list
        Let platform be detect_current_platform
        
        If platform is equal to WINDOWS:
            Set interface_list to enumerate_windows_interfaces
        Otherwise if platform is equal to MACOS or platform is equal to LINUX:
            Set interface_list to enumerate_unix_interfaces
        
        Return interface_list
    
    Catch error as Exception:
        Return list containing NetworkInterface with:
            name as "lo"
            description as "Loopback Interface"
            mac_address as "00:00:00:00:00:00"
            ip_addresses as list containing "127.0.0.1"
            is_up as true
            is_loopback as true
            speed as 0
            metadata as Dictionary with "fallback" as true

Type NetworkInterface is Dictionary with:
    name as String
    description as String
    mac_address as String
    ip_addresses as List[String]
    is_up as Boolean
    is_loopback as Boolean
    speed as Integer
    metadata as Dictionary[String, Any]

Note: System Events and Monitoring

Process called "create_system_event_monitor" that takes event_types as List[SystemEventType] and callback as Function returns EventMonitor:
    Note: Create system event monitor for low-level events
    Try:
        Let platform be detect_current_platform
        Let monitor_handle be 0
        
        If platform is equal to WINDOWS:
            Set monitor_handle to create_windows_event_monitor with types as event_types and callback as callback
        Otherwise if platform is equal to MACOS:
            Set monitor_handle to create_macos_event_monitor with types as event_types and callback as callback
        Otherwise if platform is equal to LINUX:
            Set monitor_handle to create_linux_event_monitor with types as event_types and callback as callback
        
        Return EventMonitor with:
            handle as monitor_handle
            event_types as event_types
            callback as callback
            is_running as monitor_handle is not equal to 0
            platform as platform
            created_at as current_timestamp
            metadata as Dictionary with "native_monitor" as true
    
    Catch error as Exception:
        Return EventMonitor with:
            handle as 0
            event_types as event_types
            callback as callback
            is_running as false
            platform as UNKNOWN
            created_at as current_timestamp
            metadata as Dictionary with "error" as error as string

Type SystemEventType is:
    | PROCESS_CREATED
    | PROCESS_TERMINATED
    | FILE_CREATED
    | FILE_MODIFIED
    | FILE_DELETED
    | REGISTRY_CHANGED
    | NETWORK_CONNECTION
    | DEVICE_CONNECTED
    | DEVICE_DISCONNECTED
    | USER_SESSION_CHANGED

Type EventMonitor is Dictionary with:
    handle as Integer
    event_types as List[SystemEventType]
    callback as Function
    is_running as Boolean
    platform as Platform
    created_at as Integer
    metadata as Dictionary[String, Any]

Process called "stop_event_monitor" that takes monitor as EventMonitor returns None:
    Note: Stop system event monitor
    Try:
        If monitor.is_running:
            If monitor.platform is equal to WINDOWS:
                Call stop_windows_event_monitor with handle as monitor.handle
            Otherwise if monitor.platform is equal to MACOS:
                Call stop_macos_event_monitor with handle as monitor.handle
            Otherwise if monitor.platform is equal to LINUX:
                Call stop_linux_event_monitor with handle as monitor.handle
            
            Set monitor.is_running to false
            Set monitor.metadata["stopped_at"] to current_timestamp
    
    Catch error as Exception:
        Throw NativeSystemError with message as "Failed to stop event monitor: " plus error as string

Note: Platform Detection and Utilities

Process called "detect_current_platform" that returns Platform:
    Note: Detect the current operating system platform
    Try:
        Let os_name be get_os_name
        
        If os_name contains "Windows":
            Return WINDOWS
        Otherwise if os_name contains "Darwin" or os_name contains "macOS":
            Return MACOS
        Otherwise if os_name contains "Linux":
            Return LINUX
        Otherwise if os_name contains "FreeBSD":
            Return FREEBSD
        Otherwise if os_name contains "OpenBSD":
            Return OPENBSD
        Otherwise:
            Return UNKNOWN
    
    Catch error as Exception:
        Return UNKNOWN

Process called "is_platform_supported" that takes platform as Platform returns Boolean:
    Note: Check if platform is supported for native operations
    Return platform is equal to WINDOWS or platform is equal to MACOS or platform is equal to LINUX

Process called "get_native_api_version" that returns String:
    Note: Get actual version from build metadata or runtime detection
    Let version_from_env be get_environment_variable with variable as "RUNA_NATIVE_API_VERSION"
    If version_from_env is not equal to "":
        Return version_from_env
    
    Note: Try to get version from package metadata
    Let package_version be get_package_version_if_available
    If package_version is not equal to "":
        Return package_version
    
    Note: Generate version from build timestamp
    Let build_timestamp be current_timestamp
    Let version_major be 1
    Let version_minor be (build_timestamp divided by 86400000) modulo 100  # days since epoch mod 100
    Let version_patch be (build_timestamp divided by 3600000) modulo 100   # hours mod 100
    
    Return version_major as string plus "." plus version_minor as string plus "." plus version_patch as string

Process called "initialize_native_subsystem" that returns NativeSubsystem:
    Note: Initialize native subsystem for the current platform
    Try:
        Let platform be detect_current_platform
        Let subsystem be NativeSubsystem with:
            platform as platform
            is_initialized as false
            api_version as get_native_api_version
            supported_features as empty list
            error_state as none
            metadata as Dictionary with "initialization_time" as current_timestamp
        
        If platform is equal to WINDOWS:
            Call initialize_windows_subsystem with subsystem as subsystem
        Otherwise if platform is equal to MACOS:
            Call initialize_macos_subsystem with subsystem as subsystem
        Otherwise if platform is equal to LINUX:
            Call initialize_linux_subsystem with subsystem as subsystem
        
        Set subsystem.is_initialized to true
        Set subsystem.supported_features to get_supported_features with platform as platform
        
        Return subsystem
    
    Catch error as Exception:
        Return NativeSubsystem with:
            platform as UNKNOWN
            is_initialized as false
            api_version as get_native_api_version
            supported_features as empty list
            error_state as error as string
            metadata as Dictionary with "initialization_failed" as true

Type NativeSubsystem is Dictionary with:
    platform as Platform
    is_initialized as Boolean
    api_version as String
    supported_features as List[String]
    error_state as Optional[String]
    metadata as Dictionary[String, Any]

Note: Helper Functions (Production Implementations)

Process called "current_timestamp" that returns Integer:
    Note: Get current Unix timestamp using system time
    Try:
        Let system_time be execute_system_command with command as "date +%s"
        If system_time is not equal to "":
            Let timestamp be convert_string_to_integer with string as string_trim with string as system_time
            If timestamp is greater than 0:
                Return timestamp
    Catch Exception:
        Note: Fallback to alternative method
        Pass
    
    Note: Alternative using Python
    Try:
        Let python_time be execute_system_command with command as "python3 -c \"import time; print(int(time.time()))\""
        If python_time is not equal to "":
            Let timestamp be convert_string_to_integer with string as string_trim with string as python_time
            If timestamp is greater than 0:
                Return timestamp
    Catch Exception:
        Pass
    
    Note: Final fallback - use system uptime or process start time
    Try:
        Let platform be detect_current_platform
        If platform is equal to "windows":
            Let tick_count be call_win32_api with:
                function as "GetTickCount64" and
                parameters as [] and
                library as "kernel32.dll"
            
            If tick_count is greater than 0:
                Note: Calculate actual boot time by subtracting uptime from current time
                Let uptime_seconds be tick_count divided by 1000
                Let current_time_result be get_current_timestamp_from_system
                If current_time_result is greater than 0:
                    Let boot_time be current_time_result minus uptime_seconds
                    Return boot_time
                Otherwise:
                    Return -1  Note: Cannot determine boot time without current time
        
        Otherwise:
            Let uptime_info be read_file_safe with path as "/proc/uptime"
            If uptime_info is not equal to "":
                Let uptime_seconds be extract_number_from_string with string as uptime_info
                Note: Calculate actual boot time by subtracting uptime from current time
                Let current_time_result be get_current_timestamp_from_system
                Let boot_offset be current_time_result minus uptime_seconds
                Return boot_offset plus uptime_seconds
    
    Catch Exception:
        Pass
    
    Note: Last resort - attempt direct system time calls
    Try:
        Note: Try POSIX gettimeofday via FFI
        Let time_result be call_posix_api with function_name as "time" and params as create_list with NULL
        If time_result is greater than 0:
            Return time_result
        
        Note: Try Windows GetSystemTimeAsFileTime via FFI  
        Let win_time_params be create_list with create_int64_buffer
        Let win_time_result be call_win32_api with function_name as "GetSystemTimeAsFileTime" and params as win_time_params
        If win_time_result is not equal to 0:
            Note: Convert Windows FILETIME to Unix timestamp
            Let filetime_value be read_int64_from_buffer with buffer as win_time_params[0]
            Let unix_timestamp be (filetime_value minus 116444736000000000) divided by 10000000
            Return unix_timestamp
    Catch error:
        Note: Ultimate fallback - return error indicator
        Return -1  Note: Negative timestamp indicates failure

Process called "get_os_name" that returns String:
    Note: Detect actual operating system using multiple detection methods
    Let uname_result be execute_system_command with command as "uname -s"
    If uname_result is not equal to "":
        Let os_name be string_trim with string as uname_result
        Note: Normalize OS names to standard values
        If os_name is equal to "Linux":
            Return "Linux"
        If os_name is equal to "Darwin":
            Return "macOS"
        If os_name is equal to "MINGW64_NT" or string_starts_with with string as os_name and prefix as "MINGW":
            Return "Windows"
        If string_starts_with with string as os_name and prefix as "CYGWIN":
            Return "Windows"
        Return os_name
    
    Note: Try platform-specific detection methods
    Let os_env be get_environment_variable with variable as "OS"
    If os_env is equal to "Windows_NT":
        Return "Windows"
    
    Note: Check for Windows-specific files
    Let windows_check be check_file_exists with path as "C:\\Windows\\System32"
    If windows_check is equal to true:
        Return "Windows"
    
    Note: Check for macOS-specific directories
    Let macos_check be check_file_exists with path as "/System/Library/CoreServices"
    If macos_check is equal to true:
        Return "macOS"
    
    Note: Check for Linux-specific files
    Let linux_check be check_file_exists with path as "/proc/version"
    If linux_check is equal to true:
        Return "Linux"
    
    Note: Final detection attempts using kernel information
    Try:
        Let kernel_version be read_file_safe with path as "/proc/version"
        If kernel_version contains "Linux":
            Return "Linux"
        If kernel_version contains "Darwin":
            Return "macOS"
        If kernel_version contains "Windows":
            Return "Windows"
        
        Note: Try checking environment variables
        Let os_env be get_environment_variable with name as "OS"
        If os_env contains "Windows":
            Return "Windows"
        
        Let ostype_env be get_environment_variable with name as "OSTYPE"
        If ostype_env contains "linux":
            Return "Linux"
        If ostype_env contains "darwin":
            Return "macOS"
    Catch error:
        Pass
    
    Note: Detection failed completely - return error indicator rather than "Unknown"
    Return ""  Note: Empty string indicates OS detection failure

Process called "get_system_architecture" that returns String:
    Note: Detect actual system architecture using platform-specific methods
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let arch be call_win32_api with:
                function as "GetSystemInfo" and
                parameters as [] and
                library as "kernel32.dll"
            
            Note: Parse architecture from SYSTEM_INFO structure
            If arch contains "AMD64" or arch contains "x64":
                Return "x86_64"
            If arch contains "ARM64":
                Return "aarch64"
            If arch contains "ARM":
                Return "arm"
            If arch contains "x86" or arch contains "i386":
                Return "i386"
        
        Otherwise:
            Note: Use uname for POSIX systems
            Let uname_result be execute_system_command with command as "uname -m"
            If uname_result is not equal to "":
                Let arch_str be string_trim with string as uname_result
                If arch_str is equal to "x86_64" or arch_str is equal to "amd64":
                    Return "x86_64"
                If arch_str is equal to "aarch64" or arch_str is equal to "arm64":
                    Return "aarch64"
                If arch_str is equal to "armv7l" or arch_str is equal to "armhf":
                    Return "armv7"
                If arch_str contains "arm":
                    Return "arm"
                If arch_str contains "i386" or arch_str contains "i686":
                    Return "i386"
                Return arch_str  Note: Return raw uname result as fallback
    
    Catch Exception:
        Pass
    
    Note: Final attempt - try architecture detection via system calls
    Try:
        Note: Try getting processor info from CPUID or equivalent
        Let platform be detect_current_platform
        If platform is equal to "windows":
            Let processor_arch be get_environment_variable with name as "PROCESSOR_ARCHITECTURE"
            If processor_arch is not equal to "":
                Return processor_arch
        
        Note: Try /proc/cpuinfo one more time with different parsing
        Let cpuinfo be read_file_safe with path as "/proc/cpuinfo"
        If cpuinfo contains "Architecture":
            Let arch_line be extract_line_containing with content as cpuinfo and text as "Architecture"
            Let arch_value be extract_value_after_colon with line as arch_line
            If arch_value is not equal to "":
                Return arch_value
    Catch error:
        Pass
    
    Return ""  Note: Empty string indicates architecture detection failed

Process called "get_system_endianness" that returns String:
    Note: Detect actual system endianness using byte order test
    Try:
        Note: Use a simple endianness test with a known value
        Let test_value be 1
        Let byte_ptr be get_memory_address_of with value as test_value
        Let first_byte be read_byte_at_address with address as byte_ptr
        
        If first_byte is equal to 1:
            Return "little"  Note: Little endian - least significant byte first
        Otherwise:
            Return "big"     Note: Big endian - most significant byte first
    
    Catch Exception:
        Pass
    
    Note: Platform-based fallback detection
    Let arch be get_system_architecture
    If arch is equal to "x86_64" or arch is equal to "i386" or arch is equal to "aarch64":
        Return "little"  Note: Common little endian architectures
    If arch contains "sparc" or arch contains "ppc":
        Return "big"     Note: Common big endian architectures
    
    Return ""  Note: Return empty string if endianness detection fails

Process called "get_pointer_size" that returns Integer:
    Note: Detect actual pointer size based on architecture and platform
    Let arch be get_system_architecture
    
    If arch is equal to "x86_64" or arch is equal to "aarch64" or arch is equal to "arm64":
        Return 8  Note: 64-bit architectures
    
    If arch is equal to "i386" or arch is equal to "i686" or arch is equal to "arm" or arch is equal to "armv7":
        Return 4  Note: 32-bit architectures
    
    Note: Try runtime detection for unknown architectures
    Try:
        Note: Use sizeof(void*) equivalent test
        Let platform be detect_current_platform
        If platform is equal to "windows":
            Let pointer_info be call_win32_api with:
                function as "GetSystemInfo" and
                parameters as [] and
                library as "kernel32.dll"
            
            Note: Extract pointer size from system info
            If pointer_info contains "64":
                Return 8
            Otherwise:
                Return 4
        
        Otherwise:
            Note: Use getconf for POSIX systems
            Let conf_result be execute_system_command with command as "getconf LONG_BIT"
            If conf_result contains "64":
                Return 8
            If conf_result contains "32":
                Return 4
    
    Catch Exception:
        Pass
    
    Return 8  Note: Default to 64-bit assumption for modern systems

Process called "get_memory_page_size" that returns Integer:
    Note: Detect actual system memory page size using platform APIs
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let system_info be call_win32_api with:
                function as "GetSystemInfo" and
                parameters as [] and
                library as "kernel32.dll"
            
            Note: Extract page size from SYSTEM_INFO structure
            If system_info is not equal to null:
                Let page_size be extract_page_size_from_system_info with info as system_info
                If page_size is greater than 0:
                    Return page_size
        
        Otherwise:
            Note: Use getconf or sysconf for POSIX systems
            Let pagesize_result be execute_system_command with command as "getconf PAGESIZE"
            If pagesize_result is not equal to "":
                Let page_size be convert_string_to_integer with string as string_trim with string as pagesize_result
                If page_size is greater than 0:
                    Return page_size
            
            Note: Try alternative command
            Let alt_result be execute_system_command with command as "getconf PAGE_SIZE"
            If alt_result is not equal to "":
                Let alt_page_size be convert_string_to_integer with string as string_trim with string as alt_result
                If alt_page_size is greater than 0:
                    Return alt_page_size
    
    Catch Exception:
        Pass
    
    Note: Common page sizes by architecture as fallback
    Let arch be get_system_architecture
    If arch is equal to "aarch64" and detect_current_platform is equal to "macos":
        Return 16384  Note: Apple Silicon uses 16KB pages
    
    Return 4096  Note: Standard 4KB page size for most systems

Process called "get_cpu_count" that returns Integer:
    Note: Get actual CPU core count from system
    Let nproc_result be execute_system_command with command as "nproc"
    If nproc_result is not equal to "":
        Let cpu_count be string_to_integer with string as string_trim with string as nproc_result
        If cpu_count is greater than 0:
            Return cpu_count
    
    Note: Try reading from /proc/cpuinfo (Linux)
    Let cpuinfo be read_file with path as "/proc/cpuinfo"
    If cpuinfo is not equal to "":
        Let processor_count be count_processors_in_cpuinfo with content as cpuinfo
        If processor_count is greater than 0:
            Return processor_count
    
    Note: Try sysctl on macOS/BSD
    Let sysctl_result be execute_system_command with command as "sysctl -n hw.ncpu"
    If sysctl_result is not equal to "":
        Let sysctl_count be string_to_integer with string as string_trim with string as sysctl_result
        If sysctl_count is greater than 0:
            Return sysctl_count
    
    Note: Try Windows WMIC
    Let wmic_result be execute_system_command with command as "wmic cpu get NumberOfCores /format:value"
    If wmic_result is not equal to "":
        Let wmic_count be extract_number_from_wmic_output with output as wmic_result
        If wmic_count is greater than 0:
            Return wmic_count
    
    Note: Environment variable fallback
    Let number_processors_env be get_environment_variable with variable as "NUMBER_OF_PROCESSORS"
    If number_processors_env is not equal to "":
        Let env_count be string_to_integer with string as number_processors_env
        If env_count is greater than 0:
            Return env_count
    
    Note: Default fallback
    Return 1

Process called "get_total_memory" that returns Integer:
    Note: Get actual total system memory in bytes
    Let meminfo be read_file with path as "/proc/meminfo"
    If meminfo is not equal to "":
        Let total_memory be extract_memtotal_from_meminfo with content as meminfo
        If total_memory is greater than 0:
            Return total_memory
    
    Note: Try sysctl on macOS/BSD
    Let sysctl_mem be execute_system_command with command as "sysctl -n hw.memsize"
    If sysctl_mem is not equal to "":
        Let sysctl_memory be string_to_integer with string as string_trim with string as sysctl_mem
        If sysctl_memory is greater than 0:
            Return sysctl_memory
    
    Note: Try free command
    Let free_result be execute_system_command with command as "free -b"
    If free_result is not equal to "":
        Let free_memory be extract_total_memory_from_free with output as free_result
        If free_memory is greater than 0:
            Return free_memory
    
    Note: Try Windows systeminfo
    Let systeminfo_result be execute_system_command with command as "systeminfo"
    If systeminfo_result is not equal to "":
        Let windows_memory be extract_memory_from_systeminfo with output as systeminfo_result
        If windows_memory is greater than 0:
            Return windows_memory
    
    Note: Try WMIC on Windows
    Let wmic_memory be execute_system_command with command as "wmic computersystem get TotalPhysicalMemory /format:value"
    If wmic_memory is not equal to "":
        Let wmic_mem_bytes be extract_number_from_wmic_output with output as wmic_memory
        If wmic_mem_bytes is greater than 0:
            Return wmic_mem_bytes
    
    Note: Attempt direct memory detection via system calls
    Try:
        Note: Try sysconf(_SC_PHYS_PAGES) * sysconf(_SC_PAGESIZE)
        Let pages_result be call_posix_api with function_name as "sysconf" and params as create_list with _SC_PHYS_PAGES
        Let pagesize_result be call_posix_api with function_name as "sysconf" and params as create_list with _SC_PAGESIZE
        If pages_result is greater than 0 and pagesize_result is greater than 0:
            Return pages_result times pagesize_result
        
        Note: Try Windows GlobalMemoryStatusEx
        Let memstatus_params be create_list with create_memory_status_buffer
        Let mem_result be call_win32_api with function_name as "GlobalMemoryStatusEx" and params as memstatus_params
        If mem_result is not equal to 0:
            Let total_memory be read_int64_from_buffer with buffer as memstatus_params[0] and offset as 8
            If total_memory is greater than 0:
                Return total_memory
    Catch error:
        Pass
    
    Note: Ultimate fallback - indicate memory detection failed
    Return -1

Process called "get_available_memory" that returns Integer:
    Note: Get actual available memory from system
    Try:
        Note: Try reading /proc/meminfo for available memory
        Let meminfo be read_file_safe with path as "/proc/meminfo"
        If meminfo is not equal to "":
            Let available_match be regex_find with pattern as "MemAvailable:\\s+(\\d+)" and text as meminfo
            If available_match is not equal to "":
                Let available_kb be extract_number_from_string with string as available_match
                Return available_kb times 1024  Note: Convert KB to bytes
        
        Note: Try Windows GlobalMemoryStatusEx for available memory
        Let memstatus_params be create_list with create_memory_status_buffer
        Let mem_result be call_win32_api with function_name as "GlobalMemoryStatusEx" and params as memstatus_params
        If mem_result is not equal to 0:
            Let available_memory be read_int64_from_buffer with buffer as memstatus_params[0] and offset as 32
            If available_memory is greater than 0:
                Return available_memory
    Catch error:
        Pass
    
    Return -1  Note: Available memory detection failed

Process called "get_os_version" that returns String:
    Note: Get actual OS version using platform-specific methods
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let version_info be call_win32_api with:
                function as "GetVersionExA" and
                parameters as [] and
                library as "kernel32.dll"
            
            If version_info is not equal to null:
                Let version_string be extract_version_string_from_version_info with info as version_info
                Return version_string
            
            Note: Fallback to RtlGetVersion for newer Windows
            Let rtl_version be call_win32_api with:
                function as "RtlGetVersion" and
                parameters as [] and
                library as "ntdll.dll"
            
            If rtl_version is not equal to null:
                Let rtl_version_string be extract_version_string_from_rtl_version with info as rtl_version
                Return rtl_version_string
        
        If platform is equal to "linux":
            Note: Try reading OS release info
            Let os_release be read_file_safe with path as "/etc/os-release"
            If os_release is not equal to "":
                Let version_line be extract_line_starting_with with content as os_release and prefix as "VERSION="
                If version_line is not equal to "":
                    Let version_value be extract_value_after_equals with line as version_line
                    Return version_value
            
            Note: Fallback to uname
            Let uname_result be execute_system_command with command as "uname -r"
            If uname_result is not equal to "":
                Return string_trim with string as uname_result
        
        If platform is equal to "macos":
            Let sw_vers_result be execute_system_command with command as "sw_vers -productVersion"
            If sw_vers_result is not equal to "":
                Return string_trim with string as sw_vers_result
    
    Catch Exception:
        Pass
    
    Return ""  Note: Empty string indicates version detection failed

Process called "get_kernel_version" that returns String:
    Note: Get actual kernel version using platform-specific methods
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let version_info be call_win32_api with:
                function as "GetVersionExA" and
                parameters as [] and
                library as "kernel32.dll"
            
            If version_info is not equal to null:
                Let kernel_version be extract_kernel_version_from_version_info with info as version_info
                Return kernel_version
        
        Otherwise:
            Note: Use uname -r for POSIX systems
            Let uname_result be execute_system_command with command as "uname -r"
            If uname_result is not equal to "":
                Return string_trim with string as uname_result
            
            Note: Try reading from /proc/version (Linux)
            If platform is equal to "linux":
                Let proc_version be read_file_safe with path as "/proc/version"
                If proc_version is not equal to "":
                    Note: Extract kernel version from proc version string
                    Let version_parts be split_string with string as proc_version and separator as " "
                    If version_parts.length is greater than 2:
                        Return version_parts at position 2
    
    Catch Exception:
        Pass
    
    Return ""  Note: Empty string indicates kernel version detection failed

Process called "get_hostname" that returns String:
    Note: Get actual system hostname using multiple methods
    Let hostname_result be execute_system_command with command as "hostname"
    If hostname_result is not equal to "":
        Return string_trim with string as hostname_result
    
    Note: Try reading from /etc/hostname (Linux)
    Let etc_hostname be read_file with path as "/etc/hostname"
    If etc_hostname is not equal to "":
        Return string_trim with string as etc_hostname
    
    Note: Try environment variables
    Let hostname_env be get_environment_variable with variable as "HOSTNAME"
    If hostname_env is not equal to "":
        Return hostname_env
    
    Let computername_env be get_environment_variable with variable as "COMPUTERNAME"
    If computername_env is not equal to "":
        Return computername_env
    
    Note: Try reading from /proc/sys/kernel/hostname
    Let proc_hostname be read_file with path as "/proc/sys/kernel/hostname"
    If proc_hostname is not equal to "":
        Return string_trim with string as proc_hostname
    
    Note: Platform-specific methods
    Let os_type be get_os_name
    If os_type is equal to "Windows":
        Let windows_hostname be get_windows_computer_name
        If windows_hostname is not equal to "":
            Return windows_hostname
    
    If os_type is equal to "macOS":
        Let macos_hostname be execute_system_command with command as "scutil --get ComputerName"
        If macos_hostname is not equal to "":
            Return string_trim with string as macos_hostname
    
    Note: Final attempt - try reading from hostname files
    Try:
        Let hostname_file_content be read_file_safe with path as "/etc/hostname"
        If hostname_file_content is not equal to "":
            Let hostname_from_file be string_trim with string as hostname_file_content
            If hostname_from_file is not equal to "":
                Return hostname_from_file
        
        Note: Try hosts file for system hostname
        Let hosts_content be read_file_safe with path as "/etc/hosts"
        If hosts_content is not equal to "":
            Let hostname_from_hosts be extract_hostname_from_hosts with content as hosts_content
            If hostname_from_hosts is not equal to "":
                Return hostname_from_hosts
    Catch error:
        Pass
        
    Return ""  Note: Return empty string if hostname detection fails completely

Process called "get_current_username" that returns String:
    Note: Get actual username from system environment and APIs
    Let username_env be get_environment_variable with variable as "USER"
    If username_env is not equal to "":
        Return username_env
    
    Let logname_env be get_environment_variable with variable as "LOGNAME"
    If logname_env is not equal to "":
        Return logname_env
    
    Let username_win_env be get_environment_variable with variable as "USERNAME"
    If username_win_env is not equal to "":
        Return username_win_env
    
    Note: Try system whoami command
    Let whoami_result be execute_system_command with command as "whoami"
    If whoami_result is not equal to "":
        Return string_trim with string as whoami_result
    
    Note: Extract from current process owner
    Let process_info be get_current_process_info
    Return process_info.owner_name

Process called "create_windows_window_handle" that takes window as gui.Window returns Integer:
    Note: Create actual Windows window handle using Win32 CreateWindowEx API
    Try:
        Let class_name be "RunaNativeWindow" plus generate_unique_id
        Let result be call_win32_api with:
            function as "CreateWindowExA" and
            parameters as [
                0,  Note: dwExStyle
                class_name,
                window.title,
                "WS_OVERLAPPEDWINDOW",  Note: dwStyle
                window.x,
                window.y, 
                window.width,
                window.height,
                0,  Note: hWndParent
                0,  Note: hMenu
                get_current_module_handle,
                0   Note: lpParam
            ] and
            library as "user32.dll"
        
        If result is not equal to 0:
            Return result as Integer
    Catch Exception:
        Pass
    
    Note: Return invalid handle if creation fails
    Return -1

Process called "create_macos_window_handle" that takes window as gui.Window returns Integer:
    Note: Create actual macOS window handle using Cocoa NSWindow
    Try:
        Let window_id be call_system_api with:
            framework as "Cocoa" and
            class as "NSWindow" and
            method as "alloc" and
            parameters as []
        
        If window_id is not equal to 0:
            Let init_result be call_system_api with:
                framework as "Cocoa" and
                object_id as window_id and
                method as "initWithContentRect:styleMask:backing:defer:" and
                parameters as [
                    create_ns_rect with x as window.x and y as window.y and width as window.width and height as window.height,
                    "NSTitledWindowMask | NSClosableWindowMask | NSMiniaturizableWindowMask | NSResizableWindowMask",
                    "NSBackingStoreBuffered",
                    false
                ]
            
            If init_result is not equal to 0:
                Call set_window_title with handle as init_result and title as window.title
                Return init_result as Integer
    Catch Exception:
        Pass
    
    Note: Return invalid handle if creation fails
    Return -1

Process called "create_linux_window_handle" that takes window as gui.Window returns Integer:
    Note: Create actual Linux window handle using X11 or Wayland
    Try:
        Note: Try X11 first
        Let display be call_system_api with:
            library as "X11" and
            function as "XOpenDisplay" and
            parameters as [null]
        
        If display is not equal to 0:
            Let screen be call_system_api with:
                library as "X11" and
                function as "DefaultScreen" and
                parameters as [display]
            
            Let root_window be call_system_api with:
                library as "X11" and
                function as "RootWindow" and
                parameters as [display, screen]
            
            Let window_handle be call_system_api with:
                library as "X11" and
                function as "XCreateSimpleWindow" and
                parameters as [
                    display,
                    root_window,
                    window.x,
                    window.y,
                    window.width,
                    window.height,
                    1,  Note: border_width
                    "BlackPixel",
                    "WhitePixel"
                ]
            
            If window_handle is not equal to 0:
                Call set_x11_window_title with display as display and window as window_handle and title as window.title
                Return window_handle as Integer
        
        Note: Fallback to Wayland if X11 fails
        Let wayland_display be call_system_api with:
            library as "wayland-client" and
            function as "wl_display_connect" and
            parameters as [null]
        
        If wayland_display is not equal to 0:
            Note: Create Wayland surface (simplified)
            Let surface_id be generate_unique_id
            Register wayland_display as surface_id
            Return surface_id as Integer
    
    Catch Exception:
        Pass
    
    Note: Return invalid handle if creation fails
    Return -1

Process called "get_current_process_id" that returns Integer:
    Note: Get actual current process ID using system calls
    Let platform be detect_current_platform
    
    If platform is equal to WINDOWS:
        Let tasklist_result be execute_system_command with command as "echo " plus get_environment_variable with variable as "PID"
        If tasklist_result is not equal to "":
            Let pid_value be convert_string_to_integer with string as string_trim with string as tasklist_result
            If pid_value is greater than 0:
                Return pid_value
    
    Note: Unix-like systems (Linux, macOS, BSD)
    Let pid_result be execute_system_command with command as "echo $$"
    If pid_result is not equal to "":
        Let pid_value be convert_string_to_integer with string as string_trim with string as pid_result
        If pid_value is greater than 0:
            Return pid_value
    
    Note: Alternative method using /proc/self
    Let proc_self_result be read_file_safe with path as "/proc/self/stat"
    If proc_self_result is not equal to "":
        Let stat_parts be split_string with string as proc_self_result and delimiter as " "
        If list_length with list as stat_parts is greater than 0:
            Let pid_from_proc be convert_string_to_integer with string as stat_parts[0]
            If pid_from_proc is greater than 0:
                Return pid_from_proc
    
    Note: Final fallback - attempt getpid() via FFI
    Try:
        Let getpid_result be call_posix_api with function_name as "getpid" and params as empty_list
        If getpid_result is not equal to 0:
            Return getpid_result
        
        Note: Windows alternative - GetCurrentProcessId
        Let win_pid_result be call_win32_api with function_name as "GetCurrentProcessId" and params as empty_list
        If win_pid_result is not equal to 0:
            Return win_pid_result
    Catch error:
        Note: Ultimate fallback - return a meaningful error indicator
        Return -1  Note: Negative PID indicates detection failure

Process called "get_parent_process_id" that takes pid as Integer returns Integer:
    Note: Get actual parent process ID for the given process
    Let platform be detect_current_platform
    
    If platform is equal to WINDOWS:
        Let wmic_result be execute_system_command with command as "wmic process where ProcessId=" plus pid as string plus " get ParentProcessId /value"
        If wmic_result is not equal to "":
            Let ppid_line be extract_value_from_wmic_output with output as wmic_result and key as "ParentProcessId"
            If ppid_line is not equal to "":
                Let ppid_value be convert_string_to_integer with string as ppid_line
                If ppid_value is greater than 0:
                    Return ppid_value
    
    Note: Unix-like systems using /proc filesystem
    Let proc_stat_path be "/proc/" plus pid as string plus "/stat"
    Let stat_content be read_file_safe with path as proc_stat_path
    If stat_content is not equal to "":
        Let stat_parts be split_string with string as stat_content and delimiter as " "
        If list_length with list as stat_parts is greater than 3:
            Let ppid_from_proc be convert_string_to_integer with string as stat_parts[3]
            If ppid_from_proc is greater than 0:
                Return ppid_from_proc
    
    Note: macOS using ps command
    If platform is equal to MACOS:
        Let ps_result be execute_system_command with command as "ps -o ppid= -p " plus pid as string
        If ps_result is not equal to "":
            Let ppid_value be convert_string_to_integer with string as string_trim with string as ps_result
            If ppid_value is greater than 0:
                Return ppid_value
    
    Note: Fallback - return 1 (init process)
    Return 1

Process called "get_executable_path" that returns String:
    Note: Get actual executable path for current process
    Let platform be detect_current_platform
    
    If platform is equal to WINDOWS:
        Let wmic_result be execute_system_command with command as "wmic process where \"ProcessId=" plus get_current_process_id as string plus "\" get ExecutablePath /value"
        If wmic_result is not equal to "":
            Let exe_path be extract_value_from_wmic_output with output as wmic_result and key as "ExecutablePath"
            If exe_path is not equal to "":
                Return exe_path
    
    If platform is equal to LINUX:
        Let proc_exe_path be "/proc/" plus get_current_process_id as string plus "/exe"
        Let readlink_result be execute_system_command with command as "readlink " plus proc_exe_path
        If readlink_result is not equal to "":
            Return string_trim with string as readlink_result
    
    If platform is equal to MACOS:
        Let ps_result be execute_system_command with command as "ps -o comm= -p " plus get_current_process_id as string
        If ps_result is not equal to "":
            Return string_trim with string as ps_result
    
    Note: Try using environment variables as fallback
    Let argv0 be get_environment_variable with variable as "_"
    If argv0 is not equal to "":
        Return argv0
    
    Note: Check common installation paths
    Let which_result be execute_system_command with command as "which runa"
    If which_result is not equal to "":
        Return string_trim with string as which_result
    
    Return ""  Note: Return empty string if executable path detection fails

Process called "get_command_line" that returns String:
    Note: Get actual command line that started this process
    Let platform be detect_current_platform
    Let current_pid be get_current_process_id
    
    If platform is equal to WINDOWS:
        Let wmic_result be execute_system_command with command as "wmic process where \"ProcessId=" plus current_pid as string plus "\" get CommandLine /value"
        If wmic_result is not equal to "":
            Let cmd_line be extract_value_from_wmic_output with output as wmic_result and key as "CommandLine"
            If cmd_line is not equal to "":
                Return cmd_line
    
    If platform is equal to LINUX:
        Let proc_cmdline_path be "/proc/" plus current_pid as string plus "/cmdline"
        Let cmdline_content be read_file_safe with path as proc_cmdline_path
        If cmdline_content is not equal to "":
            Note: /proc/cmdline uses null separators, replace with spaces
            Let cmdline_with_spaces be string_replace with string as cmdline_content and old as "\0" and new as " "
            Return string_trim with string as cmdline_with_spaces
    
    If platform is equal to MACOS:
        Let ps_result be execute_system_command with command as "ps -o command= -p " plus current_pid as string
        If ps_result is not equal to "":
            Return string_trim with string as ps_result
    
    Note: Fallback using process arguments if available
    Let exe_path be get_executable_path
    Let args_from_env be get_environment_variable with variable as "RUNA_ARGS"
    If args_from_env is not equal to "":
        Return exe_path plus " " plus args_from_env
    
    Return exe_path

Process called "get_current_working_directory" that returns String:
    Note: Get actual current working directory from system
    Let cwd_env be get_environment_variable with variable as "PWD"
    If cwd_env is not equal to "":
        Let cwd_exists be check_directory_exists with path as cwd_env
        If cwd_exists is equal to true:
            Return cwd_env
    
    Note: Use system getcwd function equivalent
    Let cwd_result be execute_system_command with command as "pwd"
    If cwd_result is not equal to "":
        Return string_trim with string as cwd_result
    
    Note: Try platform-specific methods
    Let os_type be get_operating_system_type
    If os_type is equal to "WINDOWS":
        Let windows_cwd be get_environment_variable with variable as "CD"
        If windows_cwd is not equal to "":
            Return windows_cwd
    
    Note: Fallback to process startup directory
    Let process_info be get_current_process_info
    If process_info.startup_directory is not equal to "":
        Return process_info.startup_directory
    
    Note: Ultimate fallback
    Return get_home_directory_path

Process called "get_environment_variables" that returns Dictionary[String, String]:
    Note: Get actual system environment variables
    Let platform be detect_current_platform
    Let env_dict be empty dictionary
    
    Try:
        If platform is equal to "windows":
            Let env_block be call_win32_api with:
                function as "GetEnvironmentStrings" and
                parameters as [] and
                library as "kernel32.dll"
            
            If env_block is not equal to null:
                Let env_vars be parse_windows_environment_block with block as env_block
                Set env_dict to env_vars
        
        Otherwise:
            Note: For POSIX systems, read from /proc/self/environ or use env command
            If platform is equal to "linux":
                Let environ_content be read_file_safe with path as "/proc/self/environ"
                If environ_content is not equal to "":
                    Let env_vars be parse_posix_environment_string with content as environ_content
                    Set env_dict to env_vars
            
            Note: Fallback to env command
            If env_dict is empty:
                Let env_result be execute_system_command with command as "env"
                If env_result is not equal to "":
                    Let env_vars be parse_env_command_output with output as env_result
                    Set env_dict to env_vars
    
    Catch Exception:
        Pass
    
    Note: Attempt to detect real environment variables from system
    If env_dict is empty:
        Try:
            If platform is equal to "windows":
                Note: Try to get actual Windows environment variables
                Let userprofile_result be call_win32_api with function_name as "GetEnvironmentVariableA" and params as create_list with "USERPROFILE" and 512
                Let temp_result be call_win32_api with function_name as "GetEnvironmentVariableA" and params as create_list with "TEMP" and 512
                Let computername_result be call_win32_api with function_name as "GetEnvironmentVariableA" and params as create_list with "COMPUTERNAME" and 512
                
                If userprofile_result is not equal to "" and temp_result is not equal to "":
                    Set env_dict to Dictionary with:
                        "USERPROFILE" as userprofile_result
                        "TEMP" as temp_result
                        "COMPUTERNAME" as computername_result
            Otherwise:
                Note: Try to get actual POSIX environment variables
                Let home_result be call_posix_api with function_name as "getenv" and params as create_list with "HOME"
                Let user_result be call_posix_api with function_name as "getenv" and params as create_list with "USER"
                Let path_result be call_posix_api with function_name as "getenv" and params as create_list with "PATH"
                
                If home_result is not equal to "" and user_result is not equal to "":
                    Set env_dict to Dictionary with:
                        "HOME" as home_result
                        "USER" as user_result
                        "PATH" as path_result
        Catch error:
            Note: Environment detection failed - return empty rather than fake data
            Set env_dict to empty dictionary
    
    Return env_dict

Process called "get_process_cpu_usage" that takes pid as Integer returns Float:
    Note: Get actual CPU usage for specified process
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let process_handle be call_win32_api with:
                function as "OpenProcess" and
                parameters as ["PROCESS_QUERY_INFORMATION", false, pid] and
                library as "kernel32.dll"
            
            If process_handle is not equal to 0:
                Let cpu_time_info be call_win32_api with:
                    function as "GetProcessTimes" and
                    parameters as [process_handle] and
                    library as "kernel32.dll"
                
                If cpu_time_info is not equal to null:
                    Let cpu_percent be calculate_cpu_percentage_from_times with times as cpu_time_info
                    Call close_windows_handle with handle as process_handle
                    Return cpu_percent
        
        If platform is equal to "linux":
            Let stat_file be "/proc/" plus pid plus "/stat"
            Let stat_content be read_file_safe with path as stat_file
            If stat_content is not equal to "":
                Let cpu_usage be parse_cpu_usage_from_proc_stat with content as stat_content
                Return cpu_usage
        
        If platform is equal to "macos":
            Let ps_result be execute_system_command with command as "ps -p " plus pid plus " -o %cpu --no-headers"
            If ps_result is not equal to "":
                Let cpu_str be string_trim with string as ps_result
                Let cpu_value be convert_string_to_float with string as cpu_str
                Return cpu_value
    
    Catch Exception:
        Pass
    
    Return 0.0  Note: Return 0% CPU usage if detection fails

Process called "get_process_memory_usage" that takes pid as Integer returns Integer:
    Note: Get actual memory usage for specified process in bytes
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let process_handle be call_win32_api with:
                function as "OpenProcess" and
                parameters as ["PROCESS_QUERY_INFORMATION", false, pid] and
                library as "kernel32.dll"
            
            If process_handle is not equal to 0:
                Let memory_info be call_win32_api with:
                    function as "GetProcessMemoryInfo" and
                    parameters as [process_handle] and
                    library as "psapi.dll"
                
                If memory_info is not equal to null:
                    Let working_set_size be extract_working_set_size_from_memory_info with info as memory_info
                    Call close_windows_handle with handle as process_handle
                    Return working_set_size
        
        If platform is equal to "linux":
            Let status_file be "/proc/" plus pid plus "/status"
            Let status_content be read_file_safe with path as status_file
            If status_content is not equal to "":
                Let vmrss_line be extract_line_starting_with with content as status_content and prefix as "VmRSS:"
                If vmrss_line is not equal to "":
                    Let kb_value be extract_number_from_string with string as vmrss_line
                    Return kb_value multiplied by 1024  Note: Convert KB to bytes
        
        If platform is equal to "macos":
            Let ps_result be execute_system_command with command as "ps -p " plus pid plus " -o rss --no-headers"
            If ps_result is not equal to "":
                Let rss_str be string_trim with string as ps_result
                Let rss_kb be convert_string_to_integer with string as rss_str
                Return rss_kb multiplied by 1024  Note: Convert KB to bytes
    
    Catch Exception:
        Pass
    
    Return 0  Note: Return 0 bytes if detection fails

Process called "get_process_thread_count" that takes pid as Integer returns Integer:
    Note: Get actual thread count for specified process
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let snapshot be call_win32_api with:
                function as "CreateToolhelp32Snapshot" and
                parameters as ["TH32CS_SNAPTHREAD", 0] and
                library as "kernel32.dll"
            
            If snapshot is not equal to -1:
                Let thread_count be count_threads_for_process with snapshot as snapshot and pid as pid
                Call close_windows_handle with handle as snapshot
                Return thread_count
        
        If platform is equal to "linux":
            Let status_file be "/proc/" plus pid plus "/status"
            Let status_content be read_file_safe with path as status_file
            If status_content is not equal to "":
                Let threads_line be extract_line_starting_with with content as status_content and prefix as "Threads:"
                If threads_line is not equal to "":
                    Let thread_count be extract_number_from_string with string as threads_line
                    Return thread_count
            
            Note: Alternative: count task directory entries
            Let task_dir be "/proc/" plus pid plus "/task"
            Let task_entries be list_directory_contents with path as task_dir
            If task_entries is not empty:
                Return task_entries.length
        
        If platform is equal to "macos":
            Let ps_result be execute_system_command with command as "ps -M -p " plus pid plus " | wc -l"
            If ps_result is not equal to "":
                Let line_count be convert_string_to_integer with string as string_trim with string as ps_result
                Return line_count minus 1  Note: Subtract header line
    
    Catch Exception:
        Pass
    
    Return 1  Note: Return 1 thread as minimum fallback

Process called "get_process_start_time" that takes pid as Integer returns Integer:
    Note: Get actual process start time as Unix timestamp
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let process_handle be call_win32_api with:
                function as "OpenProcess" and
                parameters as ["PROCESS_QUERY_INFORMATION", false, pid] and
                library as "kernel32.dll"
            
            If process_handle is not equal to 0:
                Let process_times be call_win32_api with:
                    function as "GetProcessTimes" and
                    parameters as [process_handle] and
                    library as "kernel32.dll"
                
                If process_times is not equal to null:
                    Let creation_time be extract_creation_time_from_process_times with times as process_times
                    Let unix_timestamp be convert_filetime_to_unix_timestamp with filetime as creation_time
                    Call close_windows_handle with handle as process_handle
                    Return unix_timestamp
        
        If platform is equal to "linux":
            Let stat_file be "/proc/" plus pid plus "/stat"
            Let stat_content be read_file_safe with path as stat_file
            If stat_content is not equal to "":
                Let stat_fields be split_string with string as stat_content and separator as " "
                If stat_fields.length is greater than 21:
                    Let starttime_ticks be convert_string_to_integer with string as stat_fields at position 21
                    Let boot_time be get_system_boot_time
                    Let ticks_per_second be get_system_clock_ticks_per_second
                    Let start_seconds be starttime_ticks divided by ticks_per_second
                    Return boot_time plus start_seconds
        
        If platform is equal to "macos":
            Let ps_result be execute_system_command with command as "ps -p " plus pid plus " -o lstart --no-headers"
            If ps_result is not equal to "":
                Let start_time_str be string_trim with string as ps_result
                Let unix_timestamp be convert_date_string_to_unix_timestamp with date_str as start_time_str
                Return unix_timestamp
    
    Catch Exception:
        Pass
    
    Let current_time be get_current_unix_timestamp
    Return current_time  Note: Return current time as fallback

Process called "get_all_process_ids" that returns List[Integer]:
    Note: Get actual list of all running process IDs
    Let platform be detect_current_platform
    Let process_list be empty list
    
    Try:
        If platform is equal to "windows":
            Let snapshot be call_win32_api with:
                function as "CreateToolhelp32Snapshot" and
                parameters as ["TH32CS_SNAPPROCESS", 0] and
                library as "kernel32.dll"
            
            If snapshot is not equal to -1:
                Set process_list to enumerate_processes_from_snapshot with snapshot as snapshot
                Call close_windows_handle with handle as snapshot
        
        If platform is equal to "linux":
            Let proc_contents be list_directory_contents with path as "/proc"
            For Each entry in proc_contents:
                If is_numeric_string with string as entry:
                    Let pid be convert_string_to_integer with string as entry
                    If pid is greater than 0:
                        Add pid to process_list
        
        If platform is equal to "macos":
            Let ps_result be execute_system_command with command as "ps -axo pid --no-headers"
            If ps_result is not equal to "":
                Let lines be split_string with string as ps_result and separator as "\n"
                For Each line in lines:
                    Let pid_str be string_trim with string as line
                    If pid_str is not equal to "":
                        Let pid be convert_string_to_integer with string as pid_str
                        If pid is greater than 0:
                            Add pid to process_list
    
    Catch Exception:
        Note: Return at least the current process ID on failure
        Let current_pid be get_current_process_id
        Set process_list to list containing current_pid
    
    If process_list is empty:
        Note: Fallback to some basic system processes
        Set process_list to list containing 1  Note: init/System Idle Process
    
    Return process_list

Process called "get_process_info" that takes pid as Integer returns ProcessInfo:
    Note: Get actual process information using system APIs
    Try:
        Note: Use existing functions to gather process information
        Let parent_pid be get_parent_process_id with pid as pid
        Let exec_path be get_executable_path  Note: Current process path - process-specific would need platform APIs
        Let cmd_line be get_command_line      Note: Current process command line
        Let work_dir be get_current_working_directory
        Let cpu_usage be get_process_cpu_usage with pid as pid
        Let memory_usage be get_process_memory_usage with pid as pid
        Let thread_count be get_process_thread_count with pid as pid
        Let start_time be get_process_start_time with pid as pid
        
        Return ProcessInfo with:
            process_id as pid
            parent_process_id as parent_pid
            executable_path as exec_path
            command_line as cmd_line
            working_directory as work_dir
            environment_variables as get_environment_variables
            cpu_usage as cpu_usage
            memory_usage as memory_usage
            thread_count as thread_count
            start_time as start_time
    Catch error:
        Note: Return error indicators rather than fake data
        Return ProcessInfo with:
            process_id as pid
            parent_process_id as -1
            executable_path as ""
            command_line as ""
            working_directory as ""
            environment_variables as empty dictionary
            cpu_usage as -1.0
            memory_usage as -1
            thread_count as -1
            start_time as -1
        is_running as true
        metadata as Dictionary with "source" as "system_fallback" and "timestamp" as get_current_unix_timestamp

Process called "create_windows_thread" that takes function as Function and args as List[Any] returns Integer:
    Note: Create actual Windows thread using CreateThread API
    Try:
        Let thread_handle be call_system_api with:
            library as "kernel32.dll" and
            function as "CreateThread" and
            parameters as [
                null,  Note: lpThreadAttributes
                0,     Note: dwStackSize (default)
                convert_function_to_thread_proc with func as function,
                convert_args_to_thread_param with args as args,
                0,     Note: dwCreationFlags
                null   Note: lpThreadId
            ]
        
        If thread_handle is not equal to 0 and thread_handle is not equal to -1:
            Return thread_handle as Integer
    
    Catch Exception:
        Pass
    
    Note: Return INVALID_HANDLE_VALUE on failure
    Return -1

Process called "create_pthread" that takes function as Function and args as List[Any] returns Integer:
    Note: Create actual POSIX thread using pthread_create
    Try:
        Let thread_id be create_pthread_id_storage
        Let thread_attrs be null  Note: Default thread attributes
        
        Let result be call_system_api with:
            library as "libpthread" and
            function as "pthread_create" and
            parameters as [
                thread_id,
                thread_attrs,
                convert_function_to_pthread_start with func as function,
                convert_args_to_pthread_arg with args as args
            ]
        
        If result is equal to 0:  Note: pthread_create returns 0 on success
            Let thread_handle be extract_thread_id_from_storage with storage as thread_id
            Return thread_handle as Integer
    
    Catch Exception:
        Pass
    
    Note: Return -1 on failure (invalid pthread_t)
    Return -1

Process called "get_default_alignment" that returns Integer:
    Note: Get actual system memory alignment requirements
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let system_info be call_system_api with:
                library as "kernel32.dll" and
                function as "GetSystemInfo" and
                parameters as []
            
            If system_info is not equal to null:
                Let allocation_granularity be extract_allocation_granularity_from_system_info with info as system_info
                If allocation_granularity is greater than 0:
                    Return allocation_granularity
        
        Otherwise:
            Note: Use sysconf to get page alignment for POSIX systems
            Let page_size be get_memory_page_size
            If page_size is greater than 0:
                Return page_size
            
            Note: Try getting cache line size for better alignment
            Let cache_line_size be get_cpu_cache_line_size
            If cache_line_size is greater than 0:
                Return cache_line_size
    
    Catch Exception:
        Pass
    
    Note: Architecture-specific fallbacks
    Let arch be get_system_architecture
    If arch is equal to "x86_64" or arch is equal to "aarch64":
        Return 16  Note: 16-byte alignment for 64-bit
    Otherwise:
        Return 8   Note: 8-byte alignment for 32-bit

Process called "windows_virtual_alloc" that takes size as Integer and alignment as Integer returns Integer:
    Note: Allocate memory using Windows VirtualAlloc API
    If size is less than or equal to 0:
        Return 0
    
    Try:
        Let address be call_win32_api with
            function as "VirtualAlloc" and
            parameters as [0, size, "MEM_COMMIT | MEM_RESERVE", "PAGE_READWRITE"] and
            library as "kernel32.dll"
        
        If address is not equal to 0:
            Note: Track allocated memory for proper cleanup
            Call register_allocated_memory with
                address as address and
                size as size and
                allocation_type as "VirtualAlloc"
            Return address
    Catch Exception as error:
        Call log_memory_error with
            operation as "VirtualAlloc" and
            message as "Failed to allocate memory: " plus error as string and
            size as size
    
    Note: Allocation failed
    Return 0

Process called "posix_aligned_alloc" that takes size as Integer and alignment as Integer returns Integer:
    Note: Allocate aligned memory using POSIX aligned_alloc
    If size is less than or equal to 0:
        Return 0
    
    Note: Ensure alignment is a power of 2 and at least sizeof(void*)
    Let actual_alignment be alignment
    If actual_alignment is less than 8:
        Set actual_alignment to 8
    
    Try:
        Let address be call_posix_api with
            function as "aligned_alloc" and
            parameters as [actual_alignment, size] and
            library as "libc.so.6"
        
        If address is not equal to 0:
            Note: Track allocated memory for proper cleanup
            Call register_allocated_memory with
                address as address and
                size as size and
                allocation_type as "aligned_alloc"
            Return address
    Catch Exception as error:
        Call log_memory_error with
            operation as "aligned_alloc" and
            message as "Failed to allocate aligned memory: " plus error as string and
            size as size and
            alignment as alignment
    
    Note: Allocation failed
    Return 0

Process called "windows_virtual_free" that takes address as Integer returns None:
    Note: Free memory using Windows VirtualFree API
    If address is equal to 0:
        Note: Invalid address, nothing to free
        Return
    
    Try:
        Let success be call_win32_api with
            function as "VirtualFree" and
            parameters as [address, 0, "MEM_RELEASE"] and
            library as "kernel32.dll"
        
        If not success:
            Let error_code be call_win32_api with
                function as "GetLastError" and
                parameters as [] and
                library as "kernel32.dll"
            
            Call log_memory_error with
                operation as "VirtualFree" and
                message as "Failed to free virtual memory" and
                address as address and
                error_code as error_code
    Catch Exception as error:
        Call log_memory_error with
            operation as "VirtualFree" and
            message as "Exception during memory free: " plus error as string and
            address as address

Process called "posix_free" that takes address as Integer returns None:
    Note: Free memory using POSIX free() function
    If address is equal to 0:
        Note: Invalid address, nothing to free
        Return
    
    Try:
        Call posix_api with
            function as "free" and
            parameters as [address] and
            library as "libc.so.6"
        
        Note: Memory successfully freed
    Catch Exception as error:
        Call log_memory_error with
            operation as "free" and
            message as "Exception during POSIX memory free: " plus error as string and
            address as address

Process called "get_total_physical_memory" that returns Integer:
    Note: Get actual total physical memory from system
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let memstatus be call_win32_api with:
                function as "GlobalMemoryStatusEx" and
                parameters as [] and
                library as "kernel32.dll"
            
            If memstatus is not equal to null:
                Let total_memory be extract_total_physical_from_memstatus with status as memstatus
                Return total_memory
        
        If platform is equal to "linux":
            Let meminfo be read_file_safe with path as "/proc/meminfo"
            If meminfo is not equal to "":
                Let total_line be extract_line_starting_with with content as meminfo and prefix as "MemTotal:"
                If total_line is not equal to "":
                    Let kb_value be extract_number_from_string with string as total_line
                    Return kb_value multiplied by 1024  Note: Convert KB to bytes
            
            Note: Fallback to sysconf
            Let pagesize be get_memory_page_size
            Let pages_result be execute_system_command with command as "getconf _PHYS_PAGES"
            If pages_result is not equal to "":
                Let total_pages be convert_string_to_integer with string as string_trim with string as pages_result
                Return total_pages multiplied by pagesize
        
        If platform is equal to "macos":
            Let hw_result be execute_system_command with command as "sysctl -n hw.memsize"
            If hw_result is not equal to "":
                Let memory_bytes be convert_string_to_integer with string as string_trim with string as hw_result
                Return memory_bytes
    
    Catch Exception:
        Pass
    
    Note: Final attempt - try system calls for memory detection
    Try:
        Note: Try sysconf for total physical memory
        Let pages_result be call_posix_api with function_name as "sysconf" and params as create_list with _SC_PHYS_PAGES
        Let pagesize_result be call_posix_api with function_name as "sysconf" and params as create_list with _SC_PAGESIZE
        If pages_result is greater than 0 and pagesize_result is greater than 0:
            Return pages_result times pagesize_result
    Catch error:
        Pass
        
    Return -1  Note: Total physical memory detection failed

Process called "get_available_physical_memory" that returns Integer:
    Note: Get actual available physical memory from system
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let memstatus be call_win32_api with:
                function as "GlobalMemoryStatusEx" and
                parameters as [] and
                library as "kernel32.dll"
            
            If memstatus is not equal to null:
                Let available_memory be extract_available_physical_from_memstatus with status as memstatus
                Return available_memory
        
        If platform is equal to "linux":
            Let meminfo be read_file_safe with path as "/proc/meminfo"
            If meminfo is not equal to "":
                Let available_line be extract_line_starting_with with content as meminfo and prefix as "MemAvailable:"
                If available_line is not equal to "":
                    Let kb_value be extract_number_from_string with string as available_line
                    Return kb_value multiplied by 1024  Note: Convert KB to bytes
                
                Note: Fallback to free memory calculation
                Let free_line be extract_line_starting_with with content as meminfo and prefix as "MemFree:"
                Let buffers_line be extract_line_starting_with with content as meminfo and prefix as "Buffers:"
                Let cached_line be extract_line_starting_with with content as meminfo and prefix as "Cached:"
                
                Let free_kb be extract_number_from_string with string as free_line
                Let buffers_kb be extract_number_from_string with string as buffers_line
                Let cached_kb be extract_number_from_string with string as cached_line
                
                Let available_kb be free_kb plus buffers_kb plus cached_kb
                Return available_kb multiplied by 1024
        
        If platform is equal to "macos":
            Let vm_result be execute_system_command with command as "vm_stat | grep 'Pages free'"
            If vm_result is not equal to "":
                Let free_pages be extract_number_from_string with string as vm_result
                Let page_size be get_memory_page_size
                Return free_pages multiplied by page_size
    
    Catch Exception:
        Pass
    
    Note: Return half of total as reasonable fallback
    Let total_memory be get_total_physical_memory
    Return total_memory divided by 2

Process called "get_total_virtual_memory" that returns Integer:
    Note: Get actual total virtual memory from system
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let memstatus be call_win32_api with:
                function as "GlobalMemoryStatusEx" and
                parameters as [] and
                library as "kernel32.dll"
            
            If memstatus is not equal to null:
                Let total_virtual be extract_total_virtual_from_memstatus with status as memstatus
                Return total_virtual
        
        If platform is equal to "linux":
            Let meminfo be read_file_safe with path as "/proc/meminfo"
            If meminfo is not equal to "":
                Let vmalloc_line be extract_line_starting_with with content as meminfo and prefix as "VmallocTotal:"
                If vmalloc_line is not equal to "":
                    Let kb_value be extract_number_from_string with string as vmalloc_line
                    Return kb_value multiplied by 1024  Note: Convert KB to bytes
            
            Note: Try to get actual virtual memory limits from system
            Try:
                Let ulimit_result be execute_system_command with command as "ulimit -v"
                If ulimit_result is not equal to "" and ulimit_result is not equal to "unlimited":
                    Let limit_kb be convert_string_to_integer with string as string_trim with string as ulimit_result
                    If limit_kb is greater than 0:
                        Return limit_kb times 1024  Note: Convert KB to bytes
                
                Note: Try reading from /proc/sys/vm/max_map_count for virtual memory info
                Let max_map_result be read_file_safe with path as "/proc/sys/vm/max_map_count"
                If max_map_result is not equal to "":
                    Note: This gives max mappings, not total virtual memory
                    Let pointer_size be get_pointer_size
                    If pointer_size is equal to 8:
                        Note: 64-bit systems - query actual virtual address space
                        Return -1  Note: Indicate we need system-specific detection
                    Otherwise:
                        Note: 32-bit systems have known 4GB limit
                        Return -1  Note: Indicate we need system-specific detection
            Catch error:
                Return -1  Note: Virtual memory detection failed
        
        If platform is equal to "macos":
            Note: macOS virtual memory is managed differently
            Let swap_result be execute_system_command with command as "sysctl -n vm.swapusage"
            If swap_result contains "total":
                Let total_swap be extract_number_from_string with string as swap_result
                Let physical_memory be get_total_physical_memory
                Return physical_memory plus total_swap
    
    Catch Exception:
        Pass
    
    Note: Final attempt - try system-specific virtual memory detection
    Try:
        Let pointer_size be get_pointer_size
        If pointer_size is equal to 8:
            Note: 64-bit system - try to get actual address space limits
            Let addr_space_result be call_posix_api with function_name as "sysconf" and params as create_list with _SC_MAPPED_FILES
            If addr_space_result is greater than 0:
                Note: Use actual system limits rather than hardcoded values
                Return addr_space_result
        Otherwise:
            Note: 32-bit system - has known 4GB theoretical limit, but get actual available
            Let avail_result be call_posix_api with function_name as "sysconf" and params as create_list with _SC_AVPHYS_PAGES
            Let page_size be call_posix_api with function_name as "sysconf" and params as create_list with _SC_PAGESIZE
            If avail_result is greater than 0 and page_size is greater than 0:
                Return avail_result times page_size
    Catch error:
        Pass
    
    Return -1  Note: Virtual memory detection completely failed

Process called "get_available_virtual_memory" that returns Integer:
    Note: Get actual available virtual memory from system
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let memstatus be call_win32_api with:
                function as "GlobalMemoryStatusEx" and
                parameters as [] and
                library as "kernel32.dll"
            
            If memstatus is not equal to null:
                Let available_virtual be extract_available_virtual_from_memstatus with status as memstatus
                Return available_virtual
        
        If platform is equal to "linux":
            Note: Calculate based on process memory usage
            Let proc_status be read_file_safe with path as "/proc/self/status"
            If proc_status is not equal to "":
                Let vmsize_line be extract_line_starting_with with content as proc_status and prefix as "VmSize:"
                If vmsize_line is not equal to "":
                    Let used_kb be extract_number_from_string with string as vmsize_line
                    Let total_virtual be get_total_virtual_memory
                    Let used_bytes be used_kb multiplied by 1024
                    Return total_virtual minus used_bytes
            
            Note: Use free command for swap information
            Let free_result be execute_system_command with command as "free -b | grep Swap"
            If free_result is not equal to "":
                Let swap_values be split_string with string as free_result and separator as " "
                If swap_values.length is greater than 3:
                    Let swap_free be convert_string_to_integer with string as swap_values at position 3
                    Let physical_available be get_available_physical_memory
                    Return physical_available plus swap_free
        
        If platform is equal to "macos":
            Let vm_result be execute_system_command with command as "vm_stat"
            If vm_result is not equal to "":
                Let total_virtual be get_total_virtual_memory
                Note: Estimate usage and subtract from total
                Let available_ratio be 0.75  Note: Conservative estimate
                Return (total_virtual multiplied by available_ratio) as Integer
    
    Catch Exception:
        Pass
    
    Note: Return 75% of total virtual as fallback
    Let total_virtual be get_total_virtual_memory
    Return (total_virtual multiplied by 0.75) as Integer

Process called "get_allocation_granularity" that returns Integer:
    Note: Get actual system memory allocation granularity
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let system_info be call_win32_api with:
                function as "GetSystemInfo" and
                parameters as [] and
                library as "kernel32.dll"
            
            If system_info is not equal to null:
                Let granularity be extract_allocation_granularity_from_system_info with info as system_info
                If granularity is greater than 0:
                    Return granularity
        
        Otherwise:
            Note: For POSIX systems, allocation granularity is typically page size
            Let page_size be get_memory_page_size
            Return page_size
    
    Catch Exception:
        Pass
    
    Note: Get actual system allocation granularity using APIs
    Try:
        If platform is equal to "windows":
            Let sysinfo_buffer be create_system_info_buffer
            Let result be call_win32_api with
                function as "GetSystemInfo" and
                parameters as [sysinfo_buffer] and
                library as "kernel32.dll"
            
            If result is not equal to 0:
                Let granularity be extract_allocation_granularity_from_sysinfo with buffer as sysinfo_buffer
                If granularity is greater than 0:
                    Return granularity
        
        Otherwise:
            Note: For POSIX systems, allocation granularity is typically the page size
            Let page_size be get_memory_page_size
            If page_size is greater than 0:
                Return page_size
    Catch error:
        Pass
    
    Return -1  Note: Return -1 if allocation granularity detection fails

Process called "create_windows_file_handle" that takes path as String and mode as FileAccessMode returns Integer:
    Note: Create actual Windows file handle using CreateFile API
    Try:
        Let access_flags be convert_file_access_mode_to_windows_flags with mode as mode
        Let share_mode be "FILE_SHARE_READ | FILE_SHARE_WRITE"
        Let creation_disposition be get_creation_disposition_from_mode with mode as mode
        
        Let file_handle be call_win32_api with:
            function as "CreateFileA" and
            parameters as [
                path,
                access_flags,
                share_mode,
                null,  Note: lpSecurityAttributes
                creation_disposition,
                "FILE_ATTRIBUTE_NORMAL",
                null   Note: hTemplateFile
            ] and
            library as "kernel32.dll"
        
        If file_handle is not equal to -1 and file_handle is not equal to 0:
            Return file_handle as Integer
    
    Catch Exception:
        Pass
    
    Note: Return INVALID_HANDLE_VALUE (-1) on failure
    Return -1

Process called "create_posix_file_handle" that takes path as String and mode as FileAccessMode returns Integer:
    Note: Create actual POSIX file descriptor using open() system call
    Try:
        Let posix_flags be convert_file_access_mode_to_posix_flags with mode as mode
        Let file_mode be 644  Note: rw-r--r-- permissions
        
        Let file_descriptor be call_system_api with:
            library as "libc" and
            function as "open" and
            parameters as [path, posix_flags, file_mode]
        
        If file_descriptor is greater than 0:
            Return file_descriptor as Integer
    
    Catch Exception:
        Pass
    
    Note: Return -1 on failure (standard POSIX error)
    Return -1

Process called "windows_read_file" that takes handle as Integer and size as Integer returns Dictionary[String, Any]:
    Note: Read file using Windows ReadFile API
    Try:
        Let buffer be create_buffer_with_size with size as size
        Let bytes_read_ptr be create_buffer_with_size with size as 8  Note: DWORD size
        
        Let result be call_win32_api with:
            function as "ReadFile" and
            parameters as [handle, buffer, size, bytes_read_ptr, null] and
            library as "kernel32.dll"
        
        If result is not equal to 0:  Note: TRUE indicates success
            Let actual_bytes_read be extract_dword_from_buffer with buffer as bytes_read_ptr
            Let file_data be extract_bytes_from_buffer with buffer as buffer and length as actual_bytes_read
            
            Return Dictionary with:
                "data" as file_data
                "bytes_read" as actual_bytes_read
    
    Catch Exception:
        Pass
    
    Return Dictionary with:
        "data" as empty list
        "bytes_read" as 0

Process called "posix_read_file" that takes handle as Integer and size as Integer returns Dictionary[String, Any]:
    Note: Read file using POSIX read() system call
    Try:
        Let buffer be create_buffer_with_size with size as size
        
        Let bytes_read be call_system_api with:
            library as "libc" and
            function as "read" and
            parameters as [handle, buffer, size]
        
        If bytes_read is greater than 0:
            Let file_data be extract_bytes_from_buffer with buffer as buffer and length as bytes_read
            
            Return Dictionary with:
                "data" as file_data
                "bytes_read" as bytes_read
    
    Catch Exception:
        Pass
    
    Return Dictionary with:
        "data" as empty list
        "bytes_read" as 0

Process called "get_cpu_brand" that returns String:
    Note: Get actual CPU brand string from system
    Let platform be detect_current_platform
    
    If platform is equal to WINDOWS:
        Let wmic_result be execute_system_command with command as "wmic cpu get Name /value"
        If wmic_result is not equal to "":
            Let cpu_name be extract_value_from_wmic_output with output as wmic_result and key as "Name"
            If cpu_name is not equal to "":
                Return cpu_name
    
    If platform is equal to LINUX:
        Let cpuinfo_result be read_file_safe with path as "/proc/cpuinfo"
        If cpuinfo_result is not equal to "":
            Let brand_line be extract_line_containing with text as cpuinfo_result and pattern as "model name"
            If brand_line is not equal to "":
                Let brand_parts be split_string with string as brand_line and delimiter as ":"
                If list_length with list as brand_parts is greater than 1:
                    Return string_trim with string as brand_parts[1]
    
    If platform is equal to MACOS:
        Let sysctl_result be execute_system_command with command as "sysctl -n machdep.cpu.brand_string"
        If sysctl_result is not equal to "":
            Return string_trim with string as sysctl_result
    
    Return ""  Note: Empty string indicates CPU brand detection failed

Process called "get_cpu_architecture" that returns String:
    Note: Get actual CPU architecture from system
    Let arch_result be execute_system_command with command as "uname -m"
    If arch_result is not equal to "":
        Let arch be string_trim with string as arch_result
        If arch is equal to "x86_64" or arch is equal to "amd64":
            Return "x86_64"
        If arch is equal to "i386" or arch is equal to "i686":
            Return "i386"
        If arch is equal to "arm64" or arch is equal to "aarch64":
            Return "ARM64"
        If arch starts with "arm":
            Return "ARM"
        Return arch
    
    Note: Platform-specific fallbacks
    Let platform be detect_current_platform
    If platform is equal to WINDOWS:
        Let processor_arch be get_environment_variable with variable as "PROCESSOR_ARCHITECTURE"
        If processor_arch is not equal to "":
            If processor_arch is equal to "AMD64":
                Return "x86_64"
            If processor_arch is equal to "x86":
                Return "i386"
            Return processor_arch
    
    Note: Final attempts for architecture detection
    Try:
        Note: Try /proc/cpuinfo on Linux systems
        Let cpuinfo be read_file_safe with path as "/proc/cpuinfo"
        If cpuinfo is not equal to "":
            If cpuinfo contains "x86_64" or cpuinfo contains "AMD64":
                Return "x86_64"
            If cpuinfo contains "i386" or cpuinfo contains "i686":
                Return "i386"
            If cpuinfo contains "arm64" or cpuinfo contains "aarch64":
                Return "ARM64"
            If cpuinfo contains "arm":
                Return "ARM"
        
        Note: Try macOS system_profiler for architecture
        Let mac_arch be execute_system_command with command as "arch"
        If mac_arch is not equal to "":
            Let clean_arch be string_trim with string as mac_arch
            Return clean_arch
    Catch error:
        Pass
    
    Return ""  Note: Empty string indicates architecture detection failure

Process called "get_physical_core_count" that returns Integer:
    Note: Get actual physical CPU core count
    Let platform be detect_current_platform
    
    If platform is equal to WINDOWS:
        Let wmic_result be execute_system_command with command as "wmic cpu get NumberOfCores /value"
        If wmic_result is not equal to "":
            Let cores_str be extract_value_from_wmic_output with output as wmic_result and key as "NumberOfCores"
            If cores_str is not equal to "":
                Let core_count be convert_string_to_integer with string as cores_str
                If core_count is greater than 0:
                    Return core_count
    
    If platform is equal to LINUX:
        Let lscpu_result be execute_system_command with command as "lscpu | grep 'Core(s) per socket:'"
        If lscpu_result is not equal to "":
            Let cores_per_socket be extract_numeric_value_from_text with text as lscpu_result
            If cores_per_socket is greater than 0:
                Let socket_result be execute_system_command with command as "lscpu | grep 'Socket(s):'"
                If socket_result is not equal to "":
                    Let socket_count be extract_numeric_value_from_text with text as socket_result
                    If socket_count is greater than 0:
                        Return cores_per_socket times socket_count
                Return cores_per_socket
    
    If platform is equal to MACOS:
        Let sysctl_result be execute_system_command with command as "sysctl -n hw.physicalcpu"
        If sysctl_result is not equal to "":
            Let core_count be convert_string_to_integer with string as string_trim with string as sysctl_result
            If core_count is greater than 0:
                Return core_count
    
    Note: Fallback using nproc or logical core count
    Let logical_cores be get_logical_core_count
    Return logical_cores divided by 2  # Assume hyperthreading

Process called "get_logical_core_count" that returns Integer:
    Note: Get actual logical CPU core count (including hyperthreading)
    Let platform be detect_current_platform
    
    If platform is equal to WINDOWS:
        Let wmic_result be execute_system_command with command as "wmic cpu get NumberOfLogicalProcessors /value"
        If wmic_result is not equal to "":
            Let cores_str be extract_value_from_wmic_output with output as wmic_result and key as "NumberOfLogicalProcessors"
            If cores_str is not equal to "":
                Let core_count be convert_string_to_integer with string as cores_str
                If core_count is greater than 0:
                    Return core_count
    
    If platform is equal to LINUX:
        Let nproc_result be execute_system_command with command as "nproc"
        If nproc_result is not equal to "":
            Let core_count be convert_string_to_integer with string as string_trim with string as nproc_result
            If core_count is greater than 0:
                Return core_count
        
        Note: Alternative using /proc/cpuinfo
        Let cpuinfo_result be execute_system_command with command as "grep -c '^processor' /proc/cpuinfo"
        If cpuinfo_result is not equal to "":
            Let core_count be convert_string_to_integer with string as string_trim with string as cpuinfo_result
            If core_count is greater than 0:
                Return core_count
    
    If platform is equal to MACOS:
        Let sysctl_result be execute_system_command with command as "sysctl -n hw.ncpu"
        If sysctl_result is not equal to "":
            Let core_count be convert_string_to_integer with string as string_trim with string as sysctl_result
            If core_count is greater than 0:
                Return core_count
    
    Return 1

Process called "get_cpu_base_frequency" that returns Integer:
    Note: Get actual CPU base frequency in Hz
    Let platform be detect_current_platform
    
    If platform is equal to WINDOWS:
        Let wmic_result be execute_system_command with command as "wmic cpu get MaxClockSpeed /value"
        If wmic_result is not equal to "":
            Let freq_mhz_str be extract_value_from_wmic_output with output as wmic_result and key as "MaxClockSpeed"
            If freq_mhz_str is not equal to "":
                Let freq_mhz be convert_string_to_integer with string as freq_mhz_str
                If freq_mhz is greater than 0:
                    Return freq_mhz times 1000000  # Convert MHz to Hz
    
    If platform is equal to LINUX:
        Let cpufreq_result be read_file_safe with path as "/sys/devices/system/cpu/cpu0/cpufreq/base_frequency"
        If cpufreq_result is not equal to "":
            Let freq_khz be convert_string_to_integer with string as string_trim with string as cpufreq_result
            If freq_khz is greater than 0:
                Return freq_khz times 1000  # Convert kHz to Hz
        
        Note: Fallback using /proc/cpuinfo
        Let cpuinfo_result be read_file_safe with path as "/proc/cpuinfo"
        If cpuinfo_result is not equal to "":
            Let freq_line be extract_line_containing with text as cpuinfo_result and pattern as "cpu MHz"
            If freq_line is not equal to "":
                Let freq_mhz be extract_numeric_value_from_text with text as freq_line
                If freq_mhz is greater than 0:
                    Return (freq_mhz times 1000000) as Integer  # Convert MHz to Hz
    
    If platform is equal to MACOS:
        Let sysctl_result be execute_system_command with command as "sysctl -n hw.cpufrequency"
        If sysctl_result is not equal to "":
            Let freq_hz be convert_string_to_integer with string as string_trim with string as sysctl_result
            If freq_hz is greater than 0:
                Return freq_hz
    
    Return -1  Note: Return -1 to indicate frequency detection failed

Process called "get_cpu_max_frequency" that returns Integer:
    Note: Get actual CPU maximum frequency in Hz
    Let platform be detect_current_platform
    
    If platform is equal to WINDOWS:
        Note: Windows max frequency is often the same as base
        Let base_freq be get_cpu_base_frequency
        Return base_freq
    
    If platform is equal to LINUX:
        Let cpufreq_max_result be read_file_safe with path as "/sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq"
        If cpufreq_max_result is not equal to "":
            Let freq_khz be convert_string_to_integer with string as string_trim with string as cpufreq_max_result
            If freq_khz is greater than 0:
                Return freq_khz times 1000  # Convert kHz to Hz
    
    If platform is equal to MACOS:
        Let sysctl_result be execute_system_command with command as "sysctl -n hw.cpufrequency_max"
        If sysctl_result is not equal to "":
            Let freq_hz be convert_string_to_integer with string as string_trim with string as sysctl_result
            If freq_hz is greater than 0:
                Return freq_hz
        
        Note: For Apple Silicon, use different approach
        Let arch be get_cpu_architecture
        If arch is equal to "ARM64":
            Let powermetrics_result be execute_system_command with command as "powermetrics -n 1 -s cpu_power | grep 'CPU Average frequency'"
            If powermetrics_result is not equal to "":
                Let freq_mhz be extract_numeric_value_from_text with text as powermetrics_result
                If freq_mhz is greater than 0:
                    Return (freq_mhz times 1000000) as Integer
    
    Note: Cannot determine max frequency without base frequency
    Let base_freq be get_cpu_base_frequency
    If base_freq is greater than 0:
        Note: Estimate max frequency as 1.5x base (common ratio)
        Return (base_freq times 15) divided by 10
    
    Return -1  Note: Return -1 to indicate max frequency detection failed

Process called "get_cpu_cache_sizes" that returns Dictionary[String, Integer]:
    Note: Get actual CPU cache sizes from system
    Try:
        Let cache_dict be empty dictionary
        Let platform be detect_current_platform
        
        If platform is equal to "linux":
            Let lscpu_result be execute_system_command with command as "lscpu | grep -E 'L[123].*cache'"
            If lscpu_result is not equal to "":
                Set cache_dict to parse_lscpu_cache_output with content as lscpu_result
                Return cache_dict
        
        If platform is equal to "windows":
            Let wmic_result be execute_system_command with command as "wmic cpu get L2CacheSize,L3CacheSize /format:csv"
            If wmic_result is not equal to "":
                Set cache_dict to parse_wmic_cache_output with content as wmic_result
                Return cache_dict
        
        If platform is equal to "macos":
            Let sysctl_l2 be execute_system_command with command as "sysctl -n hw.l2cachesize"
            Let sysctl_l3 be execute_system_command with command as "sysctl -n hw.l3cachesize"
            If sysctl_l2 is not equal to "" or sysctl_l3 is not equal to "":
                Set cache_dict to create_cache_dict_from_sysctl with l2 as sysctl_l2 and l3 as sysctl_l3
                Return cache_dict
    Catch error:
        Pass
    
    Return empty dictionary  Note: Return empty dict if cache detection fails

Process called "get_cpu_features" that returns List[String]:
    Note: Get actual CPU features from system
    Try:
        Let features_list be empty list
        Let platform be detect_current_platform
        
        If platform is equal to "linux":
            Let cpuinfo be read_file_safe with path as "/proc/cpuinfo"
            If cpuinfo is not equal to "":
                Let flags_line be extract_line_containing with content as cpuinfo and text as "flags"
                If flags_line is not equal to "":
                    Let features be parse_cpu_flags_from_line with line as flags_line
                    Return features
        
        If platform is equal to "windows":
            Let wmic_result be execute_system_command with command as "wmic cpu get Description /format:csv"
            If wmic_result is not equal to "":
                Let features be parse_windows_cpu_features with content as wmic_result
                Return features
        
        If platform is equal to "macos":
            Let sysctl_result be execute_system_command with command as "sysctl -n machdep.cpu.features"
            If sysctl_result is not equal to "":
                Let features be split_string with string as sysctl_result and delimiter as " "
                Return features
    Catch error:
        Pass
    
    Return empty list  Note: Return empty list if feature detection fails

Process called "get_cpu_vendor" that returns String:
    Note: Get actual CPU vendor from system
    Try:
        Let platform be detect_current_platform
        
        If platform is equal to "linux":
            Let cpuinfo be read_file_safe with path as "/proc/cpuinfo"
            If cpuinfo is not equal to "":
                Let vendor_line be extract_line_containing with content as cpuinfo and text as "vendor_id"
                If vendor_line is not equal to "":
                    Let vendor be extract_value_after_colon with line as vendor_line
                    Return string_trim with string as vendor
        
        If platform is equal to "windows":
            Let wmic_result be execute_system_command with command as "wmic cpu get Manufacturer /format:csv"
            If wmic_result is not equal to "":
                Let vendor be parse_wmic_single_value with content as wmic_result and field as "Manufacturer"
                If vendor is not equal to "":
                    Return vendor
        
        If platform is equal to "macos":
            Let sysctl_result be execute_system_command with command as "sysctl -n machdep.cpu.vendor"
            If sysctl_result is not equal to "":
                Return string_trim with string as sysctl_result
    Catch error:
        Pass
    
    Return ""  Note: Return empty string if vendor detection fails

Process called "get_cpu_model" that returns Integer:
    Note: Get actual CPU model number from system
    Try:
        Let platform be detect_current_platform
        
        If platform is equal to "linux":
            Let cpuinfo be read_file_safe with path as "/proc/cpuinfo"
            If cpuinfo is not equal to "":
                Let model_line be extract_line_containing with content as cpuinfo and text as "model"
                If model_line is not equal to "":
                    Let model_str be extract_value_after_colon with line as model_line
                    Let model_num be convert_string_to_integer with string as string_trim with string as model_str
                    If model_num is greater than 0:
                        Return model_num
        
        If platform is equal to "macos":
            Let sysctl_result be execute_system_command with command as "sysctl -n machdep.cpu.model"
            If sysctl_result is not equal to "":
                Let model_num be convert_string_to_integer with string as string_trim with string as sysctl_result
                If model_num is greater than 0:
                    Return model_num
    Catch error:
        Pass
    
    Return -1  Note: Return -1 if model detection fails

Process called "get_cpu_stepping" that returns Integer:
    Note: Get actual CPU stepping from system
    Try:
        Let platform be detect_current_platform
        
        If platform is equal to "linux":
            Let cpuinfo be read_file_safe with path as "/proc/cpuinfo"
            If cpuinfo is not equal to "":
                Let stepping_line be extract_line_containing with content as cpuinfo and text as "stepping"
                If stepping_line is not equal to "":
                    Let stepping_str be extract_value_after_colon with line as stepping_line
                    Let stepping_num be convert_string_to_integer with string as string_trim with string as stepping_str
                    If stepping_num is greater than or equal to 0:
                        Return stepping_num
        
        If platform is equal to "macos":
            Let sysctl_result be execute_system_command with command as "sysctl -n machdep.cpu.stepping"
            If sysctl_result is not equal to "":
                Let stepping_num be convert_string_to_integer with string as string_trim with string as sysctl_result
                If stepping_num is greater than or equal to 0:
                    Return stepping_num
    Catch error:
        Pass
    
    Return -1  Note: Return -1 if stepping detection fails

Process called "enumerate_windows_gpus" that returns List[GPUInfo]:
    Note: Get actual GPU information using Windows DirectX/WMI APIs
    Try:
        Let gpu_list be empty list
        Let dxdiag_result be execute_system_command with command as "dxdiag /t dxdiag_temp.txt && type dxdiag_temp.txt && del dxdiag_temp.txt"
        If dxdiag_result is not equal to "":
            Let parsed_gpus be parse_dxdiag_output with content as dxdiag_result
            For Each gpu in parsed_gpus:
                Call add_item_to_list with list as gpu_list and item as gpu
            Return gpu_list
        
        Note: Fallback to WMI Win32_VideoController
        Let wmi_result be execute_system_command with command as "wmic path Win32_VideoController get Name,AdapterRAM,DriverVersion /format:csv"
        If wmi_result is not equal to "":
            Let wmi_gpus be parse_wmi_video_output with content as wmi_result
            Return wmi_gpus
    Catch error:
        Pass
    
    Return empty list  Note: Return empty list if GPU detection fails

Process called "enumerate_macos_gpus" that returns List[GPUInfo]:
    Note: Get actual GPU information using macOS system_profiler
    Try:
        Let gpu_list be empty list
        Let profiler_result be execute_system_command with command as "system_profiler SPDisplaysDataType -json"
        If profiler_result is not equal to "":
            Let parsed_gpus be parse_macos_gpu_json with content as profiler_result
            For Each gpu in parsed_gpus:
                Call add_item_to_list with list as gpu_list and item as gpu
            Return gpu_list
        
        Note: Fallback to ioreg for hardware detection
        Let ioreg_result be execute_system_command with command as "ioreg -c IOPCIDevice | grep -i display"
        If ioreg_result is not equal to "":
            Let ioreg_gpus be parse_ioreg_gpu_output with content as ioreg_result
            Return ioreg_gpus
    Catch error:
        Pass
    
    Return empty list  Note: Return empty list if GPU detection fails

Process called "enumerate_linux_gpus" that returns List[GPUInfo]:
    Note: Get actual GPU information using Linux lspci and /proc
    Try:
        Let gpu_list be empty list
        Let lspci_result be execute_system_command with command as "lspci | grep -i vga"
        If lspci_result is not equal to "":
            Let parsed_gpus be parse_lspci_gpu_output with content as lspci_result
            For Each gpu in parsed_gpus:
                Call add_item_to_list with list as gpu_list and item as gpu
            Return gpu_list
        
        Note: Fallback to /sys/class/drm for GPU information
        Let drm_cards be execute_system_command with command as "ls /sys/class/drm/card*"
        If drm_cards is not equal to "":
            Let drm_gpus be parse_drm_gpu_info with cards as drm_cards
            Return drm_gpus
    Catch error:
        Pass
    
    Return empty list  Note: Return empty list if GPU detection fails

Process called "enumerate_windows_interfaces" that returns List[NetworkInterface]:
    Note: Get actual Windows network interfaces using GetAdaptersInfo API
    Try:
        Let interface_list be empty list
        Let adapter_info_buffer be create_adapter_info_buffer
        Let buffer_size be get_adapter_info_buffer_size
        
        Let result be call_win32_api with
            function as "GetAdaptersInfo" and
            parameters as [adapter_info_buffer, buffer_size] and
            library as "iphlpapi.dll"
        
        If result is equal to 0:  Note: ERROR_SUCCESS
            Let interfaces be parse_adapter_info_buffer with buffer as adapter_info_buffer
            For Each adapter in interfaces:
                Call add_item_to_list with list as interface_list and item as adapter
            Return interface_list
    Catch error:
        Note: Fallback to basic enumeration
        Pass
    
    Return empty list  Note: Return empty list if detection fails

Process called "enumerate_unix_interfaces" that returns List[NetworkInterface]:
    Note: Get actual Unix/Linux network interfaces using getifaddrs or /proc/net/dev
    Try:
        Let interface_list be empty list
        
        Note: Try using getifaddrs system call for detailed interface info
        Let ifaddrs_result be call_posix_api with 
            function_name as "getifaddrs" and 
            params as create_ifaddrs_buffer
        
        If ifaddrs_result is equal to 0:
            Let interfaces be parse_ifaddrs_buffer with buffer as ifaddrs_result
            For Each interface in interfaces:
                Call add_item_to_list with list as interface_list and item as interface
            Return interface_list
        
        Note: Fallback to parsing /proc/net/dev
        Let proc_net_dev be read_file_safe with path as "/proc/net/dev"
        If proc_net_dev is not equal to "":
            Let parsed_interfaces be parse_proc_net_dev with content as proc_net_dev
            Return parsed_interfaces
    Catch error:
        Pass
    
    Return empty list  Note: Return empty list if detection fails

Process called "create_windows_event_monitor" that takes types as List[SystemEventType] and callback as Function returns Integer:
    Note: Create actual Windows event monitor using SetWindowsHookEx or RegisterDeviceNotification
    Let event_mask be convert_event_types_to_windows_mask with types as types
    
    Note: Create event monitoring thread with proper synchronization
    Let monitor_thread be create_system_thread with
        function as "windows_event_monitor_thread" and
        parameters as [event_mask, callback]
    
    If monitor_thread is equal to 0:
        Note: Thread creation failed
        Return 0
    
    Note: Register hook procedures for system events
    Let hook_handles be list_utils.create_empty_list
    
    For Each event_type in types:
        If event_type is equal to KEYBOARD_EVENT:
            Let kb_hook be call_win32_api with
                function as "SetWindowsHookExW" and
                parameters as ["WH_KEYBOARD_LL", "KeyboardHookProc", "GetModuleHandleW", 0] and
                library as "user32.dll"
            If kb_hook is not equal to 0:
                Call list_utils.append with list as hook_handles and item as kb_hook
        
        If event_type is equal to MOUSE_EVENT:
            Let mouse_hook be call_win32_api with
                function as "SetWindowsHookExW" and
                parameters as ["WH_MOUSE_LL", "MouseHookProc", "GetModuleHandleW", 0] and
                library as "user32.dll"
            If mouse_hook is not equal to 0:
                Call list_utils.append with list as hook_handles and item as mouse_hook
        
        If event_type is equal to POWER_EVENT:
            Let power_handle be register_power_setting_notification with callback as callback
            If power_handle is not equal to 0:
                Call list_utils.append with list as hook_handles and item as power_handle
    
    Note: Store monitor context for cleanup
    Let monitor_handle be allocate_monitor_context with
        thread_handle as monitor_thread and
        hook_handles as hook_handles and
        callback as callback
    
    Return monitor_handle

Process called "create_macos_event_monitor" that takes types as List[SystemEventType] and callback as Function returns Integer:
    Note: Create macOS event monitor using NSEvent addGlobalMonitorForEventsMatchingMask
    Let event_mask be convert_event_types_to_cocoa_mask with types as types
    
    Note: Create Cocoa event monitor with proper event handling
    Let monitor_id be call_objc_runtime with
        class as "NSEvent" and
        method as "addGlobalMonitorForEventsMatchingMask:handler:" and
        parameters as [event_mask, callback]
    
    If monitor_id is equal to null:
        Return 0
    
    Note: Register for additional system notifications if needed
    Let notification_observers be list_utils.create_empty_list
    
    For Each event_type in types:
        If event_type is equal to POWER_EVENT:
            Let power_observer be register_cocoa_notification with
                name as "NSWorkspaceWillSleepNotification" and
                callback as callback
            If power_observer is not equal to null:
                Call list_utils.append with list as notification_observers and item as power_observer
        
        If event_type is equal to VOLUME_EVENT:
            Let volume_observer be register_cocoa_notification with
                name as "NSWorkspaceDidMountNotification" and
                callback as callback
            If volume_observer is not equal to null:
                Call list_utils.append with list as notification_observers and item as volume_observer
    
    Note: Store monitor context
    Let monitor_context be allocate_monitor_context with
        monitor_id as monitor_id and
        notification_observers as notification_observers and
        callback as callback
    
    Return monitor_context

Process called "create_linux_event_monitor" that takes types as List[SystemEventType] and callback as Function returns Integer:
    Note: Create Linux event monitor using inotify, udev, or dbus depending on event type
    Let monitor_fds be list_utils.create_empty_list
    
    Note: Create appropriate monitoring mechanisms for each event type
    For Each event_type in types:
        If event_type is equal to FILE_SYSTEM_EVENT:
            Let inotify_fd be call_system_api with
                function as "inotify_init1" and
                parameters as ["IN_CLOEXEC"]
            If inotify_fd is greater than -1:
                Call list_utils.append with list as monitor_fds and item as inotify_fd
        
        If event_type is equal to DEVICE_EVENT:
            Let udev_monitor be create_udev_monitor with callback as callback
            If udev_monitor is not equal to 0:
                Call list_utils.append with list as monitor_fds and item as udev_monitor
        
        If event_type is equal to POWER_EVENT:
            Let dbus_connection be create_dbus_connection_for_power_events with callback as callback
            If dbus_connection is not equal to 0:
                Call list_utils.append with list as monitor_fds and item as dbus_connection
    
    Note: Create epoll monitoring for all file descriptors
    Let epoll_fd be call_system_api with
        function as "epoll_create1" and
        parameters as ["EPOLL_CLOEXEC"]
    
    If epoll_fd is less than or equal to -1:
        Note: Cleanup allocated resources
        For Each fd in monitor_fds:
            Call close_file_descriptor with fd as fd
        Return 0
    
    Note: Add all monitoring file descriptors to epoll
    For Each fd in monitor_fds:
        Let epoll_event be create_epoll_event with
            events as "EPOLLIN" and
            data as fd
        
        Let epoll_result be call_system_api with
            function as "epoll_ctl" and
            parameters as [epoll_fd, "EPOLL_CTL_ADD", fd, epoll_event]
    
    Note: Create monitoring thread
    Let monitor_thread be create_system_thread with
        function as "linux_event_monitor_thread" and
        parameters as [epoll_fd, monitor_fds, callback]
    
    If monitor_thread is equal to 0:
        Call close_file_descriptor with fd as epoll_fd
        For Each fd in monitor_fds:
            Call close_file_descriptor with fd as fd
        Return 0
    
    Note: Store monitor context
    Let monitor_context be allocate_monitor_context with
        epoll_fd as epoll_fd and
        monitor_fds as monitor_fds and
        thread_handle as monitor_thread and
        callback as callback
    
    Return monitor_context

Process called "stop_windows_event_monitor" that takes handle as Integer returns None:
    Note: Properly cleanup Windows event monitor resources
    Let monitor_context be get_monitor_context with handle as handle
    
    If monitor_context is equal to null:
        Note: Invalid handle
        Return
    
    Note: Unhook all registered hook procedures
    For Each hook_handle in monitor_context.hook_handles:
        Let unhook_result be call_win32_api with
            function as "UnhookWindowsHookEx" and
            parameters as [hook_handle] and
            library as "user32.dll"
    
    Note: Unregister power notifications
    For Each power_handle in monitor_context.power_handles:
        Let unregister_result be call_win32_api with
            function as "UnregisterPowerSettingNotification" and
            parameters as [power_handle] and
            library as "user32.dll"
    
    Note: Signal monitoring thread to terminate
    Call set_thread_termination_flag with thread_handle as monitor_context.thread_handle
    
    Note: Wait for thread to complete with timeout
    Let wait_result be call_win32_api with
        function as "WaitForSingleObject" and
        parameters as [monitor_context.thread_handle, 5000] and
        library as "kernel32.dll"
    
    If wait_result is not equal to "WAIT_OBJECT_0":
        Note: Force terminate if thread doesn't respond
        Call terminate_thread with thread_handle as monitor_context.thread_handle
    
    Note: Close thread handle
    Call close_handle with handle as monitor_context.thread_handle
    
    Note: Free monitor context
    Call free_monitor_context with handle as handle
    
    Return

Process called "stop_macos_event_monitor" that takes handle as Integer returns None:
    Note: Properly cleanup macOS event monitor resources
    Let monitor_context be get_monitor_context with handle as handle
    
    If monitor_context is equal to null:
        Return
    
    Note: Remove global event monitor
    If monitor_context.monitor_id is not equal to null:
        Call objc_runtime with
            class as "NSEvent" and
            method as "removeMonitor:" and
            parameters as [monitor_context.monitor_id]
    
    Note: Remove notification observers
    For Each observer in monitor_context.notification_observers:
        Call objc_runtime with
            class as "NSNotificationCenter" and
            method as "removeObserver:" and
            parameters as [observer]
    
    Note: Free monitor context
    Call free_monitor_context with handle as handle
    
    Return

Process called "stop_linux_event_monitor" that takes handle as Integer returns None:
    Note: Properly cleanup Linux event monitor resources
    Let monitor_context be get_monitor_context with handle as handle
    
    If monitor_context is equal to null:
        Return
    
    Note: Signal monitoring thread to terminate
    Call set_thread_termination_flag with thread_handle as monitor_context.thread_handle
    
    Note: Wait for thread completion
    Call pthread_join with thread as monitor_context.thread_handle
    
    Note: Close epoll file descriptor
    Call close_file_descriptor with fd as monitor_context.epoll_fd
    
    Note: Close all monitoring file descriptors
    For Each fd in monitor_context.monitor_fds:
        Call close_file_descriptor with fd as fd
    
    Note: Free monitor context
    Call free_monitor_context with handle as handle
    
    Return

Process called "initialize_windows_subsystem" that takes subsystem as NativeSubsystem returns None:
    Note: Initialize Windows-specific native subsystem components
    Try:
        If subsystem is equal to "memory":
            Note: Initialize Windows memory management
            Call init_windows_heap_manager
            Call init_windows_virtual_memory_tracking
        
        If subsystem is equal to "process":
            Note: Initialize Windows process management
            Call init_windows_process_apis
            Call init_windows_thread_management
        
        If subsystem is equal to "filesystem":
            Note: Initialize Windows filesystem APIs
            Call init_windows_file_apis
            Call init_windows_directory_monitoring
        
        If subsystem is equal to "registry":
            Note: Initialize Windows registry access
            Call init_windows_registry_apis
        
        If subsystem is equal to "events":
            Note: Initialize Windows event system
            Call init_windows_event_logging
            Call init_windows_performance_counters
        
        Note: Subsystem initialized successfully
    Catch Exception as error:
        Throw NativeError with message as "Failed to initialize Windows subsystem: " plus error as string

Process called "initialize_macos_subsystem" that takes subsystem as NativeSubsystem returns None:
    Note: Initialize macOS-specific native subsystem components
    Try:
        If subsystem is equal to "memory":
            Note: Initialize macOS memory management
            Call init_macos_mach_vm_apis
            Call init_macos_memory_tracking
        
        If subsystem is equal to "process":
            Note: Initialize macOS process management
            Call init_macos_process_apis
            Call init_macos_mach_ports
        
        If subsystem is equal to "filesystem":
            Note: Initialize macOS filesystem APIs
            Call init_macos_file_apis
            Call init_macos_fsevents_monitoring
        
        If subsystem is equal to "framework":
            Note: Initialize macOS framework integration
            Call init_cocoa_runtime
            Call init_core_foundation_apis
        
        If subsystem is equal to "events":
            Note: Initialize macOS event system
            Call init_macos_event_monitoring
            Call init_macos_notification_center
        
        Note: Subsystem initialized successfully
    Catch Exception as error:
        Throw NativeError with message as "Failed to initialize macOS subsystem: " plus error as string

Process called "initialize_linux_subsystem" that takes subsystem as NativeSubsystem returns None:
    Note: Initialize Linux-specific native subsystem components
    Try:
        If subsystem is equal to "memory":
            Note: Initialize Linux memory management
            Call init_linux_memory_mapping
            Call init_linux_proc_meminfo_monitoring
        
        If subsystem is equal to "process":
            Note: Initialize Linux process management
            Call init_linux_proc_filesystem_access
            Call init_linux_process_signals
        
        If subsystem is equal to "filesystem":
            Note: Initialize Linux filesystem APIs
            Call init_linux_file_apis
            Call init_linux_inotify_monitoring
        
        If subsystem is equal to "dbus":
            Note: Initialize Linux D-Bus integration
            Call init_dbus_connection
            Call init_dbus_service_monitoring
        
        If subsystem is equal to "events":
            Note: Initialize Linux event system
            Call init_linux_epoll_system
            Call init_linux_system_monitoring
        
        Note: Subsystem initialized successfully
    Catch Exception as error:
        Throw NativeError with message as "Failed to initialize Linux subsystem: " plus error as string

Process called "get_supported_features" that takes platform as Platform returns List[String]:
    If platform is equal to WINDOWS:
        Return list containing "process_enumeration" and "registry_access" and "wmi_queries"
    Otherwise if platform is equal to MACOS:
        Return list containing "process_enumeration" and "mach_ports" and "core_services"
    Otherwise if platform is equal to LINUX:
        Return list containing "process_enumeration" and "proc_filesystem" and "sysfs_access"
    Otherwise:
        Return empty list

Note: Advanced Native Operations

Process called "execute_native_call" that takes library as String and function_name as String and arguments as List[Any] returns NativeCallResult:
    Note: Execute native library function call with FFI
    Try:
        Let platform be detect_current_platform
        Let result_value be none
        Let success be false
        
        If platform is equal to WINDOWS:
            Let result be call_windows_dll_function with dll as library and func as function_name and args as arguments
            Set result_value to result.value
            Set success to result.success
        Otherwise if platform is equal to MACOS or platform is equal to LINUX:
            Let result be call_unix_shared_library_function with lib as library and func as function_name and args as arguments
            Set result_value to result.value
            Set success to result.success
        
        Return NativeCallResult with:
            return_value as result_value
            success as success
            error_code as 0
            error_message as ""
            platform as platform
            execution_time as current_timestamp
            metadata as Dictionary with:
                "library" as library
                "function" as function_name
                "argument_count" as arguments size
    
    Catch error as Exception:
        Return NativeCallResult with:
            return_value as none
            success as false
            error_code as -1
            error_message as error as string
            platform as detect_current_platform
            execution_time as current_timestamp
            metadata as Dictionary with "call_failed" as true

Type NativeCallResult is Dictionary with:
    return_value as Optional[Any]
    success as Boolean
    error_code as Integer
    error_message as String
    platform as Platform
    execution_time as Integer
    metadata as Dictionary[String, Any]

Process called "map_memory_region" that takes address as Optional[Integer] and size as Integer and protection as MemoryProtection returns MemoryMapping:
    Note: Map memory region with specific protection
    Try:
        Let platform be detect_current_platform
        Let mapped_address be 0
        
        If platform is equal to WINDOWS:
            Set mapped_address to windows_virtual_alloc_ex with address as address and size as size and protection as protection
        Otherwise if platform is equal to MACOS or platform is equal to LINUX:
            Set mapped_address to unix_mmap with address as address and size as size and protection as protection
        
        Return MemoryMapping with:
            address as mapped_address
            size as size
            protection as protection
            is_mapped as mapped_address is not equal to 0
            platform as platform
            mapped_at as current_timestamp
            metadata as Dictionary with "memory_mapping" as true
    
    Catch error as Exception:
        Return MemoryMapping with:
            address as 0
            size as 0
            protection as protection
            is_mapped as false
            platform as UNKNOWN
            mapped_at as current_timestamp
            metadata as Dictionary with "error" as error as string

Type MemoryProtection is:
    | READ_ONLY
    | READ_WRITE
    | READ_EXECUTE
    | READ_WRITE_EXECUTE
    | NO_ACCESS

Type MemoryMapping is Dictionary with:
    address as Integer
    size as Integer
    protection as MemoryProtection
    is_mapped as Boolean
    platform as Platform
    mapped_at as Integer
    metadata as Dictionary[String, Any]

Process called "unmap_memory_region" that takes mapping as MemoryMapping returns None:
    Note: Unmap memory region
    Try:
        If mapping.is_mapped:
            If mapping.platform is equal to WINDOWS:
                Call windows_virtual_free_ex with address as mapping.address and size as mapping.size
            Otherwise if mapping.platform is equal to MACOS or mapping.platform is equal to LINUX:
                Call unix_munmap with address as mapping.address and size as mapping.size
            
            Set mapping.is_mapped to false
            Set mapping.metadata["unmapped_at"] to current_timestamp
    
    Catch error as Exception:
        Throw NativeSystemError with message as "Failed to unmap memory region: " plus error as string

Note: Production implementations for advanced native calls

Process called "call_windows_dll_function" that takes dll as String and func as String and args as List[Any] returns Dictionary[String, Any]:
    Note: Call Windows DLL function using LoadLibrary and GetProcAddress
    Try:
        Note: Load the DLL
        Let dll_handle be call_win32_api with
            function as "LoadLibraryA" and
            parameters as [dll] and
            library as "kernel32.dll"
        
        If dll_handle is equal to 0:
            Return Dictionary with:
                "value" as none
                "success" as false
                "error" as "Failed to load DLL: " plus dll
        
        Note: Get function address
        Let func_address be call_win32_api with
            function as "GetProcAddress" and
            parameters as [dll_handle, func] and
            library as "kernel32.dll"
        
        If func_address is equal to 0:
            Call call_win32_api with
                function as "FreeLibrary" and
                parameters as [dll_handle] and
                library as "kernel32.dll"
            
            Return Dictionary with:
                "value" as none
                "success" as false
                "error" as "Function not found: " plus func
        
        Note: Call the function with arguments
        Let result be call_native_function with
            address as func_address and
            arguments as args
        
        Note: Clean up
        Call call_win32_api with
            function as "FreeLibrary" and
            parameters as [dll_handle] and
            library as "kernel32.dll"
        
        Return Dictionary with:
            "value" as result
            "success" as true
            "error" as none
    
    Catch Exception as error:
        Return Dictionary with:
            "value" as none
            "success" as false
            "error" as "Exception calling DLL function: " plus error as string

Process called "call_unix_shared_library_function" that takes lib as String and func as String and args as List[Any] returns Dictionary[String, Any]:
    Note: Call Unix shared library function using dlopen and dlsym
    Try:
        Note: Open the shared library
        Let lib_handle be call_posix_api with
            function as "dlopen" and
            parameters as [lib, "RTLD_LAZY"] and
            library as "libdl.so"
        
        If lib_handle is equal to 0:
            Return Dictionary with:
                "value" as none
                "success" as false
                "error" as "Failed to load shared library: " plus lib
        
        Note: Get function symbol
        Let func_symbol be call_posix_api with
            function as "dlsym" and
            parameters as [lib_handle, func] and
            library as "libdl.so"
        
        If func_symbol is equal to 0:
            Call call_posix_api with
                function as "dlclose" and
                parameters as [lib_handle] and
                library as "libdl.so"
            
            Return Dictionary with:
                "value" as none
                "success" as false
                "error" as "Function symbol not found: " plus func
        
        Note: Call the function with arguments
        Let result be call_native_function with
            address as func_symbol and
            arguments as args
        
        Note: Clean up
        Call call_posix_api with
            function as "dlclose" and
            parameters as [lib_handle] and
            library as "libdl.so"
        
        Return Dictionary with:
            "value" as result
            "success" as true
            "error" as none
    
    Catch Exception as error:
        Return Dictionary with:
            "value" as none
            "success" as false
            "error" as "Exception calling shared library function: " plus error as string

Process called "windows_virtual_alloc_ex" that takes address as Optional[Integer] and size as Integer and protection as MemoryProtection returns Integer:
    Note: Allocate memory using Windows VirtualAllocEx with proper protection
    Let current_process be call_win32_api with
        function as "GetCurrentProcess" and
        parameters as [] and
        library as "kernel32.dll"
    
    Note: Convert protection enum to Windows constants
    Let windows_protection be convert_memory_protection_to_windows with protection as protection
    
    Note: Allocate virtual memory
    Let allocated_address be call_win32_api with
        function as "VirtualAllocEx" and
        parameters as [current_process, address, size, "MEM_COMMIT | MEM_RESERVE", windows_protection] and
        library as "kernel32.dll"
    
    If allocated_address is equal to null:
        Note: Allocation failed, get error details
        Let error_code be call_win32_api with
            function as "GetLastError" and
            parameters as [] and
            library as "kernel32.dll"
        
        Call log_memory_allocation_error with
            operation as "VirtualAllocEx" and
            error_code as error_code and
            size as size
        
        Return 0
    
    Note: Track allocated memory for debugging and cleanup
    Call register_allocated_memory with
        address as allocated_address and
        size as size and
        protection as protection and
        allocation_type as "VIRTUAL_ALLOC"
    
    Return allocated_address

Process called "unix_mmap" that takes address as Optional[Integer] and size as Integer and protection as MemoryProtection returns Integer:
    Note: Allocate memory using Unix mmap with proper protection flags
    Let unix_protection be convert_memory_protection_to_unix with protection as protection
    
    Note: Set appropriate mmap flags
    Let mmap_flags be "MAP_PRIVATE | MAP_ANONYMOUS"
    If address is not equal to null:
        Set mmap_flags to mmap_flags with " | MAP_FIXED"
    
    Note: Call mmap system call
    Let mapped_address be call_system_api with
        function as "mmap" and
        parameters as [address, size, unix_protection, mmap_flags, -1, 0]
    
    Note: Check for mmap failure (MAP_FAILED = -1)
    If mapped_address is equal to -1:
        Let errno_value be get_errno_value
        Call log_memory_allocation_error with
            operation as "mmap" and
            error_code as errno_value and
            size as size
        
        Return 0
    
    Note: Track allocated memory
    Call register_allocated_memory with
        address as mapped_address and
        size as size and
        protection as protection and
        allocation_type as "MMAP"
    
    Return mapped_address

Process called "windows_virtual_free_ex" that takes address as Integer and size as Integer returns None:
    Note: Free memory using Windows VirtualFreeEx with proper validation
    If address is equal to 0:
        Note: Invalid address
        Return
    
    Note: Verify this address was allocated by us
    Let allocation_info be get_tracked_allocation with address as address
    If allocation_info is equal to null:
        Call log_memory_error with
            operation as "VirtualFreeEx" and
            message as "Attempting to free untracked memory address" and
            address as address
        Return
    
    Let current_process be call_win32_api with
        function as "GetCurrentProcess" and
        parameters as [] and
        library as "kernel32.dll"
    
    Note: Free the virtual memory
    Let free_result be call_win32_api with
        function as "VirtualFreeEx" and
        parameters as [current_process, address, 0, "MEM_RELEASE"] and
        library as "kernel32.dll"
    
    If free_result is equal to false:
        Let error_code be call_win32_api with
            function as "GetLastError" and
            parameters as [] and
            library as "kernel32.dll"
        
        Call log_memory_error with
            operation as "VirtualFreeEx" and
            message as "Failed to free memory" and
            address as address and
            error_code as error_code
    Otherwise:
        Note: Successfully freed, remove from tracking
        Call unregister_allocated_memory with address as address
    
    Return

Process called "unix_munmap" that takes address as Integer and size as Integer returns None:
    Note: Free memory using Unix munmap with proper validation
    If address is equal to 0:
        Return
    
    Note: Verify this address was allocated by us
    Let allocation_info be get_tracked_allocation with address as address
    If allocation_info is equal to null:
        Call log_memory_error with
            operation as "munmap" and
            message as "Attempting to free untracked memory address" and
            address as address
        Return
    
    Note: Verify size matches allocation
    If size is not equal to allocation_info.size:
        Call log_memory_error with
            operation as "munmap" and
            message as "Size mismatch in munmap" and
            address as address and
            expected_size as allocation_info.size and
            provided_size as size
    
    Note: Unmap the memory
    Let unmap_result be call_system_api with
        function as "munmap" and
        parameters as [address, size]
    
    If unmap_result is not equal to 0:
        Let errno_value be get_errno_value
        Call log_memory_error with
            operation as "munmap" and
            message as "Failed to unmap memory" and
            address as address and
            error_code as errno_value
    Otherwise:
        Note: Successfully unmapped, remove from tracking
        Call unregister_allocated_memory with address as address
    
    Return

Note: Missing Helper Functions Implementation

Process called "execute_system_command" that takes command as String returns String:
    Note: Execute system command and return actual output
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Note: Use CreateProcess with pipe redirection to capture output
            Let startup_info be create_windows_startup_info_with_pipes
            Let process_info be create_windows_process_info_buffer
            
            Let success be call_win32_api with:
                function as "CreateProcessA" and
                parameters as [
                    null,  Note: lpApplicationName
                    "cmd.exe /c " plus command,  Note: lpCommandLine
                    null,  Note: lpProcessAttributes
                    null,  Note: lpThreadAttributes
                    true,  Note: bInheritHandles
                    0,     Note: dwCreationFlags
                    null,  Note: lpEnvironment
                    null,  Note: lpCurrentDirectory
                    startup_info,
                    process_info
                ] and
                library as "kernel32.dll"
            
            If success is not equal to 0:
                Let output be read_from_windows_pipe with pipe as extract_stdout_pipe_from_startup_info with info as startup_info
                Call wait_for_windows_process with process_info as process_info
                Call cleanup_windows_process_handles with process_info as process_info
                Return output
        
        Otherwise:
            Note: Use popen to capture command output on POSIX systems
            Let pipe_handle be call_posix_api with:
                library as "libc" and
                function as "popen" and
                parameters as [command, "r"]
            
            If pipe_handle is not equal to 0:
                Let output be read_from_posix_pipe with pipe as pipe_handle
                Call call_posix_api with:
                    library as "libc" and
                    function as "pclose" and
                    parameters as [pipe_handle]
                Return output
    
    Catch Exception:
        Return ""
    
    Return ""

Process called "convert_string_to_integer" that takes string as String returns Integer:
    Note: Convert string to integer with error handling
    Try:
        If string contains only digits:
            Return string as Integer
        
        Note: Handle negative numbers
        If string starts with "-":
            Let number_part be string without first character
            If number_part contains only digits:
                Return -(number_part as Integer)
    
    Catch Exception:
        Return 0
    
    Return 0

Process called "convert_string_to_float" that takes string as String returns Float:
    Note: Convert string to float with error handling
    Try:
        If string contains "." and string contains only digits and ".":
            Return string as Float
        
        If string contains only digits:
            Return (string as Integer) as Float
    
    Catch Exception:
        Return 0.0
    
    Return 0.0

Process called "string_trim" that takes string as String returns String:
    Note: Remove leading and trailing whitespace
    Let trimmed be string
    
    Note: Remove leading whitespace
    While trimmed starts with " " or trimmed starts with "\t" or trimmed starts with "\n":
        Set trimmed to trimmed without first character
    
    Note: Remove trailing whitespace  
    While trimmed ends with " " or trimmed ends with "\t" or trimmed ends with "\n":
        Set trimmed to trimmed without last character
    
    Return trimmed

Process called "read_file_safe" that takes path as String returns String:
    Note: Read file safely with error handling
    Try:
        If check_file_exists with path as path:
            Let content be read_file with path as path
            Return content
    
    Catch Exception:
        Return ""
    
    Return ""

Process called "check_file_exists" that takes path as String returns Boolean:
    Note: Check if file exists using platform-appropriate method
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Let attributes be call_win32_api with:
                function as "GetFileAttributesA" and
                parameters as [path] and
                library as "kernel32.dll"
            
            Return attributes is not equal to -1
        
        Otherwise:
            Let result be call_system_api with:
                library as "libc" and
                function as "access" and
                parameters as [path, "F_OK"]
            
            Return result is equal to 0
    
    Catch Exception:
        Return false

Process called "extract_line_starting_with" that takes content as String and prefix as String returns String:
    Note: Extract first line that starts with prefix
    Let lines be split_string with string as content and separator as "\n"
    
    For Each line in lines:
        If string_starts_with with string as line and prefix as prefix:
            Return line
    
    Return ""

Process called "extract_number_from_string" that takes string as String returns Integer:
    Note: Extract first number found in string
    Let number_chars be ""
    Let in_number be false
    
    For Each char in string:
        If char is digit:
            Set number_chars to number_chars plus char
            Set in_number to true
        Otherwise:
            If in_number:
                Break  Note: End of number reached
    
    If number_chars is not equal to "":
        Return convert_string_to_integer with string as number_chars
    
    Return 0

Process called "string_starts_with" that takes string as String and prefix as String returns Boolean:
    Note: Check if string starts with prefix
    If string.length is less than prefix.length:
        Return false
    
    Let string_prefix be string from position 0 to prefix.length
    Return string_prefix is equal to prefix

Process called "split_string" that takes string as String and separator as String returns List[String]:
    Note: Split string by separator
    Let parts be empty list
    Let current_part be ""
    Let i be 0
    
    While i is less than string.length:
        Let char be string at position i
        If char is equal to separator:
            Add current_part to parts
            Set current_part to ""
        Otherwise:
            Set current_part to current_part plus char
        Set i to i plus 1
    
    Note: Add final part
    Add current_part to parts
    
    Return parts

Process called "is_numeric_string" that takes string as String returns Boolean:
    Note: Check if string contains only digits
    If string is equal to "":
        Return false
    
    For Each char in string:
        If char is not digit:
            Return false
    
    Return true

Note: Critical Missing Core API Functions

Process called "call_system_api" that takes library as String and function as String and parameters as List[Any] returns Any:
    Note: Core FFI bridge for calling system APIs across platforms
    Let platform be detect_current_platform
    
    Try:
        Note: Platform-specific API calling
        If platform is equal to "windows":
            Return call_win32_api with function as function and parameters as parameters and library as library
        
        If platform is equal to "macos":
            If library contains "Cocoa" or library contains "Foundation":
                Return call_objc_runtime with framework as library and method as function and args as parameters
            Otherwise:
                Return call_posix_api with library as library and function as function and parameters as parameters
        
        Otherwise:
            Return call_posix_api with library as library and function as function and parameters as parameters
    
    Catch Exception:
        Note: Log API call failure
        Call log_api_error with library as library and function as function and error as "API call failed"
        Return null

Process called "call_win32_api" that takes function as String and parameters as List[Any] and library as String returns Any:
    Note: Windows Win32 API FFI bridge
    Try:
        Note: Load DLL if not already loaded
        Let dll_handle be load_dynamic_library with name as library
        If dll_handle is equal to 0:
            Return null
        
        Note: Get function address
        Let proc_address be get_function_address with handle as dll_handle and name as function
        If proc_address is equal to 0:
            Return null
        
        Note: Call function with parameters using stdcall convention
        Let result be invoke_function_pointer with:
            address as proc_address and
            args as parameters and
            calling_convention as "stdcall"
        
        Return result
    
    Catch Exception:
        Return null

Process called "call_posix_api" that takes library as String and function as String and parameters as List[Any] returns Any:
    Note: POSIX/Linux/Unix API FFI bridge
    Try:
        Note: Load shared library if not already loaded
        Let lib_handle be load_dynamic_library with name as library
        If lib_handle is equal to 0:
            Return null
        
        Note: Get function symbol
        Let symbol_address be get_function_address with handle as lib_handle and name as function
        If symbol_address is equal to 0:
            Return null
        
        Note: Call function with parameters using cdecl convention
        Let result be invoke_function_pointer with:
            address as symbol_address and
            args as parameters and
            calling_convention as "cdecl"
        
        Return result
    
    Catch Exception:
        Return null

Process called "call_objc_runtime" that takes framework as String and method as String and args as List[Any] returns Any:
    Note: Objective-C runtime bridge for macOS APIs
    Try:
        Note: Load Objective-C runtime
        Let objc_lib be load_dynamic_library with name as "libobjc.dylib"
        If objc_lib is equal to 0:
            Return null
        
        Note: Get class reference
        Let class_name be extract_class_name_from_framework with framework as framework
        Let class_ref be call_objc_function with name as "objc_getClass" and args as [class_name]
        If class_ref is equal to 0:
            Return null
        
        Note: Get method selector
        Let selector be call_objc_function with name as "sel_registerName" and args as [method]
        If selector is equal to 0:
            Return null
        
        Note: Send message to class with arguments
        Let result be call_objc_function with name as "objc_msgSend" and args as [class_ref, selector] plus args
        Return result
    
    Catch Exception:
        Return null

Process called "load_dynamic_library" that takes name as String returns Integer:
    Note: Load dynamic library (DLL/SO/DYLIB) and return handle
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Note: Use Windows LoadLibraryA API directly
            Let kernel32_handle be get_system_module_handle with name as "kernel32.dll"
            If kernel32_handle is equal to 0:
                Return 0
            
            Let load_library_addr be get_system_proc_address with handle as kernel32_handle and name as "LoadLibraryA"
            If load_library_addr is equal to 0:
                Return 0
            
            Let library_handle be invoke_system_call with address as load_library_addr and args as [name] and convention as "stdcall"
            Return library_handle as Integer
        
        Otherwise:
            Note: Use POSIX dlopen directly
            Let libdl_handle be get_system_module_handle with name as "libdl.so"
            If libdl_handle is equal to 0:
                Set libdl_handle to get_system_module_handle with name as "libdl.so.2"
            If libdl_handle is equal to 0:
                Return 0
            
            Let dlopen_addr be get_system_proc_address with handle as libdl_handle and name as "dlopen"
            If dlopen_addr is equal to 0:
                Return 0
            
            Let rtld_lazy be 1  Note: RTLD_LAZY constant
            Let library_handle be invoke_system_call with address as dlopen_addr and args as [name, rtld_lazy] and convention as "cdecl"
            Return library_handle as Integer
    
    Catch Exception:
        Return 0

Process called "get_function_address" that takes handle as Integer and name as String returns Integer:
    Note: Get function address from loaded library
    Let platform be detect_current_platform
    
    Try:
        If platform is equal to "windows":
            Note: Use Windows GetProcAddress API directly
            Let kernel32_handle be get_system_module_handle with name as "kernel32.dll"
            If kernel32_handle is equal to 0:
                Return 0
            
            Let get_proc_addr_addr be get_system_proc_address with handle as kernel32_handle and name as "GetProcAddress"
            If get_proc_addr_addr is equal to 0:
                Return 0
            
            Let function_address be invoke_system_call with address as get_proc_addr_addr and args as [handle, name] and convention as "stdcall"
            Return function_address as Integer
        
        Otherwise:
            Note: Use POSIX dlsym directly
            Let libdl_handle be get_system_module_handle with name as "libdl.so"
            If libdl_handle is equal to 0:
                Set libdl_handle to get_system_module_handle with name as "libdl.so.2"
            If libdl_handle is equal to 0:
                Return 0
            
            Let dlsym_addr be get_system_proc_address with handle as libdl_handle and name as "dlsym"
            If dlsym_addr is equal to 0:
                Return 0
            
            Let function_address be invoke_system_call with address as dlsym_addr and args as [handle, name] and convention as "cdecl"
            Return function_address as Integer
    
    Catch Exception:
        Return 0

Process called "invoke_function_pointer" that takes address as Integer and args as List[Any] and calling_convention as String returns Any:
    Note: Invoke function pointer with arguments and calling convention
    Return invoke_system_call with address as address and args as args and convention as calling_convention

Note: VM-Level System Functions (Core FFI Infrastructure)

Process called "get_system_module_handle" that takes name as String returns Integer:
    Note: Get handle to system module/library loaded by runtime
    Try:
        Note: This function interfaces with the Runa VM's native module system
        Let module_registry be get_vm_native_module_registry
        If module_registry contains name:
            Return module_registry at key name
        
        Note: Attempt to load module if not already loaded
        Let load_result be vm_load_native_module with name as name
        If load_result is greater than 0:
            Call vm_register_native_module with name as name and handle as load_result
            Return load_result
    
    Catch Exception:
        Pass
    
    Return 0

Process called "get_system_proc_address" that takes handle as Integer and name as String returns Integer:
    Note: Get procedure address from module handle
    Try:
        Note: This function interfaces with the Runa VM's native symbol resolution
        Let symbol_table be get_vm_native_symbol_table with handle as handle
        If symbol_table contains name:
            Return symbol_table at key name
        
        Note: Attempt symbol resolution if not cached
        Let symbol_address be vm_resolve_native_symbol with handle as handle and symbol as name
        If symbol_address is greater than 0:
            Call vm_cache_native_symbol with handle as handle and symbol as name and address as symbol_address
            Return symbol_address
    
    Catch Exception:
        Pass
    
    Return 0

Process called "invoke_system_call" that takes address as Integer and args as List[Any] and convention as String returns Any:
    Note: Invoke native function at address with calling convention
    Try:
        Note: This function interfaces with the Runa VM's native call infrastructure
        If convention is equal to "stdcall":
            Return vm_invoke_native_stdcall with address as address and arguments as args
        If convention is equal to "cdecl":
            Return vm_invoke_native_cdecl with address as address and arguments as args
        If convention is equal to "fastcall":
            Return vm_invoke_native_fastcall with address as address and arguments as args
    
    Catch Exception:
        Pass
    
    Return null

Process called "get_vm_native_module_registry" that returns Dictionary[String, Integer]:
    Note: Access VM's native module registry
    Try:
        Note: VM-provided function to access loaded native modules
        Return vm_get_native_module_registry
    Catch Exception:
        Return empty dictionary

Process called "vm_load_native_module" that takes name as String returns Integer:
    Note: Load native module through VM
    Try:
        Note: VM-provided function to load native libraries/DLLs
        Return vm_load_module with path as name
    Catch Exception:
        Return 0

Process called "vm_register_native_module" that takes name as String and handle as Integer returns None:
    Note: Register loaded module in VM registry
    Try:
        Call vm_register_module with name as name and handle as handle
    Catch Exception:
        Pass

Process called "get_vm_native_symbol_table" that takes handle as Integer returns Dictionary[String, Integer]:
    Note: Get symbol table for module
    Try:
        Return vm_get_module_symbols with handle as handle
    Catch Exception:
        Return empty dictionary

Process called "vm_resolve_native_symbol" that takes handle as Integer and symbol as String returns Integer:
    Note: Resolve symbol address in module
    Try:
        Return vm_resolve_symbol with handle as handle and name as symbol
    Catch Exception:
        Return 0

Process called "vm_cache_native_symbol" that takes handle as Integer and symbol as String and address as Integer returns None:
    Note: Cache resolved symbol
    Try:
        Call vm_cache_symbol with handle as handle and name as symbol and address as address
    Catch Exception:
        Pass

Process called "vm_invoke_native_stdcall" that takes address as Integer and arguments as List[Any] returns Any:
    Note: Invoke native function using stdcall convention
    Try:
        Return vm_call_native with address as address and args as arguments and convention as 0  Note: 0 = stdcall
    Catch Exception:
        Return null

Process called "vm_invoke_native_cdecl" that takes address as Integer and arguments as List[Any] returns Any:
    Note: Invoke native function using cdecl convention
    Try:
        Return vm_call_native with address as address and args as arguments and convention as 1  Note: 1 = cdecl
    Catch Exception:
        Return null

Process called "vm_invoke_native_fastcall" that takes address as Integer and arguments as List[Any] returns Any:
    Note: Invoke native function using fastcall convention
    Try:
        Return vm_call_native with address as address and args as arguments and convention as 2  Note: 2 = fastcall
    Catch Exception:
        Return null

Note: Additional Missing Helper Functions

Process called "current_timestamp" that returns Integer:
    Note: Get current system timestamp - core function used throughout the system
    Try:
        Let platform be detect_current_platform
        
        If platform is equal to "windows":
            Let filetime_buffer be create_buffer_for_filetime
            Call call_win32_api with:
                function as "GetSystemTimeAsFileTime" and
                parameters as [filetime_buffer] and
                library as "kernel32.dll"
            
            Let timestamp be extract_filetime_from_buffer with buffer as filetime_buffer
            If timestamp is greater than 0:
                Return timestamp
        
        Otherwise:
            Note: Use gettimeofday for POSIX systems
            Let timeval_buffer be create_buffer_with_size with size as 16  Note: struct timeval
            Let result be call_posix_api with:
                library as "libc" and
                function as "gettimeofday" and
                parameters as [timeval_buffer, null]
            
            If result is equal to 0:
                Let seconds be extract_long_from_buffer with buffer as timeval_buffer and offset as 0
                Let microseconds be extract_long_from_buffer with buffer as timeval_buffer and offset as 8
                Return seconds
    
    Catch Exception:
        Pass
    
    Note: Final fallback - use system uptime or process start time
    Try:
        Let platform be detect_current_platform
        If platform is equal to "windows":
            Let tick_count be call_win32_api with:
                function as "GetTickCount64" and
                parameters as [] and
                library as "kernel32.dll"
            
            If tick_count is greater than 0:
                Note: Calculate actual boot time by subtracting uptime from current time
                Let uptime_seconds be tick_count divided by 1000
                Let current_time_result be get_current_timestamp_from_system
                If current_time_result is greater than 0:
                    Let boot_time be current_time_result minus uptime_seconds
                    Return boot_time
                Otherwise:
                    Return -1  Note: Cannot determine boot time without current time
        
        Otherwise:
            Let uptime_info be read_file_safe with path as "/proc/uptime"
            If uptime_info is not equal to "":
                Let uptime_seconds be extract_number_from_string with string as uptime_info
                Note: Calculate actual boot time by subtracting uptime from current time
                Let current_time_result be get_current_timestamp_from_system
                Let boot_offset be current_time_result minus uptime_seconds
                Return boot_offset plus uptime_seconds
    
    Catch Exception:
        Pass
    
    Note: Last resort - return epoch with process ID offset for uniqueness
    Let process_id be get_current_process_id
    Note: Attempt to get actual system time
    Try:
        Let system_time be get_current_timestamp_from_system
        If system_time is greater than 0:
            Return system_time
    Catch error:
        Pass
    Return -1  Note: Failure to get timestamp

Process called "get_environment_variable" that takes name as String returns String:
    Note: Get single environment variable value
    Let env_vars be get_environment_variables
    If env_vars contains name:
        Return env_vars at key name
    Return ""

Process called "close_windows_handle" that takes handle as Integer returns None:
    Note: Close Windows handle using CloseHandle API
    Try:
        Call call_win32_api with:
            function as "CloseHandle" and
            parameters as [handle] and
            library as "kernel32.dll"
    Catch Exception:
        Pass

Process called "get_home_directory_path" that returns String:
    Note: Get user home directory path
    Let platform be detect_current_platform
    If platform is equal to "windows":
        Let userprofile be get_environment_variable with name as "USERPROFILE"
        If userprofile is not equal to "":
            Return userprofile
        Note: Attempt to get system default user directory
        Try:
            Let default_user_dir be call_win32_api with function_name as "SHGetSpecialFolderPathA" and params as create_list with 0 and "CSIDL_PROFILE"
            If default_user_dir is not equal to "":
                Return default_user_dir
        Catch error:
            Pass
        Return ""  Note: Return empty string if unable to detect
    Otherwise:
        Let home be get_environment_variable with name as "HOME"
        If home is not equal to "":
            Return home
        Note: Try to get actual system user directory
        Try:
            Let passwd_entry be call_posix_api with function_name as "getpwuid" and params as create_list with "getuid"
            If passwd_entry is not equal to null:
                Let home_dir be extract_home_from_passwd with entry as passwd_entry
                If home_dir is not equal to "":
                    Return home_dir
        Catch error:
            Pass
        Return ""  Note: Return empty string if unable to detect

Process called "set_window_title" that takes handle as Integer and title as String returns None:
    Note: Set window title using platform-appropriate API
    Try:
        Call call_win32_api with:
            function as "SetWindowTextA" and
            parameters as [handle, title] and
            library as "user32.dll"
    Catch Exception:
        Pass

Process called "set_x11_window_title" that takes display as Integer and window as Integer and title as String returns None:
    Note: Set X11 window title using XStoreName
    Try:
        Call call_posix_api with:
            library as "libX11" and
            function as "XStoreName" and
            parameters as [display, window, title]
    Catch Exception:
        Pass

Process called "log_api_error" that takes library as String and function as String and error as String returns None:
    Note: Log API call errors (simplified logging)
    Note: In production this would integrate with proper logging system
    Return

Process called "get_current_unix_timestamp" that returns Integer:
    Note: Get current Unix timestamp
    Try:
        Return current_timestamp
    Catch Exception:
        Note: Final attempt - try getting actual system time
        Try:
            Let system_time be get_current_timestamp_from_system
            If system_time is greater than 0:
                Return system_time
        Catch error:
            Pass
        
        Return -1  Note: Return -1 to indicate timestamp detection failed

Note: Custom Native System Exceptions
Type NativeSystemError as Exception