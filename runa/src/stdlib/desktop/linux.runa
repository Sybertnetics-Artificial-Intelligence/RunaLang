Process called "create_status_notifier_item" that takes tray_icon as SystemTrayIcon and context as LinuxGUIContext returns None:
    Note: Create StatusNotifierItem (modern system tray protocol)
    Try:
        If context.dbus_connection is equal to none:
            Throw LinuxGUIError with message as "No D-Bus connection for StatusNotifierItem"
        
        Note: Generate unique service name for this tray icon
        Let service_name be "org.runa.StatusNotifierItem." plus tray_icon.id
        Let object_path be "/StatusNotifierItem"
        
        Note: Register D-Bus service for StatusNotifierItem
        Call register_dbus_service with
            connection as context.dbus_connection and
            service_name as service_name
        
        Note: Export StatusNotifierItem interface
        Call export_status_notifier_interface with
            connection as context.dbus_connection and
            object_path as object_path and
            tray_icon as tray_icon
        
        Note: Register with StatusNotifierWatcher
        Let register_message be DBusMessage with:
            type as "method_call"
            destination as "org.kde.StatusNotifierWatcher"
            path as "/StatusNotifierWatcher"
            interface as "org.kde.StatusNotifierWatcher"
            member as "RegisterStatusNotifierItem"
            signature as "s"
            body as service_name
            timestamp as current_timestamp
        
        Call send_dbus_message with
            connection as context.dbus_connection and
            message as register_message
        
        Note: Set up tray icon properties
        Set tray_icon.sni_service_name to service_name
        Set tray_icon.sni_object_path to object_path
        Set tray_icon.sni_registered to true
    
    Catch error as Exception:
        Call log_integration_error with desktop as "status_notifier" and error as error
        
        Note: Fallback to XEmbed tray
        Call create_xembed_system_tray with tray_icon as tray_icon and context as context

Process called "create_kde_system_tray" that takes tray_icon as SystemTrayIcon and context as LinuxGUIContext returns None:
    Note: Create KDE-specific system tray using StatusNotifierItem
    Try:
        Note: Register with KDE StatusNotifierWatcher
        Let watcher_service be "org.kde.StatusNotifierWatcher"
        Let watcher_path be "/StatusNotifierWatcher"
        
        Let dbus_connection be get_dbus_system_connection
        If dbus_connection is equal to null:
            Throw LinuxError with message as "Failed to connect to D-Bus for KDE system tray"
        
        Note: Create StatusNotifierItem service
        Let item_service be "org.freedesktop.StatusNotifierItem-" plus string_from_integer with value as tray_icon.id
        Let item_path be "/StatusNotifierItem"
        
        Note: Register item with watcher
        Call dbus_method_call with
            connection as dbus_connection and
            service as watcher_service and
            path as watcher_path and
            interface as "org.kde.StatusNotifierWatcher" and
            method as "RegisterStatusNotifierItem" and
            parameters as [item_service]
        
        Note: Set up tray icon properties
        Call setup_status_notifier_properties with
            tray_icon as tray_icon and
            service as item_service and
            path as item_path
        
        Note: Handle tray icon events
        Call setup_kde_tray_event_handlers with tray_icon as tray_icon and context as context
        
    Catch error as Exception:
        Call log_integration_error with desktop as "kde_system_tray" and error as error
        
        Note: Fallback to generic system tray
        Call create_generic_system_tray with tray_icon as tray_icon and context as context

Process called "create_xembed_system_tray" that takes tray_icon as SystemTrayIcon and context as LinuxGUIContext returns None:
    Note: Create legacy XEmbed system tray icon for older desktop environments
    Try:
        If context.display_server is not equal to X11:
            Throw LinuxGUIError with message as "XEmbed tray only supports X11"
        
        Note: Find system tray window
        Let tray_window be find_x11_system_tray_window
        If tray_window is equal to 0:
            Throw LinuxGUIError with message as "No system tray found"
        
        Note: Create small window for tray icon
        Let icon_window be create_x11_tray_icon_window with
            parent as tray_window and
            size as 24 and
            icon_data as tray_icon.icon_data
        
        Note: Set up XEmbed protocol
        Call setup_xembed_protocol with
            tray_window as tray_window and
            icon_window as icon_window
        
        Note: Send system tray dock request
        Call send_system_tray_dock_request with
            tray_window as tray_window and
            icon_window as icon_window
        
        Note: Set up event handling for tray icon
        Call setup_tray_icon_events with
            icon_window as icon_window and
            tray_icon as tray_icon
        
        Note: Map the icon window
        Call map_x11_window with
            display as get_x11_display and
            window as icon_window
        
        Set tray_icon.xembed_window_id to icon_window
        Set tray_icon.xembed_registered to true
    
    Catch error as Exception:
        Call log_integration_error with desktop as "xembed_tray" and error as error

Process called "send_dbus_notification" that takes notification as LinuxNotification and context as LinuxGUIContext returns None:
    Note: Send notification via D-Bus org.freedesktop.Notifications
    Try:
        If context.dbus_connection is equal to none:
            Throw LinuxGUIError with message as "No D-Bus connection available for notifications"
        
        Note: Build notification D-Bus message
        Let notification_message be DBusMessage with:
            type as "method_call"
            destination as "org.freedesktop.Notifications"
            path as "/org/freedesktop/Notifications"
            interface as "org.freedesktop.Notifications"
            member as "Notify"
            signature as "susssasa{sv}i"
            body as create_notification_dbus_body with notification as notification
            timestamp as current_timestamp
        
        Note: Send notification message
        Call send_dbus_message with
            connection as context.dbus_connection and
            message as notification_message
        
        Note: Store notification for tracking
        Call context.notification_service.active_notifications.append with item as notification
        
        Note: Set up notification callbacks if specified
        If notification.callback_id is not equal to "":
            Set context.notification_service.notification_callbacks[notification.callback_id] to notification.callback
    
    Catch error as Exception:
        Call log_integration_error with desktop as "notifications" and error as error
        
        Note: Fallback to command line notification
        Call send_fallback_notification with notification as notification

Process called "register_mime_type" that takes mime_type as String and desktop_file as String returns None:
    Note: Register MIME type association using freedesktop.org standards
    Try:
        Note: Create or update MIME type database entry
        Let mime_db_dir be get_user_mime_directory
        Let mime_type_file be mime_db_dir plus "/packages/runa-" plus sanitize_mime_type with mime_type as mime_type plus ".xml"
        
