            Return
        
        Note: Log any warnings or errors from update command
        If string_contains with string as update_result and substring as "error":
            Call log_integration_error with desktop as "desktop_update" and error as Exception with message as update_result
    
    Catch error as Exception:
        Call log_integration_error with desktop as "desktop_update" and error as error

Process called "create_desktop_file" that takes context as LinuxGUIContext and application as gui.GUIApplication returns String:
    Note: Create proper freedesktop.org compliant desktop file
    Try:
        Let app_name be application.name
        Let sanitized_name be sanitize_filename with name as app_name
        Let desktop_filename be sanitized_name plus ".desktop"
        
        Note: Use user applications directory first, fallback to system
        Let user_apps_dir be get_user_applications_directory
        Let desktop_file_path be user_apps_dir plus "/" plus desktop_filename
        
        Note: Create desktop file content
        Let desktop_content be "[Desktop Entry]\n"
        Set desktop_content to desktop_content plus "Version=1.0\n"
        Set desktop_content to desktop_content plus "Type=Application\n"
        Set desktop_content to desktop_content plus "Name=" plus app_name plus "\n"
        Set desktop_content to desktop_content plus "Comment=Runa Application\n"
        Set desktop_content to desktop_content plus "Exec=runa " plus get_application_executable_path with application as application plus "\n"
        Set desktop_content to desktop_content plus "Icon=" plus get_application_icon_path with application as application plus "\n"
        Set desktop_content to desktop_content plus "Terminal=false\n"
        Set desktop_content to desktop_content plus "Categories=Development;IDE;\n"
        Set desktop_content to desktop_content plus "Keywords=runa;programming;development;\n"
        Set desktop_content to desktop_content plus "MimeType=text/x-runa;application/x-runa;\n"
        Set desktop_content to desktop_content plus "StartupWMClass=Runa\n"
        Set desktop_content to desktop_content plus "StartupNotify=true\n"
        
        Note: Write desktop file
        Call write_file with path as desktop_file_path and content as desktop_content
        
        Note: Set executable permissions
        Call set_file_permissions with path as desktop_file_path and permissions as "755"
        
        Return desktop_file_path
    
    Catch error as Exception:
        Call log_integration_error with desktop as "desktop_file" and error as error
        Return ""

Process called "initialize_x11_clipboard" that takes clipboard as LinuxClipboard returns None:
    Note: Initialize X11 clipboard with CLIPBOARD and PRIMARY selections
    Try:
        Let display_name be get_environment_variable with name as "DISPLAY"
        If display_name is equal to "":
            Throw LinuxGUIError with message as "No X11 display for clipboard"
        
        Note: Create invisible window for clipboard operations
        Let clipboard_window be create_x11_clipboard_window with display as display_name
        
        Note: Set up clipboard selection atoms
        Let clipboard_atom be get_x11_atom with display as display_name and name as "CLIPBOARD"
        Let primary_atom be get_x11_atom with display as display_name and name as "PRIMARY"
        Let targets_atom be get_x11_atom with display as display_name and name as "TARGETS"
        
        Set clipboard.x11_clipboard to X11Clipboard with:
            display as display_name
            window as clipboard_window
            clipboard_atom as clipboard_atom
            primary_atom as primary_atom
            targets_atom as targets_atom
            supported_targets as ["UTF8_STRING", "STRING", "TEXT"]
            current_selection_owner as none
        
        Note: Set up clipboard event handling
        Call setup_x11_clipboard_events with clipboard as clipboard
    
    Catch error as Exception:
        Call log_integration_error with desktop as "x11_clipboard" and error as error

Process called "initialize_wayland_clipboard" that takes clipboard as LinuxClipboard returns None:
    Note: Initialize Wayland clipboard with data device manager
    Try:
        Let wayland_display be get_environment_variable with name as "WAYLAND_DISPLAY"
        If wayland_display is equal to "":
            Throw LinuxGUIError with message as "No Wayland display for clipboard"
        
        Note: Connect to Wayland data device manager
        Let data_device_manager be get_wayland_data_device_manager with display as wayland_display
        If data_device_manager is equal to none:
            Throw LinuxGUIError with message as "No data device manager available"
        
        Set clipboard.wayland_clipboard to WaylandClipboard with:
            display as wayland_display
            data_device_manager as data_device_manager
            data_device as none
            data_source as none
            supported_mime_types as ["text/plain", "text/plain;charset=utf-8"]
            selection_data as none
        
        Note: Get seat and create data device
        Let seat be get_wayland_seat with display as wayland_display
        If seat is not equal to none:
            Let data_device be create_wayland_data_device with
                manager as data_device_manager and
                seat as seat
            Set clipboard.wayland_clipboard.data_device to data_device
            
            Note: Set up clipboard event callbacks
            Call setup_wayland_clipboard_events with clipboard as clipboard
    
    Catch error as Exception:
        Call log_integration_error with desktop as "wayland_clipboard" and error as error

Process called "connect_to_session_bus" that returns Optional[SessionBus]:
    Note: Connect to D-Bus session bus with proper error handling
    Try:
        Note: Check if D-Bus session is available
        Let dbus_session_address be get_environment_variable with name as "DBUS_SESSION_BUS_ADDRESS"
        If dbus_session_address is equal to "":
            Note: Try to start D-Bus session if not running
            Let dbus_launch_result be execute_system_command with command as "dbus-launch --sh-syntax"
            If dbus_launch_result is not equal to "":
                Note: Parse D-Bus session address from launch output
                Let session_address be parse_dbus_session_address with output as dbus_launch_result
                If session_address is not equal to "":
                    Call set_environment_variable with name as "DBUS_SESSION_BUS_ADDRESS" and value as session_address
        
        Note: Test D-Bus connection
        Let test_result be execute_system_command with command as "dbus-send --session --print-reply --dest=org.freedesktop.DBus /org/freedesktop/DBus org.freedesktop.DBus.GetId"
        If test_result is not equal to "":
            Let connection_id be generate_dbus_connection_id
            Return SessionBus with:
                handle as connection_id
                address as dbus_session_address
                is_connected as true
                connection_name as "session"
                last_activity as current_timestamp
                services as empty list
                subscriptions as empty list
                metadata as Dictionary with "connected_at" as current_timestamp
        
        Return none
    
    Catch error as Exception:
        Call log_dbus_error with error as error
        Return none

Process called "connect_to_system_bus" that returns Optional[SystemBus]:
    Note: Connect to D-Bus system bus with proper authorization checks
    Try:
        Note: Check if we have permission to access system bus
        Let system_bus_test be execute_system_command with command as "dbus-send --system --print-reply --dest=org.freedesktop.DBus /org/freedesktop/DBus org.freedesktop.DBus.GetId"
        If system_bus_test is not equal to "":
            Let connection_id be generate_dbus_connection_id plus 1000
            Return SystemBus with:
                handle as connection_id
                address as "unix:path=/var/run/dbus/system_bus_socket"
                is_connected as true
                connection_name as "system"
                requires_authorization as true
                last_activity as current_timestamp
                services as empty list
                subscriptions as empty list
                metadata as Dictionary with "connected_at" as current_timestamp
        
        Return none
    
    Catch error as Exception:
        Call log_dbus_error with error as error
        Return none

Process called "register_dbus_service" that takes connection as DBusConnection and service_name as String returns None:
    Note: Register D-Bus service with proper name and interface
    Try:
        Let sanitized_service_name be sanitize_dbus_service_name with name as service_name
        Let full_service_name be "org.runa." plus sanitized_service_name
        
        Note: Check if service name is available
        Let name_available be check_dbus_name_availability with
            connection as connection and
            service_name as full_service_name
        
        If name_available is equal to false:
            Throw LinuxGUIError with message as "D-Bus service name already taken: " plus full_service_name
        
        Note: Request service name ownership
        Let ownership_result be request_dbus_name_ownership with
            connection as connection and
            service_name as full_service_name and
            flags as "DBUS_NAME_FLAG_DO_NOT_QUEUE"
        
        If ownership_result is equal to true:
            Call connection.services.append with item as full_service_name
            
            Note: Export application object
            Call export_dbus_application_object with
                connection as connection and
                service_name as full_service_name and
                object_path as "/org/runa/Application"
            
            Set connection.metadata["primary_service"] to full_service_name
        Otherwise:
            Throw LinuxGUIError with message as "Failed to acquire D-Bus service name: " plus full_service_name
    
    Catch error as Exception:
        Call log_dbus_error with error as error

Process called "send_dbus_message" that takes connection as DBusConnection and message as DBusMessage returns None:
    Note: Send D-Bus message with proper error handling and validation
    Try:
        Note: Validate message format
        If message.destination is equal to "" or message.interface is equal to "":
            Throw LinuxGUIError with message as "Invalid D-Bus message: missing destination or interface"
        
        Note: Build D-Bus message command
        Let dbus_cmd be "dbus-send"
        
        Note: Add connection type
        If connection.connection_name is equal to "session":
            Set dbus_cmd to dbus_cmd plus " --session"
        Otherwise if connection.connection_name is equal to "system":
            Set dbus_cmd to dbus_cmd plus " --system"
        
        Note: Add message properties
        Set dbus_cmd to dbus_cmd plus " --dest=" plus message.destination
        Set dbus_cmd to dbus_cmd plus " " plus message.path
        Set dbus_cmd to dbus_cmd plus " " plus message.interface plus "." plus message.member
        
        Note: Add message body if present
        If message.body is not equal to none:
            Let serialized_body be serialize_dbus_message_body with
                body as message.body and
                signature as message.signature
            Set dbus_cmd to dbus_cmd plus " " plus serialized_body
        
        Note: Send message
        Let send_result be execute_system_command with command as dbus_cmd
        
        Note: Update connection activity
        Set connection.last_activity to current_timestamp
        
        Note: Log successful send for debugging
        Call log_dbus_message_sent with
            destination as message.destination and
            interface as message.interface and
            member as message.member
    
    Catch error as Exception:
        Call log_dbus_error with error as error
        Throw LinuxGUIError with message as "Failed to send D-Bus message: " plus error as string

