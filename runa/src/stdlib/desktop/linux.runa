    metadata as Dictionary[String, Any]

Process called "initialize_clipboard_manager" that returns ClipboardManager:
    Note: Initialize comprehensive clipboard manager with X11/Wayland support
    Try:
        Let display_server be detect_display_server
        Let clipboard_support be check_clipboard_support with display_server as display_server
        
        Let clipboard_manager be ClipboardManager with:
            active as clipboard_support
            display_server as display_server
            supports_text as true
            supports_images as check_image_clipboard_support with display_server as display_server
            supports_files as check_file_clipboard_support with display_server as display_server
            supports_html as check_html_clipboard_support with display_server as display_server
            clipboard_history as empty list
            max_history_items as 100
            primary_selection_support as display_server is equal to X11
            selection_owner as none
            clipboard_watcher as none
            metadata as Dictionary with "initialized_at" as current_timestamp
        
        Note: Initialize clipboard based on display server
        If display_server is equal to X11:
            Call initialize_x11_clipboard_manager with manager as clipboard_manager
        Otherwise if display_server is equal to WAYLAND:
            Call initialize_wayland_clipboard_manager with manager as clipboard_manager
        
        Note: Set up clipboard change monitoring
        Call setup_clipboard_monitoring with manager as clipboard_manager
        
        Return clipboard_manager
    
    Catch error as Exception:
        Call log_integration_error with desktop as "clipboard" and error as error
        Return ClipboardManager with:
            active as false
            display_server as UNKNOWN
            supports_text as false
            supports_images as false
            supports_files as false
            supports_html as false
            clipboard_history as empty list
            max_history_items as 0
            primary_selection_support as false
            selection_owner as none
            clipboard_watcher as none
            metadata as Dictionary with "error" as error as string

Type ClipboardManager is Dictionary with:
    active as Boolean
    display_server as LinuxDisplayServer
    supports_text as Boolean
    supports_images as Boolean
    supports_files as Boolean
    supports_html as Boolean
    clipboard_history as List[Any]
    max_history_items as Integer
    primary_selection_support as Boolean
    selection_owner as Optional[String]
    clipboard_watcher as Optional[Any]
    metadata as Dictionary[String, Any]

Process called "initialize_application_menu" that takes desktop_env as LinuxDesktopEnvironment returns ApplicationMenu:
    Return ApplicationMenu with:
        application as none
        global_menu as none
        local_menu as none
        supports_global_menu as false
        menu_items as empty list
        desktop_environment as desktop_env
        metadata as empty dictionary

Process called "setup_linux_window_manager" that takes context as LinuxGUIContext and application as gui.GUIApplication returns None:
    Note: Set up Linux-specific window manager integration
    Try:
        Let display_server be context.display_server
        Let desktop_env be context.desktop_environment
        
        Note: Initialize display server connection
        If display_server is equal to X11:
            Call setup_x11_window_manager with context as context and application as application
        Otherwise if display_server is equal to WAYLAND:
            Call setup_wayland_window_manager with context as context and application as application
        
        Note: Set up desktop environment specific features
        If desktop_env is equal to GNOME:
            Call setup_gnome_window_integration with context as context and application as application
        Otherwise if desktop_env is equal to KDE_PLASMA:
            Call setup_kde_window_integration with context as context and application as application
        Otherwise if desktop_env is equal to XFCE:
            Call setup_xfce_window_integration with context as context and application as application
        
        Note: Set up window manager protocols
        Call setup_wm_protocols with context as context and application as application
        
        Note: Enable compositing if available
        Let compositor be detect_composite_manager
        If compositor is not equal to none:
            Call enable_window_compositing with context as context and compositor as compositor
    
    Catch error as Exception:
        Call log_integration_error with desktop as "window_manager" and error as error

Process called "register_application_with_desktop" that takes context as LinuxGUIContext and application as gui.GUIApplication returns None:
    Note: Register application with desktop environment services
    Try:
        Let desktop_env be context.desktop_environment
        
        Note: Create and install desktop file
        Let desktop_file_path be create_desktop_file with context as context and application as application
        Call install_desktop_file with path as desktop_file_path
        
        Note: Register with session manager
        If desktop_env is equal to GNOME:
            Call register_with_gnome_session with context as context and application as application
        Otherwise if desktop_env is equal to KDE_PLASMA:
            Call register_with_kded with context as context and application as application
        Otherwise if desktop_env is equal to XFCE:
            Call register_with_xfce_session with context as context and application as application
        
        Note: Register application menu
        If check_global_menu_support with context as context is equal to true:
            Call setup_global_menu with menu as context.application_menu and context as context
        
        Note: Set up D-Bus service if available
        If context.dbus_connection is not equal to none:
            Call register_dbus_service with connection as context.dbus_connection and service_name as application.name
        
        Note: Register mime types and file associations
        Call register_mime_types with context as context and application as application
        Call update_desktop_database
        Call update_mime_database
        
        Note: Set up freedesktop.org compliance
        Call setup_freedesktop_compliance with context as context and application as application
    
    Catch error as Exception:
        Call log_integration_error with desktop as "registration" and error as error

Process called "create_default_window_properties" that returns WindowProperties:
    Return WindowProperties with:
        wm_class as "Runa"
        wm_name as "Runa Application"
        wm_icon_name as "runa"
        wm_protocols as empty list
        wm_state as "normal"
        wm_type as "normal"
        wm_hints as empty dictionary
        extended_wm_hints as empty dictionary

Process called "detect_composite_manager" that returns Optional[String]:
    Note: Detect if a compositing window manager is running (like Compiz, Mutter, KWin)
    Try:
        Let xdg_session_type be get_environment_variable with name as "XDG_SESSION_TYPE"
        Let display be get_environment_variable with name as "DISPLAY"
        Let wayland_display be get_environment_variable with name as "WAYLAND_DISPLAY"
        
        If wayland_display is not empty:
            Return "wayland-compositor"
        Otherwise if display is not empty:
            Note: Common X11 compositing managers
            Let desktop_session be get_environment_variable with name as "DESKTOP_SESSION"
            Let xdg_current_desktop be get_environment_variable with name as "XDG_CURRENT_DESKTOP"
            
            If xdg_current_desktop contains "GNOME":
                Return "mutter"
            Otherwise if xdg_current_desktop contains "KDE":
                Return "kwin"
            Otherwise if xdg_current_desktop contains "XFCE":
                Return "xfwm4"
            Otherwise if desktop_session contains "compiz":
                Return "compiz"
            Otherwise:
                Return "unknown-compositor"
        Otherwise:
            Return "no-display-server"
    
    Catch error as Exception:
        Return "detection-failed"

Process called "check_transparency_support" that takes context as LinuxGUIContext returns Boolean:
    Return true

Process called "create_x11_window" that takes linux_window as LinuxWindow and context as LinuxGUIContext returns None:
    Note: Create X11 window with proper attributes and window manager integration
    Try:
        Note: Get X11 display connection
        Let display_name be get_environment_variable with name as "DISPLAY"
        If display_name is equal to "":
            Throw LinuxGUIError with message as "No X11 display available"
        
        Note: Set up window attributes based on Runa window properties
        Let window_attributes be create_x11_window_attributes with
            width as linux_window.gui_window.width and
            height as linux_window.gui_window.height and
            background_color as linux_window.gui_window.background_color
        
        Note: Create X11 window with proper visual and colormap
        Let x11_window_id be create_x11_window_with_attributes with
            display as display_name and
            parent as get_root_window and
            x as linux_window.gui_window.x_position and
            y as linux_window.gui_window.y_position and
            width as linux_window.gui_window.width and
            height as linux_window.gui_window.height and
            attributes as window_attributes
        
        Note: Set window manager properties
        Call set_x11_window_properties with
            display as display_name and
            window as x11_window_id and
            title as linux_window.gui_window.title and
            class_name as "Runa" and
            instance_name as "runa-application"
        
        Note: Set up event handling
        Call setup_x11_event_handling with
            display as display_name and
            window as x11_window_id and
            linux_window as linux_window
        
        Set linux_window.x11_window to X11Window with:
            window_id as x11_window_id
            display as display_name
            is_mapped as false
            has_focus as false
            event_mask as calculate_x11_event_mask
            atom_cache as empty dictionary
        
        Note: Map window to make it visible
        Call map_x11_window with display as display_name and window as x11_window_id
        Set linux_window.x11_window.is_mapped to true
    
    Catch error as Exception:
        Call log_integration_error with desktop as "x11" and error as error
        Throw LinuxGUIError with message as "Failed to create X11 window: " plus error as string

Process called "create_wayland_window" that takes linux_window as LinuxWindow and context as LinuxGUIContext returns None:
    Note: Create Wayland surface with proper shell integration
    Try:
        Note: Connect to Wayland compositor
        Let wayland_display be get_environment_variable with name as "WAYLAND_DISPLAY"
        If wayland_display is equal to "":
            Throw LinuxGUIError with message as "No Wayland display available"
        
        Note: Create Wayland surface
        Let wayland_surface_id be create_wayland_surface with
            display as wayland_display and
            width as linux_window.gui_window.width and
            height as linux_window.gui_window.height
        
        Note: Create shell surface (xdg-shell or wl-shell)
        Let shell_surface be create_wayland_shell_surface with
            surface as wayland_surface_id and
            title as linux_window.gui_window.title and
            app_id as "runa-application"
        
        Note: Set up surface properties
        Call set_wayland_surface_properties with
            surface as wayland_surface_id and
            shell_surface as shell_surface and
            properties as linux_window.window_properties
        
        Note: Set up frame callback for rendering
        Call setup_wayland_frame_callback with
            surface as wayland_surface_id and
            linux_window as linux_window
        
        Set linux_window.wayland_surface to WaylandSurface with:
            surface_id as wayland_surface_id
            shell_surface as shell_surface
            display as wayland_display
            is_configured as false
            pending_configure as none
            frame_callback as none
            buffer as none
        
        Note: Commit initial surface state
        Call commit_wayland_surface with surface as wayland_surface_id
    
    Catch error as Exception:
        Call log_integration_error with desktop as "wayland" and error as error
        Throw LinuxGUIError with message as "Failed to create Wayland window: " plus error as string

Process called "setup_window_decorations" that takes linux_window as LinuxWindow and context as LinuxGUIContext returns None:
    Note: Set up window decorations based on desktop environment and display server
    Try:
        Let display_server be context.display_server
        Let desktop_env be context.desktop_environment
        
        If display_server is equal to X11:
            Note: Set up X11 window decorations
            Call setup_x11_window_decorations with
                linux_window as linux_window and
                desktop_env as desktop_env
        Otherwise if display_server is equal to WAYLAND:
            Note: Set up Wayland client-side decorations
            Call setup_wayland_client_decorations with
                linux_window as linux_window and
                desktop_env as desktop_env
        
        Note: Apply desktop environment specific theming
        Call apply_desktop_theme_to_window with
            linux_window as linux_window and
            context as context
        
        Note: Set up window controls (minimize, maximize, close)
        Call setup_window_controls with
            linux_window as linux_window and
            context as context
    
    Catch error as Exception:
        Call log_integration_error with desktop as "decorations" and error as error

Process called "register_window_with_wm" that takes linux_window as LinuxWindow and context as LinuxGUIContext returns None:
    Note: Register window with window manager for proper integration
    Try:
        Let display_server be context.display_server
        
        If display_server is equal to X11:
            Note: Set up EWMH (Extended Window Manager Hints) properties
            Call setup_ewmh_properties with linux_window as linux_window
            
            Note: Set up ICCCM (Inter-Client Communication Conventions Manual) properties
            Call setup_icccm_properties with linux_window as linux_window
            
            Note: Set up window manager specific protocols
            Call setup_wm_protocols with
                linux_window as linux_window and
                protocols as ["WM_DELETE_WINDOW", "WM_SAVE_YOURSELF", "WM_TAKE_FOCUS"]
        
        Otherwise if display_server is equal to WAYLAND:
            Note: Set up xdg-shell integration
            Call setup_xdg_shell_integration with linux_window as linux_window
            
            Note: Set up Wayland surface role
            Call set_wayland_surface_role with
                surface as linux_window.wayland_surface and
                role as "toplevel"
        
        Note: Register for desktop environment specific features
        Let desktop_env be context.desktop_environment
        If desktop_env is equal to GNOME:
            Call register_with_gnome_wm with linux_window as linux_window
        Otherwise if desktop_env is equal to KDE_PLASMA:
            Call register_with_kwin with linux_window as linux_window
        Otherwise if desktop_env is equal to XFCE:
            Call register_with_xfwm with linux_window as linux_window
    
    Catch error as Exception:
        Call log_integration_error with desktop as "window_manager" and error as error

