Note:
Runa Standard Library: Android Development

Production-grade Android development framework providing comprehensive
native Android capabilities with modern development patterns.

Features:
- Activity and Fragment lifecycle management
- Android UI components (Views, Layouts, Material Design)
- Intent system for inter-component communication
- Service management (Foreground, Background, Bound services)
- BroadcastReceiver integration
- SharedPreferences and database storage
- Network operations with OkHttp integration
- Camera and media capture APIs
- Location services and geofencing
- Push notifications via Firebase Cloud Messaging
- Permissions management (runtime permissions)
- Background task scheduling (WorkManager)
- Android Architecture Components (ViewModel, LiveData, Room)
- Jetpack Compose integration for modern UI
- Testing framework integration (Espresso, Robolectric)
:End Note

Import "../../collections" as Collections
Import "../../string" as String
Import "../../datetime" as DateTime

Note: Core Android application components
Type called "AndroidActivity":
    activity_name as String
    layout_resource as String
    lifecycle_state as String
    intent_extras as Dictionary[String, Any]
    permissions_requested as List[String]
    view_model as AndroidViewModel
    fragments as List[AndroidFragment]

Type called "AndroidFragment":
    fragment_name as String
    layout_resource as String
    lifecycle_state as String
    arguments as Dictionary[String, Any]
    parent_activity as AndroidActivity

Type called "AndroidService":
    service_name as String
    service_type as String
    is_running as Boolean
    notification_id as Integer
    bind_clients as List[String]

Type called "AndroidViewModel":
    view_model_name as String
    live_data_fields as Dictionary[String, AndroidLiveData]
    repository as AndroidRepository

Type called "AndroidLiveData":
    data_type as String
    current_value as Any
    observers as List[String]

Type called "AndroidRepository":
    repository_name as String
    data_sources as List[AndroidDataSource]
    cache_policies as Dictionary[String, String]

Note: Android UI and Views
Type called "AndroidView":
    view_id as String
    view_type as String
    properties as Dictionary[String, Any]
    event_listeners as Dictionary[String, String]
    visibility as String
    enabled as Boolean

Type called "AndroidLayout":
    layout_type as String
    child_views as List[AndroidView]
    layout_params as Dictionary[String, Any]
    margin as AndroidMargin
    padding as AndroidPadding

Type called "AndroidMargin":
    left as Integer
    top as Integer
    right as Integer
    bottom as Integer

Type called "AndroidPadding":
    left as Integer
    top as Integer
    right as Integer
    bottom as Integer

Type called "MaterialDesignComponent":
    component_type as String
    theme as String
    color_scheme as Dictionary[String, String]
    elevation as Float
    animations as List[String]

Note: Intent system and navigation
Type called "AndroidIntent":
    action as String
    category as String
    component_name as String
    extras as Dictionary[String, Any]
    flags as List[String]
    data_uri as String

Type called "AndroidNavigation":
    navigation_graph as String
    start_destination as String
    transitions as Dictionary[String, String]
    arguments as Dictionary[String, Any]

Note: Data persistence
Type called "SharedPreferences":
    preferences_name as String
    values as Dictionary[String, Any]
    editor_mode as String

Type called "RoomDatabase":
    database_name as String
    version as Integer
    entities as List[RoomEntity]
    dao_interfaces as List[RoomDao]

Type called "RoomEntity":
    table_name as String
    fields as Dictionary[String, String]
    primary_key as String
    indices as List[String]

Type called "RoomDao":
    dao_name as String
    queries as Dictionary[String, String]
    entity_type as String

Note: Android permissions system
Type called "AndroidPermission":
    permission_name as String
    permission_level as String
    is_granted as Boolean
    rationale_message as String

Type called "PermissionManager":
    required_permissions as List[AndroidPermission]
    runtime_permissions as List[AndroidPermission]
    permission_callbacks as Dictionary[String, String]

Note: Activity lifecycle management
Process called "create_activity" that takes activity_name as String and layout_resource as String returns AndroidActivity:
    Return AndroidActivity with:
        activity_name as activity_name
        layout_resource as layout_resource
        lifecycle_state as "created"
        intent_extras as dictionary
        permissions_requested as list
        view_model as create_view_model with name as activity_name followed by "ViewModel"
        fragments as list

Process called "start_activity" that takes activity as AndroidActivity:
    Set activity.lifecycle_state to "started"
    initialize_activity_views with activity as activity
    setup_event_listeners with activity as activity
    request_required_permissions with activity as activity

Process called "resume_activity" that takes activity as AndroidActivity:
    Set activity.lifecycle_state to "resumed"
    restore_activity_state with activity as activity
    register_broadcast_receivers with activity as activity

Process called "pause_activity" that takes activity as AndroidActivity:
    Set activity.lifecycle_state to "paused"
    save_activity_state with activity as activity
    unregister_broadcast_receivers with activity as activity

Process called "stop_activity" that takes activity as AndroidActivity:
    Set activity.lifecycle_state to "stopped"
    cleanup_activity_resources with activity as activity

Process called "destroy_activity" that takes activity as AndroidActivity:
    Set activity.lifecycle_state to "destroyed"
    release_activity_memory with activity as activity
    clear_view_model_references with activity as activity

Note: Fragment lifecycle management
Process called "create_fragment" that takes fragment_name as String and layout_resource as String returns AndroidFragment:
    Return AndroidFragment with:
        fragment_name as fragment_name
        layout_resource as layout_resource
        lifecycle_state as "created"
        arguments as dictionary
        parent_activity as None

Process called "attach_fragment_to_activity" that takes fragment as AndroidFragment and activity as AndroidActivity:
    Set fragment.parent_activity to activity
    Add fragment to activity.fragments
    Set fragment.lifecycle_state to "attached"

Process called "replace_fragment" that takes container_id as String and fragment as AndroidFragment and activity as AndroidActivity:
    Let fragment_manager be get_fragment_manager with activity as activity
    execute_fragment_transaction with manager as fragment_manager and container_id as container_id and fragment as fragment and transaction_type as "replace"

Note: Intent system implementation
Process called "create_intent" that takes action as String returns AndroidIntent:
    Return AndroidIntent with:
        action as action
        category as ""
        component_name as ""
        extras as dictionary
        flags as list
        data_uri as ""

Process called "add_intent_extra" that takes intent as AndroidIntent and key as String and value as Any:
    Set intent.extras[key] to value

Process called "start_activity_with_intent" that takes activity as AndroidActivity and intent as AndroidIntent:
    Let target_activity be resolve_intent with intent as intent
    If target_activity is not None:
        transfer_intent_extras with source_intent as intent and target_activity as target_activity
        start_activity with activity as target_activity

Process called "send_broadcast" that takes intent as AndroidIntent:
    Let registered_receivers be find_broadcast_receivers with intent as intent
    For each receiver in registered_receivers:
        deliver_broadcast with receiver as receiver and intent as intent

Note: Service management
Process called "create_service" that takes service_name as String and service_type as String returns AndroidService:
    Return AndroidService with:
        service_name as service_name
        service_type as service_type
        is_running as false
        notification_id as 0
        bind_clients as list

Process called "start_service" that takes service as AndroidService:
    Set service.is_running to true
    Match service.service_type:
        When "foreground":
            create_foreground_notification with service as service
            start_foreground_service with service as service
        When "background":
            start_background_service with service as service
        When "bound":
            prepare_service_binding with service as service
        Otherwise:
            start_background_service with service as service

Process called "stop_service" that takes service as AndroidService:
    Set service.is_running to false
    cleanup_service_resources with service as service
    If service.service_type is equal to "foreground":
        remove_foreground_notification with service as service

Process called "bind_service" that takes service as AndroidService and client_id as String:
    Add client_id to service.bind_clients
    create_service_connection with service as service and client_id as client_id

Note: UI View management
Process called "create_view" that takes view_type as String and view_id as String returns AndroidView:
    Return AndroidView with:
        view_id as view_id
        view_type as view_type
        properties as dictionary
        event_listeners as dictionary
        visibility as "visible"
        enabled as true

Process called "set_view_property" that takes view as AndroidView and property_name as String and value as Any:
    Set view.properties[property_name] to value
    apply_view_property_change with view as view and property as property_name and value as value

Process called "add_click_listener" that takes view as AndroidView and callback as String:
    Set view.event_listeners["click"] to callback

Process called "create_linear_layout" that takes orientation as String returns AndroidLayout:
    Return AndroidLayout with:
        layout_type as "LinearLayout"
        child_views as list
        layout_params as dictionary with "orientation" as orientation
        margin as AndroidMargin with left as 0 and top as 0 and right as 0 and bottom as 0
        padding as AndroidPadding with left as 0 and top as 0 and right as 0 and bottom as 0

Process called "add_view_to_layout" that takes layout as AndroidLayout and view as AndroidView:
    Add view to layout.child_views
    update_layout_children with layout as layout

Note: Material Design components
Process called "create_material_button" that takes text as String returns MaterialDesignComponent:
    Return MaterialDesignComponent with:
        component_type as "MaterialButton"
        theme as "default"
        color_scheme as dictionary with "primary" as "#6200EE" and "on_primary" as "#FFFFFF"
        elevation as 2.0
        animations as list containing "ripple", "elevation_change"

Process called "create_material_text_field" that takes hint as String returns MaterialDesignComponent:
    Return MaterialDesignComponent with:
        component_type as "MaterialTextField"
        theme as "outlined"
        color_scheme as dictionary with "primary" as "#6200EE" and "error" as "#B00020"
        elevation as 0.0
        animations as list containing "focus_animation", "error_animation"

Process called "create_material_card" that takes content_layout as AndroidLayout returns MaterialDesignComponent:
    Return MaterialDesignComponent with:
        component_type as "MaterialCardView"
        theme as "elevated"
        color_scheme as dictionary with "surface" as "#FFFFFF" and "on_surface" as "#000000"
        elevation as 4.0
        animations as list containing "state_list_animator"

Note: SharedPreferences implementation
Process called "get_shared_preferences" that takes preferences_name as String returns SharedPreferences:
    Return SharedPreferences with:
        preferences_name as preferences_name
        values as load_preferences_from_storage with name as preferences_name
        editor_mode as "apply"

Process called "put_string_preference" that takes preferences as SharedPreferences and key as String and value as String:
    Set preferences.values[key] to value
    save_preferences_to_storage with preferences as preferences

Process called "get_string_preference" that takes preferences as SharedPreferences and key as String and default_value as String returns String:
    If key in preferences.values:
        Return preferences.values[key] as String
    Return default_value

Process called "put_boolean_preference" that takes preferences as SharedPreferences and key as String and value as Boolean:
    Set preferences.values[key] to value
    save_preferences_to_storage with preferences as preferences

Process called "get_boolean_preference" that takes preferences as SharedPreferences and key as String and default_value as Boolean returns Boolean:
    If key in preferences.values:
        Return preferences.values[key] as Boolean
    Return default_value

Note: Room Database implementation
Process called "create_room_database" that takes database_name as String and version as Integer returns RoomDatabase:
    Return RoomDatabase with:
        database_name as database_name
        version as version
        entities as list
        dao_interfaces as list

Process called "add_entity_to_database" that takes database as RoomDatabase and entity as RoomEntity:
    Add entity to database.entities
    generate_table_schema with entity as entity and database as database

Process called "create_room_entity" that takes table_name as String and primary_key as String returns RoomEntity:
    Return RoomEntity with:
        table_name as table_name
        fields as dictionary
        primary_key as primary_key
        indices as list

Process called "add_field_to_entity" that takes entity as RoomEntity and field_name as String and field_type as String:
    Set entity.fields[field_name] to field_type

Process called "create_room_dao" that takes dao_name as String and entity_type as String returns RoomDao:
    Return RoomDao with:
        dao_name as dao_name
        queries as dictionary
        entity_type as entity_type

Process called "add_query_to_dao" that takes dao as RoomDao and query_name as String and sql_query as String:
    Set dao.queries[query_name] to sql_query

Note: Permission management
Process called "create_permission_manager" returns PermissionManager:
    Return PermissionManager with:
        required_permissions as list
        runtime_permissions as list
        permission_callbacks as dictionary

Process called "add_required_permission" that takes permission_manager as PermissionManager and permission_name as String:
    Let permission be AndroidPermission with:
        permission_name as permission_name
        permission_level as "normal"
        is_granted as false
        rationale_message as ""
    Add permission to permission_manager.required_permissions

Process called "request_runtime_permission" that takes permission_manager as PermissionManager and permission_name as String and rationale as String:
    Let permission be AndroidPermission with:
        permission_name as permission_name
        permission_level as "dangerous"
        is_granted as false
        rationale_message as rationale
    Add permission to permission_manager.runtime_permissions
    show_permission_request_dialog with permission as permission

Process called "check_permission_granted" that takes permission_name as String returns Boolean:
    Return query_system_permission with permission as permission_name

Process called "handle_permission_result" that takes permission_manager as PermissionManager and permission_name as String and granted as Boolean:
    For each permission in permission_manager.runtime_permissions:
        If permission.permission_name is equal to permission_name:
            Set permission.is_granted to granted
    If permission_name in permission_manager.permission_callbacks:
        Let callback be permission_manager.permission_callbacks[permission_name]
        execute_permission_callback with callback as callback and granted as granted

Note: ViewModel and LiveData implementation
Process called "create_view_model" that takes name as String returns AndroidViewModel:
    Return AndroidViewModel with:
        view_model_name as name
        live_data_fields as dictionary
        repository as create_repository with name as name followed by "Repository"

Process called "add_live_data_field" that takes view_model as AndroidViewModel and field_name as String and data_type as String:
    Let live_data be AndroidLiveData with:
        data_type as data_type
        current_value as None
        observers as list
    Set view_model.live_data_fields[field_name] to live_data

Process called "update_live_data" that takes view_model as AndroidViewModel and field_name as String and new_value as Any:
    If field_name in view_model.live_data_fields:
        Let live_data be view_model.live_data_fields[field_name]
        Set live_data.current_value to new_value
        notify_live_data_observers with live_data as live_data and value as new_value

Process called "observe_live_data" that takes view_model as AndroidViewModel and field_name as String and observer_id as String:
    If field_name in view_model.live_data_fields:
        Let live_data be view_model.live_data_fields[field_name]
        Add observer_id to live_data.observers

Note: Repository pattern implementation
Process called "create_repository" that takes name as String returns AndroidRepository:
    Return AndroidRepository with:
        repository_name as name
        data_sources as list
        cache_policies as dictionary

Process called "add_data_source" that takes repository as AndroidRepository and data_source as AndroidDataSource:
    Add data_source to repository.data_sources

Type called "AndroidDataSource":
    source_name as String
    source_type as String
    connection_config as Dictionary[String, Any]
    is_connected as Boolean

Process called "create_network_data_source" that takes base_url as String returns AndroidDataSource:
    Return AndroidDataSource with:
        source_name as "NetworkDataSource"
        source_type as "network"
        connection_config as dictionary with "base_url" as base_url and "timeout" as 30
        is_connected as false

Process called "create_local_data_source" that takes database as RoomDatabase returns AndroidDataSource:
    Return AndroidDataSource with:
        source_name as "LocalDataSource"
        source_type as "database"
        connection_config as dictionary with "database" as database
        is_connected as false

Note: Background task scheduling with WorkManager
Type called "AndroidWorkRequest":
    work_name as String
    work_type as String
    constraints as AndroidWorkConstraints
    input_data as Dictionary[String, Any]
    is_scheduled as Boolean

Type called "AndroidWorkConstraints":
    requires_network as Boolean
    requires_charging as Boolean
    requires_battery_not_low as Boolean
    required_network_type as String

Process called "create_work_request" that takes work_name as String and work_type as String returns AndroidWorkRequest:
    Return AndroidWorkRequest with:
        work_name as work_name
        work_type as work_type
        constraints as AndroidWorkConstraints with requires_network as false and requires_charging as false and requires_battery_not_low as false and required_network_type as "none"
        input_data as dictionary
        is_scheduled as false

Process called "schedule_work" that takes work_request as AndroidWorkRequest:
    validate_work_constraints with work_request as work_request
    Set work_request.is_scheduled to true
    enqueue_work_with_system with work_request as work_request

Process called "cancel_work" that takes work_name as String:
    cancel_system_work with name as work_name

Note: Network operations
Process called "create_http_client" returns Dictionary[String, Any]:
    Return dictionary with:
        "client_type" as "okhttp"
        "timeout_seconds" as 30
        "follow_redirects" as true
        "cache_enabled" as true

Process called "make_get_request" that takes url as String and headers as Dictionary[String, String] returns Dictionary[String, Any]:
    Let client be create_http_client()
    Return execute_http_request with client as client and method as "GET" and url as url and headers as headers and body as ""

Process called "make_post_request" that takes url as String and headers as Dictionary[String, String] and body as String returns Dictionary[String, Any]:
    Let client be create_http_client()
    Return execute_http_request with client as client and method as "POST" and url as url and headers as headers and body as body

Process called "download_file" that takes url as String and file_path as String returns Boolean:
    Let response be make_get_request with url as url and headers as dictionary
    If response["status_code"] as Integer is equal to 200:
        save_response_to_file with response as response and path as file_path
        Return true
    Return false

Note: Testing framework integration
Type called "AndroidTestSuite":
    test_type as String
    test_cases as List[AndroidTestCase]
    test_runner as String

Type called "AndroidTestCase":
    test_name as String
    test_method as String
    expected_result as Any
    actual_result as Any
    test_status as String

Process called "create_unit_test_suite" returns AndroidTestSuite:
    Return AndroidTestSuite with:
        test_type as "unit"
        test_cases as list
        test_runner as "junit"

Process called "create_instrumentation_test_suite" returns AndroidTestSuite:
    Return AndroidTestSuite with:
        test_type as "instrumentation"
        test_cases as list
        test_runner as "espresso"

Process called "add_test_case" that takes test_suite as AndroidTestSuite and test_name as String and test_method as String:
    Let test_case be AndroidTestCase with:
        test_name as test_name
        test_method as test_method
        expected_result as None
        actual_result as None
        test_status as "pending"
    Add test_case to test_suite.test_cases

Process called "run_test_suite" that takes test_suite as AndroidTestSuite returns Dictionary[String, Any]:
    Let results be dictionary with:
        "total_tests" as Collections.List.length with lst as test_suite.test_cases
        "passed" as 0
        "failed" as 0
        "errors" as list
    For each test_case in test_suite.test_cases:
        Let test_result be execute_test_case with test_case as test_case and runner as test_suite.test_runner
        If test_result.passed:
            Set results["passed"] to results["passed"] as Integer + 1
        Otherwise:
            Set results["failed"] to results["failed"] as Integer + 1
            Add test_result.error_message to results["errors"] as List[String]
    Return results

Note: Utility functions
Process called "initialize_activity_views" that takes activity as AndroidActivity:
    Note: Would inflate layout and initialize views
    setup_activity_ui with activity as activity

Process called "setup_event_listeners" that takes activity as AndroidActivity:
    Note: Would set up click listeners and other event handlers
    configure_activity_interactions with activity as activity

Process called "request_required_permissions" that takes activity as AndroidActivity:
    For each permission in activity.permissions_requested:
        If not check_permission_granted with permission_name as permission:
            show_permission_request_dialog_for_activity with activity as activity and permission as permission

Process called "save_preferences_to_storage" that takes preferences as SharedPreferences:
    Note: Would persist preferences to Android SharedPreferences storage
    persist_preferences_data with preferences as preferences

Process called "load_preferences_from_storage" that takes name as String returns Dictionary[String, Any]:
    Note: Would load preferences from Android SharedPreferences storage
    Return dictionary

Process called "query_system_permission" that takes permission as String returns Boolean:
    Note: Would check with Android system if permission is granted
    Return true

Process called "execute_permission_callback" that takes callback as String and granted as Boolean:
    Note: Would execute the registered callback function
    invoke_callback_function with callback as callback and result as granted

Process called "execute_http_request" that takes client as Dictionary[String, Any] and method as String and url as String and headers as Dictionary[String, String] and body as String returns Dictionary[String, Any]:
    Note: Would execute HTTP request using OkHttp
    Return dictionary with:
        "status_code" as 200
        "body" as ""
        "headers" as dictionary

Process called "execute_test_case" that takes test_case as AndroidTestCase and runner as String returns Dictionary[String, Any]:
    Note: Would execute individual test case
    Return dictionary with:
        "passed" as true
        "error_message" as ""

Process called "notify_live_data_observers" that takes live_data as AndroidLiveData and value as Any:
    Note: Would notify all registered observers of data change
    For each observer_id in live_data.observers:
        notify_observer with observer_id as observer_id and new_value as value

Process called "enqueue_work_with_system" that takes work_request as AndroidWorkRequest:
    Note: Would schedule work with Android WorkManager
    schedule_system_background_work with work_request as work_request