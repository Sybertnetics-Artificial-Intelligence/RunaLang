Note:
Runa Standard Library: Cross-Platform Notifications

Production-grade notification system providing comprehensive push notifications,
local notifications, and messaging capabilities across mobile platforms.

Features:
- Cross-platform push notifications (Firebase Cloud Messaging, Apple Push Notification Service)
- Local notifications with scheduling and triggers
- Rich notifications with images, actions, and custom UI
- Notification channels and categories for organization
- Background notification handling
- Interactive notification actions and replies
- Notification badges and sound management
- Deep linking from notification taps
- Notification analytics and tracking
- In-app messaging and banners
- Silent notifications for data sync
- Geofence-triggered notifications
- Time-based notification scheduling
- Notification permission management
- Custom notification templates and styling
:End Note

Import "../../collections" as Collections
Import "../../datetime" as DateTime
Import "../../string" as String

Note: Core notification types
Type called "NotificationManager":
    manager_id as String
    is_initialized as Boolean
    permission_status as String
    notification_channels as List[NotificationChannel]
    pending_notifications as List[PendingNotification]
    delivered_notifications as List[DeliveredNotification]
    token_callbacks as Dictionary[String, String]

Type called "NotificationChannel":
    channel_id as String
    channel_name as String
    description as String
    importance as String
    enable_lights as Boolean
    light_color as String
    enable_vibration as Boolean
    vibration_pattern as List[Integer]
    sound_uri as String
    bypass_dnd as Boolean

Type called "Notification":
    notification_id as String
    title as String
    body as String
    channel_id as String
    priority as String
    sound as String
    vibrate as List[Integer]
    lights as NotificationLights
    large_icon as String
    big_picture as String
    actions as List[NotificationAction]
    custom_data as Dictionary[String, Any]
    group as String
    sort_key as String
    when_timestamp as Integer
    show_timestamp as Boolean
    auto_cancel as Boolean
    ongoing as Boolean
    only_alert_once as Boolean

Type called "NotificationLights":
    enabled as Boolean
    color as String
    on_time as Integer
    off_time as Integer

Type called "NotificationAction":
    action_id as String
    title as String
    icon as String
    action_type as String
    requires_authentication as Boolean
    allows_generated_replies as Boolean
    remote_input as NotificationRemoteInput

Type called "NotificationRemoteInput":
    result_key as String
    label as String
    choices as List[String]
    allow_free_form_input as Boolean

Note: Scheduling and triggers
Type called "NotificationScheduler":
    scheduler_id as String
    scheduled_notifications as List[ScheduledNotification]
    recurring_notifications as List[RecurringNotification]
    is_active as Boolean

Type called "ScheduledNotification":
    schedule_id as String
    notification as Notification
    trigger_time as DateTime.DateTime
    is_scheduled as Boolean
    is_delivered as Boolean

Type called "RecurringNotification":
    recurrence_id as String
    notification as Notification
    recurrence_pattern as RecurrencePattern
    is_active as Boolean
    last_delivered as DateTime.DateTime
    next_delivery as DateTime.DateTime

Type called "RecurrencePattern":
    pattern_type as String
    interval_value as Integer
    interval_unit as String
    days_of_week as List[String]
    days_of_month as List[Integer]
    months as List[String]
    end_date as DateTime.DateTime
    max_occurrences as Integer

Note: Push notification types
Type called "PushNotificationService":
    service_type as String
    app_token as String
    server_key as String
    is_registered as Boolean
    topics as List[String]
    user_segments as List[String]

Type called "PushMessage":
    message_id as String
    from_sender as String
    to_recipient as String
    notification_payload as Notification
    data_payload as Dictionary[String, String]
    message_type as String
    time_to_live as Integer
    collapse_key as String
    priority as String

Type called "PushToken":
    token as String
    platform as String
    app_id as String
    user_id as String
    created_at as DateTime.DateTime
    last_refreshed as DateTime.DateTime
    is_valid as Boolean

Note: In-app messaging
Type called "InAppMessage":
    message_id as String
    message_type as String
    title as String
    body as String
    image_url as String
    action_url as String
    background_color as String
    text_color as String
    display_duration as Integer
