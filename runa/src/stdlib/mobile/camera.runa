Note:
Runa Standard Library: Cross-Platform Camera

Production-grade camera system providing comprehensive photography
and video capture capabilities across mobile platforms.

Features:
- Cross-platform camera API (Android CameraX, iOS AVFoundation)
- Photo capture with advanced controls (exposure, focus, ISO, white balance)
- Video recording with multiple quality settings
- Real-time camera preview with overlay support - Face detection and recognition
- Barcode/QR code scanning
- Image processing and filters
- Camera permissions management
- Flash and torch control
- Front/back camera switching
- Zoom controls and gesture support
- HDR and RAW capture support
- Live photo and burst mode capabilities
- Camera metadata extraction (EXIF data)
- Custom camera UI components
:End Note

Import "../../collections" as Collections
Import "../../datetime" as DateTime
Import "../../string" as String

Note: Core camera types
Type called "CameraDevice":
    device_id as String
    device_name as String
    facing_direction as String
    supported_resolutions as List[CameraResolution]
    supported_formats as List[String]
    has_flash as Boolean
    has_torch as Boolean
    zoom_capabilities as CameraZoom
    focus_capabilities as CameraFocus
    exposure_capabilities as CameraExposure

Type called "CameraResolution":
    width as Integer
    height as Integer
    aspect_ratio as String
    megapixels as Float

Type called "CameraZoom":
    min_zoom as Float
    max_zoom as Float
    supports_smooth_zoom as Boolean
    zoom_ratios as List[Float]

Type called "CameraFocus":
    supports_auto_focus as Boolean
    supports_manual_focus as Boolean
    focus_modes as List[String]
    focus_areas as List[CameraFocusArea]

Type called "CameraFocusArea":
    x as Float
    y as Float
    weight as Integer

Type called "CameraExposure":
    min_exposure as Integer
    max_exposure as Integer
    exposure_step as Float
    supports_auto_exposure as Boolean
    metering_modes as List[String]

Note: Camera session and preview
Type called "CameraSession":
    session_id as String
    camera_device as CameraDevice
    preview_surface as CameraSurface
    capture_surface as CameraSurface
    session_state as String
    is_recording as Boolean
    current_settings as CameraSettings

Type called "CameraSurface":
    surface_id as String
    surface_type as String
    dimensions as CameraResolution
    format as String

Type called "CameraSettings":
    resolution as CameraResolution
    format as String
    quality as String
    flash_mode as String
    focus_mode as String
    exposure_compensation as Integer
    iso_value as Integer
    white_balance as String
    scene_mode as String

