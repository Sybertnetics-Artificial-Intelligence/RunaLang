Note:
Runa Standard Library: Signal Handling and Management

Production-grade signal handling providing comprehensive signal management,
inter-process communication through signals, and cross-platform signal
operations with advanced features for robust application design.

Features:
- Cross-platform signal handling (Unix signals/Windows events)
- Custom signal handlers with context preservation
- Signal masking and blocking mechanisms
- Signal queuing and delivery management
- Real-time signal support with priority handling
- Signal-based inter-process communication
- Asynchronous signal handling with thread safety
- Signal handler chain management
- Signal debugging and diagnostic tools
- Process group signal broadcasting
- Signal-safe function execution
- Emergency signal handling for crash recovery
:End Note

Import "collections" as Collections
Import "string" as String
Import "datetime" as DateTime
Import "os/os" as OS

Note: Signal types and structures
Type called "SignalInfo":
    signal_number as Integer
    signal_name as String
    description as String
    default_action as SignalAction
    can_be_caught as Boolean
    can_be_ignored as Boolean
    can_be_blocked as Boolean
    is_real_time as Boolean
    priority as Integer

Type SignalAction is:
    | Terminate
    | TerminateCore
    | Stop
    | Continue
    | Ignore
    | Custom

Type called "SignalHandler":
    handler_id as String
    signal_number as Integer
    handler_function as String
    is_active as Boolean
    is_one_shot as Boolean
    priority as Integer
    execution_context as SignalContext
    registration_time as DateTime.DateTime
    invocation_count as Integer

Type called "SignalContext":
    sender_pid as Integer
    sender_uid as Integer
    signal_value as Integer
    timestamp as DateTime.DateTime
    stack_pointer as Integer
    instruction_pointer as Integer
    error_code as Integer
    fault_address as Integer
    additional_info as Dictionary[String, Any]

Type called "SignalMask":
    blocked_signals as List[Integer]
    pending_signals as List[Integer]
    is_active as Boolean
    mask_scope as MaskScope

Type MaskScope is:
    | Process
    | Thread
    | ProcessGroup

Type called "SignalQueue":
    queue_id as String
    max_size as Integer
    current_size as Integer
    signals as List[QueuedSignal]
    overflow_action as OverflowAction
    priority_queue as Boolean

Type OverflowAction is:
    | Drop
    | Block
    | Replace

Type called "QueuedSignal":
    signal_number as Integer
    context as SignalContext
    queue_time as DateTime.DateTime
    priority as Integer
    delivery_attempts as Integer
    max_delivery_attempts as Integer

Type called "SignalDispatcher":
    dispatcher_id as String
    is_active as Boolean
    handler_chain as List[SignalHandler]
    signal_masks as List[SignalMask]
    signal_queue as SignalQueue
    default_handlers as Dictionary[Integer, String]
    emergency_handler as String

Type SignalDeliveryMode is:
    | Synchronous
    | Asynchronous
    | Queued
    | RealTime

Type called "SignalStatistics":
    signals_sent as Integer
    signals_received as Integer
    signals_handled as Integer
    signals_blocked as Integer
    signals_ignored as Integer
    handler_failures as Integer
    last_signal_time as DateTime.DateTime
    most_frequent_signal as Integer

Note: Standard signal definitions
Process called "get_signal_info" that takes signal_number as Integer returns SignalInfo:
    Match signal_number:
    When 1:
    Return create_signal_info with number as 1 and name as "SIGHUP" and description as "Hangup" and action as Terminate
    When 2:
    Return create_signal_info with number as 2 and name as "SIGINT" and description as "Interrupt" and action as Terminate
    When 3:
    Return create_signal_info with number as 3 and name as "SIGQUIT" and description as "Quit" and action as TerminateCore
    When 9:
    Return create_signal_info with number as 9 and name as "SIGKILL" and description as "Kill" and action as Terminate
    When 11:
    Return create_signal_info with number as 11 and name as "SIGSEGV" and description as "Segmentation violation" and action as TerminateCore
    When 15:
    Return create_signal_info with number as 15 and name as "SIGTERM" and description as "Termination" and action as Terminate
    When 17:
    Return create_signal_info with number as 17 and name as "SIGCHLD" and description as "Child status changed" and action as Ignore
    When 18:
    Return create_signal_info with number as 18 and name as "SIGCONT" and description as "Continue" and action as Continue
    When 19:
    Return create_signal_info with number as 19 and name as "SIGSTOP" and description as "Stop" and action as Stop
    When 20:
    Return create_signal_info with number as 20 and name as "SIGTSTP" and description as "Terminal stop" and action as Stop
    When 30:
    Return create_signal_info with number as 30 and name as "SIGUSR1" and description as "User-defined signal 1" and action as Terminate
    When 31:
    Return create_signal_info with number as 31 and name as "SIGUSR2" and description as "User-defined signal 2" and action as Terminate
    Otherwise:
    Return create_unknown_signal_info with number as signal_number

Process called "get_signal_number" that takes signal_name as String returns Integer:
    Match signal_name:
    When "SIGHUP":
    Return 1
    When "SIGINT":
    Return 2
    When "SIGQUIT":
    Return 3
    When "SIGKILL":
    Return 9
    When "SIGSEGV":
    Return 11
    When "SIGTERM":
    Return 15
    When "SIGCHLD":
    Return 17
    When "SIGCONT":
    Return 18
    When "SIGSTOP":
    Return 19
    When "SIGTSTP":
    Return 20
    When "SIGUSR1":
    Return 30
    When "SIGUSR2":
    Return 31
    Otherwise:
    Return -1

Process called "get_all_supported_signals" returns List[SignalInfo]:
    Let signals be list Add get_signal_info with signal_number as 1 to signals
    Add get_signal_info with signal_number as 2 to signals
    Add get_signal_info with signal_number as 3 to signals
    Add get_signal_info with signal_number as 9 to signals
    Add get_signal_info with signal_number as 11 to signals
    Add get_signal_info with signal_number as 15 to signals
    Add get_signal_info with signal_number as 17 to signals
    Add get_signal_info with signal_number as 18 to signals
    Add get_signal_info with signal_number as 19 to signals
    Add get_signal_info with signal_number as 20 to signals
    Add get_signal_info with signal_number as 30 to signals
    Add get_signal_info with signal_number as 31 to signals Return signals

Note: Signal handler management
Process called "register_signal_handler" that takes signal_number as Integer and handler_function as String returns SignalHandler:
    Let signal_info be get_signal_info with signal_number as signal_number If not signal_info.can_be_caught:
    Return create_invalid_signal_handler() Let validation_result be validate_signal_handler_security with signal_number as signal_number and handler as handler_function
    If not validation_result:
    Return create_invalid_signal_handler() Return SignalHandler with:
    handler_id as generate_signal_handler_id()
    signal_number as signal_number
    handler_function as handler_function
    is_active as true
    is_one_shot as false
    priority as 0
    execution_context as create_default_signal_context()
    registration_time as DateTime.now()
    invocation_count as 0

Process called "unregister_signal_handler" that takes handler as SignalHandler returns Boolean:
    If not handler.is_active:
    Return false Set handler.is_active to false Note: In real implementation, would restore default signal handling
    Return true

Process called "register_one_shot_handler" that takes signal_number as Integer and handler_function as String returns SignalHandler:
    Let handler be register_signal_handler with signal_number as signal_number and handler_function as handler_function
    Set handler.is_one_shot to true Return handler

Process called "set_signal_handler_priority" that takes handler as SignalHandler and priority as Integer returns Boolean:
    If not handler.is_active:
    Return false Set handler.priority to priority
    Return true

Process called "ignore_signal" that takes signal_number as Integer returns Boolean:
    Let signal_info be get_signal_info with signal_number as signal_number If not signal_info.can_be_ignored:
    Return false Note: In real implementation, would set signal to SIG_IGN
    Return true

Process called "restore_default_signal_handler" that takes signal_number as Integer returns Boolean:
    Let signal_info be get_signal_info with signal_number as signal_number Note: In real implementation, would set signal to SIG_DFL
    Return true

Note: Signal sending and delivery
Process called "send_signal" that takes target_pid as Integer and signal_number as Integer returns Boolean:
    Let signal_info be get_signal_info with signal_number as signal_number
    Let target_exists be process_exists with pid as target_pid If not target_exists:
    Return false Let security_check be validate_signal_send_permission with target_pid as target_pid and signal_number as signal_number
    If not security_check:
    Return false Note: In real implementation, would use kill() system call
    Return simulate_signal_delivery with target_pid as target_pid and signal_number as signal_number

Process called "send_signal_with_value" that takes target_pid as Integer and signal_number as Integer and value as Integer returns Boolean:
    Let signal_info be get_signal_info with signal_number as signal_number If not signal_info.is_real_time:
    Return send_signal with target_pid as target_pid and signal_number as signal_number Let context be SignalContext with:
    sender_pid as OS.get_current_process_id()
    sender_uid as get_current_user_id()
    signal_value as value
    timestamp as DateTime.now()
    stack_pointer as 0
    instruction_pointer as 0
    error_code as 0
    fault_address as 0
    additional_info as dictionary Return simulate_signal_delivery_with_context with target_pid as target_pid and signal_number as signal_number and context as context

Process called "send_signal_to_process_group" that takes group_id as Integer and signal_number as Integer returns Boolean:
    Let group_processes be get_processes_in_group with group_id as group_id
    Let success_count be 0 For each pid in group_processes:
    Let send_result be send_signal with target_pid as pid and signal_number as signal_number
    If send_result:
    Set success_count to success_count 1 Return success_count is greater than 0

Process called "broadcast_signal" that takes signal_number as Integer returns Boolean:
    Note: Send signal to all processes the current process can signal
    Let all_processes be get_signalable_processes()
    Let success_count be 0 For each pid in all_processes:
    Let send_result be send_signal with target_pid as pid and signal_number as signal_number
    If send_result:
    Set success_count to success_count 1 Return success_count is greater than 0

Process called "queue_signal" that takes target_pid as Integer and signal_number as Integer and context as SignalContext returns Boolean:
    Let queue be get_signal_queue_for_process with pid as target_pid If queue.current_size is greater than or equal to queue.max_size:
    Match queue.overflow_action:
    When Drop:
    Return false
    When Block:
    Return wait_for_queue_space with queue as queue
    When Replace:
    remove_oldest_queued_signal with queue as queue Let queued_signal be QueuedSignal with:
    signal_number as signal_number
    context as context
    queue_time as DateTime.now()
    priority as calculate_signal_priority with signal_number as signal_number
    delivery_attempts as 0
    max_delivery_attempts as 3 Add queued_signal to queue.signals
    Set queue.current_size to queue.current_size 1 Return true

Note: Signal masking and blocking
Process called "create_signal_mask" that takes signal_numbers as List[Integer] and scope as MaskScope returns SignalMask:
    Let valid_signals be list For each signal_number in signal_numbers:
    Let signal_info be get_signal_info with signal_number as signal_number
    If signal_info.can_be_blocked:
    Add signal_number to valid_signals Return SignalMask with:
    blocked_signals as valid_signals
    pending_signals as list
    is_active as false
    mask_scope as scope

Process called "apply_signal_mask" that takes mask as SignalMask returns Boolean:
    If mask.is_active:
    Return false Let security_check be validate_signal_mask_security with mask as mask
    If not security_check:
    Return false Set mask.is_active to true Note: In real implementation, would use sigprocmask() or equivalent
    Return true

Process called "remove_signal_mask" that takes mask as SignalMask returns Boolean:
    If not mask.is_active:
    Return false Set mask.is_active to false
    Clear mask.blocked_signals
    Clear mask.pending_signals Return true

Process called "add_signal_to_mask" that takes mask as SignalMask and signal_number as Integer returns Boolean:
    Let signal_info be get_signal_info with signal_number as signal_number If not signal_info.can_be_blocked:
    Return false If signal_number not in mask.blocked_signals:
    Add signal_number to mask.blocked_signals Return true

Process called "remove_signal_from_mask" that takes mask as SignalMask and signal_number as Integer returns Boolean:
    If signal_number in mask.blocked_signals:
    Remove signal_number from mask.blocked_signals
    Return true Return false

Process called "get_pending_signals" that takes mask as SignalMask returns List[Integer]:
    Return mask.pending_signals

Process called "clear_pending_signals" that takes mask as SignalMask returns Boolean:
    Clear mask.pending_signals
    Return true

Note: Real-time signal management
Process called "create_realtime_signal" that takes signal_number as Integer and priority as Integer returns SignalInfo:
    If signal_number is less than 32 or signal_number is greater than 63:
    Return create_unknown_signal_info with number as signal_number Return SignalInfo with:
    signal_number as signal_number
    signal_name as "SIGRT" followed by String.from with value as signal_number - 32
    description as "Real-time signal " followed by String.from with value as signal_number - 32
    default_action as Terminate
    can_be_caught as true
    can_be_ignored as true
    can_be_blocked as true
    is_real_time as true
    priority as priority

Process called "send_realtime_signal" that takes target_pid as Integer and signal_number as Integer and priority as Integer and payload as String returns Boolean:
    If signal_number is less than 32 or signal_number is greater than 63:
    Return false Let context be SignalContext with:
    sender_pid as OS.get_current_process_id()
    sender_uid as get_current_user_id()
    signal_value as 0
    timestamp as DateTime.now()
    stack_pointer as 0
    instruction_pointer as 0
    error_code as 0
    fault_address as 0
    additional_info as dictionary Set context.additional_info["payload"] to payload
    Set context.additional_info["priority"] to priority Return queue_signal with target_pid as target_pid and signal_number as signal_number and context as context

Process called "register_realtime_handler" that takes signal_number as Integer and priority as Integer and handler_function as String returns SignalHandler:
    If signal_number is less than 32 or signal_number is greater than 63:
    Return create_invalid_signal_handler() Let handler be register_signal_handler with signal_number as signal_number and handler_function as handler_function
    Set handler.priority to priority Return handler

Note: Signal dispatcher and queue management
Process called "create_signal_dispatcher" returns SignalDispatcher:
    Return SignalDispatcher with:
    dispatcher_id as generate_signal_dispatcher_id()
    is_active as false
    handler_chain as list
    signal_masks as list
    signal_queue as create_default_signal_queue()
    default_handlers as create_default_handler_map()
    emergency_handler as ""

Process called "start_signal_dispatcher" that takes dispatcher as SignalDispatcher returns Boolean:
    If dispatcher.is_active:
    Return false Set dispatcher.is_active to true Note: In real implementation, would start signal handling thread
    Return true

Process called "stop_signal_dispatcher" that takes dispatcher as SignalDispatcher returns Boolean:
    Set dispatcher.is_active to false
    Return true

Process called "add_handler_to_chain" that takes dispatcher as SignalDispatcher and handler as SignalHandler returns Boolean:
    If not handler.is_active:
    Return false Add handler to dispatcher.handler_chain
    sort_handler_chain_by_priority with chain as dispatcher.handler_chain Return true

Process called "remove_handler_from_chain" that takes dispatcher as SignalDispatcher and handler_id as String returns Boolean:
    Let updated_chain be list For each handler in dispatcher.handler_chain:
    If handler.handler_id is not equal to handler_id:
    Add handler to updated_chain Set dispatcher.handler_chain to updated_chain
    Return true

Process called "dispatch_signal" that takes dispatcher as SignalDispatcher and signal_number as Integer and context as SignalContext returns Boolean:
    If not dispatcher.is_active:
    Return false Let signal_info be get_signal_info with signal_number as signal_number
    Let handled be false Note: Try handlers in priority order
    For each handler in dispatcher.handler_chain:
    If handler.signal_number is equal to signal_number and handler.is_active:
    Let handler_result be invoke_signal_handler with handler as handler and context as context If handler_result:
    Set handled to true
    Set handler.invocation_count to handler.invocation_count 1 If handler.is_one_shot:
    Set handler.is_active to false Break Note: Use default handler if no custom handler succeeded
    If not handled:
    Return execute_default_signal_action with signal_info as signal_info and context as context Return handled

Note: Emergency and crash handling
Process called "register_emergency_signal_handler" that takes dispatcher as SignalDispatcher and handler_function as String returns Boolean:
    Set dispatcher.emergency_handler to handler_function
    Return true

Process called "handle_emergency_signal" that takes signal_number as Integer and context as SignalContext returns Boolean:
    Note: Emergency handling for critical signals (SIGSEGV, SIGBUS, etc.) Let emergency_info be create_emergency_context with signal_number as signal_number and context as context
    save_emergency_context with info as emergency_info Match signal_number:
    When 11: Note: SIGSEGV
    Return handle_segmentation_fault with context as context
    When 7: Note: SIGBUS
    Return handle_bus_error with context as context
    When 8: Note: SIGFPE
    Return handle_floating_point_exception with context as context
    When 4: Note: SIGILL
    Return handle_illegal_instruction with context as context
    Otherwise:
    Return handle_generic_emergency with signal_number as signal_number and context as context

Process called "install_crash_handler" returns Boolean:
    Let critical_signals be list containing 11, 7, 8, 4, 6 Note: SIGSEGV, SIGBUS, SIGFPE, SIGILL, SIGABRT For each signal_number in critical_signals:
    Let handler be register_signal_handler with signal_number as signal_number and handler_function as "emergency_crash_handler"
    If not handler.is_active:
    Return false Return true

Process called "generate_crash_report" that takes signal_number as Integer and context as SignalContext returns String:
    Let report be "CRASH REPORT\\n"
    Set report to report followed by "================\\n"
    Set report to report followed by "Signal: " followed by get_signal_info with signal_number as signal_number and ".signal_name" followed by "\\n"
    Set report to report followed by "PID: " followed by String.from with value as OS.get_current_process_id() followed by "\\n"
    Set report to report followed by "Time: " followed by String.from with value as context.timestamp.timestamp followed by "\\n"
    Set report to report followed by "Sender PID: " followed by String.from with value as context.sender_pid followed by "\\n"
    Set report to report followed by "Error Code: " followed by String.from with value as context.error_code followed by "\\n"
    If context.fault_address is not equal to 0:
    Set report to report followed by "Fault Address: 0x" followed by Integer.to_hex with value as context.fault_address followed by "\\n"
    Return report

Note: Signal statistics and monitoring
Process called "create_signal_statistics" returns SignalStatistics:
    Return SignalStatistics with:
    signals_sent as 0
    signals_received as 0
    signals_handled as 0
    signals_blocked as 0
    signals_ignored as 0
    handler_failures as 0
    last_signal_time as DateTime.now()
    most_frequent_signal as 15

Process called "update_signal_statistics" that takes stats as SignalStatistics and signal_number as Integer and action as String:
    Match action:
    When "sent":
    Set stats.signals_sent to stats.signals_sent 1
    When "received":
    Set stats.signals_received to stats.signals_received 1
    When "handled":
    Set stats.signals_handled to stats.signals_handled 1
    When "blocked":
    Set stats.signals_blocked to stats.signals_blocked 1
    When "ignored":
    Set stats.signals_ignored to stats.signals_ignored 1
    When "failed":
    Set stats.handler_failures to stats.handler_failures 1 Set stats.last_signal_time to DateTime.now()

Process called "get_signal_handler_statistics" that takes handler as SignalHandler returns Dictionary[String, Integer]:
    Let stats be dictionary
    Set stats["invocation_count"] to handler.invocation_count
    Set stats["registration_duration"] to Integer.from with value as DateTime.seconds_between with start as handler.registration_time and end as DateTime.now()
    Set stats["priority"] to handler.priority
    Set stats["signal_number"] to handler.signal_number Return stats

Note: Utility and helper functions
Process called "create_signal_info" that takes number as Integer and name as String and description as String and action as SignalAction returns SignalInfo:
    Return SignalInfo with:
    signal_number as number
    signal_name as name
    description as description
    default_action as action
    can_be_caught as action is not equal to Stop and number is not equal to 9 and number is not equal to 19
    can_be_ignored as action is not equal to Stop and number is not equal to 9 and number is not equal to 19 and number is not equal to 17
    can_be_blocked as number is not equal to 9 and number is not equal to 19
    is_real_time as number is greater than or equal to 32 and number is less than or equal to 63
    priority as calculate_signal_priority with signal_number as number

Process called "create_unknown_signal_info" that takes number as Integer returns SignalInfo:
    Return SignalInfo with:
    signal_number as number
    signal_name as "UNKNOWN"
    description as "Unknown signal"
    default_action as Terminate
    can_be_caught as true
    can_be_ignored as true
    can_be_blocked as true
    is_real_time as false
    priority as 0

Process called "create_invalid_signal_handler" returns SignalHandler:
    Return SignalHandler with:
    handler_id as "invalid"
    signal_number as -1
    handler_function as ""
    is_active as false
    is_one_shot as false
    priority as 0
    execution_context as create_default_signal_context()
    registration_time as DateTime.now()
    invocation_count as 0

Process called "create_default_signal_context" returns SignalContext:
    Return SignalContext with:
    sender_pid as 0
    sender_uid as 0
    signal_value as 0
    timestamp as DateTime.now()
    stack_pointer as 0
    instruction_pointer as 0
    error_code as 0
    fault_address as 0
    additional_info as dictionary

Process called "create_default_signal_queue" returns SignalQueue:
    Return SignalQueue with:
    queue_id as generate_signal_queue_id()
    max_size as 64
    current_size as 0
    signals as list
    overflow_action as Drop
    priority_queue as true

Process called "create_default_handler_map" returns Dictionary[Integer, String]:
    Let handlers be dictionary
    Set handlers[1] to "default_hangup_handler"
    Set handlers[2] to "default_interrupt_handler"
    Set handlers[15] to "default_terminate_handler"
    Set handlers[17] to "default_child_handler"
    Return handlers

Process called "generate_signal_handler_id" returns String:
    Return "handler_" followed by String.from with value as DateTime.now().timestamp

Process called "generate_signal_dispatcher_id" returns String:
    Return "dispatcher_" followed by String.from with value as DateTime.now().timestamp

Process called "generate_signal_queue_id" returns String:
    Return "queue_" followed by String.from with value as DateTime.now().timestamp

Process called "validate_signal_handler_security" that takes signal_number as Integer and handler as String returns Boolean:
    Note: Validate signal handler for security
    If handler is equal to "":
    Return false Note: Prevent dangerous signal handlers
    If String.contains with str as handler and substring as "system(" or String.contains with str as handler and substring as "exec(":
    Return false Return true

Process called "validate_signal_send_permission" that takes target_pid as Integer and signal_number as Integer returns Boolean:
    Note: Check if current process can send signal to target
    If target_pid is equal to OS.get_current_process_id():
    Return true Let current_uid be get_current_user_id()
    Let target_uid be get_process_user_id with pid as target_pid Return current_uid is equal to target_uid or current_uid is equal to 0

Process called "validate_signal_mask_security" that takes mask as SignalMask returns Boolean:
    Note: Ensure critical signals aren't blocked inappropriately
    For each signal_number in mask.blocked_signals:
    If signal_number is equal to 9 or signal_number is equal to 19: Note: SIGKILL, SIGSTOP
    Return false Return true

Process called "calculate_signal_priority" that takes signal_number as Integer returns Integer:
    Match signal_number:
    When 9: Note: SIGKILL
    Return 100
    When 11: Note: SIGSEGV
    Return 95
    When 15: Note: SIGTERM
    Return 50
    When 2: Note: SIGINT
    Return 40
    When 1: Note: SIGHUP
    Return 30
    Otherwise:
    If signal_number is greater than or equal to 32:
    Return signal_number - 32 10 Note: Real-time signals
    Return 10

Process called "process_exists" that takes pid as Integer returns Boolean:
    Note: Mock process existence check
    Return pid is greater than 0 and pid is less than 65536

Process called "get_current_user_id" returns Integer:
    Note: Mock UID retrieval
    Return 1000

Process called "get_process_user_id" that takes pid as Integer returns Integer:
    Note: Mock process UID retrieval
    Return 1000

Process called "get_processes_in_group" that takes group_id as Integer returns List[Integer]:
    Note: Mock process group membership
    Return list containing group_id 1, group_id 2, group_id 3

Process called "get_signalable_processes" returns List[Integer]:
    Note: Mock list of processes current process can signal
    Return list containing 1001, 1002, 1003, 1004, 1005

Process called "simulate_signal_delivery" that takes target_pid as Integer and signal_number as Integer returns Boolean:
    Note: Mock signal delivery
    Return process_exists with pid as target_pid

Process called "simulate_signal_delivery_with_context" that takes target_pid as Integer and signal_number as Integer and context as SignalContext returns Boolean:
    Note: Mock signal delivery with context
    Return process_exists with pid as target_pid

Process called "get_signal_queue_for_process" that takes pid as Integer returns SignalQueue:
    Note: Mock signal queue retrieval
    Return create_default_signal_queue()

Process called "wait_for_queue_space" that takes queue as SignalQueue returns Boolean:
    Note: Mock queue space waiting
    Return true

Process called "remove_oldest_queued_signal" that takes queue as SignalQueue:
    If queue.current_size is greater than 0:
    Remove first item from queue.signals
    Set queue.current_size to queue.current_size - 1

Process called "sort_handler_chain_by_priority" that takes chain as List[SignalHandler]:
    Note: Mock sorting by priority - in real implementation would sort the list

Process called "invoke_signal_handler" that takes handler as SignalHandler and context as SignalContext returns Boolean:
    Note: Mock signal handler invocation
    If handler.is_active:
    Return true
    Return false

Process called "execute_default_signal_action" that takes signal_info as SignalInfo and context as SignalContext returns Boolean:
    Match signal_info.default_action:
    When Terminate:
    Return true
    When TerminateCore:
    Return true
    When Stop:
    Return true
    When Continue:
    Return true
    When Ignore:
    Return true
    When Custom:
    Return false
    Otherwise:
    Return false

Process called "create_emergency_context" that takes signal_number as Integer and context as SignalContext returns Dictionary[String, Any]:
    Let info be dictionary
    Set info["signal_number"] to signal_number
    Set info["timestamp"] to context.timestamp
    Set info["sender_pid"] to context.sender_pid
    Set info["fault_address"] to context.fault_address
    Set info["error_code"] to context.error_code
    Return info

