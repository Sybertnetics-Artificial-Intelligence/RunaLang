    Return 12

Process called "detect_cpu_threads" returns Integer:
    Return 20

Process called "detect_cpu_base_frequency" returns Float:
    Return 3.6

Process called "detect_cpu_max_frequency" returns Float:
    Return 5.0

Process called "detect_cpu_cache_l1" returns Integer:
    Return 80

Process called "detect_cpu_cache_l2" returns Integer:
    Return 1280

Process called "detect_cpu_cache_l3" returns Integer:
    Return 25600

Process called "detect_cpu_instruction_sets" returns List[String]:
    Return list containing "MMX", "SSE", "SSE2", "SSE3", "SSSE3", "SSE4.1", "SSE4.2", "AVX", "AVX2", "AVX-512"

Process called "detect_cpu_features" returns List[String]:
    Return list containing "Hyper-Threading", "Turbo Boost", "VT-x", "AES-NI", "TSX"

Process called "detect_cpu_architecture" returns String:
    Return "x86_64"

Process called "detect_cpu_vendor" that takes brand as String returns String:
    If String.contains with str as brand and substring as "Intel":
    Return "Intel"
    If String.contains with str as brand and substring as "AMD":
    Return "AMD"
    If String.contains with str as brand and substring as "ARM":
    Return "ARM"
    Return "Unknown"

Process called "detect_total_physical_memory" returns Integer:
    Return 16777216000

Process called "detect_available_physical_memory" returns Integer:
    Return 8388608000

Process called "detect_total_virtual_memory" returns Integer:
    Return 33554432000

Process called "detect_available_virtual_memory" returns Integer:
    Return 25165824000

Process called "detect_memory_page_size" returns Integer:
    Return 4096

Process called "detect_memory_speed" returns Integer:
    Return 3200

Process called "detect_memory_type" returns String:
    Return "DDR4"

Process called "detect_memory_ecc_support" returns Boolean:
    Return false

Process called "create_storage_device" that takes name as String and device_type as StorageType and capacity as Integer returns StorageDevice:
    Return StorageDevice with:
    name as name
    device_type as device_type
    capacity as capacity
    available_space as capacity divided by 2
    file_system as detect_file_system_for_device with name as name
    interface_type as detect_interface_for_device_type with device_type as device_type
    is_removable as false
    is_system_drive as name is equal to "C:" or name is equal to "/"
    health_status as "Good"

Process called "create_network_adapter" that takes name as String and adapter_type as NetworkType and speed as Integer returns NetworkAdapter:
    Return NetworkAdapter with:
    name as name
    adapter_type as adapter_type
    mac_address as generate_mock_mac_address()
    ip_addresses as generate_mock_ip_addresses()
    speed as speed
    is_connected as adapter_type is not equal to Loopback
    is_wireless as adapter_type is WiFi
    supports_ipv6 as true

Process called "create_graphics_device" that takes name as String and vendor as String and memory as Integer returns GraphicsDevice:
    Return GraphicsDevice with:
    name as name
    vendor as vendor
    memory as memory
    driver_version as "30.0.100.9805"
    supports_vulkan as true
    supports_directx as true
    supports_opengl as true
    max_resolution as Resolution with:
    width as 3840
    height as 2160
    refresh_rate as 60
    color_depth as 32

Process called "create_audio_device" that takes name as String and device_type as AudioType returns AudioDevice:
    Return AudioDevice with:
    name as name
    device_type as device_type
    channels as 2
    sample_rate as 48000
    bit_depth as 24
    is_default as device_type is Speaker

Process called "create_sensor" that takes name as String and sensor_type as SensorType and current_value as Float returns Sensor:
    Return Sensor with:
    name as name
    sensor_type as sensor_type
    current_value as current_value
    unit as get_sensor_unit with sensor_type as sensor_type
    min_value as 0.0
    max_value as get_sensor_max_value with sensor_type as sensor_type

Process called "detect_file_system_for_device" that takes name as String returns String:
    If String.contains with str as name and substring as "C:":
    Return "NTFS"
    If String.starts_with with str as name and prefix as "/":
    Return "ext4"
    Return "Unknown"

Process called "detect_interface_for_device_type" that takes device_type as StorageType returns String:
    Match device_type:
    When NVMe:
    Return "NVMe"
    When SSD:
    Return "SATA"
    When HDD:
    Return "SATA"
    Otherwise:
    Return "Unknown"

Process called "generate_mock_mac_address" returns String:
    Return "00:1B:44:11:3A:B7"

Process called "generate_mock_ip_addresses" returns List[String]:
    Return list containing "192.168.1.100", "fe80::1b44:1100:3a00:b700"

Process called "get_sensor_unit" that takes sensor_type as SensorType returns String:
    Match sensor_type:
    When Temperature:
    Return "°C"
    When Humidity:
    Return "%"
    When Pressure:
    Return "RPM"
    When Light:
    Return "lux"
    Otherwise:
    Return ""

Process called "get_sensor_max_value" that takes sensor_type as SensorType returns Float:
    Match sensor_type:
    When Temperature:
    Return 100.0
    When Humidity:
    Return 100.0
    When Pressure:
    Return 5000.0
    When Light:
    Return 10000.0
    Otherwise:
    Return 1000.0

