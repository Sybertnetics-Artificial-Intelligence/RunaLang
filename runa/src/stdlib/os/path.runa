Note:
Runa Standard Library: Cross-Platform Path Manipulation

Production-grade path manipulation providing comprehensive cross-platform
file system path operations with Unicode support, security validation,
and advanced path analysis for enterprise applications.

Features:
- Cross-platform path handling (Windows/Unix/macOS)
- Path normalization and canonicalization
- Path component manipulation (basename, dirname, extension)
- Relative and absolute path conversion
- Path joining with proper separator handling
- Glob pattern matching and path expansion
- Path traversal security validation
- Unicode and internationalization support
- Path comparison and matching
- Temporary path generation
- Path resolution and symbolic link handling
- Advanced path analysis and validation
- Path templating and substitution
:End Note

Import "../../collections" as Collections
Import "../../string" as String
Import "../../datetime" as DateTime
Import "os/os" as OS

Note: Path types and structures
Type called "PathInfo":
    original_path as String
    normalized_path as String
    absolute_path as String
    components as List[String]
    drive as String
    root as String
    parent as String
    name as String
    stem as String
    suffix as String
    suffixes as List[String]
    is_absolute as Boolean
    is_relative as Boolean
    exists as Boolean
    is_file as Boolean
    is_directory as Boolean

Type PathSeparator is:
    | Unix
    | Windows
    | Current

Type PathType is:
    | Absolute
    | Relative
    | Drive
    | UNC
    | URI

Type called "PathPattern":
    pattern as String
    case_sensitive as Boolean
    recursive as Boolean
    include_hidden as Boolean
    exclude_patterns as List[String]

Type called "PathTemplate":
    template_string as String
    variables as Dictionary[String, String]
    default_values as Dictionary[String, String]
    required_variables as List[String]

Note: Core path operations
Process called "join_paths" that takes base as String and component as String returns String:
    If base is equal to "":
        Return component
    If component is equal to "":
        Return base
    Let separator be get_path_separator_for_platform()
    Let normalized_base be ensure_trailing_separator_removed with path as base
    Let normalized_component be ensure_leading_separator_removed with path as component
    Return normalized_base followed by separator followed by normalized_component

Process called "join_multiple_paths" that takes paths as List[String] returns String:
    If Collections.List.length with lst as paths is equal to 0:
        Return ""
    If Collections.List.length with lst as paths is equal to 1:
        Return paths[0]
    Let result be paths[0]
    For i from 1 to Collections.List.length with lst as paths - 1:
        Set result to join_paths with base as result and component as paths[i]
    Return result

Process called "normalize_path" that takes path as String returns String:
    If path is equal to "":
        Return ""
    Let platform_info be OS.detect_current_platform()
    Match platform_info.name:
        When "Windows":
            Return normalize_windows_path with path as path
        Otherwise:
            Return normalize_unix_path with path as path

Process called "get_absolute_path" that takes path as String returns String:
    If is_absolute_path with path as path:
        Return normalize_path with path as path
    Let current_dir be OS.get_current_working_directory()
    Let joined_path be join_paths with base as current_dir and component as path
    Return normalize_path with path as joined_path

Process called "get_relative_path" that takes path as String and base as String returns String:
    Let abs_path be get_absolute_path with path as path
    Let abs_base be get_absolute_path with path as base
    Let path_components be split_path with path as abs_path
    Let base_components be split_path with path as abs_base
    Note: Find common prefix
    Let common_length be find_common_path_prefix with path1 as path_components and path2 as base_components
    Let relative_components be list
    Note: Add .. for each remaining base component
    Let remaining_base_count be Collections.List.length with lst as base_components - common_length
    For i from 1 to remaining_base_count:
        Add ".." to relative_components
    Note: Add remaining path components
    For i from common_length to Collections.List.length with lst as path_components - 1:
        Add path_components[i] to relative_components
    If Collections.List.length with lst as relative_components is equal to 0:
        Return "."
    Return join_multiple_paths with paths as relative_components

Process called "is_absolute_path" that takes path as String returns Boolean:
    If path is equal to "":
        Return false
    Let platform_info be OS.detect_current_platform()
    Match platform_info.name:
        When "Windows":
            Return is_windows_absolute_path with path as path
        Otherwise:
            Return String.starts_with with str as path and prefix as "/"

Note: Path component extraction
Process called "get_parent_directory" that takes path as String returns String:
    Let normalized_path be normalize_path with path as path
    If normalized_path is equal to "" or normalized_path is equal to "/" or is_root_path with path as normalized_path:
        Return normalized_path
    Let separator be get_path_separator_for_platform()
    Let last_separator_index be String.last_index_of with str as normalized_path and substring as separator
    If last_separator_index is equal to -1:
        Return "."
    If last_separator_index is equal to 0:
        Return separator
    Return String.substring with str as normalized_path and start as 0 and length as last_separator_index

Process called "get_file_name" that takes path as String returns String:
    If path is equal to "":
        Return ""
    Let separator be get_path_separator_for_platform()
    Let last_separator_index be String.last_index_of with str as path and substring as separator
    If last_separator_index is equal to -1:
        Return path
    Return String.substring with str as path and start as last_separator_index + 1

Process called "get_file_stem" that takes path as String returns String:
    Let filename be get_file_name with path as path
    If filename is equal to "" or filename is equal to "." or filename is equal to "..":
        Return filename
    Let dot_index be String.last_index_of with str as filename and substring as "."
    If dot_index is equal to -1 or dot_index is equal to 0:
        Return filename
    Return String.substring with str as filename and start as 0 and length as dot_index

Process called "get_file_extension" that takes path as String returns String:
    Let filename be get_file_name with path as path
    If filename is equal to "" or filename is equal to "." or filename is equal to "..":
        Return ""
    Let dot_index be String.last_index_of with str as filename and substring as "."
    If dot_index is equal to -1 or dot_index is equal to 0:
        Return ""
    Return String.substring with str as filename and start as dot_index + 1

Process called "get_all_extensions" that takes path as String returns List[String]:
    Let filename be get_file_name with path as path
    Let extensions be list
    If filename is equal to "" or filename is equal to "." or filename is equal to "..":
        Return extensions
    Let parts be String.split with str as filename and separator as "."
    If Collections.List.length with lst as parts is greater than 1:
        For i from 1 to Collections.List.length with lst as parts - 1:
            Add parts[i] to extensions
    Return extensions

Process called "change_extension" that takes path as String and new_extension as String returns String:
    Let stem be get_file_stem with path as path
    Let parent be get_parent_directory with path as path
    Let new_filename be stem
    If new_extension is not equal to "":
        If String.starts_with with str as new_extension and prefix as ".":
            Set new_filename to stem followed by new_extension
        Otherwise:
            Set new_filename to stem followed by "." followed by new_extension
    If parent is equal to ".":
        Return new_filename
    Return join_paths with base as parent and component as new_filename

Note: Path analysis and validation
Process called "get_path_info" that takes path as String returns PathInfo:
    Let normalized_path be normalize_path with path as path
    Let absolute_path be get_absolute_path with path as path
    Return PathInfo with:
        original_path as path
        normalized_path as normalized_path
        absolute_path as absolute_path
        components as split_path with path as normalized_path
        drive as get_drive_letter with path as absolute_path
        root as get_path_root with path as absolute_path
        parent as get_parent_directory with path as normalized_path
        name as get_file_name with path as normalized_path
        stem as get_file_stem with path as normalized_path
        suffix as get_file_extension with path as normalized_path
        suffixes as get_all_extensions with path as normalized_path
        is_absolute as is_absolute_path with path as path
        is_relative as not is_absolute_path with path as path
        exists as path_exists with path as absolute_path
        is_file as OS.file_exists with path as absolute_path
        is_directory as OS.directory_exists with path as absolute_path

Process called "compare_paths" that takes path1 as String and path2 as String returns Boolean:
    Let normalized_path1 be normalize_path with path as path1
    Let normalized_path2 be normalize_path with path as path2
    Let platform_info be OS.detect_current_platform()
    Match platform_info.name:
        When "Windows":
            Return String.to_lower with str as normalized_path1 is equal to String.to_lower with str as normalized_path2
        Otherwise:
            Return normalized_path1 is equal to normalized_path2

Process called "is_child_path" that takes child as String and parent as String returns Boolean:
    Let abs_child be get_absolute_path with path as child
    Let abs_parent be get_absolute_path with path as parent
    If abs_child is equal to abs_parent:
        Return false
    Let parent_with_separator be ensure_trailing_separator with path as abs_parent
    Let platform_info be OS.detect_current_platform()
    Match platform_info.name:
        When "Windows":
            Return String.starts_with with str as String.to_lower with str as abs_child and prefix as String.to_lower with str as parent_with_separator
        Otherwise:
            Return String.starts_with with str as abs_child and prefix as parent_with_separator

Process called "validate_path_security" that takes path as String returns Boolean:
    Note: Check for path traversal attacks
    Let normalized_path be normalize_path with path as path
    Note: Check for dangerous patterns
    If String.contains with str as normalized_path and substring as ".." or String.contains with str as normalized_path and substring as "~":
        Return false
    Note: Check for null bytes
    If String.contains with str as path and substring as "\0":
        Return false
    Note: Check path length limits
    If String.length with str as path is greater than 4096:
        Return false
    Note: Check for reserved names on Windows
    Let platform_info be OS.detect_current_platform()
    If platform_info.name is equal to "Windows":
        Return validate_windows_path_security with path as normalized_path
    Return true

Process called "is_safe_path" that takes path as String and base_dir as String returns Boolean:
    Let security_check be validate_path_security with path as path
    If not security_check:
        Return false
    Let abs_path be get_absolute_path with path as path
    Let abs_base be get_absolute_path with path as base_dir
    Return is_child_path with child as abs_path and parent as abs_base or compare_paths with path1 as abs_path and path2 as abs_base

Note: Pattern matching and globbing
Process called "match_pattern" that takes path as String and pattern as String returns Boolean:
    Return match_glob_pattern with path as path and pattern as pattern and case_sensitive as true

Process called "match_pattern_case_insensitive" that takes path as String and pattern as String returns Boolean:
    Return match_glob_pattern with path as path and pattern as pattern and case_sensitive as false

Process called "expand_glob_pattern" that takes pattern as String and base_dir as String returns List[String]:
    Let matching_paths be list
    Let pattern_parts be split_glob_pattern with pattern as pattern
    Let search_root be base_dir
    If base_dir is equal to "":
        Set search_root to OS.get_current_working_directory()
    expand_glob_recursive with root as search_root and pattern_parts as pattern_parts and current_depth as 0 and matches as matching_paths
    Return matching_paths

Process called "find_files_by_pattern" that takes pattern as String and root_dir as String returns List[String]:
    Return expand_glob_pattern with pattern as pattern and base_dir as root_dir

Note: Path templates and substitution
Process called "create_path_template" that takes template_string as String returns PathTemplate:
    Let variables be extract_template_variables with template as template_string
    Return PathTemplate with:
        template_string as template_string
        variables as dictionary
        default_values as dictionary
        required_variables as variables

Process called "substitute_path_template" that takes template as PathTemplate and values as Dictionary[String, String] returns String:
    Let result be template.template_string
    For each var_name and var_value in values:
        Let placeholder be "${" followed by var_name followed by "}"
        Set result to String.replace with str as result and old as placeholder and new as var_value
    Note: Apply default values for missing variables
    For each var_name and default_value in template.default_values:
        Let placeholder be "${" followed by var_name followed by "}"
        If String.contains with str as result and substring as placeholder:
            Set result to String.replace with str as result and old as placeholder and new as default_value
    Return normalize_path with path as result

Process called "generate_unique_path" that takes base_path as String and extension as String returns String:
    Let timestamp be DateTime.now().timestamp
    Let unique_id be String.from with value as timestamp modulo 1000000.0
    Let stem be get_file_stem with path as base_path
    Let parent be get_parent_directory with path as base_path
    Let unique_name be stem followed by "_" followed by unique_id
    If extension is not equal to "":
        Set unique_name to unique_name followed by "." followed by extension
    Return join_paths with base as parent and component as unique_name

Process called "generate_temp_path" that takes prefix as String and extension as String returns String:
    Let temp_dir be OS.get_temp_directory()
    Let timestamp be DateTime.now().timestamp
    Let unique_suffix be String.from with value as timestamp modulo 1000000.0
    Let temp_name be prefix followed by "_" followed by unique_suffix
    If extension is not equal to "":
        Set temp_name to temp_name followed by "." followed by extension
    Return join_paths with base as temp_dir and component as temp_name

Note: Platform-specific utilities
Process called "get_path_separator_for_platform" returns String:
    Let platform_info be OS.detect_current_platform()
    Match platform_info.name:
        When "Windows":
            Return "\\"
        Otherwise:
            Return "/"

Process called "get_path_separator" that takes separator_type as PathSeparator returns String:
    Match separator_type:
        When Unix:
            Return "/"
        When Windows:
            Return "\\"
        When Current:
            Return get_path_separator_for_platform()
        Otherwise:
            Return get_path_separator_for_platform()

Process called "convert_path_separators" that takes path as String and target_separator as PathSeparator returns String:
    Let target_sep be get_path_separator with separator_type as target_separator
    Let result be path
    Note: Replace all separator types with target
    Set result to String.replace with str as result and old as "/" and new as target_sep
    Set result to String.replace with str as result and old as "\\" and new as target_sep
    Return result

Process called "normalize_windows_path" that takes path as String returns String:
    Let result be path
    Note: Convert forward slashes to backslashes
    Set result to String.replace with str as result and old as "/" and new as "\\"
    Note: Handle UNC paths
    If String.starts_with with str as result and prefix as "\\\\\\\\":
        Set result to "\\\\" followed by String.substring with str as result and start as 4
    Note: Resolve . and .. components
    Set result to resolve_relative_components with path as result and separator as "\\"
    Note: Handle drive letter formatting
    Set result to normalize_windows_drive_letter with path as result
    Return result

Process called "normalize_unix_path" that takes path as String returns String:
    Let result be path
    Note: Convert backslashes to forward slashes
    Set result to String.replace with str as result and old as "\\" and new as "/"
    Note: Resolve . and .. components
    Set result to resolve_relative_components with path as result and separator as "/"
    Note: Ensure single leading slash for absolute paths
    While String.starts_with with str as result and prefix as "//" and String.length with str as result is greater than 1:
        Set result to String.substring with str as result and start as 1
    Return result

Note: Utility and helper functions
Process called "split_path" that takes path as String returns List[String]:
    If path is equal to "":
        Return list
    Let separator be get_path_separator_for_platform()
    Let components be String.split with str as path and separator as separator
    Let result be list
    For each component in components:
        If component is not equal to "":
            Add component to result
    Return result

Process called "ensure_trailing_separator" that takes path as String returns String:
    If path is equal to "":
        Return ""
    Let separator be get_path_separator_for_platform()
    If String.ends_with with str as path and suffix as separator:
        Return path
    Return path followed by separator

Process called "ensure_trailing_separator_removed" that takes path as String returns String:
    If path is equal to "":
        Return ""
    Let separator be get_path_separator_for_platform()
    While String.ends_with with str as path and suffix as separator and String.length with str as path is greater than 1:
        Set path to String.substring with str as path and start as 0 and length as String.length with str as path - 1
    Return path

Process called "ensure_leading_separator_removed" that takes path as String returns String:
    If path is equal to "":
        Return ""
    Let separator be get_path_separator_for_platform()
    While String.starts_with with str as path and prefix as separator and String.length with str as path is greater than 1:
        Set path to String.substring with str as path and start as 1
    Return path

Process called "find_common_path_prefix" that takes path1 as List[String] and path2 as List[String] returns Integer:
    Let min_length be Collections.List.length with lst as path1
    If Collections.List.length with lst as path2 is less than min_length:
        Set min_length to Collections.List.length with lst as path2
    Let common_count be 0
    For i from 0 to min_length - 1:
        If path1[i] is equal to path2[i]:
            Set common_count to common_count + 1
        Otherwise:
            Break
    Return common_count

Process called "resolve_relative_components" that takes path as String and separator as String returns String:
    Let components be String.split with str as path and separator as separator
    Let resolved_components be list
    For each component in components:
        If component is equal to "" or component is equal to ".":
            Continue
        If component is equal to "..":
            If Collections.List.length with lst as resolved_components is greater than 0:
                Remove last item from resolved_components
        Otherwise:
            Add component to resolved_components
    Let result be String.join with lst as resolved_components and separator as separator
    Note: Preserve leading separator for absolute paths
    If String.starts_with with str as path and prefix as separator:
        Set result to separator followed by result
    Return result

Process called "is_windows_absolute_path" that takes path as String returns Boolean:
    If String.length with str as path is less than 2:
        Return false
    Note: Check for drive letter (C:\)
    Let first_char be String.substring with str as path and start as 0 and length as 1
    Let second_char be String.substring with str as path and start as 1 and length as 1
    If second_char is equal to ":":
        If (first_char is greater than or equal to "A" and first_char is less than or equal to "Z") or (first_char is greater than or equal to "a" and first_char is less than or equal to "z"):
            Return true
    Note: Check for UNC path (\\server\share)
    If String.starts_with with str as path and prefix as "\\\\":
        Return true
    Return false

Process called "is_root_path" that takes path as String returns Boolean:
    Let normalized_path be normalize_path with path as path
    If normalized_path is equal to "/":
        Return true
    Note: Check for Windows drive root (C:\)
    Let platform_info be OS.detect_current_platform()
    If platform_info.name is equal to "Windows":
        If String.length with str as normalized_path is equal to 3 and String.ends_with with str as normalized_path and suffix as ":\\":
            Let drive_letter be String.substring with str as normalized_path and start as 0 and length as 1
            If (drive_letter is greater than or equal to "A" and drive_letter is less than or equal to "Z") or (drive_letter is greater than or equal to "a" and drive_letter is less than or equal to "z"):
                Return true
    Return false

Process called "get_drive_letter" that takes path as String returns String:
    Let platform_info be OS.detect_current_platform()
    If platform_info.name is not equal to "Windows":
        Return ""
    If String.length with str as path is less than 2:
        Return ""
    Let second_char be String.substring with str as path and start as 1 and length as 1
    If second_char is equal to ":":
        Return String.substring with str as path and start as 0 and length as 1
    Return ""

Process called "get_path_root" that takes path as String returns String:
    Let platform_info be OS.detect_current_platform()
    Match platform_info.name:
        When "Windows":
            Let drive be get_drive_letter with path as path
            If drive is not equal to "":
                Return drive followed by ":\\"
            If String.starts_with with str as path and prefix as "\\\\":
                Note: UNC path - return \\server\share
                Let components be String.split with str as path and separator as "\\"
                If Collections.List.length with lst as components is greater than or equal to 4:
                    Return "\\\\" followed by components[2] followed by "\\" followed by components[3]
                Return "\\\\"
            Return ""
        Otherwise:
            If String.starts_with with str as path and prefix as "/":
                Return "/"
            Return ""

Process called "validate_windows_path_security" that takes path as String returns Boolean:
    Note: Windows reserved names
    Let reserved_names be list containing "CON", "PRN", "AUX", "NUL", "COM1", "COM2", "COM3", "COM4", "COM5", "COM6", "COM7", "COM8", "COM9", "LPT1", "LPT2", "LPT3", "LPT4", "LPT5", "LPT6", "LPT7", "LPT8", "LPT9"
    Let filename be get_file_name with path as path
    Let stem be get_file_stem with path as filename
    For each reserved_name in reserved_names:
        If String.to_upper with str as stem is equal to reserved_name:
            Return false
    Note: Check for invalid characters
    Let invalid_chars be list containing "<", ">", ":", "\"", "|", "?", "*"
    For each invalid_char in invalid_chars:
        If String.contains with str as path and substring as invalid_char:
            Return false
    Return true

Process called "normalize_windows_drive_letter" that takes path as String returns String:
    If String.length with str as path is less than 2:
        Return path
    Let second_char be String.substring with str as path and start as 1 and length as 1
    If second_char is equal to ":":
        Let drive_letter be String.substring with str as path and start as 0 and length as 1
        Let upper_drive be String.to_upper with str as drive_letter
        Let remainder be String.substring with str as path and start as 2
        Return upper_drive followed by ":" followed by remainder
    Return path

Process called "match_glob_pattern" that takes path as String and pattern as String and case_sensitive as Boolean returns Boolean:
    Let target_path be path
    Let target_pattern be pattern
    If not case_sensitive:
        Set target_path to String.to_lower with str as target_path
        Set target_pattern to String.to_lower with str as target_pattern
    Return match_glob_pattern_recursive with path as target_path and pattern as target_pattern and path_index as 0 and pattern_index as 0

Process called "match_glob_pattern_recursive" that takes path as String and pattern as String and path_index as Integer and pattern_index as Integer returns Boolean:
    Let path_length be String.length with str as path
    Let pattern_length be String.length with str as pattern
    Note: End of pattern reached
    If pattern_index is greater than or equal to pattern_length:
        Return path_index is greater than or equal to path_length
    Note: End of path reached
    If path_index is greater than or equal to path_length:
        Note: Check if remaining pattern is all asterisks
        For i from pattern_index to pattern_length - 1:
            Let pattern_char be String.substring with str as pattern and start as i and length as 1
            If pattern_char is not equal to "*":
                Return false
        Return true
    Let pattern_char be String.substring with str as pattern and start as pattern_index and length as 1
    Let path_char be String.substring with str as path and start as path_index and length as 1
    Match pattern_char:
        When "*":
            Note: Try matching zero or more characters
            If match_glob_pattern_recursive with path as path and pattern as pattern and path_index as path_index and pattern_index as pattern_index + 1:
                Return true
            Return match_glob_pattern_recursive with path as path and pattern as pattern and path_index as path_index + 1 and pattern_index as pattern_index
        When "?":
            Note: Match single character
            Return match_glob_pattern_recursive with path as path and pattern as pattern and path_index as path_index + 1 and pattern_index as pattern_index + 1
        Otherwise:
            Note: Match literal character
            If pattern_char is equal to path_char:
                Return match_glob_pattern_recursive with path as path and pattern as pattern and path_index as path_index + 1 and pattern_index as pattern_index + 1
            Return false

Process called "split_glob_pattern" that takes pattern as String returns List[String]:
    Let separator be get_path_separator_for_platform()
    Return String.split with str as pattern and separator as separator

Process called "expand_glob_recursive" that takes root as String and pattern_parts as List[String] and current_depth as Integer and matches as List[String]:
    If current_depth is greater than or equal to Collections.List.length with lst as pattern_parts:
        Add root to matches
        Return
    Let current_pattern be pattern_parts[current_depth]
    If current_pattern is equal to "**":
        Note: Recursive wildcard - search all subdirectories
        expand_recursive_wildcard with root as root and pattern_parts as pattern_parts and current_depth as current_depth and matches as matches
    Otherwise:
        Note: Regular pattern matching
        expand_single_level with root as root and pattern as current_pattern and pattern_parts as pattern_parts and current_depth as current_depth and matches as matches

Process called "expand_recursive_wildcard" that takes root as String and pattern_parts as List[String] and current_depth as Integer and matches as List[String]:
    Note: Try matching at current level (skip **)
    expand_glob_recursive with root as root and pattern_parts as pattern_parts and current_depth as current_depth + 1 and matches as matches
    Note: Try matching in subdirectories
    Let mock_subdirs be get_mock_subdirectories with path as root
    For each subdir in mock_subdirs:
        Let subdir_path be join_paths with base as root and component as subdir
        expand_recursive_wildcard with root as subdir_path and pattern_parts as pattern_parts and current_depth as current_depth and matches as matches

Process called "expand_single_level" that takes root as String and pattern as String and pattern_parts as List[String] and current_depth as Integer and matches as List[String]:
    Let mock_entries be get_mock_directory_entries with path as root
    For each entry in mock_entries:
        If match_pattern with path as entry and pattern as pattern:
            Let entry_path be join_paths with base as root and component as entry
            expand_glob_recursive with root as entry_path and pattern_parts as pattern_parts and current_depth as current_depth + 1 and matches as matches

Process called "extract_template_variables" that takes template as String returns List[String]:
    Let variables be list
    Let current_pos be 0
    While current_pos is less than String.length with str as template:
        Let start_pos be String.index_of_from with str as template and substring as "${" and start_index as current_pos
        If start_pos is equal to -1:
            Break
        Let end_pos be String.index_of_from with str as template and substring as "}" and start_index as start_pos + 2
        If end_pos is not equal to -1:
            Let var_name be String.substring with str as template and start as start_pos + 2 and length as end_pos - start_pos - 2
            If var_name is not equal to "":
                Add var_name to variables
            Set current_pos to end_pos + 1
        Otherwise:
            Set current_pos to start_pos + 2
    Return variables

Process called "path_exists" that takes path as String returns Boolean:
    Return OS.file_exists with path as path or OS.directory_exists with path as path

Process called "get_mock_directory_entries" that takes path as String returns List[String]:
    Note: Generate mock directory entries for testing
    If String.contains with str as path and substring as "home" or String.contains with str as path and substring as "Users":
    Return list containing "Documents", "Downloads", "Pictures", "file.txt"
    If String.contains with str as path and substring as "tmp" or String.contains with str as path and substring as "temp":
    Return list containing "temp_file.tmp", "cache", "logs"
    Return list containing "example.txt", "data.json", "subdir", "script.sh"

Process called "get_mock_subdirectories" that takes path as String returns List[String]:
    Note: Generate mock subdirectories for recursive expansion
    If String.contains with str as path and substring as "home" or String.contains with str as path and substring as "Users":
    Return list containing "Documents", "Downloads", "Pictures"
    If String.contains with str as path and substring as "tmp" or String.contains with str as path and substring as "temp":
    Return list containing "cache", "logs"
    Return list containing "subdir"