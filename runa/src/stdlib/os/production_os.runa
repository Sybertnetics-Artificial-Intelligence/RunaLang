Process called "get_platform_specific_data" returns Dictionary[String, Any]:
    Note: Get platform-specific information
    Try:
        Let os_type be detect_operating_system
        Match os_type:
            When Windows:
                Return dictionary containing:
                    "registry_info" as "Available"
                    "windows_version" as get_operating_system_version
            When Linux:
                Return dictionary containing:
                    "kernel_version" as get_operating_system_version
                    "distribution" as "Unknown"
            When MacOS:
                Return dictionary containing:
                    "macos_version" as get_operating_system_version
                    "architecture" as "Unknown"
            Otherwise:
                Return dictionary containing
    Catch error:
        Return dictionary containing

Process called "get_platform_name_internal" returns String:
    Note: Get platform name using essential runtime calls
    Try:
        Note: Platform detection using environment variables
            Let env_os be get_environment_variable_internal with name as "OS"
            If env_os is not None and env_os contains "Windows":
                Return "Windows"
            Otherwise:
                Return "Linux"  Note: Safe assumption for Unix-like systems
    Catch error:
            Return "Unknown"

Process called "clean_path_component_for_platform" that takes component as String returns String:
    Note: Clean path component for platform compatibility
    Let os_type be detect_operating_system
    Let cleaned be component
    
    Match os_type:
        When Windows:
            Note: Replace forward slashes with backslashes
            Set cleaned to replace_string with text as cleaned and pattern as "/" and replacement as "\\"
            Note: Remove invalid Windows characters
            Set cleaned to remove_invalid_characters_windows with text as cleaned
        Otherwise:
            Note: Replace backslashes with forward slashes
            Set cleaned to replace_string with text as cleaned and pattern as "\\" and replacement as "/"
    
    Note: Trim whitespace
    Set cleaned to trim_whitespace with text as cleaned
    Return cleaned

Process called "replace_path_separators" that takes path as String and target_separator as String returns String:
    Note: Replace all path separators with target separator
    Let result be path
    
    If target_separator is equal to "/":
        Set result to replace_string with text as result and pattern as "\\" and replacement as "/"
    Otherwise:
        Set result to replace_string with text as result and pattern as "/" and replacement as "\\"
    
    Return result

Process called "resolve_relative_path_components" that takes path as String and separator as String returns String:
    Note: Resolve relative components like . and ..
    Let components be list containing
    Let current_component be ""
    
    For each character in path:
        If character is equal to separator:
            If current_component is not equal to "":
                Add current_component to components
                Set current_component to ""
        Otherwise:
            Set current_component to current_component plus character
    
    If current_component is not equal to "":
        Add current_component to components
    
    Let resolved_components be list containing
    
    For each component in components:
        If component is equal to ".":
            Continue
        Otherwise if component is equal to "..":
            If length of resolved_components is greater than 0:
                Remove last item from resolved_components
        Otherwise:
            Add component to resolved_components
    
    If length of resolved_components is equal to 0:
        Return separator
    
    Let result be ""
    For each resolved_component in resolved_components:
        Set result to result plus separator plus resolved_component
    
    Return result

Process called "find_common_path_length" that takes path1 as List[String] and path2 as List[String] returns Integer:
    Note: Find length of common path prefix
    Let min_length be minimum of (length of path1) and (length of path2)
    Let common_length be 0
    
    For i from 0 to (min_length minus 1):
        If (path1 at index i) is equal to (path2 at index i):
            Set common_length to common_length plus 1
        Otherwise:
            Break
    
    Return common_length

Note: Helper functions for validation and safety
Process called "contains_invalid_env_name_characters" that takes name as String returns Boolean:
    Note: Check for invalid environment variable name characters
    Let invalid_chars be list containing "=", "\0", "\n", "\r"
    For each char in invalid_chars:
        If name contains char:
            Return true
    Return false

Process called "starts_with_digit" that takes text as String returns Boolean:
    Note: Check if text starts with a digit
    If length of text is equal to 0:
        Return false
    
    Let first_char be character at index 0 in text
    Return first_char is greater than or equal to "0" and first_char is less than or equal to "9"

Process called "contains_null_character" that takes text as String returns Boolean:
    Note: Check if text contains null character
    Return text contains "\0"

Process called "contains_dangerous_command_characters" that takes command as String returns Boolean:
    Note: Check for potentially dangerous command characters
    Let dangerous_chars be list containing "|", "&", ";", "`", "$", "(", ")", "<", ">", "*", "?"
    For each char in dangerous_chars:
        If command contains char:
            Return true
    Return false

Process called "is_known_dangerous_command" that takes command as String returns Boolean:
    Note: Check if command is known to be dangerous
    Let dangerous_commands be list containing "rm", "del", "format", "fdisk", "mkfs", "dd", "shutdown", "reboot"
    Let command_name be extract_command_name with command as command
    
    For each dangerous_cmd in dangerous_commands:
        If command_name is equal to dangerous_cmd:
            Return true
    Return false

Process called "extract_command_name" that takes command as String returns String:
    Note: Extract command name from full command path
    Let path_components be split_path_cross_platform with path as command
    If length of path_components is greater than 0:
        Return path_components at index (length of path_components minus 1)
    Otherwise:
        Return command

Process called "get_dangerous_system_paths" returns List[String]:
    Note: Get list of dangerous system paths that should not be deleted
    Let os_type be detect_operating_system
    Match os_type:
        When Windows:
            Return list containing "C:\\Windows", "C:\\Program Files", "C:\\System32"
        Otherwise:
            Return list containing "/", "/bin", "/usr", "/etc", "/var", "/sys", "/proc", "/dev"

Process called "get_entry_type_internal" that takes path as String returns FileType:
    Note: Get entry type using essential runtime calls
    Try:
        Note: Use directory listing to determine type
        Let entries be system_call_directory_list with path as path
        If entries is not None:
            Return Directory
        Otherwise:
            Return RegularFile
    Catch error:
        Return Unknown

Process called "get_entry_size_internal" that takes path as String returns Integer:
    Note: Get entry size using essential runtime calls
    Try:
