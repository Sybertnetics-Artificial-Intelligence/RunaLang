Process called "get_default_dict_statistics" that takes default_dict as DefaultDict returns Dictionary[String, Any]:
    Let stats be dictionary with:
    
    Set stats["size"] to get_default_dict_size with default_dict as default_dict
    Set stats["is_empty"] to is_default_dict_empty with default_dict as default_dict
    Set stats["default_value"] to get_default_value with default_dict as default_dict
    Set stats["factory_type"] to get_factory_type with default_dict as default_dict
    Set stats["keys_count"] to length of get_default_dict_keys with default_dict as default_dict
    
    Let value_types be dictionary with:
    For each key and value in default_dict["data"]:
        Let value_type be "unknown"
        If value is String:
            Let value_type be "String"
        Otherwise if value is Integer:
            Let value_type be "Integer"
        Otherwise if value is Float:
            Let value_type be "Float"
        Otherwise if value is Boolean:
            Let value_type be "Boolean"
        Otherwise if value is list:
            Let value_type be "List"
        Otherwise if value is dictionary:
            Let value_type be "Dictionary"
        
        If value_type in value_types:
            Set value_types[value_type] to value_types[value_type] plus 1
        Otherwise:
            Set value_types[value_type] to 1
    Set stats["value_type_distribution"] to value_types
    
    Return stats

Process called "validate_default_dict" that takes default_dict as DefaultDict returns Boolean:
    If not "data" in default_dict:
        Return false
    
    If not "default_value" in default_dict:
        Return false
    
    If not "factory_type" in default_dict:
        Return false
    
    Let valid_factory_types be list containing "none", "value", "list", "dict", "int", "float", "string", "bool", "set", "nested"
    If not default_dict["factory_type"] in valid_factory_types:
        Return false
    
    Return true