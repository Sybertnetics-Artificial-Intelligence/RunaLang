Process called "merge_default_dicts" that takes default_dicts as List[DefaultDict] returns DefaultDict:
    If length of default_dicts is equal to 0:
        Return create_default_dict
    
    Let result be copy_default_dict with default_dict as default_dicts[0]
    Let index be 1
    
    While index is less than length of default_dicts:
        Let current_dict be default_dicts[index]
        Let result be update_default_dict_from_default_dict with default_dict as result and other as current_dict
        Let index be index plus 1
    
    Return result

