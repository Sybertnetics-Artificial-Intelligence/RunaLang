Note: Runa Tree Data Structures Implementation
Comprehensive tree data structures for hierarchical data organization and efficient search operations.
Includes binary search trees, AVL trees, tries, and segment trees using Dictionary-based architecture.

All operations return Dictionary types with success indicators and maintain natural language syntax compliance.
Advanced features include automatic balancing, tree traversal algorithms, and performance optimizations.
:End Note

Type called "TreeNode":
    value as Any
    left as Dictionary
    right as Dictionary
    parent as Dictionary
    height as Integer
    balance_factor as Integer

Type called "BinarySearchTree":
    root as Dictionary
    size as Integer
    comparisons_count as Integer
    insertions_count as Integer
    deletions_count as Integer
    tree_type as String

Process called "create_tree_node" that takes value as Any returns Dictionary:
    Return dictionary with:
        "value" as value
        "left" as nothing
        "right" as nothing
        "parent" as nothing
        "height" as 1
        "balance_factor" as 0

Process called "create_empty_bst" returns Dictionary:
    Return dictionary with:
        "root" as nothing
        "size" as 0
        "comparisons_count" as 0
        "insertions_count" as 0
        "deletions_count" as 0
        "tree_type" as "binary_search_tree"

Process called "create_empty_avl_tree" returns Dictionary:
    Return dictionary with:
        "root" as nothing
        "size" as 0
        "comparisons_count" as 0
        "insertions_count" as 0
        "deletions_count" as 0
        "tree_type" as "avl_tree"

Process called "bst_insert" that takes tree as Dictionary and value as Any returns Dictionary:
    Let insert_result be bst_insert_recursive with root as tree["root"] and value as value and tree as tree
    Set tree["root"] to insert_result["new_root"]
    
    If insert_result["was_inserted"]:
        Set tree["size"] to tree["size"] plus 1
        Set tree["insertions_count"] to tree["insertions_count"] plus 1
    
    Return dictionary with:
        "success" as true
        "tree" as tree
        "was_inserted" as insert_result["was_inserted"]

Process called "bst_insert_recursive" that takes root as Dictionary and value as Any and tree as Dictionary returns Dictionary:
    If root is nothing:
        Let new_node be create_tree_node with value as value
        Return dictionary with:
            "new_root" as new_node
            "was_inserted" as true
    
    Set tree["comparisons_count"] to tree["comparisons_count"] plus 1
    
    If value is less than root["value"]:
        Let left_result be bst_insert_recursive with root as root["left"] and value as value and tree as tree
        Set root["left"] to left_result["new_root"]
        
        If root["left"] is not nothing:
            Set root["left"]["parent"] to root
        
        Return dictionary with:
            "new_root" as root
            "was_inserted" as left_result["was_inserted"]
    
    Otherwise if value is greater than root["value"]:
        Let right_result be bst_insert_recursive with root as root["right"] and value as value and tree as tree
        Set root["right"] to right_result["new_root"]
        
        If root["right"] is not nothing:
            Set root["right"]["parent"] to root
        
        Return dictionary with:
            "new_root" as root
            "was_inserted" as right_result["was_inserted"]
    
    Return dictionary with:
        "new_root" as root
        "was_inserted" as false

Process called "bst_search" that takes tree as Dictionary and value as Any returns Dictionary:
    Let search_result be bst_search_recursive with root as tree["root"] and value as value and tree as tree
    
    Return dictionary with:
        "success" as true
        "found" as search_result["found"]
        "node" as search_result["node"]

Process called "bst_search_recursive" that takes root as Dictionary and value as Any and tree as Dictionary returns Dictionary:
    If root is nothing:
        Return dictionary with:
            "found" as false
            "node" as nothing
    
    Set tree["comparisons_count"] to tree["comparisons_count"] plus 1
    
    If root["value"] is equal to value:
        Return dictionary with:
            "found" as true
            "node" as root
    
    If value is less than root["value"]:
        Return bst_search_recursive with root as root["left"] and value as value and tree as tree
    
    Return bst_search_recursive with root as root["right"] and value as value and tree as tree

Process called "bst_find_min" that takes root as Dictionary returns Dictionary:
    If root is nothing:
        Return dictionary with:
            "found" as false
            "node" as nothing
    
    If root["left"] is nothing:
        Return dictionary with:
            "found" as true
            "node" as root
    
    Return bst_find_min with root as root["left"]

Process called "bst_find_max" that takes root as Dictionary returns Dictionary:
    If root is nothing:
        Return dictionary with:
            "found" as false
            "node" as nothing
    
    If root["right"] is nothing:
        Return dictionary with:
            "found" as true
            "node" as root
    
    Return bst_find_max with root as root["right"]

Process called "bst_delete" that takes tree as Dictionary and value as Any returns Dictionary:
    Let delete_result be bst_delete_recursive with root as tree["root"] and value as value and tree as tree
    Set tree["root"] to delete_result["new_root"]
    
    If delete_result["was_deleted"]:
        Set tree["size"] to tree["size"] minus 1
        Set tree["deletions_count"] to tree["deletions_count"] plus 1
    
    Return dictionary with:
        "success" as true
        "tree" as tree
        "was_deleted" as delete_result["was_deleted"]
        "deleted_value" as delete_result["deleted_value"]

Process called "bst_delete_recursive" that takes root as Dictionary and value as Any and tree as Dictionary returns Dictionary:
    If root is nothing:
        Return dictionary with:
            "new_root" as nothing
            "was_deleted" as false
            "deleted_value" as nothing
    
    Set tree["comparisons_count"] to tree["comparisons_count"] plus 1
    
    If value is less than root["value"]:
        Let left_result be bst_delete_recursive with root as root["left"] and value as value and tree as tree
        Set root["left"] to left_result["new_root"]
        
        If root["left"] is not nothing:
            Set root["left"]["parent"] to root
        
        Return dictionary with:
            "new_root" as root
            "was_deleted" as left_result["was_deleted"]
            "deleted_value" as left_result["deleted_value"]
    
    Otherwise if value is greater than root["value"]:
        Let right_result be bst_delete_recursive with root as root["right"] and value as value and tree as tree
        Set root["right"] to right_result["new_root"]
        
        If root["right"] is not nothing:
            Set root["right"]["parent"] to root
        
        Return dictionary with:
            "new_root" as root
            "was_deleted" as right_result["was_deleted"]
            "deleted_value" as right_result["deleted_value"]
    
    Let deleted_value be root["value"]
    
    If root["left"] is nothing:
        Return dictionary with:
            "new_root" as root["right"]
            "was_deleted" as true
            "deleted_value" as deleted_value
    
    Otherwise if root["right"] is nothing:
        Return dictionary with:
            "new_root" as root["left"]
            "was_deleted" as true
            "deleted_value" as deleted_value
    
    Let successor_result be bst_find_min with root as root["right"]
    Let successor be successor_result["node"]
    Set root["value"] to successor["value"]
    
    Let right_delete_result be bst_delete_recursive with root as root["right"] and value as successor["value"] and tree as tree
    Set root["right"] to right_delete_result["new_root"]
    
    If root["right"] is not nothing:
        Set root["right"]["parent"] to root
    
    Return dictionary with:
        "new_root" as root
        "was_deleted" as true
        "deleted_value" as deleted_value

Process called "get_tree_height" that takes node as Dictionary returns Integer:
    If node is nothing:
        Return 0
    
    Return node["height"]

Process called "update_tree_height" that takes node as Dictionary returns Dictionary:
    If node is not nothing:
        Let left_height be get_tree_height with node as node["left"]
        Let right_height be get_tree_height with node as node["right"]
        
        Let max_height be left_height
        If right_height is greater than max_height:
            Set max_height to right_height
        
        Set node["height"] to max_height plus 1
        Set node["balance_factor"] to left_height minus right_height
    
    Return node

Process called "rotate_right" that takes root as Dictionary returns Dictionary:
    If root is nothing or root["left"] is nothing:
        Return root
    
    Let new_root be root["left"]
    Set root["left"] to new_root["right"]
    Set new_root["right"] to root
    
    If root["left"] is not nothing:
        Set root["left"]["parent"] to root
    
    Set root["parent"] to new_root
    
    Set root to update_tree_height with node as root
    Set new_root to update_tree_height with node as new_root
    
    Return new_root

Process called "rotate_left" that takes root as Dictionary returns Dictionary:
    If root is nothing or root["right"] is nothing:
        Return root
    
    Let new_root be root["right"]
    Set root["right"] to new_root["left"]
    Set new_root["left"] to root
    
    If root["right"] is not nothing:
        Set root["right"]["parent"] to root
    
    Set root["parent"] to new_root
    
    Set root to update_tree_height with node as root
    Set new_root to update_tree_height with node as new_root
    
    Return new_root

Process called "avl_balance" that takes root as Dictionary returns Dictionary:
    If root is nothing:
        Return nothing
    
    Set root to update_tree_height with node as root
    Let balance_factor be root["balance_factor"]
    
    If balance_factor is greater than 1:
        If root["left"] is not nothing and root["left"]["balance_factor"] is less than 0:
            Set root["left"] to rotate_left with root as root["left"]
        Set root to rotate_right with root as root
    
    Otherwise if balance_factor is less than negative 1:
        If root["right"] is not nothing and root["right"]["balance_factor"] is greater than 0:
            Set root["right"] to rotate_right with root as root["right"]
        Set root to rotate_left with root as root
    
    Return root

Process called "avl_insert" that takes tree as Dictionary and value as Any returns Dictionary:
    Let insert_result be avl_insert_recursive with root as tree["root"] and value as value and tree as tree
    Set tree["root"] to insert_result["new_root"]
    
    If insert_result["was_inserted"]:
        Set tree["size"] to tree["size"] plus 1
        Set tree["insertions_count"] to tree["insertions_count"] plus 1
    
    Return dictionary with:
        "success" as true
        "tree" as tree
        "was_inserted" as insert_result["was_inserted"]

Process called "avl_insert_recursive" that takes root as Dictionary and value as Any and tree as Dictionary returns Dictionary:
    Let bst_result be bst_insert_recursive with root as root and value as value and tree as tree
    Let balanced_root be avl_balance with root as bst_result["new_root"]
    
    Return dictionary with:
        "new_root" as balanced_root
        "was_inserted" as bst_result["was_inserted"]

Process called "avl_delete" that takes tree as Dictionary and value as Any returns Dictionary:
    Let delete_result be avl_delete_recursive with root as tree["root"] and value as value and tree as tree
    Set tree["root"] to delete_result["new_root"]
    
    If delete_result["was_deleted"]:
        Set tree["size"] to tree["size"] minus 1
        Set tree["deletions_count"] to tree["deletions_count"] plus 1
    
    Return dictionary with:
        "success" as true
        "tree" as tree
        "was_deleted" as delete_result["was_deleted"]
        "deleted_value" as delete_result["deleted_value"]

Process called "avl_delete_recursive" that takes root as Dictionary and value as Any and tree as Dictionary returns Dictionary:
    Let bst_result be bst_delete_recursive with root as root and value as value and tree as tree
    Let balanced_root be avl_balance with root as bst_result["new_root"]
    
    Return dictionary with:
        "new_root" as balanced_root
        "was_deleted" as bst_result["was_deleted"]
        "deleted_value" as bst_result["deleted_value"]

Process called "inorder_traversal" that takes root as Dictionary returns List:
    If root is nothing:
        Return list containing
    
    Let result be inorder_traversal with root as root["left"]
    Add root["value"] to result
    
    Let right_result be inorder_traversal with root as root["right"]
    For each item in right_result:
        Add item to result
    
    Return result

Process called "preorder_traversal" that takes root as Dictionary returns List:
    If root is nothing:
        Return list containing
    
    Let result be list containing root["value"]
    
    Let left_result be preorder_traversal with root as root["left"]
    For each item in left_result:
        Add item to result
    
    Let right_result be preorder_traversal with root as root["right"]
    For each item in right_result:
        Add item to result
    
    Return result

Process called "postorder_traversal" that takes root as Dictionary returns List:
    If root is nothing:
        Return list containing
    
    Let result be postorder_traversal with root as root["left"]
    
    Let right_result be postorder_traversal with root as root["right"]
    For each item in right_result:
        Add item to result
    
    Add root["value"] to result
    
    Return result

Process called "level_order_traversal" that takes root as Dictionary returns List:
    If root is nothing:
        Return list containing
    
    Let result be list containing
    Let queue be list containing root
    
    While length of queue is greater than 0:
        Let level_size be length of queue
        Let current_level be list containing
        
        For i from 0 to level_size minus 1:
            Let current be queue[0]
            Remove current from queue at index 0
            Add current["value"] to current_level
            
            If current["left"] is not nothing:
                Add current["left"] to queue
            
            If current["right"] is not nothing:
                Add current["right"] to queue
        
        Add current_level to result
    
    Return result

Process called "get_tree_size" that takes root as Dictionary returns Integer:
    If root is nothing:
        Return 0
    
    Let left_size be get_tree_size with root as root["left"]
    Let right_size be get_tree_size with root as root["right"]
    
    Return 1 plus left_size plus right_size

Process called "get_tree_depth" that takes root as Dictionary returns Integer:
    If root is nothing:
        Return 0
    
    Let left_depth be get_tree_depth with root as root["left"]
    Let right_depth be get_tree_depth with root as root["right"]
    
    Let max_depth be left_depth
    If right_depth is greater than max_depth:
        Set max_depth to right_depth
    
    Return 1 plus max_depth

Process called "is_tree_balanced" that takes root as Dictionary returns Boolean:
    If root is nothing:
        Return true
    
    Let left_height be get_tree_depth with root as root["left"]
    Let right_height be get_tree_depth with root as root["right"]
    Let height_diff be left_height minus right_height
    
    If height_diff is less than 0:
        Set height_diff to height_diff multiplied by negative 1
    
    If height_diff is greater than 1:
        Return false
    
    Let left_balanced be is_tree_balanced with root as root["left"]
    Let right_balanced be is_tree_balanced with root as root["right"]
    
    Return left_balanced and right_balanced

Process called "get_leaf_nodes" that takes root as Dictionary returns List:
    If root is nothing:
        Return list containing
    
    If root["left"] is nothing and root["right"] is nothing:
        Return list containing root["value"]
    
    Let result be get_leaf_nodes with root as root["left"]
    
    Let right_leaves be get_leaf_nodes with root as root["right"]
    For each leaf in right_leaves:
        Add leaf to result
    
    Return result

Process called "get_internal_nodes" that takes root as Dictionary returns List:
    If root is nothing:
        Return list containing
    
    If root["left"] is nothing and root["right"] is nothing:
        Return list containing
    
    Let result be list containing root["value"]
    
    Let left_internals be get_internal_nodes with root as root["left"]
    For each node in left_internals:
        Add node to result
    
    Let right_internals be get_internal_nodes with root as root["right"]
    For each node in right_internals:
        Add node to result
    
    Return result

Process called "mirror_tree" that takes root as Dictionary returns Dictionary:
    If root is nothing:
        Return nothing
    
    Let mirrored be create_tree_node with value as root["value"]
    Set mirrored["left"] to mirror_tree with root as root["right"]
    Set mirrored["right"] to mirror_tree with root as root["left"]
    
    If mirrored["left"] is not nothing:
        Set mirrored["left"]["parent"] to mirrored
    
    If mirrored["right"] is not nothing:
        Set mirrored["right"]["parent"] to mirrored
    
    Return mirrored

Process called "are_trees_identical" that takes root1 as Dictionary and root2 as Dictionary returns Boolean:
    If root1 is nothing and root2 is nothing:
        Return true
    
    If root1 is nothing or root2 is nothing:
        Return false
    
    If root1["value"] is not equal to root2["value"]:
        Return false
    
    Let left_identical be are_trees_identical with root1 as root1["left"] and root2 as root2["left"]
    Let right_identical be are_trees_identical with root1 as root1["right"] and root2 as root2["right"]
    
    Return left_identical and right_identical

Process called "get_path_to_node" that takes root as Dictionary and target as Any returns List:
    If root is nothing:
        Return list containing
    
    If root["value"] is equal to target:
        Return list containing root["value"]
    
    Let left_path be get_path_to_node with root as root["left"] and target as target
    If length of left_path is greater than 0:
        Let path be list containing root["value"]
        For each node in left_path:
            Add node to path
        Return path
    
    Let right_path be get_path_to_node with root as root["right"] and target as target
    If length of right_path is greater than 0:
        Let path be list containing root["value"]
        For each node in right_path:
            Add node to path
        Return path
    
    Return list containing

Process called "find_lowest_common_ancestor" that takes root as Dictionary and value1 as Any and value2 as Any returns Dictionary:
    If root is nothing:
        Return dictionary with:
            "found" as false
            "ancestor" as nothing
    
    If root["value"] is equal to value1 or root["value"] is equal to value2:
        Return dictionary with:
            "found" as true
            "ancestor" as root["value"]
    
    Let left_result be find_lowest_common_ancestor with root as root["left"] and value1 as value1 and value2 as value2
    Let right_result be find_lowest_common_ancestor with root as root["right"] and value1 as value1 and value2 as value2
    
    If left_result["found"] and right_result["found"]:
        Return dictionary with:
            "found" as true
            "ancestor" as root["value"]
    
    If left_result["found"]:
        Return left_result
    
    If right_result["found"]:
        Return right_result
    
    Return dictionary with:
        "found" as false
        "ancestor" as nothing

Process called "tree_statistics" that takes tree as Dictionary returns Dictionary:
    Let tree_size be get_tree_size with root as tree["root"]
    Let tree_depth be get_tree_depth with root as tree["root"]
    Let is_balanced be is_tree_balanced with root as tree["root"]
    Let leaf_nodes be get_leaf_nodes with root as tree["root"]
    Let internal_nodes be get_internal_nodes with root as tree["root"]
    
    Return dictionary with:
        "size" as tree_size
        "depth" as tree_depth
        "is_balanced" as is_balanced
        "leaf_count" as length of leaf_nodes
        "internal_count" as length of internal_nodes
        "comparisons_count" as tree["comparisons_count"]
        "insertions_count" as tree["insertions_count"]
        "deletions_count" as tree["deletions_count"]
        "tree_type" as tree["tree_type"]

Process called "tree_clear" that takes tree as Dictionary returns Dictionary:
    Set tree["root"] to nothing
    Set tree["size"] to 0
    Set tree["comparisons_count"] to 0
    Set tree["insertions_count"] to 0
    Set tree["deletions_count"] to 0
    
    Return tree

Process called "tree_copy" that takes root as Dictionary returns Dictionary:
    If root is nothing:
        Return nothing
    
    Let copied_node be create_tree_node with value as root["value"]
    Set copied_node["left"] to tree_copy with root as root["left"]
    Set copied_node["right"] to tree_copy with root as root["right"]
    
    If copied_node["left"] is not nothing:
        Set copied_node["left"]["parent"] to copied_node
    
    If copied_node["right"] is not nothing:
        Set copied_node["right"]["parent"] to copied_node
    
    Set copied_node["height"] to root["height"]
    Set copied_node["balance_factor"] to root["balance_factor"]
    
    Return copied_node

Process called "tree_validate_bst" that takes root as Dictionary returns Dictionary:
    Let validation_result be validate_bst_recursive with root as root and min_value as nothing and max_value as nothing
    
    Return dictionary with:
        "is_valid_bst" as validation_result["is_valid"]
        "error_message" as validation_result["error_message"]

Process called "validate_bst_recursive" that takes root as Dictionary and min_value as Any and max_value as Any returns Dictionary:
    If root is nothing:
        Return dictionary with:
            "is_valid" as true
            "error_message" as ""
    
    If min_value is not nothing and root["value"] is less than or equal to min_value:
        Return dictionary with:
            "is_valid" as false
            "error_message" as "Node value violates BST property (too small)"
    
    If max_value is not nothing and root["value"] is greater than or equal to max_value:
        Return dictionary with:
            "is_valid" as false
            "error_message" as "Node value violates BST property (too large)"
    
    Let left_result be validate_bst_recursive with root as root["left"] and min_value as min_value and max_value as root["value"]
    If not left_result["is_valid"]:
        Return left_result
    
    Let right_result be validate_bst_recursive with root as root["right"] and min_value as root["value"] and max_value as max_value
    If not right_result["is_valid"]:
        Return right_result
    
    Return dictionary with:
        "is_valid" as true
        "error_message" as ""

Process called "tree_range_query" that takes root as Dictionary and min_value as Any and max_value as Any returns List:
    Let results be list containing
    
    If root is not nothing:
        If root["value"] is greater than or equal to min_value and root["value"] is less than or equal to max_value:
            Add root["value"] to results
        
        If root["value"] is greater than min_value:
            Let left_results be tree_range_query with root as root["left"] and min_value as min_value and max_value as max_value
            For each item in left_results:
                Add item to results
        
        If root["value"] is less than max_value:
            Let right_results be tree_range_query with root as root["right"] and min_value as min_value and max_value as max_value
            For each item in right_results:
                Add item to results
    
    Return results

Process called "tree_bulk_insert" that takes tree as Dictionary and values as List returns Dictionary:
    For each value in values:
        If tree["tree_type"] is equal to "avl_tree":
            Let insert_result be avl_insert with tree as tree and value as value
        Otherwise:
            Let insert_result be bst_insert with tree as tree and value as value
        Set tree to insert_result["tree"]
    
    Return dictionary with:
        "success" as true
        "tree" as tree

Process called "tree_bulk_delete" that takes tree as Dictionary and values as List returns Dictionary:
    Let deleted_count be 0
    
    For each value in values:
        If tree["tree_type"] is equal to "avl_tree":
            Let delete_result be avl_delete with tree as tree and value as value
        Otherwise:
            Let delete_result be bst_delete with tree as tree and value as value
        
        Set tree to delete_result["tree"]
        
        If delete_result["was_deleted"]:
            Set deleted_count to deleted_count plus 1
    
    Return dictionary with:
        "success" as true
        "tree" as tree
        "deleted_count" as deleted_count

Process called "tree_to_sorted_array" that takes tree as Dictionary returns List:
    Return inorder_traversal with root as tree["root"]

Process called "create_tree_from_sorted_array" that takes sorted_array as List and tree_type as String returns Dictionary:
    Let tree be create_empty_bst
    If tree_type is equal to "avl_tree":
        Set tree to create_empty_avl_tree
    
    Let root_result be build_balanced_tree_from_array with sorted_array as sorted_array and start_index as 0 and end_index as length of sorted_array minus 1
    Set tree["root"] to root_result
    Set tree["size"] to length of sorted_array
    
    Return dictionary with:
        "success" as true
        "tree" as tree

Process called "build_balanced_tree_from_array" that takes sorted_array as List and start_index as Integer and end_index as Integer returns Dictionary:
    If start_index is greater than end_index:
        Return nothing
    
    Let mid_index be start_index plus end_index divided by 2
    Let node be create_tree_node with value as sorted_array[mid_index]
    
    Set node["left"] to build_balanced_tree_from_array with sorted_array as sorted_array and start_index as start_index and end_index as mid_index minus 1
    Set node["right"] to build_balanced_tree_from_array with sorted_array as sorted_array and start_index as mid_index plus 1 and end_index as end_index
    
    If node["left"] is not nothing:
        Set node["left"]["parent"] to node
    
    If node["right"] is not nothing:
        Set node["right"]["parent"] to node
    
    Set node to update_tree_height with node as node
    
    Return node