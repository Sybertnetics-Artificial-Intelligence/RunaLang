Note:
Runa Standard Library: Graph Data Structures

Provides comprehensive graph data structures for representing relationships and networks.
Essential for AI systems requiring network analysis, dependency tracking, social network 
analysis, and complex relationship modeling.

Advanced features include:
- Adjacency List representation with efficient Dictionary-based storage
- Weighted and unweighted graphs with flexible edge properties
- Directed and undirected graphs with comprehensive relationship support
- Graph traversal algorithms (BFS, DFS) with optimized path finding
- Shortest path algorithms (Dijkstra, Bellman-Ford) for distance calculations
- Minimum spanning tree algorithms (Kruskal, Prim) for network optimization
- Topological sorting for dependency resolution
- Strongly connected components for network analysis
- Cycle detection for validation and debugging
- Graph analysis utilities for network metrics
- Performance optimizations for large-scale graphs
- Memory-efficient operations with Dictionary-based backing
:End Note

Type Graph is Dictionary with:
    nodes as Dictionary[Any, Dictionary] 
    edges as List[Dictionary]
    directed as Boolean
    weighted as Boolean
    node_count as Integer
    edge_count as Integer

Type GraphNode is Dictionary with:
    id as Any
    data as Any
    neighbors as List[Any]
    in_neighbors as List[Any]
    properties as Dictionary[String, Any]

Type GraphEdge is Dictionary with:
    source as Any
    target as Any
    weight as Float
    properties as Dictionary[String, Any]

Process called "create_empty_graph" that takes directed as Boolean and weighted as Boolean returns Dictionary:
    Return dictionary with:
        nodes as dictionary with:
        edges as list containing
        directed as directed
        weighted as weighted
        node_count as 0
        edge_count as 0

Process called "create_graph_node" that takes id as Any and data as Any returns Dictionary:
    Return dictionary with:
        id as id
        data as data
        neighbors as list containing
        in_neighbors as list containing
        properties as dictionary with:

Process called "create_graph_edge" that takes source as Any and target as Any and weight as Float returns Dictionary:
    Return dictionary with:
        source as source
        target as target
        weight as weight
        properties as dictionary with:

Process called "graph_add_node" that takes graph as Dictionary and node_id as Any and data as Any returns Dictionary:
    If node_id not in graph["nodes"]:
        Let node be create_graph_node with id as node_id and data as data
        Set graph["nodes"][node_id] to node
        Set graph["node_count"] to graph["node_count"] plus 1
    Otherwise:
        Set graph["nodes"][node_id]["data"] to data
    
    Return graph

Process called "graph_add_edge" that takes graph as Dictionary and source as Any and target as Any and weight as Float returns Dictionary:
    Set graph to graph_add_node with graph as graph and node_id as source and data as None
    Set graph to graph_add_node with graph as graph and node_id as target and data as None
    
    If target not in graph["nodes"][source]["neighbors"]:
        Add target to graph["nodes"][source]["neighbors"]
        Add source to graph["nodes"][target]["in_neighbors"]
        
        If not graph["directed"]:
            Add source to graph["nodes"][target]["neighbors"]
            Add target to graph["nodes"][source]["in_neighbors"]
        
        Let edge be create_graph_edge with source as source and target as target and weight as weight
        Add edge to graph["edges"]
        Set graph["edge_count"] to graph["edge_count"] plus 1
    
    Return graph

Process called "graph_remove_node" that takes graph as Dictionary and node_id as Any returns Dictionary:
    If node_id not in graph["nodes"]:
        Return graph
    
    Let neighbors be copy_list with lst as graph["nodes"][node_id]["neighbors"]
    Let in_neighbors be copy_list with lst as graph["nodes"][node_id]["in_neighbors"]
    
    For each neighbor in neighbors:
        Set graph to graph_remove_edge with graph as graph and source as node_id and target as neighbor
    
    For each in_neighbor in in_neighbors:
        Set graph to graph_remove_edge with graph as graph and source as in_neighbor and target as node_id
    
    Remove node_id from graph["nodes"]
    Set graph["node_count"] to graph["node_count"] minus 1
    
    Return graph

Process called "graph_remove_edge" that takes graph as Dictionary and source as Any and target as Any returns Dictionary:
    If source not in graph["nodes"] or target not in graph["nodes"]:
        Return graph
    
    If target in graph["nodes"][source]["neighbors"]:
        Remove target from graph["nodes"][source]["neighbors"]
        Remove source from graph["nodes"][target]["in_neighbors"]
        
        If not graph["directed"]:
            Remove source from graph["nodes"][target]["neighbors"]
            Remove target from graph["nodes"][source]["in_neighbors"]
        
        Let new_edges be list containing
        For each edge in graph["edges"]:
            If not (edge["source"] is equal to source and edge["target"] is equal to target):
                If graph["directed"] or not (edge["source"] is equal to target and edge["target"] is equal to source):
                    Add edge to new_edges
        
        Set graph["edges"] to new_edges
        Set graph["edge_count"] to graph["edge_count"] minus 1
    
    Return graph

Process called "graph_get_neighbors" that takes graph as Dictionary and node_id as Any returns List[Any]:
    If node_id in graph["nodes"]:
        Return copy_list with lst as graph["nodes"][node_id]["neighbors"]
    Otherwise:
        Return list containing

Process called "graph_get_in_neighbors" that takes graph as Dictionary and node_id as Any returns List[Any]:
    If node_id in graph["nodes"]:
        Return copy_list with lst as graph["nodes"][node_id]["in_neighbors"]
    Otherwise:
        Return list containing

Process called "graph_get_degree" that takes graph as Dictionary and node_id as Any returns Integer:
    If node_id in graph["nodes"]:
        Return length of graph["nodes"][node_id]["neighbors"]
    Otherwise:
        Return 0

Process called "graph_get_in_degree" that takes graph as Dictionary and node_id as Any returns Integer:
    If node_id in graph["nodes"]:
        Return length of graph["nodes"][node_id]["in_neighbors"]
    Otherwise:
        Return 0

Process called "graph_get_out_degree" that takes graph as Dictionary and node_id as Any returns Integer:
    Return graph_get_degree with graph as graph and node_id as node_id

Process called "graph_contains_node" that takes graph as Dictionary and node_id as Any returns Boolean:
    Return node_id in graph["nodes"]

Process called "graph_contains_edge" that takes graph as Dictionary and source as Any and target as Any returns Boolean:
    If source not in graph["nodes"]:
        Return false
    
    Return target in graph["nodes"][source]["neighbors"]

Process called "graph_get_node_data" that takes graph as Dictionary and node_id as Any returns Any:
    If node_id in graph["nodes"]:
        Return graph["nodes"][node_id]["data"]
    Otherwise:
        Return None

Process called "graph_set_node_data" that takes graph as Dictionary and node_id as Any and data as Any returns Dictionary:
    If node_id in graph["nodes"]:
        Set graph["nodes"][node_id]["data"] to data
    
    Return graph

Process called "graph_get_edge_weight" that takes graph as Dictionary and source as Any and target as Any returns Float:
    For each edge in graph["edges"]:
        If edge["source"] is equal to source and edge["target"] is equal to target:
            Return edge["weight"]
    
    Return 1.0

Process called "graph_set_edge_weight" that takes graph as Dictionary and source as Any and target as Any and weight as Float returns Dictionary:
    For each edge in graph["edges"]:
        If edge["source"] is equal to source and edge["target"] is equal to target:
            Set edge["weight"] to weight
            Break
    
    Return graph

Process called "graph_get_all_nodes" that takes graph as Dictionary returns List[Any]:
    Let result be list containing
    
    For each node_id and node_data in graph["nodes"]:
        Add node_id to result
    
    Return result

Process called "graph_get_all_edges" that takes graph as Dictionary returns List[Dictionary]:
    Return copy_list with lst as graph["edges"]

Process called "graph_is_empty" that takes graph as Dictionary returns Boolean:
    Return graph["node_count"] is equal to 0

Process called "graph_size" that takes graph as Dictionary returns Integer:
    Return graph["node_count"]

Process called "graph_edge_count" that takes graph as Dictionary returns Integer:
    Return graph["edge_count"]

Process called "graph_breadth_first_search" that takes graph as Dictionary and start as Any returns List[Any]:
    If start not in graph["nodes"]:
        Return list containing
    
    Let visited be dictionary with:
    Let queue be list containing start
    Let result be list containing
    Set visited[start] to true
    
    While length of queue is greater than 0:
        Let current be queue[0]
        Set queue to remove_at_index with lst as queue and index as 0
        Add current to result
        
        For each neighbor in graph["nodes"][current]["neighbors"]:
            If neighbor not in visited:
                Set visited[neighbor] to true
                Add neighbor to queue
    
    Return result

Process called "graph_depth_first_search" that takes graph as Dictionary and start as Any returns List[Any]:
    If start not in graph["nodes"]:
        Return list containing
    
    Let visited be dictionary with:
    Let result be list containing
    Set result to graph_dfs_recursive with graph as graph and node as start and visited as visited and result as result
    
    Return result

Process called "graph_dfs_recursive" that takes graph as Dictionary and node as Any and visited as Dictionary and result as List[Any] returns List[Any]:
    If node in visited:
        Return result
    
    Set visited[node] to true
    Add node to result
    
    For each neighbor in graph["nodes"][node]["neighbors"]:
        Set result to graph_dfs_recursive with graph as graph and node as neighbor and visited as visited and result as result
    
    Return result

Process called "graph_depth_first_search_iterative" that takes graph as Dictionary and start as Any returns List[Any]:
    If start not in graph["nodes"]:
        Return list containing
    
    Let visited be dictionary with:
    Let stack be list containing start
    Let result be list containing
    
    While length of stack is greater than 0:
        Let current be stack[length of stack minus 1]
        Set stack to remove_at_index with lst as stack and index as length of stack minus 1
        
        If current not in visited:
            Set visited[current] to true
            Add current to result
            
            For each neighbor in graph["nodes"][current]["neighbors"]:
                If neighbor not in visited:
                    Add neighbor to stack
    
    Return result

Process called "graph_dijkstra_shortest_path" that takes graph as Dictionary and start as Any and end as Any returns Dictionary:
    If start not in graph["nodes"] or end not in graph["nodes"]:
        Return dictionary with:
            path as list containing
            distance as 999999.0
            found as false
    
    Let distances be dictionary with:
    Let previous be dictionary with:
    Let unvisited be dictionary with:
    
    For each node_id and node_data in graph["nodes"]:
        Set distances[node_id] to 999999.0
        Set previous[node_id] to None
        Set unvisited[node_id] to true
    
    Set distances[start] to 0.0
    
    While dictionary_size with dict as unvisited is greater than 0:
        Let current be None
        Let min_distance be 999999.0
        
        For each node_id and value in unvisited:
            If distances[node_id] is less than min_distance:
                Set current to node_id
                Set min_distance to distances[node_id]
        
        If current is None or current is equal to end:
            Break
        
        Remove current from unvisited
        
        For each neighbor in graph["nodes"][current]["neighbors"]:
            If neighbor in unvisited:
                Let edge_weight be graph_get_edge_weight with graph as graph and source as current and target as neighbor
                Let new_distance be distances[current] plus edge_weight
                
                If new_distance is less than distances[neighbor]:
                    Set distances[neighbor] to new_distance
                    Set previous[neighbor] to current
    
    If distances[end] is equal to 999999.0:
        Return dictionary with:
            path as list containing
            distance as 999999.0
            found as false
    
    Let path be list containing
    Let current be end
    
    While current is not None:
        Set path to prepend_to_list with lst as path and item as current
        Set current to previous[current]
    
    Return dictionary with:
        path as path
        distance as distances[end]
        found as true

Process called "graph_bellman_ford_shortest_paths" that takes graph as Dictionary and start as Any returns Dictionary:
    Let distances be dictionary with:
    Let previous be dictionary with:
    Let has_negative_cycle be false
    
    For each node_id and node_data in graph["nodes"]:
        Set distances[node_id] to 999999.0
        Set previous[node_id] to None
    
    Set distances[start] to 0.0
    
    For i from 1 to graph["node_count"] minus 1:
        For each edge in graph["edges"]:
            Let u be edge["source"]
            Let v be edge["target"]
            Let weight be edge["weight"]
            
            If distances[u] is not equal to 999999.0 and distances[u] plus weight is less than distances[v]:
                Set distances[v] to distances[u] plus weight
                Set previous[v] to u
    
    For each edge in graph["edges"]:
        Let u be edge["source"]
        Let v be edge["target"]
        Let weight be edge["weight"]
        
        If distances[u] is not equal to 999999.0 and distances[u] plus weight is less than distances[v]:
            Set has_negative_cycle to true
            Break
    
    Return dictionary with:
        distances as distances
        previous as previous
        has_negative_cycle as has_negative_cycle

Process called "graph_kruskal_mst" that takes graph as Dictionary returns List[Dictionary]:
    If graph["directed"]:
        Return list containing
    
    Let mst be list containing
    Let edges be copy_list with lst as graph["edges"]
    Let sorted_edges be sort_edges_by_weight with edges as edges
    Let parent be dictionary with:
    Let rank be dictionary with:
    
    For each node_id and node_data in graph["nodes"]:
        Set parent[node_id] to node_id
        Set rank[node_id] to 0
    
    For each edge in sorted_edges:
        Let root1 be find_set_root with parent as parent and x as edge["source"]
        Let root2 be find_set_root with parent as parent and x as edge["target"]
        
        If root1 is not equal to root2:
            Add edge to mst
            Set parent to union_sets_by_rank with parent as parent and rank as rank and x as root1 and y as root2
    
    Return mst

Process called "graph_prim_mst" that takes graph as Dictionary and start as Any returns List[Dictionary]:
    If graph["directed"] or start not in graph["nodes"]:
        Return list containing
    
    Let mst be list containing
    Let visited be dictionary with:
    Let edges be list containing
    
    Set visited[start] to true
    
    For each neighbor in graph["nodes"][start]["neighbors"]:
        Let weight be graph_get_edge_weight with graph as graph and source as start and target as neighbor
        Add create_graph_edge with source as start and target as neighbor and weight as weight to edges
    
    While length of edges is greater than 0:
        Let min_edge be None
        Let min_weight be 999999.0
        Let min_index be 0
        
        For i from 0 to length of edges:
            Let edge be edges[i]
            If edge["target"] not in visited and edge["weight"] is less than min_weight:
                Set min_edge to edge
                Set min_weight to edge["weight"]
                Set min_index to i
        
        If min_edge is None:
            Break
        
        Set edges to remove_at_index with lst as edges and index as min_index
        Add min_edge to mst
        Set visited[min_edge["target"]] to true
        
        For each neighbor in graph["nodes"][min_edge["target"]]["neighbors"]:
            If neighbor not in visited:
                Let weight be graph_get_edge_weight with graph as graph and source as min_edge["target"] and target as neighbor
                Add create_graph_edge with source as min_edge["target"] and target as neighbor and weight as weight to edges
    
    Return mst

Process called "graph_topological_sort" that takes graph as Dictionary returns List[Any]:
    If not graph["directed"]:
        Return list containing
    
    Let in_degree be dictionary with:
    Let queue be list containing
    Let result be list containing
    
    For each node_id and node_data in graph["nodes"]:
        Set in_degree[node_id] to graph_get_in_degree with graph as graph and node_id as node_id
        If in_degree[node_id] is equal to 0:
            Add node_id to queue
    
    While length of queue is greater than 0:
        Let current be queue[0]
        Set queue to remove_at_index with lst as queue and index as 0
        Add current to result
        
        For each neighbor in graph["nodes"][current]["neighbors"]:
            Set in_degree[neighbor] to in_degree[neighbor] minus 1
            If in_degree[neighbor] is equal to 0:
                Add neighbor to queue
    
    If length of result is not equal to graph["node_count"]:
        Return list containing
    
    Return result

Process called "graph_has_cycle" that takes graph as Dictionary returns Boolean:
    If graph["directed"]:
        Return graph_has_cycle_directed with graph as graph
    Otherwise:
        Return graph_has_cycle_undirected with graph as graph

Process called "graph_has_cycle_directed" that takes graph as Dictionary returns Boolean:
    Let visited be dictionary with:
    Let rec_stack be dictionary with:
    
    For each node_id and node_data in graph["nodes"]:
        If node_id not in visited:
            If graph_has_cycle_dfs_directed with graph as graph and node as node_id and visited as visited and rec_stack as rec_stack:
                Return true
    
    Return false

Process called "graph_has_cycle_dfs_directed" that takes graph as Dictionary and node as Any and visited as Dictionary and rec_stack as Dictionary returns Boolean:
    Set visited[node] to true
    Set rec_stack[node] to true
    
    For each neighbor in graph["nodes"][node]["neighbors"]:
        If neighbor not in visited:
            If graph_has_cycle_dfs_directed with graph as graph and node as neighbor and visited as visited and rec_stack as rec_stack:
                Return true
        Otherwise if neighbor in rec_stack:
            Return true
    
    Remove node from rec_stack
    Return false

Process called "graph_has_cycle_undirected" that takes graph as Dictionary returns Boolean:
    Let visited be dictionary with:
    
    For each node_id and node_data in graph["nodes"]:
        If node_id not in visited:
            If graph_has_cycle_dfs_undirected with graph as graph and node as node_id and visited as visited and parent as None:
                Return true
    
    Return false

Process called "graph_has_cycle_dfs_undirected" that takes graph as Dictionary and node as Any and visited as Dictionary and parent as Any returns Boolean:
    Set visited[node] to true
    
    For each neighbor in graph["nodes"][node]["neighbors"]:
        If neighbor not in visited:
            If graph_has_cycle_dfs_undirected with graph as graph and node as neighbor and visited as visited and parent as node:
                Return true
        Otherwise if neighbor is not equal to parent:
            Return true
    
    Return false

Process called "graph_strongly_connected_components" that takes graph as Dictionary returns List[List[Any]]:
    If not graph["directed"]:
        Return list containing
    
    Let visited be dictionary with:
    Let finish_order be list containing
    
    For each node_id and node_data in graph["nodes"]:
        If node_id not in visited:
            Set finish_order to graph_dfs_fill_order with graph as graph and node as node_id and visited as visited and order as finish_order
    
    Let transposed_graph be graph_transpose with graph as graph
    Let visited be dictionary with:
    Let components be list containing
    
    For i from length of finish_order minus 1 to 0 by -1:
        Let node be finish_order[i]
        If node not in visited:
            Let component be graph_dfs_recursive with graph as transposed_graph and node as node and visited as visited and result as list containing
            Add component to components
    
    Return components

Process called "graph_dfs_fill_order" that takes graph as Dictionary and node as Any and visited as Dictionary and order as List[Any] returns List[Any]:
    Set visited[node] to true
    
    For each neighbor in graph["nodes"][node]["neighbors"]:
        If neighbor not in visited:
            Set order to graph_dfs_fill_order with graph as graph and node as neighbor and visited as visited and order as order
    
    Add node to order
    Return order

Process called "graph_transpose" that takes graph as Dictionary returns Dictionary:
    Let transposed be create_empty_graph with directed as true and weighted as graph["weighted"]
    
    For each node_id and node_data in graph["nodes"]:
        Set transposed to graph_add_node with graph as transposed and node_id as node_id and data as node_data["data"]
    
    For each edge in graph["edges"]:
        Set transposed to graph_add_edge with graph as transposed and source as edge["target"] and target as edge["source"] and weight as edge["weight"]
    
    Return transposed

Process called "graph_is_connected" that takes graph as Dictionary returns Boolean:
    If graph["node_count"] is equal to 0:
        Return true
    
    Let nodes_list be graph_get_all_nodes with graph as graph
    If length of nodes_list is equal to 0:
        Return true
    
    Let start be nodes_list[0]
    Let visited_nodes be graph_breadth_first_search with graph as graph and start as start
    
    Return length of visited_nodes is equal to graph["node_count"]

Process called "graph_get_connected_components" that takes graph as Dictionary returns List[List[Any]]:
    Let visited be dictionary with:
    Let components be list containing
    
    For each node_id and node_data in graph["nodes"]:
        If node_id not in visited:
            Let component be graph_breadth_first_search with graph as graph and start as node_id
            For each node in component:
                Set visited[node] to true
            Add component to components
    
    Return components

Process called "graph_get_density" that takes graph as Dictionary returns Float:
    Let n be graph["node_count"]
    If n is less than or equal to 1:
        Return 0.0
    
    Let max_edges be n multiplied by (n minus 1)
    If not graph["directed"]:
        Set max_edges to max_edges divided by 2
    
    Return graph["edge_count"] as Float divided by max_edges as Float

Process called "graph_get_average_degree" that takes graph as Dictionary returns Float:
    If graph["node_count"] is equal to 0:
        Return 0.0
    
    Let total_degree be 0
    For each node_id and node_data in graph["nodes"]:
        Set total_degree to total_degree plus graph_get_degree with graph as graph and node_id as node_id
    
    Return total_degree as Float divided by graph["node_count"] as Float

Process called "graph_get_isolated_nodes" that takes graph as Dictionary returns List[Any]:
    Let isolated be list containing
    
    For each node_id and node_data in graph["nodes"]:
        If graph_get_degree with graph as graph and node_id as node_id is equal to 0:
            Add node_id to isolated
    
    Return isolated

Process called "graph_get_leaf_nodes" that takes graph as Dictionary returns List[Any]:
    Let leaves be list containing
    
    For each node_id and node_data in graph["nodes"]:
        If graph_get_degree with graph as graph and node_id as node_id is equal to 1:
            Add node_id to leaves
    
    Return leaves

Process called "graph_statistics" that takes graph as Dictionary returns Dictionary[String, Any]:
    Let stats be dictionary with:
    
    Set stats["node_count"] to graph["node_count"]
    Set stats["edge_count"] to graph["edge_count"]
    Set stats["is_directed"] to graph["directed"]
    Set stats["is_weighted"] to graph["weighted"]
    Set stats["is_empty"] to graph_is_empty with graph as graph
    Set stats["is_connected"] to graph_is_connected with graph as graph
    Set stats["density"] to graph_get_density with graph as graph
    Set stats["average_degree"] to graph_get_average_degree with graph as graph
    Set stats["has_cycle"] to graph_has_cycle with graph as graph
    
    Let isolated_nodes be graph_get_isolated_nodes with graph as graph
    Let leaf_nodes be graph_get_leaf_nodes with graph as graph
    Let connected_components be graph_get_connected_components with graph as graph
    
    Set stats["isolated_node_count"] to length of isolated_nodes
    Set stats["leaf_node_count"] to length of leaf_nodes
    Set stats["connected_component_count"] to length of connected_components
    
    If graph["node_count"] is greater than 0:
        Let max_degree be 0
        Let min_degree be 999999
        Let degree_sum be 0
        
        For each node_id and node_data in graph["nodes"]:
            Let degree be graph_get_degree with graph as graph and node_id as node_id
            Set degree_sum to degree_sum plus degree
            
            If degree is greater than max_degree:
                Set max_degree to degree
            
            If degree is less than min_degree:
                Set min_degree to degree
        
        Set stats["max_degree"] to max_degree
        Set stats["min_degree"] to min_degree
        Set stats["total_degree"] to degree_sum
    Otherwise:
        Set stats["max_degree"] to 0
        Set stats["min_degree"] to 0
        Set stats["total_degree"] to 0
    
    Return stats

Process called "sort_edges_by_weight" that takes edges as List[Dictionary] returns List[Dictionary]:
    Let result be copy_list with lst as edges
    Let length be length of result
    
    For i from 0 to length minus 1:
        For j from 0 to length minus i minus 1:
            If result[j]["weight"] is greater than result[j plus 1]["weight"]:
                Let temp be result[j]
                Set result[j] to result[j plus 1]
                Set result[j plus 1] to temp
    
    Return result

Process called "find_set_root" that takes parent as Dictionary and x as Any returns Any:
    If parent[x] is not equal to x:
        Set parent[x] to find_set_root with parent as parent and x as parent[x]
    
    Return parent[x]

Process called "union_sets_by_rank" that takes parent as Dictionary and rank as Dictionary and x as Any and y as Any returns Dictionary:
    Let root_x be find_set_root with parent as parent and x as x
    Let root_y be find_set_root with parent as parent and x as y
    
    If root_x is equal to root_y:
        Return parent
    
    If rank[root_x] is less than rank[root_y]:
        Set parent[root_x] to root_y
    Otherwise if rank[root_x] is greater than rank[root_y]:
        Set parent[root_y] to root_x
    Otherwise:
        Set parent[root_y] to root_x
        Set rank[root_x] to rank[root_x] plus 1
    
    Return parent

Process called "dictionary_size" that takes dict as Dictionary returns Integer:
    Let count be 0
    For each key and value in dict:
        Set count to count plus 1
    Return count

Process called "copy_list" that takes lst as List[Any] returns List[Any]:
    Let result be list containing
    
    For each item in lst:
        Add item to result
    
    Return result

Process called "remove_at_index" that takes lst as List[Any] and index as Integer returns List[Any]:
    Let result be list containing
    
    For i from 0 to length of lst:
        If i is not equal to index:
            Add lst[i] to result
    
    Return result

Process called "prepend_to_list" that takes lst as List[Any] and item as Any returns List[Any]:
    Let result be list containing item
    
    For each existing_item in lst:
        Add existing_item to result
    
    Return result