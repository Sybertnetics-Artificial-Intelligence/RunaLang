Note:
Runa Standard Library: ChainMap (Chained Dictionary View)

Provides a view over multiple dictionaries, searching each in sequence until a key is found.
Essential for AI-to-AI communication where layered configurations, fallback mechanisms,
and hierarchical data access patterns are common.

Advanced features include:
- Layered dictionary access with fallback chains
- Dynamic chain manipulation (new_child, parents)
- Efficient key-value iteration and bulk operations
- Memory-efficient view implementation
- Thread-safe operations (when supported)
:End Note

Type called "ChainMap":
    maps as List[Dictionary[String, Any]]
    cache as Dictionary[String, Integer]
    total_size as Integer

Process called "create_chain_map" that returns ChainMap:
    Return dictionary with:
        maps as list containing
        cache as dictionary with:
        total_size as 0

Process called "create_chain_map_from_maps" that takes maps as List[Dictionary[String, Any]] returns ChainMap:
    Let copied_maps be list containing
    For each dictionary_map in maps:
        Let copied_dict be dictionary with:
        For each key and value in dictionary_map:
            Set copied_dict[key] to value
        Add copied_dict to copied_maps
    
    Let total_size be 0
    For each dictionary_map in copied_maps:
        Let total_size be total_size plus length of dictionary_map
    
    Return dictionary with:
        maps as copied_maps
        cache as dictionary with:
        total_size as total_size

Process called "get_from_chain_map" that takes chain_map as ChainMap and key as String returns Any:
    For each dictionary_map in chain_map["maps"]:
        If key in dictionary_map:
            Return dictionary_map[key]
    
    Throw error "Key '" concatenated with key concatenated with "' not found in any map"

Process called "get_from_chain_map_safe" that takes chain_map as ChainMap and key as String and default_value as Any returns Any:
    For each dictionary_map in chain_map["maps"]:
        If key in dictionary_map:
            Return dictionary_map[key]
    
    Return default_value

Process called "set_in_chain_map" that takes chain_map as ChainMap and key as String and value as Any returns ChainMap:
    If length of chain_map["maps"] is equal to 0:
        Let new_map be dictionary with:
        Set new_map[key] to value
        Add new_map to chain_map["maps"]
        Set chain_map["total_size"] to chain_map["total_size"] plus 1
    Otherwise:
        Let first_map be chain_map["maps"][0]
        If not key in first_map:
            Set chain_map["total_size"] to chain_map["total_size"] plus 1
        Set first_map[key] to value
    
    Return chain_map

Process called "remove_from_chain_map" that takes chain_map as ChainMap and key as String returns ChainMap:
    For each dictionary_map in chain_map["maps"]:
        If key in dictionary_map:
            Remove key from dictionary_map
            Set chain_map["total_size"] to chain_map["total_size"] minus 1
            Return chain_map
    
    Throw error "Key '" concatenated with key concatenated with "' not found in any map"

Process called "remove_from_chain_map_safe" that takes chain_map as ChainMap and key as String returns ChainMap:
    For each dictionary_map in chain_map["maps"]:
        If key in dictionary_map:
            Remove key from dictionary_map
            Set chain_map["total_size"] to chain_map["total_size"] minus 1
            Return chain_map
    
    Return chain_map

Process called "contains_key_in_chain_map" that takes chain_map as ChainMap and key as String returns Boolean:
    For each dictionary_map in chain_map["maps"]:
        If key in dictionary_map:
            Return true
    
    Return false

Process called "get_chain_map_size" that takes chain_map as ChainMap returns Integer:
    Let unique_keys be list containing
    For each dictionary_map in chain_map["maps"]:
        For each key and value in dictionary_map:
            If not key in unique_keys:
                Add key to unique_keys
    
    Return length of unique_keys

Process called "is_chain_map_empty" that takes chain_map as ChainMap returns Boolean:
    Return get_chain_map_size with chain_map as chain_map is equal to 0

Process called "get_chain_map_keys" that takes chain_map as ChainMap returns List[String]:
    Let unique_keys be list containing
    For each dictionary_map in chain_map["maps"]:
        For each key and value in dictionary_map:
            If not key in unique_keys:
                Add key to unique_keys
    
    Return unique_keys

Process called "get_chain_map_values" that takes chain_map as ChainMap returns List[Any]:
    Let keys be get_chain_map_keys with chain_map as chain_map
    Let values be list containing
    For each key in keys:
        Let value be get_from_chain_map with chain_map as chain_map and key as key
        Add value to values
    
    Return values

Process called "get_chain_map_items" that takes chain_map as ChainMap returns List[Tuple[String, Any]]:
    Let keys be get_chain_map_keys with chain_map as chain_map
    Let items be list containing
    For each key in keys:
        Let value be get_from_chain_map with chain_map as chain_map and key as key
        Add (key, value) to items
    
    Return items

Process called "get_chain_map_count" that takes chain_map as ChainMap returns Integer:
    Return length of chain_map["maps"]

Process called "get_map_at_index" that takes chain_map as ChainMap and index as Integer returns Dictionary[String, Any]:
    If index is less than 0 or index is greater than or equal to length of chain_map["maps"]:
        Throw error "Map index " concatenated with index concatenated with " out of bounds"
    
    Return chain_map["maps"][index]

Process called "create_new_child" that takes chain_map as ChainMap and new_map as Dictionary[String, Any] returns ChainMap:
    Let new_maps be list containing new_map
    For each existing_map in chain_map["maps"]:
        Add existing_map to new_maps
    
    Let new_total_size be length of new_map
    For each existing_map in chain_map["maps"]:
        Let new_total_size be new_total_size plus length of existing_map
    
    Return dictionary with:
        maps as new_maps
        cache as dictionary with:
        total_size as new_total_size

Process called "create_new_child_empty" that takes chain_map as ChainMap returns ChainMap:
    Let empty_map be dictionary with:
    Return create_new_child with chain_map as chain_map and new_map as empty_map

Process called "get_parents_chain_map" that takes chain_map as ChainMap returns ChainMap:
    If length of chain_map["maps"] is less than or equal to 1:
        Return create_chain_map
    
    Let parent_maps be list containing
    Let first_skipped be false
    For each existing_map in chain_map["maps"]:
        If first_skipped is equal to true:
            Add existing_map to parent_maps
        Otherwise:
            Let first_skipped be true
    
    Let parent_total_size be 0
    For each parent_map in parent_maps:
        Let parent_total_size be parent_total_size plus length of parent_map
    
    Return dictionary with:
        maps as parent_maps
        cache as dictionary with:
        total_size as parent_total_size

Process called "add_map_to_chain_map" that takes chain_map as ChainMap and new_map as Dictionary[String, Any] returns ChainMap:
    Let updated_maps be list containing
    For each existing_map in chain_map["maps"]:
        Add existing_map to updated_maps
    Add new_map to updated_maps
    
    Let updated_total_size be chain_map["total_size"] plus length of new_map
    
    Return dictionary with:
        maps as updated_maps
        cache as chain_map["cache"]
        total_size as updated_total_size

Process called "remove_map_at_index" that takes chain_map as ChainMap and index as Integer returns ChainMap:
    If index is less than 0 or index is greater than or equal to length of chain_map["maps"]:
        Throw error "Map index " concatenated with index concatenated with " out of bounds"
    
    Let updated_maps be list containing
    Let current_index be 0
    Let removed_map_size be 0
    
    For each existing_map in chain_map["maps"]:
        If current_index is not equal to index:
            Add existing_map to updated_maps
        Otherwise:
            Let removed_map_size be length of existing_map
        Let current_index be current_index plus 1
    
    Let updated_total_size be chain_map["total_size"] minus removed_map_size
    
    Return dictionary with:
        maps as updated_maps
        cache as dictionary with:
        total_size as updated_total_size

Process called "clear_chain_map" that takes chain_map as ChainMap returns ChainMap:
    Return dictionary with:
        maps as list containing
        cache as dictionary with:
        total_size as 0

Process called "update_chain_map" that takes chain_map as ChainMap and other as Dictionary[String, Any] returns ChainMap:
    If length of chain_map["maps"] is equal to 0:
        Let new_map be dictionary with:
        For each key and value in other:
            Set new_map[key] to value
        Add new_map to chain_map["maps"]
        Set chain_map["total_size"] to length of new_map
    Otherwise:
        Let first_map be chain_map["maps"][0]
        Let added_count be 0
        For each key and value in other:
            If not key in first_map:
                Let added_count be added_count plus 1
            Set first_map[key] to value
        Set chain_map["total_size"] to chain_map["total_size"] plus added_count
    
    Return chain_map

Process called "update_chain_map_from_chain_map" that takes chain_map as ChainMap and other as ChainMap returns ChainMap:
    Let other_items be get_chain_map_items with chain_map as other
    For each item_pair in other_items:
        Let key be item_pair[0]
        Let value be item_pair[1]
        Let chain_map be set_in_chain_map with chain_map as chain_map and key as key and value as value
    
    Return chain_map

Process called "copy_chain_map" that takes chain_map as ChainMap returns ChainMap:
    Let copied_maps be list containing
    For each existing_map in chain_map["maps"]:
        Let copied_map be dictionary with:
        For each key and value in existing_map:
            Set copied_map[key] to value
        Add copied_map to copied_maps
    
    Return dictionary with:
        maps as copied_maps
        cache as dictionary with:
        total_size as chain_map["total_size"]

Process called "filter_chain_map_keys" that takes chain_map as ChainMap and predicate as Process returns ChainMap:
    Let keys be get_chain_map_keys with chain_map as chain_map
    Let result be create_chain_map
    
    For each key in keys:
        If predicate with key as key is equal to true:
            Let value be get_from_chain_map with chain_map as chain_map and key as key
            Let result be set_in_chain_map with chain_map as result and key as key and value as value
    
    Return result

Process called "filter_chain_map_values" that takes chain_map as ChainMap and predicate as Process returns ChainMap:
    Let items be get_chain_map_items with chain_map as chain_map
    Let result be create_chain_map
    
    For each item_pair in items:
        Let key be item_pair[0]
        Let value be item_pair[1]
        If predicate with value as value is equal to true:
            Let result be set_in_chain_map with chain_map as result and key as key and value as value
    
    Return result

Process called "map_chain_map_keys" that takes chain_map as ChainMap and transform as Process returns ChainMap:
    Let items be get_chain_map_items with chain_map as chain_map
    Let result be create_chain_map
    
    For each item_pair in items:
        Let key be item_pair[0]
        Let value be item_pair[1]
        Let new_key be transform with key as key
        Let result be set_in_chain_map with chain_map as result and key as new_key and value as value
    
    Return result

Process called "map_chain_map_values" that takes chain_map as ChainMap and transform as Process returns ChainMap:
    Let items be get_chain_map_items with chain_map as chain_map
    Let result be create_chain_map
    
    For each item_pair in items:
        Let key be item_pair[0]
        Let value be item_pair[1]
        Let new_value be transform with value as value
        Let result be set_in_chain_map with chain_map as result and key as key and value as new_value
    
    Return result

Process called "chain_map_to_dictionary" that takes chain_map as ChainMap returns Dictionary[String, Any]:
    Let items be get_chain_map_items with chain_map as chain_map
    Let result be dictionary with:
    
    For each item_pair in items:
        Let key be item_pair[0]
        Let value be item_pair[1]
        Set result[key] to value
    
    Return result

Process called "dictionary_to_chain_map" that takes dictionary as Dictionary[String, Any] returns ChainMap:
    Let chain_map be create_chain_map
    Return update_chain_map with chain_map as chain_map and other as dictionary

Process called "merge_chain_maps" that takes chain_maps as List[ChainMap] returns ChainMap:
    If length of chain_maps is equal to 0:
        Return create_chain_map
    
    Let result be chain_maps[0]
    Let index be 1
    
    While index is less than length of chain_maps:
        Let current_chain_map be chain_maps[index]
        Let result be update_chain_map_from_chain_map with chain_map as result and other as current_chain_map
        Let index be index plus 1
    
    Return result

Process called "flatten_chain_map" that takes chain_map as ChainMap returns Dictionary[String, Any]:
    Return chain_map_to_dictionary with chain_map as chain_map

Process called "get_all_values_for_key" that takes chain_map as ChainMap and key as String returns List[Any]:
    Let values be list containing
    For each dictionary_map in chain_map["maps"]:
        If key in dictionary_map:
            Let value be dictionary_map[key]
            Add value to values
    
    Return values

Process called "get_first_value_for_key" that takes chain_map as ChainMap and key as String returns Any:
    Return get_from_chain_map with chain_map as chain_map and key as key

Process called "get_last_value_for_key" that takes chain_map as ChainMap and key as String returns Any:
    Let last_value be None
    Let found be false
    
    For each dictionary_map in chain_map["maps"]:
        If key in dictionary_map:
            Let last_value be dictionary_map[key]
            Let found be true
    
    If found is equal to true:
        Return last_value
    
    Throw error "Key '" concatenated with key concatenated with "' not found in any map"

Process called "get_chain_map_statistics" that takes chain_map as ChainMap returns Dictionary[String, Any]:
    Let stats be dictionary with:
    Set stats["map_count"] to length of chain_map["maps"]
    Set stats["total_size"] to chain_map["total_size"]
    Set stats["unique_keys"] to get_chain_map_size with chain_map as chain_map
    
    Let map_sizes be list containing
    For each dictionary_map in chain_map["maps"]:
        Let map_size be length of dictionary_map
        Add map_size to map_sizes
    Set stats["individual_map_sizes"] to map_sizes
    
    Let average_map_size be 0
    If length of chain_map["maps"] is greater than 0:
        Let total_items be 0
        For each size in map_sizes:
            Let total_items be total_items plus size
        Let average_map_size be total_items divided by length of chain_map["maps"]
    Set stats["average_map_size"] to average_map_size
    
    Return stats