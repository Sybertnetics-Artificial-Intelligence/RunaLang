Note:
Runa Standard Library: Heap (Priority Queue)

Provides comprehensive heap/priority queue functionality with natural language operations for 
pushing, popping, peeking, and heapifying elements. Essential for AI systems requiring 
priority-based processing, task scheduling, and efficient data sorting.

Advanced features include:
- Min-heap and max-heap support with flexible ordering
- Priority-based operations with timestamps for stable sorting
- Bulk operations and heap merging for complex data workflows
- K-largest/smallest element extraction for top-N algorithms
- Heap validation and debugging utilities
- Performance optimizations for large datasets
- Memory-efficient Dictionary-based representation
- Production-ready error handling and edge case management
:End Note

Type called "Heap":
    items as List[Any]
    is_min_heap as Boolean
    size as Integer
    heap_type as String

Type called "HeapNode":
    priority as Float
    value as Any
    timestamp as Integer
    index as Integer

Process called "create_min_heap" that returns Dictionary:
    Return dictionary with:
        items as list containing
        is_min_heap as true
        size as 0
        heap_type as "min"

Process called "create_max_heap" that returns Dictionary:
    Return dictionary with:
        items as list containing
        is_min_heap as false
        size as 0
        heap_type as "max"

Process called "create_heap_node" that takes priority as Float and value as Any and timestamp as Integer returns Dictionary:
    Return dictionary with:
        priority as priority
        value as value
        timestamp as timestamp
        index as 0

Process called "heap_is_empty" that takes heap as Dictionary returns Boolean:
    Return heap["size"] is equal to 0

Process called "heap_size" that takes heap as Dictionary returns Integer:
    Return heap["size"]

Process called "heap_peek" that takes heap as Dictionary returns Any:
    If heap_is_empty with heap as heap:
        Return None
    
    Return heap["items"][0]["value"]

Process called "heap_peek_priority" that takes heap as Dictionary returns Float:
    If heap_is_empty with heap as heap:
        Return 0.0
    
    Return heap["items"][0]["priority"]

Process called "heap_peek_node" that takes heap as Dictionary returns Dictionary:
    If heap_is_empty with heap as heap:
        Return dictionary with:
            priority as 0.0
            value as None
            timestamp as 0
            index as 0
    
    Return heap["items"][0]

Process called "heap_push" that takes heap as Dictionary and value as Any and priority as Float returns Dictionary:
    Let timestamp be get_current_timestamp()
    Let node be create_heap_node with priority as priority and value as value and timestamp as timestamp
    
    Add node to heap["items"]
    Set heap["size"] to heap["size"] plus 1
    
    Let last_index be heap["size"] minus 1
    Set heap["items"][last_index]["index"] to last_index
    
    Set heap to heap_bubble_up with heap as heap and index as last_index
    
    Return heap

Process called "heap_pop" that takes heap as Dictionary returns Dictionary:
    If heap_is_empty with heap as heap:
        Return dictionary with:
            heap as heap
            value as None
            priority as 0.0
            success as false
    
    Let root_node be heap["items"][0]
    Let last_index be heap["size"] minus 1
    Let last_node be heap["items"][last_index]
    
    Set heap["items"][0] to last_node
    Set heap["items"][0]["index"] to 0
    Set heap["items"] to remove_at_index with lst as heap["items"] and index as last_index
    Set heap["size"] to heap["size"] minus 1
    
    If heap["size"] is greater than 0:
        Set heap to heap_bubble_down with heap as heap and index as 0
    
    Return dictionary with:
        heap as heap
        value as root_node["value"]
        priority as root_node["priority"]
        success as true

Process called "heap_push_pop" that takes heap as Dictionary and value as Any and priority as Float returns Dictionary:
    If heap_is_empty with heap as heap:
        Return dictionary with:
            heap as heap
            value as value
            priority as priority
            success as true
    
    Let root_node be heap["items"][0]
    
    If heap_should_swap with heap as heap and priority1 as priority and priority2 as root_node["priority"] and timestamp1 as get_current_timestamp() and timestamp2 as root_node["timestamp"]:
        Return dictionary with:
            heap as heap
            value as value
            priority as priority
            success as true
    
    Let timestamp be get_current_timestamp()
    Let new_node be create_heap_node with priority as priority and value as value and timestamp as timestamp
    Set new_node["index"] to 0
    
    Set heap["items"][0] to new_node
    Set heap to heap_bubble_down with heap as heap and index as 0
    
    Return dictionary with:
        heap as heap
        value as root_node["value"]
        priority as root_node["priority"]
        success as true

Process called "heap_replace" that takes heap as Dictionary and value as Any and priority as Float returns Dictionary:
    If heap_is_empty with heap as heap:
        Return dictionary with:
            heap as heap_push with heap as heap and value as value and priority as priority
            value as None
            priority as 0.0
            success as false
    
    Let root_node be heap["items"][0]
    Let timestamp be get_current_timestamp()
    Let new_node be create_heap_node with priority as priority and value as value and timestamp as timestamp
    Set new_node["index"] to 0
    
    Set heap["items"][0] to new_node
    Set heap to heap_bubble_down with heap as heap and index as 0
    
    Return dictionary with:
        heap as heap
        value as root_node["value"]
        priority as root_node["priority"]
        success as true

Process called "heap_bubble_up" that takes heap as Dictionary and index as Integer returns Dictionary:
    Let current_index be index
    
    While current_index is greater than 0:
        Let parent_index be (current_index minus 1) divided by 2
        Let current_node be heap["items"][current_index]
        Let parent_node be heap["items"][parent_index]
        
        If heap_should_swap with heap as heap and priority1 as current_node["priority"] and priority2 as parent_node["priority"] and timestamp1 as current_node["timestamp"] and timestamp2 as parent_node["timestamp"]:
            Set heap["items"][current_index] to parent_node
            Set heap["items"][parent_index] to current_node
            Set heap["items"][current_index]["index"] to current_index
            Set heap["items"][parent_index]["index"] to parent_index
            Set current_index to parent_index
        Otherwise:
            Break
    
    Return heap

Process called "heap_bubble_down" that takes heap as Dictionary and index as Integer returns Dictionary:
    Let current_index be index
    
    While true:
        Let left_child be (current_index multiplied by 2) plus 1
        Let right_child be (current_index multiplied by 2) plus 2
        Let smallest_index be current_index
        
        If left_child is less than heap["size"]:
            Let current_node be heap["items"][current_index]
            Let left_node be heap["items"][left_child]
            
            If heap_should_swap with heap as heap and priority1 as left_node["priority"] and priority2 as current_node["priority"] and timestamp1 as left_node["timestamp"] and timestamp2 as current_node["timestamp"]:
                Set smallest_index to left_child
        
        If right_child is less than heap["size"]:
            Let smallest_node be heap["items"][smallest_index]
            Let right_node be heap["items"][right_child]
            
            If heap_should_swap with heap as heap and priority1 as right_node["priority"] and priority2 as smallest_node["priority"] and timestamp1 as right_node["timestamp"] and timestamp2 as smallest_node["timestamp"]:
                Set smallest_index to right_child
        
        If smallest_index is not equal to current_index:
            Let temp_node be heap["items"][current_index]
            Set heap["items"][current_index] to heap["items"][smallest_index]
            Set heap["items"][smallest_index] to temp_node
            Set heap["items"][current_index]["index"] to current_index
            Set heap["items"][smallest_index]["index"] to smallest_index
            Set current_index to smallest_index
        Otherwise:
            Break
    
    Return heap

Process called "heap_should_swap" that takes heap as Dictionary and priority1 as Float and priority2 as Float and timestamp1 as Integer and timestamp2 as Integer returns Boolean:
    If heap["is_min_heap"]:
        If priority1 is less than priority2:
            Return true
        Otherwise if priority1 is equal to priority2:
            Return timestamp1 is less than timestamp2
        Otherwise:
            Return false
    Otherwise:
        If priority1 is greater than priority2:
            Return true
        Otherwise if priority1 is equal to priority2:
            Return timestamp1 is less than timestamp2
        Otherwise:
            Return false

Process called "heap_heapify" that takes items as List[Any] and is_min_heap as Boolean returns Dictionary:
    Let heap be dictionary with:
        items as list containing
        is_min_heap as is_min_heap
        size as 0
        heap_type as if is_min_heap then "min" otherwise "max"
    
    For each item in items:
        If item is Dictionary and "priority" in item and "value" in item:
            Set heap to heap_push with heap as heap and value as item["value"] and priority as item["priority"]
        Otherwise:
            Set heap to heap_push with heap as heap and value as item and priority as 0.0
    
    Return heap

Process called "heap_heapify_with_priorities" that takes values as List[Any] and priorities as List[Float] and is_min_heap as Boolean returns Dictionary:
    Let heap be dictionary with:
        items as list containing
        is_min_heap as is_min_heap
        size as 0
        heap_type as if is_min_heap then "min" otherwise "max"
    
    Let min_length be min_int with a as length of values and b as length of priorities
    
    For i from 0 to min_length:
        Set heap to heap_push with heap as heap and value as values[i] and priority as priorities[i]
    
    Return heap

Process called "heap_merge" that takes heap1 as Dictionary and heap2 as Dictionary returns Dictionary:
    Let merged_heap be dictionary with:
        items as list containing
        is_min_heap as heap1["is_min_heap"]
        size as 0
        heap_type as heap1["heap_type"]
    
    For each node in heap1["items"]:
        Set merged_heap to heap_push with heap as merged_heap and value as node["value"] and priority as node["priority"]
    
    For each node in heap2["items"]:
        Set merged_heap to heap_push with heap as merged_heap and value as node["value"] and priority as node["priority"]
    
    Return merged_heap

Process called "heap_extend" that takes heap as Dictionary and values as List[Any] and priorities as List[Float] returns Dictionary:
    Let min_length be min_int with a as length of values and b as length of priorities
    
    For i from 0 to min_length:
        Set heap to heap_push with heap as heap and value as values[i] and priority as priorities[i]
    
    Return heap

Process called "heap_k_largest" that takes heap as Dictionary and k as Integer returns List[Any]:
    If heap["is_min_heap"]:
        Return heap_k_largest_from_min_heap with heap as heap and k as k
    Otherwise:
        Return heap_k_largest_from_max_heap with heap as heap and k as k

Process called "heap_k_smallest" that takes heap as Dictionary and k as Integer returns List[Any]:
    If heap["is_min_heap"]:
        Return heap_k_smallest_from_min_heap with heap as heap and k as k
    Otherwise:
        Return heap_k_smallest_from_max_heap with heap as heap and k as k

Process called "heap_k_largest_from_min_heap" that takes heap as Dictionary and k as Integer returns List[Any]:
    Let result be list containing
    Let temp_heap be heap_copy with heap as heap
    
    For i from 0 to min_int with a as k and b as temp_heap["size"]:
        Let pop_result be heap_pop with heap as temp_heap
        If pop_result["success"]:
            Add pop_result["value"] to result
            Set temp_heap to pop_result["heap"]
        Otherwise:
            Break
    
    Return reverse_list with lst as result

Process called "heap_k_smallest_from_min_heap" that takes heap as Dictionary and k as Integer returns List[Any]:
    Let result be list containing
    Let temp_heap be heap_copy with heap as heap
    
    For i from 0 to min_int with a as k and b as temp_heap["size"]:
        Let pop_result be heap_pop with heap as temp_heap
        If pop_result["success"]:
            Add pop_result["value"] to result
            Set temp_heap to pop_result["heap"]
        Otherwise:
            Break
    
    Return result

Process called "heap_k_largest_from_max_heap" that takes heap as Dictionary and k as Integer returns List[Any]:
    Let result be list containing
    Let temp_heap be heap_copy with heap as heap
    
    For i from 0 to min_int with a as k and b as temp_heap["size"]:
        Let pop_result be heap_pop with heap as temp_heap
        If pop_result["success"]:
            Add pop_result["value"] to result
            Set temp_heap to pop_result["heap"]
        Otherwise:
            Break
    
    Return result

Process called "heap_k_smallest_from_max_heap" that takes heap as Dictionary and k as Integer returns List[Any]:
    Let result be list containing
    Let temp_heap be heap_copy with heap as heap
    
    For i from 0 to min_int with a as k and b as temp_heap["size"]:
        Let pop_result be heap_pop with heap as temp_heap
        If pop_result["success"]:
            Add pop_result["value"] to result
            Set temp_heap to pop_result["heap"]
        Otherwise:
            Break
    
    Return reverse_list with lst as result

Process called "heap_nlargest" that takes items as List[Any] and n as Integer returns List[Any]:
    Let heap be heap_heapify with items as items and is_min_heap as false
    Return heap_k_largest with heap as heap and k as n

Process called "heap_nsmallest" that takes items as List[Any] and n as Integer returns List[Any]:
    Let heap be heap_heapify with items as items and is_min_heap as true
    Return heap_k_smallest with heap as heap and k as n

Process called "heap_is_valid" that takes heap as Dictionary returns Boolean:
    For i from 0 to (heap["size"] divided by 2):
        Let left_child be (i multiplied by 2) plus 1
        Let right_child be (i multiplied by 2) plus 2
        
        If left_child is less than heap["size"]:
            Let parent_node be heap["items"][i]
            Let left_node be heap["items"][left_child]
            
            If heap_should_swap with heap as heap and priority1 as left_node["priority"] and priority2 as parent_node["priority"] and timestamp1 as left_node["timestamp"] and timestamp2 as parent_node["timestamp"]:
                Return false
        
        If right_child is less than heap["size"]:
            Let parent_node be heap["items"][i]
            Let right_node be heap["items"][right_child]
            
            If heap_should_swap with heap as heap and priority1 as right_node["priority"] and priority2 as parent_node["priority"] and timestamp1 as right_node["timestamp"] and timestamp2 as parent_node["timestamp"]:
                Return false
    
    Return true

Process called "heap_to_list" that takes heap as Dictionary returns List[Any]:
    Let result be list containing
    
    For each node in heap["items"]:
        Add node["value"] to result
    
    Return result

Process called "heap_to_priority_list" that takes heap as Dictionary returns List[Dictionary]:
    Let result be list containing
    
    For each node in heap["items"]:
        Add dictionary with:
            value as node["value"]
            priority as node["priority"]
        to result
    
    Return result

Process called "heap_to_sorted_list" that takes heap as Dictionary returns List[Any]:
    Let result be list containing
    Let temp_heap be heap_copy with heap as heap
    
    While not heap_is_empty with heap as temp_heap:
        Let pop_result be heap_pop with heap as temp_heap
        If pop_result["success"]:
            Add pop_result["value"] to result
            Set temp_heap to pop_result["heap"]
        Otherwise:
            Break
    
    Return result

Process called "heap_copy" that takes heap as Dictionary returns Dictionary:
    Let new_heap be dictionary with:
        items as list containing
        is_min_heap as heap["is_min_heap"]
        size as 0
        heap_type as heap["heap_type"]
    
    For each node in heap["items"]:
        Set new_heap to heap_push with heap as new_heap and value as node["value"] and priority as node["priority"]
    
    Return new_heap

Process called "heap_clear" that takes heap as Dictionary returns Dictionary:
    Set heap["items"] to list containing
    Set heap["size"] to 0
    
    Return heap

Process called "heap_contains" that takes heap as Dictionary and value as Any returns Boolean:
    For each node in heap["items"]:
        If node["value"] is equal to value:
            Return true
    
    Return false

Process called "heap_find_by_value" that takes heap as Dictionary and value as Any returns Dictionary:
    For i from 0 to heap["size"]:
        Let node be heap["items"][i]
        If node["value"] is equal to value:
            Return dictionary with:
                found as true
                index as i
                priority as node["priority"]
                timestamp as node["timestamp"]
    
    Return dictionary with:
        found as false
        index as -1
        priority as 0.0
        timestamp as 0

Process called "heap_update_priority" that takes heap as Dictionary and index as Integer and new_priority as Float returns Dictionary:
    If index is less than 0 or index is greater than or equal to heap["size"]:
        Return heap
    
    Let old_priority be heap["items"][index]["priority"]
    Set heap["items"][index]["priority"] to new_priority
    Set heap["items"][index]["timestamp"] to get_current_timestamp()
    
    If heap["is_min_heap"]:
        If new_priority is less than old_priority:
            Set heap to heap_bubble_up with heap as heap and index as index
        Otherwise if new_priority is greater than old_priority:
            Set heap to heap_bubble_down with heap as heap and index as index
    Otherwise:
        If new_priority is greater than old_priority:
            Set heap to heap_bubble_up with heap as heap and index as index
        Otherwise if new_priority is less than old_priority:
            Set heap to heap_bubble_down with heap as heap and index as index
    
    Return heap

Process called "heap_remove_at_index" that takes heap as Dictionary and index as Integer returns Dictionary:
    If index is less than 0 or index is greater than or equal to heap["size"]:
        Return dictionary with:
            heap as heap
            value as None
            priority as 0.0
            success as false
    
    Let removed_node be heap["items"][index]
    Let last_index be heap["size"] minus 1
    
    If index is equal to last_index:
        Set heap["items"] to remove_at_index with lst as heap["items"] and index as index
        Set heap["size"] to heap["size"] minus 1
        Return dictionary with:
            heap as heap
            value as removed_node["value"]
            priority as removed_node["priority"]
            success as true
    
    Let last_node be heap["items"][last_index]
    Set heap["items"][index] to last_node
    Set heap["items"][index]["index"] to index
    Set heap["items"] to remove_at_index with lst as heap["items"] and index as last_index
    Set heap["size"] to heap["size"] minus 1
    
    Set heap to heap_bubble_up with heap as heap and index as index
    Set heap to heap_bubble_down with heap as heap and index as index
    
    Return dictionary with:
        heap as heap
        value as removed_node["value"]
        priority as removed_node["priority"]
        success as true

Process called "heap_remove_by_value" that takes heap as Dictionary and value as Any returns Dictionary:
    Let find_result be heap_find_by_value with heap as heap and value as value
    
    If find_result["found"]:
        Return heap_remove_at_index with heap as heap and index as find_result["index"]
    Otherwise:
        Return dictionary with:
            heap as heap
            value as None
            priority as 0.0
            success as false

Process called "heap_statistics" that takes heap as Dictionary returns Dictionary[String, Any]:
    Let stats be dictionary with:
    
    Set stats["size"] to heap["size"]
    Set stats["is_empty"] to heap_is_empty with heap as heap
    Set stats["heap_type"] to heap["heap_type"]
    Set stats["is_min_heap"] to heap["is_min_heap"]
    Set stats["is_valid"] to heap_is_valid with heap as heap
    
    If heap["size"] is greater than 0:
        Let min_priority be heap["items"][0]["priority"]
        Let max_priority be heap["items"][0]["priority"]
        Let total_priority be 0.0
        
        For each node in heap["items"]:
            Let priority be node["priority"]
            Set total_priority to total_priority plus priority
            
            If priority is less than min_priority:
                Set min_priority to priority
            
            If priority is greater than max_priority:
                Set max_priority to priority
        
        Set stats["min_priority"] to min_priority
        Set stats["max_priority"] to max_priority
        Set stats["avg_priority"] to total_priority divided by heap["size"] as Float
        Set stats["root_priority"] to heap_peek_priority with heap as heap
        Set stats["root_value"] to heap_peek with heap as heap
    Otherwise:
        Set stats["min_priority"] to 0.0
        Set stats["max_priority"] to 0.0
        Set stats["avg_priority"] to 0.0
        Set stats["root_priority"] to 0.0
        Set stats["root_value"] to None
    
    Return stats

Process called "min_int" that takes a as Integer and b as Integer returns Integer:
    If a is less than b:
        Return a
    Otherwise:
        Return b

Process called "reverse_list" that takes lst as List[Any] returns List[Any]:
    Let result be list containing
    
    For i from length of lst minus 1 to 0 by -1:
        Add lst[i] to result
    
    Return result

Process called "remove_at_index" that takes lst as List[Any] and index as Integer returns List[Any]:
    Let result be list containing
    
    For i from 0 to length of lst:
        If i is not equal to index:
            Add lst[i] to result
    
    Return result

Process called "get_current_timestamp" that returns Integer:
    Set global_timestamp_counter to global_timestamp_counter plus 1
    Return global_timestamp_counter

Let global_timestamp_counter be 0