Note:
Runa Standard Library: Bloom Filter (Probabilistic Set Membership)

Provides space-efficient probabilistic data structure for set membership testing with 
configurable false positive rates. Essential for AI systems requiring memory-efficient 
approximate membership queries.

Advanced features include:
- Optimal parameter calculation
- Multiple hash functions with proper seeding
- Scaling bloom filters for dynamic growth
- Binary serialization for persistence
- Union and intersection operations
- Statistical analysis and performance metrics
:End Note

Type called "BloomFilter":
    bit_array as List[Boolean]
    size as Integer
    hash_functions_count as Integer
    elements_count as Integer
    expected_elements as Integer
    false_positive_probability as Float

Type called "ScalingBloomFilter":
    filters as List[BloomFilter]
    expected_elements_per_filter as Integer
    false_positive_probability as Float
    growth_factor as Float

Process called "hash_string_for_bloom" that takes value as String and seed as Integer returns Integer:
    Let hash_value be 0
    Let multiplier be 31
    Let current_seed be seed
    
    For each character in value:
        Let char_code be character as Integer
        Let hash_value be hash_value multiplied by multiplier plus char_code plus current_seed
        Let hash_value be hash_value modulo 2147483647
    
    Return absolute_value with value as hash_value

Process called "create_bloom_filter" that takes expected_elements as Integer and false_positive_probability as Float returns BloomFilter:
    Let size be negative 1 multiplied by expected_elements multiplied by natural_logarithm with value as false_positive_probability
    Let size be size divided by power with base as natural_logarithm with value as 2.0 and exponent as 2.0
    Let size be round_up with value as size
    
    Let hash_functions_count be size divided by expected_elements multiplied by natural_logarithm of 2
    Let hash_functions_count be round of hash_functions_count
    
    If size is less than 1:
        Let size be 1
    If hash_functions_count is less than 1:
        Let hash_functions_count be 1
    
    Let bit_array be list containing
    For i from 0 to size minus 1:
        Add false to bit_array
    
    Return dictionary with:
        bit_array as bit_array
        size as size
        hash_functions_count as hash_functions_count
        elements_count as 0
        expected_elements as expected_elements
        false_positive_probability as false_positive_probability

Process called "add_to_bloom_filter" that takes filter as BloomFilter and element as String returns BloomFilter:
    For hash_index from 0 to filter["hash_functions_count"] minus 1:
        Let hash_value be hash_string_for_bloom with value as element and seed as hash_index
        Let bit_position be hash_value modulo filter["size"]
        Set filter["bit_array"][bit_position] to true
    
    Set filter["elements_count"] to filter["elements_count"] plus 1
    Return filter

Process called "contains_in_bloom_filter" that takes filter as BloomFilter and element as String returns Boolean:
    For hash_index from 0 to filter["hash_functions_count"] minus 1:
        Let hash_value be hash_string_for_bloom with value as element and seed as hash_index
        Let bit_position be hash_value modulo filter["size"]
        
        If filter["bit_array"][bit_position] is equal to false:
            Return false
    
    Return true

Process called "current_false_positive_probability" that takes filter as BloomFilter returns Float:
    If filter["elements_count"] is equal to 0:
        Return 0.0
    
    Let probability_bit_is_zero be 1.0 minus 1.0 divided by filter["size"]
    Let probability_bit_is_zero be power with base as probability_bit_is_zero and exponent as filter["hash_functions_count"] multiplied by filter["elements_count"] as Float
    
    Let false_positive_prob be 1.0 minus probability_bit_is_zero
    Let false_positive_prob be power with base as false_positive_prob and exponent as filter["hash_functions_count"] as Float
    
    Return false_positive_prob

Process called "get_bloom_filter_stats" that takes filter as BloomFilter returns Dictionary[String, Any]:
    Let stats be dictionary with:
    Set stats["size"] to filter["size"]
    Set stats["hash_functions_count"] to filter["hash_functions_count"]
    Set stats["elements_count"] to filter["elements_count"]
    Set stats["expected_elements"] to filter["expected_elements"]
    Set stats["expected_false_positive_probability"] to filter["false_positive_probability"]
    Set stats["current_false_positive_probability"] to current_false_positive_probability with filter as filter
    
    Let bits_set be 0
    For each bit in filter["bit_array"]:
        If bit is equal to true:
            Let bits_set be bits_set plus 1
    
    Let utilization be bits_set as Float divided by filter["size"] as Float
    Set stats["bit_utilization"] to utilization
    
    Return stats

Process called "clear_bloom_filter" that takes filter as BloomFilter returns BloomFilter:
    For i from 0 to filter["size"] minus 1:
        Set filter["bit_array"][i] to false
    
    Set filter["elements_count"] to 0
    Return filter

Process called "union_bloom_filters" that takes filter1 as BloomFilter and filter2 as BloomFilter returns BloomFilter:
    If filter1["size"] is not equal to filter2["size"]:
        Throw error "Cannot union Bloom Filters with different sizes"
    
    If filter1["hash_functions_count"] is not equal to filter2["hash_functions_count"]:
        Throw error "Cannot union Bloom Filters with different hash function counts"
    
    Let result_filter be create_bloom_filter with expected_elements as filter1["expected_elements"] and false_positive_probability as filter1["false_positive_probability"]
    
    For i from 0 to filter1["size"] minus 1:
        Let union_bit be filter1["bit_array"][i] or filter2["bit_array"][i]
        Set result_filter["bit_array"][i] to union_bit
    
    Set result_filter["elements_count"] to filter1["elements_count"] plus filter2["elements_count"]
    Return result_filter

Process called "intersect_bloom_filters" that takes filter1 as BloomFilter and filter2 as BloomFilter returns BloomFilter:
    If filter1["size"] is not equal to filter2["size"]:
        Throw error "Cannot intersect Bloom Filters with different sizes"
    
    If filter1["hash_functions_count"] is not equal to filter2["hash_functions_count"]:
        Throw error "Cannot intersect Bloom Filters with different hash function counts"
    
    Let result_filter be create_bloom_filter with expected_elements as filter1["expected_elements"] and false_positive_probability as filter1["false_positive_probability"]
    
    For i from 0 to filter1["size"] minus 1:
        Let intersection_bit be filter1["bit_array"][i] and filter2["bit_array"][i]
        Set result_filter["bit_array"][i] to intersection_bit
    
    Let result_filter["elements_count"] be minimum of filter1["elements_count"] and filter2["elements_count"]
    Return result_filter

Process called "export_bloom_filter_binary" that takes filter as BloomFilter returns List[Integer]:
    Let binary_data be list containing
    
    Add filter["size"] to binary_data
    Add filter["hash_functions_count"] to binary_data
    Add filter["elements_count"] to binary_data
    Add filter["expected_elements"] to binary_data
    
    Let current_byte be 0
    Let bit_count be 0
    
    For each bit in filter["bit_array"]:
        If bit is equal to true:
            Let current_byte be current_byte or power with base as 2.0 and exponent as bit_count as Float as Integer
        
        Let bit_count be bit_count plus 1
        
        If bit_count is equal to 8:
            Add current_byte to binary_data
            Let current_byte be 0
            Let bit_count be 0
    
    If bit_count is greater than 0:
        Add current_byte to binary_data
    
    Return binary_data

Process called "import_bloom_filter_binary" that takes binary_data as List[Integer] and false_positive_probability as Float returns BloomFilter:
    If length of binary_data is less than 4:
        Throw error "Invalid binary data: insufficient metadata"
    
    Let size be binary_data[0]
    Let hash_functions_count be binary_data[1]
    Let elements_count be binary_data[2]
    Let expected_elements be binary_data[3]
    
    Let filter be create_bloom_filter with expected_elements as expected_elements and false_positive_probability as false_positive_probability
    Set filter["size"] to size
    Set filter["hash_functions_count"] to hash_functions_count
    Set filter["elements_count"] to elements_count
    
    Set filter["bit_array"] to list containing
    For i from 0 to size minus 1:
        Add false to filter["bit_array"]
    
    Let bit_index be 0
    For byte_index from 4 to length of binary_data minus 1:
        Let byte_value be binary_data[byte_index]
        
        For bit_position from 0 to 7:
            If bit_index is less than size:
                Let bit_value be byte_value and power with base as 2.0 and exponent as bit_position as Float as Integer
                Set filter["bit_array"][bit_index] to bit_value is not equal to 0
                Let bit_index be bit_index plus 1
    
    Return filter

Process called "create_scaling_bloom_filter" that takes expected_elements_per_filter as Integer and false_positive_probability as Float returns ScalingBloomFilter:
    Let initial_filter be create_bloom_filter with expected_elements as expected_elements_per_filter and false_positive_probability as false_positive_probability
    Let filters be list containing initial_filter
    
    Return dictionary with:
        filters as filters
        expected_elements_per_filter as expected_elements_per_filter
        false_positive_probability as false_positive_probability
        growth_factor as 2.0

Process called "add_to_scaling_bloom_filter" that takes scaling_filter as ScalingBloomFilter and element as String returns ScalingBloomFilter:
    Let last_filter be last element of scaling_filter["filters"]
    
    If last_filter["elements_count"] is greater than or equal to last_filter["expected_elements"]:
        Let new_expected_elements be round of scaling_filter["expected_elements_per_filter"] multiplied by scaling_filter["growth_factor"]
        Let new_filter be create_bloom_filter with expected_elements as new_expected_elements and false_positive_probability as scaling_filter["false_positive_probability"]
        Add new_filter to scaling_filter["filters"]
        Let last_filter be new_filter
    
    Let updated_filter be add_to_bloom_filter with filter as last_filter and element as element
    Set last element of scaling_filter["filters"] to updated_filter
    
    Return scaling_filter

Process called "contains_in_scaling_bloom_filter" that takes scaling_filter as ScalingBloomFilter and element as String returns Boolean:
    For each filter in scaling_filter["filters"]:
        If contains_in_bloom_filter with filter as filter and element as element is equal to true:
            Return true
    
    Return false

Process called "get_scaling_bloom_filter_stats" that takes scaling_filter as ScalingBloomFilter returns Dictionary[String, Any]:
    Let stats be dictionary with:
    Set stats["filter_count"] to length of scaling_filter["filters"]
    Set stats["expected_elements_per_filter"] to scaling_filter["expected_elements_per_filter"]
    Set stats["false_positive_probability"] to scaling_filter["false_positive_probability"]
    Set stats["growth_factor"] to scaling_filter["growth_factor"]
    
    Let total_elements be 0
    Let total_capacity be 0
    Let individual_stats be list containing
    
    For each filter in scaling_filter["filters"]:
        Let filter_stats be get_bloom_filter_stats with filter as filter
        Add filter_stats to individual_stats
        Let total_elements be total_elements plus filter["elements_count"]
        Let total_capacity be total_capacity plus filter["expected_elements"]
    
    Set stats["total_elements"] to total_elements
    Set stats["total_capacity"] to total_capacity
    Set stats["individual_filter_stats"] to individual_stats
    
    Return stats

Process called "absolute_value" that takes value as Integer returns Integer:
    If value is less than 0:
        Return negative value
    Return value

Process called "round_up" that takes value as Float returns Integer:
    Let int_part be integer_part_of with value as value
    If value minus int_part as Float is greater than 0.0:
        Return int_part plus 1
    Return int_part

Process called "integer_part_of" that takes value as Float returns Integer:
    Let int_value be 0
    Let abs_value be value
    If value is less than 0.0:
        Let abs_value be negative value
    
    While int_value as Float is less than abs_value:
        Let int_value be int_value plus 1
    
    If int_value as Float is greater than abs_value:
        Let int_value be int_value minus 1
    
    If value is less than 0.0:
        Return negative int_value
    Return int_value

Process called "power" that takes base as Float and exponent as Float returns Float:
    If exponent is equal to 0.0:
        Return 1.0
    If exponent is equal to 1.0:
        Return base
    
    Let result be 1.0
    Let abs_exp be exponent
    If exponent is less than 0.0:
        Let abs_exp be negative exponent
    
    Let current_power be base
    Let exp_bits be integer_part_of with value as abs_exp
    
    While exp_bits is greater than 0:
        If exp_bits modulo 2 is equal to 1:
            Let result be result multiplied by current_power
        Let current_power be current_power multiplied by current_power
        Let exp_bits be exp_bits divided by 2
    
    If exponent is less than 0.0:
        Return 1.0 divided by result
    Return result

Process called "natural_logarithm" that takes value as Float returns Float:
    If value is less than or equal to 0.0:
        Throw error "Cannot calculate natural logarithm of non-positive number"
    If value is equal to 1.0:
        Return 0.0
    
    Let x be value minus 1.0
    Let result be 0.0
    Let term be x
    Let sign be 1.0
    
    For i from 1 to 15:
        Let result be result plus sign multiplied by term divided by i as Float
        Let term be term multiplied by x
        Let sign be sign multiplied by negative 1.0
    
    Return result