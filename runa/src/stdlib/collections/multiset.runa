Note:
Runa Standard Library: Multiset (Bag) Data Structure

Provides comprehensive multiset/bag functionality for collections that allow duplicate elements
with count tracking. Essential for AI systems requiring frequency analysis, statistical operations,
and multi-occurrence data management.

Advanced features include:
- Element count tracking with efficient increment/decrement operations
- Set-like operations adapted for multiplicities (union, intersection, difference)
- Statistical analysis with frequency distributions and mode calculation
- Bulk operations and multiset arithmetic
- Memory-efficient representation using Dictionary backing
- Performance optimizations for large datasets
- Comprehensive multiset algebra operations
:End Note

Type called "Multiset":
    elements as Dictionary[Any, Integer]
    total_count as Integer

Process called "create_multiset" that returns Dictionary:
    Return dictionary with:
        elements as dictionary with:
        total_count as 0

Process called "create_multiset_from_list" that takes items as List[Any] returns Dictionary:
    Let ms be create_multiset()
    
    For each item in items:
        Set ms to multiset_add with ms as ms and element as item and count as 1
    
    Return ms

Process called "create_multiset_from_dict" that takes counts as Dictionary[Any, Integer] returns Dictionary:
    Let ms be create_multiset()
    
    For each element and count in counts:
        If count is greater than 0:
            Set ms["elements"][element] to count
            Set ms["total_count"] to ms["total_count"] plus count
    
    Return ms

Process called "multiset_add" that takes ms as Dictionary and element as Any and count as Integer returns Dictionary:
    If count is less than or equal to 0:
        Return ms
    
    If element in ms["elements"]:
        Set ms["elements"][element] to ms["elements"][element] plus count
    Otherwise:
        Set ms["elements"][element] to count
    
    Set ms["total_count"] to ms["total_count"] plus count
    Return ms

Process called "multiset_remove" that takes ms as Dictionary and element as Any and count as Integer returns Dictionary:
    If element not in ms["elements"] or count is less than or equal to 0:
        Return ms
    
    Let current_count be ms["elements"][element]
    Let remove_count be min_value with a as count and b as current_count
    
    Set ms["elements"][element] to current_count minus remove_count
    Set ms["total_count"] to ms["total_count"] minus remove_count
    
    If ms["elements"][element] is equal to 0:
        Remove element from ms["elements"]
    
    Return ms

Process called "multiset_remove_all" that takes ms as Dictionary and element as Any returns Dictionary:
    If element not in ms["elements"]:
        Return ms
    
    Let current_count be ms["elements"][element]
    Set ms["total_count"] to ms["total_count"] minus current_count
    Remove element from ms["elements"]
    
    Return ms

Process called "multiset_count" that takes ms as Dictionary and element as Any returns Integer:
    If element in ms["elements"]:
        Return ms["elements"][element]
    Otherwise:
        Return 0

Process called "multiset_contains" that takes ms as Dictionary and element as Any returns Boolean:
    Return element in ms["elements"]

Process called "multiset_size" that takes ms as Dictionary returns Integer:
    Return ms["total_count"]

Process called "multiset_unique_count" that takes ms as Dictionary returns Integer:
    Return length of keys with d as ms["elements"]

Process called "multiset_is_empty" that takes ms as Dictionary returns Boolean:
    Return ms["total_count"] is equal to 0

Process called "multiset_clear" that takes ms as Dictionary returns Dictionary:
    Set ms["elements"] to dictionary with:
    Set ms["total_count"] to 0
    Return ms

Process called "multiset_copy" that takes ms as Dictionary returns Dictionary:
    Let new_elements be dictionary with:
    
    For each element and count in ms["elements"]:
        Set new_elements[element] to count
    
    Return dictionary with:
        elements as new_elements
        total_count as ms["total_count"]

Process called "multiset_to_list" that takes ms as Dictionary returns List[Any]:
    Let result be list containing
    
    For each element and count in ms["elements"]:
        For i from 1 to count:
            Add element to result
    
    Return result

Process called "multiset_to_set" that takes ms as Dictionary returns Dictionary[Any, Boolean]:
    Let result be dictionary with:
    
    For each element and count in ms["elements"]:
        Set result[element] to true
    
    Return result

Process called "multiset_unique_elements" that takes ms as Dictionary returns List[Any]:
    Let result be list containing
    
    For each element and count in ms["elements"]:
        Add element to result
    
    Return result

Process called "multiset_union" that takes ms1 as Dictionary and ms2 as Dictionary returns Dictionary:
    Let result be multiset_copy with ms as ms1
    
    For each element and count in ms2["elements"]:
        Let current_count be multiset_count with ms as result and element as element
        Let max_count be max_value with a as current_count and b as count
        
        If current_count is greater than 0:
            Set result to multiset_remove_all with ms as result and element as element
        
        Set result to multiset_add with ms as result and element as element and count as max_count
    
    Return result

Process called "multiset_intersection" that takes ms1 as Dictionary and ms2 as Dictionary returns Dictionary:
    Let result be create_multiset()
    
    For each element and count1 in ms1["elements"]:
        If element in ms2["elements"]:
            Let count2 be ms2["elements"][element]
            Let min_count be min_value with a as count1 and b as count2
            Set result to multiset_add with ms as result and element as element and count as min_count
    
    Return result

Process called "multiset_difference" that takes ms1 as Dictionary and ms2 as Dictionary returns Dictionary:
    Let result be multiset_copy with ms as ms1
    
    For each element and count in ms2["elements"]:
        Set result to multiset_remove with ms as result and element as element and count as count
    
    Return result

Process called "multiset_symmetric_difference" that takes ms1 as Dictionary and ms2 as Dictionary returns Dictionary:
    Let result be create_multiset()
    Let all_elements be dictionary with:
    
    For each element and count in ms1["elements"]:
        Set all_elements[element] to true
    
    For each element and count in ms2["elements"]:
        Set all_elements[element] to true
    
    For each element and value in all_elements:
        Let count1 be multiset_count with ms as ms1 and element as element
        Let count2 be multiset_count with ms as ms2 and element as element
        Let diff_count be abs_value with n as count1 minus count2
        
        If diff_count is greater than 0:
            Set result to multiset_add with ms as result and element as element and count as diff_count
    
    Return result

Process called "multiset_is_subset" that takes ms1 as Dictionary and ms2 as Dictionary returns Boolean:
    For each element and count in ms1["elements"]:
        Let count2 be multiset_count with ms as ms2 and element as element
        If count is greater than count2:
            Return false
    
    Return true

Process called "multiset_is_superset" that takes ms1 as Dictionary and ms2 as Dictionary returns Boolean:
    Return multiset_is_subset with ms1 as ms2 and ms2 as ms1

Process called "multiset_is_proper_subset" that takes ms1 as Dictionary and ms2 as Dictionary returns Boolean:
    If not multiset_is_subset with ms1 as ms1 and ms2 as ms2:
        Return false
    
    Return not multiset_equals with ms1 as ms1 and ms2 as ms2

Process called "multiset_is_proper_superset" that takes ms1 as Dictionary and ms2 as Dictionary returns Boolean:
    If not multiset_is_superset with ms1 as ms1 and ms2 as ms2:
        Return false
    
    Return not multiset_equals with ms1 as ms1 and ms2 as ms2

Process called "multiset_equals" that takes ms1 as Dictionary and ms2 as Dictionary returns Boolean:
    If ms1["total_count"] is not equal to ms2["total_count"]:
        Return false
    
    If multiset_unique_count with ms as ms1 is not equal to multiset_unique_count with ms as ms2:
        Return false
    
    For each element and count in ms1["elements"]:
        Let count2 be multiset_count with ms as ms2 and element as element
        If count is not equal to count2:
            Return false
    
    Return true

Process called "multiset_is_disjoint" that takes ms1 as Dictionary and ms2 as Dictionary returns Boolean:
    For each element and count in ms1["elements"]:
        If element in ms2["elements"]:
            Return false
    
    Return true

Process called "multiset_add_multiset" that takes ms1 as Dictionary and ms2 as Dictionary returns Dictionary:
    Let result be multiset_copy with ms as ms1
    
    For each element and count in ms2["elements"]:
        Set result to multiset_add with ms as result and element as element and count as count
    
    Return result

Process called "multiset_subtract_multiset" that takes ms1 as Dictionary and ms2 as Dictionary returns Dictionary:
    Return multiset_difference with ms1 as ms1 and ms2 as ms2

Process called "multiset_multiply" that takes ms as Dictionary and factor as Integer returns Dictionary:
    If factor is less than or equal to 0:
        Return create_multiset()
    
    Let result be create_multiset()
    
    For each element and count in ms["elements"]:
        Let new_count be count multiplied by factor
        Set result to multiset_add with ms as result and element as element and count as new_count
    
    Return result

Process called "multiset_most_common" that takes ms as Dictionary and n as Optional[Integer] returns List[Tuple[Any, Integer]]:
    Let pairs be list containing
    
    For each element and count in ms["elements"]:
        Add (element, count) to pairs
    
    Let sorted_pairs be sort_pairs_by_count with pairs as pairs
    
    If n is None:
        Return sorted_pairs
    
    If n is less than or equal to 0:
        Return list containing
    
    Let result be list containing
    For i from 0 to min_value with a as n and b as length of sorted_pairs:
        Add sorted_pairs[i] to result
    
    Return result

Process called "multiset_least_common" that takes ms as Dictionary and n as Optional[Integer] returns List[Tuple[Any, Integer]]:
    Let pairs be list containing
    
    For each element and count in ms["elements"]:
        Add (element, count) to pairs
    
    Let sorted_pairs be sort_pairs_by_count_ascending with pairs as pairs
    
    If n is None:
        Return sorted_pairs
    
    If n is less than or equal to 0:
        Return list containing
    
    Let result be list containing
    For i from 0 to min_value with a as n and b as length of sorted_pairs:
        Add sorted_pairs[i] to result
    
    Return result

Process called "multiset_mode" that takes ms as Dictionary returns List[Any]:
    If multiset_is_empty with ms as ms:
        Return list containing
    
    Let max_count be 0
    For each element and count in ms["elements"]:
        If count is greater than max_count:
            Set max_count to count
    
    Let modes be list containing
    For each element and count in ms["elements"]:
        If count is equal to max_count:
            Add element to modes
    
    Return modes

Process called "multiset_frequencies" that takes ms as Dictionary returns Dictionary[Any, Float]:
    Let result be dictionary with:
    Let total be ms["total_count"] as Float
    
    If total is equal to 0.0:
        Return result
    
    For each element and count in ms["elements"]:
        Let frequency be count as Float divided by total
        Set result[element] to frequency
    
    Return result

Process called "multiset_entropy" that takes ms as Dictionary returns Float:
    Let frequencies be multiset_frequencies with ms as ms
    Let entropy be 0.0
    
    For each element and frequency in frequencies:
        If frequency is greater than 0.0:
            Let log_freq be natural_log with x as frequency
            Set entropy to entropy minus frequency multiplied by log_freq
    
    Return entropy

Process called "multiset_filter" that takes ms as Dictionary and predicate as Process returns Dictionary:
    Let result be create_multiset()
    
    For each element and count in ms["elements"]:
        If predicate with item as element is equal to true:
            Set result to multiset_add with ms as result and element as element and count as count
    
    Return result

Process called "multiset_map" that takes ms as Dictionary and transform as Process returns Dictionary:
    Let result be create_multiset()
    
    For each element and count in ms["elements"]:
        Let transformed be transform with item as element
        Set result to multiset_add with ms as result and element as transformed and count as count
    
    Return result

Process called "multiset_reduce" that takes ms as Dictionary and reducer as Process and initial as Any returns Any:
    Let accumulator be initial
    
    For each element and count in ms["elements"]:
        For i from 1 to count:
            Set accumulator to reducer with acc as accumulator and item as element
    
    Return accumulator

Process called "multiset_sample" that takes ms as Dictionary and count as Integer returns Dictionary:
    If count is less than or equal to 0:
        Return create_multiset()
    
    If count is greater than or equal to ms["total_count"]:
        Return multiset_copy with ms as ms
    
    Let elements_list be multiset_to_list with ms as ms
    Let sampled_list be sample_list_proper with lst as elements_list and count as count
    
    Return create_multiset_from_list with items as sampled_list

Process called "multiset_statistics" that takes ms as Dictionary returns Dictionary[String, Any]:
    Let stats be dictionary with:
    
    Set stats["total_count"] to ms["total_count"]
    Set stats["unique_count"] to multiset_unique_count with ms as ms
    Set stats["is_empty"] to multiset_is_empty with ms as ms
    
    If not multiset_is_empty with ms as ms:
        Let most_common be multiset_most_common with ms as ms and n as 1
        Let least_common be multiset_least_common with ms as ms and n as 1
        Let modes be multiset_mode with ms as ms
        
        Set stats["most_common_element"] to most_common[0][0]
        Set stats["most_common_count"] to most_common[0][1]
        Set stats["least_common_element"] to least_common[0][0]
        Set stats["least_common_count"] to least_common[0][1]
        Set stats["mode"] to modes
        Set stats["entropy"] to multiset_entropy with ms as ms
        
        Let total_squared be 0
        For each element and count in ms["elements"]:
            Set total_squared to total_squared plus count multiplied by count
        
        Set stats["diversity_index"] to ms["total_count"] multiplied by ms["total_count"] divided by total_squared
    Otherwise:
        Set stats["most_common_element"] to None
        Set stats["most_common_count"] to 0
        Set stats["least_common_element"] to None
        Set stats["least_common_count"] to 0
        Set stats["mode"] to list containing
        Set stats["entropy"] to 0.0
        Set stats["diversity_index"] to 0.0
    
    Return stats

Process called "sort_pairs_by_count" that takes pairs as List[Tuple[Any, Integer]] returns List[Tuple[Any, Integer]]:
    Let result be copy_list with lst as pairs
    Let length be length of result
    
    For i from 0 to length minus 1:
        For j from 0 to length minus i minus 1:
            If result[j][1] is less than result[j plus 1][1]:
                Let temp be result[j]
                Set result[j] to result[j plus 1]
                Set result[j plus 1] to temp
    
    Return result

Process called "sort_pairs_by_count_ascending" that takes pairs as List[Tuple[Any, Integer]] returns List[Tuple[Any, Integer]]:
    Let result be copy_list with lst as pairs
    Let length be length of result
    
    For i from 0 to length minus 1:
        For j from 0 to length minus i minus 1:
            If result[j][1] is greater than result[j plus 1][1]:
                Let temp be result[j]
                Set result[j] to result[j plus 1]
                Set result[j plus 1] to temp
    
    Return result

Process called "copy_list" that takes lst as List[Any] returns List[Any]:
    Let result be list containing
    
    For each item in lst:
        Add item to result
    
    Return result

Process called "sample_list_proper" that takes lst as List[Any] and count as Integer returns List[Any]:
    If count is greater than or equal to length of lst:
        Return copy_list with lst as lst
    
    Let result be list containing
    Let available be copy_list with lst as lst
    
    For i from 0 to count minus 1:
        Let random_index be proper_random with max as length of available
        Add available[random_index] to result
        Set available to remove_at_index with lst as available and index as random_index
    
    Return result

Process called "remove_at_index" that takes lst as List[Any] and index as Integer returns List[Any]:
    Let result be list containing
    
    For i from 0 to length of lst:
        If i is not equal to index:
            Add lst[i] to result
    
    Return result

Process called "keys" that takes d as Dictionary returns List[Any]:
    Let result be list containing
    
    For each key and value in d:
        Add key to result
    
    Return result

Process called "min_value" that takes a as Integer and b as Integer returns Integer:
    If a is less than b:
        Return a
    Otherwise:
        Return b

Process called "max_value" that takes a as Integer and b as Integer returns Integer:
    If a is greater than b:
        Return a
    Otherwise:
        Return b

Process called "abs_value" that takes n as Integer returns Integer:
    If n is less than 0:
        Return negative n
    Otherwise:
        Return n

Process called "natural_log" that takes x as Float returns Float:
    If x is less than or equal to 0.0:
        Return negative 1000000.0
    
    If x is equal to 1.0:
        Return 0.0
    
    Let result be 0.0
    Let term be x minus 1.0
    Let sign be 1.0
    
    For i from 1 to 20:
        Let power_term be power_float with base as term and exponent as i
        Let factorial_term be factorial_float with n as i
        Let series_term be sign multiplied by power_term divided by factorial_term
        Set result to result plus series_term
        Set sign to negative sign
    
    Return result

Process called "power_float" that takes base as Float and exponent as Integer returns Float:
    If exponent is equal to 0:
        Return 1.0
    
    Let result be 1.0
    Let abs_exp be abs_value with n as exponent
    
    For i from 1 to abs_exp:
        Set result to result multiplied by base
    
    If exponent is less than 0:
        Return 1.0 divided by result
    
    Return result

Process called "factorial_float" that takes n as Integer returns Float:
    If n is less than or equal to 1:
        Return 1.0
    
    Let result be 1.0
    
    For i from 2 to n:
        Set result to result multiplied by i as Float
    
    Return result

Process called "proper_random" that takes max as Integer returns Integer:
    Set global_random_seed to linear_congruential_generator with seed as global_random_seed
    Return global_random_seed modulo max

Process called "linear_congruential_generator" that takes seed as Integer returns Integer:
    Let a be 1664525
    Let c be 1013904223
    Let m be 4294967296
    
    Let next_seed be (a multiplied by seed plus c) modulo m
    Return next_seed

Let global_random_seed be 12345