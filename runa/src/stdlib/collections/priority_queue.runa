Note:
collections/priority_queue.runa
Priority Queue and Heap Data Structure Implementation

This module provides priority queue functionality using binary heap implementation.
Supports both min-heap and max-heap configurations for efficient priority-based
element retrieval and insertion operations.

Key features include heap construction, insertion, deletion, priority updates,
and heap validation with O(log n) complexity for core operations.
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: PRIORITY QUEUE DATA STRUCTURES
Note: =====================================================================

Type called "PriorityQueueElement":
    value as String
    priority as Float
    insertion_order as Integer
    data_payload as Dictionary[String, String]

Type called "PriorityQueue":
    elements as List[PriorityQueueElement]
    heap_type as String
    size as Integer
    insertion_counter as Integer
    comparison_function as String

Type called "HeapValidationResult":
    is_valid as Boolean
    violations as List[String]
    heap_property_satisfied as Boolean
    structure_integrity as Boolean

Note: =====================================================================
Note: PRIORITY QUEUE CONSTRUCTION OPERATIONS
Note: =====================================================================

Process called "create_priority_queue" that takes heap_type as String returns PriorityQueue:
    Note: Create new priority queue with specified heap type (min or max)
    
    If heap_type != "min" and heap_type != "max":
        Throw Errors.InvalidArgument with "Heap type must be 'min' or 'max', got: " + heap_type
    
    Let queue be PriorityQueue
    Set queue.elements to List[PriorityQueueElement]
    Set queue.heap_type to heap_type
    Set queue.size to 0
    Set queue.insertion_counter to 0
    Set queue.comparison_function to ""
    
    Return queue

Process called "insert_with_priority" that takes queue as PriorityQueue, value as String, priority as Float returns Nothing:
    Note: Insert element with given priority, maintaining heap property
    
    Let element be PriorityQueueElement
    Set element.value to value
    Set element.priority to priority
    Set element.insertion_order to queue.insertion_counter
    Set element.data_payload to Dictionary[String, String]
    
    Call queue.elements.append(element)
    Set queue.size to queue.size + 1
    Set queue.insertion_counter to queue.insertion_counter + 1
    
    Note: Restore heap property by bubbling up
    Call heapify_up(queue, queue.size - 1)

Process called "extract_top_priority" that takes queue as PriorityQueue returns PriorityQueueElement:
    Note: Remove and return highest priority element
    
    If queue.size equals 0:
        Throw Errors.EmptyContainer with "Cannot extract from empty priority queue"
    
    Let top_element be queue.elements[0]
    
    Note: Move last element to root and restore heap property
    Set queue.elements[0] to queue.elements[queue.size - 1]
    Call queue.elements.remove_at(queue.size - 1)
    Set queue.size to queue.size - 1
    
    If queue.size > 0:
        Call heapify_down(queue, 0)
    
    Return top_element

Process called "peek_top_priority" that takes queue as PriorityQueue returns PriorityQueueElement:
    Note: Return highest priority element without removing it
    
    If queue.size equals 0:
        Throw Errors.EmptyContainer with "Cannot peek into empty priority queue"
    
    Return queue.elements[0]

Process called "update_priority" that takes queue as PriorityQueue, value as String, new_priority as Float returns Boolean:
    Note: Update priority of existing element, return true if found and updated
    
    Let element_index be -1
    For i from 0 to queue.size - 1:
        If queue.elements[i].value equals value:
            Set element_index to i
            Break
    
    If element_index equals -1:
        Return false
    
    Let old_priority be queue.elements[element_index].priority
    Set queue.elements[element_index].priority to new_priority
    
    Note: Restore heap property based on priority change direction
    If queue.heap_type equals "min":
        If new_priority < old_priority:
            Call heapify_up(queue, element_index)
        Otherwise:
            Call heapify_down(queue, element_index)
    Otherwise:
        If new_priority > old_priority:
            Call heapify_up(queue, element_index)
        Otherwise:
            Call heapify_down(queue, element_index)
    
    Return true

Note: =====================================================================
Note: HEAP MAINTENANCE OPERATIONS
Note: =====================================================================

Process called "heapify_up" that takes queue as PriorityQueue, index as Integer returns Nothing:
    Note: Restore heap property by moving element up the tree
    
    If index equals 0:
        Return
    
    Let parent_index be (index - 1) / 2
    Let should_swap be false
    
    If queue.heap_type equals "min":
        Set should_swap to queue.elements[index].priority < queue.elements[parent_index].priority
    Otherwise:
        Set should_swap to queue.elements[index].priority > queue.elements[parent_index].priority
    
    If should_swap:
        Call swap_elements(queue, index, parent_index)
        Call heapify_up(queue, parent_index)

Process called "heapify_down" that takes queue as PriorityQueue, index as Integer returns Nothing:
    Note: Restore heap property by moving element down the tree
    
    Let left_child be (2 * index) + 1
    Let right_child be (2 * index) + 2
    Let target_index be index
    
    If queue.heap_type equals "min":
        If left_child < queue.size and queue.elements[left_child].priority < queue.elements[target_index].priority:
            Set target_index to left_child
        If right_child < queue.size and queue.elements[right_child].priority < queue.elements[target_index].priority:
            Set target_index to right_child
    Otherwise:
        If left_child < queue.size and queue.elements[left_child].priority > queue.elements[target_index].priority:
            Set target_index to left_child
        If right_child < queue.size and queue.elements[right_child].priority > queue.elements[target_index].priority:
            Set target_index to right_child
    
    If target_index != index:
        Call swap_elements(queue, index, target_index)
        Call heapify_down(queue, target_index)

Process called "swap_elements" that takes queue as PriorityQueue, index1 as Integer, index2 as Integer returns Nothing:
    Note: Swap two elements in the heap array
    
    Let temp_element be queue.elements[index1]
    Set queue.elements[index1] to queue.elements[index2]
    Set queue.elements[index2] to temp_element

Process called "build_heap_from_array" that takes elements as List[PriorityQueueElement], heap_type as String returns PriorityQueue:
    Note: Build heap from existing array of elements using Floyd's algorithm
    
    Let queue be create_priority_queue(heap_type)
    Set queue.elements to elements
    Set queue.size to elements.size()
    
    Note: Start from last non-leaf node and heapify down
    Let start_index be (queue.size / 2) - 1
    For i from start_index down to 0:
        Call heapify_down(queue, i)
    
    Return queue

Process called "is_empty" that takes queue as PriorityQueue returns Boolean:
    Note: Check if priority queue is empty
    Return queue.size equals 0

Process called "get_size" that takes queue as PriorityQueue returns Integer:
    Note: Get current number of elements in priority queue
    Return queue.size

Process called "validate_heap_property" that takes queue as PriorityQueue returns HeapValidationResult:
    Note: Validate that heap property is maintained throughout the structure
    
    Let result be HeapValidationResult
    Set result.violations to List[String]
    Set result.is_valid to true
    Set result.structure_integrity to true
    
    For i from 0 to queue.size - 1:
        Let left_child be (2 * i) + 1
        Let right_child be (2 * i) + 2
        
        If left_child < queue.size:
            Let parent_priority be queue.elements[i].priority
            Let left_priority be queue.elements[left_child].priority
            Let violation_found be false
            
            If queue.heap_type equals "min" and parent_priority > left_priority:
                Set violation_found to true
            If queue.heap_type equals "max" and parent_priority < left_priority:
                Set violation_found to true
            
            If violation_found:
                Call result.violations.append("Heap property violated at index " + String(i) + " with left child " + String(left_child))
                Set result.is_valid to false
        
        If right_child < queue.size:
            Let parent_priority be queue.elements[i].priority
            Let right_priority be queue.elements[right_child].priority
            Let violation_found be false
            
            If queue.heap_type equals "min" and parent_priority > right_priority:
                Set violation_found to true
            If queue.heap_type equals "max" and parent_priority < right_priority:
                Set violation_found to true
            
            If violation_found:
                Call result.violations.append("Heap property violated at index " + String(i) + " with right child " + String(right_child))
                Set result.is_valid to false
    
    Set result.heap_property_satisfied to result.is_valid
    Return result