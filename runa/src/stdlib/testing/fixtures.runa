    metadata as dictionary containing "scope_type" as describe_fixture_scope with scope as scope

Process called "fixture_with_dependencies" that takes name as String and factory_function as String and dependencies as List[String] returns Fixture:
    Note: Create fixture with explicit dependencies
    Return Fixture with:
    name as name
    factory_function as factory_function
    scope as FunctionScope
    dependencies as dependencies
    parameters as None
    cached_value as None
    cleanup_function as None
    created_at as None
    access_count as 0
    metadata as dictionary containing "dependency_count" as length of dependencies

Process called "parameterized_fixture" that takes name as String and factory_function as String and parameter_sets as List[List[Any]] returns List[Fixture]:
    Note: Create multiple fixtures from parameter sets for data-driven testing
    Let parameterized_fixtures be list containing For i from 0 to (length of parameter_sets - 1):
    Let parameter_set be parameter_sets[i]
    Let parameterized_name be name "_param_" Format.integer_to_string with value as i Let fixture be Fixture with:
    name as parameterized_name
    factory_function as factory_function
    scope as FunctionScope
    dependencies as list containing
    parameters as Some with value as parameter_set
    cached_value as None
    cleanup_function as None
    created_at as None
    access_count as 0
    metadata as dictionary containing "parameter_index" as i, "base_fixture_name" as name Add fixture to parameterized_fixtures Return parameterized_fixtures

Note: Fixture Resolution and Instantiation
Process called "resolve_fixture" that takes registry as FixtureRegistry and request as FixtureRequest returns FixtureResult:
    Note: Resolve fixture with dependency injection and caching
    Let resolution_start_time be get_current_timestamp Try:
    Note: Check if fixture is already cached at appropriate scope
    Let cached_instance be get_cached_fixture_instance with registry as registry and fixture_name as request.fixture_name and scope as request.required_scope
    If cached_instance is not None:
    Set cached_instance.fixture_name's access_count in registry to cached_instance.fixture_name's access_count + 1
    Return FixtureResult with:
    success as true
    value as cached_instance.value
    creation_time as get_current_timestamp - resolution_start_time
    dependencies_resolved as cached_instance.dependencies
    error_message as ""
    metadata as dictionary containing "cache_hit" as true Note: Get fixture definition
    If not registry.fixtures contains key request.fixture_name:
    Return FixtureResult with:
    success as false
    value as None
    creation_time as get_current_timestamp - resolution_start_time
    dependencies_resolved as list containing
    error_message as "Fixture not found: " request.fixture_name
    metadata as dictionary containing Let fixture_def be registry.fixtures[request.fixture_name] Note: Resolve dependencies first
    Let resolved_dependencies be list containing
    Let dependency_values be dictionary containing For each dependency_name in fixture_def.dependencies:
    Let dependency_request be FixtureRequest with:
    fixture_name as dependency_name
    requesting_context as request.fixture_name
    parameters as None
    required_scope as fixture_def.scope
    metadata as dictionary containing "parent_fixture" as request.fixture_name Let dependency_result be resolve_fixture with registry as registry and request as dependency_request
    If not dependency_result.success:
    Return FixtureResult with:
    success as false
    value as None
    creation_time as get_current_timestamp - resolution_start_time
    dependencies_resolved as resolved_dependencies
    error_message as "Failed to resolve dependency " dependency_name ": " dependency_result.error_message
    metadata as dictionary containing Add dependency_name to resolved_dependencies
    Set dependency_values at key dependency_name to dependency_result.value Note: Create fixture instance
    Let instance_result be create_fixture_instance with fixture_def as fixture_def and dependencies as dependency_values and parameters as request.parameters
    If not instance_result.success:
    Return FixtureResult with:
    success as false
    value as None
    creation_time as get_current_timestamp - resolution_start_time
    dependencies_resolved as resolved_dependencies
    error_message as instance_result.error_message
    metadata as dictionary containing Note: Cache the instance at appropriate scope
    Let fixture_instance be FixtureInstance with:
    fixture_name as request.fixture_name
    value as instance_result.value
    scope as fixture_def.scope
    created_at as get_current_timestamp
    dependencies as resolved_dependencies
    cleanup_scheduled as false
    metadata as dictionary containing "creation_context" as request.requesting_context Cache fixture_instance in registry at appropriate scope Note: Schedule cleanup if needed
    If fixture_def.cleanup_function is not None:
    Schedule cleanup for fixture_instance in registry Note: Update fixture access statistics
    Set fixture_def.access_count to fixture_def.access_count + 1
    Set fixture_def.created_at to Some with value as get_current_timestamp Return FixtureResult with:
    success as true
    value as instance_result.value
    creation_time as get_current_timestamp - resolution_start_time
    dependencies_resolved as resolved_dependencies
    error_message as ""
    metadata as dictionary containing "cache_hit" as false, "dependencies_count" as length of resolved_dependencies Catch error:
    Return FixtureResult with:
    success as false
    value as None
    creation_time as get_current_timestamp - resolution_start_time
    dependencies_resolved as list containing
    error_message as "Fixture resolution error: " error.message
    metadata as dictionary containing

Process called "create_fixture_instance" that takes fixture_def as Fixture and dependencies as Dictionary[String, Any] and parameters as Optional[List[Any]] returns Dictionary[String, Any]:
    Note: Create new instance of fixture by calling factory function
    Try:
    Note: Prepare factory function call
    Let function_args be list containing Note: Add dependency values as arguments
    For each dependency_name in fixture_def.dependencies:
    If dependencies contains key dependency_name:
    Add dependencies[dependency_name] to function_args Note: Add parameters if provided
    If parameters is not None:
    For each param in parameters:
    Add param to function_args Note: Execute factory function
    Let factory_result be execute_factory_function with function_name as fixture_def.factory_function and arguments as function_args If factory_result.success:
    Return dictionary containing:
    "success" as true,
    "value" as factory_result.value,
    "error_message" as ""
    Otherwise:
    Return dictionary containing:
    "success" as false,
    "value" as None,
    "error_message" as "Factory function failed: " factory_result.error_message Catch error:
    Return dictionary containing:
    "success" as false,
    "value" as None,
    "error_message" as "Factory execution error: " error.message

Note: Fixture Scope Management
Process called "start_scope" that takes registry as FixtureRegistry and scope_name as String returns Boolean:
    Note: Start new fixture scope and initialize scope manager
    If registry.scope_managers contains key scope_name:
    Let scope_manager be registry.scope_managers[scope_name]
    Set scope_manager.scope_started_at to get_current_timestamp
    Set scope_manager.active_fixtures to list containing
    Set scope_manager.cleanup_order to list containing
    Set scope_manager.scope_data to dictionary containing "started" as true Set registry.metadata at key ("scope_" scope_name "_active") to true
    Return true
    Otherwise:
    Let new_scope_manager be create_scope_manager with name as scope_name
    Set registry.scope_managers at key scope_name to new_scope_manager
    Return start_scope with registry as registry and scope_name as scope_name

Process called "end_scope" that takes registry as FixtureRegistry and scope_name as String returns Boolean:
    Note: End fixture scope and execute all cleanup actions
    If not registry.scope_managers contains key scope_name:
    Return false Let scope_manager be registry.scope_managers[scope_name]
    Let cleanup_success be true Note: Execute cleanup for all fixtures in reverse order of creation
    Let cleanup_order be reverse_list with list as scope_manager.cleanup_order
    For each fixture_name in cleanup_order:
    Let cleanup_result be cleanup_fixture with registry as registry and fixture_name as fixture_name
    If not cleanup_result:
    Set cleanup_success to false
    Set registry.metadata at key "last_cleanup_error" to "Failed to cleanup fixture: " fixture_name Note: Clear scope manager state
    Set scope_manager.active_fixtures to list containing
    Set scope_manager.cleanup_order to list containing
    Set scope_manager.scope_data to dictionary containing "ended" as true Note: Remove cached instances for this scope
    Let instances_to_remove be list containing
    For each instance_name in keys of registry.active_instances:
    Let instance be registry.active_instances[instance_name]
    If scope_matches with instance_scope as instance.scope and target_scope as scope_name:
    Add instance_name to instances_to_remove For each instance_name in instances_to_remove:
    Remove instance_name from registry.active_instances Set registry.metadata at key ("scope_" scope_name "_active") to false
    Return cleanup_success

Process called "cleanup_fixture" that takes registry as FixtureRegistry and fixture_name as String returns Boolean:
    Note: Execute cleanup for specific fixture
    If not registry.fixtures contains key fixture_name:
    Return false Let fixture_def be registry.fixtures[fixture_name]
    If fixture_def.cleanup_function is None:
    Return true Note: No cleanup needed Try:
    Note: Get fixture instance for cleanup
    If registry.active_instances contains key fixture_name:
    Let instance be registry.active_instances[fixture_name]
    Let cleanup_result be execute_cleanup_function with function_name as fixture_def.cleanup_function and fixture_value as instance.value If cleanup_result.success:
    Set instance.cleanup_scheduled to false
    Set registry.metadata at key ("cleanup_" fixture_name) to get_current_timestamp
    Return true
    Otherwise:
    Set registry.metadata at key "last_cleanup_error" to cleanup_result.error_message
    Return false Return true Note: Instance not active, no cleanup needed Catch error:
    Set registry.metadata at key "last_cleanup_error" to error.message
    Return false

Note: Fixture Caching and Performance
Process called "get_cached_fixture_instance" that takes registry as FixtureRegistry and fixture_name as String and scope as FixtureScope returns Optional[FixtureInstance]:
    Note: Retrieve cached fixture instance if available at appropriate scope
    If registry.active_instances contains key fixture_name:
    Let instance be registry.active_instances[fixture_name] Note: Check if cached instance scope is compatible with requested scope
    If is_scope_compatible with cached_scope as instance.scope and requested_scope as scope:
    Return Some with value as instance Return None

Process called "cache_fixture_instance" that takes registry as FixtureRegistry and instance as FixtureInstance returns Boolean:
    Note: Cache fixture instance at appropriate scope level
    Let scope_key be get_scope_key with scope as instance.scope Note: Add to active instances
    Set registry.active_instances at key instance.fixture_name to instance Note: Add to scope manager
    If registry.scope_managers contains key scope_key:
    Let scope_manager be registry.scope_managers[scope_key]
    Add instance.fixture_name to scope_manager.active_fixtures
    Add instance.fixture_name to scope_manager.cleanup_order Set registry.metadata at key ("cached_" instance.fixture_name) to get_current_timestamp
    Return true

Process called "invalidate_fixture_cache" that takes registry as FixtureRegistry and fixture_name as String returns Boolean:
    Note: Invalidate cached fixture and force recreation on next access
    If registry.active_instances contains key fixture_name:
    Let instance be registry.active_instances[fixture_name] Note: Execute cleanup if not already done
    If not instance.cleanup_scheduled:
    Cleanup fixture with registry and fixture_name Remove fixture_name from registry.active_instances
    Set registry.metadata at key ("invalidated_" fixture_name) to get_current_timestamp
    Return true Return false

Note: Fixture Dependencies and Validation
Process called "validate_fixture_definition" that takes fixture as Fixture and registry as FixtureRegistry returns Dictionary[String, Any]:
    Note: Validate fixture definition for common errors
    Let validation_errors be list containing Note: Check fixture name
    If length of fixture.name is equal to 0:
    Add "Fixture name cannot be empty" to validation_errors Note: Check factory function
    If length of fixture.factory_function is equal to 0:
    Add "Factory function name cannot be empty" to validation_errors Note: Check for self-dependency
    For each dependency in fixture.dependencies:
    If dependency is equal to fixture.name:
    Add "Fixture cannot depend on itself" to validation_errors Note: Check if all dependencies exist
    For each dependency in fixture.dependencies:
    If not registry.fixtures contains key dependency:
    Add "Dependency not found: " dependency to validation_errors Let is_valid be length of validation_errors is equal to 0
    Let error_message be ""
    If not is_valid:
    Set error_message to Format.join with items as validation_errors and sep as "; "
    Return dictionary containing:
    "valid" as is_valid,
    "error_message" as error_message,
    "errors" as validation_errors

Process called "check_circular_dependencies" that takes registry as FixtureRegistry returns Dictionary[String, Any]:
    Note: Check for circular dependencies using depth-first search
    Let visited be Collections.create_set
    Let recursion_stack be Collections.create_set
    Let cycle_path be list containing For each fixture_name in keys of registry.fixtures:
    If not Collections.contains with set as visited and item as fixture_name:
    Let cycle_result be detect_cycle_dfs with registry as registry and node as fixture_name and visited as visited and recursion_stack as recursion_stack and path as cycle_path
    If cycle_result.has_cycle:
    Return dictionary containing:
    "has_cycles" as true,
    "cycle_description" as Format.join with items as cycle_result.cycle_path and sep as " -> ",
    "cycle_path" as cycle_result.cycle_path Return dictionary containing:
    "has_cycles" as false,
    "cycle_description" as "",
    "cycle_path" as list containing

Process called "detect_cycle_dfs" that takes registry as FixtureRegistry and node as String and visited as Collections.Set and recursion_stack as Collections.Set and path as List[String] returns Dictionary[String, Any]:
    Note: Depth-first search to detect cycles in dependency graph
    Collections.add with set as visited and item as node
    Collections.add with set as recursion_stack and item as node
    Add node to path If registry.dependency_graph contains key node:
    For each dependency in registry.dependency_graph[node]:
    If not Collections.contains with set as visited and item as dependency:
    Let cycle_result be detect_cycle_dfs with registry as registry and node as dependency and visited as visited and recursion_stack as recursion_stack and path as path
    If cycle_result.has_cycle:
    Return cycle_result
    Otherwise if Collections.contains with set as recursion_stack and item as dependency:
    Note: Cycle detected
    Add dependency to path
    Return dictionary containing:
    "has_cycle" as true,
    "cycle_path" as copy_list with list as path Collections.remove with set as recursion_stack and item as node
    Remove last item from path Return dictionary containing:
    "has_cycle" as false,
    "cycle_path" as list containing

Note: Utility Functions for Fixture Management
Process called "create_scope_manager" that takes name as String returns ScopeManager:
    Note: Create scope manager for fixture lifecycle
    Return ScopeManager with:
    scope_name as name
    active_fixtures as list containing
    cleanup_order as list containing
    scope_started_at as get_current_timestamp
    scope_data as dictionary containing
    metadata as dictionary containing

Process called "describe_fixture_scope" that takes scope as FixtureScope returns String:
    Note: Get human-readable description of fixture scope
    Match scope:
    When FunctionScope:
    Return "function"
    When ClassScope:
    Return "class"
    When ModuleScope:
    Return "module"
    When SessionScope:
    Return "session"
    When CustomScope with scope_name as name:
    Return name

Process called "get_scope_key" that takes scope as FixtureScope returns String:
    Note: Get string key for scope-based caching
    Return describe_fixture_scope with scope as scope

Process called "is_scope_compatible" that takes cached_scope as FixtureScope and requested_scope as FixtureScope returns Boolean:
    Note: Check if cached fixture scope is compatible with requested scope
    Let cached_key be get_scope_key with scope as cached_scope
    Let requested_key be get_scope_key with scope as requested_scope Note: Session scope fixtures can be used by any scope
    If cached_key is equal to "session":
    Return true Note: Module scope fixtures can be used by class and function scopes
    If cached_key is equal to "module" and (requested_key is equal to "class" or requested_key is equal to "function"):
    Return true Note: Class scope fixtures can be used by function scope
    If cached_key is equal to "class" and requested_key is equal to "function":
    Return true Note: Otherwise, scopes must match exactly
    Return cached_key is equal to requested_key

Process called "scope_matches" that takes instance_scope as FixtureScope and target_scope as String returns Boolean:
    Note: Check if instance scope matches target scope name
    Let instance_scope_key be get_scope_key with scope as instance_scope
    Return instance_scope_key is equal to target_scope

Process called "reverse_list" that takes list as List[String] returns List[String]:
    Note: Reverse order of list items
    Let reversed_list be list containing
    For i from (length of list - 1) down to 0:
    Add list[i] to reversed_list
    Return reversed_list

Process called "copy_list" that takes list as List[String] returns List[String]:
    Note: Create copy of list
    Let copied_list be list containing
    For each item in list:
    Add item to copied_list
    Return copied_list

Process called "keys" that takes dict as Dictionary[String, Any] returns List[String]:
    Note: Extract keys from dictionary
    Return list containing

