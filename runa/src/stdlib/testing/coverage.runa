Note:
Runa Standard Library: Advanced Code Coverage Analysis Framework

Production-grade code coverage system designed to surpass competitors like
Coverage.py, JaCoCo, OpenCover, and gcov. Comprehensive coverage measurement
with advanced analysis and reporting capabilities.

Key Features:
- Line, branch, function, and condition coverage measurement
- Real-time coverage tracking during test execution
- Coverage report generation in multiple formats (HTML, XML, JSON, LCOV)
- Path coverage analysis with cyclomatic complexity calculation
- Coverage differential analysis between runs and branches
- Integration with CI/CD systems for automated coverage enforcement
- Coverage exclusion patterns and ignore rules
- Dead code detection and unused code identification
- Coverage-guided test generation suggestions
- Performance-optimized instrumentation with minimal overhead
- Distributed coverage collection for parallel test execution
- Coverage trend analysis and historical tracking
- Integration with mutation testing for coverage quality assessment

Architecture:
Built on Runa's natural language primitives with efficient instrumentation
and data collection. Provides both runtime coverage tracking and static
analysis capabilities with comprehensive reporting APIs.
:End Note

Import "../../collections" as Collections
Import "string/format" as Format
Import "io/file" as File

Note: Core Coverage Types and Structures
Type called "CoverageTracker":
    source_files as Dictionary[String, SourceFile]
    coverage_data as Dictionary[String, FileCoverage]
    instrumentation_points as Dictionary[String, List[InstrumentationPoint]]
    execution_trace as List[ExecutionEvent]
    configuration as CoverageConfiguration
    metadata as Dictionary[String, Any]

Type called "SourceFile":
    file_path as String
    source_lines as List[String]
    line_count as Integer
    function_definitions as List[FunctionInfo]
    branch_points as List[BranchPoint]
    instrumentation_id as String
    metadata as Dictionary[String, Any]

Type called "FileCoverage":
    file_path as String
    line_coverage as Dictionary[Integer, LineCoverage]
    branch_coverage as Dictionary[Integer, BranchCoverage]
    function_coverage as Dictionary[String, FunctionCoverage]
    condition_coverage as Dictionary[Integer, ConditionCoverage]
    total_lines as Integer
    covered_lines as Integer
    coverage_percentage as Float
    metadata as Dictionary[String, Any]

Type called "LineCoverage":
    line_number as Integer
    execution_count as Integer
    is_covered as Boolean
    is_executable as Boolean
    source_content as String
    execution_times as List[Float]
    metadata as Dictionary[String, Any]

Type called "BranchCoverage":
    branch_id as String
    line_number as Integer
    true_branch_count as Integer
    false_branch_count as Integer
    total_branches as Integer
    covered_branches as Integer
    branch_percentage as Float
    metadata as Dictionary[String, Any]

Type called "FunctionCoverage":
    function_name as String
    start_line as Integer
    end_line as Integer
    call_count as Integer
    is_covered as Boolean
    cyclomatic_complexity as Integer
    path_coverage as PathCoverage
    metadata as Dictionary[String, Any]

Type called "ConditionCoverage":
    condition_id as String
    line_number as Integer
    total_conditions as Integer
    covered_conditions as Integer
    condition_results as List[ConditionResult]
    coverage_percentage as Float
    metadata as Dictionary[String, Any]

Type called "PathCoverage":
    function_name as String
    total_paths as Integer
    covered_paths as Integer
    path_coverage_percentage as Float
    executed_paths as List[ExecutionPath]
    uncovered_paths as List[ExecutionPath]
    metadata as Dictionary[String, Any]

Type called "ExecutionPath":
    path_id as String
    nodes as List[String]
    execution_count as Integer
    average_execution_time as Float
    complexity_score as Integer
    metadata as Dictionary[String, Any]

Type called "InstrumentationPoint":
    point_id as String
    file_path as String
    line_number as Integer
    point_type as InstrumentationType
    target_element as String
    insertion_point as String
    metadata as Dictionary[String, Any]

Type InstrumentationType is:
    | LineInstrumentation
    | BranchInstrumentation
    | FunctionEntryInstrumentation
    | FunctionExitInstrumentation
    | ConditionInstrumentation

Type called "ExecutionEvent":
    event_id as String
    timestamp as Float
    file_path as String
    line_number as Integer
    event_type as String
    execution_context as String
    metadata as Dictionary[String, Any]

Type called "CoverageConfiguration":
    include_patterns as List[String]
    exclude_patterns as List[String]
    branch_coverage_enabled as Boolean
    function_coverage_enabled as Boolean
    condition_coverage_enabled as Boolean
    path_coverage_enabled as Boolean
    minimum_coverage_threshold as Float
    report_formats as List[String]
    output_directory as String
    metadata as Dictionary[String, Any]

Type called "CoverageReport":
    overall_coverage as OverallCoverage
    file_reports as List[FileCoverageReport]
    summary_statistics as CoverageSummary
    generation_time as Float
    report_format as String
    metadata as Dictionary[String, Any]

Type called "OverallCoverage":
    line_coverage_percentage as Float
    branch_coverage_percentage as Float
    function_coverage_percentage as Float
    condition_coverage_percentage as Float
    path_coverage_percentage as Float
    total_files as Integer
    covered_files as Integer
    metadata as Dictionary[String, Any]

Note: Coverage Tracker Initialization and Configuration
Process called "create_coverage_tracker" returns CoverageTracker:
    Note: Create coverage tracker with default configuration
    Let config be CoverageConfiguration with:
    include_patterns as list containing "**/*.runa"
    exclude_patterns as list containing "**/test_*", "**/*_test.runa"
    branch_coverage_enabled as true
    function_coverage_enabled as true
    condition_coverage_enabled as true
    path_coverage_enabled as false
    minimum_coverage_threshold as 80.0
    report_formats as list containing "console", "html"
    output_directory as "coverage_reports"
    metadata as dictionary containing
    Return CoverageTracker with:
    source_files as dictionary containing
    coverage_data as dictionary containing
    instrumentation_points as dictionary containing
    execution_trace as list containing
    configuration as config
    metadata as dictionary containing "created_at" as get_current_timestamp

Process called "create_coverage_tracker_with_config" that takes config as CoverageConfiguration returns CoverageTracker:
    Note: Create coverage tracker with custom configuration
    Return CoverageTracker with:
    source_files as dictionary containing
    coverage_data as dictionary containing
    instrumentation_points as dictionary containing
    execution_trace as list containing
    configuration as config
    metadata as dictionary containing "created_at" as get_current_timestamp

Process called "register_source_file" that takes tracker as CoverageTracker and file_path as String returns Boolean:
    Note: Register source file for coverage tracking
    Try:
    Let source_content be File.read_file with path as file_path
    Let source_lines be Format.split_lines with text as source_content
    Let functions be analyze_function_definitions with source_lines as source_lines
    Let branches be analyze_branch_points with source_lines as source_lines Let source_file be SourceFile with:
    file_path as file_path
    source_lines as source_lines
    line_count as length of source_lines
    function_definitions as functions
    branch_points as branches
    instrumentation_id as generate_instrumentation_id with file as file_path
    metadata as dictionary containing "registered_at" as get_current_timestamp Set tracker.source_files at key file_path to source_file Note: Initialize coverage data for file
    Let file_coverage be FileCoverage with:
    file_path as file_path
    line_coverage as dictionary containing
    branch_coverage as dictionary containing
    function_coverage as dictionary containing
    condition_coverage as dictionary containing
    total_lines as length of source_lines
    covered_lines as 0
    coverage_percentage as 0.0
    metadata as dictionary containing "initialized_at" as get_current_timestamp Set tracker.coverage_data at key file_path to file_coverage
    Return true Catch error:
    Set tracker.metadata at key "last_error" to "Failed to register file: " error.message
    Return false

Process called "instrument_source_files" that takes tracker as CoverageTracker returns Boolean:
    Note: Add instrumentation points to all registered source files
    Let instrumentation_success be true For each file_path in keys of tracker.source_files:
    Let source_file be tracker.source_files[file_path]
    Let instrumentation_points be generate_instrumentation_points with source_file as source_file and config as tracker.configuration If length of instrumentation_points is greater than 0:
    Set tracker.instrumentation_points at key file_path to instrumentation_points
    Set tracker.metadata at key ("instrumented_" file_path) to get_current_timestamp
    Otherwise:
    Set instrumentation_success to false Set tracker.metadata at key "instrumentation_completed" to instrumentation_success
    Return instrumentation_success

Note: Coverage Data Collection and Tracking
Process called "start_coverage_tracking" that takes tracker as CoverageTracker returns Boolean:
    Note: Begin coverage data collection
    Set tracker.metadata at key "tracking_started" to get_current_timestamp
    Set tracker.metadata at key "tracking_active" to true Note: Clear previous execution trace
    Set tracker.execution_trace to list containing Note: Reset coverage counters
    For each file_path in keys of tracker.coverage_data:
    Reset file_coverage_counters with coverage as tracker.coverage_data[file_path] Return true

Process called "stop_coverage_tracking" that takes tracker as CoverageTracker returns Boolean:
    Note: Stop coverage data collection and finalize results
    Set tracker.metadata at key "tracking_stopped" to get_current_timestamp
    Set tracker.metadata at key "tracking_active" to false Note: Process execution trace to generate coverage statistics
    Process execution_trace_to_coverage with tracker as tracker Note: Calculate coverage percentages
    For each file_path in keys of tracker.coverage_data:
    Calculate file_coverage_percentages with coverage as tracker.coverage_data[file_path] Return true

Process called "record_line_execution" that takes tracker as CoverageTracker and file_path as String and line_number as Integer and execution_time as Float returns Boolean:
    Note: Record execution of specific line
    If not tracker.metadata contains key "tracking_active" or not tracker.metadata["tracking_active"]:
    Return false Let event be ExecutionEvent with:
    event_id as generate_event_id with file as file_path and line as line_number
    timestamp as get_current_timestamp
    file_path as file_path
    line_number as line_number
    event_type as "line_execution"
    execution_context as get_current_execution_context
    metadata as dictionary containing "execution_time" as execution_time Add event to tracker.execution_trace Note: Update line coverage immediately for performance
    If tracker.coverage_data contains key file_path:
    Let file_coverage be tracker.coverage_data[file_path]
    If file_coverage.line_coverage contains key line_number:
    Let line_cov be file_coverage.line_coverage[line_number]
    Set line_cov.execution_count to line_cov.execution_count + 1
    Set line_cov.is_covered to true
    Add execution_time to line_cov.execution_times
    Otherwise:
    Let line_cov be LineCoverage with:
    line_number as line_number
    execution_count as 1
    is_covered as true
    is_executable as true
    source_content as get_line_content with tracker as tracker and file_path as file_path and line_number as line_number
    execution_times as list containing execution_time
    metadata as dictionary containing
    Set file_coverage.line_coverage at key line_number to line_cov Return true

Process called "record_branch_execution" that takes tracker as CoverageTracker and file_path as String and line_number as Integer and branch_taken as Boolean returns Boolean:
    Note: Record branch execution decision
    If not tracker.configuration.branch_coverage_enabled:
    Return true Let event be ExecutionEvent with:
    event_id as generate_event_id with file as file_path and line as line_number
    timestamp as get_current_timestamp
    file_path as file_path
    line_number as line_number
    event_type as "branch_execution"
    execution_context as get_current_execution_context
    metadata as dictionary containing "branch_taken" as branch_taken Add event to tracker.execution_trace Note: Update branch coverage
    If tracker.coverage_data contains key file_path:
    Let file_coverage be tracker.coverage_data[file_path]
    Let branch_id be file_path ":" Format.integer_to_string with value as line_number If file_coverage.branch_coverage contains key line_number:
    Let branch_cov be file_coverage.branch_coverage[line_number]
    If branch_taken:
    Set branch_cov.true_branch_count to branch_cov.true_branch_count + 1
    Otherwise:
    Set branch_cov.false_branch_count to branch_cov.false_branch_count + 1 Set branch_cov.covered_branches to count_covered_branches with branch_coverage as branch_cov
    Set branch_cov.branch_percentage to calculate_branch_percentage with branch_coverage as branch_cov
    Otherwise:
    Let branch_cov be BranchCoverage with:
    branch_id as branch_id
    line_number as line_number
    true_branch_count as if branch_taken then 1 else 0
    false_branch_count as if branch_taken then 0 else 1
    total_branches as 2
    covered_branches as 1
    branch_percentage as 50.0
    metadata as dictionary containing
    Set file_coverage.branch_coverage at key line_number to branch_cov Return true

Process called "record_function_execution" that takes tracker as CoverageTracker and file_path as String and function_name as String and start_line as Integer and end_line as Integer returns Boolean:
    Note: Record function execution
    If not tracker.configuration.function_coverage_enabled:
    Return true Let event be ExecutionEvent with:
    event_id as generate_event_id with file as file_path and line as start_line
    timestamp as get_current_timestamp
    file_path as file_path
    line_number as start_line
    event_type as "function_execution"
    execution_context as get_current_execution_context
    metadata as dictionary containing "function_name" as function_name, "end_line" as end_line Add event to tracker.execution_trace Note: Update function coverage
    If tracker.coverage_data contains key file_path:
    Let file_coverage be tracker.coverage_data[file_path] If file_coverage.function_coverage contains key function_name:
    Let func_cov be file_coverage.function_coverage[function_name]
    Set func_cov.call_count to func_cov.call_count + 1
    Set func_cov.is_covered to true
    Otherwise:
    Let func_cov be FunctionCoverage with:
    function_name as function_name
    start_line as start_line
    end_line as end_line
    call_count as 1
    is_covered as true
    cyclomatic_complexity as calculate_cyclomatic_complexity with tracker as tracker and file_path as file_path and function_name as function_name
    path_coverage as create_empty_path_coverage with function_name as function_name
    metadata as dictionary containing
    Set file_coverage.function_coverage at key function_name to func_cov Return true

Note: Coverage Analysis and Statistics
Process called "analyze_coverage_data" that takes tracker as CoverageTracker returns CoverageReport:
    Note: Analyze collected coverage data and generate comprehensive report
    Let analysis_start_time be get_current_timestamp Let overall_coverage be calculate_overall_coverage with tracker as tracker
    Let file_reports be generate_file_coverage_reports with tracker as tracker
    Let summary_statistics be calculate_coverage_summary with tracker as tracker Return CoverageReport with:
    overall_coverage as overall_coverage
    file_reports as file_reports
    summary_statistics as summary_statistics
    generation_time as get_current_timestamp - analysis_start_time
    report_format as "analysis"
    metadata as dictionary containing "analyzed_at" as get_current_timestamp, "file_count" as length of keys of tracker.coverage_data

Process called "calculate_overall_coverage" that takes tracker as CoverageTracker returns OverallCoverage:
    Note: Calculate overall coverage statistics across all files
    Let total_lines be 0
    Let covered_lines be 0
    Let total_branches be 0
    Let covered_branches be 0
    Let total_functions be 0
    Let covered_functions be 0
    Let covered_files be 0 For each file_path in keys of tracker.coverage_data:
    Let file_coverage be tracker.coverage_data[file_path]
    Set total_lines to total_lines + file_coverage.total_lines
    Set covered_lines to covered_lines + file_coverage.covered_lines Note: Count branches
    For each line_num in keys of file_coverage.branch_coverage:
    Let branch_cov be file_coverage.branch_coverage[line_num]
    Set total_branches to total_branches + branch_cov.total_branches
    Set covered_branches to covered_branches + branch_cov.covered_branches Note: Count functions
    For each func_name in keys of file_coverage.function_coverage:
    Let func_cov be file_coverage.function_coverage[func_name]
    Set total_functions to total_functions + 1
    If func_cov.is_covered:
    Set covered_functions to covered_functions + 1 Note: Check if file has any coverage
    If file_coverage.coverage_percentage is greater than 0.0:
    Set covered_files to covered_files + 1 Let line_coverage_pct be if total_lines is greater than 0 then (covered_lines divided by total_lines) multiplied by 100.0 else 0.0
    Let branch_coverage_pct be if total_branches is greater than 0 then (covered_branches divided by total_branches) multiplied by 100.0 else 0.0
    Let function_coverage_pct be if total_functions is greater than 0 then (covered_functions divided by total_functions) multiplied by 100.0 else 0.0 Return OverallCoverage with:
    line_coverage_percentage as line_coverage_pct
    branch_coverage_percentage as branch_coverage_pct
    function_coverage_percentage as function_coverage_pct
    condition_coverage_percentage as 0.0 Note: Placeholder for condition coverage
    path_coverage_percentage as 0.0 Note: Placeholder for path coverage
    total_files as length of keys of tracker.coverage_data
    covered_files as covered_files
    metadata as dictionary containing "calculation_method" as "aggregate"

Process called "find_uncovered_lines" that takes tracker as CoverageTracker and file_path as String returns List[Integer]:
    Note: Find all uncovered executable lines in a file
    Let uncovered_lines be list containing If tracker.coverage_data contains key file_path:
    Let file_coverage be tracker.coverage_data[file_path]
    Let source_file be tracker.source_files[file_path] For line_num from 1 to source_file.line_count:
    If is_executable_line with source_file as source_file and line_number as line_num:
    If not file_coverage.line_coverage contains key line_num or not file_coverage.line_coverage[line_num].is_covered:
    Add line_num to uncovered_lines Return uncovered_lines

Process called "find_dead_code" that takes tracker as CoverageTracker returns Dictionary[String, List[Integer]]:
    Note: Identify potentially dead code across all files
    Let dead_code_map be dictionary containing For each file_path in keys of tracker.coverage_data:
    Let uncovered_lines be find_uncovered_lines with tracker as tracker and file_path as file_path
    Let suspicious_lines be filter_suspicious_lines with tracker as tracker and file_path as file_path and uncovered_lines as uncovered_lines If length of suspicious_lines is greater than 0:
    Set dead_code_map at key file_path to suspicious_lines Return dead_code_map

Process called "calculate_coverage_differential" that takes current_tracker as CoverageTracker and baseline_tracker as CoverageTracker returns Dictionary[String, Any]:
    Note: Calculate coverage differences between two tracking sessions
    Let current_overall be calculate_overall_coverage with tracker as current_tracker
    Let baseline_overall be calculate_overall_coverage with tracker as baseline_tracker Let line_coverage_diff be current_overall.line_coverage_percentage - baseline_overall.line_coverage_percentage
    Let branch_coverage_diff be current_overall.branch_coverage_percentage - baseline_overall.branch_coverage_percentage
    Let function_coverage_diff be current_overall.function_coverage_percentage - baseline_overall.function_coverage_percentage Let file_changes be dictionary containing
    For each file_path in keys of current_tracker.coverage_data:
    If baseline_tracker.coverage_data contains key file_path:
    Let current_file_cov be current_tracker.coverage_data[file_path].coverage_percentage
    Let baseline_file_cov be baseline_tracker.coverage_data[file_path].coverage_percentage
    Let file_diff be current_file_cov - baseline_file_cov
    Set file_changes at key file_path to file_diff Return dictionary containing:
    "line_coverage_change" as line_coverage_diff,
    "branch_coverage_change" as branch_coverage_diff,
    "function_coverage_change" as function_coverage_diff,
    "file_coverage_changes" as file_changes,
    "overall_trend" as if line_coverage_diff is greater than 0.0 then "improved" else if line_coverage_diff is less than 0.0 then "declined" else "unchanged"

Note: Coverage Reporting and Output Generation
Process called "generate_console_report" that takes report as CoverageReport returns String:
    Note: Generate human-readable console coverage report
    Let output be ""
    Set output to output "\n" "=" multiplied by 60 "\n"
    Set output to output "RUNA CODE COVERAGE REPORT\n"
    Set output to output "=" multiplied by 60 "\n\n" Note: Overall coverage summary
    Set output to output "OVERALL COVERAGE:\n"
    Set output to output "Line Coverage: " Format.float_to_string with value as report.overall_coverage.line_coverage_percentage "%\n"
    Set output to output "Branch Coverage: " Format.float_to_string with value as report.overall_coverage.branch_coverage_percentage "%\n"
    Set output to output "Function Coverage: " Format.float_to_string with value as report.overall_coverage.function_coverage_percentage "%\n"
    Set output to output "Files Covered: " Format.integer_to_string with value as report.overall_coverage.covered_files "/" Format.integer_to_string with value as report.overall_coverage.total_files "\n\n" Note: File-by-file breakdown
    Set output to output "FILE COVERAGE DETAILS:\n"
    Set output to output "-" multiplied by 60 "\n"
    For each file_report in report.file_reports:
    Set output to output Format.pad_right with s as file_report.file_path and width as 40
    Set output to output " " Format.float_to_string with value as file_report.coverage_percentage "%"
    If file_report.coverage_percentage is less than 50.0:
    Set output to output " (LOW)"
    Otherwise if file_report.coverage_percentage is less than 80.0:
    Set output to output " (MEDIUM)"
    Otherwise:
    Set output to output " (GOOD)"
    Set output to output "\n"
    Set output to output "\n" Note: Coverage thresholds and warnings
    If report.overall_coverage.line_coverage_percentage is less than 80.0:
    Set output to output "⚠️ WARNING: Line coverage below 80% threshold\n"
    If report.overall_coverage.branch_coverage_percentage is less than 70.0:
    Set output to output "⚠️ WARNING: Branch coverage below 70% threshold\n"
    Set output to output "\nGeneration time: " Format.float_to_string with value as report.generation_time "s\n"
    Return output

Process called "generate_html_report" that takes report as CoverageReport and output_path as String returns Boolean:
    Note: Generate comprehensive HTML coverage report
    Let html_content be generate_html_report_content with report as report Try:
    File.write_file with path as output_path and content as html_content
    Return true
    Catch error:
    Return false

Process called "generate_json_report" that takes report as CoverageReport returns String:
    Note: Generate JSON format coverage report
    Let json_object be dictionary containing
    Set json_object at key "overall_coverage" to serialize_overall_coverage with coverage as report.overall_coverage
    Set json_object at key "file_reports" to serialize_file_reports with reports as report.file_reports
    Set json_object at key "summary_statistics" to serialize_coverage_summary with summary as report.summary_statistics
    Set json_object at key "generation_time" to report.generation_time
    Set json_object at key "report_format" to report.report_format Return Format.to_json with object as json_object

Process called "generate_lcov_report" that takes tracker as CoverageTracker returns String:
    Note: Generate LCOV format report for integration with external tools
    Let lcov_content be ""
    For each file_path in keys of tracker.coverage_data:
    Set lcov_content to lcov_content "SF:" file_path "\n"
    Let file_coverage be tracker.coverage_data[file_path] Note: Function coverage
    For each func_name in keys of file_coverage.function_coverage:
    Let func_cov be file_coverage.function_coverage[func_name]
    Set lcov_content to lcov_content "FN:" Format.integer_to_string with value as func_cov.start_line "," func_name "\n"
    Set lcov_content to lcov_content "FNDA:" Format.integer_to_string with value as func_cov.call_count "," func_name "\n" Note: Line coverage
    For each line_num in keys of file_coverage.line_coverage:
    Let line_cov be file_coverage.line_coverage[line_num]
    Set lcov_content to lcov_content "DA:" Format.integer_to_string with value as line_num "," Format.integer_to_string with value as line_cov.execution_count "\n" Note: Branch coverage
    For each line_num in keys of file_coverage.branch_coverage:
    Let branch_cov be file_coverage.branch_coverage[line_num]
    Set lcov_content to lcov_content "BRDA:" Format.integer_to_string with value as line_num ",0,0," Format.integer_to_string with value as branch_cov.true_branch_count "\n"
    Set lcov_content to lcov_content "BRDA:" Format.integer_to_string with value as line_num ",0,1," Format.integer_to_string with value as branch_cov.false_branch_count "\n"
    Set lcov_content to lcov_content "end_of_record\n"
    Return lcov_content

Note: Utility Functions for Coverage Analysis
Process called "is_executable_line" that takes source_file as SourceFile and line_number as Integer returns Boolean:
    Note: Determine if line contains executable code
    If line_number is less than 1 or line_number is greater than length of source_file.source_lines:
    Return false Let line_content be Format.trim with s as source_file.source_lines[line_number - 1] Note: Skip empty lines and comments
    If length of line_content is equal to 0:
    Return false
    If Format.starts_with with s as line_content and prefix as "Note:":
    Return false
    If Format.starts_with with s as line_content and prefix as "//":
    Return false Note: Check for executable constructs
    If Format.contains with s as line_content and substr as "Process called":
    Return true
    If Format.contains with s as line_content and substr as "Let ":
    Return true
    If Format.contains with s as line_content and substr as "Set ":
    Return true
    If Format.contains with s as line_content and substr as "Return ":
    Return true
    If Format.contains with s as line_content and substr as "If ":
    Return true
    If Format.contains with s as line_content and substr as "For ":
    Return true
    If Format.contains with s as line_content and substr as "While ":
    Return true Return false

Process called "calculate_cyclomatic_complexity" that takes tracker as CoverageTracker and file_path as String and function_name as String returns Integer:
    Note: Calculate cyclomatic complexity for function
    Let complexity be 1 Note: Base complexity If tracker.source_files contains key file_path:
    Let source_file be tracker.source_files[file_path]
    Let function_info be find_function_definition with source_file as source_file and function_name as function_name If function_info is not None:
    For line_num from function_info.start_line to function_info.end_line:
    If line_num is less than or equal to length of source_file.source_lines:
    Let line_content be source_file.source_lines[line_num - 1] Note: Count decision points
    If Format.contains with s as line_content and substr as "If ":
    Set complexity to complexity + 1
    If Format.contains with s as line_content and substr as "Otherwise if ":
    Set complexity to complexity + 1
    If Format.contains with s as line_content and substr as "While ":
    Set complexity to complexity + 1
    If Format.contains with s as line_content and substr as "For ":
    Set complexity to complexity + 1
    If Format.contains with s as line_content and substr as "Match ":
    Set complexity to complexity + 1
    If Format.contains with s as line_content and substr as "When ":
    Set complexity to complexity + 1 Return complexity

Process called "generate_instrumentation_id" that takes file as String returns String:
    Note: Generate unique instrumentation identifier
    Let timestamp be get_current_timestamp
    Let hash_value be simple_string_hash with text as file
    Return "instr_" Format.integer_to_string with value as hash_value "_" Format.integer_to_string with value as timestamp mod 1000000

Process called "generate_event_id" that takes file as String and line as Integer returns String:
    Note: Generate unique event identifier
    Let timestamp be get_current_timestamp
    Return "event_" Format.integer_to_string with value as simple_string_hash with text as file "_" Format.integer_to_string with value as line "_" Format.integer_to_string with value as timestamp mod 1000000

Process called "simple_string_hash" that takes text as String returns Integer:
    Note: Calculate simple hash for strings
    Let hash_value be 0
    For each character in text:
    Let char_code be Format.ascii_value_of with char as character
    Set hash_value to (hash_value multiplied by 31 + char_code) mod 1000000
    Return hash_value

Process called "get_current_timestamp" returns Float:
    Note: Get current timestamp - would delegate to system in production
    Return 0.0

Process called "get_current_execution_context" returns String:
    Note: Get current execution context - would delegate to runtime
    Return "test_context"

Process called "get_line_content" that takes tracker as CoverageTracker and file_path as String and line_number as Integer returns String:
    Note: Get source content for specific line
    If tracker.source_files contains key file_path:
    Let source_file be tracker.source_files[file_path]
    If line_number is greater than 0 and line_number is less than or equal to length of source_file.source_lines:
    Return source_file.source_lines[line_number - 1]
    Return ""

Process called "count_covered_branches" that takes branch_coverage as BranchCoverage returns Integer:
    Note: Count how many branches have been covered
    Let covered_count be 0
    If branch_coverage.true_branch_count is greater than 0:
    Set covered_count to covered_count + 1
    If branch_coverage.false_branch_count is greater than 0:
    Set covered_count to covered_count + 1
    Return covered_count

Process called "calculate_branch_percentage" that takes branch_coverage as BranchCoverage returns Float:
    Note: Calculate branch coverage percentage
    If branch_coverage.total_branches is equal to 0:
    Return 0.0
    Return (branch_coverage.covered_branches divided by branch_coverage.total_branches) multiplied by 100.0

Process called "keys" that takes dict as Dictionary[String, Any] returns List[String]:
    Note: Extract keys from dictionary by iterating through key-value pairs
    Let key_list be list containing
    For each key and value in dict:
    Add key to key_list
    Return key_list