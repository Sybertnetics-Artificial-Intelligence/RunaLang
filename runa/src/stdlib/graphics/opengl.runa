Process gl_get_extensions:
    Note: Get supported OpenGL extensions
    Return list_utils.create_empty_list

Process gl_query_capabilities:
    Note: Query OpenGL implementation capabilities
    Return GLCapabilities with:\
        max_texture_size as 16384 and\
        max_texture_units as 32 and\
        max_vertex_attribs as 16 and\
        max_uniform_buffer_bindings as 84 and\
        max_shader_storage_buffer_bindings as 8 and\
        max_compute_work_group_count as list_utils.create_list_with_items with items as [65535, 65535, 65535] and\
        max_compute_work_group_size as list_utils.create_list_with_items with items as [1024, 1024, 64] and\
        max_compute_work_group_invocations as 1024 and\
        supports_compute_shaders as true and\
        supports_tessellation as true and\
        supports_geometry_shaders as true and\
        supports_bindless_textures as false and\
        supports_direct_state_access as true and\
        supports_multi_draw_indirect as true and\
        supports_debug_output as true

Process create_gl_state_cache:
    Return GLStateCache with:\
        current_program as 0 and\
        current_vertex_array as 0 and\
        bound_buffers as dict_utils.create_empty_dict and\
        bound_textures as dict_utils.create_empty_dict and\
        active_texture_unit as 0 and\
        viewport as list_utils.create_list_with_items with items as [0, 0, 1920, 1080] and\
        scissor_box as list_utils.create_list_with_items with items as [0, 0, 1920, 1080] and\
        depth_test_enabled as false and\
        blend_enabled as false and\
        face_culling_enabled as false and\
        current_blend_equation as 32774 and\
        current_blend_func as list_utils.create_list_with_items with items as [1, 0]

Process create_invalid_gl_context with error as String:
    Return GLContext with:\
        context_handle as 0 and\
        version_major as 0 and\
        version_minor as 0 and\
        profile as CORE and\
        debug_enabled as false and\
        extensions as list_utils.create_empty_list and\
        capabilities as gl_query_capabilities and\
        state_cache as create_gl_state_cache and\
        error_callback as create_default_error_callback and\
        debug_callback as create_default_debug_callback and\
        metadata as dict_utils.create_dict_with_entries with entries as [("error", error)]

Process create_null_gl_buffer:
    Return GLBuffer with:\
        buffer_id as 0 and\
        buffer_type as ARRAY_BUFFER and\
        usage as STATIC_DRAW and\
        size as 0 and\
        data as list_utils.create_empty_list and\
        mapped as false and\
        map_access as 0 and\
        metadata as dict_utils.create_empty_dict

