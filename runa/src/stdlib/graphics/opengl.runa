    metadata as Dictionary[String, String]

Note: Query and Sync Objects

Type GLQuery is Dictionary with:
    query_id as Integer
    query_type as GLQueryType
    result_available as Boolean
    result as Integer
    metadata as Dictionary[String, String]

Type GLQueryType is:
    | SAMPLES_PASSED
    | ANY_SAMPLES_PASSED
    | ANY_SAMPLES_PASSED_CONSERVATIVE
    | PRIMITIVES_GENERATED
    | TRANSFORM_FEEDBACK_PRIMITIVES_WRITTEN
    | TIME_ELAPSED
    | TIMESTAMP

Type GLSync is Dictionary with:
    sync_object as Integer
    condition as GLSyncCondition
    flags as Integer
    status as GLSyncStatus

Type GLSyncCondition is:
    | SYNC_GPU_COMMANDS_COMPLETE

Type GLSyncStatus is:
    | ALREADY_SIGNALED
    | TIMEOUT_EXPIRED
    | CONDITION_SATISFIED
    | WAIT_FAILED

Note: Core OpenGL Functions

Process gl_create_context with major_version as Integer and minor_version as Integer and profile as GLProfile:
    Let context_handle be gl_native_create_context with major as major_version and minor as minor_version and profile as gl_profile_to_native with profile as profile
    
    If context_handle is equal to 0:
        Return create_invalid_gl_context with error as "Failed to create OpenGL context"
    
    Let extensions be gl_get_extensions
    Let capabilities be gl_query_capabilities
    Let state_cache be create_gl_state_cache
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "gl_context"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    Call dict_utils.set_value with dict as metadata and key as "version" and value as string_utils.format_string with template as "{}.{}" and args as [string_utils.integer_to_string with value as major_version, string_utils.integer_to_string with value as minor_version]
    
    Return GLContext with:\
        context_handle as context_handle and\
        version_major as major_version and\
        version_minor as minor_version and\
        profile as profile and\
        debug_enabled as false and\
        extensions as extensions and\
        capabilities as capabilities and\
        state_cache as state_cache and\
        error_callback as create_default_error_callback and\
        debug_callback as create_default_debug_callback and\
        metadata as metadata

Process gl_make_current with context as GLContext:
    Call gl_native_make_current with handle as context.context_handle
    Call gl_clear_error

Process gl_swap_buffers with context as GLContext:
    Call gl_native_swap_buffers with handle as context.context_handle

Process gl_destroy_context with context as GLContext:
    Call gl_native_destroy_context with handle as context.context_handle
    Set context.context_handle to 0

Note: Buffer Operations

Process gl_create_buffer with buffer_type as GLBufferType and usage as GLUsage:
    Let buffer_id be gl_gen_buffer
    Let buffer_type_native be gl_buffer_type_to_native with buffer_type as buffer_type
    Let usage_native be gl_usage_to_native with usage as usage
    
    Call gl_bind_buffer with target as buffer_type_native and buffer as buffer_id
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "gl_buffer"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return GLBuffer with:\
        buffer_id as buffer_id and\
        buffer_type as buffer_type and\
        usage as usage and\
        size as 0 and\
        data as list_utils.create_empty_list and\
        mapped as false and\
        map_access as 0 and\
        metadata as metadata

Process gl_buffer_data with buffer as GLBuffer and data as List[Byte]:
    Let buffer_type_native be gl_buffer_type_to_native with buffer_type as buffer.buffer_type
    Let usage_native be gl_usage_to_native with usage as buffer.usage
    Let data_size be list_utils.get_length with list as data
    
    Call gl_bind_buffer with target as buffer_type_native and buffer as buffer.buffer_id
    Call gl_buffer_data_native with target as buffer_type_native and size as data_size and data as data and usage as usage_native
    
    Set buffer.data to data
    Set buffer.size to data_size

Process gl_buffer_sub_data with buffer as GLBuffer and offset as Integer and data as List[Byte]:
    Let buffer_type_native be gl_buffer_type_to_native with buffer_type as buffer.buffer_type
    Let data_size be list_utils.get_length with list as data
    
    Call gl_bind_buffer with target as buffer_type_native and buffer as buffer.buffer_id
    Call gl_buffer_sub_data_native with target as buffer_type_native and offset as offset and size as data_size and data as data

Process gl_map_buffer with buffer as GLBuffer and access as Integer:
    Let buffer_type_native be gl_buffer_type_to_native with buffer_type as buffer.buffer_type
    Call gl_bind_buffer with target as buffer_type_native and buffer as buffer.buffer_id
    Let mapped_ptr be gl_map_buffer_native with target as buffer_type_native and access as access
    
    Set buffer.mapped to mapped_ptr is not equal to 0
    Set buffer.map_access to access
    Return mapped_ptr

Process gl_unmap_buffer with buffer as GLBuffer:
    Let buffer_type_native be gl_buffer_type_to_native with buffer_type as buffer.buffer_type
    Call gl_bind_buffer with target as buffer_type_native and buffer as buffer.buffer_id
    Let result be gl_unmap_buffer_native with target as buffer_type_native
    
    Set buffer.mapped to false
    Set buffer.map_access to 0
    Return result

Process gl_delete_buffer with buffer as GLBuffer:
    Call gl_delete_buffers_native with count as 1 and buffers as [buffer.buffer_id]
    Set buffer.buffer_id to 0

Note: Vertex Array Operations

Process gl_create_vertex_array:
    Let vao_id be gl_gen_vertex_array
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "gl_vertex_array"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return GLVertexArray with:\
        vao_id as vao_id and\
        vertex_buffers as list_utils.create_empty_list and\
        index_buffer as create_null_gl_buffer and\
        attribute_bindings as list_utils.create_empty_list and\
        metadata as metadata

Process gl_bind_vertex_array with vao as GLVertexArray:
    Call gl_bind_vertex_array_native with array as vao.vao_id

Process gl_vertex_attrib_pointer with index as Integer and size as Integer and attribute_type as GLAttributeType and normalized as Boolean and stride as Integer and offset as Integer:
    Let type_native be gl_attribute_type_to_native with attribute_type as attribute_type
    Call gl_vertex_attrib_pointer_native with index as index and size as size and type as type_native and normalized as normalized and stride as stride and pointer as offset

Process gl_enable_vertex_attrib_array with index as Integer:
    Call gl_enable_vertex_attrib_array_native with index as index

Process gl_disable_vertex_attrib_array with index as Integer:
    Call gl_disable_vertex_attrib_array_native with index as index

Process gl_vertex_attrib_divisor with index as Integer and divisor as Integer:
    Call gl_vertex_attrib_divisor_native with index as index and divisor as divisor

Process gl_delete_vertex_array with vao as GLVertexArray:
    Call gl_delete_vertex_arrays_native with count as 1 and arrays as [vao.vao_id]
    Set vao.vao_id to 0

Note: Shader Operations

Process gl_create_shader with shader_type as GLShaderType:
    Let shader_type_native be gl_shader_type_to_native with shader_type as shader_type
    Let shader_id be gl_create_shader_native with shader_type as shader_type_native
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "gl_shader"
    Call dict_utils.set_value with dict as metadata and key as "shader_type" and value as gl_shader_type_to_string with shader_type as shader_type
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return GLShader with:\
        shader_id as shader_id and\
        shader_type as shader_type and\
        source_code as "" and\
        compiled as false and\
        compile_log as "" and\
        metadata as metadata

Process gl_shader_source with shader as GLShader and source as String:
    Call gl_shader_source_native with shader as shader.shader_id and count as 1 and string as source and length as string_utils.get_string_length with string as source
    Set shader.source_code to source

Process gl_compile_shader with shader as GLShader:
    Call gl_compile_shader_native with shader as shader.shader_id
    
    Let compile_status be gl_get_shader_iv with shader as shader.shader_id and pname as GL_COMPILE_STATUS
    Set shader.compiled to compile_status is not equal to 0
    
    Let log_length be gl_get_shader_iv with shader as shader.shader_id and pname as GL_INFO_LOG_LENGTH
    If log_length is greater than 0:
        Let log be gl_get_shader_info_log with shader as shader.shader_id and max_length as log_length
        Set shader.compile_log to log

Process gl_delete_shader with shader as GLShader:
    Call gl_delete_shader_native with shader as shader.shader_id
    Set shader.shader_id to 0

Note: Program Operations

Process gl_create_program:
    Let program_id be gl_create_program_native
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "gl_program"
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return GLProgram with:\
        program_id as program_id and\
        shaders as list_utils.create_empty_list and\
        linked as false and\
        link_log as "" and\
        uniforms as dict_utils.create_empty_dict and\
        uniform_blocks as dict_utils.create_empty_dict and\
        attributes as dict_utils.create_empty_dict and\
        shader_storage_blocks as dict_utils.create_empty_dict and\
        metadata as metadata

Process gl_attach_shader with program as GLProgram and shader as GLShader:
    Call gl_attach_shader_native with program as program.program_id and shader as shader.shader_id
    Call list_utils.append with list as program.shaders and item as shader

Process gl_detach_shader with program as GLProgram and shader as GLShader:
    Call gl_detach_shader_native with program as program.program_id and shader as shader.shader_id
    Call list_utils.remove_item with list as program.shaders and item as shader

Process gl_link_program with program as GLProgram:
    Call gl_link_program_native with program as program.program_id
    
    Let link_status be gl_get_program_iv with program as program.program_id and pname as GL_LINK_STATUS
    Set program.linked to link_status is not equal to 0
    
    Let log_length be gl_get_program_iv with program as program.program_id and pname as GL_INFO_LOG_LENGTH
    If log_length is greater than 0:
        Let log be gl_get_program_info_log with program as program.program_id and max_length as log_length
        Set program.link_log to log
    
    If program.linked:
        Call gl_query_program_resources with program as program

Process gl_use_program with program as GLProgram:
    Call gl_use_program_native with program as program.program_id

Process gl_delete_program with program as GLProgram:
    Call gl_delete_program_native with program as program.program_id
    Set program.program_id to 0

Note: Uniform Operations

Process gl_get_uniform_location with program as GLProgram and name as String:
    Return gl_get_uniform_location_native with program as program.program_id and name as name

Process gl_uniform_1f with location as Integer and v0 as Float:
    Call gl_uniform_1f_native with location as location and v0 as v0

Process gl_uniform_2f with location as Integer and v0 as Float and v1 as Float:
    Call gl_uniform_2f_native with location as location and v0 as v0 and v1 as v1

Process gl_uniform_3f with location as Integer and v0 as Float and v1 as Float and v2 as Float:
    Call gl_uniform_3f_native with location as location and v0 as v0 and v1 as v1 and v2 as v2

Process gl_uniform_4f with location as Integer and v0 as Float and v1 as Float and v2 as Float and v3 as Float:
    Call gl_uniform_4f_native with location as location and v0 as v0 and v1 as v1 and v2 as v2 and v3 as v3

Process gl_uniform_1i with location as Integer and v0 as Integer:
    Call gl_uniform_1i_native with location as location and v0 as v0

Process gl_uniform_matrix_4fv with location as Integer and count as Integer and transpose as Boolean and value as List[Float]:
    Call gl_uniform_matrix_4fv_native with location as location and count as count and transpose as transpose and value as value

Note: Texture Operations

Process gl_create_texture with texture_type as GLTextureType:
    Let texture_id be gl_gen_texture
    Let target_native be gl_texture_type_to_native with texture_type as texture_type
    
    Call gl_bind_texture with target as target_native and texture as texture_id
    
    Let metadata be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as metadata and key as "type" and value as "gl_texture"
    Call dict_utils.set_value with dict as metadata and key as "texture_type" and value as gl_texture_type_to_string with texture_type as texture_type
    Call dict_utils.set_value with dict as metadata and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return GLTexture with:\
        texture_id as texture_id and\
        texture_type as texture_type and\
        internal_format as RGBA8 and\
        width as 0 and\
        height as 0 and\
        depth as 0 and\
        mip_levels as 1 and\
        samples as 1 and\
        format as RGBA and\
        pixel_type as UNSIGNED_BYTE and\
        wrap_s as REPEAT and\
        wrap_t as REPEAT and\
        wrap_r as REPEAT and\
        min_filter as LINEAR and\
        mag_filter as LINEAR and\
        anisotropy as 1.0 and\
        metadata as metadata

Process gl_bind_texture with target as Integer and texture as Integer:
    Call gl_bind_texture_native with target as target and texture as texture

Process gl_tex_image_2d with target as Integer and level as Integer and internal_format as GLInternalFormat and width as Integer and height as Integer and format as GLFormat and pixel_type as GLPixelType and pixels as List[Byte]:
    Let internal_format_native be gl_internal_format_to_native with internal_format as internal_format
    Let format_native be gl_format_to_native with format as format
    Let type_native be gl_pixel_type_to_native with pixel_type as pixel_type
    
    Call gl_tex_image_2d_native with target as target and level as level and internal_format as internal_format_native and width as width and height as height and border as 0 and format as format_native and type as type_native and pixels as pixels

Process gl_tex_sub_image_2d with target as Integer and level as Integer and xoffset as Integer and yoffset as Integer and width as Integer and height as Integer and format as GLFormat and pixel_type as GLPixelType and pixels as List[Byte]:
    Let format_native be gl_format_to_native with format as format
