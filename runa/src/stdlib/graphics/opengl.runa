Note: Additional conversion helpers
Process gl_attribute_type_to_native with attribute_type as GLAttributeType:
    Match attribute_type:
        When FLOAT: Return 5126
        When INT: Return 5124
        When UNSIGNED_INT: Return 5125
        Otherwise: Return 5126

Process gl_texture_type_to_native with texture_type as GLTextureType:
    Match texture_type:
        When TEXTURE_2D: Return 3553
        When TEXTURE_3D: Return 32879
        When TEXTURE_CUBE_MAP: Return 34067
        Otherwise: Return 3553

Process gl_internal_format_to_native with internal_format as GLInternalFormat:
    Match internal_format:
        When RGBA8: Return 32856
        When RGBA16F: Return 34842
        When RGBA32F: Return 34836
        Otherwise: Return 32856

Process gl_format_to_native with format as GLFormat:
    Match format:
        When RGBA: Return 6408
        When RGB: Return 6407
        When RED: Return 6403
        Otherwise: Return 6408

Process gl_pixel_type_to_native with pixel_type as GLPixelType:
    Match pixel_type:
        When UNSIGNED_BYTE: Return 5121
        When FLOAT: Return 5126
        When UNSIGNED_INT: Return 5125
        Otherwise: Return 5121

Process gl_shader_type_to_string with shader_type as GLShaderType:
    Match shader_type:
        When VERTEX_SHADER: Return "vertex"
        When FRAGMENT_SHADER: Return "fragment"
        When GEOMETRY_SHADER: Return "geometry"
        When COMPUTE_SHADER: Return "compute"
        Otherwise: Return "unknown"

Process gl_texture_type_to_string with texture_type as GLTextureType:
    Match texture_type:
        When TEXTURE_2D: Return "texture_2d"
        When TEXTURE_3D: Return "texture_3d"
        When TEXTURE_CUBE_MAP: Return "texture_cube_map"
        Otherwise: Return "unknown"

Process gl_log_error with operation as String and error as String:
    Note: Log OpenGL error for debugging
    Return

Note: Module Information

Process get_opengl_info:
    Let info be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as info and key as "module_name" and value as "graphics.opengl"
    Call dict_utils.set_value with dict as info and key as "version" and value as "4.6.0"
    Call dict_utils.set_value with dict as info and key as "description" and value as "Complete OpenGL 4.6+ bindings with modern features and compute shaders"
    Call dict_utils.set_value with dict as info and key as "api_version" and value as "OpenGL 4.6"
    Call dict_utils.set_value with dict as info and key as "features" and value as "Core profile, Compute shaders, Direct state access, Debug output, Multi-draw indirect"
    Call dict_utils.set_value with dict as info and key as "competitive_advantage" and value as "Modern OpenGL API with complete feature coverage and optimized state management"
    Call dict_utils.set_value with dict as info and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return info