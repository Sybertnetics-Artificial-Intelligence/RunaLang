Note: Debug and Error Handling

Process gl_get_error:
    Return gl_get_error_native

Process gl_clear_error:
    Let error be gl_get_error
    While error is not equal to GL_NO_ERROR:
        Set error to gl_get_error

Process gl_check_error with operation as String:
    Let error be gl_get_error
    If error is not equal to GL_NO_ERROR:
        Let error_string be gl_error_to_string with error as error
        Call gl_log_error with operation as operation and error as error_string
        Return false
    Return true

Process gl_enable_debug_output with context as GLContext:
    Call gl_enable with cap as GL_DEBUG_OUTPUT
    Call gl_enable with cap as GL_DEBUG_OUTPUT_SYNCHRONOUS
    Call gl_debug_message_callback with callback as context.debug_callback and user_param as 0
    Set context.debug_enabled to true

Process gl_debug_message_callback with callback as Process and user_param as Integer:
    Call gl_debug_message_callback_native with callback as callback and user_param as user_param

