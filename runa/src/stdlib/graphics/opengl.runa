    | FRAGMENT_SHADER
    | GEOMETRY_SHADER
    | TESS_CONTROL_SHADER
    | TESS_EVALUATION_SHADER
    | COMPUTE_SHADER

Type GLProgram is Dictionary with:
    program_id as Integer
    shaders as List[GLShader]
    linked as Boolean
    link_log as String
    uniforms as Dictionary[String, GLUniform]
    uniform_blocks as Dictionary[String, GLUniformBlock]
    attributes as Dictionary[String, GLAttribute]
    shader_storage_blocks as Dictionary[String, GLShaderStorageBlock]
    metadata as Dictionary[String, String]

Type GLUniform is Dictionary with:
    location as Integer
    uniform_type as GLUniformType
    size as Integer
