    size as Integer
    active_uniforms as List[String]
    binding_point as Integer

Type GLAttribute is Dictionary with:
    location as Integer
    attribute_type as GLUniformType
    name as String

Type GLShaderStorageBlock is Dictionary with:
    index as Integer
    name as String
    size as Integer
    binding_point as Integer

