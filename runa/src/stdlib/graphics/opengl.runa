Process get_gl_constants:
    Let constants be dict_utils.create_empty_dict
    
    Note: Buffer targets
    Call dict_utils.set_value with dict as constants and key as "GL_ARRAY_BUFFER" and value as "34962"
    Call dict_utils.set_value with dict as constants and key as "GL_ELEMENT_ARRAY_BUFFER" and value as "34963"
    Call dict_utils.set_value with dict as constants and key as "GL_UNIFORM_BUFFER" and value as "35345"
    Call dict_utils.set_value with dict as constants and key as "GL_SHADER_STORAGE_BUFFER" and value as "37074"
    
    Note: Buffer usage
    Call dict_utils.set_value with dict as constants and key as "GL_STATIC_DRAW" and value as "35044"
    Call dict_utils.set_value with dict as constants and key as "GL_DYNAMIC_DRAW" and value as "35048"
    Call dict_utils.set_value with dict as constants and key as "GL_STREAM_DRAW" and value as "35040"
    
    Note: Shader types
    Call dict_utils.set_value with dict as constants and key as "GL_VERTEX_SHADER" and value as "35633"
    Call dict_utils.set_value with dict as constants and key as "GL_FRAGMENT_SHADER" and value as "35632"
    Call dict_utils.set_value with dict as constants and key as "GL_GEOMETRY_SHADER" and value as "36313"
    Call dict_utils.set_value with dict as constants and key as "GL_COMPUTE_SHADER" and value as "37305"
    
    Note: Program parameters
    Call dict_utils.set_value with dict as constants and key as "GL_COMPILE_STATUS" and value as "35713"
    Call dict_utils.set_value with dict as constants and key as "GL_LINK_STATUS" and value as "35714"
    Call dict_utils.set_value with dict as constants and key as "GL_INFO_LOG_LENGTH" and value as "35716"
    
    Note: Texture formats
    Call dict_utils.set_value with dict as constants and key as "GL_RGBA8" and value as "32856"
    Call dict_utils.set_value with dict as constants and key as "GL_RGBA16F" and value as "34842"
    Call dict_utils.set_value with dict as constants and key as "GL_RGBA32F" and value as "34836"
    
    Note: Error codes
    Call dict_utils.set_value with dict as constants and key as "GL_NO_ERROR" and value as "0"
    Call dict_utils.set_value with dict as constants and key as "GL_INVALID_ENUM" and value as "1280"
    Call dict_utils.set_value with dict as constants and key as "GL_INVALID_VALUE" and value as "1281"
    Call dict_utils.set_value with dict as constants and key as "GL_INVALID_OPERATION" and value as "1282"
    
    Note: Debug output
    Call dict_utils.set_value with dict as constants and key as "GL_DEBUG_OUTPUT" and value as "37600"
    Call dict_utils.set_value with dict as constants and key as "GL_DEBUG_OUTPUT_SYNCHRONOUS" and value as "33346"
    
    Return constants

Note: Helper functions for enum conversions

Process gl_buffer_type_to_native with buffer_type as GLBufferType:
    Match buffer_type:
        When ARRAY_BUFFER: Return 34962
        When ELEMENT_ARRAY_BUFFER: Return 34963
        When UNIFORM_BUFFER: Return 35345
        When SHADER_STORAGE_BUFFER: Return 37074
        Otherwise: Return 34962

Process gl_usage_to_native with usage as GLUsage:
    Match usage:
        When STATIC_DRAW: Return 35044
        When DYNAMIC_DRAW: Return 35048
        When STREAM_DRAW: Return 35040
        Otherwise: Return 35044

Process gl_shader_type_to_native with shader_type as GLShaderType:
    Match shader_type:
        When VERTEX_SHADER: Return 35633
        When FRAGMENT_SHADER: Return 35632
        When GEOMETRY_SHADER: Return 36313
        When COMPUTE_SHADER: Return 37305
        Otherwise: Return 35633

Process gl_error_to_string with error as Integer:
    Match error:
        When 0: Return "GL_NO_ERROR"
        When 1280: Return "GL_INVALID_ENUM"
        When 1281: Return "GL_INVALID_VALUE"
        When 1282: Return "GL_INVALID_OPERATION"
        When 1283: Return "GL_STACK_OVERFLOW"
        When 1284: Return "GL_STACK_UNDERFLOW"
        When 1285: Return "GL_OUT_OF_MEMORY"
        When 1286: Return "GL_INVALID_FRAMEBUFFER_OPERATION"
        Otherwise: Return "UNKNOWN_ERROR"

Note: Stub implementations for native calls (would be implemented in C/C++ or platform-specific code)

Let GL_NO_ERROR be 0
Let GL_COMPILE_STATUS be 35713
Let GL_LINK_STATUS be 35714
Let GL_INFO_LOG_LENGTH be 35716
Let GL_DEBUG_OUTPUT be 37600
Let GL_DEBUG_OUTPUT_SYNCHRONOUS be 33346

