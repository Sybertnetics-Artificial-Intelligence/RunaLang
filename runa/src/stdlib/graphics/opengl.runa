Note: Modern OpenGL 4.6+ Bindings
Note: Complete OpenGL API bindings with modern features, compute shaders, and advanced debugging
Note: Provides direct GPU access for maximum performance and control over rendering pipeline
:End Note

Import "gaming/core" as core
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "string/format" as string_utils
Import "datetime/datetime" as datetime_module
Import "math/core" as math_module

Note: OpenGL Core Types

Type GLContext is Dictionary with:
    context_handle as Integer
    version_major as Integer
    version_minor as Integer
    profile as GLProfile
    debug_enabled as Boolean
    extensions as List[String]
    capabilities as GLCapabilities
    state_cache as GLStateCache
    error_callback as Process
    debug_callback as Process
    metadata as Dictionary[String, String]

Type GLProfile is:
    | CORE
    | COMPATIBILITY
    | ES

Type GLCapabilities is Dictionary with:
    max_texture_size as Integer
    max_texture_units as Integer
    max_vertex_attribs as Integer
    max_uniform_buffer_bindings as Integer
    max_shader_storage_buffer_bindings as Integer
    max_compute_work_group_count as List[Integer]
    max_compute_work_group_size as List[Integer]
    max_compute_work_group_invocations as Integer
    supports_compute_shaders as Boolean
    supports_tessellation as Boolean
    supports_geometry_shaders as Boolean
    supports_bindless_textures as Boolean
    supports_direct_state_access as Boolean
    supports_multi_draw_indirect as Boolean
    supports_debug_output as Boolean

Type GLStateCache is Dictionary with:
    current_program as Integer
    current_vertex_array as Integer
    bound_buffers as Dictionary[Integer, Integer]
    bound_textures as Dictionary[Integer, Integer]
    active_texture_unit as Integer
    viewport as List[Integer]
    scissor_box as List[Integer]
    depth_test_enabled as Boolean
    blend_enabled as Boolean
    face_culling_enabled as Boolean
    current_blend_equation as Integer
    current_blend_func as List[Integer]

Note: Buffer and Vertex Array Objects

Type GLBuffer is Dictionary with:
    buffer_id as Integer
    buffer_type as GLBufferType
    usage as GLUsage
    size as Integer
    data as List[Byte]
    mapped as Boolean
    map_access as Integer
    metadata as Dictionary[String, String]

Type GLBufferType is:
    | ARRAY_BUFFER
    | ELEMENT_ARRAY_BUFFER
    | UNIFORM_BUFFER
    | SHADER_STORAGE_BUFFER
    | ATOMIC_COUNTER_BUFFER
    | TRANSFORM_FEEDBACK_BUFFER
    | DRAW_INDIRECT_BUFFER
    | DISPATCH_INDIRECT_BUFFER
    | PIXEL_PACK_BUFFER
    | PIXEL_UNPACK_BUFFER
    | TEXTURE_BUFFER
    | COPY_READ_BUFFER
    | COPY_WRITE_BUFFER

Type GLUsage is:
    | STATIC_DRAW
    | DYNAMIC_DRAW
    | STREAM_DRAW
    | STATIC_READ
    | DYNAMIC_READ
    | STREAM_READ
    | STATIC_COPY
    | DYNAMIC_COPY
    | STREAM_COPY

Type GLVertexArray is Dictionary with:
    vao_id as Integer
    vertex_buffers as List[GLBuffer]
    index_buffer as GLBuffer
    attribute_bindings as List[GLVertexAttribute]
    metadata as Dictionary[String, String]

Type GLVertexAttribute is Dictionary with:
    index as Integer
    size as Integer
    attribute_type as GLAttributeType
    normalized as Boolean
    stride as Integer
    offset as Integer
    divisor as Integer
    enabled as Boolean

Type GLAttributeType is:
    | FLOAT
    | DOUBLE
    | BYTE
    | UNSIGNED_BYTE
    | SHORT
    | UNSIGNED_SHORT
    | INT
    | UNSIGNED_INT
    | HALF_FLOAT
    | FIXED
    | INT_2_10_10_10_REV
    | UNSIGNED_INT_2_10_10_10_REV

Note: Shader and Program Objects

Type GLShader is Dictionary with:
    shader_id as Integer
    shader_type as GLShaderType
    source_code as String
    compiled as Boolean
    compile_log as String
    metadata as Dictionary[String, String]

Type GLShaderType is:
