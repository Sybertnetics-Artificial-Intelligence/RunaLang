Note: Graphics Core Module
Note: Fundamental graphics types, utilities, and abstractions for the Runa graphics system.
Note: Provides the foundation for 2D/3D graphics, image processing, and rendering pipelines.
Note: Designed to surpass OpenGL, DirectX, Vulkan raw APIs with high-level, type-safe abstractions.
:End Note

Import "math/core" as math_module
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "gaming/core" as gaming_core
Import "string/format" as string_utils

Note: Fundamental Graphics Data Structures

Type called "Point":
    x as Float
    y as Float
    metadata as Dictionary[String, String]

Type called "Size":
    width as Float
    height as Float
    metadata as Dictionary[String, String]

Type called "Rectangle":
    origin as Point
    size as Size
    metadata as Dictionary[String, String]

Type called "Pixel":
    red as Float
    green as Float
    blue as Float
    alpha as Float
    position as Point
    metadata as Dictionary[String, String]

Type called "ColorSpace":
    space_type as ColorSpaceType
    gamma as Float
    white_point as Point
    primaries as ColorPrimaries
    transfer_function as TransferFunction
    metadata as Dictionary[String, String]

Type ColorSpaceType is:
    | SRGB
    | DISPLAY_P3
    | ADOBE_RGB
    | REC2020
    | LINEAR_RGB
    | CIE_XYZ
    | LAB
    | LUV
    | HSV
    | HSL
    | CUSTOM

Type called "ColorPrimaries":
    red_x as Float
    red_y as Float
    green_x as Float
    green_y as Float
    blue_x as Float
    blue_y as Float
    white_x as Float
    white_y as Float

Type TransferFunction is:
    | LINEAR
    | SRGB_CURVE
    | GAMMA_22
    | GAMMA_28
    | BT709
    | BT2020
    | DCI_P3
    | CUSTOM_GAMMA with gamma as Float

Note: Graphics Resource Management

Type called "GraphicsResource":
    resource_id as String
    resource_type as ResourceType
    size_bytes as Integer
    is_resident as Boolean
    access_pattern as AccessPattern
    last_used as Integer
    reference_count as Integer
    metadata as Dictionary[String, String]

Type ResourceType is:
    | TEXTURE_2D
    | TEXTURE_3D
    | TEXTURE_CUBE
    | VERTEX_BUFFER
    | INDEX_BUFFER
    | UNIFORM_BUFFER
    | FRAMEBUFFER
