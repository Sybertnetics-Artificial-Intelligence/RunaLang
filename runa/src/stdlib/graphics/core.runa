    | WRITE_ONLY
    | READ_WRITE
    | STATIC
    | DYNAMIC
    | STREAMING

Type called "GraphicsContext":
    context_id as String
    backend_type as GraphicsBackend
    capabilities as GraphicsCapabilities
    resource_manager as ResourceManager
    error_handler as ErrorHandler
    performance_monitor as PerformanceMonitor
    debug_enabled as Boolean
