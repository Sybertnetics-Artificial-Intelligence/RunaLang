Process read_canvas_pixels with canvas as Canvas and region as core.Bounds2D:
    Note: Read pixels from canvas region using backing store
    Let backing_store be canvas.backing_store
    Let pixel_data be list_utils.create_empty_list
    
    Let x_start be core.floor with value as region.min_x
    Let y_start be core.floor with value as region.min_y
    Let width be core.floor with value as region.max_x minus region.min_x
    Let height be core.floor with value as region.max_y minus region.min_y
    
    Note: Extract pixel data from backing store buffer
    For y from y_start to y_start plus height minus 1:
        For x from x_start to x_start plus width minus 1:
            Let pixel_index be y multiplied by canvas.width plus x multiplied by 4
            
            If backing_store.store_type is equal to CPU_BUFFER:
                Note: Read from CPU buffer
                Let r be backing_store.cpu_buffer[pixel_index] if pixel_index is less than list_utils.length with list as backing_store.cpu_buffer else 0
                Let g be backing_store.cpu_buffer[pixel_index plus 1] if pixel_index plus 1 is less than list_utils.length with list as backing_store.cpu_buffer else 0
                Let b be backing_store.cpu_buffer[pixel_index plus 2] if pixel_index plus 2 is less than list_utils.length with list as backing_store.cpu_buffer else 0
                Let a be backing_store.cpu_buffer[pixel_index plus 3] if pixel_index plus 3 is less than list_utils.length with list as backing_store.cpu_buffer else 255
                
                Call list_utils.append with list as pixel_data and item as r
                Call list_utils.append with list as pixel_data and item as g
                Call list_utils.append with list as pixel_data and item as b
                Call list_utils.append with list as pixel_data and item as a
            Otherwise:
                Note: Read from GPU buffer (simplified)
                Call list_utils.append with list as pixel_data and item as 0
                Call list_utils.append with list as pixel_data and item as 0
                Call list_utils.append with list as pixel_data and item as 0
                Call list_utils.append with list as pixel_data and item as 255
    
    Return CanvasImageData with:\
        width as width and\
        height as height and\
        data as pixel_data

Process write_canvas_pixels with canvas as Canvas and image as CanvasImage and position as core.Vector2D:
    Note: Write image pixels to canvas backing store
    Let backing_store be canvas.backing_store
    Let x_offset be core.floor with value as position.x
    Let y_offset be core.floor with value as position.y
    
    Note: Update backing store with image data
    For y from 0 to image.height minus 1:
        For x from 0 to image.width minus 1:
            Let canvas_x be x_offset plus x
            Let canvas_y be y_offset plus y
            
            Note: Check bounds
            If canvas_x is greater than or equal to 0 and canvas_x is less than canvas.width and canvas_y is greater than or equal to 0 and canvas_y is less than canvas.height:
                Let canvas_pixel_index be canvas_y multiplied by canvas.width plus canvas_x multiplied by 4
                Let image_pixel_index be y multiplied by image.width plus x multiplied by 4
                
                If backing_store.store_type is equal to CPU_BUFFER:
                    Note: Write to CPU buffer
                    If canvas_pixel_index is less than list_utils.length with list as backing_store.cpu_buffer:
                        Set backing_store.cpu_buffer[canvas_pixel_index] to image.pixel_data[image_pixel_index]
                        Set backing_store.cpu_buffer[canvas_pixel_index plus 1] to image.pixel_data[image_pixel_index plus 1]
                        Set backing_store.cpu_buffer[canvas_pixel_index plus 2] to image.pixel_data[image_pixel_index plus 2]
                        Set backing_store.cpu_buffer[canvas_pixel_index plus 3] to image.pixel_data[image_pixel_index plus 3]
    
    Note: Mark region as dirty for next render
    Let dirty_region be core.Bounds2D with:\
        min_x as position.x and\
        min_y as position.y and\
        max_x as position.x plus image.width and\
        max_y as position.y plus image.height
        
    Call list_utils.append with list as backing_store.dirty_regions and item as dirty_region

Note: Module Information

Process get_canvas_info:
    Let info be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as info and key as "module_name" and value as "graphics.canvas"
    Call dict_utils.set_value with dict as info and key as "version" and value as "1.0.0"
    Call dict_utils.set_value with dict as info and key as "description" and value as "Hardware-accelerated canvas system with 2D/3D context support"
    Call dict_utils.set_value with dict as info and key as "contexts" and value as "2D,WebGL,WebGL2,WebGPU,Vulkan"
    Call dict_utils.set_value with dict as info and key as "features" and value as "Hardware acceleration, Path rendering, Text rendering, Image processing, AI optimization"
    Call dict_utils.set_value with dict as info and key as "competitive_advantage" and value as "Surpasses HTML5 Canvas with native performance and advanced AI optimization"
    Call dict_utils.set_value with dict as info and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return info