    font_weight as FontWeight
    font_style as FontStyle
    font_variant as FontVariant
    line_height as Float
    letter_spacing as Float
    word_spacing as Float
    text_decoration as TextDecoration
    metadata as Dictionary[String, String]

Type FontWeight is:
    | THIN
    | EXTRA_LIGHT
    | LIGHT
    | NORMAL
    | MEDIUM
    | SEMI_BOLD
    | BOLD
    | EXTRA_BOLD
    | BLACK

Type FontStyle is:
    | NORMAL
    | ITALIC
    | OBLIQUE

Type FontVariant is:
    | NORMAL
    | SMALL_CAPS

Type TextDecoration is:
    | NONE
    | UNDERLINE
