        mouse_buttons as list_utils.create_empty_list and\
        keyboard_state as list_utils.create_empty_list and\
        touch_points as list_utils.create_empty_list and\
        hover_element as "" and\
        focus_element as "" and\
        event_capture_enabled as false and\
        metadata as dict_utils.create_empty_dict

Process create_canvas_performance_monitor:
    Return CanvasPerformanceMonitor with:\
        frame_times as list_utils.create_empty_list and\
        draw_call_counts as list_utils.create_empty_list and\
        memory_usage_samples as list_utils.create_empty_list and\
        cache_hit_rates as list_utils.create_empty_list and\
        gpu_utilization as list_utils.create_empty_list and\
        performance_warnings as list_utils.create_empty_list and\
        profiling_enabled as true and\
        metadata as dict_utils.create_empty_dict

Process create_canvas_ai_optimizer:
    Return CanvasAIOptimizer with:\
        optimization_level as ADAPTIVE and\
        auto_batching_enabled as true and\
        auto_culling_enabled as true and\
        adaptive_quality_enabled as true and\
        path_simplification_enabled as true and\
        glyph_caching_optimization as true and\
        texture_streaming_enabled as true and\
        performance_predictor as create_ai_performance_predictor and\
        metadata as dict_utils.create_empty_dict

Process create_path_builder:
    Return PathBuilder with:\
        current_path as create_empty_canvas_path and\
        path_stack as list_utils.create_empty_list and\
        current_point as core.create_vector2d with x as 0.0 and y as 0.0 and\
        path_closed as false and\
        subpaths as list_utils.create_empty_list and\
        path_cache as create_path_cache and\
        metadata as dict_utils.create_empty_dict

Process create_text_renderer:
    Return TextRenderer with:\
        font_manager as create_font_manager and\
        text_cache as create_text_cache and\
        glyph_cache as create_glyph_cache and\
        text_metrics_cache as create_text_metrics_cache and\
        text_shaping_engine as create_text_shaping_engine and\
        font_rasterizer as create_font_rasterizer and\
