        alpha_type as PREMULTIPLIED and\
        sample_count as 1 and\
        stencil_bits as 8 and\
        depth_bits as 24

Process create_backing_store with width as Integer and height as Integer and store_type as BackingStoreType:
    Return BackingStore with:\
        store_type as store_type and\
        gpu_buffer_handle as datetime_module.get_timestamp modulo 2147483647 and\
        cpu_buffer as list_utils.create_empty_list and\
        dirty_regions as list_utils.create_empty_list and\
        double_buffering as true and\
        triple_buffering as false and\
        vsync_enabled as true and\
        metadata as dict_utils.create_empty_dict

Process create_canvas_event_manager:
    Return CanvasEventManager with:\
        event_listeners as dict_utils.create_empty_dict and\
