    Call dict_utils.set_value with dict as info and key as "backends" and value as "OpenGL 4.6,Vulkan 1.3,DirectX 12,Metal 3,WebGPU 1.0"
    Call dict_utils.set_value with dict as info and key as "features" and value as "PBR materials, Advanced lighting, Shadow mapping, Post-processing, Clustered rendering, AI optimization"
    Call dict_utils.set_value with dict as info and key as "competitive_advantage" and value as "Modern 3D pipeline competitive with Unity HDRP and Unreal Engine 5"
