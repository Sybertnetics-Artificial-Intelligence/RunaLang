Note: Advanced Paint and Color System
Note: Comprehensive paint, color, stroke, and styling system for Runa graphics
Note: Surpasses CSS, Skia, CoreGraphics with advanced color science and GPU acceleration
Note: Provides professional-grade color management, gradients, patterns, and effects
:End Note

Import "graphics/core" as graphics_core
Import "gaming/core" as gaming_core
Import "math/core" as math_module
Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "string/format" as string_utils

Note: Advanced Color Definitions

Type called "Color":
    red as Float
    green as Float
    blue as Float
    alpha as Float
    color_space as graphics_core.ColorSpace
    profile as Optional[ColorProfile]
    metadata as Dictionary[String, String]

Type called "ColorProfile":
    profile_name as String
    icc_data as Optional[ByteArray]
    gamma as Float
    white_point as ChromaticPoint
    primaries as ColorGamut
    rendering_intent as RenderingIntent
    metadata as Dictionary[String, String]

Type called "ChromaticPoint":
    x as Float
    y as Float
    luminance as Float

Type called "ColorGamut":
    red_primary as ChromaticPoint
    green_primary as ChromaticPoint
    blue_primary as ChromaticPoint
    gamut_coverage as Float
    metadata as Dictionary[String, String]

Type RenderingIntent is:
    | PERCEPTUAL
    | RELATIVE_COLORIMETRIC
    | SATURATION
    | ABSOLUTE_COLORIMETRIC

Type called "Paint":
    paint_type as PaintType
    color as Color
    gradient as Optional[Gradient]
    pattern as Optional[Pattern]
    texture as Optional[TexturePaint]
    shader as Optional[ShaderPaint]
    blend_mode as BlendMode
    opacity as Float
    anti_alias as Boolean
    dither as Boolean
    color_filter as Optional[ColorFilter]
    mask_filter as Optional[MaskFilter]
    path_effect as Optional[PathEffect]
    metadata as Dictionary[String, String]

Type PaintType is:
    | SOLID_COLOR
    | LINEAR_GRADIENT
    | RADIAL_GRADIENT
    | ANGULAR_GRADIENT
    | PATTERN
    | TEXTURE
    | SHADER

Type BlendMode is:
    | CLEAR
    | SRC
    | DST
    | SRC_OVER
    | DST_OVER
    | SRC_IN
    | DST_IN
    | SRC_OUT
    | DST_OUT
    | SRC_ATOP
    | DST_ATOP
    | XOR
    | PLUS
    | MODULATE
    | SCREEN
    | OVERLAY
    | DARKEN
    | LIGHTEN
    | COLOR_DODGE
    | COLOR_BURN
    | HARD_LIGHT
    | SOFT_LIGHT
    | DIFFERENCE
    | EXCLUSION
    | MULTIPLY
    | HUE
    | SATURATION
    | COLOR
    | LUMINOSITY

Note: Advanced Gradient System

Type called "Gradient":
    gradient_type as GradientType
    color_stops as List[ColorStop]
    start_point as gaming_core.Vector2D
    end_point as gaming_core.Vector2D
    center as Optional[gaming_core.Vector2D]
    radius as Optional[Float]
    focal_point as Optional[gaming_core.Vector2D]
    focal_radius as Optional[Float]
    angle as Optional[Float]
    tile_mode as TileMode
    interpolation as ColorInterpolation
    color_space as graphics_core.ColorSpace
    transformation_matrix as Optional[TransformationMatrix]
    metadata as Dictionary[String, String]

Type GradientType is:
    | LINEAR
    | RADIAL
    | ANGULAR
    | SWEEP
    | DIAMOND
    | REFLECTED
    | CONIC

Type called "ColorStop":
    position as Float
    color as Color
    interpolation_hint as Optional[Float]
    transition_type as TransitionType
    metadata as Dictionary[String, String]

Type TransitionType is:
    | SMOOTH
    | SHARP
    | CUBIC_BEZIER with control_points as List[Float]

Type TileMode is:
    | CLAMP
    | REPEAT
    | MIRROR
    | DECAL
    | PAD

Type ColorInterpolation is:
    | RGB
    | HSV
    | HSL
    | LAB
    | LUV
    | OKLAB
    | LINEAR_RGB
    | SRGB

Type called "TransformationMatrix":
    m00 as Float
    m01 as Float
    m02 as Float
    m10 as Float
    m11 as Float
    m12 as Float
    m20 as Float
    m21 as Float
    m22 as Float

Note: Pattern and Texture Paint

Type called "Pattern":
    pattern_type as PatternType
    image as Optional[Image]
    tile_mode_x as TileMode
    tile_mode_y as TileMode
    transformation as Optional[TransformationMatrix]
    filter_quality as FilterQuality
    opacity as Float
    blend_mode as BlendMode
    metadata as Dictionary[String, String]

Type PatternType is:
    | IMAGE_PATTERN
    | NOISE_PATTERN
    | PROCEDURAL
    | HATCHING
    | STIPPLING
    | CHECKERBOARD
    | GRID

Type called "TexturePaint":
    texture_id as String
    uv_coordinates as List[gaming_core.Vector2D]
    sampling_mode as SamplingMode
    wrap_mode_u as WrapMode
    wrap_mode_v as WrapMode
    filter_mode as FilterMode
    mip_bias as Float
    max_anisotropy as Integer
    border_color as Color
    metadata as Dictionary[String, String]

Type SamplingMode is:
    | POINT
    | LINEAR
    | CUBIC
    | LANCZOS

Type WrapMode is:
    | REPEAT
    | MIRRORED_REPEAT
    | CLAMP_TO_EDGE
    | CLAMP_TO_BORDER

Type FilterMode is:
    | NEAREST
    | LINEAR
    | NEAREST_MIPMAP_NEAREST
    | LINEAR_MIPMAP_NEAREST
    | NEAREST_MIPMAP_LINEAR
    | LINEAR_MIPMAP_LINEAR

Type FilterQuality is:
    | LOW
    | MEDIUM
    | HIGH
    | VERY_HIGH

Type called "ShaderPaint":
    shader_source as String
    shader_type as ShaderType
    uniforms as Dictionary[String, Any]
    vertex_attributes as Dictionary[String, Any]
    compilation_flags as List[String]
    metadata as Dictionary[String, String]

Type ShaderType is:
    | VERTEX_SHADER
    | FRAGMENT_SHADER
    | GEOMETRY_SHADER
    | COMPUTE_SHADER

Note: Stroke and Line Styles

Type called "Stroke":
    width as Float
    cap as StrokeCap
    join as StrokeJoin
    miter_limit as Float
    dash_pattern as Optional[DashPattern]
    dash_offset as Float
    paint as Paint
    path_effect as Optional[PathEffect]
    metadata as Dictionary[String, String]

Type StrokeCap is:
    | BUTT
    | ROUND
    | SQUARE
    | CUSTOM with shape as PathShape

Type StrokeJoin is:
    | MITER
    | ROUND
    | BEVEL
    | CUSTOM with shape as PathShape

Type called "DashPattern":
    intervals as List[Float]
    phase as Float
    count as Integer
    metadata as Dictionary[String, String]

Note: Advanced Filter and Effect System

Type called "ColorFilter":
    filter_type as ColorFilterType
    matrix as Optional[ColorMatrix]
    hue_adjustment as Float
    saturation_adjustment as Float
    brightness_adjustment as Float
    contrast_adjustment as Float
    gamma_correction as Float
    color_lookup_table as Optional[ByteArray]
    metadata as Dictionary[String, String]

Type ColorFilterType is:
    | IDENTITY
    | MATRIX
    | HUE_ROTATE
    | SATURATION
    | BRIGHTNESS
    | CONTRAST
    | GAMMA
    | SEPIA
    | GRAYSCALE
    | INVERT
    | POSTERIZE
    | SOLARIZE
    | LOOKUP_TABLE

Type called "ColorMatrix":
    values as List[Float]
    is_identity as Boolean
