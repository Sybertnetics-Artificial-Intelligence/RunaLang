Note: Module Information and Utilities

Process get_vulkan_info:
    Let info be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as info and key as "module_name" and value as "graphics.vulkan"
    Call dict_utils.set_value with dict as info and key as "version" and value as "1.3.0"
    Call dict_utils.set_value with dict as info and key as "description" and value as "Modern Vulkan 1.3+ API bindings for maximum GPU performance"
    Call dict_utils.set_value with dict as info and key as "api_version" and value as "Vulkan 1.3"
    Call dict_utils.set_value with dict as info and key as "features" and value as "Explicit GPU control, Ray tracing, Mesh shaders, Compute shaders, Multi-threading"
    Call dict_utils.set_value with dict as info and key as "competitive_advantage" and value as "Next-generation low-level GPU API with maximum performance and explicit control"
    Call dict_utils.set_value with dict as info and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    
    Return info

Process vk_destroy_instance with instance as VkInstance:
    Call vk_destroy_instance_native with instance as instance.instance_handle
    Set instance.instance_handle to 0

Process vk_destroy_device with device as VkDevice:
    Call vk_destroy_device_native with device as device.device_handle
    Set device.device_handle to 0

Process vk_destroy_buffer with device as VkDevice and buffer as VkBuffer:
    Call vk_destroy_buffer_native with device as device.device_handle and buffer as buffer.buffer_handle
