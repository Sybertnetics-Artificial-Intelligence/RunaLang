    load_op as VkAttachmentLoadOp
    store_op as VkAttachmentStoreOp
    stencil_load_op as VkAttachmentLoadOp
    stencil_store_op as VkAttachmentStoreOp
    initial_layout as VkImageLayout
    final_layout as VkImageLayout

Type VkFormat is:
