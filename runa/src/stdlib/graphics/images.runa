        std_deviation as core.create_color_rgba with red as 0.1 and green as 0.1 and blue as 0.1 and alpha as 0.0 and\
        min_color as core.create_color_rgba with red as 0.0 and green as 0.0 and blue as 0.0 and alpha as 0.0 and\
        max_color as core.create_color_rgba with red as 1.0 and green as 1.0 and blue as 1.0 and alpha as 1.0 and\
