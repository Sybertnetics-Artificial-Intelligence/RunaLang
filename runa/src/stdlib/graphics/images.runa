    rendering_intent as RenderingIntent

Type RenderingIntent is:
    | PERCEPTUAL
    | RELATIVE_COLORIMETRIC
    | SATURATION
    | ABSOLUTE_COLORIMETRIC

Type CompressionInfo is Dictionary with:
    compression_type as CompressionType
    quality as Float
    lossless as Boolean
    progressive as Boolean
    compression_ratio as Float
    original_size as Integer
    compressed_size as Integer

Type CompressionType is:
    | NONE
    | JPEG
    | PNG_DEFLATE
    | WEBP
    | AVIF
    | HEIF
    | TIFF_LZW
    | TIFF_ZIP
    | EXR_ZIP
    | EXR_PIZ
    | EXR_RLE

Type MipLevel is Dictionary with:
    level as Integer
