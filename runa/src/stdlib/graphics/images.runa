Type AnimationFrame is Dictionary with:
    frame_index as Integer
    delay_ms as Integer
    disposal_method as FrameDisposalMethod
    pixel_data as List[Byte]
    has_transparency as Boolean

Type FrameDisposalMethod is:
    | NONE
    | DO_NOT_DISPOSE
    | RESTORE_TO_BACKGROUND
    | RESTORE_TO_PREVIOUS

Type MemoryLayout is:
    | INTERLEAVED
    | PLANAR
    | PACKED
    | CHUNKY

Type ImageFlags is Dictionary with:
    has_alpha as Boolean
