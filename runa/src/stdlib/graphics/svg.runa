Process create_default_quality_settings:
    Return SVGQualitySettings with:\
        anti_aliasing as true and\
        high_quality_text as true and\
        gpu_acceleration as true and\
        path_simplification as false and\
        adaptive_tessellation as true and\
        filter_quality as HIGH and\
        animation_quality as HIGH

