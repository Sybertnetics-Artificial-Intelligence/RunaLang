Process called "add_grammar_rule" that takes grammar as Grammar and rule_name as String and productions as List[Production] returns Boolean:
    Note: Add rule to grammar with validation
    If grammar.rules contains key rule_name:
    Set grammar.metadata at key "last_error" to "Rule already exists: " rule_name
    Return false Let rule be GrammarRule with:
            name as rule_name
            alternatives as productions
            precedence as 0
            associativity as NonAssociative
            semantic_action as None
            rule_type as NonTerminalRule
            metadata as dictionary containing "created_at" as get_current_timestamp Set grammar.rules at key rule_name to rule
            Set grammar.metadata at key "last_rule_added" to rule_name
            Return true

Process called "add_terminal_rule" that takes grammar as Grammar and terminal_name as String and pattern as String returns Boolean:
    Note: Add terminal rule to grammar
    If grammar.terminals contains key terminal_name:
    Set grammar.metadata at key "last_error" to "Terminal already exists: " terminal_name
    Return false Let terminal_rule be TerminalRule with:
            pattern as pattern
            flags as list containing
            priority as 0
            context_sensitive as false
            case_sensitive as grammar.options.case_sensitive
            terminal_metadata as dictionary containing Set grammar.terminals at key terminal_name to terminal_rule
            Return true

