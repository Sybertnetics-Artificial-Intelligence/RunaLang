            Let analysis_start_time be get_current_timestamp Let first_sets be calculate_first_sets with grammar as grammar
            Let follow_sets be calculate_follow_sets with grammar as grammar and first_sets as first_sets
            Let nullable_rules be find_nullable_rules with grammar as grammar
            Let left_recursive_rules be detect_left_recursion with grammar as grammar
            Let conflicts be detect_conflicts with grammar as grammar
    Let unreachable_rules be find_unreachable_rules with grammar as grammar Return GrammarAnalysis with:
            grammar as grammar
            first_sets as first_sets
            follow_sets as follow_sets
            nullable_rules as nullable_rules
            left_recursive_rules as left_recursive_rules
            conflicts as conflicts
            unreachable_rules as unreachable_rules
