Note: Parser Generation and Construction
Process called "generate_parser" that takes grammar as Grammar returns Parser:
    Note: Generate parser from grammar
    Let generation_start_time be get_current_timestamp Note: Analyze grammar first
            Let analysis be analyze_grammar with grammar as grammar
    If length of analysis.conflicts > 0:
    Set grammar.metadata at key "generation_warnings" to "Grammar has conflicts" Note: Generate parse table
    Let parse_table be generate_parse_table with grammar as grammar and analysis as analysis Note: Create tokenizer
    let tokenizer be create_tokenizer_from_grammar with grammar as grammar Note: Setup error recovery
    Let error_recovery be create_error_recovery_system with grammar as grammar Let parser be Parser with:
            grammar as grammar
            parse_table as parse_table
            tokenizer as tokenizer
            error_recovery as error_recovery
            parse_state as create_initial_parse_state
            diagnostics as list containing
            performance_stats as create_empty_performance_stats
            parser_metadata as dictionary containing "generated_at" as get_current_timestamp, "generation_time" as get_current_timestamp - generation_start_time Return parser

Process called "generate_parse_table" that takes grammar as Grammar and analysis as GrammarAnalysis returns ParseTable:
    Note: Generate LR parse table from grammar
            Let states be generate_lr_states with grammar as grammar and analysis as analysis
            Let action_table be generate_action_table with grammar as grammar and states as states
    Let goto_table be generate_goto_table with grammar as grammar and states as states Return ParseTable with:
            action_table as action_table
            goto_table as goto_table
            states as states
            conflicts as analysis.conflicts
            table_metadata as dictionary containing

Process called "create_tokenizer_from_grammar" that takes grammar as Grammar returns Tokenizer:
    Note: Create tokenizer from grammar terminals
    Let token_rules be list containing For each terminal_name in keys of grammar.terminals:
            Let terminal_rule be grammar.terminals[terminal_name]
    Let token_rule be TokenRule with:
            pattern as terminal_rule.pattern
            token_type as terminal_name
            priority as terminal_rule.priority
            context as None
            action as None
            rule_metadata as dictionary containing
    Add token_rule to token_rules Return Tokenizer with:
            rules as token_rules
            states as create_tokenizer_states with rules as token_rules
            current_state as 0
            input_buffer as ""
            position as 0
            line_number as 1
            column_number as 1
            tokenizer_metadata as dictionary containing

Note: Parsing and Token Processing
Process called "parse_text" that takes parser as Parser and input_text as String returns ParseResult:
    Note: Parse input text using generated parser
            Let parse_start_time be get_current_timestamp
    Let tokenization_start_time be get_current_timestamp Note: Tokenize input
            Let tokens be tokenize_input with tokenizer as parser.tokenizer and input as input_text
    Let tokenization_time be get_current_timestamp - tokenization_start_time Note: Parse tokens
            Let parsing_start_time be get_current_timestamp
            Let parse_result be parse_tokens with parser as parser and tokens as tokens
    Let parsing_time be get_current_timestamp - parsing_start_time Note: Update performance statistics
    Let performance_stats be PerformanceStats with:
            parse_time as parsing_time
            tokenization_time as tokenization_time
            memory_usage as estimate_memory_usage with result as parse_result
            tokens_processed as length of tokens
            nodes_created as count_nodes_in_tree with tree as parse_result.parse_tree
            backtrack_count as 0
            cache_hits as 0
            cache_misses as 0
    stats_metadata as dictionary containing Return ParseResult with:
            success as parse_result.success
            parse_tree as parse_result.parse_tree
            tokens as tokens
            errors as parse_result.errors
            warnings as parse_result.warnings
            performance_info as performance_stats
            result_metadata as dictionary containing "parsed_at" as get_current_timestamp, "total_time" as get_current_timestamp - parse_start_time

Process called "tokenize_input" that takes tokenizer as Tokenizer and input as String returns List[Token]:
    Note: Tokenize input string into tokens
            Let tokens be list containing
            Let position be 0
            Let line be 1
            Let column be 1
    Let input_length be Format.length_of with s as input While position < input_length:
    Let token_match be find_next_token with tokenizer as tokenizer and input as input and position as position If token_match is not None:
    Let token be Token with:
            type as token_match.token_type
            value as token_match.matched_text
            line as line
            column as column
            start_position as position
            end_position as position + Format.length_of with s as token_match.matched_text
            source_text as token_match.matched_text
    token_metadata as dictionary containing Add token to tokens Note: Update position tracking
            Let token_length be Format.length_of with s as token_match.matched_text
    Set position to position + token_length Note: Update line and column for newlines
    For each char in token_match.matched_text:
    If char = "\n":
            Set line to line + 1
            Set column to 1
    Otherwise:
            Set column to column + 1
    Otherwise:
    Note: Handle lexical error
    Let error_token be Token with:
            type as "ERROR"
            value as Format.character_at_index with text as input and index as position
            line as line
            column as column
            start_position as position
            end_position as position + 1
            source_text as Format.character_at_index with text as input and index as position
            token_metadata as dictionary containing "error" as "unrecognized character" Add error_token to tokens
            Set position to position + 1
    Set column to column + 1 Note: Add end-of-input token
    Let eof_token be Token with:
            type as "EOF"
            value as ""
            line as line
            column as column
            start_position as position
            end_position as position
            source_text as ""
            token_metadata as dictionary containing
            Add eof_token to tokens Return tokens

Process called "find_next_token" that takes tokenizer as Tokenizer and input as String and position as Integer returns Optional[TokenMatch]:
    Note: Find next token match at position
            Let input_length be Format.length_of with s as input
    If position > or equal to input_length:
            Return None Let remaining_input be Format.substring with s as input and start as position and end as input_length
            Let best_match as None
    Let best_length be 0 For each token_rule in tokenizer.rules:
            Let match_result be match_token_pattern with pattern as token_rule.pattern and input as remaining_input
    If match_result is not None and match_result.match_length > best_length:
    Set best_match to Some with value as TokenMatch with:
            token_type as token_rule.token_type
            matched_text as match_result.matched_text
            match_length as match_result.match_length
            rule_priority as token_rule.priority
            metadata as dictionary containing
            Set best_length to match_result.match_length Return best_match

Type called "TokenMatch":
            token_type as String
            matched_text as String
            match_length as Integer
            rule_priority as Integer
            metadata as Dictionary[String, Any]

Process called "parse_tokens" that takes parser as Parser and tokens as List[Token] returns ParseResult:
    Note: Parse token stream using parse table
    Let parse_stack be list containing 0 Note: Start with state 0
            Let token_index be 0
            Let parse_tree_stack be list containing
            Let errors be list containing
    Let warnings be list containing While token_index < length of tokens:
            Let current_token be tokens[token_index]
    Let current_state be parse_stack[length of parse_stack - 1] Note: Look up action in parse table
    Let action be lookup_parser_action with table as parser.parse_table and state as current_state and token as current_token.type If action is not None:
    Match action.action_type:
    When Shift:
            Add action.target to parse_stack
            Add create_leaf_node with token as current_token to parse_tree_stack
    Set token_index to token_index + 1 When Reduce:
            Let production be action.production
    If production is not None:
            Let reduce_result be apply_reduction with stack as parse_stack and tree_stack as parse_tree_stack and production as production and parser as parser
    If not reduce_result.success:
            Let error be create_parse_error with message as "Reduction failed" and token as current_token and error_type as SyntaxError
    Add error to errors When Accept:
    Note: Parse completed successfully
            Let final_tree be if length of parse_tree_stack > 0 then Some with value as parse_tree_stack[0] else None
    Return ParseResult with:
            success as true
            parse_tree as final_tree
            tokens as tokens
            errors as errors
            warnings as warnings
            performance_info as create_empty_performance_stats
            result_metadata as dictionary containing "completion_type" as "accept"
    When Error:
            Let error be create_parse_error with message as "Unexpected token" and token as current_token and error_type as SyntaxError
    Add error to errors Note: Attempt error recovery
            Let recovery_result be attempt_error_recovery with parser as parser and stack as parse_stack and token_index as token_index and tokens as tokens
    If recovery_result.success:
            Set token_index to recovery_result.new_token_index
            Set parse_stack to recovery_result.new_stack
    Otherwise:
            Set token_index to token_index + 1
    Otherwise:
    Note: No action found - error
            Let error be create_parse_error with message as "No valid action" and token as current_token and error_type as SyntaxError
            Add error to errors
    Set token_index to token_index + 1 Note: Parse completed with errors
            Let final_tree be if length of parse_tree_stack > 0 then Some with value as parse_tree_stack[0] else None
    Return ParseResult with:
            success as length of errors = 0
            parse_tree as final_tree
            tokens as tokens
            errors as errors
            warnings as warnings
            performance_info as create_empty_performance_stats
            result_metadata as dictionary containing "completion_type" as "error_end"

Note: Parse Tree Construction and Manipulation
Process called "create_leaf_node" that takes token as Token returns ParseTree:
    Note: Create leaf node from token
    Return ParseTree with:
            node_type as token.type
            value as Some with value as token.value
            children as list containing
            parent as None
            source_range as SourceRange with:
            start_line as token.line
            start_column as token.column
            end_line as token.line
            end_column as token.column + Format.length_of with s as token.value
            start_offset as token.start_position
            end_offset as token.end_position
            metadata as dictionary containing
            attributes as dictionary containing
            tree_metadata as dictionary containing "node_kind" as "leaf", "token_type" as token.type

Process called "create_internal_node" that takes rule_name as String and children as List[ParseTree] returns ParseTree:
    Note: Create internal node from rule reduction
            Let start_range be if length of children > 0 then children[0].source_range else create_empty_source_range
    Let end_range be if length of children > 0 then children[length of children - 1].source_range else create_empty_source_range Let node be ParseTree with:
            node_type as rule_name
            value as None
            children as children
            parent as None
            source_range as SourceRange with:
            start_line as start_range.start_line
            start_column as start_range.start_column
            end_line as end_range.end_line
            end_column as end_range.end_column
            start_offset as start_range.start_offset
            end_offset as end_range.end_offset
            metadata as dictionary containing
            attributes as dictionary containing
    tree_metadata as dictionary containing "node_kind" as "internal", "rule_name" as rule_name Note: Set parent references for children
    For each child in children:
            Set child.parent to Some with value as node Return node

Process called "visit_parse_tree" that takes tree as ParseTree and visitor as TreeVisitor returns Any:
    Note: Visit parse tree with visitor pattern
    Let result be visitor.visit_enter with node as tree For each child in tree.children:
            Let child_result be visit_parse_tree with tree as child and visitor as visitor
            visitor.visit_child_result with parent as tree and child as child and result as child_result Return visitor.visit_exit with node as tree and enter_result as result

Type called "TreeVisitor":
            visit_enter as Process[ParseTree, Any]
            visit_exit as Process[ParseTree, Any, Any]
