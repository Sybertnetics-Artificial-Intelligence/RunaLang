    iso_3166_1_alpha3 as "USA"
    iso_3166_1_numeric as 840
    continent as "North America"
    subregion as "Northern America"
    official_languages as list containing "en"
    default_currency as "USD"
    measurement_system as "imperial"
    calendar_systems as list containing "gregorian"
    timezone_examples as list containing "America/New_York", "America/Chicago", "America/Denver", "America/Los_Angeles"
    metadata as dictionary containing Set territories at key "US" to usa Return territories

Process called "create_script_info_database" returns Dictionary[String, ScriptInfo]:
    Note: Create script information database
    Let scripts be dictionary containing Let latin be ScriptInfo with:
    script_code as "Latn"
