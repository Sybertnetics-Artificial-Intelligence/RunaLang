    typical_exemplars as "ا ب ت ث ج ح خ د ذ ر ز س ش ص ض ط ظ ع غ ف ق ك ل م ن ه و ي"
    metadata as dictionary containing Set scripts at key "Arab" to arabic Return scripts

Process called "detect_from_environment" returns Optional[String]:
    Note: Detect locale from environment variables
    Note: In production, this would check actual environment variables
    Return Some with value as "en-US"

Process called "detect_from_system_settings" returns Optional[String]:
    Note: Detect locale from system settings
    Note: In production, this would check actual system settings
    Return Some with value as "en-US"

Process called "is_all_alphabetic" that takes s as String returns Boolean:
    Note: Check if string contains only alphabetic characters
    Let s_length be Format.length_of with s as s
    For i from 0 to (s_length - 1):
    Let char be Format.character_at_index with text as s and index as i
    If not is_alphabetic_char with char as char:
    Return false
    Return true

Process called "is_all_numeric" that takes s as String returns Boolean:
    Note: Check if string contains only numeric characters
    Let s_length be Format.length_of with s as s
    For i from 0 to (s_length - 1):
    Let char be Format.character_at_index with text as s and index as i
    If not is_numeric_char with char as char:
    Return false
    Return true

Process called "is_all_alphanumeric" that takes s as String returns Boolean:
    Note: Check if string contains only alphanumeric characters
    Let s_length be Format.length_of with s as s
    For i from 0 to (s_length - 1):
    Let char be Format.character_at_index with text as s and index as i
    If not is_alphanumeric_char with char as char:
    Return false
    Return true

Process called "is_alphabetic_char" that takes char as String returns Boolean:
    Note: Check if character is alphabetic
    Let char_code be Format.ascii_value_of with char as char
    Return char_code is greater than or equal to 65 and char_code is less than or equal to 90 or char_code is greater than or equal to 97 and char_code is less than or equal to 122

Process called "is_numeric_char" that takes char as String returns Boolean:
    Note: Check if character is numeric
    Let char_code be Format.ascii_value_of with char as char
    Return char_code is greater than or equal to 48 and char_code is less than or equal to 57

Process called "is_digit" that takes char as String returns Boolean:
    Note: Check if character is digit
    Return is_numeric_char with char as char

Process called "is_alphanumeric_char" that takes char as String returns Boolean:
    Note: Check if character is alphanumeric
    Return is_alphabetic_char with char as char or is_numeric_char with char as char

Process called "format_locale_tag" that takes language as String and script as Optional[String] and territory as Optional[String] and variant as Optional[String] returns String:
    Note: Format locale components into proper tag
    Let parts be list containing language If script is not None:
    Add script to parts
    If territory is not None:
    Add territory to parts
    If variant is not None:
    Add variant to parts Return Format.join with items as parts and sep as "-"

Process called "get_current_timestamp" returns Float:
    Note: Get current timestamp - would delegate to system in production
    Return 0.0

Note: Public API Functions
Process called "parse" that takes locale_tag as String returns Locale:
    Return parse_locale_tag with locale_tag as locale_tag

Process called "create_manager" returns LocaleManager:
    Return create_locale_manager

Process called "detect_locale" that takes manager as LocaleManager returns Locale:
    Let detection be detect_system_locale with manager as manager
    Return detection.detected_locale

Process called "negotiate" that takes manager as LocaleManager and requested as List[String] returns Locale:
    Let negotiation be negotiate_locale with manager as manager and requested_locales as requested
    Return negotiation.negotiated_locale

Process called "set_locale" that takes manager as LocaleManager and locale_tag as String returns Boolean:
    Return set_current_locale with manager as manager and locale_tag as locale_tag

Process called "get_display_name" that takes manager as LocaleManager and locale as Locale returns String:
    Return get_locale_display_name with manager as manager and locale as locale and display_locale as manager.current_locale

Process called "is_rtl" that takes manager as LocaleManager and locale as Locale returns Boolean:
    Return is_rtl_locale with manager as manager and locale as locale

Process called "minimize" that takes locale as Locale returns String:
    Return minimize_locale with locale as locale

Process called "maximize" that takes locale as Locale returns Locale:
    Return maximize_locale with locale as locale

Process called "validate" that takes locale_tag as String returns Boolean:
    Return is_well_formed_locale_tag with locale_tag as locale_tag