Note: Locale Parsing and Construction
Process called "parse_locale_tag" that takes locale_tag as String returns Locale:
    Note: Parse IETF BCP 47 language tag into Locale structure
    Let parts be split_locale_tag with tag as locale_tag
    Let language be extract_language_subtag with parts as parts
    Let script be extract_script_subtag with parts as parts
    Let territory be extract_territory_subtag with parts as parts
    Let variant be extract_variant_subtag with parts as parts
    Let extensions be extract_extensions with parts as parts
    Let private_use be extract_private_use with parts as parts Let canonical_tag be canonicalize_locale_tag with tag as locale_tag
    Let parent be determine_parent_locale with language as language and script as script and territory as territory
    Let likely be add_likely_subtags with language as language and script as script and territory as territory Return Locale with:
    language as language
    script as script
    territory as territory
    variant as variant
    extensions as extensions
    private_use as private_use
    tag as locale_tag
    canonical_tag as canonical_tag
    parent_locale as parent
    likely_subtags as likely
    locale_metadata as dictionary containing "parsed_at" as get_current_timestamp

Process called "split_locale_tag" that takes tag as String returns List[String]:
    Note: Split locale tag into subtags
    Let normalized_tag be Format.replace with s as tag and old as "_" and new as "-"
    Return Format.split with s as normalized_tag and delimiter as "-"

Process called "extract_language_subtag" that takes parts as List[String] returns String:
    Note: Extract language subtag (first 2-3 character component)
    If length of parts is greater than 0:
    Let first_part be parts[0]
    If Format.length_of with s as first_part is greater than or equal to 2 and Format.length_of with s as first_part is less than or equal to 3:
    Return Format.to_lowercase with s as first_part
    Return "und" Note: Undefined language

Process called "extract_script_subtag" that takes parts as List[String] returns Optional[String]:
    Note: Extract script subtag (4 character titlecase component)
    For i from 1 to (length of parts - 1):
    Let part be parts[i]
    If Format.length_of with s as part is equal to 4 and is_all_alphabetic with s as part:
    Return Some with value as Format.to_titlecase with s as part
    Return None

Process called "extract_territory_subtag" that takes parts as List[String] returns Optional[String]:
    Note: Extract territory subtag (2 character uppercase or 3 digit numeric)
    For i from 1 to (length of parts - 1):
    Let part be parts[i]
    If Format.length_of with s as part is equal to 2 and is_all_alphabetic with s as part:
    Return Some with value as Format.to_uppercase with s as part
    Otherwise if Format.length_of with s as part is equal to 3 and is_all_numeric with s as part:
    Return Some with value as part
    Return None

Process called "extract_variant_subtag" that takes parts as List[String] returns Optional[String]:
    Note: Extract variant subtag (5-8 chars or 4 chars starting with digit)
    For i from 1 to (length of parts - 1):
    Let part be parts[i]
    Let part_length be Format.length_of with s as part
    If part_length is greater than or equal to 5 and part_length is less than or equal to 8 and is_all_alphanumeric with s as part:
    Return Some with value as Format.to_lowercase with s as part
    Otherwise if part_length is equal to 4 and is_digit with char as Format.character_at_index with text as part and index as 0:
    Return Some with value as Format.to_lowercase with s as part
    Return None

Process called "extract_extensions" that takes parts as List[String] returns Dictionary[String, String]:
    Note: Extract extension subtags
    Let extensions be dictionary containing
    Let i be 1 While i is less than length of parts:
    Let part be parts[i]
    If Format.length_of with s as part is equal to 1 and is_all_alphabetic with s as part:
    Let extension_key be Format.to_lowercase with s as part
    Let extension_values be list containing
    Set i to i + 1 While i is less than length of parts and Format.length_of with s as parts[i] is greater than or equal to 2:
    Add parts[i] to extension_values
    Set i to i + 1 Set extensions at key extension_key to Format.join with items as extension_values and sep as "-"
    Otherwise:
    Set i to i + 1 Return extensions

Process called "canonicalize_locale_tag" that takes tag as String returns String:
    Note: Canonicalize locale tag according to BCP 47 rules
    Let parts be split_locale_tag with tag as tag
    Let canonical_parts be list containing Note: Language is required and comes first
    Let language be extract_language_subtag with parts as parts
    Add language to canonical_parts Note: Script comes next if present
    Let script be extract_script_subtag with parts as parts
    If script is not None:
    Add script to canonical_parts Note: Territory comes next if present
    Let territory be extract_territory_subtag with parts as parts
    If territory is not None:
    Add territory to canonical_parts Note: Variants come next (sorted alphabetically)
    Let variant be extract_variant_subtag with parts as parts
    If variant is not None:
    Add variant to canonical_parts Note: Extensions come last (sorted by key)
    Let extensions be extract_extensions with parts as parts
    For each extension_key in sorted_keys of extensions:
    Add extension_key to canonical_parts
    Add extensions[extension_key] to canonical_parts Return Format.join with items as canonical_parts and sep as "-"

Process called "add_likely_subtags" that takes language as String and script as Optional[String] and territory as Optional[String] returns LikelySubtags:
    Note: Add likely subtags based on CLDR data
    Let likely_script be script
    Let likely_territory be territory
    Let confidence be 1.0 Note: Infer script based on language
    If likely_script is None:
    Set likely_script to Some with value as infer_script_from_language with language as language
    Set confidence to confidence multiplied by 0.9 Note: Infer territory based on language and script
    If likely_territory is None:
    Set likely_territory to Some with value as infer_territory_from_language with language as language and script as likely_script
    Set confidence to confidence multiplied by 0.8 Return LikelySubtags with:
    likely_language as language
    likely_script as if likely_script is None then "Zyyy" else likely_script
    likely_territory as if likely_territory is None then "ZZ" else likely_territory
    confidence_score as confidence
    source as "inference"
    metadata as dictionary containing

Process called "infer_script_from_language" that takes language as String returns String:
    Note: Infer likely script from language code
    Match language:
    When "ar":
    Return "Arab"
    When "zh":
    Return "Hans"
    When "ja":
    Return "Jpan"
    When "ko":
    Return "Kore"
    When "hi":
    Return "Deva"
    When "th":
    Return "Thai"
    When "he":
    Return "Hebr"
    When "ru":
    Return "Cyrl"
    When "el":
    Return "Grek"
    Otherwise:
    Return "Latn"

Process called "infer_territory_from_language" that takes language as String and script as Optional[String] returns String:
    Note: Infer likely territory from language and script
    Match language:
    When "en":
    Return "US"
    When "es":
    Return "ES"
    When "fr":
    Return "FR"
    When "de":
    Return "DE"
    When "it":
    Return "IT"
    When "pt":
    Return "BR"
    When "ru":
    Return "RU"
    When "ja":
    Return "JP"
    When "ko":
    Return "KR"
    When "ar":
    Return "SA"
    When "hi":
    Return "IN"
    When "zh":
    If script is not None and script is equal to "Hant":
    Return "TW"
    Otherwise:
    Return "CN"
    Otherwise:
    Return "ZZ" Note: Unknown territory

Note: Locale Management and Detection
Process called "create_locale_manager" returns LocaleManager:
    Note: Create locale manager with default configuration
    Let config be LocaleConfiguration with:
    enable_fallback as true
    strict_matching as false
    enable_caching as true
    cache_size_limit as 1000
    enable_territory_inference as true
    enable_script_detection as true
    default_territory as "US"
    default_script as "Latn"
    negotiation_timeout as 5.0
    metadata as dictionary containing Let cache be LocaleCache with:
    parsed_locales as dictionary containing
    negotiation_results as dictionary containing
    detection_results as dictionary containing
    hit_count as 0
    miss_count as 0
    cache_effectiveness as 0.0
    metadata as dictionary containing Let default_locale be parse_locale_tag with locale_tag as "en-US"
    Return LocaleManager with:
    current_locale as default_locale
    available_locales as create_default_available_locales
    fallback_chain as list containing default_locale
    locale_database as create_locale_database
    negotiation_rules as create_default_negotiation_rules
    detection_preferences as create_default_detection_preferences
    performance_cache as cache
    configuration as config
    metadata as dictionary containing "created_at" as get_current_timestamp

Process called "detect_system_locale" that takes manager as LocaleManager returns LocaleDetection:
    Note: Detect system locale using multiple evidence sources
    Let evidence_sources be list containing
    let confidence_scores be dictionary containing Note: Check environment variables
    Let env_locale be detect_from_environment
    If env_locale is not None:
    Let env_evidence be EvidenceSource with:
    source_type as EnvironmentVariables
    evidence_value as env_locale
    confidence_weight as 0.9
    quality_score as 0.8
    metadata as dictionary containing
    Add env_evidence to evidence_sources
    Set confidence_scores at key env_locale to 0.9 Note: Check system settings (placeholder)
    Let system_locale be detect_from_system_settings
    If system_locale is not None:
    Let system_evidence be EvidenceSource with:
    source_type as SystemSettings
    evidence_value as system_locale
    confidence_weight as 0.8
    quality_score as 0.9
    metadata as dictionary containing
    Add system_evidence to evidence_sources
    Set confidence_scores at key system_locale to 0.8 Note: Analyze all evidence to determine best locale
    Let best_locale_tag be select_best_locale_from_evidence with evidence as evidence_sources and scores as confidence_scores
    Let detected_locale be parse_locale_tag with locale_tag as best_locale_tag
    Let final_confidence be calculate_detection_confidence with evidence as evidence_sources Return LocaleDetection with:
    detected_locale as detected_locale
    detection_method as EnvironmentVariables
    confidence_score as final_confidence
    evidence_sources as evidence_sources
    alternative_locales as extract_alternative_locales with evidence as evidence_sources
    metadata as dictionary containing "detection_completed_at" as get_current_timestamp

Process called "negotiate_locale" that takes manager as LocaleManager and requested_locales as List[String] returns LocaleNegotiation:
    Note: Negotiate best locale match from available options
    Let quality_scores be dictionary containing
    Let best_match as None
    Let best_score be 0.0 For each requested_locale in requested_locales:
    Let parsed_requested be parse_locale_tag with locale_tag as requested_locale For each available_locale in manager.available_locales:
    Let match_score be calculate_locale_match_score with requested as parsed_requested and available as available_locale
    Let quality_key be requested_locale "->" available_locale.tag
    Set quality_scores at key quality_key to match_score If match_score is greater than best_score:
    Set best_match to available_locale
    Set best_score to match_score Let negotiated_locale be if best_match is None then manager.current_locale else best_match
    Let fallback_used be best_match is None Return LocaleNegotiation with:
    requested_locales as requested_locales
    available_locales as manager.available_locales
    negotiated_locale as negotiated_locale
    quality_scores as quality_scores
    negotiation_strategy as BestMatch
    fallback_applied as fallback_used
    metadata as dictionary containing "negotiation_completed_at" as get_current_timestamp

Process called "calculate_locale_match_score" that takes requested as Locale and available as Locale returns Float:
    Note: Calculate matching score between requested and available locale
    Let score be 0.0 Note: Language match is most important
    If requested.language is equal to available.language:
    Set score to score + 0.6
    Otherwise:
    Return 0.0 Note: No match without language compatibility Note: Territory match is second most important
    If requested.territory is not None and available.territory is not None:
    If requested.territory is equal to available.territory:
    Set score to score + 0.25
    Otherwise:
    Set score to score + 0.1 Note: Partial credit for having territory Note: Script match is third most important
    If requested.script is not None and available.script is not None:
    If requested.script is equal to available.script:
    Set score to score + 0.15
    Otherwise:
    Set score to score + 0.05 Note: Partial credit for having script Note: Bonus for exact match
    If requested.tag is equal to available.tag:
    Set score to score + 0.1 Return score

Process called "build_fallback_chain" that takes manager as LocaleManager and primary_locale as Locale returns List[Locale]:
    Note: Build fallback chain for locale resolution
    Let fallback_chain be list containing primary_locale
    Let current_locale be primary_locale Note: Add parent locales
    While current_locale.parent_locale is not None:
    Let parent_tag be current_locale.parent_locale
    Let parent_locale be parse_locale_tag with locale_tag as parent_tag
    Add parent_locale to fallback_chain
    Set current_locale to parent_locale Note: Add likely subtags variants
    Let likely_locale be create_likely_locale with locale as primary_locale
    If likely_locale.tag is not equal to primary_locale.tag:
    Add likely_locale to fallback_chain Note: Add language-only fallback
    If primary_locale.territory is not None or primary_locale.script is not None:
    Let language_only be parse_locale_tag with locale_tag as primary_locale.language
    Add language_only to fallback_chain Note: Add default fallback
    Let default_locale be parse_locale_tag with locale_tag as "en"
    If not contains_locale with chain as fallback_chain and locale as default_locale:
    Add default_locale to fallback_chain Return fallback_chain

Process called "set_current_locale" that takes manager as LocaleManager and locale_tag as String returns Boolean:
    Note: Set current locale with validation
    Try:
    Let new_locale be parse_locale_tag with locale_tag as locale_tag Note: Validate locale is supported
    If not is_locale_supported with manager as manager and locale as new_locale:
    Return false Set manager.current_locale to new_locale
    Set manager.fallback_chain to build_fallback_chain with manager as manager and primary_locale as new_locale
    Set manager.metadata at key "locale_changed_at" to get_current_timestamp Return true Catch error:
    Set manager.metadata at key "locale_change_error" to error.message
    Return false

Note: Locale Information and Cultural Adaptation
Process called "get_territory_info" that takes manager as LocaleManager and territory_code as String returns Optional[TerritoryInfo]:
    Note: Get territory information from locale database
    If manager.locale_database.territory_info contains key territory_code:
    Return Some with value as manager.locale_database.territory_info[territory_code]
    Otherwise:
    Return None

Process called "get_currency_for_territory" that takes manager as LocaleManager and territory_code as String returns Optional[String]:
    Note: Get default currency for territory
    Let territory_info be get_territory_info with manager as manager and territory_code as territory_code
    If territory_info is not None:
    Return Some with value as territory_info.default_currency
    Otherwise:
    Return None

Process called "get_measurement_system" that takes manager as LocaleManager and locale as Locale returns MeasurementSystem:
    Note: Get measurement system for locale
    Let territory_code be if locale.territory is None then "ZZ" else locale.territory If manager.locale_database.measurement_systems contains key territory_code:
    Return manager.locale_database.measurement_systems[territory_code] Note: Default to metric system
    Return MeasurementSystem with:
    system_name as "metric"
    length_unit as "meter"
    weight_unit as "kilogram"
    temperature_unit as "celsius"
    volume_unit as "liter"
    area_unit as "square_meter"
    used_in_territories as list containing
    metadata as dictionary containing

Process called "get_collation_rules" that takes manager as LocaleManager and locale as Locale returns Optional[CollationRules]:
    Note: Get collation rules for locale
    Let locale_key be locale.language
    If locale.territory is not None:
    Set locale_key to locale_key "-" locale.territory If manager.locale_database.collation_rules contains key locale_key:
    Return Some with value as manager.locale_database.collation_rules[locale_key]
    Otherwise if manager.locale_database.collation_rules contains key locale.language:
    Return Some with value as manager.locale_database.collation_rules[locale.language]
    Otherwise:
    Return None

Process called "get_calendar_system" that takes manager as LocaleManager and locale as Locale returns String:
    Note: Get primary calendar system for locale
    Let territory_code be if locale.territory is None then "ZZ" else locale.territory If manager.locale_database.territory_info contains key territory_code:
    Let territory_info be manager.locale_database.territory_info[territory_code]
    If length of territory_info.calendar_systems is greater than 0:
    Return territory_info.calendar_systems[0] Note: Default to Gregorian
    Return "gregorian"

Process called "get_writing_direction" that takes manager as LocaleManager and locale as Locale returns WritingDirection:
    Note: Get writing direction for locale's script
    Let script_code be if locale.script is None then infer_script_from_language with language as locale.language else locale.script If manager.locale_database.script_info contains key script_code:
    Let script_info be manager.locale_database.script_info[script_code]
    Return script_info.direction Note: Default to left-to-right
    Return LeftToRight

Process called "is_rtl_locale" that takes manager as LocaleManager and locale as Locale returns Boolean:
    Note: Check if locale uses right-to-left writing
    Let direction be get_writing_direction with manager as manager and locale as locale
    Return direction is equal to RightToLeft

Process called "get_locale_display_name" that takes manager as LocaleManager and locale as Locale and display_locale as Locale returns String:
    Note: Get localized display name for locale
    Note: This would use CLDR display name data in production
    Let language_name be get_language_display_name with language_code as locale.language and display_locale as display_locale If locale.territory is not None:
    Let territory_name be get_territory_display_name with territory_code as locale.territory and display_locale as display_locale
    Return language_name " (" territory_name ")"
    Return language_name

Process called "get_language_display_name" that takes language_code as String and display_locale as Locale returns String:
    Note: Get localized language name
    Match display_locale.language:
    When "en":
    Match language_code:
    When "en":
    Return "English"
    When "es":
    Return "Spanish"
    When "fr":
    Return "French"
    When "de":
    Return "German"
    When "zh":
    Return "Chinese"
    When "ja":
    Return "Japanese"
    When "ar":
    Return "Arabic"
    When "ru":
    Return "Russian"
    Otherwise:
    Return language_code
    When "es":
    Match language_code:
    When "en":
    Return "inglés"
    When "es":
    Return "español"
    When "fr":
    Return "francés"
    When "de":
    Return "alemán"
    Otherwise:
    Return language_code
    Otherwise:
    Return language_code

Process called "get_territory_display_name" that takes territory_code as String and display_locale as Locale returns String:
    Note: Get localized territory name
    Match display_locale.language:
    When "en":
    Match territory_code:
    When "US":
    Return "United States"
    When "GB":
    Return "United Kingdom"
    When "CA":
    Return "Canada"
    When "AU":
    Return "Australia"
    When "DE":
    Return "Germany"
    When "FR":
    Return "France"
    When "ES":
    Return "Spain"
    When "IT":
    Return "Italy"
    When "JP":
    Return "Japan"
    When "CN":
    Return "China"
    Otherwise:
    Return territory_code
    Otherwise:
    Return territory_code

Note: Locale Validation and Utilities
Process called "is_well_formed_locale_tag" that takes locale_tag as String returns Boolean:
    Note: Validate locale tag conforms to BCP 47
    Try:
    Let parsed be parse_locale_tag with locale_tag as locale_tag
    Return parsed.language is not equal to "und"
    Catch error:
    Return false

Process called "is_locale_supported" that takes manager as LocaleManager and locale as Locale returns Boolean:
    Note: Check if locale is supported by manager
    For each available_locale in manager.available_locales:
    If available_locale.language is equal to locale.language:
    If locale.territory is None or available_locale.territory is equal to locale.territory:
    If locale.script is None or available_locale.script is equal to locale.script:
    Return true
    Return false

Process called "minimize_locale" that takes locale as Locale returns String:
    Note: Minimize locale tag by removing likely subtags
    Note: Start with full tag and remove redundant parts
    Let minimal_parts be list containing locale.language Note: Add script only if not the likely script
    If locale.script is not None:
    Let likely_script be infer_script_from_language with language as locale.language
    If locale.script is not equal to likely_script:
    Add locale.script to minimal_parts Note: Add territory only if not the likely territory
    If locale.territory is not None:
    Let likely_territory be infer_territory_from_language with language as locale.language and script as locale.script
    If locale.territory is not equal to likely_territory:
    Add locale.territory to minimal_parts Return Format.join with items as minimal_parts and sep as "-"

Process called "maximize_locale" that takes locale as Locale returns Locale:
    Note: Maximize locale by adding all likely subtags
    Let likely_subtags be locale.likely_subtags Return Locale with:
    language as locale.language
    script as Some with value as likely_subtags.likely_script
    territory as Some with value as likely_subtags.likely_territory
    variant as locale.variant
    extensions as locale.extensions
    private_use as locale.private_use
    tag as format_locale_tag with language as locale.language and script as Some with value as likely_subtags.likely_script and territory as Some with value as likely_subtags.likely_territory and variant as locale.variant
    canonical_tag as locale.canonical_tag
    parent_locale as locale.parent_locale
    likely_subtags as likely_subtags
    locale_metadata as locale.locale_metadata

Process called "compare_locales" that takes locale1 as Locale and locale2 as Locale returns Integer:
    Note: Compare two locales for sorting
    Let lang_compare be Unicode.compare_strings with text1 as locale1.language and text2 as locale2.language
    If lang_compare is not equal to 0:
    Return lang_compare Let script1 be if locale1.script is None then "" else locale1.script
    Let script2 be if locale2.script is None then "" else locale2.script
    Let script_compare be Unicode.compare_strings with text1 as script1 and text2 as script2
    If script_compare is not equal to 0:
    Return script_compare Let territory1 be if locale1.territory is None then "" else locale1.territory
    Let territory2 be if locale2.territory is None then "" else locale2.territory
    Return Unicode.compare_strings with text1 as territory1 and text2 as territory2

