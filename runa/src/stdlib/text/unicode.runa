    utf8_sequence as String
    utf16_sequence as List[Integer]
    utf32_value as Integer
    character_name as String
    category as UnicodeCategory
    combining_class as Integer
    bidirectional_type as BidirectionalType
    numeric_value as Optional[Float]
    case_mapping as CaseMapping
    script as UnicodeScript
    block as UnicodeBlock
    properties as List[UnicodeProperty]
    metadata as Dictionary[String, Any]

