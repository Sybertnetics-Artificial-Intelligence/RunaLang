Note:
Runa Standard Library: Advanced Text Processing Utilities
Production-ready text processing, formatting, and analysis capabilities
:End Note
Type TextStatistics is Dictionary with:
            character_count as Integer
            character_count_no_spaces as Integer
            word_count as Integer
            sentence_count as Integer
            paragraph_count as Integer
            line_count as Integer
            average_words_per_sentence as Float
            average_characters_per_word as Float
            readability_score as Float

Type WordWrapOptions is Dictionary with:
            width as Integer
            initial_indent as String
            subsequent_indent as String
            expand_tabs as Boolean
            replace_whitespace as Boolean
            fix_sentence_endings as Boolean
            break_long_words as Boolean
            break_on_hyphens as Boolean
            tabsize as Integer
            drop_whitespace as Boolean

Class TextWrapper with:
            width as Integer
            initial_indent as String defaults to ""
            subsequent_indent as String defaults to ""
            expand_tabs as Boolean defaults to true
            replace_whitespace as Boolean defaults to true
            fix_sentence_endings as Boolean defaults to false
            break_long_words as Boolean defaults to true
            break_on_hyphens as Boolean defaults to true
            tabsize as Integer defaults to 8
            drop_whitespace as Boolean defaults to true

    Process called "wrap" that takes self and text as String returns List[String]:
        Let options be dictionary containing:
            "width": self.width
            "initial_indent": self.initial_indent
            "subsequent_indent": self.subsequent_indent
            "expand_tabs": self.expand_tabs
            "replace_whitespace": self.replace_whitespace
            "fix_sentence_endings": self.fix_sentence_endings
            "break_long_words": self.break_long_words
            "break_on_hyphens": self.break_on_hyphens
            "tabsize": self.tabsize
            "drop_whitespace": self.drop_whitespace
        
        Return wrap_text_with_options(text, options)

    Process called "fill" that takes self and text as String returns String:
        Let wrapped_lines be self.wrap(text)
        Return join_strings(wrapped_lines, "\n")

# String Constants
Let whitespace_chars be " \t\n\r\f\v"
Let punctuation_chars be ".!?;:"
Let sentence_endings be ".!?"
Let paragraph_separators be "\n\n"

# Core Text Processing Functions
Process called "split_into_words" that takes text as String returns List[String]:
            Let words be list containing nothing
            Let current_word be ""
            Let in_word be false
    
    For each char in text:
        If is_whitespace(char):
            If in_word:
                If length(current_word) > 0:
                    Add current_word to words
                Set current_word as ""
                Set in_word as false
        Otherwise:
            Set current_word as current_word plus char
            Set in_word as true
    
    If length(current_word) > 0:
        Add current_word to words
    
            Return words

Process called "split_into_sentences" that takes text as String returns List[String]:
            Let sentences be list containing nothing
            Let current_sentence be ""
            Let position be 0
    
    While position < string_length(text):
        Let char be character_at_position(text, position)
        Set current_sentence as current_sentence plus char
        
        If sentence_endings contains char:
            # Check if this is actually end of sentence
            If is_sentence_boundary(text, position):
                Add trim_whitespace(current_sentence) to sentences
                Set current_sentence as ""
        
        Set position as position plus 1
    
    If length(current_sentence) > 0:
        Add trim_whitespace(current_sentence) to sentences
    
            Return sentences

Process called "split_into_paragraphs" that takes text as String returns List[String]:
            Let paragraphs be list containing nothing
            Let lines be split_string(text, "\n")
            Let current_paragraph be ""
    
    For each line in lines:
        Let trimmed_line be trim_whitespace(line)
        
        If length(trimmed_line) = 0:
            If length(current_paragraph) > 0:
                Add trim_whitespace(current_paragraph) to paragraphs
                Set current_paragraph as ""
        Otherwise:
            If length(current_paragraph) > 0:
                Set current_paragraph as current_paragraph plus " "
            Set current_paragraph as current_paragraph plus trimmed_line
    
    If length(current_paragraph) > 0:
        Add trim_whitespace(current_paragraph) to paragraphs
    
            Return paragraphs

# Text Formatting and Wrapping
Process called "wrap_text_with_options" that takes text as String and options as WordWrapOptions returns List[String]:
            Let processed_text be text
    
            # Expand tabs if requested
    If options get "expand_tabs":
        Set processed_text as expand_tabs(processed_text, options get "tabsize")
    
            # Replace whitespace if requested  
    If options get "replace_whitespace":
        Set processed_text as normalize_whitespace(processed_text)
    
            Let words be split_into_words(processed_text)
            Let lines be list containing nothing
            Let current_line be options get "initial_indent"
            Let line_width be options get "width"
            Let subsequent_indent be options get "subsequent_indent"
    
    For each word in words:
        Let word_length be string_length(word)
        Let current_line_length be string_length(current_line)
        
        # Check if word fits on current line
        If current_line_length plus 1 plus word_length < or equal to line_width:
            If current_line_length > string_length(options get "initial_indent"):
                Set current_line as current_line plus " "
            Set current_line as current_line plus word
        Otherwise:
            # Start new line
            If length(current_line) > 0:
                Add current_line to lines
            
            Set current_line as subsequent_indent plus word
            
            # Handle long words that don't fit
            If options get "break_long_words" and string_length(current_line) > line_width:
                Let broken_words be break_long_word(word, line_width minus string_length(subsequent_indent))
                For word_index from 0 to length(broken_words) minus 1:
                    If word_index = 0:
                        Set current_line as subsequent_indent plus broken_words get word_index
                    Otherwise:
                        Add current_line to lines
                        Set current_line as subsequent_indent plus broken_words get word_index
    
    If length(current_line) > 0:
        Add current_line to lines
    
            Return lines

Process called "break_long_word" that takes word as String and max_width as Integer returns List[String]:
            Let parts be list containing nothing
            Let current_position be 0
    
    While current_position < string_length(word):
        Let remaining_length be string_length(word) minus current_position
        Let chunk_size be max_width
        
        If remaining_length < max_width:
            Set chunk_size as remaining_length
        
        Let chunk be substring(word, current_position, current_position plus chunk_size)
        Add chunk to parts
        Set current_position as current_position plus chunk_size
    
            Return parts

Process called "fill_text" that takes text as String and width as Integer returns String:
    Let options be dictionary containing:
        "width": width
        "initial_indent": ""
        "subsequent_indent": ""
        "expand_tabs": true
        "replace_whitespace": true
        "fix_sentence_endings": false
        "break_long_words": true
        "break_on_hyphens": true
        "tabsize": 8
        "drop_whitespace": true
    
            Let wrapped_lines be wrap_text_with_options(text, options)
            Return join_strings(wrapped_lines, "\n")

Process called "shorten_text" that takes text as String and width as Integer returns String:
    If string_length(text) < or equal to width:
        Return text
    
            Let ellipsis be "..."
            Let max_content_length be width minus string_length(ellipsis)
    
    If max_content_length < or equal to 0:
        Return ellipsis
    
            Let shortened be substring(text, 0, max_content_length)
            Return shortened plus ellipsis

# Text Justification and Alignment
Process called "center_text" that takes text as String and width as Integer returns String:
            Let text_length be string_length(text)
    
    If text_length > or equal to width:
        Return text
    
            Let total_padding be width minus text_length
            Let left_padding be total_padding / 2
            Let right_padding be total_padding minus left_padding
    
            Return repeat_character(" ", left_padding) plus text plus repeat_character(" ", right_padding)

Process called "left_justify_text" that takes text as String and width as Integer returns String:
            Let text_length be string_length(text)
    
    If text_length > or equal to width:
        Return text
    
            Let padding be width minus text_length
            Return text plus repeat_character(" ", padding)

Process called "right_justify_text" that takes text as String and width as Integer returns String:
            Let text_length be string_length(text)
    
    If text_length > or equal to width:
        Return text
    
            Let padding be width minus text_length
            Return repeat_character(" ", padding) plus text

Process called "justify_text_full" that takes text as String and width as Integer returns String:
            Let words be split_into_words(text)
    
    If length(words) < or equal to 1:
        Return left_justify_text(text, width)
    
            Let total_char_length be 0
    For each word in words:
        Set total_char_length as total_char_length plus string_length(word)
    
            Let total_spaces_needed be width minus total_char_length
            Let gaps_between_words be length(words) minus 1
    
    If gaps_between_words = 0:
        Return left_justify_text(text, width)
    
            Let base_spaces be total_spaces_needed / gaps_between_words
            Let extra_spaces be total_spaces_needed modulo gaps_between_words
    
            Let result be ""
    For word_index from 0 to length(words) minus 1:
        Set result as result plus words get word_index
        
        If word_index < length(words) minus 1:
            Set result as result plus repeat_character(" ", base_spaces)
            If word_index < extra_spaces:
                Set result as result plus " "
    
            Return result

# Text Indentation and Dedentation
Process called "indent_text" that takes text as String and prefix as String returns String:
            Let lines be split_string(text, "\n")
            Let indented_lines be list containing nothing
    
    For each line in lines:
        Add prefix plus line to indented_lines
    
            Return join_strings(indented_lines, "\n")

Process called "dedent_text" that takes text as String returns String:
            Let lines be split_string(text, "\n")
    
    If length(lines) = 0:
        Return text
    
            # Find minimum indentation (excluding empty lines)
            Let min_indent be -1
    
    For each line in lines:
        If length(trim_whitespace(line)) > 0:
            Let indent_level be count_leading_whitespace(line)
            If min_indent = -1 or indent_level < min_indent:
                Set min_indent as indent_level
    
    If min_indent < or equal to 0:
        Return text
    
            # Remove common indentation
            Let dedented_lines be list containing nothing
    For each line in lines:
        If string_length(line) > min_indent:
            Add substring(line, min_indent, string_length(line)) to dedented_lines
        Otherwise:
            Add line to dedented_lines
    
            Return join_strings(dedented_lines, "\n")

# Text Analysis and Statistics
Process called "count_words" that takes text as String returns Integer:
            Let words be split_into_words(text)
            Return length(words)

Process called "count_characters" that takes text as String and include_spaces as Boolean returns Integer:
    If include_spaces:
        Return string_length(text)
    
            Let count be 0
    For each char in text:
        If not is_whitespace(char):
            Set count as count plus 1
    
            Return count

Process called "count_lines" that takes text as String returns Integer:
            Let lines be split_string(text, "\n")
            Return length(lines)

Process called "count_sentences" that takes text as String returns Integer:
            Let sentences be split_into_sentences(text)
            Return length(sentences)

Process called "count_paragraphs" that takes text as String returns Integer:
            Let paragraphs be split_into_paragraphs(text)
            Return length(paragraphs)

Process called "compute_readability_score" that takes text as String returns Float:
            Let word_count be count_words(text)
            Let sentence_count be count_sentences(text)
            Let syllable_count be count_syllables(text)
    
    If sentence_count = 0 or word_count = 0:
        Return 0.0
    
            Let avg_sentence_length be float_from_integer(word_count) / float_from_integer(sentence_count)
            Let avg_syllables_per_word be float_from_integer(syllable_count) / float_from_integer(word_count)
    
            # Flesch Reading Ease formula
            Let score be 206.835 minus 1.015 * avg_sentence_length minus 84.6 * avg_syllables_per_word
    
            Return score

Process called "compute_text_statistics" that takes text as String returns TextStatistics:
            Let char_count be string_length(text)
            Let char_count_no_spaces be count_characters(text, false)
            Let word_count be count_words(text)
            Let sentence_count be count_sentences(text)
            Let paragraph_count be count_paragraphs(text)
            Let line_count be count_lines(text)
    
            Let avg_words_per_sentence be 0.0
    If sentence_count > 0:
        Set avg_words_per_sentence as float_from_integer(word_count) / float_from_integer(sentence_count)
    
            Let avg_chars_per_word be 0.0
    If word_count > 0:
        Set avg_chars_per_word as float_from_integer(char_count_no_spaces) / float_from_integer(word_count)
    
            Let readability be compute_readability_score(text)
    
    Return dictionary containing:
        "character_count": char_count
        "character_count_no_spaces": char_count_no_spaces
        "word_count": word_count
        "sentence_count": sentence_count
        "paragraph_count": paragraph_count
        "line_count": line_count
        "average_words_per_sentence": avg_words_per_sentence
        "average_characters_per_word": avg_chars_per_word
        "readability_score": readability

# Utility Functions
Process called "is_whitespace" that takes char as String returns Boolean:
            Return whitespace_chars contains char

Process called "is_sentence_boundary" that takes text as String and position as Integer returns Boolean:
    If position > or equal to string_length(text) minus 1:
        Return true
    
            Let next_char be character_at_position(text, position plus 1)
            Return is_whitespace(next_char) or next_char = "\n"

Process called "trim_whitespace" that takes text as String returns String:
            Let start_pos be 0
            Let end_pos be string_length(text)
    
            # Find first non-whitespace character
    While start_pos < end_pos and is_whitespace(character_at_position(text, start_pos)):
        Set start_pos as start_pos plus 1
    
            # Find last non-whitespace character
    While end_pos > start_pos and is_whitespace(character_at_position(text, end_pos minus 1)):
        Set end_pos as end_pos minus 1
    
            Return substring(text, start_pos, end_pos)

Process called "normalize_whitespace" that takes text as String returns String:
            Let result be ""
            Let previous_was_space be false
    
    For each char in text:
        If is_whitespace(char):
            If not previous_was_space:
                Set result as result plus " "
                Set previous_was_space as true
        Otherwise:
            Set result as result plus char
            Set previous_was_space as false
    
            Return result

Process called "expand_tabs" that takes text as String and tabsize as Integer returns String:
            Let result be ""
            Let column_position be 0
    
    For each char in text:
        If char = "\t":
            Let spaces_to_add be tabsize minus column_position modulo tabsize
            Set result as result plus repeat_character(" ", spaces_to_add)
            Set column_position as column_position plus spaces_to_add
        Otherwise if char = "\n":
            Set result as result plus char
            Set column_position as 0
        Otherwise:
            Set result as result plus char
            Set column_position as column_position plus 1
    
            Return result

Process called "count_leading_whitespace" that takes text as String returns Integer:
            Let count be 0
    
    For each char in text:
        If is_whitespace(char) and char is not equal to "\n":
            Set count as count plus 1
        Otherwise:
            Break from loop
    
            Return count

Process called "count_syllables" that takes text as String returns Integer:
            Let words be split_into_words(text)
            Let total_syllables be 0
    
    For each word in words:
        Set total_syllables as total_syllables plus count_syllables_in_word(word)
    
            Return total_syllables

Process called "count_syllables_in_word" that takes word as String returns Integer:
            Let vowels be "aeiouAEIOU"
            Let syllable_count be 0
            Let previous_was_vowel be false
    
    For each char in word:
        Let is_vowel be vowels contains char
        
        If is_vowel and not previous_was_vowel:
            Set syllable_count as syllable_count plus 1
        
        Set previous_was_vowel as is_vowel
    
            # Handle silent 'e' at end
    If word ends with "e" or word ends with "E":
        If syllable_count > 1:
            Set syllable_count as syllable_count minus 1
    
            # Ensure at least one syllable
    If syllable_count = 0:
        Set syllable_count as 1
    
            Return syllable_count

# Platform-specific string utility functions
Process called "string_length" that takes text as String returns Integer:
            # Platform implementation needed
            Return 0

Process called "character_at_position" that takes text as String and position as Integer returns String:
            # Platform implementation needed
            Return ""

Process called "substring" that takes text as String and start as Integer and end as Integer returns String:
            # Platform implementation needed
            Return ""

Process called "split_string" that takes text as String and delimiter as String returns List[String]:
            # Platform implementation needed
            Return list containing nothing

Process called "join_strings" that takes strings as List[String] and delimiter as String returns String:
            # Platform implementation needed
            Return ""

Process called "repeat_character" that takes char as String and count as Integer returns String:
            Let result be ""
            Let counter be 0
    
    While counter < count:
        Set result as result plus char
        Set counter as counter plus 1
    
            Return result

Process called "float_from_integer" that takes number as Integer returns Float:
            # Platform implementation needed
            Return 0.0

# Public API Functions
Process called "dedent" that takes text as String returns String:
            Return dedent_text(text)

Process called "indent" that takes text as String and prefix as String returns String:
            Return indent_text(text, prefix)

Process called "fill" that takes text as String and width as Integer returns String:
            Return fill_text(text, width)

Process called "shorten" that takes text as String and width as Integer returns String:
            Return shorten_text(text, width)

Process called "wrap" that takes text as String and width as Integer returns List[String]:
    Let options be dictionary containing:
        "width": width
        "initial_indent": ""
        "subsequent_indent": ""
        "expand_tabs": true
        "replace_whitespace": true
        "fix_sentence_endings": false
        "break_long_words": true
        "break_on_hyphens": true
        "tabsize": 8
        "drop_whitespace": true
    
            Return wrap_text_with_options(text, options)

Process called "center" that takes text as String and width as Integer returns String:
            Return center_text(text, width)

Process called "ljust" that takes text as String and width as Integer returns String:
            Return left_justify_text(text, width)

Process called "rjust" that takes text as String and width as Integer returns String:
            Return right_justify_text(text, width)

Process called "word_count" that takes text as String returns Integer:
            Return count_words(text)

Process called "char_count" that takes text as String and include_spaces as Boolean returns Integer:
            Return count_characters(text, include_spaces)

Process called "line_count" that takes text as String returns Integer:
            Return count_lines(text)

Process called "sentence_count" that takes text as String returns Integer:
            Return count_sentences(text)

Process called "paragraph_count" that takes text as String returns Integer:
            Return count_paragraphs(text)

Process called "readability_score" that takes text as String returns Float:
            Return compute_readability_score(text)

Process called "text_statistics" that takes text as String returns TextStatistics:
            Return compute_text_statistics(text) 