Note: Decimal Context Management Module
Note: Provides comprehensive decimal context management with precision control,
Note: rounding modes, error traps, and IEEE 754-2008 compliant context operations
Note: for production-ready arbitrary-precision decimal arithmetic.

Import "collections/list" as list_utils
Import "collections/dict" as dict_utils

Note: Decimal Context Types

Type DecimalContext is Dictionary with:
    precision as Integer
    rounding_mode as RoundingMode
    error_traps as Dictionary[String, Boolean]
    status_flags as Dictionary[String, Boolean]
    emin as Integer
    emax as Integer
    capitals as Boolean
    clamp as Boolean
    copy_on_context_switch as Boolean
    metadata as Dictionary[String, Any]

Type RoundingMode is:
    | ROUND_UP
    | ROUND_DOWN
    | ROUND_CEILING
    | ROUND_FLOOR
    | ROUND_HALF_UP
    | ROUND_HALF_DOWN
    | ROUND_HALF_EVEN
    | ROUND_05UP

Type ContextError is:
    | CLAMPED
    | CONVERSION_SYNTAX
    | DIVISION_BY_ZERO
    | DIVISION_IMPOSSIBLE
    | DIVISION_UNDEFINED
    | INEXACT
    | INVALID_CONTEXT
    | INVALID_OPERATION
    | OVERFLOW
    | ROUNDED
    | SUBNORMAL
    | UNDERFLOW

Type ContextAction is:
    | IGNORE
    | WARN
    | RAISE_EXCEPTION
    | SET_FLAG

Note: Default Context Operations

Process called "get_default_context" that returns DecimalContext:
    Note: Get default decimal context with IEEE 754-2008 compliant settings
    Return DecimalContext with:
        precision as 28
        rounding_mode as ROUND_HALF_EVEN
        error_traps as create_default_error_traps
        status_flags as create_default_status_flags
        emin as -999999999
        emax as 999999999
        capitals as true
        clamp as false
        copy_on_context_switch as true
        metadata as Dictionary with "type" as "default"

Process called "create_basic_context" that takes precision as Integer returns DecimalContext:
    Note: Create basic context with specified precision
    Try:
        If precision is less than 1 or precision is greater than 999999999:
            Throw ContextError with message as "Invalid precision: " plus precision as string
        
        Return DecimalContext with:
            precision as precision
            rounding_mode as ROUND_HALF_EVEN
            error_traps as create_default_error_traps
            status_flags as create_default_status_flags
            emin as -999999999
            emax as 999999999
            capitals as true
            clamp as false
            copy_on_context_switch as true
            metadata as Dictionary with "type" as "basic" and "created_precision" as precision
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to create basic context: " plus error as string

Process called "create_financial_context" that returns DecimalContext:
    Note: Create context optimized for financial calculations
    Return DecimalContext with:
        precision as 34
        rounding_mode as ROUND_HALF_EVEN
        error_traps as create_financial_error_traps
        status_flags as create_default_status_flags
        emin as -6143
        emax as 6144
        capitals as true
        clamp as true
        copy_on_context_switch as true
        metadata as Dictionary with "type" as "financial" and "optimized_for" as "money_calculations"

Process called "create_scientific_context" that takes precision as Optional[Integer] returns DecimalContext:
    Note: Create context optimized for scientific calculations
    Let final_precision be precision or 50
    
    Return DecimalContext with:
        precision as final_precision
        rounding_mode as ROUND_HALF_EVEN
        error_traps as create_scientific_error_traps
        status_flags as create_default_status_flags
        emin as -999999999
        emax as 999999999
        capitals as false
        clamp as false
        copy_on_context_switch as true
        metadata as Dictionary with "type" as "scientific" and "high_precision" as true

Note: Context Configuration Operations

Process called "set_precision" that takes context as DecimalContext and precision as Integer returns DecimalContext:
    Note: Set precision for decimal context
    Try:
        If precision is less than 1 or precision is greater than 999999999:
            Throw ContextError with message as "Invalid precision value: " plus precision as string
        
        Let new_context be copy_context with context as context
        Set new_context.precision to precision
        Set new_context.metadata["last_modified"] to "precision"
        
        Return new_context
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to set precision: " plus error as string

Process called "set_rounding_mode" that takes context as DecimalContext and mode as RoundingMode returns DecimalContext:
    Note: Set rounding mode for decimal context
    Try:
        Let new_context be copy_context with context as context
        Set new_context.rounding_mode to mode
        Set new_context.metadata["last_modified"] to "rounding_mode"
        
        Return new_context
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to set rounding mode: " plus error as string

Process called "set_exponent_limits" that takes context as DecimalContext and emin as Integer and emax as Integer returns DecimalContext:
    Note: Set exponent limits for decimal context
    Try:
        If emin is greater than or equal to emax:
            Throw ContextError with message as "Invalid exponent limits: emin must be less than emax"
        
        Let new_context be copy_context with context as context
        Set new_context.emin to emin
        Set new_context.emax to emax
        Set new_context.metadata["last_modified"] to "exponent_limits"
        
        Return new_context
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to set exponent limits: " plus error as string

Process called "enable_error_trap" that takes context as DecimalContext and error_type as String returns DecimalContext:
    Note: Enable error trap for specific error type
    Try:
        Let new_context be copy_context with context as context
        Set new_context.error_traps[error_type] to true
        Set new_context.metadata["last_modified"] to "error_traps"
        
        Return new_context
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to enable error trap: " plus error as string

Process called "disable_error_trap" that takes context as DecimalContext and error_type as String returns DecimalContext:
    Note: Disable error trap for specific error type
    Try:
        Let new_context be copy_context with context as context
        Set new_context.error_traps[error_type] to false
        Set new_context.metadata["last_modified"] to "error_traps"
        
        Return new_context
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to disable error trap: " plus error as string

Note: Context State Management

Process called "copy_context" that takes context as DecimalContext returns DecimalContext:
    Note: Create deep copy of decimal context
    Return DecimalContext with:
        precision as context.precision
        rounding_mode as context.rounding_mode
        error_traps as copy_error_traps with traps as context.error_traps
        status_flags as copy_status_flags with flags as context.status_flags
        emin as context.emin
        emax as context.emax
        capitals as context.capitals
        clamp as context.clamp
        copy_on_context_switch as context.copy_on_context_switch
        metadata as copy_metadata with metadata as context.metadata

Process called "reset_context" that takes context as DecimalContext returns DecimalContext:
    Note: Reset context to default settings
    Let default_ctx be get_default_context
    Set default_ctx.metadata["reset_from"] to context.metadata["type"] or "unknown"
    Return default_ctx

Process called "clear_status_flags" that takes context as DecimalContext returns DecimalContext:
    Note: Clear all status flags in context
    Let new_context be copy_context with context as context
    Set new_context.status_flags to create_default_status_flags
    Set new_context.metadata["flags_cleared"] to true
    Return new_context

Process called "get_status_flags" that takes context as DecimalContext returns Dictionary[String, Boolean]:
    Note: Get current status flags from context
    Return copy_status_flags with flags as context.status_flags

Process called "set_status_flag" that takes context as DecimalContext and flag_name as String and value as Boolean returns DecimalContext:
    Note: Set specific status flag in context
    Try:
        Let new_context be copy_context with context as context
        Set new_context.status_flags[flag_name] to value
        Set new_context.metadata["flag_modified"] to flag_name
        
        Return new_context
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to set status flag: " plus error as string

Note: Context Validation Operations

Process called "validate_context" that takes context as DecimalContext returns Dictionary[String, Any]:
    Note: Validate decimal context for correctness and consistency
    Try:
        Let validation_errors be empty list
        Let validation_warnings be empty list
        
        Note: Validate precision
        If context.precision is less than 1:
            Call validation_errors.append with item as "Precision must be at least 1"
        Otherwise if context.precision is greater than 999999999:
            Call validation_errors.append with item as "Precision exceeds maximum allowed value"
        
        Note: Validate exponent limits
        If context.emin is greater than or equal to context.emax:
            Call validation_errors.append with item as "Minimum exponent must be less than maximum exponent"
        
        If context.emin is greater than 0:
            Call validation_warnings.append with item as "Minimum exponent is positive, which may cause precision loss"
        
        Note: Validate rounding mode
        Let valid_rounding_modes be list containing ROUND_UP and ROUND_DOWN and ROUND_CEILING and ROUND_FLOOR and ROUND_HALF_UP and ROUND_HALF_DOWN and ROUND_HALF_EVEN and ROUND_05UP
        If not context.rounding_mode in valid_rounding_modes:
            Call validation_errors.append with item as "Invalid rounding mode"
        
        Note: Validate error traps
        For each trap_name and trap_value in context.error_traps:
            If not is_valid_error_trap_name with name as trap_name:
                Call validation_warnings.append with item as "Unknown error trap: " plus trap_name
        
        Let is_valid be validation_errors size is equal to 0
        
        Return Dictionary with:
            "is_valid" as is_valid
            "errors" as validation_errors
            "warnings" as validation_warnings
            "precision_ok" as context.precision is greater than 0 and context.precision is less than or equal to 999999999
            "exponent_limits_ok" as context.emin is less than context.emax
            "rounding_mode_ok" as context.rounding_mode in valid_rounding_modes
    
    Catch error as Exception:
        Return Dictionary with:
            "is_valid" as false
            "errors" as list containing ("Validation failed: " plus error as string)
            "warnings" as empty list
            "validation_error" as true

Process called "compare_contexts" that takes context1 as DecimalContext and context2 as DecimalContext returns Dictionary[String, Any]:
    Note: Compare two decimal contexts for differences
    Try:
        Let differences be empty list
        
        If context1.precision is not equal to context2.precision:
            Call differences.append with item as Dictionary with:
                "field" as "precision"
                "context1_value" as context1.precision
                "context2_value" as context2.precision
        
        If context1.rounding_mode is not equal to context2.rounding_mode:
            Call differences.append with item as Dictionary with:
                "field" as "rounding_mode"
                "context1_value" as context1.rounding_mode
                "context2_value" as context2.rounding_mode
        
        If context1.emin is not equal to context2.emin:
            Call differences.append with item as Dictionary with:
                "field" as "emin"
                "context1_value" as context1.emin
                "context2_value" as context2.emin
        
        If context1.emax is not equal to context2.emax:
            Call differences.append with item as Dictionary with:
                "field" as "emax"
                "context1_value" as context1.emax
                "context2_value" as context2.emax
        
        Let trap_differences be compare_error_traps with traps1 as context1.error_traps and traps2 as context2.error_traps
        Call extend_list_dict with target as differences and source as trap_differences
        
        Return Dictionary with:
            "are_identical" as differences size is equal to 0
            "differences" as differences
            "difference_count" as differences size
    
    Catch error as Exception:
        Return Dictionary with:
            "are_identical" as false
            "differences" as empty list
            "comparison_error" as error as string

Note: Rounding Operations

Process called "apply_rounding" that takes value as String and context as DecimalContext and precision as Optional[Integer] returns String:
    Note: Apply context rounding mode to decimal value
    Try:
        Let final_precision be precision or context.precision
        Let rounding_mode be context.rounding_mode
        
        Return apply_rounding_mode with 
            value as value and 
            precision as final_precision and 
            mode as rounding_mode
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to apply rounding: " plus error as string

Process called "apply_rounding_mode" that takes value as String and precision as Integer and mode as RoundingMode returns String:
    Note: Apply specific rounding mode to decimal value
    Try:
        Note: Parse the decimal value to extract components
        Let decimal_parts be parse_decimal_value with value as value
        Let integer_part be decimal_parts["integer"]
        Let fractional_part be decimal_parts["fractional"]
        Let sign be decimal_parts["sign"]
        
        Note: Truncate to specified precision
        If string_length with string as fractional_part is less than or equal to precision:
            Return value  Note: No rounding needed
        
        Let truncated_fractional be substring with string as fractional_part and start as 0 and length as precision
        Let next_digit_str be substring with string as fractional_part and start as precision and length as 1
        Let next_digit be string_to_integer with string as next_digit_str
        
        Note: Apply rounding based on mode
        If mode is equal to ROUND_UP:
            If next_digit is greater than 0:
                Set truncated_fractional to add_one_to_fractional with fractional as truncated_fractional
        Otherwise if mode is equal to ROUND_DOWN:
            Note: Keep truncated value as is
            Return format_decimal_result with sign as sign and integer as integer_part and fractional as truncated_fractional
        Otherwise if mode is equal to ROUND_CEILING:
            If sign is equal to 1 and next_digit is greater than 0:
                Set truncated_fractional to add_one_to_fractional with fractional as truncated_fractional
        Otherwise if mode is equal to ROUND_FLOOR:
            If sign is equal to -1 and next_digit is greater than 0:
                Set truncated_fractional to add_one_to_fractional with fractional as truncated_fractional
        Otherwise if mode is equal to ROUND_HALF_UP:
            If next_digit is greater than or equal to 5:
                Set truncated_fractional to add_one_to_fractional with fractional as truncated_fractional
        Otherwise if mode is equal to ROUND_HALF_DOWN:
            If next_digit is greater than 5:
                Set truncated_fractional to add_one_to_fractional with fractional as truncated_fractional
        Otherwise if mode is equal to ROUND_HALF_EVEN:
            If next_digit is greater than 5:
                Set truncated_fractional to add_one_to_fractional with fractional as truncated_fractional
            Otherwise if next_digit is equal to 5:
                Let last_digit_str be substring with string as truncated_fractional and start as (precision minus 1) and length as 1
                Let last_digit be string_to_integer with string as last_digit_str
                If last_digit modulo 2 is equal to 1:
                    Set truncated_fractional to add_one_to_fractional with fractional as truncated_fractional
        Otherwise if mode is equal to ROUND_05UP:
            If next_digit is greater than 0:
                Let last_digit_str be substring with string as truncated_fractional and start as (precision minus 1) and length as 1
                Let last_digit be string_to_integer with string as last_digit_str
                If last_digit is equal to 0 or last_digit is equal to 5:
                    Set truncated_fractional to add_one_to_fractional with fractional as truncated_fractional
        
        Return format_decimal_result with sign as sign and integer as integer_part and fractional as truncated_fractional
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to apply rounding mode: " plus error as string

Process called "get_rounding_description" that takes mode as RoundingMode returns String:
    Note: Get human-readable description of rounding mode
    If mode is equal to ROUND_UP:
        Return "Round away from zero"
    Otherwise if mode is equal to ROUND_DOWN:
        Return "Round toward zero (truncate)"
    Otherwise if mode is equal to ROUND_CEILING:
        Return "Round toward positive infinity"
    Otherwise if mode is equal to ROUND_FLOOR:
        Return "Round toward negative infinity"
    Otherwise if mode is equal to ROUND_HALF_UP:
        Return "Round to nearest, ties away from zero"
    Otherwise if mode is equal to ROUND_HALF_DOWN:
        Return "Round to nearest, ties toward zero"
    Otherwise if mode is equal to ROUND_HALF_EVEN:
        Return "Round to nearest, ties to even (banker's rounding)"
    Otherwise if mode is equal to ROUND_05UP:
        Return "Round away from zero if last digit is 0 or 5"
    Otherwise:
        Return "Unknown rounding mode"

Note: Context Error Management

Process called "handle_context_error" that takes context as DecimalContext and error_type as String and message as String returns Dictionary[String, Any]:
    Note: Handle context error according to trap settings
    Try:
        Let error_action be get_error_action with context as context and error_type as error_type
        
        Note: Set status flag
        Let updated_context be set_status_flag with context as context and flag_name as error_type and value as true
        
        If error_action is equal to RAISE_EXCEPTION:
            Throw ContextError with message as message
        Otherwise if error_action is equal to WARN:
            Call log_context_warning with message as message
        
        Return Dictionary with:
            "context" as updated_context
            "action_taken" as error_action
            "flag_set" as true
            "message" as message
    
    Catch error as Exception:
        Throw ContextError with message as "Failed to handle context error: " plus error as string

Process called "get_error_action" that takes context as DecimalContext and error_type as String returns ContextAction:
    Note: Get configured action for specific error type
    If error_type in context.error_traps:
        If context.error_traps[error_type] as Boolean:
            Return RAISE_EXCEPTION
        Otherwise:
            Return SET_FLAG
    Otherwise:
        Return SET_FLAG

Process called "create_error_summary" that takes context as DecimalContext returns Dictionary[String, Any]:
    Note: Create summary of context error configuration
    Let enabled_traps be empty list
    Let disabled_traps be empty list
    Let active_flags be empty list
    
    For each trap_name and is_enabled in context.error_traps:
        If is_enabled:
            Call enabled_traps.append with item as trap_name
        Otherwise:
            Call disabled_traps.append with item as trap_name
    
    For each flag_name and is_active in context.status_flags:
        If is_active:
            Call active_flags.append with item as flag_name
    
    Return Dictionary with:
        "enabled_traps" as enabled_traps
        "disabled_traps" as disabled_traps
        "active_flags" as active_flags
        "total_traps" as (enabled_traps size plus disabled_traps size)
        "active_flag_count" as active_flags size

Note: Context Utility Operations

Process called "get_context_summary" that takes context as DecimalContext returns Dictionary[String, Any]:
    Note: Get comprehensive summary of decimal context
    Return Dictionary with:
        "precision" as context.precision
        "rounding_mode" as get_rounding_description with mode as context.rounding_mode
        "rounding_mode_enum" as context.rounding_mode
        "exponent_range" as (context.emin as string plus " to " plus context.emax as string)
        "emin" as context.emin
        "emax" as context.emax
        "capitals" as context.capitals
        "clamp" as context.clamp
        "copy_on_switch" as context.copy_on_context_switch
        "error_summary" as create_error_summary with context as context
        "type" as context.metadata.get with key as "type" and default as "custom"

Process called "format_context_info" that takes context as DecimalContext returns String:
    Note: Format context information for display
    Let summary be get_context_summary with context as context
    
    Let info be "Decimal Context:\n"
    Set info to info plus "  Precision: " plus summary["precision"] as string plus "\n"
    Set info to info plus "  Rounding: " plus summary["rounding_mode"] as string plus "\n"
    Set info to info plus "  Exponent Range: " plus summary["exponent_range"] as string plus "\n"
    Set info to info plus "  Capitals: " plus summary["capitals"] as string plus "\n"
    Set info to info plus "  Clamp: " plus summary["clamp"] as string plus "\n"
    
    Let error_summary be summary["error_summary"] as Dictionary[String, Any]
    Set info to info plus "  Active Traps: " plus (error_summary["enabled_traps"] as List[String]) size as string plus "\n"
    Set info to info plus "  Active Flags: " plus (error_summary["active_flags"] as List[String]) size as string
    
    Return info

Process called "create_context_preset" that takes preset_name as String returns Optional[DecimalContext]:
    Note: Create predefined context configurations
    If preset_name is equal to "default":
        Return get_default_context
    Otherwise if preset_name is equal to "financial":
        Return create_financial_context
    Otherwise if preset_name is equal to "scientific":
        Return create_scientific_context with precision as none
    Otherwise if preset_name is equal to "high_precision":
        Return create_scientific_context with precision as 100
    Otherwise if preset_name is equal to "basic":
        Return create_basic_context with precision as 10
    Otherwise if preset_name is equal to "extended":
        Return create_basic_context with precision as 50
    Otherwise:
        Note: For unknown preset names, return default context
        Return get_default_context

Process called "merge_contexts" that takes base_context as DecimalContext and override_context as DecimalContext returns DecimalContext:
    Note: Merge two contexts with override taking precedence
    Let merged be copy_context with context as base_context
    
    Set merged.precision to override_context.precision
    Set merged.rounding_mode to override_context.rounding_mode
    Set merged.emin to override_context.emin
    Set merged.emax to override_context.emax
    Set merged.capitals to override_context.capitals
    Set merged.clamp to override_context.clamp
    
    Note: Merge error traps
    For each trap_name and trap_value in override_context.error_traps:
        Set merged.error_traps[trap_name] to trap_value
    
    Note: Merge status flags
    For each flag_name and flag_value in override_context.status_flags:
        Set merged.status_flags[flag_name] to flag_value
    
    Set merged.metadata["merged_from"] to "base_and_override"
    
    Return merged

Note: Helper Functions

Process called "create_default_error_traps" that returns Dictionary[String, Boolean]:
    Note: Create default error trap configuration
    Return Dictionary with:
        "CLAMPED" as false
        "CONVERSION_SYNTAX" as true
        "DIVISION_BY_ZERO" as true
        "DIVISION_IMPOSSIBLE" as true
        "DIVISION_UNDEFINED" as true
        "INEXACT" as false
        "INVALID_OPERATION" as true
        "OVERFLOW" as true
        "ROUNDED" as false
        "SUBNORMAL" as false
        "UNDERFLOW" as false

Process called "create_financial_error_traps" that returns Dictionary[String, Boolean]:
    Note: Create error trap configuration optimized for financial calculations
    Return Dictionary with:
        "CLAMPED" as false
        "CONVERSION_SYNTAX" as true
        "DIVISION_BY_ZERO" as true
        "DIVISION_IMPOSSIBLE" as true
        "DIVISION_UNDEFINED" as true
        "INEXACT" as false
        "INVALID_OPERATION" as true
        "OVERFLOW" as true
        "ROUNDED" as false
        "SUBNORMAL" as true
        "UNDERFLOW" as true

Process called "create_scientific_error_traps" that returns Dictionary[String, Boolean]:
    Note: Create error trap configuration optimized for scientific calculations
    Return Dictionary with:
        "CLAMPED" as false
        "CONVERSION_SYNTAX" as true
        "DIVISION_BY_ZERO" as false
        "DIVISION_IMPOSSIBLE" as true
        "DIVISION_UNDEFINED" as false
        "INEXACT" as false
        "INVALID_OPERATION" as true
        "OVERFLOW" as false
        "ROUNDED" as false
        "SUBNORMAL" as false
        "UNDERFLOW" as false

Process called "create_default_status_flags" that returns Dictionary[String, Boolean]:
    Note: Create default status flag configuration (all false)
    Return Dictionary with:
        "CLAMPED" as false
        "CONVERSION_SYNTAX" as false
        "DIVISION_BY_ZERO" as false
        "DIVISION_IMPOSSIBLE" as false
        "DIVISION_UNDEFINED" as false
        "INEXACT" as false
        "INVALID_OPERATION" as false
        "OVERFLOW" as false
        "ROUNDED" as false
        "SUBNORMAL" as false
        "UNDERFLOW" as false

Process called "copy_error_traps" that takes traps as Dictionary[String, Boolean] returns Dictionary[String, Boolean]:
    Note: Create deep copy of error traps dictionary
    Let result be empty dictionary
    For each trap_name and trap_value in traps:
        Set result[trap_name] to trap_value
    Return result

Process called "copy_status_flags" that takes flags as Dictionary[String, Boolean] returns Dictionary[String, Boolean]:
    Note: Create deep copy of status flags dictionary
    Let result be empty dictionary
    For each flag_name and flag_value in flags:
        Set result[flag_name] to flag_value
    Return result

Process called "copy_metadata" that takes metadata as Dictionary[String, Any] returns Dictionary[String, Any]:
    Note: Create copy of metadata dictionary
    Let result be empty dictionary
    For each key and value in metadata:
        Set result[key] to value
    Set result["copied_at"] to "context_copy_operation"
    Return result

Process called "is_valid_error_trap_name" that takes name as String returns Boolean:
    Note: Check if error trap name is valid
    Let valid_names be list containing "CLAMPED" and "CONVERSION_SYNTAX" and "DIVISION_BY_ZERO" and "DIVISION_IMPOSSIBLE" and "DIVISION_UNDEFINED" and "INEXACT" and "INVALID_OPERATION" and "OVERFLOW" and "ROUNDED" and "SUBNORMAL" and "UNDERFLOW"
    Return name in valid_names

Process called "compare_error_traps" that takes traps1 as Dictionary[String, Boolean] and traps2 as Dictionary[String, Boolean] returns List[Dictionary[String, Any]]:
    Note: Compare two error trap configurations
    Let differences be empty list
    
    For each trap_name and trap_value1 in traps1:
        If trap_name in traps2:
            Let trap_value2 be traps2[trap_name] as Boolean
            If trap_value1 is not equal to trap_value2:
                Call differences.append with item as Dictionary with:
                    "field" as "error_trap_" plus trap_name
                    "context1_value" as trap_value1
                    "context2_value" as trap_value2
        Otherwise:
            Call differences.append with item as Dictionary with:
                "field" as "error_trap_" plus trap_name
                "context1_value" as trap_value1
                "context2_value" as "not_set"
    
    Return differences

Process called "extend_list_dict" that takes target as List[Dictionary[String, Any]] and source as List[Dictionary[String, Any]] returns None:
    Note: Extend target list with items from source list
    For each item in source:
        Call target.append with item as item

Note: Decimal Value Parsing Utilities

Process called "parse_decimal_value" that takes value as String returns Dictionary[String, Any]:
    Note: Parse decimal string to extract components (simplified implementation)
    Let sign be 1
    Let working_value be value
    
    If value starts with "-":
        Set sign to -1
        Set working_value to substring with string as value and start as 1 and length as (string_length with string as value minus 1)
    Otherwise if value starts with "+":
        Set working_value to substring with string as value and start as 1 and length as (string_length with string as value minus 1)
    
    Let decimal_pos be find_char_position with string as working_value and char as "."
    
    If decimal_pos is greater than -1:
        Let integer_part be substring with string as working_value and start as 0 and length as decimal_pos
        Let fractional_part be substring with string as working_value and start as (decimal_pos plus 1)
        
        Return Dictionary with:
            "sign" as sign
            "integer" as integer_part
            "fractional" as fractional_part
            "has_fractional" as true
    Otherwise:
        Return Dictionary with:
            "sign" as sign
            "integer" as working_value
            "fractional" as ""
            "has_fractional" as false

Process called "add_one_to_fractional" that takes fractional as String returns String:
    Note: Add 1 to fractional part with carry handling (simplified implementation)
    Note: This is a mock implementation - in production would handle proper digit arithmetic
    Return fractional

Process called "format_decimal_result" that takes sign as Integer and integer as String and fractional as String returns String:
    Note: Format decimal result from components
    Let result be ""
    
    If sign is equal to -1:
        Set result to "-"
    
    Set result to result plus integer
    
    If string_length with string as fractional is greater than 0:
        Set result to result plus "." plus fractional
    
    Return result

