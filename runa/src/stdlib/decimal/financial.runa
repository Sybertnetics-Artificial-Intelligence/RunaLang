Note: Decimal Financial Calculations Module
Note: Provides comprehensive financial calculations with exact decimal precision,
Note: including compound interest, present value, loan calculations, bond pricing,
Note: and other production-ready financial mathematics operations.

Import "decimal/decimal" as decimal_module
Import "decimal/context" as decimal_context
Import "decimal/core" as decimal_core
Import "collections/list" as list_utils

Note: Financial Calculation Types

Type FinancialResult is:
    | SUCCESS with value as decimal_module.Decimal and metadata as Dictionary[String, Any]
    | ERROR with message as String and error_code as String

Type LoanCalculation is Dictionary with:
    principal as decimal_module.Decimal
    interest_rate as decimal_module.Decimal
    term_years as Integer
    monthly_payment as decimal_module.Decimal
    total_payments as decimal_module.Decimal
    total_interest as decimal_module.Decimal
    payment_schedule as List[Dictionary[String, Any]]
    metadata as Dictionary[String, Any]

Type BondPricing is Dictionary with:
    face_value as decimal_module.Decimal
    coupon_rate as decimal_module.Decimal
    yield_to_maturity as decimal_module.Decimal
    years_to_maturity as decimal_module.Decimal
    present_value as decimal_module.Decimal
    coupon_payments as List[decimal_module.Decimal]
    metadata as Dictionary[String, Any]

Type InvestmentAnalysis is Dictionary with:
    initial_investment as decimal_module.Decimal
    cash_flows as List[decimal_module.Decimal]
    discount_rate as decimal_module.Decimal
    net_present_value as decimal_module.Decimal
    internal_rate_of_return as Optional[decimal_module.Decimal]
    payback_period as Optional[decimal_module.Decimal]
    profitability_index as decimal_module.Decimal
    metadata as Dictionary[String, Any]

Note: Compound Interest and Growth Calculations

Process called "compound_interest" that takes principal as decimal_module.Decimal and annual_rate as decimal_module.Decimal and periods_per_year as Integer and years as decimal_module.Decimal returns FinancialResult:
    Note: Calculate compound interest with exact decimal precision
    Try:
        Let context be decimal_context.create_financial_context
        
        Note: Validate inputs
        If decimal_module.is_negative with decimal as principal:
            Return ERROR with message as "Principal cannot be negative" and error_code as "INVALID_PRINCIPAL"
        
        If decimal_module.is_negative with decimal as annual_rate:
            Return ERROR with message as "Interest rate cannot be negative" and error_code as "INVALID_RATE"
        
        If periods_per_year is less than 1:
            Return ERROR with message as "Compounding periods must be at least 1" and error_code as "INVALID_PERIODS"
        
        Note: Calculate compound interest: A = P(1 + r/n)^(nt)
        Let rate_per_period be divide_decimals_safe with 
            dividend as annual_rate and 
            divisor as decimal_module.from_integer with value as periods_per_year and context as context and 
            context as context
        
        If rate_per_period is ERROR:
            Return rate_per_period
        
        Let one be decimal_module.one with context as context
        Let base be add_decimals_safe with a as one and b as rate_per_period.value and context as context
        
        If base is ERROR:
            Return base
        
        Let total_periods be multiply_decimals_safe with 
            a as decimal_module.from_integer with value as periods_per_year and context as context and 
            b as years and 
            context as context
        
        If total_periods is ERROR:
            Return total_periods
        
        Note: Calculate (1 + r/n)^(nt)
        Let power_result be power_decimal_safe with base as base.value and exponent as total_periods.value and context as context
        
        If power_result is ERROR:
            Return power_result
        
        Note: Calculate final amount A = P * (1 + r/n)^(nt)
        Let final_amount be multiply_decimals_safe with a as principal and b as power_result.value and context as context
        
        If final_amount is ERROR:
            Return final_amount
        
        Let interest_earned be subtract_decimals_safe with a as final_amount.value and b as principal and context as context
        
        If interest_earned is ERROR:
            Return interest_earned
        
        Return SUCCESS with 
            value as final_amount.value and 
            metadata as Dictionary with:
                "principal" as principal
                "annual_rate" as annual_rate
                "periods_per_year" as periods_per_year
                "years" as years
                "interest_earned" as interest_earned.value
                "effective_rate" as calculate_effective_rate with nominal_rate as annual_rate and periods as periods_per_year
    
    Catch error as Exception:
        Return ERROR with message as "Compound interest calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Process called "simple_interest" that takes principal as decimal_module.Decimal and annual_rate as decimal_module.Decimal and years as decimal_module.Decimal returns FinancialResult:
    Note: Calculate simple interest: I = P * r * t
    Try:
        Let context be decimal_context.create_financial_context
        
        Note: Validate inputs
        If decimal_module.is_negative with decimal as principal or decimal_module.is_negative with decimal as annual_rate:
            Return ERROR with message as "Principal and rate must be non-negative" and error_code as "INVALID_INPUT"
        
        Let interest_result be multiply_decimals_safe with a as principal and b as annual_rate and context as context
        
        If interest_result is ERROR:
            Return interest_result
        
        Let final_interest be multiply_decimals_safe with a as interest_result.value and b as years and context as context
        
        If final_interest is ERROR:
            Return final_interest
        
        Return SUCCESS with 
            value as final_interest.value and 
            metadata as Dictionary with:
                "principal" as principal
                "annual_rate" as annual_rate
                "years" as years
                "calculation_type" as "simple_interest"
    
    Catch error as Exception:
        Return ERROR with message as "Simple interest calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Process called "effective_annual_rate" that takes nominal_rate as decimal_module.Decimal and compounding_periods as Integer returns FinancialResult:
    Note: Calculate effective annual rate from nominal rate
    Try:
        Let context be decimal_context.create_financial_context
        
        Let rate_per_period be divide_decimals_safe with 
            dividend as nominal_rate and 
            divisor as decimal_module.from_integer with value as compounding_periods and context as context and 
            context as context
        
        If rate_per_period is ERROR:
            Return rate_per_period
        
        Let one be decimal_module.one with context as context
        Let base be add_decimals_safe with a as one and b as rate_per_period.value and context as context
        
        If base is ERROR:
            Return base
        
        Let exponent be decimal_module.from_integer with value as compounding_periods and context as context
        Let power_result be power_decimal_safe with base as base.value and exponent as exponent and context as context
        
        If power_result is ERROR:
            Return power_result
        
        Let effective_rate be subtract_decimals_safe with a as power_result.value and b as one and context as context
        
        If effective_rate is ERROR:
            Return effective_rate
        
        Return SUCCESS with 
            value as effective_rate.value and 
            metadata as Dictionary with:
                "nominal_rate" as nominal_rate
                "compounding_periods" as compounding_periods
                "calculation_type" as "effective_annual_rate"
    
    Catch error as Exception:
        Return ERROR with message as "Effective rate calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Note: Present and Future Value Calculations

Process called "present_value" that takes future_value as decimal_module.Decimal and discount_rate as decimal_module.Decimal and periods as Integer returns FinancialResult:
    Note: Calculate present value: PV = FV / (1 + r)^n
    Try:
        Let context be decimal_context.create_financial_context
        
        If decimal_module.is_negative with decimal as future_value or decimal_module.is_negative with decimal as discount_rate:
            Return ERROR with message as "Values must be non-negative" and error_code as "INVALID_INPUT"
        
        Let one be decimal_module.one with context as context
        Let base be add_decimals_safe with a as one and b as discount_rate and context as context
        
        If base is ERROR:
            Return base
        
        Let exponent be decimal_module.from_integer with value as periods and context as context
        Let discount_factor be power_decimal_safe with base as base.value and exponent as exponent and context as context
        
        If discount_factor is ERROR:
            Return discount_factor
        
        Let present_val be divide_decimals_safe with dividend as future_value and divisor as discount_factor.value and context as context
        
        If present_val is ERROR:
            Return present_val
        
        Return SUCCESS with 
            value as present_val.value and 
            metadata as Dictionary with:
                "future_value" as future_value
                "discount_rate" as discount_rate
                "periods" as periods
                "discount_factor" as discount_factor.value
    
    Catch error as Exception:
        Return ERROR with message as "Present value calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Process called "future_value" that takes present_value as decimal_module.Decimal and interest_rate as decimal_module.Decimal and periods as Integer returns FinancialResult:
    Note: Calculate future value: FV = PV * (1 + r)^n
    Try:
        Let context be decimal_context.create_financial_context
        
        If decimal_module.is_negative with decimal as present_value or decimal_module.is_negative with decimal as interest_rate:
            Return ERROR with message as "Values must be non-negative" and error_code as "INVALID_INPUT"
        
        Let one be decimal_module.one with context as context
        Let base be add_decimals_safe with a as one and b as interest_rate and context as context
        
        If base is ERROR:
            Return base
        
        Let exponent be decimal_module.from_integer with value as periods and context as context
        Let growth_factor be power_decimal_safe with base as base.value and exponent as exponent and context as context
        
        If growth_factor is ERROR:
            Return growth_factor
        
        Let future_val be multiply_decimals_safe with a as present_value and b as growth_factor.value and context as context
        
        If future_val is ERROR:
            Return future_val
        
        Return SUCCESS with 
            value as future_val.value and 
            metadata as Dictionary with:
                "present_value" as present_value
                "interest_rate" as interest_rate
                "periods" as periods
                "growth_factor" as growth_factor.value
    
    Catch error as Exception:
        Return ERROR with message as "Future value calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Process called "present_value_annuity" that takes payment as decimal_module.Decimal and interest_rate as decimal_module.Decimal and periods as Integer returns FinancialResult:
    Note: Calculate present value of ordinary annuity
    Try:
        Let context be decimal_context.create_financial_context
        
        If decimal_module.is_zero with decimal as interest_rate:
            Note: Special case: zero interest rate
            Let total_payments be multiply_decimals_safe with 
                a as payment and 
                b as decimal_module.from_integer with value as periods and context as context and 
                context as context
            
            If total_payments is ERROR:
                Return total_payments
            
            Return SUCCESS with 
                value as total_payments.value and 
                metadata as Dictionary with:
                    "payment" as payment
                    "interest_rate" as interest_rate
                    "periods" as periods
                    "special_case" as "zero_interest"
        
        Let one be decimal_module.one with context as context
        Let base be add_decimals_safe with a as one and b as interest_rate and context as context
        
        If base is ERROR:
            Return base
        
        Let exponent be decimal_module.from_integer with value as periods and context as context
        Let discount_factor be power_decimal_safe with base as base.value and exponent as exponent and context as context
        
        If discount_factor is ERROR:
            Return discount_factor
        
        Note: Calculate [1 - (1 + r)^(-n)] / r
        Let one_over_factor be divide_decimals_safe with dividend as one and divisor as discount_factor.value and context as context
        
        If one_over_factor is ERROR:
            Return one_over_factor
        
        Let numerator be subtract_decimals_safe with a as one and b as one_over_factor.value and context as context
        
        If numerator is ERROR:
            Return numerator
        
        Let annuity_factor be divide_decimals_safe with dividend as numerator.value and divisor as interest_rate and context as context
        
        If annuity_factor is ERROR:
            Return annuity_factor
        
        Let pv_annuity be multiply_decimals_safe with a as payment and b as annuity_factor.value and context as context
        
        If pv_annuity is ERROR:
            Return pv_annuity
        
        Return SUCCESS with 
            value as pv_annuity.value and 
            metadata as Dictionary with:
                "payment" as payment
                "interest_rate" as interest_rate
                "periods" as periods
                "annuity_factor" as annuity_factor.value
    
    Catch error as Exception:
        Return ERROR with message as "Annuity present value calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Note: Loan and Mortgage Calculations

Process called "calculate_loan_payment" that takes principal as decimal_module.Decimal and annual_rate as decimal_module.Decimal and years as Integer returns FinancialResult:
    Note: Calculate monthly loan payment using exact decimal arithmetic
    Try:
        Let context be decimal_context.create_financial_context
        
        If decimal_module.is_zero with decimal as annual_rate:
            Note: Special case: zero interest loan
            Let monthly_payment be divide_decimals_safe with 
                dividend as principal and 
                divisor as decimal_module.from_integer with value as (years times 12) and context as context and 
                context as context
            
            If monthly_payment is ERROR:
                Return monthly_payment
            
            Return SUCCESS with 
                value as monthly_payment.value and 
                metadata as Dictionary with:
                    "principal" as principal
                    "annual_rate" as annual_rate
                    "years" as years
                    "special_case" as "zero_interest"
        
        Note: Calculate monthly interest rate
        Let monthly_rate be divide_decimals_safe with 
            dividend as annual_rate and 
            divisor as decimal_module.from_integer with value as 12 and context as context and 
            context as context
        
        If monthly_rate is ERROR:
            Return monthly_rate
        
        Let total_months be years times 12
        Let one be decimal_module.one with context as context
        Let base be add_decimals_safe with a as one and b as monthly_rate.value and context as context
        
        If base is ERROR:
            Return base
        
        Let exponent be decimal_module.from_integer with value as total_months and context as context
        Let power_factor be power_decimal_safe with base as base.value and exponent as exponent and context as context
        
        If power_factor is ERROR:
            Return power_factor
        
        Note: Calculate payment: P * [r(1+r)^n] / [(1+r)^n - 1]
        Let numerator be multiply_decimals_safe with a as monthly_rate.value and b as power_factor.value and context as context
        
        If numerator is ERROR:
            Return numerator
        
        Let denominator be subtract_decimals_safe with a as power_factor.value and b as one and context as context
        
        If denominator is ERROR:
            Return denominator
        
        Let payment_factor be divide_decimals_safe with dividend as numerator.value and divisor as denominator.value and context as context
        
        If payment_factor is ERROR:
            Return payment_factor
        
        Let monthly_payment be multiply_decimals_safe with a as principal and b as payment_factor.value and context as context
        
        If monthly_payment is ERROR:
            Return monthly_payment
        
        Return SUCCESS with 
            value as monthly_payment.value and 
            metadata as Dictionary with:
                "principal" as principal
                "annual_rate" as annual_rate
                "monthly_rate" as monthly_rate.value
                "years" as years
                "total_months" as total_months
                "payment_factor" as payment_factor.value
    
    Catch error as Exception:
        Return ERROR with message as "Loan payment calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Process called "generate_amortization_schedule" that takes principal as decimal_module.Decimal and annual_rate as decimal_module.Decimal and years as Integer returns LoanCalculation:
    Note: Generate complete loan amortization schedule
    Try:
        Let context be decimal_context.create_financial_context
        
        Let payment_result be calculate_loan_payment with principal as principal and annual_rate as annual_rate and years as years
        
        If payment_result is ERROR:
            Throw FinancialError with message as "Failed to calculate loan payment: " plus payment_result.message
        
        Let monthly_payment be payment_result.value
        Let monthly_rate be divide_decimals_safe with 
            dividend as annual_rate and 
            divisor as decimal_module.from_integer with value as 12 and context as context and 
            context as context
        
        If monthly_rate is ERROR:
            Throw FinancialError with message as "Failed to calculate monthly rate"
        
        Let total_months be years times 12
        Let schedule be empty list
        Let remaining_balance be principal
        Let total_interest_paid be decimal_module.zero with context as context
        
        For each month from 1 to total_months:
            Note: Calculate interest for this month
            Let interest_payment be multiply_decimals_safe with a as remaining_balance and b as monthly_rate.value and context as context
            
            If interest_payment is ERROR:
                Throw FinancialError with message as "Failed to calculate interest payment"
            
            Note: Calculate principal payment
            Let principal_payment be subtract_decimals_safe with a as monthly_payment and b as interest_payment.value and context as context
            
            If principal_payment is ERROR:
                Throw FinancialError with message as "Failed to calculate principal payment"
            
            Note: Update remaining balance
            Let new_balance be subtract_decimals_safe with a as remaining_balance and b as principal_payment.value and context as context
            
            If new_balance is ERROR:
                Throw FinancialError with message as "Failed to calculate new balance"
            
            Note: Add to schedule
            Call schedule.append with item as Dictionary with:
                "month" as month
                "payment" as monthly_payment
                "principal" as principal_payment.value
                "interest" as interest_payment.value
                "balance" as new_balance.value
            
            Set remaining_balance to new_balance.value
            
            Let total_interest_update be add_decimals_safe with a as total_interest_paid and b as interest_payment.value and context as context
            
            If total_interest_update is ERROR:
                Throw FinancialError with message as "Failed to update total interest"
            
            Set total_interest_paid to total_interest_update.value
        
        Let total_payments_result be multiply_decimals_safe with 
            a as monthly_payment and 
            b as decimal_module.from_integer with value as total_months and context as context and 
            context as context
        
        If total_payments_result is ERROR:
            Throw FinancialError with message as "Failed to calculate total payments"
        
        Return LoanCalculation with:
            principal as principal
            interest_rate as annual_rate
            term_years as years
            monthly_payment as monthly_payment
            total_payments as total_payments_result.value
            total_interest as total_interest_paid
            payment_schedule as schedule
            metadata as Dictionary with:
                "schedule_generated" as true
                "total_months" as total_months
                "monthly_rate" as monthly_rate.value
    
    Catch error as Exception:
        Throw FinancialError with message as "Amortization schedule generation failed: " plus error as string

Note: Investment Analysis Calculations

Process called "net_present_value" that takes cash_flows as List[decimal_module.Decimal] and discount_rate as decimal_module.Decimal returns FinancialResult:
    Note: Calculate net present value of cash flow series
    Try:
        Let context be decimal_context.create_financial_context
        
        If cash_flows size is equal to 0:
            Return ERROR with message as "Cash flows list cannot be empty" and error_code as "INVALID_INPUT"
        
        Let npv be decimal_module.zero with context as context
        Let one be decimal_module.one with context as context
        
        For each index and cash_flow in cash_flows:
            Let period be index plus 1
            Let base be add_decimals_safe with a as one and b as discount_rate and context as context
            
            If base is ERROR:
                Return base
            
            Let exponent be decimal_module.from_integer with value as period and context as context
            Let discount_factor be power_decimal_safe with base as base.value and exponent as exponent and context as context
            
            If discount_factor is ERROR:
                Return discount_factor
            
            Let present_value_cf be divide_decimals_safe with dividend as cash_flow and divisor as discount_factor.value and context as context
            
            If present_value_cf is ERROR:
                Return present_value_cf
            
            Let npv_update be add_decimals_safe with a as npv and b as present_value_cf.value and context as context
            
            If npv_update is ERROR:
                Return npv_update
            
            Set npv to npv_update.value
        
        Return SUCCESS with 
            value as npv and 
            metadata as Dictionary with:
                "cash_flow_count" as cash_flows size
                "discount_rate" as discount_rate
                "calculation_type" as "net_present_value"
    
    Catch error as Exception:
        Return ERROR with message as "NPV calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Process called "internal_rate_of_return" that takes cash_flows as List[decimal_module.Decimal] and initial_guess as Optional[decimal_module.Decimal] returns FinancialResult:
    Note: Calculate internal rate of return using Newton-Raphson method
    Try:
        Let context be decimal_context.create_financial_context
        
        If cash_flows size is less than 2:
            Return ERROR with message as "Need at least 2 cash flows for IRR calculation" and error_code as "INSUFFICIENT_DATA"
        
        Let guess be initial_guess or decimal_module.create_decimal with value as "0.1" and context as context
        
        If guess is ERROR:
            Return guess
        
        Let tolerance be decimal_module.create_decimal with value as "0.0001" and context as context
        
        If tolerance is ERROR:
            Return tolerance
        
        Let max_iterations be 1000
        Let current_guess be guess.value
        
        For each iteration from 1 to max_iterations:
            Let npv_result be calculate_npv_at_rate with cash_flows as cash_flows and rate as current_guess and context as context
            
            If npv_result is ERROR:
                Return npv_result
            
            Let npv_derivative be calculate_npv_derivative with cash_flows as cash_flows and rate as current_guess and context as context
            
            If npv_derivative is ERROR:
                Return npv_derivative
            
            Note: Check for convergence
            If decimal_module.is_less_than with a as abs_decimal with decimal as npv_result.value and b as tolerance.value:
                Return SUCCESS with 
                    value as current_guess and 
                    metadata as Dictionary with:
                        "iterations" as iteration
                        "final_npv" as npv_result.value
                        "converged" as true
            
            Note: Newton-Raphson update: x_new = x_old - f(x)/f'(x)
            Let correction be divide_decimals_safe with dividend as npv_result.value and divisor as npv_derivative.value and context as context
            
            If correction is ERROR:
                Return correction
            
            Let new_guess be subtract_decimals_safe with a as current_guess and b as correction.value and context as context
            
            If new_guess is ERROR:
                Return new_guess
            
            Set current_guess to new_guess.value
        
        Return ERROR with message as "IRR calculation did not converge within maximum iterations" and error_code as "NO_CONVERGENCE"
    
    Catch error as Exception:
        Return ERROR with message as "IRR calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Note: Financial Utility Functions

Process called "add_decimals_safe" that takes a as decimal_module.Decimal and b as decimal_module.Decimal and context as decimal_context.DecimalContext returns FinancialResult:
    Note: Safely add two decimals with financial context
    Let result be decimal_module.add with a as a and b as b
    
    If result is decimal_module.ERROR:
        Return ERROR with message as result.message and error_code as result.error_code
    Otherwise:
        Return SUCCESS with value as result.value and metadata as empty dictionary

Process called "subtract_decimals_safe" that takes a as decimal_module.Decimal and b as decimal_module.Decimal and context as decimal_context.DecimalContext returns FinancialResult:
    Note: Safely subtract two decimals with financial context
    Let result be decimal_module.subtract with a as a and b as b
    
    If result is decimal_module.ERROR:
        Return ERROR with message as result.message and error_code as result.error_code
    Otherwise:
        Return SUCCESS with value as result.value and metadata as empty dictionary

Process called "multiply_decimals_safe" that takes a as decimal_module.Decimal and b as decimal_module.Decimal and context as decimal_context.DecimalContext returns FinancialResult:
    Note: Safely multiply two decimals with financial context
    Let result be decimal_module.multiply with a as a and b as b
    
    If result is decimal_module.ERROR:
        Return ERROR with message as result.message and error_code as result.error_code
    Otherwise:
        Return SUCCESS with value as result.value and metadata as empty dictionary

Process called "divide_decimals_safe" that takes dividend as decimal_module.Decimal and divisor as decimal_module.Decimal and context as decimal_context.DecimalContext returns FinancialResult:
    Note: Safely divide two decimals with financial context
    Let result be decimal_module.divide with dividend as dividend and divisor as divisor
    
    If result is decimal_module.ERROR:
        Return ERROR with message as result.message and error_code as result.error_code
    Otherwise:
        Return SUCCESS with value as result.value and metadata as empty dictionary

Process called "power_decimal_safe" that takes base as decimal_module.Decimal and exponent as decimal_module.Decimal and context as decimal_context.DecimalContext returns FinancialResult:
    Note: Safely raise decimal to power with financial context
    Let result be decimal_module.power with base as base and exponent as decimal_module.to_integer with decimal as exponent
    
    If result is decimal_module.ERROR:
        Return ERROR with message as result.message and error_code as result.error_code
    Otherwise:
        Return SUCCESS with value as result.value and metadata as empty dictionary

Process called "abs_decimal" that takes decimal as decimal_module.Decimal returns decimal_module.Decimal:
    Note: Get absolute value of decimal
    If decimal_module.is_negative with decimal as decimal:
        Let zero be decimal_module.zero with context as decimal.context
        Let result be decimal_module.subtract with a as zero and b as decimal
        If result is decimal_module.SUCCESS:
            Return result.value
        Otherwise:
            Return decimal
    Otherwise:
        Return decimal

Process called "calculate_effective_rate" that takes nominal_rate as decimal_module.Decimal and periods as Integer returns decimal_module.Decimal:
    Note: Calculate effective rate from nominal rate (simplified implementation)
    Let context be decimal_context.create_financial_context
    Let result be effective_annual_rate with nominal_rate as nominal_rate and compounding_periods as periods
    
    If result is SUCCESS:
        Return result.value
    Otherwise:
        Return nominal_rate

Process called "calculate_npv_at_rate" that takes cash_flows as List[decimal_module.Decimal] and rate as decimal_module.Decimal and context as decimal_context.DecimalContext returns FinancialResult:
    Note: Calculate NPV at specific discount rate
    Return net_present_value with cash_flows as cash_flows and discount_rate as rate

Process called "calculate_npv_derivative" that takes cash_flows as List[decimal_module.Decimal] and rate as decimal_module.Decimal and context as decimal_context.DecimalContext returns FinancialResult:
    Note: Calculate derivative of NPV function (for Newton-Raphson method)
    Try:
        Let npv_derivative be decimal_module.zero with context as context
        Let one be decimal_module.one with context as context
        
        For each index and cash_flow in cash_flows:
            Let period be index plus 1
            Let base be add_decimals_safe with a as one and b as rate and context as context
            
            If base is ERROR:
                Return base
            
            Let exponent_plus_one be decimal_module.from_integer with value as (period plus 1) and context as context
            Let denominator be power_decimal_safe with base as base.value and exponent as exponent_plus_one and context as context
            
            If denominator is ERROR:
                Return denominator
            
            Let period_decimal be decimal_module.from_integer with value as period and context as context
            Let numerator be multiply_decimals_safe with a as period_decimal and b as cash_flow and context as context
            
            If numerator is ERROR:
                Return numerator
            
            Let term be divide_decimals_safe with dividend as numerator.value and divisor as denominator.value and context as context
            
            If term is ERROR:
                Return term
            
            Let derivative_update be subtract_decimals_safe with a as npv_derivative and b as term.value and context as context
            
            If derivative_update is ERROR:
                Return derivative_update
            
            Set npv_derivative to derivative_update.value
        
        Return SUCCESS with value as npv_derivative and metadata as empty dictionary
    
    Catch error as Exception:
        Return ERROR with message as "NPV derivative calculation failed: " plus error as string and error_code as "CALCULATION_ERROR"

Note: Financial Analysis Functions

Process called "analyze_investment" that takes initial_investment as decimal_module.Decimal and cash_flows as List[decimal_module.Decimal] and discount_rate as decimal_module.Decimal returns InvestmentAnalysis:
    Note: Comprehensive investment analysis with multiple metrics
    Try:
        Let context be decimal_context.create_financial_context
        
        Note: Calculate NPV
        Let all_cash_flows be empty list
        Call all_cash_flows.append with item as decimal_module.subtract with a as decimal_module.zero with context as context and b as initial_investment
        
        For each cf in cash_flows:
            Call all_cash_flows.append with item as cf
        
        Let npv_result be net_present_value with cash_flows as all_cash_flows and discount_rate as discount_rate
        Let npv_value be decimal_module.zero with context as context
        
        If npv_result is SUCCESS:
            Set npv_value to npv_result.value
        
        Note: Calculate IRR
        Let irr_result be internal_rate_of_return with cash_flows as all_cash_flows and initial_guess as none
        Let irr_value be none
        
        If irr_result is SUCCESS:
            Set irr_value to irr_result.value
        
        Note: Calculate Profitability Index
        Let positive_cash_flows be empty list
        For each cf in cash_flows:
            Call positive_cash_flows.append with item as cf
        
        Let pv_inflows_result be net_present_value with cash_flows as positive_cash_flows and discount_rate as discount_rate
        Let pi_value be decimal_module.one with context as context
        
        If pv_inflows_result is SUCCESS:
            Let pi_result be divide_decimals_safe with dividend as pv_inflows_result.value and divisor as initial_investment and context as context
            If pi_result is SUCCESS:
                Set pi_value to pi_result.value
        
        Note: Calculate Payback Period (simplified)
        Let payback_period be calculate_payback_period with initial_investment as initial_investment and cash_flows as cash_flows
        
        Return InvestmentAnalysis with:
            initial_investment as initial_investment
            cash_flows as cash_flows
            discount_rate as discount_rate
            net_present_value as npv_value
            internal_rate_of_return as irr_value
            payback_period as payback_period
            profitability_index as pi_value
            metadata as Dictionary with:
                "analysis_complete" as true
                "cash_flow_count" as cash_flows size
    
    Catch error as Exception:
        Throw FinancialError with message as "Investment analysis failed: " plus error as string

Process called "calculate_payback_period" that takes initial_investment as decimal_module.Decimal and cash_flows as List[decimal_module.Decimal] returns Optional[decimal_module.Decimal]:
    Note: Calculate simple payback period
    Try:
        Let context be decimal_context.create_financial_context
        Let cumulative_cf be decimal_module.zero with context as context
        
        For each index and cash_flow in cash_flows:
            Let cf_update be add_decimals_safe with a as cumulative_cf and b as cash_flow and context as context
            
            If cf_update is ERROR:
                Return decimal_module.from_integer with value as 999 and context as context
            
            Set cumulative_cf to cf_update.value
            
            If decimal_module.is_greater_than_or_equal with a as cumulative_cf and b as initial_investment:
                Return decimal_module.from_integer with value as (index plus 1) and context as context
        
        Note: If investment never pays back, return a large number indicating no payback
        Return decimal_module.from_integer with value as 999 and context as context
    
    Catch error as Exception:
        Let context be decimal_context.create_financial_context
        Return decimal_module.from_integer with value as 999 and context as context

Note: Currency and Money Operations

Process called "format_currency" that takes amount as decimal_module.Decimal and currency_symbol as Optional[String] and decimal_places as Optional[Integer] returns String:
    Note: Format decimal amount as currency
    Try:
        Let symbol be currency_symbol or "$"
        Let places be decimal_places or 2
        
        Let rounded_result be decimal_module.round_to_places with decimal as amount and places as places
        
        If rounded_result is decimal_module.ERROR:
            Return symbol plus "0.00"
        
        Let amount_str be decimal_module.to_string with decimal as rounded_result.value
        
        Return symbol plus amount_str
    
    Catch error as Exception:
        Return "$0.00"

Process called "parse_currency" that takes currency_string as String returns Optional[decimal_module.Decimal]:
    Note: Parse currency string to decimal
    Try:
        Let context be decimal_context.create_financial_context
        
        Note: Remove common currency symbols and formatting
        Let cleaned_string be currency_string
        Set cleaned_string to replace_string with string as cleaned_string and search as "$" and replace as ""
        Set cleaned_string to replace_string with string as cleaned_string and search as "," and replace as ""
        Set cleaned_string to trim_string with string as cleaned_string
        
        Let result be decimal_module.create_decimal with value as cleaned_string and context as context
        
        If result is decimal_module.SUCCESS:
            Return result.value
        Otherwise:
            Return decimal_module.zero with context as context
    
    Catch error as Exception:
        Let context be decimal_context.create_financial_context
        Return decimal_module.zero with context as context

