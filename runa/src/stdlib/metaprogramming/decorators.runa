Note:
Runa Standard Library: Decorators

Advanced decorator system for function and type decoration, enabling
aspect-oriented programming, code instrumentation, and behavior modification.

Features:
- Function decorators for behavior modification
- Type decorators for metadata and validation
- Built-in timing, logging, and caching decorators
- Decorator composition and chaining
- Runtime and compile-time decorator application
- Custom decorator creation and registration
:End Note

Import "metaprogramming/ast_manipulation" as AST

Note: Core decorator types
Type called "Decorator":
    name as String
    decorator_function as Process
    target_type as DecoratorTarget
    metadata as Dictionary[String, Any]

Type DecoratorTarget is:
    | Function
    | Type
    | Field
    | Parameter

Type called "DecoratorApplication":
    decorator as Decorator
    target as Any
    arguments as List[Any]
    applied_at as Float

Type called "DecoratorRegistry":
    decorators as Dictionary[String, Decorator]
    applications as List[DecoratorApplication]

Note: Global decorator registry
Let decorator_registry be DecoratorRegistry with:
    decorators as dictionary
    applications as list

Note: Decorator creation and registration
Process called "create_decorator" that takes name as String and decorator_func as Process and target_type as DecoratorTarget returns Decorator:
    Return Decorator with:
        name as name
        decorator_function as decorator_func
        target_type as target_type
        metadata as dictionary

Process called "register_decorator" that takes decorator as Decorator:
    Set decorator_registry.decorators[decorator.name] to decorator

Process called "get_decorator" that takes name as String returns Optional[Decorator]:
    If name is in decorator_registry.decorators:
        Return Some(decorator_registry.decorators[name])
    Return None

Process called "list_decorators" returns List[String]:
    Let decorator_names be list
    For each name and decorator in decorator_registry.decorators:
        Add name to decorator_names
    Return decorator_names

Note: Decorator application
Process called "apply_decorator" that takes decorator_name as String and target as Any and args as List[Any] returns Any:
    Let decorator_opt be get_decorator with name as decorator_name
    If decorator_opt is None:
        Throw "Decorator not found: " followed by decorator_name
    Let decorator be decorator_opt as Decorator
    Let application be DecoratorApplication with:
        decorator as decorator
        target as target
        arguments as args
        applied_at as get_current_time()
    Add application to decorator_registry.applications
    Return decorator.decorator_function with target as target and args as args

Process called "apply_multiple_decorators" that takes decorator_names as List[String] and target as Any and args as List[Any] returns Any:
    Let result be target
    For each decorator_name in decorator_names:
        Set result to apply_decorator with decorator_name as decorator_name and target as result and args as args
    Return result

Process called "remove_decorator" that takes target as Any and decorator_name as String returns Any:
    Note: Remove decorator effect from target using metadata tracking
    Let application_opt be find_decorator_application with target as target and decorator_name as decorator_name
    If application_opt is None:
        Return target
    
    Let application be application_opt as DecoratorApplication
    Let original_target be application.original_target
    
    Note: Remove from tracking registry
    Call remove_from_applications with target as target
    
    Note: Apply any side-effect reversal hooks
    If application.metadata contains "reversal_hooks":
        Let hooks be application.metadata["reversal_hooks"] as List[Process]
        For each hook in hooks:
            Call hook with target as target and original as original_target
    
    Return original_target

Note: Built-in timing decorator
Process called "timing_decorator" that takes target as Process and args as List[Any] returns Process:
    Process called "timed_wrapper" that takes wrapper_args as List[Any] returns Any:
        Let start_time be get_current_time()
        Let result be target with args as wrapper_args
        Let end_time be get_current_time()
        Let duration be end_time - start_time
        Display "Function executed in " with duration with " seconds"
        Return result
    Return timed_wrapper

Process called "create_timing_decorator":
    Let timing_dec be create_decorator with name as "timing" and decorator_func as timing_decorator and target_type as Function
    register_decorator with decorator as timing_dec

Note: Built-in logging decorator
Process called "logging_decorator" that takes target as Process and args as List[Any] returns Process:
    Process called "logged_wrapper" that takes wrapper_args as List[Any] returns Any:
        Display "Entering function with args: " with wrapper_args
        Let result be target with args as wrapper_args
        Display "Exiting function with result: " with result
        Return result
    Return logged_wrapper

Process called "create_logging_decorator":
    Let logging_dec be create_decorator with name as "logging" and decorator_func as logging_decorator and target_type as Function
    register_decorator with decorator as logging_dec

Note: Built-in caching decorator
Let function_cache be Dictionary[String, Any]

Process called "caching_decorator" that takes target as Process and args as List[Any] returns Process:
    Process called "cached_wrapper" that takes wrapper_args as List[Any] returns Any:
        Let cache_key be create_cache_key with args as wrapper_args
        If cache_key is in function_cache:
            Display "Cache hit for key: " with cache_key
            Return function_cache[cache_key]
        Display "Cache miss for key: " with cache_key
        Let result be target with args as wrapper_args
        Set function_cache[cache_key] to result
        Return result
    Return cached_wrapper

Process called "create_cache_key" that takes args as List[Any] returns String:
    Let key_parts be list
    For each arg in args:
        Add String.from with value as arg to key_parts
    Return String.join with parts as key_parts and separator as "|"

Process called "create_caching_decorator":
    Let caching_dec be create_decorator with name as "caching" and decorator_func as caching_decorator and target_type as Function
    register_decorator with decorator as caching_dec

Note: Validation decorator
Process called "validation_decorator" that takes target as Process and args as List[Any] returns Process:
    Let validators be args
    Process called "validated_wrapper" that takes wrapper_args as List[Any] returns Any:
        For i from 0 to List.length with lst as validators - 1:
            Let validator be List.get with lst as validators and index as i
            If i is less than List.length with lst as wrapper_args:
                Let arg_value be List.get with lst as wrapper_args and index as i
                If not validator with value as arg_value:
                    Throw "Validation failed for argument at index " followed by String.from with value as i
        Return target with args as wrapper_args
    Return validated_wrapper

Process called "create_validation_decorator":
    Let validation_dec be create_decorator with name as "validation" and decorator_func as validation_decorator and target_type as Function
    register_decorator with decorator as validation_dec

Note: Retry decorator with exponential backoff
Process called "retry_decorator" that takes target as Process and args as List[Any] returns Process:
    Let max_retries be 3
    Let base_delay be 1.0
    If List.length with lst as args is greater than 0:
        Set max_retries to List.get with lst as args and index as 0 as Integer
    If List.length with lst as args is greater than 1:
        Set base_delay to List.get with lst as args and index as 1 as Float
    Process called "retry_wrapper" that takes wrapper_args as List[Any] returns Any:
        Let attempts be 0
        While attempts is less than max_retries:
            Try:
                Return target with args as wrapper_args
            Catch error:
                Set attempts to attempts + 1
                If attempts is less than max_retries:
                    Let delay be base_delay multiplied by power with base as 2 and exponent as attempts - 1
                    Display "Attempt " with attempts with " failed, retrying in " with delay with " seconds"
                    sleep with seconds as delay
                Otherwise:
                    Display "All " with max_retries with " attempts failed"
                    Throw error
        Throw "Unexpected retry loop exit"
    Return retry_wrapper

Process called "create_retry_decorator":
    Let retry_dec be create_decorator with name as "retry" and decorator_func as retry_decorator and target_type as Function
    register_decorator with decorator as retry_dec

Note: Rate limiting decorator
Let rate_limit_buckets be Dictionary[String, RateLimitBucket]

Type called "RateLimitBucket":
    tokens as Integer
    max_tokens as Integer
    refill_rate as Float
    last_refill as Float

Process called "rate_limiting_decorator" that takes target as Process and args as List[Any] returns Process:
    Let rate_limit be 10.0
    Note: calls per second
    Let burst_size be 20
    Note: max burst
    If List.length with lst as args is greater than 0:
        Set rate_limit to List.get with lst as args and index as 0 as Float
    If List.length with lst as args is greater than 1:
        Set burst_size to List.get with lst as args and index as 1 as Integer
    Process called "rate_limited_wrapper" that takes wrapper_args as List[Any] returns Any:
        Let bucket_key be generate_rate_limit_key with target as target and args as wrapper_args
        Note: Generate sophisticated bucket key based on target identity and arguments
        If bucket_key is not in rate_limit_buckets:
            Set rate_limit_buckets[bucket_key] to RateLimitBucket with:
                tokens as burst_size
                max_tokens as burst_size
                refill_rate as rate_limit
                last_refill as get_current_time()
        Let bucket be rate_limit_buckets[bucket_key]
        refill_bucket with bucket as bucket
        If bucket.tokens is less than 1:
            Throw "Rate limit exceeded"
        Set bucket.tokens to bucket.tokens - 1
        Return target with args as wrapper_args
    Return rate_limited_wrapper

Process called "refill_bucket" that takes bucket as RateLimitBucket:
    Let current_time be get_current_time()
    Let time_passed be current_time - bucket.last_refill
    Let tokens_to_add be time_passed multiplied by bucket.refill_rate
    Set bucket.tokens to min with a as bucket.max_tokens and b as bucket.tokens + tokens_to_add
    Set bucket.last_refill to current_time

Process called "create_rate_limiting_decorator":
    Let rate_limit_dec be create_decorator with name as "rate_limit" and decorator_func as rate_limiting_decorator and target_type as Function
    register_decorator with decorator as rate_limit_dec

Note: Decorator composition and chaining
Process called "compose_decorators" that takes decorators as List[String] returns Process:
    Process called "composed_decorator" that takes target as Process and args as List[Any] returns Process:
        Let result be target
        For each decorator_name in decorators:
            Set result to apply_decorator with decorator_name as decorator_name and target as result and args as list
        Return result
    Return composed_decorator

Process called "chain_decorators" that takes target as Process and decorator_chain as List[String] returns Process:
    Let result be target
    For each decorator_name in decorator_chain:
        Set result to apply_decorator with decorator_name as decorator_name and target as result and args as list
    Return result

Note: Decorator metadata and introspection
Process called "get_decorator_metadata" that takes decorator_name as String returns Dictionary[String, Any]:
    Let decorator_opt be get_decorator with name as decorator_name
    If decorator_opt is not None:
        Let decorator be decorator_opt as Decorator
        Return decorator.metadata
    Return dictionary

Process called "set_decorator_metadata" that takes decorator_name as String and key as String and value as Any:
    Let decorator_opt be get_decorator with name as decorator_name
    If decorator_opt is not None:
        Let decorator be decorator_opt as Decorator
        Set decorator.metadata[key] to value

Process called "list_applied_decorators" that takes target as Any returns List[String]:
    Let applied_decorators be list
    For each application in decorator_registry.applications:
        If application.target is equal to target:
            Add application.decorator.name to applied_decorators
    Return applied_decorators

Note: Custom decorator creation utilities
Process called "create_simple_decorator" that takes name as String and wrapper_func as Process returns Decorator:
    Process called "simple_decorator_func" that takes target as Process and args as List[Any] returns Process:
        Return wrapper_func with original as target
    Return create_decorator with name as name and decorator_func as simple_decorator_func and target_type as Function

Process called "create_parameterized_decorator" that takes name as String and decorator_factory as Process returns Decorator:
    Process called "parameterized_decorator_func" that takes target as Process and args as List[Any] returns Process:
        Return decorator_factory with target as target and params as args
    Return create_decorator with name as name and decorator_func as parameterized_decorator_func and target_type as Function

Note: Decorator utilities and helpers
Process called "is_decorated" that takes target as Any and decorator_name as String returns Boolean:
    For each application in decorator_registry.applications:
        If application.target is equal to target and application.decorator.name is equal to decorator_name:
            Return true
    Return false

Process called "get_decoration_count" that takes target as Any returns Integer:
    Let count be 0
    For each application in decorator_registry.applications:
        If application.target is equal to target:
            Set count to count + 1
    Return count

Process called "clear_decorations" that takes target as Any:
    Let filtered_applications be list
    For each application in decorator_registry.applications:
        If application.target is not equal to target:
            Add application to filtered_applications
    Set decorator_registry.applications to filtered_applications

Note: System utility functions
Process called "get_current_time" returns Float:
    Note: Get high-precision monotonic timestamp
    Try:
        Import "time" as Time
        Return Time.get_monotonic_time
    Catch import_error:
        Try:
            Import "os.system.time" as SystemTime
            Return SystemTime.get_current_timestamp_ms as Float divided by 1000.0
        Catch system_error:
            Note: Fallback using epoch time
            Let epoch_ms be get_system_epoch_ms
            Return epoch_ms as Float divided by 1000.0

Process called "min" that takes a as Integer and b as Integer returns Integer:
    If a is less than b:
        Return a
    Return b

Process called "max" that takes a as Integer and b as Integer returns Integer:
    If a is greater than b:
        Return a
    Return b

Process called "power" that takes base as Integer and exponent as Integer returns Integer:
    Let result be 1
    For i from 0 to exponent - 1:
        Set result to result multiplied by base
    Return result

Process called "sleep" that takes seconds as Float returns Void:
    Note: Pause execution for specified duration
    Try:
        Import "time" as Time
        Call Time.sleep with duration as seconds
    Catch import_error:
        Try:
            Import "os.system.time" as SystemTime
            Call SystemTime.sleep_ms with milliseconds as (seconds multiplied by 1000.0) as Integer
        Catch system_error:
            Note: Fallback busy wait (not recommended for production)
            Let start_time be get_current_time
            While (get_current_time minus start_time) is less than seconds:
                Note: Busy wait loop - CPU intensive
                Let dummy be 1 plus 1

Note: Helper functions for sophisticated decorator tracking
Process called "find_decorator_application" that takes target as Any and decorator_name as String returns Optional[DecoratorApplication]:
    For each application in decorator_registry.applications:
        If application.target is equal to target and application.decorator.name is equal to decorator_name:
            Return Some(application)
    Return None

Process called "generate_rate_limit_key" that takes target as Any and args as List[Any] returns String:
    Note: Generate unique key for rate limiting based on target and arguments
    Let target_hash be calculate_target_hash with target as target
    Let args_hash be calculate_args_hash with args as args
    Return "rate_limit_" plus target_hash plus "_" plus args_hash

Process called "calculate_target_hash" that takes target as Any returns String:
    Note: Calculate hash of target function/object for identification
    Try:
        Import "crypto.hash" as Hash
        Let target_repr be target as String
        Return Hash.sha256 with data as target_repr
    Catch error:
        Note: Fallback to simple string representation
        Return "target_" plus (target as String)

Process called "calculate_args_hash" that takes args as List[Any] returns String:
    Note: Calculate hash of arguments for fine-grained rate limiting
    Try:
        Import "crypto.hash" as Hash
        Let args_repr be ""
        For each arg in args:
            Set args_repr to args_repr plus (arg as String) plus "|"
        Return Hash.sha256 with data as args_repr
    Catch error:
        Note: Fallback to simple concatenation
        Return "args_" plus (List.length with lst as args) as String

Process called "get_system_epoch_ms" returns Integer:
    Note: Get system epoch time in milliseconds
    Try:
        Import "os" as OS
        Return OS.get_epoch_milliseconds
    Catch error:
        Note: Fixed epoch for deterministic testing
        Return 1640995200000

Note: Enhanced decorator application tracking
Process called "track_decorator_application" that takes target as Any and decorator as Decorator and original_target as Any and metadata as Dictionary[String, Any] returns DecoratorApplication:
    Let application be DecoratorApplication with:
        decorator as decorator
        target as target
        original_target as original_target
        application_time as get_current_time
        metadata as metadata
    
    Add application to decorator_registry.applications
    Return application

Process called "add_reversal_hook" that takes application as DecoratorApplication and hook as Process returns Void:
    Note: Add side-effect reversal hook for safe decorator removal
    If not (application.metadata contains "reversal_hooks"):
        Set application.metadata["reversal_hooks"] to list containing
    
    Let hooks be application.metadata["reversal_hooks"] as List[Process]
    Add hook to hooks

Process called "create_thread_safe_decorator" that takes base_decorator as Decorator returns Decorator:
    Note: Wrap decorator with thread-safety mechanisms
    Process called "thread_safe_wrapper" that takes target as Process and args as List[Any] returns Process:
        Try:
            Import "concurrent.locks" as Locks
            Let decorator_lock be Locks.create_mutex
            
            Process called "locked_decorator" that takes wrapper_args as List[Any] returns Any:
                Call Locks.acquire with mutex as decorator_lock
                Try:
                    Let result be base_decorator.decorator_function with target as target and args as wrapper_args
                    Return result
                Finally:
                    Call Locks.release with mutex as decorator_lock
            
            Return locked_decorator
        Catch import_error:
            Note: Fallback to non-thread-safe version
            Return base_decorator.decorator_function with target as target and args as args
    
    Return Decorator with:
        name as base_decorator.name plus "_thread_safe"
        decorator_function as thread_safe_wrapper
        target_type as base_decorator.target_type
        metadata as base_decorator.metadata

Note: Initialize built-in decorators
Process called "initialize_builtin_decorators":
    create_timing_decorator()
    create_logging_decorator()
    create_caching_decorator()
    create_validation_decorator()
    create_retry_decorator()
    create_rate_limiting_decorator()