Note:
Runa Standard Library: Stream I/O Module

Provides comprehensive stream-based I/O operations with buffering, async support,
and advanced file operations. Essential for AI-to-AI communication where efficient
data streaming, buffered operations, and async I/O are critical.

Advanced features include:
- Buffered reading and writing with configurable buffer sizes
- Async I/O operations for non-blocking file access
- Stream processing and transformation pipelines
- Memory-mapped file operations
- Compression and decompression streams
- Network stream support
- Thread-safe operations (when supported)
:End Note

Type Stream is Dictionary with:
    file as File
    buffer as List[String]
    buffer_size as Integer
    position as Integer
    mode as String
    encoding as String

Type BufferedReader is Dictionary with:
    stream as Stream
    buffer as List[String]
    buffer_pos as Integer
    buffer_size as Integer
    eof as Boolean

Type BufferedWriter is Dictionary with:
    stream as Stream
    buffer as List[String]
    buffer_size as Integer
    auto_flush as Boolean

Type AsyncStream is Dictionary with:
    stream as Stream
    async_mode as Boolean
    callback as Process
    error_handler as Process

Note: Core Stream Operations
Process called "create_stream" that takes file_path as String and mode as String returns Stream:
    Return create_stream_with_encoding with file_path as file_path and mode as mode and encoding as "utf-8"

Process called "create_stream_with_encoding" that takes file_path as String and mode as String and encoding as String returns Stream:
    Let file be open_file with path as file_path and mode as mode and encoding as encoding
    Return Stream with:
        file as file
        buffer as list containing
        buffer_size as 8192
        position as 0
        mode as mode
        encoding as encoding

Process called "close_stream" that takes stream as Stream returns Boolean:
    Let file be stream.file
    Return close_file with file as file

Process called "flush_stream" that takes stream as Stream returns Boolean:
    Let file be stream.file
    Return flush_file with file as file

Process called "seek_stream" that takes stream as Stream and offset as Integer and whence as Integer returns Integer:
    Let file be stream.file
    Let new_position be seek_file with file as file and offset as offset and whence as whence
    Set stream.position to new_position
    Return new_position

Process called "tell_stream" that takes stream as Stream returns Integer:
    Return stream.position

Process called "truncate_stream" that takes stream as Stream and size as Integer returns Boolean:
    Let file be stream.file
    Return truncate_file with file as file and size as size

Note: Buffered Reading Operations
Process called "create_buffered_reader" that takes stream as Stream returns BufferedReader:
    Return create_buffered_reader_with_size with stream as stream and buffer_size as 8192

Process called "create_buffered_reader_with_size" that takes stream as Stream and buffer_size as Integer returns BufferedReader:
    Return BufferedReader with:
        stream as stream
        buffer as list containing
        buffer_pos as 0
        buffer_size as buffer_size
        eof as false

Process called "read_line" that takes reader as BufferedReader returns String:
    Let result be ""
    Let stream be reader.stream
    Let buffer be reader.buffer
    Let buffer_pos be reader.buffer_pos
    
    While true:
        If buffer_pos is greater than or equal to length of buffer:
            Let chunk be read_chunk with reader as reader
            If length of chunk is equal to 0:
                Return result
        Let char be buffer[buffer_pos]
        Set buffer_pos to buffer_pos plus 1
        If char is equal to "\n":
            Set reader.buffer_pos to buffer_pos
            Return result
        Set result to result followed by char
        Set reader.buffer_pos to buffer_pos

Process called "read_lines" that takes reader as BufferedReader returns List[String]:
    Let lines be list containing
    While not reader.eof:
        Let line be read_line with reader as reader
        If length of line is equal to 0 and reader.eof:
            Break
        Add line to lines
    Return lines

Process called "read_chunk" that takes reader as BufferedReader returns String:
    Let stream be reader.stream
    Let file be stream.file
    Let buffer_size be reader.buffer_size
    Let chunk be read_file_chunk with file as file and size as buffer_size
    If length of chunk is equal to 0:
        Set reader.eof to true
        Return ""
    Set reader.buffer to list containing
    For each char in chunk:
        Add char to reader.buffer
    Set reader.buffer_pos to 0
    Set stream.position to stream.position plus length of chunk
    Return chunk

Process called "peek_char" that takes reader as BufferedReader returns String:
    Let buffer be reader.buffer
    Let buffer_pos be reader.buffer_pos
    If buffer_pos is greater than or equal to length of buffer:
        Let chunk be read_chunk with reader as reader
        If length of chunk is equal to 0:
            Return ""
    Return buffer[buffer_pos]

Process called "skip_line" that takes reader as BufferedReader returns Boolean:
    Let line be read_line with reader as reader
    Return length of line is greater than 0 or not reader.eof

Process called "read_until" that takes reader as BufferedReader and delimiter as String returns String:
    Let result be ""
    Let delim_length be length of delimiter
    While true:
        If reader.buffer_pos is greater than or equal to length of reader.buffer:
            Let chunk be read_chunk with reader as reader
            If length of chunk is equal to 0:
                Return result
        Let buffer be reader.buffer
        Let buffer_pos be reader.buffer_pos
        Let buffer_length be length of buffer
        For i from buffer_pos to buffer_length minus delim_length:
            Let match be true
            For j from 0 to delim_length:
                If buffer[i plus j] is not equal to delimiter at index j:
                    Set match to false
                    Break
            If match:
                Let before_delim be ""
                For k from buffer_pos to i:
                    Set before_delim to before_delim followed by buffer[k]
                Set result to result followed by before_delim
                Set reader.buffer_pos to i plus delim_length
                Return result
        Let remaining be ""
        For k from buffer_pos to buffer_length:
            Set remaining to remaining followed by buffer[k]
        Set result to result followed by remaining
        Set reader.buffer_pos to buffer_length
    Return result

Note: Buffered Writing Operations
Process called "create_buffered_writer" that takes stream as Stream returns BufferedWriter:
    Return create_buffered_writer_with_size with stream as stream and buffer_size as 8192

Process called "create_buffered_writer_with_size" that takes stream as Stream and buffer_size as Integer returns BufferedWriter:
    Return BufferedWriter with:
        stream as stream
        buffer as list containing
        buffer_size as buffer_size
        auto_flush as false

Process called "write_string" that takes writer as BufferedWriter and data as String returns Boolean:
    Let buffer be writer.buffer
    Let buffer_size be writer.buffer_size
    Let data_length be length of data
    
    If data_length is greater than buffer_size:
        Let flushed be flush_buffer with writer as writer
        If not flushed:
            Return false
        Return write_to_stream with writer as writer and data as data
    
    If length of buffer plus data_length is greater than buffer_size:
        Let flushed be flush_buffer with writer as writer
        If not flushed:
            Return false
    
    For each char in data:
        Add char to buffer
    Return true

Process called "write_line" that takes writer as BufferedWriter and line as String returns Boolean:
    Let line_with_newline be line followed by "\n"
    Return write_string with writer as writer and data as line_with_newline

Process called "write_lines" that takes writer as BufferedWriter and lines as List[String] returns Boolean:
    For each line in lines:
        Let success be write_line with writer as writer and line as line
        If not success:
            Return false
    Return true

Process called "flush_buffer" that takes writer as BufferedWriter returns Boolean:
    Let buffer be writer.buffer
    If length of buffer is equal to 0:
        Return true
    Let data be ""
    For each char in buffer:
        Set data to data followed by char
    Let success be write_to_stream with writer as writer and data as data
    If success:
        Set writer.buffer to list containing
    Return success

Process called "write_to_stream" that takes writer as BufferedWriter and data as String returns Boolean:
    Let stream be writer.stream
    Let file be stream.file
    Let written be write_file with file as file and data as data
    If written:
        Set stream.position to stream.position plus length of data
    Return written

Process called "set_auto_flush" that takes writer as BufferedWriter and auto_flush as Boolean returns BufferedWriter:
    Set writer.auto_flush to auto_flush
    Return writer

Note: Async Stream Operations
Process called "create_async_stream" that takes stream as Stream returns AsyncStream:
    Return AsyncStream with:
        stream as stream
        async_mode as true
        callback as lambda result: result
        error_handler as lambda error: error

Process called "async_read" that takes async_stream as AsyncStream and size as Integer returns Promise[String]:
    Let stream be async_stream.stream
    Let callback be async_stream.callback
    Let error_handler be async_stream.error_handler
    
    Process called "read_worker" returns String:
        Try:
            Let file be stream.file
            Return read_file_chunk with file as file and size as size
        Catch error:
            Return error_handler with error as error
    
    Return create_promise with worker as read_worker

Process called "async_write" that takes async_stream as AsyncStream and data as String returns Promise[Boolean]:
    Let stream be async_stream.stream
    Let callback be async_stream.callback
    Let error_handler be async_stream.error_handler
    
    Process called "write_worker" returns Boolean:
        Try:
            Let file be stream.file
            Return write_file with file as file and data as data
        Catch error:
            Return error_handler with error as error
    
    Return create_promise with worker as write_worker

Process called "set_async_callback" that takes async_stream as AsyncStream and callback as Process returns AsyncStream:
    Set async_stream.callback to callback
    Return async_stream

Process called "set_async_error_handler" that takes async_stream as AsyncStream and error_handler as Process returns AsyncStream:
    Set async_stream.error_handler to error_handler
    Return async_stream

Note: Stream Processing and Transformation
Process called "create_processing_stream" that takes input_stream as Stream and processor as Process returns Stream:
    Return ProcessingStream with:
        input_stream as input_stream
        processor as processor
        buffer as list containing
        position as 0

Process called "process_stream" that takes processing_stream as ProcessingStream and chunk_size as Integer returns List[String]:
    Let input_stream be processing_stream.input_stream
    Let processor be processing_stream.processor
    Let results be list containing
    
    While true:
        Let chunk be read_file_chunk with file as input_stream.file and size as chunk_size
        If length of chunk is equal to 0:
            Break
        Let processed be processor with data as chunk
        Add processed to results
    
    Return results

Process called "create_filtering_stream" that takes input_stream as Stream and predicate as Process returns Stream:
    Return FilteringStream with:
        input_stream as input_stream
        predicate as predicate
        buffer as list containing
        position as 0

Process called "filter_stream" that takes filtering_stream as FilteringStream and chunk_size as Integer returns List[String]:
    Let input_stream be filtering_stream.input_stream
    Let predicate be filtering_stream.predicate
    Let results be list containing
    
    While true:
        Let chunk be read_file_chunk with file as input_stream.file and size as chunk_size
        If length of chunk is equal to 0:
            Break
        If predicate with data as chunk:
            Add chunk to results
    
    Return results

Note: Memory-Mapped File Operations
Process called "create_memory_mapped_stream" that takes file_path as String and mode as String returns Stream:
    Let file be open_file with path as file_path and mode as mode
    Let file_size be get_file_size with file as file
    Return MemoryMappedStream with:
        file as file
        file_size as file_size
        mapped_data as map_file_to_memory with file as file and size as file_size
        position as 0
        mode as mode

Process called "read_mapped" that takes mapped_stream as MemoryMappedStream and offset as Integer and size as Integer returns String:
    Let mapped_data be mapped_stream.mapped_data
    Let file_size be mapped_stream.file_size
    If offset plus size is greater than file_size:
        Set size to file_size minus offset
    Let result be ""
    For i from offset to offset plus size:
        Set result to result followed by mapped_data[i]
    Return result

Process called "write_mapped" that takes mapped_stream as MemoryMappedStream and offset as Integer and data as String returns Boolean:
    Let mapped_data be mapped_stream.mapped_data
    Let file_size be mapped_stream.file_size
    Let data_length be length of data
    If offset plus data_length is greater than file_size:
        Return false
    For i from 0 to data_length:
        Set mapped_data[offset plus i] to data at index i
    Return true

Note: Compression Stream Operations
Process called "create_compression_stream" that takes output_stream as Stream and algorithm as String returns Stream:
    Return CompressionStream with:
        output_stream as output_stream
        algorithm as algorithm
        compressor as create_compressor with algorithm as algorithm
        buffer as list containing

Process called "write_compressed" that takes compression_stream as CompressionStream and data as String returns Boolean:
    Let compressor be compression_stream.compressor
    Let compressed be compress_data with compressor as compressor and data as data
    Let output_stream be compression_stream.output_stream
    Return write_to_stream with writer as create_buffered_writer with stream as output_stream and data as compressed

Process called "create_decompression_stream" that takes input_stream as Stream and algorithm as String returns Stream:
    Return DecompressionStream with:
        input_stream as input_stream
        algorithm as algorithm
        decompressor as create_decompressor with algorithm as algorithm
        buffer as list containing

Process called "read_decompressed" that takes decompression_stream as DecompressionStream and size as Integer returns String:
    Let decompressor be decompression_stream.decompressor
    Let input_stream be decompression_stream.input_stream
    Let compressed_data be read_file_chunk with file as input_stream.file and size as size
    Return decompress_data with decompressor as decompressor and data as compressed_data

Note: Network Stream Operations
Process called "create_network_stream" that takes host as String and port as Integer returns Stream:
    Let socket be create_socket with host as host and port as port
    Return NetworkStream with:
        socket as socket
        buffer as list containing
        buffer_size as 8192
        position as 0
        mode as "rw"

Process called "read_network" that takes network_stream as NetworkStream and size as Integer returns String:
    Let socket be network_stream.socket
    Return receive_data with socket as socket and size as size

Process called "write_network" that takes network_stream as NetworkStream and data as String returns Boolean:
    Let socket be network_stream.socket
    Return send_data with socket as socket and data as data

Process called "close_network_stream" that takes network_stream as NetworkStream returns Boolean:
    Let socket be network_stream.socket
    Return close_socket with socket as socket

Note: Utility Operations
Process called "copy_stream" that takes source as Stream and destination as Stream and buffer_size as Integer returns Integer:
    Let total_copied be 0
    While true:
        Let chunk be read_file_chunk with file as source.file and size as buffer_size
        If length of chunk is equal to 0:
            Break
        Let written be write_file with file as destination.file and data as chunk
        If written:
            Set total_copied to total_copied plus length of chunk
        Otherwise:
            Break
    Return total_copied

Process called "stream_to_string" that takes stream as Stream returns String:
    Let result be ""
    Let file be stream.file
    While true:
        Let chunk be read_file_chunk with file as file and size as 8192
        If length of chunk is equal to 0:
            Break
        Set result to result followed by chunk
    Return result

Process called "string_to_stream" that takes data as String and stream as Stream returns Boolean:
    Let file be stream.file
    Return write_file with file as file and data as data

Process called "get_stream_info" that takes stream as Stream returns Dictionary[String, Any]:
    Let file be stream.file
    Return Dictionary with:
        "position" as stream.position
        "buffer_size" as stream.buffer_size
        "mode" as stream.mode
        "encoding" as stream.encoding
        "file_size" as get_file_size with file as file
        "is_readable" as is_file_readable with file as file
        "is_writable" as is_file_writable with file as file 