Process called "create_directory_recursive" that takes path as String returns Boolean:
    Note: Create directory and all parent directories
    Try:
        Let exists_check be directory_exists_internal with path as path
        If exists_check:
            Return true
        
        Let parent_dir be get_parent_directory with path as path
        If parent_dir is not equal to "." and parent_dir is not equal to path:
            Let parent_created be create_directory_recursive with path as parent_dir
            If not parent_created:
                Return false
        
        Let create_result be create_directory_internal with path as path
        Return create_result.success
    Catch error:
        Return false

Process called "create_backup_if_needed" that takes path as String and mode as FileMode returns String:
    Note: Create backup file if needed based on mode
    Try:
        Match mode:
            When CreateNew:
                Note: No backup needed for new files
                Return ""
            When AppendOnly:
                Note: No backup needed for append
                Return ""
            Otherwise:
                Let exists_check be file_exists_internal with path as path
                If exists_check:
                    Let backup_path be path plus ".backup." plus string representation of current_time_milliseconds
                    Let copy_result be copy_file_safe with source as path and destination as backup_path
                    If copy_result:
                        Return backup_path
                    Otherwise:
                        Return ""
                Otherwise:
                    Return ""
    Catch error:
        Return ""

Process called "restore_from_backup" that takes original_path as String and backup_path as String returns Boolean:
    Note: Restore file from backup
    Try:
        If backup_path is empty:
            Return true
        
        Let backup_exists be file_exists_internal with path as backup_path
        If backup_exists:
            Let restore_result be copy_file_safe with source as backup_path and destination as original_path
            Let cleanup_result be delete_file_safe with path as backup_path
            Return restore_result
        Otherwise:
            Return false
    Catch error:
        Return false

Process called "cleanup_backup" that takes path as String returns Boolean:
    Note: Clean up backup file
    Try:
        If path is empty:
            Return true
        
        Return delete_file_safe with path as path
    Catch error:
        Return false

Process called "create_safety_backup" that takes path as String returns String:
    Note: Create safety backup before risky operations
    Try:
        Let exists_check be file_exists_internal with path as path
        If exists_check:
            Let backup_path be path plus ".safety." plus string representation of current_time_milliseconds
            Let copy_result be copy_file_safe with source as path and destination as backup_path
            If copy_result:
                Return backup_path
            Otherwise:
                Return ""
        Otherwise:
            Return ""
    Catch error:
        Return ""

