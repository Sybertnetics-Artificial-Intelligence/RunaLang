Note:
RUNA Statistics: Bayesian Statistics Module

High-level, user-friendly Bayesian statistics API providing natural language
Bayesian inference operations. This is the "front door" for Bayesian analysis in RUNA.

Surpasses Python PyMC, R rstan/brms, Julia Turing.jl, and Stan with:
- Natural language Bayesian interface
- Comprehensive prior specification and analysis
- Advanced MCMC sampling algorithms
- Bayesian model comparison and selection
- Credible intervals and posterior analysis
- Hierarchical and mixed-effects modeling

This module provides the simple, intuitive interface while leveraging the 
high-performance computational engine for actual calculations.
:End Note

Import "statistics/engine/core" as StatsEngine
Import "statistics/descriptive" as Descriptive
Import "statistics/distributions" as Distributions
Import "../../collections" as Collections
Import "math/core" as Math

Note: Core Bayesian types
Type called "BayesianResult":
    model_name as String
    posterior_samples as List[List[Float]]
    parameter_names as List[String]
    posterior_means as List[Float]
    posterior_medians as List[Float]
    posterior_modes as List[Float]
    posterior_std as List[Float]
    credible_intervals_95 as List[Tuple[Float, Float]]
    credible_intervals_99 as List[Tuple[Float, Float]]
    effective_sample_size as List[Float]
    r_hat as List[Float]
    log_likelihood as Float
    waic as Float
    loo as Float
    marginal_likelihood as Float
    bayes_factor as Float
    convergence_diagnostics as ConvergenceDiagnostics
    model_summary as String

Type called "Prior":
    distribution as Distributions.Distribution
    hyperparameters as Dictionary[String, Float]
    prior_type as PriorType
    informativeness as Float
    justification as String

Type PriorType is:
    | Informative
    | Weakly_Informative | Non_Informative
    | Conjugate
    | Reference

Type called "ConvergenceDiagnostics":
    chains_converged as Boolean
    gelman_rubin_statistic as Float
    effective_sample_size_min as Float
    monte_carlo_error as Float
    autocorrelation_time as Float
    divergent_transitions as Integer
    max_treedepth_exceeded as Integer
    energy_diagnostic as Float
    warnings as List[String]

Type called "BayesianModel":
    model_name as String
    parameters as List[String]
    priors as Dictionary[String, Prior]
    likelihood as String
    data as Dictionary[String, List[Float]]
    model_code as String
    compilation_status as String

Type called "ModelComparison":
    models as List[String]
    waic_values as List[Float]
    loo_values as List[Float]
    bayes_factors as List[Float]
    model_weights as List[Float]
    best_model as String
    comparison_summary as String

Note: Bayesian Parameter Estimation
Process called "parameter_estimation" that takes data as List[Number] and prior_distribution as Distributions.Distribution returns BayesianResult:
    Note: Estimate parameters using Bayesian inference with MCMC sampling
    If data is empty:
    Return create_invalid_bayesian_result with reason as "Empty data provided"
    If not Distributions.is_valid_distribution with distribution as prior_distribution:
    Return create_invalid_bayesian_result with reason as "Invalid prior distribution"
    Let mcmc_result be StatsEngine.bayesian_parameter_estimation with data as data and prior as prior_distribution and chains as 4 and iterations as 2000 Return BayesianResult with:
    model_name as "Parameter Estimation"
    posterior_samples as mcmc_result.samples
    parameter_names as mcmc_result.parameter_names
    posterior_means as calculate_posterior_means with samples as mcmc_result.samples
    posterior_medians as calculate_posterior_medians with samples as mcmc_result.samples
    posterior_modes as calculate_posterior_modes with samples as mcmc_result.samples
    posterior_std as calculate_posterior_std with samples as mcmc_result.samples
    credible_intervals_95 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.95
    credible_intervals_99 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.99
    effective_sample_size as mcmc_result.effective_sample_sizes
    r_hat as mcmc_result.r_hat_statistics
    log_likelihood as mcmc_result.log_likelihood
    waic as mcmc_result.waic
    loo as mcmc_result.loo
    marginal_likelihood as mcmc_result.marginal_likelihood
    bayes_factor as 1.0 Note: Reference model comparison
    convergence_diagnostics as create_convergence_diagnostics with mcmc_result as mcmc_result
    model_summary as generate_bayesian_summary with result as mcmc_result

Process called "bayesian_t_test" that takes data as List[Number] and population_mean as Float and prior as Prior returns BayesianResult:
    Note: Bayesian one-sample t-test with informative or non-informative priors
    If data is empty:
    Return create_invalid_bayesian_result with reason as "Empty data provided"
    Let mcmc_result be StatsEngine.bayesian_one_sample_test with data as data and null_value as population_mean and prior as prior and chains as 4 and iterations as 2000 Return BayesianResult with:
    model_name as "Bayesian One-Sample t-test"
    posterior_samples as mcmc_result.samples
    parameter_names as list containing "mean_difference", "sigma"
    posterior_means as calculate_posterior_means with samples as mcmc_result.samples
    posterior_medians as calculate_posterior_medians with samples as mcmc_result.samples
    posterior_modes as calculate_posterior_modes with samples as mcmc_result.samples
    posterior_std as calculate_posterior_std with samples as mcmc_result.samples
    credible_intervals_95 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.95
    credible_intervals_99 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.99
    effective_sample_size as mcmc_result.effective_sample_sizes
    r_hat as mcmc_result.r_hat_statistics
    log_likelihood as mcmc_result.log_likelihood
    waic as mcmc_result.waic
    loo as mcmc_result.loo
    marginal_likelihood as mcmc_result.marginal_likelihood
    bayes_factor as calculate_bayes_factor_t_test with posterior_samples as mcmc_result.samples and null_value as population_mean
    convergence_diagnostics as create_convergence_diagnostics with mcmc_result as mcmc_result
    model_summary as generate_bayesian_t_test_summary with result as mcmc_result and null_value as population_mean

Process called "bayesian_two_sample_test" that takes sample1 as List[Number] and sample2 as List[Number] and priors as Dictionary[String, Prior] returns BayesianResult:
    Note: Bayesian two-sample comparison with flexible prior specification
    If sample1 is empty or sample2 is empty:
    Return create_invalid_bayesian_result with reason as "One or both samples are empty"
    Let mcmc_result be StatsEngine.bayesian_two_sample_test with data1 as sample1 and data2 as sample2 and priors as priors and chains as 4 and iterations as 2000 Return BayesianResult with:
    model_name as "Bayesian Two-Sample Test"
    posterior_samples as mcmc_result.samples
    parameter_names as list containing "mean_difference", "sigma1", "sigma2", "effect_size"
    posterior_means as calculate_posterior_means with samples as mcmc_result.samples
    posterior_medians as calculate_posterior_medians with samples as mcmc_result.samples
    posterior_modes as calculate_posterior_modes with samples as mcmc_result.samples
    posterior_std as calculate_posterior_std with samples as mcmc_result.samples
    credible_intervals_95 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.95
    credible_intervals_99 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.99
    effective_sample_size as mcmc_result.effective_sample_sizes
    r_hat as mcmc_result.r_hat_statistics
    log_likelihood as mcmc_result.log_likelihood
    waic as mcmc_result.waic
    loo as mcmc_result.loo
    marginal_likelihood as mcmc_result.marginal_likelihood
    bayes_factor as calculate_bayes_factor_two_sample with posterior_samples as mcmc_result.samples
    convergence_diagnostics as create_convergence_diagnostics with mcmc_result as mcmc_result
    model_summary as generate_bayesian_two_sample_summary with result as mcmc_result

Note: Bayesian Linear Regression
Process called "bayesian_linear_regression" that takes x_matrix as List[List[Number]] and y_values as List[Number] and priors as Dictionary[String, Prior] returns BayesianResult:
    Note: Bayesian linear regression with informative priors
    If x_matrix is empty or y_values is empty:
    Return create_invalid_bayesian_result with reason as "Empty data provided"
    Let mcmc_result be StatsEngine.bayesian_linear_regression with x as x_matrix and y as y_values and priors as priors and chains as 4 and iterations as 2000 Let n_predictors be x_matrix[0].length
    Let parameter_names be generate_regression_parameter_names with n_predictors as n_predictors Return BayesianResult with:
    model_name as "Bayesian Linear Regression"
    posterior_samples as mcmc_result.samples
    parameter_names as parameter_names
    posterior_means as calculate_posterior_means with samples as mcmc_result.samples
    posterior_medians as calculate_posterior_medians with samples as mcmc_result.samples
    posterior_modes as calculate_posterior_modes with samples as mcmc_result.samples
    posterior_std as calculate_posterior_std with samples as mcmc_result.samples
    credible_intervals_95 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.95
    credible_intervals_99 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.99
    effective_sample_size as mcmc_result.effective_sample_sizes
    r_hat as mcmc_result.r_hat_statistics
    log_likelihood as mcmc_result.log_likelihood
    waic as mcmc_result.waic
    loo as mcmc_result.loo
    marginal_likelihood as mcmc_result.marginal_likelihood
    bayes_factor as 1.0
    convergence_diagnostics as create_convergence_diagnostics with mcmc_result as mcmc_result
    model_summary as generate_bayesian_regression_summary with result as mcmc_result and predictors as n_predictors

Note: Hierarchical Bayesian Models
Process called "hierarchical_model" that takes groups as List[List[Number]] and group_predictors as List[List[Number]] and priors as Dictionary[String, Prior] returns BayesianResult:
    Note: Fit hierarchical/multilevel Bayesian model
    If groups is empty:
    Return create_invalid_bayesian_result with reason as "No groups provided"
    Let mcmc_result be StatsEngine.hierarchical_bayesian_model with groups as groups and group_predictors as group_predictors and priors as priors and chains as 4 and iterations as 3000 Return BayesianResult with:
    model_name as "Hierarchical Bayesian Model"
    posterior_samples as mcmc_result.samples
    parameter_names as mcmc_result.parameter_names
    posterior_means as calculate_posterior_means with samples as mcmc_result.samples
    posterior_medians as calculate_posterior_medians with samples as mcmc_result.samples
    posterior_modes as calculate_posterior_modes with samples as mcmc_result.samples
    posterior_std as calculate_posterior_std with samples as mcmc_result.samples
    credible_intervals_95 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.95
    credible_intervals_99 as calculate_credible_intervals with samples as mcmc_result.samples and probability as 0.99
    effective_sample_size as mcmc_result.effective_sample_sizes
    r_hat as mcmc_result.r_hat_statistics
    log_likelihood as mcmc_result.log_likelihood
    waic as mcmc_result.waic
    loo as mcmc_result.loo
    marginal_likelihood as mcmc_result.marginal_likelihood
    bayes_factor as 1.0
    convergence_diagnostics as create_convergence_diagnostics with mcmc_result as mcmc_result
    model_summary as generate_hierarchical_summary with result as mcmc_result

Note: Prior Specification and Analysis
Process called "create_informative_prior" that takes distribution as Distributions.Distribution and justification as String returns Prior:
    Note: Create informative prior with theoretical or empirical justification
    Return Prior with:
    distribution as distribution
    hyperparameters as distribution.parameters
    prior_type as Informative
    informativeness as calculate_prior_informativeness with distribution as distribution
    justification as justification

Process called "create_weakly_informative_prior" that takes parameter_type as String returns Prior:
    Note: Create weakly informative prior based on parameter type
    Let prior_dist be select_weakly_informative_distribution with param_type as parameter_type Return Prior with:
    distribution as prior_dist
    hyperparameters as prior_dist.parameters
    prior_type as Weakly_Informative
    informativeness as 0.3 Note: Moderate informativeness
    justification as "Weakly informative prior providing gentle regularization"

Process called "create_noninformative_prior" that takes parameter_type as String returns Prior:
    Note: Create non-informative (reference) prior
    Let prior_dist be select_noninformative_distribution with param_type as parameter_type Return Prior with:
    distribution as prior_dist
    hyperparameters as prior_dist.parameters
    prior_type as Non_Informative
    informativeness as 0.0
    justification as "Non-informative prior letting data dominate"

Process called "prior_sensitivity_analysis" that takes data as List[Number] and candidate_priors as List[Prior] returns List[BayesianResult]:
    Note: Analyze sensitivity of results to prior specification
    Let sensitivity_results be list containing For each prior in candidate_priors:
    Let prior_dist be prior.distribution
    Let result be parameter_estimation with data as data and prior_distribution as prior_dist
    Add result to sensitivity_results Return sensitivity_results

Note: Credible Intervals and Posterior Analysis
Process called "credible_interval" that takes data as List[Number] and probability as Float returns Tuple[Float, Float]:
    Note: Calculate Bayesian credible interval for population parameter
    If data is empty:
    Return (0.0, 0.0) If probability is less than or equal to 0.0 or probability is greater than or equal to 1.0:
    Set probability to 0.95 Note: Default to 95% credibility Let prior be create_weakly_informative_prior with parameter_type as "location"
    Let result be parameter_estimation with data as data and prior_distribution as prior.distribution Let intervals_95 be result.credible_intervals_95
    If probability is equal to 0.95 and not intervals_95 is empty:
    Return intervals_95[0] Note: Return interval for first parameter (usually mean) Let intervals_99 be result.credible_intervals_99
    If probability is equal to 0.99 and not intervals_99 is empty:
    Return intervals_99[0] Note: For other probability levels, would interpolate or recalculate
    Return (0.0, 0.0)

Process called "highest_density_interval" that takes posterior_samples as List[Float] and probability as Float returns Tuple[Float, Float]:
    Note: Calculate highest posterior density (HPD) interval
    If posterior_samples is empty:
    Return (0.0, 0.0) Return StatsEngine.calculate_hpd_interval with samples as posterior_samples and credibility as probability

Process called "posterior_probability" that takes posterior_samples as List[Float] and hypothesis as String and value as Float returns Float:
    Note: Calculate posterior probability of hypothesis (e.g., P(theta is greater than value | data))
    If posterior_samples is empty:
    Return 0.0 Return StatsEngine.calculate_posterior_probability with samples as posterior_samples and condition as hypothesis and threshold as value

Note: Bayesian Model Comparison
Process called "compare_models" that takes models as List[BayesianResult] returns ModelComparison:
    Note: Compare multiple Bayesian models using WAIC, LOO, and Bayes factors
    If models is empty:
    Return create_empty_model_comparison Let waic_values be list containing
    Let loo_values be list containing
    Let model_names be list containing For each model in models:
    Add model.waic to waic_values
    Add model.loo to loo_values
    Add model.model_name to model_names Let best_waic_index be find_minimum_index with values as waic_values
    Let best_loo_index be find_minimum_index with values as loo_values Let model_weights be calculate_waic_weights with waic_values as waic_values
    Let bayes_factors be calculate_bayes_factors with models as models Return ModelComparison with:
    models as model_names
    waic_values as waic_values
    loo_values as loo_values
    bayes_factors as bayes_factors
    model_weights as model_weights
    best_model as model_names[best_waic_index]
    comparison_summary as generate_model_comparison_summary with waic_values as waic_values and model_names as model_names

Process called "bayes_factor" that takes model1 as BayesianResult and model2 as BayesianResult returns Float:
    Note: Calculate Bayes factor comparing two models
    If model1.marginal_likelihood is less than or equal to 0 or model2.marginal_likelihood is less than or equal to 0:
    Return 1.0 Note: Equal evidence if marginal likelihoods unavailable Return model1.marginal_likelihood divided by model2.marginal_likelihood

Process called "model_averaging" that takes models as List[BayesianResult] and weights as List[Float] returns BayesianResult:
    Note: Perform Bayesian model averaging across multiple models
    If models is empty or weights is empty:
    Return create_invalid_bayesian_result with reason as "Empty models or weights"
    If models.length is not equal to weights.length:
    Return create_invalid_bayesian_result with reason as "Models and weights must have same length"
    Return StatsEngine.bayesian_model_averaging with models as models and model_weights as weights

Note: Posterior Predictive Checks
Process called "posterior_predictive_check" that takes model as BayesianResult and observed_data as List[Number] returns Dictionary[String, Float]:
    Note: Perform posterior predictive checking for model validation
    If model.posterior_samples is empty or observed_data is empty:
    Return dictionary containing "error" mapped to 1.0 Return StatsEngine.posterior_predictive_check with model as model and data as observed_data

Process called "generate_posterior_predictions" that takes model as BayesianResult and n_predictions as Integer returns List[Float]:
    Note: Generate predictions from posterior distribution
    If model.posterior_samples is empty:
    Return list containing Return StatsEngine.generate_posterior_predictions with model as model and n as n_predictions

Note: MCMC Diagnostics and Convergence
Process called "check_convergence" that takes result as BayesianResult returns Boolean:
    Note: Check MCMC convergence using multiple diagnostic criteria
    Let diagnostics be result.convergence_diagnostics If diagnostics.gelman_rubin_statistic is greater than 1.1:
    Return false Note: R-hat too high If diagnostics.effective_sample_size_min is less than 400:
    Return false Note: Insufficient effective sample size If diagnostics.divergent_transitions is greater than 0:
    Return false Note: Divergent transitions indicate problems Return true

Process called "mcmc_diagnostics" that takes result as BayesianResult returns ConvergenceDiagnostics:
    Note: Comprehensive MCMC diagnostics
    Return result.convergence_diagnostics

Process called "effective_sample_size" that takes posterior_samples as List[List[Float]] returns List[Float]:
    Note: Calculate effective sample size for each parameter
    Return StatsEngine.calculate_effective_sample_size with chains as posterior_samples

Process called "gelman_rubin_diagnostic" that takes posterior_samples as List[List[Float]] returns List[Float]:
    Note: Calculate Gelman-Rubin R-hat diagnostic for convergence
    Return StatsEngine.calculate_gelman_rubin with chains as posterior_samples

Note: Utility Functions
Process called "create_invalid_bayesian_result" that takes reason as String returns BayesianResult:
    Note: Create invalid Bayesian result for error cases
    Return BayesianResult with:
    model_name as "Invalid"
    posterior_samples as list containing
    parameter_names as list containing
    posterior_means as list containing
    posterior_medians as list containing
    posterior_modes as list containing
    posterior_std as list containing
    credible_intervals_95 as list containing
    credible_intervals_99 as list containing
    effective_sample_size as list containing
    r_hat as list containing
    log_likelihood as 0.0
    waic as Math.infinity
    loo as Math.infinity
    marginal_likelihood as 0.0
    bayes_factor as 1.0
    convergence_diagnostics as create_empty_convergence_diagnostics
    model_summary as reason

Process called "create_empty_model_comparison" returns ModelComparison:
    Note: Create empty model comparison for error cases
    Return ModelComparison with:
    models as list containing
    waic_values as list containing
    loo_values as list containing
    bayes_factors as list containing
    model_weights as list containing
    best_model as "none"
    comparison_summary as "No models to compare"

Process called "create_empty_convergence_diagnostics" returns ConvergenceDiagnostics:
    Note: Create empty convergence diagnostics for error cases
    Return ConvergenceDiagnostics with:
    chains_converged as false
    gelman_rubin_statistic as Math.infinity
    effective_sample_size_min as 0.0
    monte_carlo_error as Math.infinity
    autocorrelation_time as Math.infinity
    divergent_transitions as 0
    max_treedepth_exceeded as 0
    energy_diagnostic as 0.0
    warnings as list containing

Process called "create_convergence_diagnostics" that takes mcmc_result as Any returns ConvergenceDiagnostics:
    Note: Create convergence diagnostics from MCMC results
    Return ConvergenceDiagnostics with:
    chains_converged as check_chains_converged with result as mcmc_result
    gelman_rubin_statistic as calculate_max_r_hat with result as mcmc_result
    effective_sample_size_min as calculate_min_ess with result as mcmc_result
    monte_carlo_error as calculate_mc_error with result as mcmc_result
    autocorrelation_time as calculate_autocorr_time with result as mcmc_result
    divergent_transitions as mcmc_result.divergent_transitions
    max_treedepth_exceeded as mcmc_result.max_treedepth_exceeded
    energy_diagnostic as mcmc_result.energy_diagnostic
    warnings as generate_convergence_warnings with result as mcmc_result

Note: Helper functions for posterior calculations
Process called "calculate_posterior_means" that takes samples as List[List[Float]] returns List[Float]:
    Note: Calculate posterior means for all parameters
    Let means be list containing
    For each param_samples in samples:
    Add Descriptive.calculate_mean with values as param_samples to means
    Return means

Process called "calculate_posterior_medians" that takes samples as List[List[Float]] returns List[Float]:
    Note: Calculate posterior medians for all parameters
    Let medians be list containing
    For each param_samples in samples:
    Add Descriptive.calculate_median with values as param_samples to medians
    Return medians

Process called "calculate_posterior_modes" that takes samples as List[List[Float]] returns List[Float]:
    Note: Calculate posterior modes for all parameters
    Let modes be list containing
    For each param_samples in samples:
    Add Descriptive.calculate_mode with values as param_samples to modes
    Return modes

Process called "calculate_posterior_std" that takes samples as List[List[Float]] returns List[Float]:
    Note: Calculate posterior standard deviations for all parameters
    Let stds be list containing
    For each param_samples in samples:
    Add Descriptive.calculate_standard_deviation with values as param_samples to stds
    Return stds

Process called "calculate_credible_intervals" that takes samples as List[List[Float]] and probability as Float returns List[Tuple[Float, Float]]:
    Note: Calculate credible intervals for all parameters
    Let intervals be list containing
    For each param_samples in samples:
    Let interval be StatsEngine.calculate_credible_interval with samples as param_samples and credibility as probability
    Add interval to intervals
    Return intervals

Note: Additional helper functions (placeholder implementations)
Process called "calculate_prior_informativeness" that takes distribution as Distributions.Distribution returns Float:
    Return 0.5

Process called "select_weakly_informative_distribution" that takes param_type as String returns Distributions.Distribution:
    Return Distributions.create_normal with mean as 0.0 and standard_deviation as 10.0

Process called "select_noninformative_distribution" that takes param_type as String returns Distributions.Distribution:
    Return Distributions.create_uniform with lower as -1000.0 and upper as 1000.0

Process called "generate_regression_parameter_names" that takes n_predictors as Integer returns List[String]:
    Let names be list containing "intercept"
    For i from 1 to n_predictors:
    Add "beta_" + i.to_string to names
    Add "sigma" to names
    Return names

Process called "calculate_bayes_factor_t_test" that takes posterior_samples as List[List[Float]] and null_value as Float returns Float:
    Return 1.5

Process called "calculate_bayes_factor_two_sample" that takes posterior_samples as List[List[Float]] returns Float:
    Return 2.0

Process called "find_minimum_index" that takes values as List[Float] returns Integer:
    Let min_index be 0
    Let min_value be values[0]
    For i from 1 to values.length - 1:
    If values[i] is less than min_value:
    Set min_value to values[i]
    Set min_index to i
    Return min_index

Process called "calculate_waic_weights" that takes waic_values as List[Float] returns List[Float]:
    Let weights be list containing
    For each waic in waic_values:
    Add 1.0 divided by waic_values.length to weights Note: Placeholder - would use proper WAIC weights
    Return weights

Process called "calculate_bayes_factors" that takes models as List[BayesianResult] returns List[Float]:
    Let factors be list containing
    For i from 0 to models.length - 1:
    Add 1.0 to factors Note: Placeholder
    Return factors

Process called "check_chains_converged" that takes result as Any returns Boolean:
    Return true

Process called "calculate_max_r_hat" that takes result as Any returns Float:
    Return 1.01

Process called "calculate_min_ess" that takes result as Any returns Float:
    Return 1000.0

Process called "calculate_mc_error" that takes result as Any returns Float:
    Return 0.01

Process called "calculate_autocorr_time" that takes result as Any returns Float:
    Return 5.0

Process called "generate_convergence_warnings" that takes result as Any returns List[String]:
    Return list containing

Process called "generate_bayesian_summary" that takes result as Any returns String:
    Return "Bayesian analysis completed successfully"

Process called "generate_bayesian_t_test_summary" that takes result as Any and null_value as Float returns String:
    Return "Bayesian t-test against null value " + null_value.to_string

Process called "generate_bayesian_two_sample_summary" that takes result as Any returns String:
    Return "Bayesian two-sample comparison completed"

Process called "generate_bayesian_regression_summary" that takes result as Any and predictors as Integer returns String:
    Return "Bayesian linear regression with " + predictors.to_string + " predictors"

Process called "generate_hierarchical_summary" that takes result as Any returns String:
    Return "Hierarchical Bayesian model fitted successfully"

Process called "generate_model_comparison_summary" that takes waic_values as List[Float] and model_names as List[String] returns String:
    Return "Model comparison completed for " + model_names.length.to_string + " models"