Note: Runa Standard Library - Generic Programming Utilities
Note: Advanced generic type system utilities and type-level programming
Note: Provides constraint checking, type bounds, variance, and higher-kinded type support

Import "../../builtins" as Builtins
Import "../../collections" as Collections
Import "types/primitives" as Primitives

Note: Core generic type system types and utilities

Type called "TypeParameter":
    name as String
    bounds as List[TypeConstraint]
    variance as Variance
    default_type as Optional[String]
    
    Process called "create" that takes name as String returns TypeParameter:
        Return TypeParameter with:
            name as name
            bounds as list containing
            variance as Variance.Invariant
            default_type as None

Type Variance is:
    | Covariant
    | Contravariant
    | Invariant

Type called "TypeConstraint":
    constraint_type as ConstraintType
    required_type as String
    required_methods as List[String]
    required_fields as List[String]

Type ConstraintType is:
    | Subtype
    | Supertype
    | Interface
    | Trait
    | Equality

Type called "TypeBound":
    parameter as String
    upper_bound as Optional[String]
    lower_bound as Optional[String]
    constraints as List[TypeConstraint]

Type called "GenericSignature":
    type_parameters as List[TypeParameter]
    constraints as List[TypeConstraint]
    return_type as String
    parameter_types as List[String]

Note: Higher-kinded type support

Type called "TypeConstructor":
    name as String
    arity as Integer
    kind as TypeKind
    parameters as List[TypeParameter]

Type TypeKind is:
    | Type
    | TypeToType
    | TypeToTypeToType
    | Higher with arity as Integer

Type called "HigherKindedType":
    constructor as TypeConstructor
    applied_types as List[String]
    remaining_arity as Integer
    
    Process called "apply_type" that takes type_arg as String returns HigherKindedType:
        If self.remaining_arity is equal to 0:
            Throw GenericError with message as "Cannot apply type to fully saturated type constructor"
        
        Let new_applied be self.applied_types.copy()
        Add type_arg to new_applied
        
        Return HigherKindedType with:
            constructor as self.constructor
            applied_types as new_applied
            remaining_arity as self.remaining_arity - 1
    
    Process called "is_fully_applied" returns Boolean:
        Return self.remaining_arity is equal to 0

Note: Generic constraint checking and validation

Process called "check_type_constraints" that takes type_name as String and constraints as List[TypeConstraint] returns Boolean:
    For each constraint in constraints:
        If not satisfies_constraint with type_name as type_name and constraint as constraint:
            Return false
    Return true

Process called "satisfies_constraint" that takes type_name as String and constraint as TypeConstraint returns Boolean:
    Match constraint.constraint_type:
        When Subtype:
            Return is_subtype_of with child as type_name and parent as constraint.required_type
        When Supertype:
            Return is_subtype_of with child as constraint.required_type and parent as type_name
        When Interface:
            Return implements_interface with type_name as type_name and interface as constraint.required_type
        When Trait:
            Return implements_trait with type_name as type_name and trait as constraint.required_type
        When Equality:
            Return type_name is equal to constraint.required_type

Process called "is_subtype_of" that takes child as String and parent as String returns Boolean:
    Note: Check if child type is a subtype of parent type
    If child is equal to parent:
        Return true
    If parent is equal to "Any":
        Return true
    
    Note: Primitive type subtyping rules
    If child is equal to "Integer" and parent is equal to "Float":
        Return true
    If child is equal to "Byte" and parent is equal to "Integer":
        Return true
    If child is equal to "Character" and parent is equal to "String":
        Return true
    
    Note: Generic type subtyping
    If is_generic_type with type_name as child and is_generic_type with type_name as parent:
        Return check_generic_subtyping with child_type as child and parent_type as parent
    
    Return false

Process called "implements_interface" that takes type_name as String and interface as String returns Boolean:
    Note: Check if type implements required interface methods
    Let interface_methods be get_interface_methods with interface_name as interface
    For each method in interface_methods:
        If not type_has_method with type_name as type_name and method_name as method:
            Return false
    Return true

Process called "implements_trait" that takes type_name as String and trait as String returns Boolean:
    Note: Check if type implements required trait behavior
    Let trait_requirements be get_trait_requirements with trait_name as trait
    For each requirement in trait_requirements:
        If not type_satisfies_requirement with type_name as type_name and requirement as requirement:
            Return false
    Return true

Note: Generic type manipulation and utilities

Process called "instantiate_generic_type" that takes generic_type as String and type_args as List[String] returns String:
    Let type_params be extract_type_parameters with type_signature as generic_type
    
    If length of type_args is not equal to length of type_params:
        Throw GenericError with message as f"Type argument count mismatch: expected {length of type_params}, got {length of type_args}"
    
    Let substitutions be dictionary containing
    For i from 0 to length of type_params - 1:
        Set substitutions[type_params[i].name] to type_args[i]
    
    Return substitute_type_parameters with type_signature as generic_type and substitutions as substitutions

Process called "extract_type_parameters" that takes type_signature as String returns List[TypeParameter]:
    Note: Parse type signature to extract generic parameters
    Let parameters be list containing
    
    If not contains with string as type_signature and substring as "[":
        Return parameters
    
    Let param_section be extract_between with string as type_signature and start as "[" and end as "]"
    Let param_names be split with string as param_section and delimiter as ","
    
    For each param_name in param_names:
        Let trimmed_name be trim with string as param_name
        Let param be TypeParameter.create with name as trimmed_name
        Add param to parameters
    
    Return parameters

Process called "substitute_type_parameters" that takes type_signature as String and substitutions as Dictionary[String, String] returns String:
    Let result be type_signature
    
    For each param_name and replacement in substitutions:
        Set result to replace_all with string as result and pattern as param_name and replacement as replacement
    
    Return result

Process called "check_generic_subtyping" that takes child_type as String and parent_type as String returns Boolean:
    Let child_base be extract_base_type with type_signature as child_type
    Let parent_base be extract_base_type with type_signature as parent_type
    
    If child_base is not equal to parent_base:
        Return false
    
    Let child_args be extract_type_arguments with type_signature as child_type
    Let parent_args be extract_type_arguments with type_signature as parent_type
    
    If length of child_args is not equal to length of parent_args:
        Return false
    
    Note: Check variance rules for each type argument
    Let type_params be get_type_parameters_for_type with type_name as child_base
    
    For i from 0 to length of child_args - 1:
        Let variance be type_params[i].variance
        Match variance:
            When Covariant:
                If not is_subtype_of with child as child_args[i] and parent as parent_args[i]:
                    Return false
            When Contravariant:
                If not is_subtype_of with child as parent_args[i] and parent as child_args[i]:
                    Return false
            When Invariant:
                If child_args[i] is not equal to parent_args[i]:
                    Return false
    
    Return true

Note: Type bounds and constraint management

Process called "create_type_bound" that takes parameter as String returns TypeBound:
    Return TypeBound with:
        parameter as parameter
        upper_bound as None
        lower_bound as None
        constraints as list containing

Process called "add_upper_bound" that takes bound as TypeBound and upper_type as String returns TypeBound:
    Return TypeBound with:
        parameter as bound.parameter
        upper_bound as Some with value as upper_type
        lower_bound as bound.lower_bound
        constraints as bound.constraints

Process called "add_lower_bound" that takes bound as TypeBound and lower_type as String returns TypeBound:
    Return TypeBound with:
        parameter as bound.parameter
        upper_bound as bound.upper_bound
        lower_bound as Some with value as lower_type
        constraints as bound.constraints

Process called "add_constraint_to_bound" that takes bound as TypeBound and constraint as TypeConstraint returns TypeBound:
    Let new_constraints be bound.constraints.copy()
    Add constraint to new_constraints
    
    Return TypeBound with:
        parameter as bound.parameter
        upper_bound as bound.upper_bound
        lower_bound as bound.lower_bound
        constraints as new_constraints

Process called "check_bound_satisfaction" that takes type_name as String and bound as TypeBound returns Boolean:
    Note: Check upper bound
    If bound.upper_bound is not None:
        If not is_subtype_of with child as type_name and parent as bound.upper_bound:
            Return false
    
    Note: Check lower bound
    If bound.lower_bound is not None:
        If not is_subtype_of with child as bound.lower_bound and parent as type_name:
            Return false
    
    Note: Check constraints
    Return check_type_constraints with type_name as type_name and constraints as bound.constraints

Note: Advanced generic programming utilities

Process called "create_generic_function_signature" that takes name as String and type_params as List[TypeParameter] returns GenericSignature:
    Return GenericSignature with:
        type_parameters as type_params
        constraints as list containing
        return_type as "Any"
        parameter_types as list containing

Process called "specialize_generic_function" that takes signature as GenericSignature and type_args as List[String] returns GenericSignature:
    Let substitutions be dictionary containing
    
    For i from 0 to length of signature.type_parameters - 1:
        If i is less than length of type_args:
            Set substitutions[signature.type_parameters[i].name] to type_args[i]
    
    Let specialized_return be substitute_type_parameters with:
        type_signature as signature.return_type
        substitutions as substitutions
    
    Let specialized_params be list containing
    For each param_type in signature.parameter_types:
        Let specialized_param be substitute_type_parameters with:
            type_signature as param_type
            substitutions as substitutions
        Add specialized_param to specialized_params
    
    Return GenericSignature with:
        type_parameters as list containing
        constraints as signature.constraints
        return_type as specialized_return
        parameter_types as specialized_params

Process called "infer_type_arguments" that takes signature as GenericSignature and actual_args as List[String] returns List[String]:
    Let inferred_types be list containing
    
    For each type_param in signature.type_parameters:
        Let inferred_type be infer_single_type_argument with:
            parameter as type_param
            signature as signature
            actual_args as actual_args
        Add inferred_type to inferred_types
    
    Return inferred_types

Process called "infer_single_type_argument" that takes parameter as TypeParameter and signature as GenericSignature and actual_args as List[String] returns String:
    Note: Simple type inference - look for direct matches
    For i from 0 to length of signature.parameter_types - 1:
        If signature.parameter_types[i] is equal to parameter.name:
            If i is less than length of actual_args:
                Return actual_args[i]
    
    Note: Use default type if available
    If parameter.default_type is not None:
        Return parameter.default_type
    
    Note: Use first bound as fallback
    If length of parameter.bounds is greater than 0:
        Return parameter.bounds[0].required_type
    
    Return "Any"

Note: Variance analysis and checking

Process called "check_variance_safety" that takes type_constructor as TypeConstructor and usage_context as VarianceContext returns Boolean:
    For each param in type_constructor.parameters:
        If not is_variance_safe with parameter as param and context as usage_context:
            Return false
    Return true

Type VarianceContext is:
    | InputPosition
    | OutputPosition
    | InvariantPosition

Process called "is_variance_safe" that takes parameter as TypeParameter and context as VarianceContext returns Boolean:
    Match parameter.variance:
        When Covariant:
            Return context is not equal to VarianceContext.InputPosition
        When Contravariant:
            Return context is not equal to VarianceContext.OutputPosition
        When Invariant:
            Return true

Process called "compute_variance" that takes type_signature as String and parameter as String returns Variance:
    Note: Analyze how type parameter is used to determine safe variance
    Let input_uses be count_parameter_in_input_positions with signature as type_signature and param as parameter
    Let output_uses be count_parameter_in_output_positions with signature as type_signature and param as parameter
    
    If input_uses is greater than 0 and output_uses is greater than 0:
        Return Variance.Invariant
    If input_uses is greater than 0:
        Return Variance.Contravariant
    If output_uses is greater than 0:
        Return Variance.Covariant
    Return Variance.Invariant

Note: Type-level computation and utilities

Process called "compose_type_constructors" that takes f as TypeConstructor and g as TypeConstructor returns TypeConstructor:
    Note: Compose two type constructors (f . g)
    If f.arity is not equal to 1 or g.arity is not equal to 1:
        Throw GenericError with message as "Can only compose unary type constructors"
    
    Return TypeConstructor with:
        name as f.name Joined with "_compose_" Joined with g.name
        arity as 1
        kind as TypeKind.TypeToType
        parameters as combine_parameters with params1 as f.parameters and params2 as g.parameters

Process called "combine_parameters" that takes params1 as List[TypeParameter] and params2 as List[TypeParameter] returns List[TypeParameter]:
    Let combined be list containing
    
    For each param in params1:
        Add param to combined
    
    For each param in params2:
        If not contains_parameter with parameters as combined and param_name as param.name:
            Add param to combined
    
    Return combined

Process called "contains_parameter" that takes parameters as List[TypeParameter] and param_name as String returns Boolean:
    For each param in parameters:
        If param.name is equal to param_name:
            Return true
    Return false

Note: Generic collection utilities

Process called "map_generic_container"[F, T, U] that takes container as F[T] and transform as Function[T, U] returns F[U]:
    Note: Generic map operation over any functor
    Return apply_functor_map with container as container and function as transform

Process called "flat_map_generic_container"[M, T, U] that takes container as M[T] and transform as Function[T, M[U]] returns M[U]:
    Note: Generic flatMap operation over any monad
    Return apply_monad_bind with container as container and function as transform

Process called "filter_generic_container"[F, T] that takes container as F[T] and predicate as Function[T, Boolean] returns F[T]:
    Note: Generic filter operation
    Return apply_filterable_filter with container as container and predicate as predicate

Process called "fold_generic_container"[F, T, U] that takes container as F[T] and initial as U and combiner as Function[U, T, U] returns U:
    Note: Generic fold operation over any foldable
    Return apply_foldable_fold with container as container and initial as initial and function as combiner

Note: Type-safe casting and conversion utilities

Process called "safe_cast"[T, U] that takes value as T and target_type as String returns Optional[U]:
    Try:
        If can_cast_to with value as value and target_type as target_type:
            Return Some with value as value as U
        Otherwise:
            Return None
    Catch cast_error:
        Return None

Process called "can_cast_to" that takes value as Any and target_type as String returns Boolean:
    Let source_type be Primitives.get_type_name with value as value
    Return is_subtype_of with child as source_type and parent as target_type or 
           has_implicit_conversion with from_type as source_type and to_type as target_type

Process called "has_implicit_conversion" that takes from_type as String and to_type as String returns Boolean:
    Note: Check for built-in implicit conversions
    Match from_type:
        When "Integer":
            Return to_type is equal to "Float" or to_type is equal to "String"
        When "Float":
            Return to_type is equal to "String"
        When "Character":
            Return to_type is equal to "String"
        When "Boolean":
            Return to_type is equal to "String" or to_type is equal to "Integer"
        Otherwise:
            Return false

Note: Advanced constraint solving

Process called "solve_constraints" that takes constraints as List[TypeConstraint] and variables as List[String] returns Dictionary[String, String]:
    Let solution be dictionary containing
    
    For each variable in variables:
        Let inferred_type be solve_single_constraint with:
            variable as variable
            constraints as constraints
            partial_solution as solution
        Set solution[variable] to inferred_type
    
    Return solution

Process called "solve_single_constraint" that takes variable as String and constraints as List[TypeConstraint] and partial_solution as Dictionary[String, String] returns String:
    Let applicable_constraints be filter_constraints_for_variable with:
        variable as variable
        constraints as constraints
    
    If length of applicable_constraints is equal to 0:
        Return "Any"
    
    Note: Find most specific type that satisfies all constraints
    Let candidate_types be get_candidate_types_for_constraints with constraints as applicable_constraints
    Return find_most_specific_type with types as candidate_types and constraints as applicable_constraints

Process called "filter_constraints_for_variable" that takes variable as String and constraints as List[TypeConstraint] returns List[TypeConstraint]:
    Let filtered be list containing
    
    For each constraint in constraints:
        If constraint_involves_variable with constraint as constraint and variable as variable:
            Add constraint to filtered
    
    Return filtered

Process called "constraint_involves_variable" that takes constraint as TypeConstraint and variable as String returns Boolean:
    Return constraint.required_type is equal to variable or 
           contains with string as constraint.required_type and substring as variable

Note: Utility functions for type analysis

Process called "extract_base_type" that takes type_signature as String returns String:
    If not contains with string as type_signature and substring as "[":
        Return type_signature
    
    Let bracket_index be find_character with string as type_signature and character as '['
    Return substring with string as type_signature and start as 0 and end as bracket_index

Process called "extract_type_arguments" that takes type_signature as String returns List[String]:
    If not contains with string as type_signature and substring as "[":
        Return list containing
    
    Let args_section be extract_between with string as type_signature and start as "[" and end as "]"
    Return split_respecting_brackets with string as args_section and delimiter as ","

Process called "extract_between" that takes string as String and start as String and end as String returns String:
    Let start_index be find_substring with string as string and substring as start
    Let end_index be find_substring with string as string and substring as end
    
    If start_index is equal to -1 or end_index is equal to -1:
        Return ""
    
    Return substring with string as string and start as start_index + length of start and end as end_index

Process called "split_respecting_brackets" that takes string as String and delimiter as String returns List[String]:
    Let parts be list containing
    Let current_part be ""
    Let bracket_depth be 0
    
    For i from 0 to length of string - 1:
        Let char be character_at with string as string and index as i
        
        If char is equal to '[':
            Set bracket_depth to bracket_depth + 1
        If char is equal to ']':
            Set bracket_depth to bracket_depth - 1
        
        If char is equal to ',' and bracket_depth is equal to 0:
            Add trim with string as current_part to parts
            Set current_part to ""
        Otherwise:
            Set current_part to current_part Joined with char
    
    If length of current_part is greater than 0:
        Add trim with string as current_part to parts
    
    Return parts

Process called "find_substring" that takes string as String and substring as String returns Integer:
    For i from 0 to length of string - length of substring:
        If substring_at_position with string as string and position as i and target as substring:
            Return i
    Return -1

Process called "substring_at_position" that takes string as String and position as Integer and target as String returns Boolean:
    If position + length of target is greater than length of string:
        Return false
    
    For i from 0 to length of target - 1:
        If character_at with string as string and index as position + i is not equal to character_at with string as target and index as i:
            Return false
    
    Return true

Note: Error types for generic programming

Type called "GenericError":
    message as String
    error_type as GenericErrorType

Type GenericErrorType is:
    | TypeArgumentMismatch
    | ConstraintViolation
    | VarianceError
    | KindError
    | SubstitutionError

Type called "ConstraintError":
    constraint as TypeConstraint
    violating_type as String
    message as String

Type called "VarianceError":
    parameter as TypeParameter
    expected_variance as Variance
    actual_variance as Variance
    message as String

Note: Platform integration functions (delegated to builtins)

Process called "get_interface_methods" that takes interface_name as String returns List[String]:
    Return Builtins.get_interface_methods with interface_name as interface_name

Process called "get_trait_requirements" that takes trait_name as String returns List[String]:
    Return Builtins.get_trait_requirements with trait_name as trait_name

Process called "type_has_method" that takes type_name as String and method_name as String returns Boolean:
    Return Builtins.type_has_method with type_name as type_name and method_name as method_name

Process called "type_satisfies_requirement" that takes type_name as String and requirement as String returns Boolean:
    Return Builtins.type_satisfies_requirement with type_name as type_name and requirement as requirement

Process called "get_type_parameters_for_type" that takes type_name as String returns List[TypeParameter]:
    Return Builtins.get_type_parameters_for_type with type_name as type_name

Process called "is_generic_type" that takes type_name as String returns Boolean:
    Return contains with string as type_name and substring as "["

Process called "count_parameter_in_input_positions" that takes signature as String and param as String returns Integer:
    Return Builtins.count_parameter_in_input_positions with signature as signature and param as param

Process called "count_parameter_in_output_positions" that takes signature as String and param as String returns Integer:
    Return Builtins.count_parameter_in_output_positions with signature as signature and param as param

Process called "apply_functor_map"[F, T, U] that takes container as F[T] and function as Function[T, U] returns F[U]:
    Return Builtins.apply_functor_map with container as container and function as function

Process called "apply_monad_bind"[M, T, U] that takes container as M[T] and function as Function[T, M[U]] returns M[U]:
    Return Builtins.apply_monad_bind with container as container and function as function

Process called "apply_filterable_filter"[F, T] that takes container as F[T] and predicate as Function[T, Boolean] returns F[T]:
    Return Builtins.apply_filterable_filter with container as container and predicate as predicate

Process called "apply_foldable_fold"[F, T, U] that takes container as F[T] and initial as U and function as Function[U, T, U] returns U:
    Return Builtins.apply_foldable_fold with container as container and initial as initial and function as function

Process called "get_candidate_types_for_constraints" that takes constraints as List[TypeConstraint] returns List[String]:
    Return Builtins.get_candidate_types_for_constraints with constraints as constraints

Process called "find_most_specific_type" that takes types as List[String] and constraints as List[TypeConstraint] returns String:
    Return Builtins.find_most_specific_type with types as types and constraints as constraints

Process called "replace_all" that takes string as String and pattern as String and replacement as String returns String:
    Return Builtins.replace_all with string as string and pattern as pattern and replacement as replacement

Process called "trim" that takes string as String returns String:
    Return Builtins.trim with string as string

Process called "split" that takes string as String and delimiter as String returns List[String]:
    Return Builtins.split with string as string and delimiter as delimiter

Process called "character_at" that takes string as String and index as Integer returns Character:
    Return Builtins.character_at with string as string and index as index

Process called "find_character" that takes string as String and character as Character returns Integer:
    Return Builtins.find_character with string as string and character as character

Process called "substring" that takes string as String and start as Integer and end as Integer returns String:
    Return Builtins.substring with string as string and start as start and end as end

Process called "contains" that takes string as String and substring as String returns Boolean:
    Return Builtins.contains with string as string and substring as substring

