Note: Runa Standard Library - Reflection System
Note: Runtime type introspection, dynamic method invocation, and metaprogramming
Note: Provides comprehensive reflection capabilities for dynamic programming

Import "../../builtins" as Builtins
Import "../../collections" as Collections
Import "types/primitives" as Primitives
Import "types/generics" as Generics
Import "types/protocols" as Protocols

Note: Core reflection types

Type called "TypeInfo":
    name as String
    qualified_name as String
    module_name as String
    base_types as List[String]
    implemented_interfaces as List[String]
    type_parameters as List[String]
    is_abstract as Boolean
    is_final as Boolean
    is_generic as Boolean
    is_primitive as Boolean
    size_in_bytes as Optional[Integer]
    attributes as List[AttributeInfo]
    
    Process called "create" that takes name as String returns TypeInfo:
        Return TypeInfo with:
            name as name
            qualified_name as name
            module_name as ""
            base_types as list containing
            implemented_interfaces as list containing
            type_parameters as list containing
            is_abstract as false
            is_final as false
            is_generic as false
            is_primitive as false
            size_in_bytes as None
            attributes as list containing

Type called "MethodInfo":
    name as String
    declaring_type as String
    return_type as String
    parameter_types as List[String]
    parameter_names as List[String]
    generic_parameters as List[String]
    is_static as Boolean
    is_abstract as Boolean
    is_virtual as Boolean
    is_override as Boolean
    visibility as Visibility
    attributes as List[AttributeInfo]
    
Type called "PropertyInfo":
    name as String
    declaring_type as String
    property_type as String
    has_getter as Boolean
    has_setter as Boolean
    is_static as Boolean
    is_abstract as Boolean
    is_virtual as Boolean
    visibility as Visibility
    attributes as List[AttributeInfo]

Type called "FieldInfo":
    name as String
    declaring_type as String
    field_type as String
    is_static as Boolean
    is_readonly as Boolean
    is_const as Boolean
    default_value as Optional[Any]
    visibility as Visibility
    attributes as List[AttributeInfo]

Type called "ConstructorInfo":
    declaring_type as String
    parameter_types as List[String]
    parameter_names as List[String]
    is_primary as Boolean
    visibility as Visibility
    attributes as List[AttributeInfo]

Type Visibility is:
    | Public
    | Private
    | Protected
    | Internal

Type called "AttributeInfo":
    name as String
    attribute_type as String
    arguments as Dictionary[String, Any]
    target as AttributeTarget

Type AttributeTarget is:
    | Type
    | Method
    | Property
    | Field
    | Parameter
    | Constructor

Note: Dynamic type inspection

Process called "get_type_info" that takes type_name as String returns Optional[TypeInfo]:
    Try:
        Let runtime_type be get_runtime_type with name as type_name
        If runtime_type is None:
            Return None
        
        Return Some with value as TypeInfo with:
            name as runtime_type.name
            qualified_name as runtime_type.qualified_name
            module_name as runtime_type.module_name
            base_types as runtime_type.base_types
            implemented_interfaces as runtime_type.implemented_interfaces
            type_parameters as runtime_type.type_parameters
            is_abstract as runtime_type.is_abstract
            is_final as runtime_type.is_final
            is_generic as runtime_type.is_generic
            is_primitive as runtime_type.is_primitive
            size_in_bytes as runtime_type.size_in_bytes
            attributes as runtime_type.attributes
    Catch reflection_error:
        Return None

Process called "get_type_of" that takes value as Any returns TypeInfo:
    Let type_name be Primitives.get_type_name with value as value
    Let type_info be get_type_info with type_name as type_name
    
    If type_info is None:
        Throw ReflectionError with message as f"Cannot get type information for {type_name}"
    
    Return type_info

Process called "get_methods" that takes type_name as String returns List[MethodInfo]:
    Let runtime_methods be get_runtime_methods with type_name as type_name
    Let method_infos be list containing
    
    For each runtime_method in runtime_methods:
        Let method_info be MethodInfo with:
            name as runtime_method.name
            declaring_type as runtime_method.declaring_type
            return_type as runtime_method.return_type
            parameter_types as runtime_method.parameter_types
            parameter_names as runtime_method.parameter_names
            generic_parameters as runtime_method.generic_parameters
            is_static as runtime_method.is_static
            is_abstract as runtime_method.is_abstract
            is_virtual as runtime_method.is_virtual
            is_override as runtime_method.is_override
            visibility as runtime_method.visibility
            attributes as runtime_method.attributes
        Add method_info to method_infos
    
    Return method_infos

Process called "get_properties" that takes type_name as String returns List[PropertyInfo]:
    Let runtime_properties be get_runtime_properties with type_name as type_name
    Let property_infos be list containing
    
    For each runtime_property in runtime_properties:
        Let property_info be PropertyInfo with:
            name as runtime_property.name
            declaring_type as runtime_property.declaring_type
            property_type as runtime_property.property_type
            has_getter as runtime_property.has_getter
            has_setter as runtime_property.has_setter
            is_static as runtime_property.is_static
            is_abstract as runtime_property.is_abstract
            is_virtual as runtime_property.is_virtual
            visibility as runtime_property.visibility
            attributes as runtime_property.attributes
        Add property_info to property_infos
    
    Return property_infos

Process called "get_fields" that takes type_name as String returns List[FieldInfo]:
    Let runtime_fields be get_runtime_fields with type_name as type_name
    Let field_infos be list containing
    
    For each runtime_field in runtime_fields:
        Let field_info be FieldInfo with:
            name as runtime_field.name
            declaring_type as runtime_field.declaring_type
            field_type as runtime_field.field_type
            is_static as runtime_field.is_static
            is_readonly as runtime_field.is_readonly
            is_const as runtime_field.is_const
            default_value as runtime_field.default_value
            visibility as runtime_field.visibility
            attributes as runtime_field.attributes
        Add field_info to field_infos
    
    Return field_infos

Process called "get_constructors" that takes type_name as String returns List[ConstructorInfo]:
    Let runtime_constructors be get_runtime_constructors with type_name as type_name
    Let constructor_infos be list containing
    
    For each runtime_constructor in runtime_constructors:
        Let constructor_info be ConstructorInfo with:
            declaring_type as runtime_constructor.declaring_type
            parameter_types as runtime_constructor.parameter_types
            parameter_names as runtime_constructor.parameter_names
            is_primary as runtime_constructor.is_primary
            visibility as runtime_constructor.visibility
            attributes as runtime_constructor.attributes
        Add constructor_info to constructor_infos
    
    Return constructor_infos

Note: Dynamic method and property access

Process called "invoke_method" that takes instance as Any and method_name as String and args as List[Any] returns Any:
    Let type_name be Primitives.get_type_name with value as instance
    Let method_info be find_method with type_name as type_name and method_name as method_name and arg_types as get_arg_types with args as args
    
    If method_info is None:
        Throw ReflectionError with message as f"Method {method_name} not found on type {type_name}"
    
    Return invoke_method_with_info with instance as instance and method as method_info and args as args

Process called "invoke_static_method" that takes type_name as String and method_name as String and args as List[Any] returns Any:
    Let method_info be find_static_method with type_name as type_name and method_name as method_name and arg_types as get_arg_types with args as args
    
    If method_info is None:
        Throw ReflectionError with message as f"Static method {method_name} not found on type {type_name}"
    
    Return invoke_static_method_with_info with type_name as type_name and method as method_info and args as args

Process called "get_property_value" that takes instance as Any and property_name as String returns Any:
    Let type_name be Primitives.get_type_name with value as instance
    Let property_info be find_property with type_name as type_name and property_name as property_name
    
    If property_info is None:
        Throw ReflectionError with message as f"Property {property_name} not found on type {type_name}"
    
    If not property_info.has_getter:
        Throw ReflectionError with message as f"Property {property_name} has no getter"
    
    Return get_property_value_with_info with instance as instance and property as property_info

Process called "set_property_value" that takes instance as Any and property_name as String and value as Any returns None:
    Let type_name be Primitives.get_type_name with value as instance
    Let property_info be find_property with type_name as type_name and property_name as property_name
    
    If property_info is None:
        Throw ReflectionError with message as f"Property {property_name} not found on type {type_name}"
    
    If not property_info.has_setter:
        Throw ReflectionError with message as f"Property {property_name} has no setter"
    
    set_property_value_with_info with instance as instance and property as property_info and value as value

Process called "get_field_value" that takes instance as Any and field_name as String returns Any:
    Let type_name be Primitives.get_type_name with value as instance
    Let field_info be find_field with type_name as type_name and field_name as field_name
    
    If field_info is None:
        Throw ReflectionError with message as f"Field {field_name} not found on type {type_name}"
    
    Return get_field_value_with_info with instance as instance and field as field_info

Process called "set_field_value" that takes instance as Any and field_name as String and value as Any returns None:
    Let type_name be Primitives.get_type_name with value as instance
    Let field_info be find_field with type_name as type_name and field_name as field_name
    
    If field_info is None:
        Throw ReflectionError with message as f"Field {field_name} not found on type {type_name}"
    
    If field_info.is_readonly:
        Throw ReflectionError with message as f"Field {field_name} is readonly"
    
    set_field_value_with_info with instance as instance and field as field_info and value as value

Note: Dynamic type creation and instantiation

Process called "create_instance" that takes type_name as String and args as List[Any] returns Any:
    Let constructor_info be find_constructor with type_name as type_name and arg_types as get_arg_types with args as args
    
    If constructor_info is None:
        Throw ReflectionError with message as f"No matching constructor found for type {type_name}"
    
    Return create_instance_with_constructor with constructor as constructor_info and args as args

Process called "create_instance_with_constructor" that takes constructor as ConstructorInfo and args as List[Any] returns Any:
    Return invoke_constructor with constructor as constructor and args as args

Process called "create_generic_instance" that takes generic_type as String and type_args as List[String] and constructor_args as List[Any] returns Any:
    Let instantiated_type be Generics.instantiate_generic_type with generic_type as generic_type and type_args as type_args
    Return create_instance with type_name as instantiated_type and args as constructor_args

Process called "create_array" that takes element_type as String and length as Integer returns Any:
    Return create_array_with_type_and_length with element_type as element_type and length as length

Process called "create_dictionary" that takes key_type as String and value_type as String returns Any:
    Let dict_type be f"Dictionary[{key_type}, {value_type}]"
    Return create_instance with type_name as dict_type and args as list containing

Note: Attribute and annotation system

Process called "get_type_attributes" that takes type_name as String returns List[AttributeInfo]:
    Let type_info be get_type_info with type_name as type_name
    If type_info is None:
        Return list containing
    Return type_info.attributes

Process called "get_method_attributes" that takes type_name as String and method_name as String returns List[AttributeInfo]:
    Let methods be get_methods with type_name as type_name
    For each method in methods:
        If method.name is equal to method_name:
            Return method.attributes
    Return list containing

Process called "get_property_attributes" that takes type_name as String and property_name as String returns List[AttributeInfo]:
    Let properties be get_properties with type_name as type_name
    For each property in properties:
        If property.name is equal to property_name:
            Return property.attributes
    Return list containing

Process called "has_attribute" that takes type_name as String and attribute_name as String returns Boolean:
    Let attributes be get_type_attributes with type_name as type_name
    For each attribute in attributes:
        If attribute.name is equal to attribute_name:
            Return true
    Return false

Process called "find_attribute" that takes attributes as List[AttributeInfo] and attribute_name as String returns Optional[AttributeInfo]:
    For each attribute in attributes:
        If attribute.name is equal to attribute_name:
            Return Some with value as attribute
    Return None

Process called "get_attribute_argument" that takes attribute as AttributeInfo and argument_name as String returns Optional[Any]:
    If argument_name is in attribute.arguments:
        Return Some with value as attribute.arguments[argument_name]
    Return None

Note: Advanced reflection utilities

Process called "is_assignable_from" that takes target_type as String and source_type as String returns Boolean:
    Return target_type is equal to source_type or
           Generics.is_subtype_of with child as source_type and parent as target_type

Process called "get_compatible_methods" that takes type_name as String and method_name as String and arg_types as List[String] returns List[MethodInfo]:
    Let all_methods be get_methods with type_name as type_name
    Let compatible_methods be list containing
    
    For each method in all_methods:
        If method.name is equal to method_name:
            If is_method_compatible with method as method and arg_types as arg_types:
                Add method to compatible_methods
    
    Return compatible_methods

Process called "is_method_compatible" that takes method as MethodInfo and arg_types as List[String] returns Boolean:
    If length of method.parameter_types is not equal to length of arg_types:
        Return false
    
    For i from 0 to length of method.parameter_types - 1:
        If not is_assignable_from with target_type as method.parameter_types[i] and source_type as arg_types[i]:
            Return false
    
    Return true

Process called "get_most_specific_method" that takes methods as List[MethodInfo] and arg_types as List[String] returns Optional[MethodInfo]:
    Let best_method be None
    Let best_specificity be -1
    
    For each method in methods:
        Let specificity be calculate_method_specificity with method as method and arg_types as arg_types
        If specificity is greater than best_specificity:
            Set best_method to Some with value as method
            Set best_specificity to specificity
    
    Return best_method

Process called "calculate_method_specificity" that takes method as MethodInfo and arg_types as List[String] returns Integer:
    Let specificity be 0
    
    For i from 0 to length of method.parameter_types - 1:
        If method.parameter_types[i] is equal to arg_types[i]:
            Set specificity to specificity + 10
        Otherwise:
            If Generics.is_subtype_of with child as arg_types[i] and parent as method.parameter_types[i]:
                Set specificity to specificity + 5
    
    Return specificity

Note: Type hierarchy and inheritance analysis

Process called "get_type_hierarchy" that takes type_name as String returns List[String]:
    Let hierarchy be list containing
    Let current_type be type_name
    
    While current_type is not None:
        Add current_type to hierarchy
        Set current_type to get_base_type with type_name as current_type
    
    Return hierarchy

Process called "get_base_type" that takes type_name as String returns Optional[String]:
    Let type_info be get_type_info with type_name as type_name
    If type_info is None:
        Return None
    
    If length of type_info.base_types is greater than 0:
        Return Some with value as type_info.base_types[0]
    
    Return None

Process called "get_all_interfaces" that takes type_name as String returns List[String]:
    Let all_interfaces be list containing
    Let hierarchy be get_type_hierarchy with type_name as type_name
    
    For each type in hierarchy:
        Let type_info be get_type_info with type_name as type
        If type_info is not None:
            For each interface in type_info.implemented_interfaces:
                If interface is not in all_interfaces:
                    Add interface to all_interfaces
    
    Return all_interfaces

Process called "implements_interface" that takes type_name as String and interface_name as String returns Boolean:
    Let interfaces be get_all_interfaces with type_name as type_name
    Return interface_name is in interfaces

Process called "get_common_base_type" that takes type1 as String and type2 as String returns Optional[String]:
    Let hierarchy1 be get_type_hierarchy with type_name as type1
    Let hierarchy2 be get_type_hierarchy with type_name as type2
    
    For each type in hierarchy1:
        If type is in hierarchy2:
            Return Some with value as type
    
    Return None

Note: Dynamic code generation and execution

Type called "CodeBuilder":
    statements as List[String]
    imports as List[String]
    type_definitions as List[String]
    
    Process called "create" returns CodeBuilder:
        Return CodeBuilder with:
            statements as list containing
            imports as list containing
            type_definitions as list containing

Process called "add_import" that takes builder as CodeBuilder and import_statement as String returns None:
    Add import_statement to builder.imports

Process called "add_type_definition" that takes builder as CodeBuilder and type_def as String returns None:
    Add type_def to builder.type_definitions

Process called "add_statement" that takes builder as CodeBuilder and statement as String returns None:
    Add statement to builder.statements

Process called "build_code" that takes builder as CodeBuilder returns String:
    Let code be ""
    
    For each import in builder.imports:
        Set code to code concatenated with import concatenated with "\n"
    
    Set code to code concatenated with "\n"
    
    For each type_def in builder.type_definitions:
        Set code to code concatenated with type_def concatenated with "\n"
    
    Set code to code concatenated with "\n"
    
    For each statement in builder.statements:
        Set code to code concatenated with statement concatenated with "\n"
    
    Return code

Process called "compile_and_execute" that takes code as String returns Any:
    Return compile_and_execute_code with code as code

Process called "create_lambda_from_code" that takes parameter_names as List[String] and body as String returns Function:
    Let lambda_code be build_lambda_code with parameters as parameter_names and body as body
    Return compile_lambda with code as lambda_code

Note: Helper functions for reflection operations

Process called "find_method" that takes type_name as String and method_name as String and arg_types as List[String] returns Optional[MethodInfo]:
    Let compatible_methods be get_compatible_methods with type_name as type_name and method_name as method_name and arg_types as arg_types
    
    If length of compatible_methods is equal to 0:
        Return None
    
    If length of compatible_methods is equal to 1:
        Return Some with value as compatible_methods[0]
    
    Return get_most_specific_method with methods as compatible_methods and arg_types as arg_types

Process called "find_static_method" that takes type_name as String and method_name as String and arg_types as List[String] returns Optional[MethodInfo]:
    Let method_info be find_method with type_name as type_name and method_name as method_name and arg_types as arg_types
    
    If method_info is None:
        Return None
    
    If not method_info.is_static:
        Return None
    
    Return method_info

Process called "find_property" that takes type_name as String and property_name as String returns Optional[PropertyInfo]:
    Let properties be get_properties with type_name as type_name
    For each property in properties:
        If property.name is equal to property_name:
            Return Some with value as property
    Return None

Process called "find_field" that takes type_name as String and field_name as String returns Optional[FieldInfo]:
    Let fields be get_fields with type_name as type_name
    For each field in fields:
        If field.name is equal to field_name:
            Return Some with value as field
    Return None

Process called "find_constructor" that takes type_name as String and arg_types as List[String] returns Optional[ConstructorInfo]:
    Let constructors be get_constructors with type_name as type_name
    
    For each constructor in constructors:
        If length of constructor.parameter_types is equal to length of arg_types:
            Let compatible be true
            For i from 0 to length of constructor.parameter_types - 1:
                If not is_assignable_from with target_type as constructor.parameter_types[i] and source_type as arg_types[i]:
                    Set compatible to false
                    Break
            If compatible:
                Return Some with value as constructor
    
    Return None

Process called "get_arg_types" that takes args as List[Any] returns List[String]:
    Let arg_types be list containing
    For each arg in args:
        Add Primitives.get_type_name with value as arg to arg_types
    Return arg_types

Note: Error types

Type called "ReflectionError":
    message as String
    error_type as ReflectionErrorType

Type ReflectionErrorType is:
    | TypeNotFound
    | MethodNotFound
    | PropertyNotFound
    | FieldNotFound
    | ConstructorNotFound
    | InvocationError
    | AccessError
    | CompilationError

Note: Platform integration functions (delegated to builtins)

Process called "get_runtime_type" that takes name as String returns Optional[Any]:
    Return Builtins.get_runtime_type with name as name

Process called "get_runtime_methods" that takes type_name as String returns List[Any]:
    Return Builtins.get_runtime_methods with type_name as type_name

Process called "get_runtime_properties" that takes type_name as String returns List[Any]:
    Return Builtins.get_runtime_properties with type_name as type_name

Process called "get_runtime_fields" that takes type_name as String returns List[Any]:
    Return Builtins.get_runtime_fields with type_name as type_name

Process called "get_runtime_constructors" that takes type_name as String returns List[Any]:
    Return Builtins.get_runtime_constructors with type_name as type_name

Process called "invoke_method_with_info" that takes instance as Any and method as MethodInfo and args as List[Any] returns Any:
    Return Builtins.invoke_method_with_info with instance as instance and method as method and args as args

Process called "invoke_static_method_with_info" that takes type_name as String and method as MethodInfo and args as List[Any] returns Any:
    Return Builtins.invoke_static_method_with_info with type_name as type_name and method as method and args as args

Process called "get_property_value_with_info" that takes instance as Any and property as PropertyInfo returns Any:
    Return Builtins.get_property_value_with_info with instance as instance and property as property

Process called "set_property_value_with_info" that takes instance as Any and property as PropertyInfo and value as Any returns None:
    Builtins.set_property_value_with_info with instance as instance and property as property and value as value

Process called "get_field_value_with_info" that takes instance as Any and field as FieldInfo returns Any:
    Return Builtins.get_field_value_with_info with instance as instance and field as field

Process called "set_field_value_with_info" that takes instance as Any and field as FieldInfo and value as Any returns None:
    Builtins.set_field_value_with_info with instance as instance and field as field and value as value

Process called "invoke_constructor" that takes constructor as ConstructorInfo and args as List[Any] returns Any:
    Return Builtins.invoke_constructor with constructor as constructor and args as args

Process called "create_array_with_type_and_length" that takes element_type as String and length as Integer returns Any:
    Return Builtins.create_array_with_type_and_length with element_type as element_type and length as length

Process called "compile_and_execute_code" that takes code as String returns Any:
    Return Builtins.compile_and_execute_code with code as code

Process called "compile_lambda" that takes code as String returns Function:
    Return Builtins.compile_lambda with code as code

Process called "build_lambda_code" that takes parameters as List[String] and body as String returns String:
    Return Builtins.build_lambda_code with parameters as parameters and body as body

