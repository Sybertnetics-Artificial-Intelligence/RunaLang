Note: Runa Standard Library - Union Types System
Note: Discriminated unions, algebraic data types, and sum type utilities
Note: Provides type-safe union operations, pattern matching, and variant management

Import "builtins" as Builtins
Import "collections" as Collections
Import "types/primitives" as Primitives
Import "types/generics" as Generics
Import "types/protocols" as Protocols

Note: Core union type system

Type called "UnionType":
    name as String
    variants as List[VariantDefinition]
    type_parameters as List[String]
    is_generic as Boolean
    is_exhaustive as Boolean
    documentation as Optional[String]
    
    Process called "create" that takes name as String returns UnionType:
        Return UnionType with:
            name as name
            variants as list containing
            type_parameters as list containing
            is_generic as false
            is_exhaustive as true
            documentation as None

Type called "VariantDefinition":
    name as String
    fields as List[FieldDefinition]
    discriminator as Optional[String]
    is_singleton as Boolean
    
    Process called "create" that takes name as String returns VariantDefinition:
        Return VariantDefinition with:
            name as name
            fields as list containing
            discriminator as None
            is_singleton as true

Type called "FieldDefinition":
    name as String
    field_type as String
    is_optional as Boolean
    default_value as Optional[Any]

Type called "UnionValue":
    union_type as String
    variant_name as String
    variant_data as Dictionary[String, Any]
    discriminator_value as Optional[Any]
    
    Process called "create" that takes union_type as String and variant_name as String returns UnionValue:
        Return UnionValue with:
            union_type as union_type
            variant_name as variant_name
            variant_data as dictionary containing
            discriminator_value as None

Note: Variant construction and management

Process called "create_variant" that takes union_type as String and variant_name as String and data as Dictionary[String, Any] returns UnionValue:
    Let union_def be get_union_definition with name as union_type
    If union_def is None:
        Throw UnionError with message as f"Union type {union_type} not found"
    
    Let variant_def be find_variant_definition with union as union_def and variant_name as variant_name
    If variant_def is None:
        Throw UnionError with message as f"Variant {variant_name} not found in union {union_type}"
    
    Note: Validate variant data
    Let validation_result be validate_variant_data with variant as variant_def and data as data
    If not validation_result.is_valid:
        Throw UnionError with message as f"Invalid data for variant {variant_name}: {validation_result.error_message}"
    
    Let union_value be UnionValue.create with union_type as union_type and variant_name as variant_name
    Set union_value.variant_data to data
    
    If variant_def.discriminator is not None:
        Set union_value.discriminator_value to Some with value as data[variant_def.discriminator]
    
    Return union_value

Process called "create_singleton_variant" that takes union_type as String and variant_name as String returns UnionValue:
    Return create_variant with union_type as union_type and variant_name as variant_name and data as dictionary containing

Process called "with_field" that takes union_value as UnionValue and field_name as String and value as Any returns UnionValue:
    Let new_data be union_value.variant_data.copy()
    Set new_data[field_name] to value
    
    Return create_variant with:
        union_type as union_value.union_type
        variant_name as union_value.variant_name
        data as new_data

Process called "get_field" that takes union_value as UnionValue and field_name as String returns Optional[Any]:
    If field_name is in union_value.variant_data:
        Return Some with value as union_value.variant_data[field_name]
    Return None

Process called "has_field" that takes union_value as UnionValue and field_name as String returns Boolean:
    Return field_name is in union_value.variant_data

Process called "get_variant_name" that takes union_value as UnionValue returns String:
    Return union_value.variant_name

Process called "get_union_type_name" that takes union_value as UnionValue returns String:
    Return union_value.union_type

Note: Pattern matching and type checking

Process called "match_variant" that takes union_value as UnionValue and variant_name as String returns Boolean:
    Return union_value.variant_name is equal to variant_name

Process called "extract_variant_data" that takes union_value as UnionValue and variant_name as String returns Optional[Dictionary[String, Any]]:
    If match_variant with union_value as union_value and variant_name as variant_name:
        Return Some with value as union_value.variant_data
    Return None

Process called "is_variant" that takes value as Any and union_type as String and variant_name as String returns Boolean:
    If not is_union_value with value as value:
        Return false
    
    Let union_value be value as UnionValue
    Return union_value.union_type is equal to union_type and union_value.variant_name is equal to variant_name

Process called "is_union_value" that takes value as Any returns Boolean:
    Return Primitives.get_type_name with value as value is equal to "UnionValue"

Process called "extract_if_variant"[T] that takes union_value as UnionValue and variant_name as String and extractor as Function[Dictionary[String, Any], T] returns Optional[T]:
    Let variant_data be extract_variant_data with union_value as union_value and variant_name as variant_name
    If variant_data is None:
        Return None
    
    Try:
        Return Some with value as extractor with data as variant_data
    Catch extraction_error:
        Return None

Note: Union type validation and analysis

Type called "ValidationResult":
    is_valid as Boolean
    error_message as String
    missing_fields as List[String]
    type_mismatches as List[String]

Process called "validate_variant_data" that takes variant as VariantDefinition and data as Dictionary[String, Any] returns ValidationResult:
    Let result be ValidationResult with:
        is_valid as true
        error_message as ""
        missing_fields as list containing
        type_mismatches as list containing
    
    Note: Check required fields
    For each field_def in variant.fields:
        If not field_def.is_optional and field_def.name is not in data:
            Add field_def.name to result.missing_fields
            Set result.is_valid to false
    
    Note: Check field types
    For each field_name and value in data:
        Let field_def be find_field_definition with variant as variant and field_name as field_name
        If field_def is not None:
            Let value_type be Primitives.get_type_name with value as value
            If not is_compatible_type with expected as field_def.field_type and actual as value_type:
                Add f"Field {field_name}: expected {field_def.field_type}, got {value_type}" to result.type_mismatches
                Set result.is_valid to false
    
    If not result.is_valid:
        Let error_parts be list containing
        If length of result.missing_fields is greater than 0:
            Add f"Missing fields: {join_strings with strings as result.missing_fields and separator as \", \"}" to error_parts
        If length of result.type_mismatches is greater than 0:
            Add f"Type mismatches: {join_strings with strings as result.type_mismatches and separator as \"; \"}" to error_parts
        Set result.error_message to join_strings with strings as error_parts and separator as "; "
    
    Return result

Process called "is_compatible_type" that takes expected as String and actual as String returns Boolean:
    Return expected is equal to actual or 
           expected is equal to "Any" or
           Generics.is_subtype_of with child as actual and parent as expected

Process called "check_exhaustiveness" that takes union_type as UnionType and handled_variants as List[String] returns ExhaustivenessResult:
    Let missing_variants be list containing
    
    For each variant in union_type.variants:
        If variant.name is not in handled_variants:
            Add variant.name to missing_variants
    
    Return ExhaustivenessResult with:
        is_exhaustive as length of missing_variants is equal to 0
        missing_variants as missing_variants

Type called "ExhaustivenessResult":
    is_exhaustive as Boolean
    missing_variants as List[String]

Note: Union type composition and transformation

Process called "compose_unions" that takes union1 as UnionType and union2 as UnionType returns UnionType:
    Let composed_name be union1.name concatenated with "_and_" concatenated with union2.name
    Let composed be UnionType.create with name as composed_name
    
    Note: Add all variants from both unions
    For each variant in union1.variants:
        Add variant to composed.variants
    
    For each variant in union2.variants:
        Note: Check for name conflicts
        If not has_variant_with_name with union as composed and variant_name as variant.name:
            Add variant to composed.variants
        Otherwise:
            Note: Create qualified variant name
            Let qualified_variant be VariantDefinition with:
                name as variant.name concatenated with "_from_" concatenated with union2.name
                fields as variant.fields
                discriminator as variant.discriminator
                is_singleton as variant.is_singleton
            Add qualified_variant to composed.variants
    
    Return composed

Process called "map_union"[T, U] that takes union_value as UnionValue and mappers as Dictionary[String, Function[T, U]] returns Optional[U]:
    Let variant_name be union_value.variant_name
    
    If variant_name is not in mappers:
        Return None
    
    Let mapper be mappers[variant_name]
    
    Try:
        Note: Extract the variant data and apply the mapper
        Let data be union_value.variant_data
        Return Some with value as mapper with input as data as T
    Catch mapping_error:
        Return None

Process called "fold_union"[T] that takes union_value as UnionValue and folders as Dictionary[String, Function[Dictionary[String, Any], T]] returns Optional[T]:
    Let variant_name be union_value.variant_name
    
    If variant_name is not in folders:
        Return None
    
    Let folder be folders[variant_name]
    
    Try:
        Return Some with value as folder with data as union_value.variant_data
    Catch folding_error:
        Return None

Process called "transform_union" that takes union_value as UnionValue and transformers as Dictionary[String, Function[Dictionary[String, Any], UnionValue]] returns Optional[UnionValue]:
    Let variant_name be union_value.variant_name
    
    If variant_name is not in transformers:
        Return None
    
    Let transformer be transformers[variant_name]
    
    Try:
        Return Some with value as transformer with data as union_value.variant_data
    Catch transformation_error:
        Return None

Note: Common union type patterns

Process called "create_option_type" returns UnionType:
    Let some_variant be VariantDefinition.create with name as "Some"
    Add FieldDefinition with:
        name as "value"
        field_type as "T"
        is_optional as false
        default_value as None
    to some_variant.fields
    Set some_variant.is_singleton to false
    
    Let none_variant be VariantDefinition.create with name as "None"
    
    Let option_type be UnionType.create with name as "Option"
    Add some_variant to option_type.variants
    Add none_variant to option_type.variants
    Add "T" to option_type.type_parameters
    Set option_type.is_generic to true
    
    Return option_type

Process called "create_result_type" returns UnionType:
    Let success_variant be VariantDefinition.create with name as "Success"
    Add FieldDefinition with:
        name as "value"
        field_type as "T"
        is_optional as false
        default_value as None
    to success_variant.fields
    Set success_variant.is_singleton to false
    
    Let error_variant be VariantDefinition.create with name as "Error"
    Add FieldDefinition with:
        name as "error"
        field_type as "E"
        is_optional as false
        default_value as None
    to error_variant.fields
    Set error_variant.is_singleton to false
    
    Let result_type be UnionType.create with name as "Result"
    Add success_variant to result_type.variants
    Add error_variant to result_type.variants
    Add "T" to result_type.type_parameters
    Add "E" to result_type.type_parameters
    Set result_type.is_generic to true
    
    Return result_type

Process called "create_either_type" returns UnionType:
    Let left_variant be VariantDefinition.create with name as "Left"
    Add FieldDefinition with:
        name as "value"
        field_type as "L"
        is_optional as false
        default_value as None
    to left_variant.fields
    Set left_variant.is_singleton to false
    
    Let right_variant be VariantDefinition.create with name as "Right"
    Add FieldDefinition with:
        name as "value"
        field_type as "R"
        is_optional as false
        default_value as None
    to right_variant.fields
    Set right_variant.is_singleton to false
    
    Let either_type be UnionType.create with name as "Either"
    Add left_variant to either_type.variants
    Add right_variant to either_type.variants
    Add "L" to either_type.type_parameters
    Add "R" to either_type.type_parameters
    Set either_type.is_generic to true
    
    Return either_type

Note: Convenience functions for common union types

Process called "some"[T] that takes value as T returns UnionValue:
    Return create_variant with:
        union_type as "Option[T]"
        variant_name as "Some"
        data as dictionary with "value" as value

Process called "none"[T] returns UnionValue:
    Return create_singleton_variant with:
        union_type as "Option[T]"
        variant_name as "None"

Process called "success"[T, E] that takes value as T returns UnionValue:
    Return create_variant with:
        union_type as "Result[T, E]"
        variant_name as "Success"
        data as dictionary with "value" as value

Process called "error"[T, E] that takes error_value as E returns UnionValue:
    Return create_variant with:
        union_type as "Result[T, E]"
        variant_name as "Error"
        data as dictionary with "error" as error_value

Process called "left"[L, R] that takes value as L returns UnionValue:
    Return create_variant with:
        union_type as "Either[L, R]"
        variant_name as "Left"
        data as dictionary with "value" as value

Process called "right"[L, R] that takes value as R returns UnionValue:
    Return create_variant with:
        union_type as "Either[L, R]"
        variant_name as "Right"
        data as dictionary with "value" as value

Note: Union value operations and utilities

Process called "is_some" that takes option_value as UnionValue returns Boolean:
    Return match_variant with union_value as option_value and variant_name as "Some"

Process called "is_none" that takes option_value as UnionValue returns Boolean:
    Return match_variant with union_value as option_value and variant_name as "None"

Process called "is_success" that takes result_value as UnionValue returns Boolean:
    Return match_variant with union_value as result_value and variant_name as "Success"

Process called "is_error" that takes result_value as UnionValue returns Boolean:
    Return match_variant with union_value as result_value and variant_name as "Error"

Process called "unwrap_or"[T] that takes option_value as UnionValue and default_value as T returns T:
    If is_some with option_value as option_value:
        Let some_data be extract_variant_data with union_value as option_value and variant_name as "Some"
        If some_data is not None:
            Return some_data["value"] as T
    Return default_value

Process called "unwrap_or_else"[T] that takes option_value as UnionValue and default_fn as Function[T] returns T:
    If is_some with option_value as option_value:
        Let some_data be extract_variant_data with union_value as option_value and variant_name as "Some"
        If some_data is not None:
            Return some_data["value"] as T
    Return default_fn()

Process called "map_option"[T, U] that takes option_value as UnionValue and mapper as Function[T, U] returns UnionValue:
    If is_some with option_value as option_value:
        Let some_data be extract_variant_data with union_value as option_value and variant_name as "Some"
        If some_data is not None:
            Let mapped_value be mapper with input as some_data["value"] as T
            Return some with value as mapped_value
    Return option_value

Process called "flat_map_option"[T, U] that takes option_value as UnionValue and mapper as Function[T, UnionValue] returns UnionValue:
    If is_some with option_value as option_value:
        Let some_data be extract_variant_data with union_value as option_value and variant_name as "Some"
        If some_data is not None:
            Return mapper with input as some_data["value"] as T
    Return option_value

Process called "filter_option"[T] that takes option_value as UnionValue and predicate as Function[T, Boolean] returns UnionValue:
    If is_some with option_value as option_value:
        Let some_data be extract_variant_data with union_value as option_value and variant_name as "Some"
        If some_data is not None:
            If predicate with input as some_data["value"] as T:
                Return option_value
    Return none[T]()

Note: Tagged union support

Type called "TaggedUnion":
    tag_field as String
    value_field as String
    tag_mappings as Dictionary[Any, String]
    
    Process called "create" that takes tag_field as String and value_field as String returns TaggedUnion:
        Return TaggedUnion with:
            tag_field as tag_field
            value_field as value_field
            tag_mappings as dictionary containing

Process called "add_tag_mapping" that takes tagged_union as TaggedUnion and tag_value as Any and variant_name as String returns None:
    Set tagged_union.tag_mappings[tag_value] to variant_name

Process called "create_tagged_value" that takes tagged_union as TaggedUnion and tag_value as Any and value as Any returns UnionValue:
    If tag_value is not in tagged_union.tag_mappings:
        Throw UnionError with message as f"Unknown tag value: {tag_value}"
    
    Let variant_name be tagged_union.tag_mappings[tag_value]
    Let data be dictionary with:
        tagged_union.tag_field as tag_value
        tagged_union.value_field as value
    
    Return create_variant with:
        union_type as "TaggedUnion"
        variant_name as variant_name
        data as data

Process called "extract_tagged_value" that takes tagged_union as TaggedUnion and union_value as UnionValue returns Optional[Any]:
    If tagged_union.value_field is in union_value.variant_data:
        Return Some with value as union_value.variant_data[tagged_union.value_field]
    Return None

Process called "get_tag_value" that takes tagged_union as TaggedUnion and union_value as UnionValue returns Optional[Any]:
    If tagged_union.tag_field is in union_value.variant_data:
        Return Some with value as union_value.variant_data[tagged_union.tag_field]
    Return None

Note: Helper functions for union management

Process called "find_variant_definition" that takes union as UnionType and variant_name as String returns Optional[VariantDefinition]:
    For each variant in union.variants:
        If variant.name is equal to variant_name:
            Return Some with value as variant
    Return None

Process called "find_field_definition" that takes variant as VariantDefinition and field_name as String returns Optional[FieldDefinition]:
    For each field in variant.fields:
        If field.name is equal to field_name:
            Return Some with value as field
    Return None

Process called "has_variant_with_name" that takes union as UnionType and variant_name as String returns Boolean:
    For each variant in union.variants:
        If variant.name is equal to variant_name:
            Return true
    Return false

Process called "get_variant_names" that takes union as UnionType returns List[String]:
    Let names be list containing
    For each variant in union.variants:
        Add variant.name to names
    Return names

Process called "get_field_names" that takes variant as VariantDefinition returns List[String]:
    Let names be list containing
    For each field in variant.fields:
        Add field.name to names
    Return names

Process called "union_to_string" that takes union_value as UnionValue returns String:
    Let variant_data_str be dictionary_to_string with dict as union_value.variant_data
    Return f"{union_value.union_type}::{union_value.variant_name}({variant_data_str})"

Note: Error types

Type called "UnionError":
    message as String
    error_type as UnionErrorType

Type UnionErrorType is:
    | UnionNotFound
    | VariantNotFound
    | FieldNotFound
    | ValidationError
    | ExtractionError
    | TagError

Note: Platform integration functions (delegated to builtins)

Process called "get_union_definition" that takes name as String returns Optional[UnionType]:
    Return Builtins.get_union_definition with name as name

Process called "register_union_type" that takes union_type as UnionType returns None:
    Builtins.register_union_type with union_type as union_type

Process called "join_strings" that takes strings as List[String] and separator as String returns String:
    Return Builtins.join_strings with strings as strings and separator as separator

Process called "dictionary_to_string" that takes dict as Dictionary[String, Any] returns String:
    Return Builtins.dictionary_to_string with dict as dict

