Note: Runa Standard Library - Protocol System
Note: Structural typing, interface definitions, and protocol-based polymorphism
Note: Provides protocol conformance checking, dynamic dispatch, and composition

Import "builtins" as Builtins
Import "collections" as Collections
Import "types/primitives" as Primitives
Import "types/generics" as Generics

Note: Core protocol system types

Type called "Protocol":
    name as String
    methods as List[MethodSignature]
    properties as List[PropertySignature]
    type_parameters as List[Generics.TypeParameter]
    constraints as List[ProtocolConstraint]
    documentation as Optional[String]
    
    Process called "create" that takes name as String returns Protocol:
        Return Protocol with:
            name as name
            methods as list containing
            properties as list containing
            type_parameters as list containing
            constraints as list containing
            documentation as None

Type called "MethodSignature":
    name as String
    parameters as List[ParameterSignature]
    return_type as String
    is_static as Boolean
    is_optional as Boolean
    generic_parameters as List[String]
    constraints as List[String]
    
    Process called "create" that takes name as String and return_type as String returns MethodSignature:
        Return MethodSignature with:
            name as name
            parameters as list containing
            return_type as return_type
            is_static as false
            is_optional as false
            generic_parameters as list containing
            constraints as list containing

Type called "ParameterSignature":
    name as String
    parameter_type as String
    is_optional as Boolean
    default_value as Optional[String]
    
Type called "PropertySignature":
    name as String
    property_type as String
    is_readonly as Boolean
    is_optional as Boolean
    getter_required as Boolean
    setter_required as Boolean

Type called "ProtocolConstraint":
    constraint_type as ProtocolConstraintType
    target_protocol as String
    relationship as ProtocolRelationship

Type ProtocolConstraintType is:
    | Inherits
    | Implements
    | Excludes
    | Requires

Type ProtocolRelationship is:
    | Extends
    | Composes
    | Conflicts
    | Depends

Note: Protocol conformance and checking

Type called "ConformanceResult":
    conforms as Boolean
    missing_methods as List[String]
    missing_properties as List[String]
    type_mismatches as List[TypeMismatch]
    constraint_violations as List[String]

Type called "TypeMismatch":
    member_name as String
    expected_type as String
    actual_type as String
    mismatch_type as MismatchType

Type MismatchType is:
    | ParameterType
    | ReturnType
    | PropertyType
    | Variance

Process called "check_protocol_conformance" that takes type_name as String and protocol as Protocol returns ConformanceResult:
    Let result be ConformanceResult with:
        conforms as true
        missing_methods as list containing
        missing_properties as list containing
        type_mismatches as list containing
        constraint_violations as list containing
    
    Note: Check required methods
    For each method in protocol.methods:
        If not method.is_optional:
            If not type_has_method with type_name as type_name and method_sig as method:
                Add method.name to result.missing_methods
                Set result.conforms to false
            Otherwise:
                Let type_mismatch be check_method_signature_match with:
                    type_name as type_name
                    expected as method
                If type_mismatch is not None:
                    Add type_mismatch to result.type_mismatches
                    Set result.conforms to false
    
    Note: Check required properties
    For each property in protocol.properties:
        If not property.is_optional:
            If not type_has_property with type_name as type_name and property_sig as property:
                Add property.name to result.missing_properties
                Set result.conforms to false
            Otherwise:
                Let property_mismatch be check_property_signature_match with:
                    type_name as type_name
                    expected as property
                If property_mismatch is not None:
                    Add property_mismatch to result.type_mismatches
                    Set result.conforms to false
    
    Note: Check protocol constraints
    For each constraint in protocol.constraints:
        If not check_protocol_constraint with type_name as type_name and constraint as constraint:
            Add f"Constraint violation: {constraint.constraint_type}" to result.constraint_violations
            Set result.conforms to false
    
    Return result

Process called "type_has_method" that takes type_name as String and method_sig as MethodSignature returns Boolean:
    Let type_methods be get_type_methods with type_name as type_name
    
    For each type_method in type_methods:
        If type_method.name is equal to method_sig.name:
            Return true
    
    Return false

Process called "type_has_property" that takes type_name as String and property_sig as PropertySignature returns Boolean:
    Let type_properties be get_type_properties with type_name as type_name
    
    For each type_property in type_properties:
        If type_property.name is equal to property_sig.name:
            Return true
    
    Return false

Process called "check_method_signature_match" that takes type_name as String and expected as MethodSignature returns Optional[TypeMismatch]:
    Let actual_method be get_method_signature with type_name as type_name and method_name as expected.name
    
    If actual_method is None:
        Return None
    
    Note: Check return type compatibility
    If not is_compatible_type with expected_type as expected.return_type and actual_type as actual_method.return_type:
        Return Some with value as TypeMismatch with:
            member_name as expected.name
            expected_type as expected.return_type
            actual_type as actual_method.return_type
            mismatch_type as MismatchType.ReturnType
    
    Note: Check parameter compatibility
    If length of expected.parameters is not equal to length of actual_method.parameters:
        Return Some with value as TypeMismatch with:
            member_name as expected.name
            expected_type as f"{length of expected.parameters} parameters"
            actual_type as f"{length of actual_method.parameters} parameters"
            mismatch_type as MismatchType.ParameterType
    
    For i from 0 to length of expected.parameters - 1:
        Let expected_param be expected.parameters[i]
        Let actual_param be actual_method.parameters[i]
        
        If not is_compatible_type with expected_type as expected_param.parameter_type and actual_type as actual_param.parameter_type:
            Return Some with value as TypeMismatch with:
                member_name as f"{expected.name}.{expected_param.name}"
                expected_type as expected_param.parameter_type
                actual_type as actual_param.parameter_type
                mismatch_type as MismatchType.ParameterType
    
    Return None

Process called "check_property_signature_match" that takes type_name as String and expected as PropertySignature returns Optional[TypeMismatch]:
    Let actual_property be get_property_signature with type_name as type_name and property_name as expected.name
    
    If actual_property is None:
        Return None
    
    If not is_compatible_type with expected_type as expected.property_type and actual_type as actual_property.property_type:
        Return Some with value as TypeMismatch with:
            member_name as expected.name
            expected_type as expected.property_type
            actual_type as actual_property.property_type
            mismatch_type as MismatchType.PropertyType
    
    Note: Check read/write compatibility
    If expected.is_readonly and not actual_property.is_readonly:
        Return Some with value as TypeMismatch with:
            member_name as expected.name
            expected_type as "readonly"
            actual_type as "read-write"
            mismatch_type as MismatchType.PropertyType
    
    Return None

Process called "is_compatible_type" that takes expected_type as String and actual_type as String returns Boolean:
    Return actual_type is equal to expected_type or 
           Generics.is_subtype_of with child as actual_type and parent as expected_type

Note: Protocol composition and inheritance

Process called "compose_protocols" that takes protocols as List[Protocol] returns Protocol:
    If length of protocols is equal to 0:
        Throw ProtocolError with message as "Cannot compose empty protocol list"
    
    If length of protocols is equal to 1:
        Return protocols[0]
    
    Let composed_name be join_protocol_names with protocols as protocols
    Let composed be Protocol.create with name as composed_name
    
    Note: Merge all methods and properties
    For each protocol in protocols:
        For each method in protocol.methods:
            If not has_method_with_name with protocol as composed and method_name as method.name:
                Add method to composed.methods
            Otherwise:
                Note: Check for conflicts and merge if compatible
                Let existing_method be find_method_by_name with protocol as composed and method_name as method.name
                Let merged_method be merge_method_signatures with existing as existing_method and new as method
                replace_method_in_protocol with protocol as composed and old_method as existing_method and new_method as merged_method
        
        For each property in protocol.properties:
            If not has_property_with_name with protocol as composed and property_name as property.name:
                Add property to composed.properties
            Otherwise:
                Let existing_property be find_property_by_name with protocol as composed and property_name as property.name
                Let merged_property be merge_property_signatures with existing as existing_property and new as property
                replace_property_in_protocol with protocol as composed and old_property as existing_property and new_property as merged_property
    
    Return composed

Process called "extend_protocol" that takes base as Protocol and extension as Protocol returns Protocol:
    Let extended be Protocol with:
        name as base.name concatenated with "_extended_with_" concatenated with extension.name
        methods as base.methods.copy()
        properties as base.properties.copy()
        type_parameters as base.type_parameters.copy()
        constraints as base.constraints.copy()
        documentation as base.documentation
    
    Note: Add extension methods and properties
    For each method in extension.methods:
        If not has_method_with_name with protocol as extended and method_name as method.name:
            Add method to extended.methods
        Otherwise:
            Note: Override base method with extension method
            Let base_method be find_method_by_name with protocol as extended and method_name as method.name
            replace_method_in_protocol with protocol as extended and old_method as base_method and new_method as method
    
    For each property in extension.properties:
        If not has_property_with_name with protocol as extended and property_name as property.name:
            Add property to extended.properties
        Otherwise:
            Let base_property be find_property_by_name with protocol as extended and property_name as property.name
            replace_property_in_protocol with protocol as extended and old_property as base_property and new_property as property
    
    Return extended

Note: Dynamic protocol dispatch

Type called "ProtocolDispatcher":
    registered_implementations as Dictionary[String, List[ProtocolImplementation]]
    
    Process called "create" returns ProtocolDispatcher:
        Return ProtocolDispatcher with:
            registered_implementations as dictionary containing

Type called "ProtocolImplementation":
    type_name as String
    protocol_name as String
    implementation_methods as Dictionary[String, Function]
    conformance_check as Function[Any, Boolean]

Process called "register_implementation" that takes dispatcher as ProtocolDispatcher and impl as ProtocolImplementation returns None:
    If impl.protocol_name is not in dispatcher.registered_implementations:
        Set dispatcher.registered_implementations[impl.protocol_name] to list containing
    
    Add impl to dispatcher.registered_implementations[impl.protocol_name]

Process called "find_implementation" that takes dispatcher as ProtocolDispatcher and value as Any and protocol_name as String returns Optional[ProtocolImplementation]:
    If protocol_name is not in dispatcher.registered_implementations:
        Return None
    
    Let implementations be dispatcher.registered_implementations[protocol_name]
    Let value_type be Primitives.get_type_name with value as value
    
    For each impl in implementations:
        If impl.type_name is equal to value_type:
            If impl.conformance_check with value as value:
                Return Some with value as impl
        Otherwise:
            Note: Check for subtype relationships
            If Generics.is_subtype_of with child as value_type and parent as impl.type_name:
                If impl.conformance_check with value as value:
                    Return Some with value as impl
    
    Return None

Process called "dispatch_method" that takes dispatcher as ProtocolDispatcher and value as Any and protocol_name as String and method_name as String and args as List[Any] returns Any:
    Let impl be find_implementation with dispatcher as dispatcher and value as value and protocol_name as protocol_name
    
    If impl is None:
        Throw ProtocolError with message as f"No implementation found for protocol {protocol_name} on type {Primitives.get_type_name with value as value}"
    
    If method_name is not in impl.implementation_methods:
        Throw ProtocolError with message as f"Method {method_name} not found in protocol implementation"
    
    Let method_impl be impl.implementation_methods[method_name]
    Return call_function_with_args with function as method_impl and arguments as args

Note: Protocol-based type classes and higher-order abstractions

Type called "TypeClass":
    name as String
    protocol as Protocol
    laws as List[TypeClassLaw]
    default_implementations as Dictionary[String, Function]
    instances as List[TypeClassInstance]

Type called "TypeClassLaw":
    name as String
    description as String
    check_function as Function[Any, Boolean]

Type called "TypeClassInstance":
    type_name as String
    instance_methods as Dictionary[String, Function]
    law_proofs as Dictionary[String, Function]

Process called "create_type_class" that takes name as String and protocol as Protocol returns TypeClass:
    Return TypeClass with:
        name as name
        protocol as protocol
        laws as list containing
        default_implementations as dictionary containing
        instances as list containing

Process called "add_type_class_instance" that takes type_class as TypeClass and instance as TypeClassInstance returns None:
    Note: Verify the instance conforms to the protocol
    Let conformance be check_protocol_conformance with type_name as instance.type_name and protocol as type_class.protocol
    
    If not conformance.conforms:
        Throw ProtocolError with message as f"Type {instance.type_name} does not conform to protocol {type_class.protocol.name}"
    
    Note: Check type class laws
    For each law in type_class.laws:
        If law.name is not in instance.law_proofs:
            Throw ProtocolError with message as f"Type class instance missing proof for law: {law.name}"
    
    Add instance to type_class.instances

Process called "find_type_class_instance" that takes type_class as TypeClass and type_name as String returns Optional[TypeClassInstance]:
    For each instance in type_class.instances:
        If instance.type_name is equal to type_name:
            Return Some with value as instance
        If Generics.is_subtype_of with child as type_name and parent as instance.type_name:
            Return Some with value as instance
    
    Return None

Note: Common protocol definitions

Process called "create_equatable_protocol" returns Protocol:
    Let equals_method be MethodSignature.create with name as "equals" and return_type as "Boolean"
    Add ParameterSignature with:
        name as "other"
        parameter_type as "Self"
        is_optional as false
        default_value as None
    to equals_method.parameters
    
    Let hash_method be MethodSignature.create with name as "hash_code" and return_type as "Integer"
    
    Let protocol be Protocol.create with name as "Equatable"
    Add equals_method to protocol.methods
    Add hash_method to protocol.methods
    
    Return protocol

Process called "create_comparable_protocol" returns Protocol:
    Let equatable be create_equatable_protocol()
    
    Let compare_method be MethodSignature.create with name as "compare_to" and return_type as "Integer"
    Add ParameterSignature with:
        name as "other"
        parameter_type as "Self"
        is_optional as false
        default_value as None
    to compare_method.parameters
    
    Let extended be extend_protocol with base as equatable and extension as Protocol.create with name as "ComparableExtension"
    Add compare_method to extended.methods
    Set extended.name to "Comparable"
    
    Return extended

Process called "create_iterable_protocol" returns Protocol:
    Let iterator_method be MethodSignature.create with name as "iterator" and return_type as "Iterator[T]"
    Add "T" to iterator_method.generic_parameters
    
    Let protocol be Protocol.create with name as "Iterable"
    Add Generics.TypeParameter.create with name as "T" to protocol.type_parameters
    Add iterator_method to protocol.methods
    
    Return protocol

Process called "create_functor_protocol" returns Protocol:
    Let map_method be MethodSignature.create with name as "map" and return_type as "F[U]"
    Add "T" to map_method.generic_parameters
    Add "U" to map_method.generic_parameters
    Add ParameterSignature with:
        name as "transform"
        parameter_type as "Function[T, U]"
        is_optional as false
        default_value as None
    to map_method.parameters
    
    Let protocol be Protocol.create with name as "Functor"
    Add Generics.TypeParameter.create with name as "F" to protocol.type_parameters
    Add Generics.TypeParameter.create with name as "T" to protocol.type_parameters
    Add map_method to protocol.methods
    
    Return protocol

Process called "create_monad_protocol" returns Protocol:
    Let functor be create_functor_protocol()
    
    Let bind_method be MethodSignature.create with name as "flat_map" and return_type as "M[U]"
    Add "T" to bind_method.generic_parameters
    Add "U" to bind_method.generic_parameters
    Add ParameterSignature with:
        name as "transform"
        parameter_type as "Function[T, M[U]]"
        is_optional as false
        default_value as None
    to bind_method.parameters
    
    Let unit_method be MethodSignature.create with name as "unit" and return_type as "M[T]"
    Set unit_method.is_static to true
    Add "T" to unit_method.generic_parameters
    Add ParameterSignature with:
        name as "value"
        parameter_type as "T"
        is_optional as false
        default_value as None
    to unit_method.parameters
    
    Let extended be extend_protocol with base as functor and extension as Protocol.create with name as "MonadExtension"
    Add bind_method to extended.methods
    Add unit_method to extended.methods
    Set extended.name to "Monad"
    
    Return extended

Note: Protocol validation and analysis

Process called "validate_protocol" that takes protocol as Protocol returns List[ValidationError]:
    Let errors be list containing
    
    Note: Check for duplicate method names
    Let method_names be list containing
    For each method in protocol.methods:
        If method.name is in method_names:
            Add ValidationError with:
                error_type as ValidationErrorType.DuplicateMethod
                message as f"Duplicate method name: {method.name}"
            to errors
        Otherwise:
            Add method.name to method_names
    
    Note: Check for duplicate property names
    Let property_names be list containing
    For each property in protocol.properties:
        If property.name is in property_names:
            Add ValidationError with:
                error_type as ValidationErrorType.DuplicateProperty
                message as f"Duplicate property name: {property.name}"
            to errors
        Otherwise:
            Add property.name to property_names
    
    Note: Check for conflicts between methods and properties
    For each method_name in method_names:
        If method_name is in property_names:
            Add ValidationError with:
                error_type as ValidationErrorType.MethodPropertyConflict
                message as f"Name conflict between method and property: {method_name}"
            to errors
    
    Note: Validate method signatures
    For each method in protocol.methods:
        Let method_errors be validate_method_signature with method as method
        For each error in method_errors:
            Add error to errors
    
    Return errors

Process called "validate_method_signature" that takes method as MethodSignature returns List[ValidationError]:
    Let errors be list containing
    
    Note: Check parameter names for duplicates
    Let param_names be list containing
    For each param in method.parameters:
        If param.name is in param_names:
            Add ValidationError with:
                error_type as ValidationErrorType.DuplicateParameter
                message as f"Duplicate parameter name in method {method.name}: {param.name}"
            to errors
        Otherwise:
            Add param.name to param_names
    
    Note: Check that required parameters come before optional ones
    Let found_optional be false
    For each param in method.parameters:
        If param.is_optional:
            Set found_optional to true
        Otherwise:
            If found_optional:
                Add ValidationError with:
                    error_type as ValidationErrorType.ParameterOrder
                    message as f"Required parameter {param.name} after optional parameter in method {method.name}"
                to errors
    
    Return errors

Type called "ValidationError":
    error_type as ValidationErrorType
    message as String

Type ValidationErrorType is:
    | DuplicateMethod
    | DuplicateProperty
    | MethodPropertyConflict
    | DuplicateParameter
    | ParameterOrder
    | InvalidType
    | CircularDependency

Note: Protocol utilities and helper functions

Process called "join_protocol_names" that takes protocols as List[Protocol] returns String:
    Let names be list containing
    For each protocol in protocols:
        Add protocol.name to names
    Return join with list as names and separator as "_and_"

Process called "has_method_with_name" that takes protocol as Protocol and method_name as String returns Boolean:
    For each method in protocol.methods:
        If method.name is equal to method_name:
            Return true
    Return false

Process called "has_property_with_name" that takes protocol as Protocol and property_name as String returns Boolean:
    For each property in protocol.properties:
        If property.name is equal to property_name:
            Return true
    Return false

Process called "find_method_by_name" that takes protocol as Protocol and method_name as String returns Optional[MethodSignature]:
    For each method in protocol.methods:
        If method.name is equal to method_name:
            Return Some with value as method
    Return None

Process called "find_property_by_name" that takes protocol as Protocol and property_name as String returns Optional[PropertySignature]:
    For each property in protocol.properties:
        If property.name is equal to property_name:
            Return Some with value as property
    Return None

Process called "merge_method_signatures" that takes existing as MethodSignature and new as MethodSignature returns MethodSignature:
    Note: Merge two method signatures, preferring the new one for conflicts
    Return MethodSignature with:
        name as existing.name
        parameters as new.parameters
        return_type as new.return_type
        is_static as new.is_static
        is_optional as existing.is_optional and new.is_optional
        generic_parameters as combine_generic_parameters with existing as existing.generic_parameters and new as new.generic_parameters
        constraints as combine_constraints with existing as existing.constraints and new as new.constraints

Process called "merge_property_signatures" that takes existing as PropertySignature and new as PropertySignature returns PropertySignature:
    Return PropertySignature with:
        name as existing.name
        property_type as new.property_type
        is_readonly as existing.is_readonly or new.is_readonly
        is_optional as existing.is_optional and new.is_optional
        getter_required as existing.getter_required or new.getter_required
        setter_required as existing.setter_required or new.setter_required

Process called "combine_generic_parameters" that takes existing as List[String] and new as List[String] returns List[String]:
    Let combined be existing.copy()
    For each param in new:
        If param is not in combined:
            Add param to combined
    Return combined

Process called "combine_constraints" that takes existing as List[String] and new as List[String] returns List[String]:
    Let combined be existing.copy()
    For each constraint in new:
        If constraint is not in combined:
            Add constraint to combined
    Return combined

Process called "replace_method_in_protocol" that takes protocol as Protocol and old_method as MethodSignature and new_method as MethodSignature returns None:
    For i from 0 to length of protocol.methods - 1:
        If protocol.methods[i].name is equal to old_method.name:
            Set protocol.methods[i] to new_method
            Break

Process called "replace_property_in_protocol" that takes protocol as Protocol and old_property as PropertySignature and new_property as PropertySignature returns None:
    For i from 0 to length of protocol.properties - 1:
        If protocol.properties[i].name is equal to old_property.name:
            Set protocol.properties[i] to new_property
            Break

Note: Error types

Type called "ProtocolError":
    message as String
    error_type as ProtocolErrorType

Type ProtocolErrorType is:
    | ConformanceError
    | CompositionError
    | DispatchError
    | ValidationError

Note: Platform integration functions (delegated to builtins)

Process called "get_type_methods" that takes type_name as String returns List[MethodSignature]:
    Return Builtins.get_type_methods with type_name as type_name

Process called "get_type_properties" that takes type_name as String returns List[PropertySignature]:
    Return Builtins.get_type_properties with type_name as type_name

Process called "get_method_signature" that takes type_name as String and method_name as String returns Optional[MethodSignature]:
    Return Builtins.get_method_signature with type_name as type_name and method_name as method_name

Process called "get_property_signature" that takes type_name as String and property_name as String returns Optional[PropertySignature]:
    Return Builtins.get_property_signature with type_name as type_name and property_name as property_name

Process called "check_protocol_constraint" that takes type_name as String and constraint as ProtocolConstraint returns Boolean:
    Return Builtins.check_protocol_constraint with type_name as type_name and constraint as constraint

Process called "call_function_with_args" that takes function as Function and arguments as List[Any] returns Any:
    Return Builtins.call_function_with_args with function as function and arguments as arguments

Process called "join" that takes list as List[String] and separator as String returns String:
    Return Builtins.join with list as list and separator as separator

