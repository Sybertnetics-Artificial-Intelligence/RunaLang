Note: Timezone Operations Module
Note: Provides comprehensive timezone management, conversions, and calculations
Note: including DST handling, timezone databases, and geographic timezone mapping.

Import "collections/list" as list_utils
Import "collections/dict" as dict_utils

Note: Timezone Types

Type Timezone is Dictionary with:
    name as String
    abbreviation as String
    utc_offset_seconds as Integer
    dst_offset_seconds as Integer
    is_dst_active as Boolean
    dst_start_rule as Optional[Dictionary[String, Any]]
    dst_end_rule as Optional[Dictionary[String, Any]]
    country_code as Optional[String]
    region as Optional[String]
    coordinates as Optional[Dictionary[String, Float]]
    metadata as Dictionary[String, Any]

Type TimezoneOffset is Dictionary with:
    hours as Integer
    minutes as Integer
    total_seconds as Integer
    is_negative as Boolean

Type DSTRule is Dictionary with:
    month as Integer
    week as Integer
    day_of_week as Integer
    time_hour as Integer
    time_minute as Integer
    offset_change as Integer
    rule_type as String

Type TimezoneConversion is Dictionary with:
    source_timezone as Timezone
    target_timezone as Timezone
    offset_difference as Integer
    requires_dst_calculation as Boolean
    conversion_timestamp as Integer

Note: Timezone Creation and Lookup Operations

Process called "create_timezone" that takes name as String and utc_offset_hours as Float and abbreviation as Optional[String] returns Timezone:
    Note: Create a basic timezone with UTC offset
    Try:
        Let offset_seconds be utc_offset_hours times 3600 as Integer
        Let final_abbreviation be abbreviation or extract_abbreviation_from_name with name as name
        
        Return Timezone with:
            name as name
            abbreviation as final_abbreviation
            utc_offset_seconds as offset_seconds
            dst_offset_seconds as 0
            is_dst_active as false
            dst_start_rule as none
            dst_end_rule as none
            country_code as none
            region as none
            coordinates as none
            metadata as empty dictionary
    
    Catch error as Exception:
        Throw TimezoneError with message as "Failed to create timezone: " plus error as string

Process called "get_utc_timezone" that returns Timezone:
    Note: Get the UTC timezone
    Return Timezone with:
        name as "Coordinated Universal Time"
        abbreviation as "UTC"
        utc_offset_seconds as 0
        dst_offset_seconds as 0
        is_dst_active as false
        dst_start_rule as none
        dst_end_rule as none
        country_code as none
        region as "Universal"
        coordinates as none
        metadata as Dictionary with "is_utc" as true

Process called "get_system_timezone" that returns Timezone:
    Note: Get the system default timezone
    Let system_tz_info be get_system_timezone_info
    
    Return Timezone with:
        name as system_tz_info["name"]
        abbreviation as system_tz_info["abbreviation"]
        utc_offset_seconds as system_tz_info["utc_offset_seconds"]
        dst_offset_seconds as system_tz_info["dst_offset_seconds"]
        is_dst_active as system_tz_info["is_dst_active"]
        dst_start_rule as system_tz_info["dst_start_rule"]
        dst_end_rule as system_tz_info["dst_end_rule"]
        country_code as system_tz_info["country_code"]
        region as system_tz_info["region"]
        coordinates as system_tz_info["coordinates"]
        metadata as Dictionary with "source" as "system"

Process called "lookup_timezone" that takes identifier as String returns Optional[Timezone]:
    Note: Lookup timezone by IANA identifier (e.g., "America/New_York")
    Try:
        Let timezone_db be get_timezone_database
        
        If identifier in timezone_db:
            Let tz_data be timezone_db[identifier]
            Return create_timezone_from_database_entry with data as tz_data
        
        Note: If timezone not found, try common aliases
        Let common_aliases be Dictionary with:
            "EST" as "America/New_York"
            "PST" as "America/Los_Angeles"
            "GMT" as "UTC"
            "UTC" as "UTC"
            "CET" as "Europe/Berlin"
            "JST" as "Asia/Tokyo"
        
        If identifier in common_aliases:
            Let canonical_id be common_aliases[identifier]
            If canonical_id in timezone_db:
                Let tz_data be timezone_db[canonical_id]
                Return create_timezone_from_database_entry with data as tz_data
        
        Return none
    
    Catch error as Exception:
        Call log_timezone_error with message as "Failed to lookup timezone " plus identifier plus ": " plus error as string
        Note: Return a basic timezone with zero offset as fallback
        Return Timezone with:
            identifier as identifier
            name as identifier
            abbreviation as identifier
            utc_offset_seconds as 0
            dst_rules as empty list
            country_code as "XX"
            is_dst_active as false
            next_transition as none
            metadata as Dictionary with "fallback" as true and "error" as error as string

Process called "get_timezone_by_country" that takes country_code as String returns List[Timezone]:
    Note: Get all timezones for a specific country
    Try:
        Let timezone_db be get_timezone_database
        Let country_timezones be empty list
        
        For each identifier and data in timezone_db:
            If data["country_code"] as String is equal to country_code:
                Let timezone be create_timezone_from_database_entry with data as data
                Call country_timezones.append with item as timezone
        
        Return country_timezones
    
    Catch error as Exception:
        Call log_timezone_error with message as "Failed to get timezones for country " plus country_code plus ": " plus error as string
        Return empty list

Process called "find_timezone_by_coordinates" that takes latitude as Float and longitude as Float returns Optional[Timezone]:
    Note: Find timezone based on geographic coordinates
    Try:
        Let timezone_db be get_timezone_database
        Let closest_timezone be none
        Let closest_distance be 999999.0
        
        For each identifier and data in timezone_db:
            Let coords be data["coordinates"] as Dictionary[String, Float]
            If coords is not none:
                Let distance be calculate_coordinate_distance with 
                    lat1 as latitude and 
                    lon1 as longitude and 
                    lat2 as coords["latitude"] and 
                    lon2 as coords["longitude"]
                
                If distance is less than closest_distance:
                    Set closest_distance to distance
                    Set closest_timezone to create_timezone_from_database_entry with data as data
        
        Return closest_timezone
    
    Catch error as Exception:
        Call log_timezone_error with message as "Failed to find timezone by coordinates: " plus error as string
        Return Timezone with:
            identifier as "UTC"
            name as "Coordinated Universal Time"
            abbreviation as "UTC"
            utc_offset_seconds as 0
            dst_rules as empty list
            country_code as "XX"
            is_dst_active as false
            next_transition as none
            metadata as Dictionary with "coordinate_fallback" as true

Note: Timezone Offset Operations

Process called "parse_timezone_offset" that takes offset_string as String returns TimezoneOffset:
    Note: Parse timezone offset string (e.g., "+05:30", "-08:00")
    Try:
        Let is_negative be offset_string starts with "-"
        Let offset_part be offset_string
        
        If offset_string starts with "+" or offset_string starts with "-":
            Set offset_part to substring with string as offset_string and start as 1 and length as (length_of_string with string as offset_string minus 1)
        
        Let parts be split_string with string as offset_part and separator as ":"
        If length_of_list with list as parts is not equal to 2:
            Throw TimezoneError with message as "Invalid timezone offset format: " plus offset_string
        
        Let hours be string_to_integer with string as parts[0]
        Let minutes be string_to_integer with string as parts[1]
        
        If is_negative:
            Set hours to hours times -1
            Set minutes to minutes times -1
        
        Let total_seconds be (hours times 3600) plus (minutes times 60)
        
        Return TimezoneOffset with:
            hours as hours
            minutes as minutes
            total_seconds as total_seconds
            is_negative as total_seconds is less than 0
    
    Catch error as Exception:
        Throw TimezoneError with message as "Failed to parse timezone offset: " plus error as string

Process called "format_timezone_offset" that takes offset_seconds as Integer returns String:
    Note: Format timezone offset as string (e.g., "+05:30", "-08:00")
    Try:
        Let is_negative be offset_seconds is less than 0
        Let abs_seconds be abs_integer with value as offset_seconds
        
        Let hours be abs_seconds divided by 3600
        Let minutes be (abs_seconds modulo 3600) divided by 60
        
        Let sign be "+"
        If is_negative:
            Set sign to "-"
        
        Let hour_str be pad_integer with value as hours and width as 2
        Let minute_str be pad_integer with value as minutes and width as 2
        
        Return sign plus hour_str plus ":" plus minute_str
    
    Catch error as Exception:
        Throw TimezoneError with message as "Failed to format timezone offset: " plus error as string

Process called "get_timezone_offset" that takes timezone as Timezone returns Integer:
    Note: Get current effective timezone offset in seconds
    Let base_offset be timezone.utc_offset_seconds
    
    If timezone.is_dst_active:
        Return base_offset plus timezone.dst_offset_seconds
    Otherwise:
        Return base_offset

Note: Timezone Conversion Operations

Process called "convert_between_timezones" that takes timestamp as Integer and source_timezone as Timezone and target_timezone as Timezone returns TimezoneConversion:
    Note: Convert timestamp between timezones
    Try:
        Let source_offset be get_timezone_offset with timezone as source_timezone
        Let target_offset be get_timezone_offset with timezone as target_timezone
        Let offset_difference be target_offset minus source_offset
        
        Return TimezoneConversion with:
            source_timezone as source_timezone
            target_timezone as target_timezone
            offset_difference as offset_difference
            requires_dst_calculation as source_timezone.is_dst_active or target_timezone.is_dst_active
            conversion_timestamp as timestamp plus offset_difference
    
    Catch error as Exception:
        Throw TimezoneError with message as "Failed to convert between timezones: " plus error as string

Process called "convert_to_utc" that takes timestamp as Integer and source_timezone as Timezone returns Integer:
    Note: Convert local timestamp to UTC
    Let source_offset be get_timezone_offset with timezone as source_timezone
    Return timestamp minus source_offset

Process called "convert_from_utc" that takes utc_timestamp as Integer and target_timezone as Timezone returns Integer:
    Note: Convert UTC timestamp to local timezone
    Let target_offset be get_timezone_offset with timezone as target_timezone
    Return utc_timestamp plus target_offset

Process called "get_timezone_difference" that takes timezone1 as Timezone and timezone2 as Timezone returns Integer:
    Note: Get offset difference between two timezones in seconds
    Let offset1 be get_timezone_offset with timezone as timezone1
    Let offset2 be get_timezone_offset with timezone as timezone2
    Return offset2 minus offset1

Note: DST (Daylight Saving Time) Operations

Process called "calculate_dst_transition" that takes timezone as Timezone and year as Integer returns Dictionary[String, Any]:
    Note: Calculate DST transition dates for a given year
    Try:
        If timezone.dst_start_rule is none or timezone.dst_end_rule is none:
            Return Dictionary with:
                "has_dst" as false
                "start_date" as none
                "end_date" as none
        
        Let start_rule be timezone.dst_start_rule
        Let end_rule be timezone.dst_end_rule
        
        Let start_date be calculate_dst_date with rule as start_rule and year as year
        Let end_date be calculate_dst_date with rule as end_rule and year as year
        
        Return Dictionary with:
            "has_dst" as true
            "start_date" as start_date
            "end_date" as end_date
            "start_timestamp" as convert_date_to_timestamp with date as start_date
            "end_timestamp" as convert_date_to_timestamp with date as end_date
    
    Catch error as Exception:
        Return Dictionary with:
            "has_dst" as false
            "error" as error as string

Process called "is_dst_active_at" that takes timezone as Timezone and timestamp as Integer returns Boolean:
    Note: Check if DST is active for given timezone at specific timestamp
    Try:
        If timezone.dst_start_rule is none or timezone.dst_end_rule is none:
            Return false
        
        Let year be extract_year_from_timestamp with timestamp as timestamp
        Let dst_info be calculate_dst_transition with timezone as timezone and year as year
        
        If not dst_info["has_dst"] as Boolean:
            Return false
        
        Let start_ts be dst_info["start_timestamp"] as Integer
        Let end_ts be dst_info["end_timestamp"] as Integer
        
        Note: Handle northern vs southern hemisphere DST
        If start_ts is less than end_ts:
            Note: Northern hemisphere (DST in summer)
            Return timestamp is greater than or equal to start_ts and timestamp is less than end_ts
        Otherwise:
            Note: Southern hemisphere (DST in winter)
            Return timestamp is less than end_ts or timestamp is greater than or equal to start_ts
    
    Catch error as Exception:
        Return false

Process called "get_dst_offset_at" that takes timezone as Timezone and timestamp as Integer returns Integer:
    Note: Get DST offset for timezone at specific timestamp
    If is_dst_active_at with timezone as timezone and timestamp as timestamp:
        Return timezone.dst_offset_seconds
    Otherwise:
        Return 0

Process called "find_dst_transitions" that takes timezone as Timezone and start_timestamp as Integer and end_timestamp as Integer returns List[Dictionary[String, Any]]:
    Note: Find all DST transitions within a timestamp range
    Try:
        Let transitions be empty list
        Let start_year be extract_year_from_timestamp with timestamp as start_timestamp
        Let end_year be extract_year_from_timestamp with timestamp as end_timestamp
        
        For each year from start_year to end_year:
            Let dst_info be calculate_dst_transition with timezone as timezone and year as year
            
            If dst_info["has_dst"] as Boolean:
                Let start_ts be dst_info["start_timestamp"] as Integer
                Let end_ts be dst_info["end_timestamp"] as Integer
                
                If start_ts is greater than or equal to start_timestamp and start_ts is less than or equal to end_timestamp:
                    Call transitions.append with item as Dictionary with:
                        "timestamp" as start_ts
                        "type" as "dst_start"
                        "offset_change" as timezone.dst_offset_seconds
                        "year" as year
                
                If end_ts is greater than or equal to start_timestamp and end_ts is less than or equal to end_timestamp:
                    Call transitions.append with item as Dictionary with:
                        "timestamp" as end_ts
                        "type" as "dst_end"
                        "offset_change" as timezone.dst_offset_seconds times -1
                        "year" as year
        
        Return sort_transitions_by_timestamp with transitions as transitions
    
    Catch error as Exception:
        Return empty list

