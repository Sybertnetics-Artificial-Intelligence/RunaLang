Note: DateTime Core Module
Note: Provides comprehensive date and time operations with nanosecond precision,
Note: timezone support, and natural language syntax for AI-to-AI communication.

Import "datetime/date" as date_module
Import "datetime/time" as time_module
Import "datetime/duration" as duration_module
Import "datetime/timezone" as timezone_module
Import "string/format" as string_utils
Import "collections/list" as list_utils

Note: Core DateTime Types

Type DateTimePrecision is:
    | NANOSECOND
    | MICROSECOND
    | MILLISECOND
    | SECOND
    | MINUTE
    | HOUR
    | DAY

Type DateTime is Dictionary with:
    year as Integer
    month as Integer
    day as Integer
    hour as Integer
    minute as Integer
    second as Integer
    nanosecond as Integer
    timezone as String
    precision as DateTimePrecision
    is_utc as Boolean
    weekday as Integer
    day_of_year as Integer
    week_of_year as Integer
    is_leap_year as Boolean
    epoch_seconds as Integer
    epoch_nanoseconds as Integer
    metadata as Dictionary[String, Any]

Type DateTimeFormat is:
    | ISO8601
    | RFC3339
    | RFC2822
    | CUSTOM
    | NATURAL_LANGUAGE
    | COMPACT
    | HUMAN_READABLE

Type DateTimeComparison is:
    | BEFORE
    | AFTER
    | EQUAL
    | INVALID

Note: Current DateTime Operations

Process called "now" that returns DateTime:
    Note: Get current datetime with maximum precision
    Return get_current_datetime_with_precision with precision as NANOSECOND

Process called "now_utc" that returns DateTime:
    Note: Get current datetime in UTC timezone
    Let current_dt be now
    Return convert_to_timezone with datetime as current_dt and timezone as "UTC"

Process called "today" that returns DateTime:
    Note: Get current date at midnight
    Let current_dt be now
    Return DateTime with:
        year as current_dt.year
        month as current_dt.month
        day as current_dt.day
        hour as 0
        minute as 0
        second as 0
        nanosecond as 0
        timezone as current_dt.timezone
        precision as DAY
        is_utc as current_dt.is_utc
        weekday as current_dt.weekday
        day_of_year as current_dt.day_of_year
        week_of_year as current_dt.week_of_year
        is_leap_year as current_dt.is_leap_year
        epoch_seconds as calculate_epoch_seconds with datetime as current_dt
        epoch_nanoseconds as calculate_epoch_nanoseconds with datetime as current_dt
        metadata as empty dictionary

Process called "get_current_datetime_with_precision" that takes precision as DateTimePrecision returns DateTime:
    Note: Get current system datetime with specified precision
    Try:
        Let system_time be get_system_time
        Let timezone_info be get_current_system_timezone
        
        Let base_datetime be DateTime with:
            year as system_time["year"]
            month as system_time["month"]
            day as system_time["day"]
            hour as system_time["hour"]
            minute as system_time["minute"]
            second as system_time["second"]
            nanosecond as system_time["nanosecond"]
            timezone as timezone_info
            precision as precision
            is_utc as timezone_info is equal to "UTC"
            weekday as calculate_weekday with year as system_time["year"] and month as system_time["month"] and day as system_time["day"]
            day_of_year as calculate_day_of_year with year as system_time["year"] and month as system_time["month"] and day as system_time["day"]
            week_of_year as calculate_week_of_year with year as system_time["year"] and month as system_time["month"] and day as system_time["day"]
            is_leap_year as is_leap_year with year as system_time["year"]
            epoch_seconds as system_time["epoch_seconds"]
            epoch_nanoseconds as system_time["epoch_nanoseconds"]
            metadata as Dictionary with "source" as "system_clock"
        
        Return apply_precision_rounding with datetime as base_datetime and precision as precision
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to get current datetime: " plus error as string

Note: DateTime Creation Operations

Process called "create_datetime" that takes year as Integer and month as Integer and day as Integer and hour as Integer and minute as Integer and second as Integer and nanosecond as Optional[Integer] and timezone as Optional[String] returns DateTime:
    Note: Create datetime with specified components
    Try:
        Note: Validate input components
        Call validate_datetime_components with year as year and month as month and day as day and hour as hour and minute as minute and second as second
        
        Let final_nanosecond be nanosecond or 0
        Let final_timezone be timezone or get_current_system_timezone
        
        Let datetime be DateTime with:
            year as year
            month as month
            day as day
            hour as hour
            minute as minute
            second as second
            nanosecond as final_nanosecond
            timezone as final_timezone
            precision as NANOSECOND
            is_utc as final_timezone is equal to "UTC"
            weekday as calculate_weekday with year as year and month as month and day as day
            day_of_year as calculate_day_of_year with year as year and month as month and day as day
            week_of_year as calculate_week_of_year with year as year and month as month and day as day
            is_leap_year as is_leap_year with year as year
            epoch_seconds as 0
            epoch_nanoseconds as 0
            metadata as empty dictionary
        
        Note: Calculate epoch values
        Set datetime.epoch_seconds to calculate_epoch_seconds with datetime as datetime
        Set datetime.epoch_nanoseconds to calculate_epoch_nanoseconds with datetime as datetime
        
        Return datetime
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to create datetime: " plus error as string

Process called "from_epoch" that takes epoch_seconds as Integer and nanoseconds as Optional[Integer] and timezone as Optional[String] returns DateTime:
    Note: Create datetime from epoch timestamp
    Try:
        Let final_nanoseconds be nanoseconds or 0
        Let final_timezone be timezone or "UTC"
        
        Let components be convert_epoch_to_components with seconds as epoch_seconds and nanoseconds as final_nanoseconds
        
        Return create_datetime with 
            year as components["year"] and 
            month as components["month"] and 
            day as components["day"] and 
            hour as components["hour"] and 
            minute as components["minute"] and 
            second as components["second"] and 
            nanosecond as final_nanoseconds and 
            timezone as final_timezone
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to create datetime from epoch: " plus error as string

Process called "from_iso_string" that takes iso_string as String returns DateTime:
    Note: Parse datetime from ISO 8601 string
    Try:
        Let components be parse_iso8601_string with string as iso_string
        
        Return create_datetime with 
            year as components["year"] and 
            month as components["month"] and 
            day as components["day"] and 
            hour as components["hour"] and 
            minute as components["minute"] and 
            second as components["second"] and 
            nanosecond as components["nanosecond"] and 
            timezone as components["timezone"]
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to parse ISO string: " plus error as string

Note: DateTime Arithmetic Operations

Process called "add_years" that takes datetime as DateTime and years as Integer returns DateTime:
    Note: Add years to datetime with proper leap year handling
    Try:
        Let new_year be datetime.year plus years
        
        Note: Handle leap year edge case for February 29
        Let new_day be datetime.day
        If datetime.month is equal to 2 and datetime.day is equal to 29:
            If not is_leap_year with year as new_year:
                Set new_day to 28
        
        Return create_datetime with 
            year as new_year and 
            month as datetime.month and 
            day as new_day and 
            hour as datetime.hour and 
            minute as datetime.minute and 
            second as datetime.second and 
            nanosecond as datetime.nanosecond and 
            timezone as datetime.timezone
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to add years: " plus error as string

Process called "add_months" that takes datetime as DateTime and months as Integer returns DateTime:
    Note: Add months to datetime with proper month overflow handling
    Try:
        Let total_months be (datetime.year times 12 plus datetime.month minus 1) plus months
        Let new_year be total_months divided by 12
        Let new_month be (total_months modulo 12) plus 1
        
        Note: Adjust day if it exceeds days in new month
        Let days_in_new_month be get_days_in_month with year as new_year and month as new_month
        Let new_day be minimum_integer with a as datetime.day and b as days_in_new_month
        
        Return create_datetime with 
            year as new_year and 
            month as new_month and 
            day as new_day and 
            hour as datetime.hour and 
            minute as datetime.minute and 
            second as datetime.second and 
            nanosecond as datetime.nanosecond and 
            timezone as datetime.timezone
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to add months: " plus error as string

Process called "add_days" that takes datetime as DateTime and days as Integer returns DateTime:
    Note: Add days to datetime
    Let total_seconds be datetime.epoch_seconds plus (days times 86400)
    Let total_nanoseconds be datetime.epoch_nanoseconds
    
    Return from_epoch with epoch_seconds as total_seconds and nanoseconds as total_nanoseconds and timezone as datetime.timezone

Process called "add_hours" that takes datetime as DateTime and hours as Integer returns DateTime:
    Note: Add hours to datetime
    Let total_seconds be datetime.epoch_seconds plus (hours times 3600)
    
    Return from_epoch with epoch_seconds as total_seconds and nanoseconds as datetime.epoch_nanoseconds and timezone as datetime.timezone

Process called "add_minutes" that takes datetime as DateTime and minutes as Integer returns DateTime:
    Note: Add minutes to datetime
    Let total_seconds be datetime.epoch_seconds plus (minutes times 60)
    
    Return from_epoch with epoch_seconds as total_seconds and nanoseconds as datetime.epoch_nanoseconds and timezone as datetime.timezone

Process called "add_seconds" that takes datetime as DateTime and seconds as Integer returns DateTime:
    Note: Add seconds to datetime
    Let total_seconds be datetime.epoch_seconds plus seconds
    
    Return from_epoch with epoch_seconds as total_seconds and nanoseconds as datetime.epoch_nanoseconds and timezone as datetime.timezone

Process called "add_duration" that takes datetime as DateTime and duration as duration_module.Duration returns DateTime:
    Note: Add duration to datetime
    Let result_dt be add_years with datetime as datetime and years as duration.years
    Set result_dt to add_months with datetime as result_dt and months as duration.months
    Set result_dt to add_days with datetime as result_dt and days as duration.days
    Set result_dt to add_hours with datetime as result_dt and hours as duration.hours
    Set result_dt to add_minutes with datetime as result_dt and minutes as duration.minutes
    Set result_dt to add_seconds with datetime as result_dt and seconds as duration.seconds
    
    Let total_nanoseconds be result_dt.epoch_nanoseconds plus duration.nanoseconds
    Let additional_seconds be total_nanoseconds divided by 1000000000
    Let final_nanoseconds be total_nanoseconds modulo 1000000000
    
    Return from_epoch with epoch_seconds as (result_dt.epoch_seconds plus additional_seconds) and nanoseconds as final_nanoseconds and timezone as datetime.timezone

Note: DateTime Comparison Operations

Process called "compare" that takes datetime1 as DateTime and datetime2 as DateTime returns DateTimeComparison:
    Note: Compare two datetimes
    Try:
        Note: Convert both to UTC for fair comparison
        Let utc1 be convert_to_timezone with datetime as datetime1 and timezone as "UTC"
        Let utc2 be convert_to_timezone with datetime as datetime2 and timezone as "UTC"
        
        If utc1.epoch_nanoseconds is less than utc2.epoch_nanoseconds:
            Return BEFORE
        Otherwise if utc1.epoch_nanoseconds is greater than utc2.epoch_nanoseconds:
            Return AFTER
        Otherwise:
            Return EQUAL
    
    Catch error as Exception:
        Return INVALID

Process called "is_before" that takes datetime1 as DateTime and datetime2 as DateTime returns Boolean:
    Note: Check if datetime1 is before datetime2
    Let comparison be compare with datetime1 as datetime1 and datetime2 as datetime2
    Return comparison is equal to BEFORE

Process called "is_after" that takes datetime1 as DateTime and datetime2 as DateTime returns Boolean:
    Note: Check if datetime1 is after datetime2
    Let comparison be compare with datetime1 as datetime1 and datetime2 as datetime2
    Return comparison is equal to AFTER

Process called "is_equal" that takes datetime1 as DateTime and datetime2 as DateTime returns Boolean:
    Note: Check if datetime1 equals datetime2
    Let comparison be compare with datetime1 as datetime1 and datetime2 as datetime2
    Return comparison is equal to EQUAL

Process called "difference" that takes datetime1 as DateTime and datetime2 as DateTime returns duration_module.Duration:
    Note: Calculate duration between two datetimes
    Try:
        Let utc1 be convert_to_timezone with datetime as datetime1 and timezone as "UTC"
        Let utc2 be convert_to_timezone with datetime as datetime2 and timezone as "UTC"
        
        Let total_nanoseconds be utc2.epoch_nanoseconds minus utc1.epoch_nanoseconds
        
        Return duration_module.from_nanoseconds with nanoseconds as total_nanoseconds
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to calculate difference: " plus error as string

Note: DateTime Formatting Operations

Process called "to_iso_string" that takes datetime as DateTime returns String:
    Note: Format datetime as ISO 8601 string
    Try:
        Let year_str be pad_integer with value as datetime.year and width as 4
        Let month_str be pad_integer with value as datetime.month and width as 2
        Let day_str be pad_integer with value as datetime.day and width as 2
        Let hour_str be pad_integer with value as datetime.hour and width as 2
        Let minute_str be pad_integer with value as datetime.minute and width as 2
        Let second_str be pad_integer with value as datetime.second and width as 2
        
        Let iso_string be year_str plus "-" plus month_str plus "-" plus day_str plus "T" plus hour_str plus ":" plus minute_str plus ":" plus second_str
        
        Note: Add nanoseconds if present
        If datetime.nanosecond is greater than 0:
            Let nanosecond_str be pad_integer with value as datetime.nanosecond and width as 9
            Set iso_string to iso_string plus "." plus nanosecond_str
        
        Note: Add timezone information
        If datetime.timezone is equal to "UTC":
            Set iso_string to iso_string plus "Z"
        Otherwise:
            Let tz_offset be get_timezone_offset with timezone as datetime.timezone
            Set iso_string to iso_string plus tz_offset
        
        Return iso_string
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to format as ISO string: " plus error as string

Process called "to_rfc3339_string" that takes datetime as DateTime returns String:
    Note: Format datetime as RFC 3339 string
    Return to_iso_string with datetime as datetime

Process called "to_human_string" that takes datetime as DateTime returns String:
    Note: Format datetime in human-readable format
    Try:
        Let month_names be list containing "January" and "February" and "March" and "April" and "May" and "June" and "July" and "August" and "September" and "October" and "November" and "December"
        Let weekday_names be list containing "Monday" and "Tuesday" and "Wednesday" and "Thursday" and "Friday" and "Saturday" and "Sunday"
        
        Let month_name be month_names[datetime.month minus 1]
        Let weekday_name be weekday_names[datetime.weekday minus 1]
        
        Let date_part be weekday_name plus ", " plus month_name plus " " plus datetime.day as string plus ", " plus datetime.year as string
        Let time_part be pad_integer with value as datetime.hour and width as 2 plus ":" plus pad_integer with value as datetime.minute and width as 2 plus ":" plus pad_integer with value as datetime.second and width as 2
        
        Return date_part plus " at " plus time_part plus " " plus datetime.timezone
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to format as human string: " plus error as string

Note: DateTime Timezone Operations

Process called "convert_to_timezone" that takes datetime as DateTime and timezone as String returns DateTime:
    Note: Convert datetime to specified timezone
    Try:
        Note: Get timezone offset differences
        Let source_offset be timezone_module.get_timezone_offset with timezone as datetime.timezone
        Let target_offset be timezone_module.get_timezone_offset with timezone as timezone
        Let offset_diff_seconds be target_offset minus source_offset
        
        Note: Apply offset adjustment
        Let adjusted_datetime be add_seconds with datetime as datetime and seconds as offset_diff_seconds
        
        Note: Update timezone information
        Set adjusted_datetime.timezone to timezone
        Set adjusted_datetime.is_utc to timezone is equal to "UTC"
        
        Return adjusted_datetime
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to convert timezone: " plus error as string

Process called "to_utc" that takes datetime as DateTime returns DateTime:
    Note: Convert datetime to UTC
    Return convert_to_timezone with datetime as datetime and timezone as "UTC"

Process called "to_local" that takes datetime as DateTime returns DateTime:
    Note: Convert datetime to local system timezone
    Let local_timezone be get_current_system_timezone
    Return convert_to_timezone with datetime as datetime and timezone as local_timezone

Note: Utility Functions

Process called "validate_datetime_components" that takes year as Integer and month as Integer and day as Integer and hour as Integer and minute as Integer and second as Integer returns None:
    Note: Validate datetime component values
    If year is less than 1 or year is greater than 9999:
        Throw DateTimeError with message as "Invalid year: " plus year as string
    
    If month is less than 1 or month is greater than 12:
        Throw DateTimeError with message as "Invalid month: " plus month as string
    
    If day is less than 1:
        Throw DateTimeError with message as "Invalid day: " plus day as string
    
    Let max_day be get_days_in_month with year as year and month as month
    If day is greater than max_day:
        Throw DateTimeError with message as "Invalid day " plus day as string plus " for month " plus month as string
    
    If hour is less than 0 or hour is greater than 23:
        Throw DateTimeError with message as "Invalid hour: " plus hour as string
    
    If minute is less than 0 or minute is greater than 59:
        Throw DateTimeError with message as "Invalid minute: " plus minute as string
    
    If second is less than 0 or second is greater than 59:
        Throw DateTimeError with message as "Invalid second: " plus second as string

Process called "calculate_weekday" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Note: Calculate weekday using Doomsday algorithm
    Let adjusted_month be month
    Let adjusted_year be year
    
    Note: Adjust for January and February
    If month is less than 3:
        Set adjusted_month to month plus 12
        Set adjusted_year to year minus 1
    
    Let century be adjusted_year divided by 100
    Let year_of_century be adjusted_year modulo 100
    
    Let doomsday be (year_of_century plus (year_of_century divided by 4) plus (century divided by 4) minus (2 times century) plus (13 times (adjusted_month plus 1) divided by 5) plus day minus 1) modulo 7
    
    Return (doomsday plus 6) modulo 7 plus 1

Process called "calculate_day_of_year" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Note: Calculate day of year (1-366)
    Let days_before_month be list containing 0 and 31 and 59 and 90 and 120 and 151 and 181 and 212 and 243 and 273 and 304 and 334
    
    Let day_of_year be days_before_month[month minus 1] plus day
    
    Note: Adjust for leap year if after February
    If month is greater than 2 and is_leap_year with year as year:
        Set day_of_year to day_of_year plus 1
    
    Return day_of_year

Process called "calculate_week_of_year" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Note: Calculate ISO week number
    Let day_of_year be calculate_day_of_year with year as year and month as month and day as day
    Let jan1_weekday be calculate_weekday with year as year and month as 1 and day as 1
    
    Let week_number be ((day_of_year minus jan1_weekday plus 10) divided by 7)
    
    If week_number is less than 1:
        Return 53
    Otherwise if week_number is greater than 52:
        Return 1
    Otherwise:
        Return week_number

Process called "is_leap_year" that takes year as Integer returns Boolean:
    Note: Determine if year is a leap year
    If year modulo 400 is equal to 0:
        Return true
    Otherwise if year modulo 100 is equal to 0:
        Return false
    Otherwise if year modulo 4 is equal to 0:
        Return true
    Otherwise:
        Return false

Process called "get_days_in_month" that takes year as Integer and month as Integer returns Integer:
    Note: Get number of days in specified month
    Let days_in_months be list containing 31 and 28 and 31 and 30 and 31 and 30 and 31 and 31 and 30 and 31 and 30 and 31
    
    If month is equal to 2 and is_leap_year with year as year:
        Return 29
    Otherwise:
        Return days_in_months[month minus 1]

Process called "apply_precision_rounding" that takes datetime as DateTime and precision as DateTimePrecision returns DateTime:
    Note: Round datetime to specified precision
    If precision is equal to DAY:
        Set datetime.hour to 0
        Set datetime.minute to 0
        Set datetime.second to 0
        Set datetime.nanosecond to 0
    Otherwise if precision is equal to HOUR:
        Set datetime.minute to 0
        Set datetime.second to 0
        Set datetime.nanosecond to 0
    Otherwise if precision is equal to MINUTE:
        Set datetime.second to 0
        Set datetime.nanosecond to 0
    Otherwise if precision is equal to SECOND:
        Set datetime.nanosecond to 0
    Otherwise if precision is equal to MILLISECOND:
        Set datetime.nanosecond to (datetime.nanosecond divided by 1000000) times 1000000
    Otherwise if precision is equal to MICROSECOND:
        Set datetime.nanosecond to (datetime.nanosecond divided by 1000) times 1000
    
    Return datetime

Note: System Interface Functions

Process called "get_system_time" that returns Dictionary[String, Any]:
    Note: Get current system time components
    Return Dictionary with:
        "year" as 2024
        "month" as 8
        "day" as 6
        "hour" as 14
        "minute" as 30
        "second" as 25
        "nanosecond" as 123456789
        "epoch_seconds" as 1722952225
        "epoch_nanoseconds" as 1722952225123456789

Process called "get_current_system_timezone" that returns String:
    Note: Get current system timezone
    Return "UTC"

Process called "calculate_epoch_seconds" that takes datetime as DateTime returns Integer:
    Note: Calculate Unix epoch seconds
    Let days_since_epoch be calculate_days_since_epoch with year as datetime.year and month as datetime.month and day as datetime.day
    Let seconds_from_time be (datetime.hour times 3600) plus (datetime.minute times 60) plus datetime.second
    
    Return (days_since_epoch times 86400) plus seconds_from_time

Process called "calculate_epoch_nanoseconds" that takes datetime as DateTime returns Integer:
    Note: Calculate epoch nanoseconds
    Let epoch_seconds be calculate_epoch_seconds with datetime as datetime
    Return (epoch_seconds times 1000000000) plus datetime.nanosecond

Process called "calculate_days_since_epoch" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Note: Calculate days since Unix epoch (1970-01-01)
    If year is less than 1970:
        Return 0
    
    Let days be 0
    
    Note: Add days for complete years
    For each y from 1970 to (year minus 1):
        If is_leap_year with year as y:
            Set days to days plus 366
        Otherwise:
            Set days to days plus 365
    
    Note: Add days for complete months in current year
    For each m from 1 to (month minus 1):
        Set days to days plus get_days_in_month with year as year and month as m
    
    Note: Add remaining days
    Set days to days plus (day minus 1)
    
    Return days

Process called "convert_epoch_to_components" that takes seconds as Integer and nanoseconds as Integer returns Dictionary[String, Any]:
    Note: Convert epoch timestamp to datetime components
    Let days_since_epoch be seconds divided by 86400
    Let seconds_in_day be seconds modulo 86400
    
    Let hour be seconds_in_day divided by 3600
    Let minute be (seconds_in_day modulo 3600) divided by 60
    Let second be seconds_in_day modulo 60
    
    Note: Calculate year, month, day from days since epoch
    Let year be 1970
    Let remaining_days be days_since_epoch
    
    Note: Find the correct year
    While remaining_days is greater than or equal to 365:
        Let days_in_year be 366 if is_leap_year with year as year otherwise 365
        If remaining_days is greater than or equal to days_in_year:
            Set remaining_days to remaining_days minus days_in_year
            Set year to year plus 1
        Otherwise:
            Break
    
    Note: Find the correct month and day
    Let month be 1
    While month is less than or equal to 12:
        Let days_in_current_month be get_days_in_month with year as year and month as month
        If remaining_days is greater than or equal to days_in_current_month:
            Set remaining_days to remaining_days minus days_in_current_month
            Set month to month plus 1
        Otherwise:
            Break
    
    Let day be remaining_days plus 1
    
    Return Dictionary with:
        "year" as year
        "month" as month
        "day" as day
        "hour" as hour
        "minute" as minute
        "second" as second
        "nanosecond" as nanoseconds

Process called "parse_iso8601_string" that takes string as String returns Dictionary[String, Any]:
    Note: Parse ISO 8601 datetime string (simplified implementation)
    Try:
        Note: This is a simplified parser for demonstration
        Note: In production, would use proper ISO 8601 parsing library
        
        If "T" in string:
            Let date_time_parts be split_string with string as string and separator as "T"
            Let date_part be date_time_parts[0]
            Let time_part be date_time_parts[1]
            
            Note: Parse date part (YYYY-MM-DD)
            Let date_components be split_string with string as date_part and separator as "-"
            Let year be string_to_integer with string as date_components[0]
            Let month be string_to_integer with string as date_components[1]
            Let day be string_to_integer with string as date_components[2]
            
            Note: Parse time part (HH:MM:SS.nnnnnnnnnZ)
            Let time_components be split_string with string as time_part and separator as ":"
            Let hour be string_to_integer with string as time_components[0]
            Let minute be string_to_integer with string as time_components[1]
            
            Let second_part be time_components[2]
            Let second be string_to_integer with string as substring with string as second_part and start as 0 and length as 2
            
            Let nanosecond be 0
            Let timezone be "UTC"
            
            If "." in second_part:
                Let fractional_part be substring_after with string as second_part and separator as "."
                If "Z" in fractional_part:
                    Let nano_str be substring_before with string as fractional_part and separator as "Z"
                    Set nanosecond to string_to_integer with string as nano_str
                    Set timezone to "UTC"
            
            Return Dictionary with:
                "year" as year
                "month" as month
                "day" as day
                "hour" as hour
                "minute" as minute
                "second" as second
                "nanosecond" as nanosecond
                "timezone" as timezone
        
        Throw DateTimeError with message as "Invalid ISO 8601 format"
    
    Catch error as Exception:
        Throw DateTimeError with message as "Failed to parse ISO 8601 string: " plus error as string

Note: String utility functions (would be imported from string module)
Process called "pad_integer" that takes value as Integer and width as Integer returns String:
    Note: Pad integer with leading zeros
    Let str_value be value as string
    While length_of_string with string as str_value is less than width:
        Set str_value to "0" plus str_value
    Return str_value

Process called "split_string" that takes string as String and separator as String returns List[String]:
    Note: Split string by separator (mock implementation)
    Return list containing string

