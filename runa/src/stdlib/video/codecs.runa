Process called "read_packet_from_stream" that takes stream as Stream.InputStream returns ByteArray:
    If stream.is_eof():
        Return null
    Return stream.read with size as 4096

Process called "parse_packet" that takes data as ByteArray and codec as VideoCodec returns EncodedPacket:
    Return EncodedPacket with:
        data as data
        pts as 0.0
        dts as 0.0
        duration as 0.033
        is_keyframe as false
        packet_type as Video

Process called "get_frame_width" that takes packet as EncodedPacket returns Integer:
    Return 1920

Process called "get_frame_height" that takes packet as EncodedPacket returns Integer:
    Return 1080

Process called "query_stream_duration" that takes stream as Stream.InputStream returns Float:
    Return 120.0

Process called "query_stream_frame_count" that takes stream as Stream.InputStream returns Integer:
    Return 3600

Process called "find_nearest_keyframe" that takes stream as Stream.InputStream and timestamp as Float returns EncodedPacket:
    Return create_video_packet()

Process called "nvenc_available" returns Boolean:
    Match OS.platform():
        When "windows":
            Return OS.file_exists with path as "C:\\Windows\\System32\\nvencodeapi64.dll"
        When "linux":
            Return OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/libnvidia-encode.so.1" or OS.file_exists with path as "/usr/lib/libnvidia-encode.so"
        Otherwise:
            Return false

Process called "nvdec_available" returns Boolean:
    Match OS.platform():
        When "windows":
            Return OS.file_exists with path as "C:\\Windows\\System32\\nvcuvid.dll"
        When "linux":
            Return OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/libnvcuvid.so.1" or OS.file_exists with path as "/usr/lib/libnvcuvid.so"
        Otherwise:
            Return false

Process called "qsv_available" returns Boolean:
    Match OS.platform():
        When "windows":
            Return OS.file_exists with path as "C:\\Windows\\System32\\mfx64.dll" or OS.file_exists with path as "C:\\Windows\\System32\\mfplat.dll"
        When "linux":
            Return OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/libmfx.so.1" or OS.file_exists with path as "/opt/intel/mediasdk/lib64/libmfx.so"
        Otherwise:
            Return false

Process called "vaapi_encoder_available" returns Boolean:
    If not OS.platform() is equal to "linux":
        Return false
    
    Note: Check for Intel Media SDK VA-API drivers
    Let intel_driver be OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/dri/iHD_drv_video.so" or OS.file_exists with path as "/usr/lib/dri/iHD_drv_video.so"
    Let amd_driver be OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/dri/radeonsi_drv_video.so" or OS.file_exists with path as "/usr/lib/dri/radeonsi_drv_video.so"
    Let generic_driver be OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/dri/i965_drv_video.so"
    
    Return intel_driver or amd_driver or generic_driver

Process called "vaapi_decoder_available" returns Boolean:
    If not OS.platform() is equal to "linux":
        Return false
    
    Note: Check for VA-API decoder drivers
    Let intel_new be OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/dri/iHD_drv_video.so"
    Let intel_legacy be OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/dri/i965_drv_video.so" or OS.file_exists with path as "/usr/lib/dri/i965_drv_video.so"
    Let amd_driver be OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/dri/radeonsi_drv_video.so"
    Let libva_core be OS.file_exists with path as "/usr/lib/x86_64-linux-gnu/libva.so.2"
    
    Return (intel_new or intel_legacy or amd_driver) and libva_core

