Note:
Runa Standard Library: Calendar Display and Manipulation

Provides calendar display functions, calendar navigation, and calendar-based
calculations as specified in the Runa language specification. Supports multiple
calendar systems and customizable display formats.
:End Note

Import "calendar/core" as core

Type called "CalendarDisplay":
    year as Integer
    month as Integer
    calendar_grid as List[List[Integer]]
    month_name as String
    weekday_headers as List[String]
    first_day_of_week as Integer
    week_count as Integer

Type called "CalendarRange":
    start_date as core.Date
    end_date as core.Date
    total_days as Integer
    total_weeks as Integer
    total_months as Integer

Process called "create_month_calendar" that takes year as Integer and month as Integer returns CalendarDisplay:
    If not (core.is_valid_date with year as year and month as month and day as 1):
        Throw create_value_error with value as dictionary with "year" as year, "month" as month and constraint as "Invalid year or month"
    
    Let first_day be core.create_date with year as year and month as month and day as 1
    Let days_in_current_month be core.days_in_month with year as year and month as month
    Let first_day_of_week be first_day["day_of_week"]
    
    Let calendar_grid be create_calendar_grid with year as year and month as month and first_day_of_week as first_day_of_week and days_in_month as days_in_current_month
    
    Return CalendarDisplay with:
        year as year
        month as month
        calendar_grid as calendar_grid
        month_name as core.MONTH_NAMES[month minus 1]
        weekday_headers as core.WEEKDAY_NAMES
        first_day_of_week as first_day_of_week
        week_count as length of calendar_grid

Process called "create_calendar_grid" that takes year as Integer and month as Integer and first_day_of_week as Integer and days_in_month as Integer returns List[List[Integer]]:
    Let grid be list containing
    Let current_week be list containing
    
    Note: Fill in leading empty days
    For i from 0 to (first_day_of_week minus 1):
        Add 0 to current_week
    
    Note: Fill in days of month
    For day from 1 to days_in_month:
        Add day to current_week
        
        If length of current_week is equal to 7:
            Add current_week to grid
            Set current_week to list containing
    
    Note: Fill in trailing empty days
    While length of current_week is greater than 0 and length of current_week is less than 7:
        Add 0 to current_week
    
    If length of current_week is equal to 7:
        Add current_week to grid
    
    Return grid

Process called "format_calendar" that takes calendar_display as CalendarDisplay and format_options as Dictionary[String, Any] returns String:
    Let output be list containing
    
    Note: Add header
    Let header be calendar_display["month_name"] with message " " with message calendar_display["year"]
    Add center_text with text as header and width as get_format_option with options as format_options and key as "width" and default as 20 to output
    Add "" to output
    
    Note: Add weekday headers
    Let weekday_line be ""
    For each weekday in calendar_display["weekday_headers"]:
        Let abbreviated_weekday be substring of weekday from 0 to 3
        Set weekday_line to weekday_line with message pad_text with text as abbreviated_weekday and width as 3 with message " "
    Add weekday_line to output
    
    Note: Add calendar grid
    For each week in calendar_display["calendar_grid"]:
        Let week_line be ""
        For each day in week:
            If day is equal to 0:
                Set week_line to week_line with message "   "
            Otherwise:
                Set week_line to week_line with message pad_text with text as ("" with message day) and width as 3
            Set week_line to week_line with message " "
        Add week_line to output
    
    Return join_lines with lines as output

Process called "center_text" that takes text as String and width as Integer returns String:
    Let text_length be length of text
    If text_length is greater than or equal to width:
        Return text
    
    Let padding be width minus text_length
    Let left_padding be padding divided by 2
    Let right_padding be padding minus left_padding
    
    Let result be ""
    For i from 1 to left_padding:
        Set result to result with message " "
    Set result to result with message text
    For i from 1 to right_padding:
        Set result to result with message " "
    
    Return result

Process called "pad_text" that takes text as String and width as Integer returns String:
    Let text_length be length of text
    If text_length is greater than or equal to width:
        Return text
    
    Let padding_needed be width minus text_length
    Let result be text
    For i from 1 to padding_needed:
        Set result to " " with message result
    
    Return result

Process called "join_lines" that takes lines as List[String] returns String:
    Let result be ""
    For i from 0 to (length of lines minus 1):
        Set result to result with message lines[i]
        If i is less than (length of lines minus 1):
            Set result to result with message "\n"
    Return result

Process called "get_format_option" that takes options as Dictionary[String, Any] and key as String and default as Any returns Any:
    If options contains key key:
        Return options[key]
    Return default

Process called "substring" that takes text as String and start as Integer and end as Integer returns String:
    Note: Extract substring from start index to end index (exclusive)
    If start is less than 0 or end is less than 0 or start is greater than or equal to length of text:
        Return ""
    
    If end is greater than length of text:
        Set end to length of text
    
    If start is greater than or equal to end:
        Return ""
    
    Let result be ""
    For i from start to end minus 1:
        Let char be system_call_get_character_at with text as text and position as i
        Set result to result plus char
    
    Return result

Import "builtins/exceptions" as exceptions
Process called "create_value_error" that takes value as Any and constraint as String returns exceptions.ValueError:
    Return exceptions.create_value_error with value as value and constraint as constraint 