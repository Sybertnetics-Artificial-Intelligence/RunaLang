Note:
Runa Standard Library: Holiday and Special Date System

Provides comprehensive holiday calculation, recognition, and management as specified
in the Runa language specification. Supports international holidays, regional 
variations, and custom holiday definitions with date arithmetic.
:End Note

Import "calendar/core" as core

Type Holiday is Dictionary with:
    name as String
    date as core.Date
    category as String
    country_code as Optional[String]
    region as Optional[String]
    is_observed as Boolean
    is_federal as Boolean
    is_religious as Boolean
    description as String

Type HolidayRule is Dictionary with:
    name as String
    calculation_type as String
    reference_date as Optional[core.Date]
    offset_days as Integer
    weekday_adjustment as String
    recurring_pattern as String
    valid_years as Optional[List[Integer]]

Type HolidayCalendar is Dictionary with:
    country_code as String
    region as Optional[String]
    holidays as List[Holiday]
    custom_rules as List[HolidayRule]
    year as Integer

Note: Fixed Date Holidays (Same date every year)
Process called "create_fixed_holiday" that takes name as String and month as Integer and day as Integer and category as String returns HolidayRule:
    Return HolidayRule with:
        name as name
        calculation_type as "fixed"
        reference_date as core.create_date with year as 2024 and month as month and day as day
        offset_days as 0
        weekday_adjustment as "none"
        recurring_pattern as "annual"
        valid_years as None

Process called "create_floating_holiday" that takes name as String and month as Integer and weekday as Integer and occurrence as Integer and category as String returns HolidayRule:
    Return HolidayRule with:
        name as name
        calculation_type as "floating"
        reference_date as core.create_date with year as 2024 and month as month and day as 1
        offset_days as (occurrence minus 1) times 7 plus weekday
        weekday_adjustment as "none"
        recurring_pattern as "annual"
        valid_years as None

Process called "create_easter_based_holiday" that takes name as String and offset_days as Integer and category as String returns HolidayRule:
    Return HolidayRule with:
        name as name
        calculation_type as "easter_based"
        reference_date as None
        offset_days as offset_days
        weekday_adjustment as "none"
        recurring_pattern as "annual"
        valid_years as None

Note: Major Holiday Definitions
Process called "get_us_federal_holidays" returns List[HolidayRule]:
    Return list containing
        create_fixed_holiday with name as "New Year's Day" and month as 1 and day as 1 and category as "federal",
        create_floating_holiday with name as "Martin Luther King Jr. Day" and month as 1 and weekday as 1 and occurrence as 3 and category as "federal",
        create_floating_holiday with name as "Presidents' Day" and month as 2 and weekday as 1 and occurrence as 3 and category as "federal",
        create_floating_holiday with name as "Memorial Day" and month as 5 and weekday as 1 and occurrence as -1 and category as "federal",
        create_fixed_holiday with name as "Independence Day" and month as 7 and day as 4 and category as "federal",
        create_floating_holiday with name as "Labor Day" and month as 9 and weekday as 1 and occurrence as 1 and category as "federal",
        create_floating_holiday with name as "Columbus Day" and month as 10 and weekday as 1 and occurrence as 2 and category as "federal",
        create_fixed_holiday with name as "Veterans Day" and month as 11 and day as 11 and category as "federal",
        create_floating_holiday with name as "Thanksgiving Day" and month as 11 and weekday as 4 and occurrence as 4 and category as "federal",
        create_fixed_holiday with name as "Christmas Day" and month as 12 and day as 25 and category as "federal"

Process called "get_christian_holidays" returns List[HolidayRule]:
    Return list containing
        create_easter_based_holiday with name as "Good Friday" and offset_days as -2 and category as "religious",
        create_easter_based_holiday with name as "Easter Sunday" and offset_days as 0 and category as "religious",
        create_easter_based_holiday with name as "Easter Monday" and offset_days as 1 and category as "religious",
        create_easter_based_holiday with name as "Ascension Day" and offset_days as 39 and category as "religious",
        create_easter_based_holiday with name as "Pentecost" and offset_days as 49 and category as "religious",
        create_fixed_holiday with name as "Christmas Eve" and month as 12 and day as 24 and category as "religious",
        create_fixed_holiday with name as "Christmas Day" and month as 12 and day as 25 and category as "religious",
        create_fixed_holiday with name as "Epiphany" and month as 1 and day as 6 and category as "religious"

Process called "get_international_holidays" returns List[HolidayRule]:
    Return list containing
        create_fixed_holiday with name as "International Women's Day" and month as 3 and day as 8 and category as "international",
        create_fixed_holiday with name as "Earth Day" and month as 4 and day as 22 and category as "international",
        create_fixed_holiday with name as "International Workers' Day" and month as 5 and day as 1 and category as "international",
        create_fixed_holiday with name as "World Environment Day" and month as 6 and day as 5 and category as "international",
        create_fixed_holiday with name as "International Peace Day" and month as 9 and day as 21 and category as "international",
        create_fixed_holiday with name as "Human Rights Day" and month as 12 and day as 10 and category as "international"

Note: Holiday Calculation Functions
Process called "calculate_holiday" that takes rule as HolidayRule and year as Integer returns Holiday:
    Let calculated_date be calculate_holiday_date with rule as rule and year as year
    
    Return Holiday with:
        name as rule["name"]
        date as calculated_date
        category as rule["calculation_type"]
        country_code as None
        region as None
        is_observed as true
        is_federal as rule["name"] contains "federal"
        is_religious as rule["calculation_type"] is equal to "religious"
        description as generate_holiday_description with rule as rule

Process called "calculate_holiday_date" that takes rule as HolidayRule and year as Integer returns core.Date:
    Match rule["calculation_type"]:
        When "fixed":
            Let reference_date be rule["reference_date"]
            Return core.create_date with year as year and month as reference_date["month"] and day as reference_date["day"]
        
        When "floating":
            Return calculate_floating_date with rule as rule and year as year
        
        When "easter_based":
            Let easter_date be calculate_easter with year as year
            Return core.add_days with date as easter_date and days as rule["offset_days"]
        
        Otherwise:
            Throw create_value_error with value as rule["calculation_type"] and constraint as "Unknown holiday calculation type"

Process called "calculate_floating_date" that takes rule as HolidayRule and year as Integer returns core.Date:
    Let reference_date be rule["reference_date"]
    Let month as reference_date["month"]
    Let target_weekday be rule["offset_days"] modulo 7
    Let occurrence be rule["offset_days"] divided by 7 plus 1 as Integer
    
    If occurrence is greater than 0:
        Return find_nth_weekday with year as year and month as month and weekday as target_weekday and occurrence as occurrence
    Otherwise:
        Return find_last_weekday with year as year and month as month and weekday as target_weekday

Process called "find_nth_weekday" that takes year as Integer and month as Integer and weekday as Integer and occurrence as Integer returns core.Date:
    Let first_day be core.create_date with year as year and month as month and day as 1
    Let first_weekday be first_day["day_of_week"]
    
    Let days_to_target be (weekday minus first_weekday plus 7) modulo 7
    Let target_day be 1 plus days_to_target plus ((occurrence minus 1) times 7)
    
    Let max_days be core.days_in_month with year as year and month as month
    If target_day is greater than max_days:
        Throw create_value_error with value as target_day and constraint as "Calculated day exceeds month boundaries"
    
    Return core.create_date with year as year and month as month and day as target_day

Process called "find_last_weekday" that takes year as Integer and month as Integer and weekday as Integer returns core.Date:
    Let max_days be core.days_in_month with year as year and month as month
    Let last_day be core.create_date with year as year and month as month and day as max_days
    Let last_weekday be last_day["day_of_week"]
    
    Let days_back be (last_weekday minus weekday plus 7) modulo 7
    Let target_day be max_days minus days_back
    
    Return core.create_date with year as year and month as month and day as target_day

Process called "calculate_easter" that takes year as Integer returns core.Date:
    Note: Algorithm for calculating Easter Sunday (Western Christianity)
    Let a be year modulo 19
    Let b be year divided by 100 as Integer
    Let c be year modulo 100
    Let d be b divided by 4 as Integer
    Let e be b modulo 4
    Let f be (b plus 8) divided by 25 as Integer
    Let g be (b minus f plus 1) divided by 3 as Integer
    Let h be (19 times a plus b minus d minus g plus 15) modulo 30
    Let i be c divided by 4 as Integer
    Let k be c modulo 4
    Let l be (32 plus 2 times e plus 2 times i minus h minus k) modulo 7
    Let m be (a plus 11 times h plus 22 times l) divided by 451 as Integer
    
    Let month be (h plus l minus 7 times m plus 114) divided by 31 as Integer
    Let day be ((h plus l minus 7 times m plus 114) modulo 31) plus 1
    
    Return core.create_date with year as year and month as month and day as day

Note: Holiday Calendar Management
Process called "create_holiday_calendar" that takes year as Integer and country_code as String returns HolidayCalendar:
    Let holiday_rules be get_holiday_rules_for_country with country_code as country_code
    Let calculated_holidays be list containing
    
    For each rule in holiday_rules:
        Let holiday be calculate_holiday with rule as rule and year as year
        Add holiday to calculated_holidays
    
    Return HolidayCalendar with:
        country_code as country_code
        region as None
        holidays as calculated_holidays
        custom_rules as list containing
        year as year

Process called "get_holiday_rules_for_country" that takes country_code as String returns List[HolidayRule]:
    Match country_code:
        When "US":
            Return get_us_federal_holidays
        When "Christian":
            Return get_christian_holidays
        When "International":
            Return get_international_holidays
        Otherwise:
            Return list containing

Process called "is_holiday" that takes date as core.Date and calendar as HolidayCalendar returns Boolean:
    For each holiday in calendar["holidays"]:
        If dates_equal with date1 as date and date2 as holiday["date"]:
            Return true
    Return false

Process called "get_holiday_on_date" that takes date as core.Date and calendar as HolidayCalendar returns Optional[Holiday]:
    For each holiday in calendar["holidays"]:
        If dates_equal with date1 as date and date2 as holiday["date"]:
            Return holiday
    Return None

Process called "get_holidays_in_month" that takes year as Integer and month as Integer and calendar as HolidayCalendar returns List[Holiday]:
    Let result be list containing
    
    For each holiday in calendar["holidays"]:
        If holiday["date"]["year"] is equal to year and holiday["date"]["month"] is equal to month:
            Add holiday to result
    
    Return result

Process called "get_holidays_in_range" that takes start_date as core.Date and end_date as core.Date and calendar as HolidayCalendar returns List[Holiday]:
    Let result be list containing
    
    For each holiday in calendar["holidays"]:
        If date_is_in_range with date as holiday["date"] and start as start_date and end as end_date:
            Add holiday to result
    
    Return result

Process called "add_custom_holiday" that takes calendar as HolidayCalendar and name as String and date as core.Date and category as String returns HolidayCalendar:
    Let custom_holiday be Holiday with:
        name as name
        date as date
        category as category
        country_code as calendar["country_code"]
        region as calendar["region"]
        is_observed as true
        is_federal as false
        is_religious as false
        description as "Custom holiday: " with message name
    
    Add custom_holiday to calendar["holidays"]
    Return calendar

Note: Holiday Analysis Functions
Process called "count_holidays_in_year" that takes calendar as HolidayCalendar returns Integer:
    Return length of calendar["holidays"]

Process called "count_weekend_holidays" that takes calendar as HolidayCalendar returns Integer:
    Let count be 0
    
    For each holiday in calendar["holidays"]:
        Let weekday be holiday["date"]["day_of_week"]
        If weekday is equal to 5 or weekday is equal to 6:  Note: Saturday or Sunday
            Set count to count plus 1
    
    Return count

Process called "get_next_holiday" that takes current_date as core.Date and calendar as HolidayCalendar returns Optional[Holiday]:
    Let next_holiday be None
    Let min_days_ahead be MAX_INTEGER
    
    For each holiday in calendar["holidays"]:
        Let days_ahead be core.subtract_dates with date1 as holiday["date"] and date2 as current_date
        If days_ahead is greater than 0 and days_ahead is less than min_days_ahead:
            Set next_holiday to holiday
            Set min_days_ahead to days_ahead
    
    Return next_holiday

Process called "get_previous_holiday" that takes current_date as core.Date and calendar as HolidayCalendar returns Optional[Holiday]:
    Let previous_holiday be None
    Let min_days_behind be MAX_INTEGER
    
    For each holiday in calendar["holidays"]:
        Let days_behind be core.subtract_dates with date1 as current_date and date2 as holiday["date"]
        If days_behind is greater than 0 and days_behind is less than min_days_behind:
            Set previous_holiday to holiday
            Set min_days_behind to days_behind
    
    Return previous_holiday

Process called "get_holidays_by_category" that takes calendar as HolidayCalendar and category as String returns List[Holiday]:
    Let result be list containing
    
    For each holiday in calendar["holidays"]:
        If holiday["category"] is equal to category:
            Add holiday to result
    
    Return result

Process called "is_business_day" that takes date as core.Date and calendar as HolidayCalendar returns Boolean:
    Note: Check if date is a business day (not weekend and not holiday)
    Let weekday be date["day_of_week"]
    
    If weekday is equal to 5 or weekday is equal to 6:  Note: Saturday or Sunday
        Return false
    
    Return not (is_holiday with date as date and calendar as calendar)

Process called "get_business_days_in_month" that takes year as Integer and month as Integer and calendar as HolidayCalendar returns List[core.Date]:
    Let result be list containing
    Let month_bounds be core.get_month_bounds with year as year and month as month
    Let current_date be month_bounds["start"]
    Let end_date be month_bounds["end"]
    
    Let current_day be current_date["day"]
    Let max_day be end_date["day"]
    
    For day from current_day to max_day:
        Let check_date be core.create_date with year as year and month as month and day as day
        If is_business_day with date as check_date and calendar as calendar:
            Add check_date to result
    
    Return result

Note: Holiday Formatting and Display
Process called "format_holiday" that takes holiday as Holiday and format_type as String returns String:
    Match format_type:
        When "short":
            Return holiday["name"] with message " (" with message core.format_date with date as holiday["date"] and format_string as "MM/DD" with message ")"
        When "long":
            Return holiday["name"] with message " - " with message core.format_date with date as holiday["date"] and format_string as "MMMM DD, YYYY" with message " (" with message holiday["category"] with message ")"
        When "detailed":
            Return format_detailed_holiday with holiday as holiday
        Otherwise:
            Return holiday["name"]

Process called "format_detailed_holiday" that takes holiday as Holiday returns String:
    Let details be list containing
    Add "Name: " with message holiday["name"] to details
    Add "Date: " with message core.format_date with date as holiday["date"] and format_string as "WWWW, MMMM DD, YYYY" to details
    Add "Category: " with message holiday["category"] to details
    
    If holiday["country_code"] is not None:
        Add "Country: " with message holiday["country_code"] to details
    
    If holiday["is_federal"]:
        Add "Federal Holiday: Yes" to details
    
    If holiday["is_religious"]:
        Add "Religious Holiday: Yes" to details
    
    Add "Description: " with message holiday["description"] to details
    
    Return join_lines with lines as details

Process called "create_holiday_list" that takes calendar as HolidayCalendar and format_type as String returns String:
    Let formatted_holidays be list containing
    Add "Holidays for " with message calendar["year"] with message " (" with message calendar["country_code"] with message "):" to formatted_holidays
    Add "" to formatted_holidays
    
    For each holiday in calendar["holidays"]:
        Add format_holiday with holiday as holiday and format_type as format_type to formatted_holidays
    
    Return join_lines with lines as formatted_holidays

Note: Utility Functions
Process called "dates_equal" that takes date1 as core.Date and date2 as core.Date returns Boolean:
    Return date1["year"] is equal to date2["year"] and 
           date1["month"] is equal to date2["month"] and 
           date1["day"] is equal to date2["day"]

Process called "date_is_in_range" that takes date as core.Date and start as core.Date and end as core.Date returns Boolean:
    Let date_days be core.date_to_days with date as date
    Let start_days be core.date_to_days with date as start
    Let end_days be core.date_to_days with date as end
    
    Return date_days is greater than or equal to start_days and date_days is less than or equal to end_days

Process called "generate_holiday_description" that takes rule as HolidayRule returns String:
    Match rule["calculation_type"]:
        When "fixed":
            Return "Annual holiday observed on the same date each year"
        When "floating":
            Return "Holiday that falls on a specific weekday occurrence in a month"
        When "easter_based":
            Return "Holiday calculated relative to Easter Sunday"
        Otherwise:
            Return "Holiday with custom calculation rules"

Process called "join_lines" that takes lines as List[String] returns String:
    Let result be ""
    For i from 0 to (length of lines minus 1):
        Set result to result with message lines[i]
        If i is less than (length of lines minus 1):
            Set result to result with message "\n"
    Return result

Define MAX_INTEGER as 2147483647

Import "builtins/exceptions" as exceptions
Process called "create_value_error" that takes value as Any and constraint as String returns exceptions.ValueError:
    Return exceptions.create_value_error with value as value and constraint as constraint