Process called "get_chinese_month_names" returns List[String]:
    Return list containing "正月", "二月", "三月", "四月", "五月", "六月", "七月", "八月", "九月", "十月", "十一月", "十二月"

Process called "get_chinese_zodiac_animal" that takes year as Integer returns String:
    Let animals be list containing "Rat", "Ox", "Tiger", "Rabbit", "Dragon", "Snake", "Horse", "Goat", "Monkey", "Rooster", "Dog", "Pig"
    Let animal_index be (year minus 4) modulo 12
    Return animals[animal_index]

Process called "get_chinese_zodiac_element" that takes year as Integer returns String:
    Let elements be list containing "Wood", "Fire", "Earth", "Metal", "Water"
    Let element_index be ((year minus 4) divided by 2) modulo 5
    Return elements[element_index]

Process called "is_islamic_leap_year" that takes year as Integer returns Boolean:
    Note: Islamic leap year follows 30-year cycle
    Let cycle_year be year modulo 30
    Let leap_years be list containing 2, 5, 7, 10, 13, 16, 18, 21, 24, 26, 29
    Return leap_years contains cycle_year

Process called "is_hebrew_leap_year" that takes year as Integer returns Boolean:
    Note: Hebrew leap year follows 19-year Metonic cycle
    Let cycle_year be year modulo 19
    Let leap_years be list containing 3, 6, 8, 11, 14, 17, 19
    Return leap_years contains cycle_year

Process called "is_persian_leap_year" that takes year as Integer returns Boolean:
    Note: Persian calendar leap year algorithm (simplified)
    Return ((year plus 2346) times 683) modulo 1029 is less than 342

Process called "create_gregorian_calendar_info" returns CalendarSystemInfo:
    Return CalendarSystemInfo with:
        system_name as "Gregorian"
        description as "Most widely used civil calendar system"
        origin as "Introduced by Pope Gregory XIII in 1582"
