Note: ===== BUSINESS CALENDAR OPERATIONS (12 functions) =====

Process called "calculate_business_days_between" that takes start_date as Date and end_date as Date and business_calendar as BusinessCalendar returns Integer:
    Note: Calculate business days between two dates excluding weekends and holidays
    If not is_valid_date_range with start_date as start_date and end_date as end_date:
        Throw create_value_error with value as "Invalid date range" and constraint as "Start date must be before or equal to end date"
    
    Let business_days be 0
    Let current_date be start_date
    
    While date_is_before_or_equal with date1 as current_date and date2 as end_date:
        If is_business_day_advanced with date as current_date and calendar as business_calendar:
            Set business_days to business_days plus 1
        Set current_date to add_days with date as current_date and days as 1
    
    Return business_days

Process called "is_business_day_advanced" that takes date as Date and calendar as BusinessCalendar returns Boolean:
    Note: Enhanced business day check with custom rules and regional holidays
    Let weekday be date["day_of_week"]
    
    Note: Check if it's a weekend day according to business calendar
    If calendar["weekend_days"] contains weekday:
        Return false
    
    Note: Check if it's a company-specific non-working day
    Let date_key be format_date_key with date as date
    If calendar["company_holidays"] contains date_key:
        Return false
    
    Note: Check if it's a regional/national holiday
    If calendar["regional_holidays"] contains date_key:
        Return false
    
    Note: Check custom business rules
    For each rule in calendar["custom_business_rules"]:
        If evaluate_business_rule with rule as rule and date as date:
            Return false
    
    Return true

Process called "add_business_days" that takes start_date as Date and business_days as Integer and business_calendar as BusinessCalendar returns Date:
    Note: Add specified number of business days to a date
    If business_days is less than 0:
        Return subtract_business_days with start_date as start_date and business_days as (0 minus business_days) and business_calendar as business_calendar
    
    Let current_date be start_date
    Let days_added be 0
    
    While days_added is less than business_days:
        Set current_date to add_days with date as current_date and days as 1
        If is_business_day_advanced with date as current_date and calendar as business_calendar:
            Set days_added to days_added plus 1
    
    Return current_date

Process called "subtract_business_days" that takes start_date as Date and business_days as Integer and business_calendar as BusinessCalendar returns Date:
    Note: Subtract specified number of business days from a date
    Let current_date be start_date
    Let days_subtracted be 0
    
    While days_subtracted is less than business_days:
        Set current_date to subtract_days with date as current_date and days as 1
        If is_business_day_advanced with date as current_date and calendar as business_calendar:
            Set days_subtracted to days_subtracted plus 1
    
    Return current_date

Process called "get_next_business_day" that takes date as Date and business_calendar as BusinessCalendar returns Date:
    Note: Get the next business day after the given date
    Let next_date be add_days with date as date and days as 1
    
    While not is_business_day_advanced with date as next_date and calendar as business_calendar:
        Set next_date to add_days with date as next_date and days as 1
    
    Return next_date

Process called "get_previous_business_day" that takes date as Date and business_calendar as BusinessCalendar returns Date:
    Note: Get the previous business day before the given date
    Let previous_date be subtract_days with date as date and days as 1
    
    While not is_business_day_advanced with date as previous_date and calendar as business_calendar:
        Set previous_date to subtract_days with date as previous_date and days as 1
    
    Return previous_date

Process called "get_business_days_in_month_advanced" that takes year as Integer and month as Integer and business_calendar as BusinessCalendar returns List[Date]:
    Note: Get all business days in a specific month with advanced business rules
    Let business_days be list containing
    Let month_bounds be get_month_bounds with year as year and month as month
    Let current_date be month_bounds["start"]
    Let end_date be month_bounds["end"]
    
    While date_is_before_or_equal with date1 as current_date and date2 as end_date:
        If is_business_day_advanced with date as current_date and calendar as business_calendar:
            Add current_date to business_days
        Set current_date to add_days with date as current_date and days as 1
    
    Return business_days

Process called "calculate_business_day_percentage" that takes year as Integer and month as Integer and business_calendar as BusinessCalendar returns Float:
    Note: Calculate percentage of business days in a month
    Let total_days be days_in_month with year as year and month as month
    Let business_days_list be get_business_days_in_month_advanced with year as year and month as month and business_calendar as business_calendar
    Let business_day_count be length of business_days_list
    
    If total_days is equal to 0:
        Return 0.0
    
    Return (business_day_count times 100.0) divided by total_days

Process called "create_business_calendar" that takes country_code as String and region as Optional[String] and custom_holidays as List[Date] returns BusinessCalendar:
    Note: Create a business calendar with regional settings and custom holidays
    Let weekend_days be get_weekend_days_for_country with country_code as country_code
    Let regional_holidays be get_regional_holidays with country_code as country_code and region as region
    Let company_holidays be custom_holidays
    
    Return BusinessCalendar with:
        country_code as country_code
        region as region
        weekend_days as weekend_days
        regional_holidays as convert_dates_to_key_dict with dates as regional_holidays
        company_holidays as convert_dates_to_key_dict with dates as company_holidays
        custom_business_rules as list containing
        fiscal_year_start_month as get_fiscal_year_start_month with country_code as country_code

Process called "get_fiscal_quarter_dates" that takes year as Integer and quarter as Integer and business_calendar as BusinessCalendar returns QuarterDates:
    Note: Get start and end dates for a fiscal quarter
    If quarter is less than 1 or quarter is greater than 4:
        Throw create_value_error with value as quarter and constraint as "Quarter must be between 1 and 4"
    
    Let fiscal_start_month be business_calendar["fiscal_year_start_month"]
    Let quarter_start_month be fiscal_start_month plus ((quarter minus 1) times 3)
    
    Note: Handle year rollover for fiscal year
    Let actual_year be year
    If quarter_start_month is greater than 12:
        Set quarter_start_month to quarter_start_month minus 12
        Set actual_year to actual_year plus 1
    
    Let quarter_start be create_date with year as actual_year and month as quarter_start_month and day as 1
    Let quarter_end_month be quarter_start_month plus 2
    Let quarter_end_year be actual_year
    
    If quarter_end_month is greater than 12:
        Set quarter_end_month to quarter_end_month minus 12
        Set quarter_end_year to quarter_end_year plus 1
    
    Let days_in_end_month be days_in_month with year as quarter_end_year and month as quarter_end_month
    Let quarter_end be create_date with year as quarter_end_year and month as quarter_end_month and day as days_in_end_month
    
    Return QuarterDates with:
        quarter as quarter
        start_date as quarter_start
        end_date as quarter_end
        business_days as calculate_business_days_between with start_date as quarter_start and end_date as quarter_end and business_calendar as business_calendar

Process called "generate_payroll_schedule" that takes start_date as Date and end_date as Date and frequency as PayrollFrequency and business_calendar as BusinessCalendar returns List[Date]:
    Note: Generate payroll dates within date range based on frequency
    Let payroll_dates be list containing
    Let current_date be start_date
    
    Match frequency:
        When WEEKLY:
            While date_is_before_or_equal with date1 as current_date and date2 as end_date:
                Let payroll_date be ensure_business_day with date as current_date and business_calendar as business_calendar
                Add payroll_date to payroll_dates
                Set current_date to add_days with date as current_date and days as 7
        
        When BIWEEKLY:
            While date_is_before_or_equal with date1 as current_date and date2 as end_date:
                Let payroll_date be ensure_business_day with date as current_date and business_calendar as business_calendar
                Add payroll_date to payroll_dates
                Set current_date to add_days with date as current_date and days as 14
        
        When MONTHLY:
            Let current_month be start_date["month"]
            Let current_year be start_date["year"]
            While date_is_before_or_equal with date1 as create_date with year as current_year and month as current_month and day as 1 and date2 as end_date:
                Let month_end be get_last_day_of_month with year as current_year and month as current_month
                Let payroll_date be ensure_business_day with date as month_end and business_calendar as business_calendar
                Add payroll_date to payroll_dates
                
                Set current_month to current_month plus 1
                If current_month is greater than 12:
                    Set current_month to 1
                    Set current_year to current_year plus 1
        
        When SEMIMONTHLY:
            Let current_month be start_date["month"]
            Let current_year be start_date["year"]
            While date_is_before_or_equal with date1 as create_date with year as current_year and month as current_month and day as 1 and date2 as end_date:
                Note: 15th and last day of month
                Let mid_month be ensure_business_day with date as create_date with year as current_year and month as current_month and day as 15 and business_calendar as business_calendar
                Let month_end be get_last_day_of_month with year as current_year and month as current_month
                Let end_month be ensure_business_day with date as month_end and business_calendar as business_calendar
                
                If date_is_before_or_equal with date1 as mid_month and date2 as end_date:
                    Add mid_month to payroll_dates
                If date_is_before_or_equal with date1 as end_month and date2 as end_date:
                    Add end_month to payroll_dates
                
                Set current_month to current_month plus 1
                If current_month is greater than 12:
                    Set current_month to 1
                    Set current_year to current_year plus 1
    
    Return payroll_dates

Type called "BusinessCalendar":
    country_code as String
    region as Optional[String]
    weekend_days as List[Integer]
    regional_holidays as Dictionary[String, Boolean]
    company_holidays as Dictionary[String, Boolean]
    custom_business_rules as List[BusinessRule]
    fiscal_year_start_month as Integer

Type called "QuarterDates":
    quarter as Integer
    start_date as Date
    end_date as Date
    business_days as Integer

Type PayrollFrequency is:
    | WEEKLY
    | BIWEEKLY
    | SEMIMONTHLY
    | MONTHLY

Type called "BusinessRule":
    rule_name as String
    rule_type as String
    conditions as Dictionary[String, Any]
    action as String

Note: ===== BUSINESS CALENDAR UTILITY FUNCTIONS =====

Process called "format_date_key" that takes date as Date returns String:
    Note: Format date as string key for dictionary lookups
    Return ("" with message date["year"]) with message "-" with message pad_number with number as date["month"] and width as 2 with message "-" with message pad_number with number as date["day"] and width as 2

Process called "convert_dates_to_key_dict" that takes dates as List[Date] returns Dictionary[String, Boolean]:
    Note: Convert list of dates to dictionary with date keys
    Let result be dictionary with
    
    For each date in dates:
        Let date_key be format_date_key with date as date
        Set result[date_key] to true
    
    Return result

Process called "get_weekend_days_for_country" that takes country_code as String returns List[Integer]:
    Note: Get weekend days for country (0=Sunday, 1=Monday, ..., 6=Saturday)
    Match country_code:
        When "US" or "CA" or "MX" or "BR" or "AU" or "NZ":
            Return list containing 6, 0  Note: Saturday, Sunday
        When "SA" or "AE" or "BH" or "KW" or "OM" or "QA":
            Return list containing 5, 6  Note: Friday, Saturday
        When "IL":
            Return list containing 5, 6  Note: Friday, Saturday
        When "BD" or "AF":
            Return list containing 5, 6  Note: Friday, Saturday
        Otherwise:
            Return list containing 6, 0  Note: Default: Saturday, Sunday

Process called "get_fiscal_year_start_month" that takes country_code as String returns Integer:
    Note: Get fiscal year start month for country
    Match country_code:
        When "US":
            Return 10  Note: October
        When "UK" or "IN" or "AU" or "NZ":
            Return 4   Note: April
        When "JP":
            Return 4   Note: April
        When "CA":
            Return 4   Note: April
        Otherwise:
            Return 1   Note: Default: January

Process called "ensure_business_day" that takes date as Date and business_calendar as BusinessCalendar returns Date:
    Note: If date is not a business day, move to next business day
    If is_business_day_advanced with date as date and calendar as business_calendar:
        Return date
    Otherwise:
        Return get_next_business_day with date as date and business_calendar as business_calendar

Process called "evaluate_business_rule" that takes rule as BusinessRule and date as Date returns Boolean:
    Note: Evaluate if business rule applies to date (makes it non-business day)
    Match rule["rule_type"]:
        When "date_range":
            Let start_date be rule["conditions"]["start_date"]
            Let end_date be rule["conditions"]["end_date"]
            Return date_is_in_range with date as date and start as start_date and end as end_date
        When "monthly_closure":
            Let closure_day be rule["conditions"]["day"]
            Return date["day"] is equal to closure_day
        When "seasonal_closure":
            Let closure_months be rule["conditions"]["months"]
            Return closure_months contains date["month"]
        Otherwise:
            Return false

Process called "get_last_day_of_month" that takes year as Integer and month as Integer returns Date:
    Note: Get the last day of the month
    Let days_in_current_month be days_in_month with year as year and month as month
    Return create_date with year as year and month as month and day as days_in_current_month

Note: ===== ADDITIONAL UTILITY FUNCTIONS FOR BUSINESS CALENDAR =====

Process called "get_medium_date_format" that takes locale as Locale returns String:
    Match locale["language_code"]:
        When "en":
            Return "MMM D, YYYY"
        When "de":
            Return "D. MMM YYYY"
        When "fr":
            Return "D MMM YYYY"
        When "es":
            Return "D MMM YYYY"
        When "ja":
            Return "YYYY年M月D日"
        When "zh":
            Return "YYYY年M月D日"
        When "ar":
            Return "D MMM، YYYY"
        Otherwise:
            Return "MMM D, YYYY"

Process called "get_long_date_format" that takes locale as Locale returns String:
    Match locale["language_code"]:
        When "en":
            Return "MMMM D, YYYY"
        When "de":
            Return "D. MMMM YYYY"
        When "fr":
            Return "D MMMM YYYY"
        When "es":
            Return "D de MMMM de YYYY"
        When "ja":
            Return "YYYY年M月D日"
        When "zh":
            Return "YYYY年M月D日"
        When "ar":
            Return "D MMMM، YYYY"
        Otherwise:
            Return "MMMM D, YYYY"

Process called "get_full_date_format" that takes locale as Locale returns String:
    Match locale["language_code"]:
        When "en":
            Return "WWWW, MMMM D, YYYY"
        When "de":
            Return "WWWW, D. MMMM YYYY"
        When "fr":
            Return "WWWW D MMMM YYYY"
        When "es":
            Return "WWWW, D de MMMM de YYYY"
        When "ja":
            Return "YYYY年M月D日WWWW"
        When "zh":
            Return "YYYY年M月D日WWWW"
        When "ar":
            Return "WWWW، D MMMM، YYYY"
        Otherwise:
            Return "WWWW, MMMM D, YYYY"

Process called "get_24h_time_format" that takes locale as Locale returns String:
    Match locale["language_code"]:
        When "en":
            Return "HH:mm"
        When "de" or "fr" or "es":
            Return "HH:mm"
        When "ja" or "zh":
            Return "HH:mm"
        When "ar":
            Return "HH:mm"
        Otherwise:
            Return "HH:mm"

Process called "get_weekend_days_for_locale" that takes locale_code as String returns List[Integer]:
    Note: Extract country from locale and get weekend days
    Let parts be split_string with text as locale_code and delimiter as "_"
    Let country_code be "US"  Note: Default
    
    If length of parts is greater than 1:
        Set country_code to parts[1]
    
    Return get_weekend_days_for_country with country_code as country_code

Process called "pad_number" that takes number as Integer and width as Integer returns String:
    Note: Pad number with leading zeros to specified width
    Let number_string be "" with message number
    Let current_length be length of number_string
    
    If current_length is greater than or equal to width:
        Return number_string
    
    Let padding_needed be width minus current_length
    Let result be ""
    
    For i from 1 to padding_needed:
        Set result to result with message "0"
    
    Set result to result with message number_string
    Return result

Note: ===== MULTIPLE CALENDAR SYSTEMS (18 functions) =====

Process called "convert_gregorian_to_julian" that takes gregorian_date as Date returns JulianDate:
    Note: Convert Gregorian date to Julian calendar date
    Let year be gregorian_date["year"]
    Let month be gregorian_date["month"]
    Let day be gregorian_date["day"]
    
    Note: Calculate Julian Day Number first, then convert to Julian calendar
    Let jdn be calculate_julian_day_number with date as gregorian_date
    Let julian_calendar_date be julian_day_number_to_julian_date with jdn as jdn
    
    Return JulianDate with:
        year as julian_calendar_date["year"]
        month as julian_calendar_date["month"]
        day as julian_calendar_date["day"]
        calendar_system as "julian"

Process called "convert_gregorian_to_islamic" that takes gregorian_date as Date returns IslamicDate:
    Note: Convert Gregorian date to Islamic Hijri calendar
    Let jdn be calculate_julian_day_number with date as gregorian_date
    Let islamic_date be julian_day_number_to_islamic_date with jdn as jdn
    
    Return IslamicDate with:
        year as islamic_date["year"]
        month as islamic_date["month"]
        day as islamic_date["day"]
        calendar_system as "islamic"
        month_name as get_islamic_month_name with month as islamic_date["month"]

Process called "convert_gregorian_to_hebrew" that takes gregorian_date as Date returns HebrewDate:
    Note: Convert Gregorian date to Hebrew calendar
    Let jdn be calculate_julian_day_number with date as gregorian_date
    Let hebrew_date be julian_day_number_to_hebrew_date with jdn as jdn
    
    Return HebrewDate with:
        year as hebrew_date["year"]
        month as hebrew_date["month"]
        day as hebrew_date["day"]
        calendar_system as "hebrew"
        month_name as get_hebrew_month_name with month as hebrew_date["month"] and year as hebrew_date["year"]

Process called "convert_gregorian_to_persian" that takes gregorian_date as Date returns PersianDate:
    Note: Convert Gregorian date to Persian (Solar Hijri) calendar
    Let jdn be calculate_julian_day_number with date as gregorian_date
    Let persian_date be julian_day_number_to_persian_date with jdn as jdn
    
    Return PersianDate with:
        year as persian_date["year"]
        month as persian_date["month"]
        day as persian_date["day"]
        calendar_system as "persian"
        month_name as get_persian_month_name with month as persian_date["month"]

Process called "convert_gregorian_to_chinese" that takes gregorian_date as Date returns ChineseDate:
    Note: Convert Gregorian date to Chinese calendar with lunar months and zodiac
    Let jdn be calculate_julian_day_number with date as gregorian_date
    Let chinese_date be julian_day_number_to_chinese_date with jdn as jdn
    
    Return ChineseDate with:
        year as chinese_date["year"]
        month as chinese_date["month"]
        day as chinese_date["day"]
        calendar_system as "chinese"
        lunar_month as chinese_date["lunar_month"]
        zodiac_animal as get_chinese_zodiac_animal with year as chinese_date["year"]
        zodiac_element as get_chinese_zodiac_element with year as chinese_date["year"]

Process called "convert_islamic_to_gregorian" that takes islamic_date as IslamicDate returns Date:
    Note: Convert Islamic Hijri date to Gregorian calendar
    Let jdn be islamic_date_to_julian_day_number with islamic_date as islamic_date
    Return julian_day_number_to_gregorian_date with jdn as jdn

Process called "convert_hebrew_to_gregorian" that takes hebrew_date as HebrewDate returns Date:
    Note: Convert Hebrew date to Gregorian calendar
    Let jdn be hebrew_date_to_julian_day_number with hebrew_date as hebrew_date
    Return julian_day_number_to_gregorian_date with jdn as jdn

Process called "convert_persian_to_gregorian" that takes persian_date as PersianDate returns Date:
    Note: Convert Persian date to Gregorian calendar
    Let jdn be persian_date_to_julian_day_number with persian_date as persian_date
    Return julian_day_number_to_gregorian_date with jdn as jdn

Process called "convert_chinese_to_gregorian" that takes chinese_date as ChineseDate returns Date:
    Note: Convert Chinese date to Gregorian calendar (approximate)
    Let jdn be chinese_date_to_julian_day_number with chinese_date as chinese_date
    Return julian_day_number_to_gregorian_date with jdn as jdn

Process called "get_calendar_system_info" that takes calendar_system as String returns CalendarSystemInfo:
    Note: Get comprehensive information about a calendar system
    Match calendar_system:
        When "gregorian":
            Return create_gregorian_calendar_info
        When "julian":
            Return create_julian_calendar_info
        When "islamic":
            Return create_islamic_calendar_info
        When "hebrew":
            Return create_hebrew_calendar_info
        When "persian":
            Return create_persian_calendar_info
        When "chinese":
            Return create_chinese_calendar_info
        Otherwise:
            Throw create_value_error with value as calendar_system and constraint as "Unsupported calendar system"

Process called "format_date_in_calendar_system" that takes date as Date and calendar_system as String and format_style as String returns String:
    Note: Format date according to specific calendar system conventions
    Match calendar_system:
        When "gregorian":
            Return format_gregorian_date with date as date and format_style as format_style
        When "islamic":
            Let islamic_date be convert_gregorian_to_islamic with gregorian_date as date
            Return format_islamic_date with islamic_date as islamic_date and format_style as format_style
        When "hebrew":
            Let hebrew_date be convert_gregorian_to_hebrew with gregorian_date as date
            Return format_hebrew_date with hebrew_date as hebrew_date and format_style as format_style
        When "persian":
            Let persian_date be convert_gregorian_to_persian with gregorian_date as date
            Return format_persian_date with persian_date as persian_date and format_style as format_style
        When "chinese":
            Let chinese_date be convert_gregorian_to_chinese with gregorian_date as date
            Return format_chinese_date with chinese_date as chinese_date and format_style as format_style
        Otherwise:
            Return format_date with date as date and format_string as "YYYY-MM-DD"

Process called "calculate_days_in_month_for_calendar" that takes year as Integer and month as Integer and calendar_system as String returns Integer:
    Note: Calculate days in month for specific calendar system
    Match calendar_system:
        When "gregorian":
            Return days_in_month with year as year and month as month
        When "islamic":
            Return get_islamic_days_in_month with year as year and month as month
        When "hebrew":
            Return get_hebrew_days_in_month with year as year and month as month
        When "persian":
            Return get_persian_days_in_month with year as year and month as month
        When "chinese":
            Return get_chinese_days_in_month with year as year and month as month
        Otherwise:
            Return 30  Note: Default approximation

Process called "get_new_year_date" that takes year as Integer and calendar_system as String returns Date:
    Note: Get New Year date for specific calendar system in Gregorian equivalent
    Match calendar_system:
        When "gregorian":
            Return create_date with year as year and month as 1 and day as 1
        When "islamic":
            Let islamic_new_year be IslamicDate with year as year, month as 1, day as 1, calendar_system as "islamic", month_name as "Muharram"
            Return convert_islamic_to_gregorian with islamic_date as islamic_new_year
        When "hebrew":
            Let hebrew_new_year be HebrewDate with year as year, month as 7, day as 1, calendar_system as "hebrew", month_name as "Tishrei"
            Return convert_hebrew_to_gregorian with hebrew_date as hebrew_new_year
        When "persian":
            Let persian_new_year be PersianDate with year as year, month as 1, day as 1, calendar_system as "persian", month_name as "Farvardin"
            Return convert_persian_to_gregorian with persian_date as persian_new_year
        When "chinese":
            Return calculate_chinese_new_year with year as year
        Otherwise:
            Return create_date with year as year and month as 1 and day as 1

Process called "calculate_chinese_new_year" that takes year as Integer returns Date:
    Note: Calculate Chinese New Year date (complex lunar calculation)
    Note: Simplified calculation - Chinese New Year typically falls between Jan 21 - Feb 20
    Let base_day be 21
    Let cycle_offset be (year minus 1900) modulo 12
    Let estimated_day be base_day plus cycle_offset
    
    If estimated_day is greater than 31:
        Return create_date with year as year and month as 2 and day as (estimated_day minus 31)
    Otherwise:
        Return create_date with year as year and month as 1 and day as estimated_day

Process called "is_leap_year_in_calendar" that takes year as Integer and calendar_system as String returns Boolean:
    Note: Check if year is leap year in specific calendar system
    Match calendar_system:
        When "gregorian":
            Return is_leap_year with year as year
        When "julian":
            Return year modulo 4 is equal to 0
        When "islamic":
            Return is_islamic_leap_year with year as year
        When "hebrew":
            Return is_hebrew_leap_year with year as year
        When "persian":
            Return is_persian_leap_year with year as year
        Otherwise:
            Return false

Process called "get_month_names_for_calendar" that takes calendar_system as String returns List[String]:
    Note: Get month names for specific calendar system
    Match calendar_system:
        When "gregorian":
            Return MONTH_NAMES
        When "islamic":
            Return get_islamic_month_names
        When "hebrew":
            Return get_hebrew_month_names
        When "persian":
            Return get_persian_month_names
        When "chinese":
            Return get_chinese_month_names
        Otherwise:
            Return MONTH_NAMES

Process called "convert_between_calendar_systems" that takes source_date as Any and source_system as String and target_system as String returns Any:
    Note: Universal calendar conversion function
    If source_system is equal to target_system:
        Return source_date
    
    Note: Convert to Gregorian as intermediate step
    Let gregorian_date be convert_to_gregorian with date as source_date and source_system as source_system
    
    Note: Convert from Gregorian to target system
    Return convert_from_gregorian with gregorian_date as gregorian_date and target_system as target_system

Process called "convert_to_gregorian" that takes date as Any and source_system as String returns Date:
    Note: Convert any calendar system to Gregorian
    Match source_system:
        When "gregorian":
            Return date
        When "islamic":
            Return convert_islamic_to_gregorian with islamic_date as date
        When "hebrew":
            Return convert_hebrew_to_gregorian with hebrew_date as date
        When "persian":
            Return convert_persian_to_gregorian with persian_date as date
        When "chinese":
            Return convert_chinese_to_gregorian with chinese_date as date
        Otherwise:
            Return date  Note: Assume already Gregorian

Process called "convert_from_gregorian" that takes gregorian_date as Date and target_system as String returns Any:
    Note: Convert Gregorian to any calendar system
    Match target_system:
        When "gregorian":
            Return gregorian_date
        When "islamic":
            Return convert_gregorian_to_islamic with gregorian_date as gregorian_date
        When "hebrew":
            Return convert_gregorian_to_hebrew with gregorian_date as gregorian_date
        When "persian":
            Return convert_gregorian_to_persian with gregorian_date as gregorian_date
        When "chinese":
            Return convert_gregorian_to_chinese with gregorian_date as gregorian_date
        Otherwise:
            Return gregorian_date  Note: Default to Gregorian

Note: ===== CALENDAR SYSTEM TYPE DEFINITIONS =====

Type called "JulianDate":
    year as Integer
    month as Integer
    day as Integer
    calendar_system as String

Type called "IslamicDate":
    year as Integer
    month as Integer
    day as Integer
    calendar_system as String
    month_name as String

Type called "HebrewDate":
    year as Integer
    month as Integer
    day as Integer
    calendar_system as String
    month_name as String

Type called "PersianDate":
    year as Integer
    month as Integer
    day as Integer
    calendar_system as String
    month_name as String

