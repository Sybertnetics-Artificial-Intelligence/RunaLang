        "lv_LV", "lt_LT", "uk_UA", "be_BY",
        "he_IL", "el_GR", "mt_MT", "ga_IE"

Process called "detect_locale_from_timezone" that takes timezone_id as String returns String:
    Note: Detect appropriate locale based on timezone
    Match timezone_id:
        When "America/New_York", "America/Chicago", "America/Denver", "America/Los_Angeles":
            Return "en_US"
        When "America/Toronto", "America/Vancouver":
            Return "en_CA"
        When "Europe/London":
            Return "en_GB"
        When "Europe/Paris":
            Return "fr_FR"
        When "Europe/Berlin":
            Return "de_DE"
        When "Europe/Rome":
            Return "it_IT"
        When "Europe/Madrid":
            Return "es_ES"
        When "Asia/Tokyo":
            Return "ja_JP"
        When "Asia/Shanghai":
            Return "zh_CN"
        When "Asia/Seoul":
            Return "ko_KR"
        When "Australia/Sydney", "Australia/Melbourne":
            Return "en_AU"
        Otherwise:
            Return "en_US"

Process called "format_number_localized" that takes number as Float and locale_code as String and format_type as String returns String:
    Note: Format numbers according to locale conventions
    Let culture_info be get_culture_info with locale_code as locale_code
    Let number_format be culture_info["number_format"]
    
    Match format_type:
        When "decimal":
            Return format_decimal_localized with number as number and format as number_format
        When "currency":
            Return format_currency_localized with number as number and format as number_format
        When "percent":
            Return format_percent_localized with number as number and format as number_format
        Otherwise:
            Return format_decimal_localized with number as number and format as number_format

Process called "parse_date_localized" that takes date_string as String and locale_code as String returns ParseResult:
    Note: Parse date string using locale-specific formats and conventions
    Let culture_info be get_culture_info with locale_code as locale_code
    Let locale be culture_info["locale"]
    Let strings be culture_info["localized_strings"]
    
    Note: Create locale-aware parsing context
    Let context be create_localized_parse_context with locale as locale and strings as strings
    
    Note: Try locale-specific format first
    Let locale_result be parse_with_specific_format with input as date_string and format as locale["date_format"] and context as context
    If locale_result["success"]:
        Set locale_result["confidence_score"] to 0.9
        Return locale_result
    
    Note: Try common locale formats
    Let common_formats be get_common_date_formats_for_locale with locale_code as locale_code
    For each format in common_formats:
        Let attempt be parse_with_specific_format with input as date_string and format as format and context as context
        If attempt["success"]:
            Set attempt["confidence_score"] to 0.8
            Return attempt
    
    Note: Fall back to natural language parsing with locale awareness
    Return parse_natural_language_localized with input as date_string and locale_code as locale_code

Process called "get_calendar_week_info" that takes date as Date and locale_code as String returns Dictionary[String, Any]:
    Note: Get week information according to locale conventions
    Let culture_info be get_culture_info with locale_code as locale_code
    Let locale be culture_info["locale"]
    
    Let week_start_day be locale["first_day_of_week"]
    Let adjusted_date be adjust_date_for_week_start with date as date and start_day as week_start_day
    
    Return dictionary with:
        "week_of_year" as calculate_iso_week_number with date as adjusted_date
        "week_start_date" as get_week_start_date with date as date and start_day as week_start_day
        "week_end_date" as get_week_end_date with date as date and start_day as week_start_day
        "first_day_of_week" as week_start_day
        "days_in_week" as 7

Process called "sort_dates_localized" that takes dates as List[Date] and locale_code as String returns List[Date]:
    Note: Sort dates according to locale-specific sorting rules
    Let culture_info be get_culture_info with locale_code as locale_code
    Let sorting_rules be culture_info["sorting_rules"]
    
    Note: For now, use standard chronological sorting
    Note: In full implementation, would consider cultural sorting preferences
    Return sort_dates_chronologically with dates as dates

