Note: ===== CALENDAR SYSTEM UTILITY FUNCTIONS =====

Process called "julian_day_number_to_gregorian_date" that takes jdn as Integer returns Date:
    Note: Convert Julian Day Number to Gregorian date (simplified algorithm)
    Let a be jdn plus 32044
    Let b be (4 times a plus 3) divided by 146097
    Let c be a minus ((146097 times b) divided by 4)
    Let d be (4 times c plus 3) divided by 1461
    Let e be c minus ((1461 times d) divided by 4)
    Let m be (5 times e plus 2) divided by 153
    
    Let day be e minus ((153 times m plus 2) divided by 5) plus 1
    Let month be m plus 3 minus (12 times (m divided by 10))
    Let year be 100 times b plus d minus 4800 plus (m divided by 10)
    
    Return create_date with year as year and month as month and day as day

Process called "calculate_julian_day_number" that takes date as Date returns Integer:
    Note: Calculate Julian Day Number for Gregorian date (simplified)
    Let year be date["year"]
    Let month be date["month"]
    Let day be date["day"]
    
    If month is less than or equal to 2:
        Set year to year minus 1
        Set month to month plus 12
    
    Let a be year divided by 100
    Let b be 2 minus a plus (a divided by 4)
    
    Return (365.25 times (year plus 4716)) plus (30.6001 times (month plus 1)) plus day plus b minus 1524 as Integer

Process called "get_islamic_month_names" returns List[String]:
    Return list containing "Muharram", "Safar", "Rabi' al-awwal", "Rabi' al-thani", "Jumada al-awwal", "Jumada al-thani", "Rajab", "Sha'ban", "Ramadan", "Shawwal", "Dhu al-Qi'dah", "Dhu al-Hijjah"

Process called "get_hebrew_month_names" returns List[String]:
    Return list containing "Tishrei", "Heshvan", "Kislev", "Tevet", "Shvat", "Adar", "Nisan", "Iyar", "Sivan", "Tammuz", "Av", "Elul"

Process called "get_persian_month_names" returns List[String]:
