Note:
Runa Standard Library: Calendar Core System

Provides the fundamental calendar system with date/time calculations, calendar
arithmetic, and timezone support as specified in the Runa language specification.
All calculations follow ISO 8601 standards and astronomical algorithms.
:End Note

Type Date is Dictionary with:
    year as Integer
    month as Integer
    day as Integer
    day_of_week as Integer
    day_of_year as Integer
    week_of_year as Integer
    is_leap_year as Boolean

Type Time is Dictionary with:
    hour as Integer
    minute as Integer
    second as Integer
    millisecond as Integer
    microsecond as Integer
    nanosecond as Integer

Type DateTime is Dictionary with:
    date as Date
    time as Time
    timezone as String
    utc_offset as Integer
    is_dst as Boolean
    timestamp as Integer

Type Duration is Dictionary with:
    days as Integer
    hours as Integer
    minutes as Integer
    seconds as Integer
    milliseconds as Integer
    total_seconds as Float

Type CalendarSystem is Dictionary with:
    calendar_type as String
    epoch_year as Integer
    months_per_year as Integer
    days_per_week as Integer
    week_start_day as Integer
    leap_year_rule as String

Note: Calendar Constants
Define GREGORIAN_EPOCH as 1
Define JULIAN_EPOCH as -45
Define DAYS_PER_WEEK as 7
Define MONTHS_PER_YEAR as 12
Define HOURS_PER_DAY as 24
Define MINUTES_PER_HOUR as 60
Define SECONDS_PER_MINUTE as 60
Define MILLISECONDS_PER_SECOND as 1000

Define WEEKDAY_NAMES as list containing "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"
Define MONTH_NAMES as list containing "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"
Define MONTH_ABBREVIATIONS as list containing "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"

Define DAYS_IN_MONTH as list containing 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31
Define DAYS_IN_MONTH_LEAP as list containing 31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31

Note: Core Calendar Functions
Process called "create_date" that takes year as Integer and month as Integer and day as Integer returns Date:
    If not (is_valid_date with year as year and month as month and day as day):
        Throw create_value_error with value as dictionary with "year" as year, "month" as month, "day" as day and constraint as "Invalid date"
    
    Let is_leap be is_leap_year with year as year
    Let day_of_week be calculate_day_of_week with year as year and month as month and day as day
    Let day_of_year be calculate_day_of_year with year as year and month as month and day as day
    Let week_of_year be calculate_week_of_year with year as year and month as month and day as day
    
    Return Date with:
        year as year
        month as month
        day as day
        day_of_week as day_of_week
        day_of_year as day_of_year
        week_of_year as week_of_year
        is_leap_year as is_leap

Process called "create_time" that takes hour as Integer and minute as Integer and second as Integer returns Time:
    If not (is_valid_time with hour as hour and minute as minute and second as second):
        Throw create_value_error with value as dictionary with "hour" as hour, "minute" as minute, "second" as second and constraint as "Invalid time"
    
    Return Time with:
        hour as hour
        minute as minute
        second as second
        millisecond as 0
        microsecond as 0
        nanosecond as 0

Process called "create_datetime" that takes date as Date and time as Time and timezone as String returns DateTime:
    Let utc_offset be get_timezone_offset with timezone as timezone
    Let is_dst be is_daylight_saving_time with date as date and timezone as timezone
    Let timestamp be calculate_timestamp with date as date and time as time and utc_offset as utc_offset
    
    Return DateTime with:
        date as date
        time as time
        timezone as timezone
        utc_offset as utc_offset
        is_dst as is_dst
        timestamp as timestamp

Process called "now" returns DateTime:
    Let current_timestamp be get_current_unix_timestamp
    Return from_timestamp with timestamp as current_timestamp and timezone as "UTC"

Process called "today" returns Date:
    Let current_datetime be now
    Return current_datetime["date"]

Process called "current_time" returns Time:
    Let current_datetime be now
    Return current_datetime["time"]

Process called "is_leap_year" that takes year as Integer returns Boolean:
    If year modulo 400 is equal to 0:
        Return true
    Otherwise if year modulo 100 is equal to 0:
        Return false
    Otherwise if year modulo 4 is equal to 0:
        Return true
    Otherwise:
        Return false

Process called "days_in_month" that takes year as Integer and month as Integer returns Integer:
    If month is less than 1 or month is greater than 12:
        Throw create_value_error with value as month and constraint as "Month must be between 1 and 12"
    
    If month is equal to 2 and is_leap_year with year as year:
        Return 29
    
    Return DAYS_IN_MONTH[month minus 1]

Process called "days_in_year" that takes year as Integer returns Integer:
    If is_leap_year with year as year:
        Return 366
    Otherwise:
        Return 365

Process called "is_valid_date" that takes year as Integer and month as Integer and day as Integer returns Boolean:
    If month is less than 1 or month is greater than 12:
        Return false
    
    If day is less than 1:
        Return false
    
    Let max_days be days_in_month with year as year and month as month
    Return day is less than or equal to max_days

Process called "is_valid_time" that takes hour as Integer and minute as Integer and second as Integer returns Boolean:
    Return hour is greater than or equal to 0 and hour is less than 24 and
           minute is greater than or equal to 0 and minute is less than 60 and
           second is greater than or equal to 0 and second is less than 60

Process called "calculate_day_of_week" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Note: Zeller's congruence algorithm
    Let adjusted_month be month
    Let adjusted_year be year
    
    If month is less than 3:
        Set adjusted_month to month plus 12
        Set adjusted_year to year minus 1
    
    Let q be day
    Let m be adjusted_month
    Let k be adjusted_year modulo 100
    Let j be adjusted_year divided by 100 as Integer
    
    Let h be (q plus ((13 times (m plus 1)) divided by 5 as Integer) plus k plus (k divided by 4 as Integer) plus (j divided by 4 as Integer) minus (2 times j)) modulo 7
    
    Note: Convert to Monday=0, Sunday=6 format
    Return (h plus 5) modulo 7

Process called "calculate_day_of_year" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Let day_count be 0
    
    For m from 1 to (month minus 1):
        Set day_count to day_count plus days_in_month with year as year and month as m
    
    Return day_count plus day

Process called "calculate_week_of_year" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Let day_of_year be calculate_day_of_year with year as year and month as month and day as day
    Let jan_1_day_of_week be calculate_day_of_week with year as year and month as 1 and day as 1
    
    Note: ISO 8601 week calculation
    Let days_from_monday be (day_of_year minus 1) plus jan_1_day_of_week
    Return (days_from_monday divided by 7 as Integer) plus 1

Process called "add_days" that takes date as Date and days as Integer returns Date:
    Let total_days be date_to_days with date as date plus days
    Return days_to_date with days as total_days

Process called "add_months" that takes date as Date and months as Integer returns Date:
    Let new_year be date["year"]
    Let new_month be date["month"] plus months
    
    While new_month is greater than 12:
        Set new_year to new_year plus 1
        Set new_month to new_month minus 12
    
    While new_month is less than 1:
        Set new_year to new_year minus 1
        Set new_month to new_month plus 12
    
    Let max_day be days_in_month with year as new_year and month as new_month
    Let new_day be minimum of date["day"] and max_day
    
    Return create_date with year as new_year and month as new_month and day as new_day

Process called "add_years" that takes date as Date and years as Integer returns Date:
    Let new_year be date["year"] plus years
    Let new_month be date["month"]
    Let new_day be date["day"]
    
    Note: Handle leap year edge case for February 29
    If new_month is equal to 2 and new_day is equal to 29 and not (is_leap_year with year as new_year):
        Set new_day to 28
    
    Return create_date with year as new_year and month as new_month and day as new_day

Process called "subtract_dates" that takes date1 as Date and date2 as Date returns Integer:
    Let days1 be date_to_days with date as date1
    Let days2 be date_to_days with date as date2
    Return days1 minus days2

Process called "date_to_days" that takes date as Date returns Integer:
    Note: Calculate days since epoch (January 1, Year 1)
    Let year be date["year"]
    Let month be date["month"]
    Let day be date["day"]
    
    Let total_days be day minus 1
    
    Note: Add days for complete years
    For y from 1 to (year minus 1):
        Set total_days to total_days plus days_in_year with year as y
    
    Note: Add days for complete months in current year
    For m from 1 to (month minus 1):
        Set total_days to total_days plus days_in_month with year as year and month as m
    
    Return total_days

Process called "days_to_date" that takes days as Integer returns Date:
    Note: Convert days since epoch back to date
    Let remaining_days be days
    Let year be 1
    
    Note: Find the year
    While remaining_days is greater than or equal to days_in_year with year as year:
        Set remaining_days to remaining_days minus days_in_year with year as year
        Set year to year plus 1
    
    Note: Find the month
    Let month be 1
    While remaining_days is greater than or equal to days_in_month with year as year and month as month:
        Set remaining_days to remaining_days minus days_in_month with year as year and month as month
        Set month to month plus 1
    
    Let day be remaining_days plus 1
    
    Return create_date with year as year and month as month and day as day

Process called "format_date" that takes date as Date and format_string as String returns String:
    Let result be format_string
    
    Note: Replace format tokens
    Set result to replace_all with text as result and old_text as "YYYY" and new_text as zero_pad with number as date["year"] and width as 4
    Set result to replace_all with text as result and old_text as "YY" and new_text as zero_pad with number as (date["year"] modulo 100) and width as 2
    Set result to replace_all with text as result and old_text as "MM" and new_text as zero_pad with number as date["month"] and width as 2
    Set result to replace_all with text as result and old_text as "DD" and new_text as zero_pad with number as date["day"] and width as 2
    Set result to replace_all with text as result and old_text as "DDD" and new_text as zero_pad with number as date["day_of_year"] and width as 3
    Set result to replace_all with text as result and old_text as "WW" and new_text as zero_pad with number as date["week_of_year"] and width as 2
    
    Set result to replace_all with text as result and old_text as "MMMM" and new_text as MONTH_NAMES[date["month"] minus 1]
    Set result to replace_all with text as result and old_text as "MMM" and new_text as MONTH_ABBREVIATIONS[date["month"] minus 1]
    Set result to replace_all with text as result and old_text as "WWWW" and new_text as WEEKDAY_NAMES[date["day_of_week"]]
    
    Return result

Process called "parse_date" that takes date_string as String and format_string as String returns Date:
    Note: Parse date string according to format
    Let tokens be extract_format_tokens with format_string as format_string
    Let values be extract_date_values with date_string as date_string and tokens as tokens
    
    Let year be get_value_or_default with values as values and key as "year" and default as 1
    Let month be get_value_or_default with values as values and key as "month" and default as 1
    Let day be get_value_or_default with values as values and key as "day" and default as 1
    
    Return create_date with year as year and month as month and day as day

Process called "get_week_bounds" that takes year as Integer and week as Integer returns Dictionary[String, Date]:
    Let jan_1 be create_date with year as year and month as 1 and day as 1
    Let jan_1_day_of_week be jan_1["day_of_week"]
    
    Let days_to_first_monday be (7 minus jan_1_day_of_week) modulo 7
    Let first_week_start be add_days with date as jan_1 and days as days_to_first_monday
    
    Let week_start_days be (week minus 1) times 7
    Let week_start be add_days with date as first_week_start and days as week_start_days
    Let week_end be add_days with date as week_start and days as 6
    
    Return dictionary with:
        "start" as week_start
        "end" as week_end

Process called "get_month_bounds" that takes year as Integer and month as Integer returns Dictionary[String, Date]:
    Let month_start be create_date with year as year and month as month and day as 1
    Let days_in_current_month be days_in_month with year as year and month as month
    Let month_end be create_date with year as year and month as month and day as days_in_current_month
    
    Return dictionary with:
        "start" as month_start
        "end" as month_end

Process called "get_year_bounds" that takes year as Integer returns Dictionary[String, Date]:
    Let year_start be create_date with year as year and month as 1 and day as 1
    Let year_end be create_date with year as year and month as 12 and day as 31
    
    Return dictionary with:
        "start" as year_start
        "end" as year_end

Note: Time and DateTime operations
Process called "add_time" that takes time1 as Time and time2 as Time returns Time:
    Let total_seconds be time_to_seconds with time as time1 plus time_to_seconds with time as time2
    Return seconds_to_time with seconds as total_seconds

Process called "subtract_time" that takes time1 as Time and time2 as Time returns Duration:
    Let seconds1 be time_to_seconds with time as time1
    let seconds2 be time_to_seconds with time as time2
    Let diff_seconds be seconds1 minus seconds2
    
    Return seconds_to_duration with seconds as diff_seconds

Process called "time_to_seconds" that takes time as Time returns Integer:
    Return (time["hour"] times 3600) plus (time["minute"] times 60) plus time["second"]

Process called "seconds_to_time" that takes seconds as Integer returns Time:
    Let normalized_seconds be seconds modulo 86400  Note: 24 * 60 * 60
    If normalized_seconds is less than 0:
        Set normalized_seconds to normalized_seconds plus 86400
    
    Let hours be normalized_seconds divided by 3600 as Integer
    Let remaining_seconds be normalized_seconds modulo 3600
    Let minutes be remaining_seconds divided by 60 as Integer
    Let secs be remaining_seconds modulo 60
    
    Return create_time with hour as hours and minute as minutes and second as secs

Process called "seconds_to_duration" that takes seconds as Float returns Duration:
    Let total_seconds be seconds
    Let days be (total_seconds divided by 86400) as Integer
    Set total_seconds to total_seconds modulo 86400
    
    Let hours be (total_seconds divided by 3600) as Integer
    Set total_seconds to total_seconds modulo 3600
    
    Let minutes be (total_seconds divided by 60) as Integer
    Let remaining_seconds be total_seconds modulo 60
    
    Let milliseconds be ((remaining_seconds minus (remaining_seconds as Integer)) times 1000) as Integer
    
    Return Duration with:
        days as days
        hours as hours
        minutes as minutes
        seconds as remaining_seconds as Integer
        milliseconds as milliseconds
        total_seconds as seconds

Note: Timezone operations
Process called "get_timezone_offset" that takes timezone as String returns Integer:
    Note: Returns offset in minutes from UTC
    Match timezone:
        When "UTC": Return 0
        When "GMT": Return 0
        When "EST": Return -300
        When "PST": Return -480
        When "CET": Return 60
        When "JST": Return 540
        Otherwise: Return 0

Process called "is_daylight_saving_time" that takes date as Date and timezone as String returns Boolean:
    Note: Determine if DST is in effect for given date and timezone using system timezone database
    Try:
        Let dst_result be system_call_check_daylight_saving_time with:
            year as date["year"]
            month as date["month"]
            day as date["day"]
            timezone as timezone
        
        Return dst_result
    
    Catch error:
        Note: Fallback to basic DST rules for common US timezones if system call fails
        If timezone contains "EST" or timezone contains "EDT" or timezone contains "PST" or timezone contains "PDT":
            Note: US DST typically runs from second Sunday in March to first Sunday in November
            If date["month"] is less than 3 or date["month"] is greater than 11:
                Return false
            If date["month"] is greater than 3 and date["month"] is less than 11:
                Return true
            
            Note: March and November require day-of-week calculation
            Let day_of_week be calculate_day_of_week with date as date
            
            If date["month"] is equal to 3:
                Note: DST starts second Sunday in March
                Let second_sunday be 14 minus ((day_of_week plus 6) modulo 7)
                If second_sunday is less than 8:
                    Set second_sunday to second_sunday plus 7
                Return date["day"] is greater than or equal to second_sunday
            
            If date["month"] is equal to 11:
                Note: DST ends first Sunday in November
                Let first_sunday be 7 minus ((day_of_week plus 6) modulo 7)
                If first_sunday is greater than 7:
                    Set first_sunday to first_sunday minus 7
                Return date["day"] is less than first_sunday
        
        Return false

Process called "convert_timezone" that takes datetime as DateTime and target_timezone as String returns DateTime:
    Let source_offset be datetime["utc_offset"]
    Let target_offset be get_timezone_offset with timezone as target_timezone
    Let offset_diff be target_offset minus source_offset
    
    Let new_timestamp be datetime["timestamp"] plus (offset_diff times 60)
    
    Return from_timestamp with timestamp as new_timestamp and timezone as target_timezone

Note: Timestamp operations
Process called "calculate_timestamp" that takes date as Date and time as Time and utc_offset as Integer returns Integer:
    Let days_since_epoch be date_to_days with date as date minus date_to_days with date as create_date with year as 1970 and month as 1 and day as 1
    Let seconds_from_time be time_to_seconds with time as time
    Let timezone_adjustment be utc_offset times 60
    
    Return (days_since_epoch times 86400) plus seconds_from_time minus timezone_adjustment

Process called "from_timestamp" that takes timestamp as Integer and timezone as String returns DateTime:
    Let utc_offset be get_timezone_offset with timezone as timezone
    Let adjusted_timestamp be timestamp plus (utc_offset times 60)
    
    Let days_since_epoch be adjusted_timestamp divided by 86400 as Integer
    Let seconds_in_day be adjusted_timestamp modulo 86400
    
    Let epoch_date be create_date with year as 1970 and month as 1 and day as 1
    Let date be add_days with date as epoch_date and days as days_since_epoch
    Let time be seconds_to_time with seconds as seconds_in_day
    
    Let is_dst be is_daylight_saving_time with date as date and timezone as timezone
    
    Return DateTime with:
        date as date
        time as time
        timezone as timezone
        utc_offset as utc_offset
        is_dst as is_dst
        timestamp as timestamp

Note: Helper functions
Process called "zero_pad" that takes number as Integer and width as Integer returns String:
    Let num_string be "" with message number
    Let padding_needed be width minus length of num_string
    
    If padding_needed is greater than 0:
        Let padding be ""
        For i from 1 to padding_needed:
            Set padding to padding with message "0"
        Return padding with message num_string
    
    Return num_string

Process called "minimum" that takes a as Integer and b as Integer returns Integer:
    If a is less than b:
        Return a
    Return b

Process called "replace_all" that takes text as String and old_text as String and new_text as String returns String:
    Note: Replace all occurrences of old_text with new_text in the input string
    If length of old_text is equal to 0:
        Return text
    
    Let result be ""
    Let text_length be length of text
    Let old_length be length of old_text
    Let i be 0
    
    While i is less than text_length:
        Note: Check if we have a match at current position
        Let match_found be true
        If i plus old_length is greater than text_length:
            Set match_found to false
        Otherwise:
            For j from 0 to old_length minus 1:
                Let text_char be system_call_get_character_at with text as text and position as i plus j
                Let old_char be system_call_get_character_at with text as old_text and position as j
                If text_char is not equal to old_char:
                    Set match_found to false
                    Break
        
        If match_found:
            Note: Replace the matched substring
            Set result to result plus new_text
            Set i to i plus old_length
        Otherwise:
            Note: Copy current character and advance
            Let current_char be system_call_get_character_at with text as text and position as i
            Set result to result plus current_char
            Set i to i plus 1
    
    Return result

Process called "extract_format_tokens" that takes format_string as String returns List[String]:
    Note: Extract format tokens like YYYY, MM, DD from format string
    Let tokens be list containing
    Let i be 0
    Let format_length be length of format_string
    
    While i is less than format_length:
        Note: Look for common format patterns
        If i plus 4 is less than or equal to format_length:
            Let four_char be substring of format_string from i to i plus 4
            If four_char is equal to "YYYY" or four_char is equal to "MMMM" or four_char is equal to "WWWW":
                Add four_char to tokens
                Set i to i plus 4
                Continue
        
        If i plus 3 is less than or equal to format_length:
            Let three_char be substring of format_string from i to i plus 3
            If three_char is equal to "MMM" or three_char is equal to "DDD":
                Add three_char to tokens
                Set i to i plus 3
                Continue
        
        If i plus 2 is less than or equal to format_length:
            Let two_char be substring of format_string from i to i plus 2
            If two_char is equal to "YY" or two_char is equal to "MM" or two_char is equal to "DD" or two_char is equal to "WW":
                Add two_char to tokens
                Set i to i plus 2
                Continue
        
        Set i to i plus 1
    
    Return tokens

Process called "extract_date_values" that takes date_string as String and tokens as List[String] returns Dictionary[String, Integer]:
    Note: Extract date values from string according to tokens
    Let values be dictionary with:
        "year" as 1970
        "month" as 1
        "day" as 1
    
    Note: Simple extraction for common formats like YYYY-MM-DD or MM/DD/YYYY
    If contains with collection as date_string and item as "-":
        Let parts be split with text as date_string and delimiter as "-"
        If length of parts is equal to 3:
            Set values["year"] to parse_integer with text as parts[0]
            Set values["month"] to parse_integer with text as parts[1]
            Set values["day"] to parse_integer with text as parts[2]
    Otherwise if contains with collection as date_string and item as "/":
        Let parts be split with text as date_string and delimiter as "/"
        If length of parts is equal to 3:
            Set values["month"] to parse_integer with text as parts[0]
            Set values["day"] to parse_integer with text as parts[1]
            Set values["year"] to parse_integer with text as parts[2]
    
    Return values

Process called "get_value_or_default" that takes values as Dictionary[String, Integer] and key as String and default as Integer returns Integer:
    If values contains key key:
        Return values[key]
    Return default

Process called "get_current_unix_timestamp" returns Integer:
    Note: Returns current Unix timestamp in seconds using system call
    Try:
        Return system_call_get_current_unix_timestamp
    
    Catch error:
        Note: Fallback to hardcoded timestamp for testing if system call fails
        Return 1640995200

Import "builtins/exceptions" as exceptions
Process called "create_value_error" that takes value as Any and constraint as String returns exceptions.ValueError:
    Return exceptions.create_value_error with value as value and constraint as constraint