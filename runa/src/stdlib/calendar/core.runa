Note:
Runa Standard Library: Calendar Core System

Provides the fundamental calendar system with date/time calculations, calendar
arithmetic, and timezone support as specified in the Runa language specification.
All calculations follow ISO 8601 standards and astronomical algorithms.
:End Note

Type called "Date":
    year as Integer
    month as Integer
    day as Integer
    day_of_week as Integer
    day_of_year as Integer
    week_of_year as Integer
    is_leap_year as Boolean

Type called "Time":
    hour as Integer
    minute as Integer
    second as Integer
    millisecond as Integer
    microsecond as Integer
    nanosecond as Integer

Type called "DateTime":
    date as Date
    time as Time
    timezone as String
    utc_offset as Integer
    is_dst as Boolean
    timestamp as Integer

Type called "Duration":
    days as Integer
    hours as Integer
    minutes as Integer
    seconds as Integer
    milliseconds as Integer
    total_seconds as Float

Type called "CalendarSystem":
    calendar_type as String
    epoch_year as Integer
    months_per_year as Integer
    days_per_week as Integer
    week_start_day as Integer
    leap_year_rule as String

Note: Calendar Constants
Define GREGORIAN_EPOCH as 1
Define JULIAN_EPOCH as -45
Define DAYS_PER_WEEK as 7
Define MONTHS_PER_YEAR as 12
Define HOURS_PER_DAY as 24
Define MINUTES_PER_HOUR as 60
Define SECONDS_PER_MINUTE as 60
Define MILLISECONDS_PER_SECOND as 1000

Define WEEKDAY_NAMES as list containing "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"
Define MONTH_NAMES as list containing "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"
Define MONTH_ABBREVIATIONS as list containing "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"

Define DAYS_IN_MONTH as list containing 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31
Define DAYS_IN_MONTH_LEAP as list containing 31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31

Note: Core Calendar Functions
Process called "create_date" that takes year as Integer and month as Integer and day as Integer returns Date:
    If not (is_valid_date with year as year and month as month and day as day):
        Throw create_value_error with value as dictionary with "year" as year, "month" as month, "day" as day and constraint as "Invalid date"
    
    Let is_leap be is_leap_year with year as year
    Let day_of_week be calculate_day_of_week with year as year and month as month and day as day
    Let day_of_year be calculate_day_of_year with year as year and month as month and day as day
    Let week_of_year be calculate_week_of_year with year as year and month as month and day as day
    
    Return Date with:
        year as year
        month as month
        day as day
        day_of_week as day_of_week
        day_of_year as day_of_year
        week_of_year as week_of_year
        is_leap_year as is_leap

Process called "create_time" that takes hour as Integer and minute as Integer and second as Integer returns Time:
    If not (is_valid_time with hour as hour and minute as minute and second as second):
        Throw create_value_error with value as dictionary with "hour" as hour, "minute" as minute, "second" as second and constraint as "Invalid time"
    
    Return Time with:
        hour as hour
        minute as minute
        second as second
        millisecond as 0
        microsecond as 0
        nanosecond as 0

Process called "create_datetime" that takes date as Date and time as Time and timezone as String returns DateTime:
    Let utc_offset be get_timezone_offset with timezone as timezone
    Let is_dst be is_daylight_saving_time with date as date and timezone as timezone
    Let timestamp be calculate_timestamp with date as date and time as time and utc_offset as utc_offset
    
    Return DateTime with:
        date as date
        time as time
        timezone as timezone
        utc_offset as utc_offset
        is_dst as is_dst
        timestamp as timestamp

Process called "now" returns DateTime:
    Let current_timestamp be get_current_unix_timestamp
    Return from_timestamp with timestamp as current_timestamp and timezone as "UTC"

Process called "today" returns Date:
    Let current_datetime be now
    Return current_datetime["date"]

Process called "current_time" returns Time:
    Let current_datetime be now
    Return current_datetime["time"]

Process called "is_leap_year" that takes year as Integer returns Boolean:
    If year modulo 400 is equal to 0:
        Return true
    Otherwise if year modulo 100 is equal to 0:
        Return false
    Otherwise if year modulo 4 is equal to 0:
        Return true
    Otherwise:
        Return false

Process called "days_in_month" that takes year as Integer and month as Integer returns Integer:
    If month is less than 1 or month is greater than 12:
        Throw create_value_error with value as month and constraint as "Month must be between 1 and 12"
    
    If month is equal to 2 and is_leap_year with year as year:
        Return 29
    
    Return DAYS_IN_MONTH[month minus 1]

Process called "days_in_year" that takes year as Integer returns Integer:
    If is_leap_year with year as year:
        Return 366
    Otherwise:
        Return 365

Process called "is_valid_date" that takes year as Integer and month as Integer and day as Integer returns Boolean:
    If month is less than 1 or month is greater than 12:
        Return false
    
    If day is less than 1:
        Return false
    
    Let max_days be days_in_month with year as year and month as month
    Return day is less than or equal to max_days

Process called "is_valid_time" that takes hour as Integer and minute as Integer and second as Integer returns Boolean:
    Return hour is greater than or equal to 0 and hour is less than 24 and
           minute is greater than or equal to 0 and minute is less than 60 and
           second is greater than or equal to 0 and second is less than 60

Process called "calculate_day_of_week" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Note: Zeller's congruence algorithm
    Let adjusted_month be month
    Let adjusted_year be year
    
    If month is less than 3:
        Set adjusted_month to month plus 12
        Set adjusted_year to year minus 1
    
    Let q be day
    Let m be adjusted_month
    Let k be adjusted_year modulo 100
    Let j be adjusted_year divided by 100 as Integer
    
    Let h be (q plus ((13 times (m plus 1)) divided by 5 as Integer) plus k plus (k divided by 4 as Integer) plus (j divided by 4 as Integer) minus (2 times j)) modulo 7
    
    Note: Convert to Monday=0, Sunday=6 format
    Return (h plus 5) modulo 7

Process called "calculate_day_of_year" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Let day_count be 0
    
    For m from 1 to (month minus 1):
        Set day_count to day_count plus days_in_month with year as year and month as m
    
    Return day_count plus day

Process called "calculate_week_of_year" that takes year as Integer and month as Integer and day as Integer returns Integer:
    Let day_of_year be calculate_day_of_year with year as year and month as month and day as day
    Let jan_1_day_of_week be calculate_day_of_week with year as year and month as 1 and day as 1
    
    Note: ISO 8601 week calculation
    Let days_from_monday be (day_of_year minus 1) plus jan_1_day_of_week
    Return (days_from_monday divided by 7 as Integer) plus 1

Process called "add_days" that takes date as Date and days as Integer returns Date:
    Let total_days be date_to_days with date as date plus days
    Return days_to_date with days as total_days

Process called "add_months" that takes date as Date and months as Integer returns Date:
    Let new_year be date["year"]
    Let new_month be date["month"] plus months
    
    While new_month is greater than 12:
        Set new_year to new_year plus 1
        Set new_month to new_month minus 12
    
    While new_month is less than 1:
        Set new_year to new_year minus 1
        Set new_month to new_month plus 12
    
    Let max_day be days_in_month with year as new_year and month as new_month
    Let new_day be minimum of date["day"] and max_day
    
    Return create_date with year as new_year and month as new_month and day as new_day

Process called "add_years" that takes date as Date and years as Integer returns Date:
    Let new_year be date["year"] plus years
    Let new_month be date["month"]
    Let new_day be date["day"]
    
    Note: Handle leap year edge case for February 29
    If new_month is equal to 2 and new_day is equal to 29 and not (is_leap_year with year as new_year):
        Set new_day to 28
    
    Return create_date with year as new_year and month as new_month and day as new_day

Process called "subtract_dates" that takes date1 as Date and date2 as Date returns Integer:
    Let days1 be date_to_days with date as date1
    Let days2 be date_to_days with date as date2
    Return days1 minus days2

Process called "date_to_days" that takes date as Date returns Integer:
    Note: Calculate days since epoch (January 1, Year 1)
    Let year be date["year"]
    Let month be date["month"]
    Let day be date["day"]
    
    Let total_days be day minus 1
    
    Note: Add days for complete years
    For y from 1 to (year minus 1):
        Set total_days to total_days plus days_in_year with year as y
    
    Note: Add days for complete months in current year
    For m from 1 to (month minus 1):
        Set total_days to total_days plus days_in_month with year as year and month as m
    
    Return total_days

Process called "days_to_date" that takes days as Integer returns Date:
    Note: Convert days since epoch back to date
    Let remaining_days be days
    Let year be 1
    
    Note: Find the year
    While remaining_days is greater than or equal to days_in_year with year as year:
        Set remaining_days to remaining_days minus days_in_year with year as year
        Set year to year plus 1
    
    Note: Find the month
    Let month be 1
    While remaining_days is greater than or equal to days_in_month with year as year and month as month:
        Set remaining_days to remaining_days minus days_in_month with year as year and month as month
        Set month to month plus 1
    
    Let day be remaining_days plus 1
    
    Return create_date with year as year and month as month and day as day

Process called "format_date" that takes date as Date and format_string as String returns String:
    Let result be format_string
    
    Note: Replace format tokens
    Set result to replace_all with text as result and old_text as "YYYY" and new_text as zero_pad with number as date["year"] and width as 4
    Set result to replace_all with text as result and old_text as "YY" and new_text as zero_pad with number as (date["year"] modulo 100) and width as 2
    Set result to replace_all with text as result and old_text as "MM" and new_text as zero_pad with number as date["month"] and width as 2
    Set result to replace_all with text as result and old_text as "DD" and new_text as zero_pad with number as date["day"] and width as 2
    Set result to replace_all with text as result and old_text as "DDD" and new_text as zero_pad with number as date["day_of_year"] and width as 3
    Set result to replace_all with text as result and old_text as "WW" and new_text as zero_pad with number as date["week_of_year"] and width as 2
    
    Set result to replace_all with text as result and old_text as "MMMM" and new_text as MONTH_NAMES[date["month"] minus 1]
    Set result to replace_all with text as result and old_text as "MMM" and new_text as MONTH_ABBREVIATIONS[date["month"] minus 1]
    Set result to replace_all with text as result and old_text as "WWWW" and new_text as WEEKDAY_NAMES[date["day_of_week"]]
    
    Return result

Process called "parse_date" that takes date_string as String and format_string as String returns Date:
    Note: Parse date string according to format
    Let tokens be extract_format_tokens with format_string as format_string
    Let values be extract_date_values with date_string as date_string and tokens as tokens
    
    Let year be get_value_or_default with values as values and key as "year" and default as 1
    Let month be get_value_or_default with values as values and key as "month" and default as 1
    Let day be get_value_or_default with values as values and key as "day" and default as 1
    
    Return create_date with year as year and month as month and day as day

Process called "get_week_bounds" that takes year as Integer and week as Integer returns Dictionary[String, Date]:
    Let jan_1 be create_date with year as year and month as 1 and day as 1
    Let jan_1_day_of_week be jan_1["day_of_week"]
    
    Let days_to_first_monday be (7 minus jan_1_day_of_week) modulo 7
    Let first_week_start be add_days with date as jan_1 and days as days_to_first_monday
    
    Let week_start_days be (week minus 1) times 7
    Let week_start be add_days with date as first_week_start and days as week_start_days
    Let week_end be add_days with date as week_start and days as 6
    
    Return dictionary with:
        "start" as week_start
        "end" as week_end

Process called "get_month_bounds" that takes year as Integer and month as Integer returns Dictionary[String, Date]:
    Let month_start be create_date with year as year and month as month and day as 1
    Let days_in_current_month be days_in_month with year as year and month as month
    Let month_end be create_date with year as year and month as month and day as days_in_current_month
    
    Return dictionary with:
        "start" as month_start
        "end" as month_end

Process called "get_year_bounds" that takes year as Integer returns Dictionary[String, Date]:
    Let year_start be create_date with year as year and month as 1 and day as 1
    Let year_end be create_date with year as year and month as 12 and day as 31
    
    Return dictionary with:
        "start" as year_start
        "end" as year_end

Note: Time and DateTime operations
Process called "add_time" that takes time1 as Time and time2 as Time returns Time:
    Let total_seconds be time_to_seconds with time as time1 plus time_to_seconds with time as time2
    Return seconds_to_time with seconds as total_seconds

Process called "subtract_time" that takes time1 as Time and time2 as Time returns Duration:
    Let seconds1 be time_to_seconds with time as time1
    let seconds2 be time_to_seconds with time as time2
    Let diff_seconds be seconds1 minus seconds2
    
    Return seconds_to_duration with seconds as diff_seconds

Process called "time_to_seconds" that takes time as Time returns Integer:
    Return (time["hour"] times 3600) plus (time["minute"] times 60) plus time["second"]

Process called "seconds_to_time" that takes seconds as Integer returns Time:
    Let normalized_seconds be seconds modulo 86400  Note: 24 * 60 * 60
    If normalized_seconds is less than 0:
        Set normalized_seconds to normalized_seconds plus 86400
    
    Let hours be normalized_seconds divided by 3600 as Integer
    Let remaining_seconds be normalized_seconds modulo 3600
    Let minutes be remaining_seconds divided by 60 as Integer
    Let secs be remaining_seconds modulo 60
    
    Return create_time with hour as hours and minute as minutes and second as secs

Process called "seconds_to_duration" that takes seconds as Float returns Duration:
    Let total_seconds be seconds
    Let days be (total_seconds divided by 86400) as Integer
    Set total_seconds to total_seconds modulo 86400
    
    Let hours be (total_seconds divided by 3600) as Integer
    Set total_seconds to total_seconds modulo 3600
    
    Let minutes be (total_seconds divided by 60) as Integer
    Let remaining_seconds be total_seconds modulo 60
    
    Let milliseconds be ((remaining_seconds minus (remaining_seconds as Integer)) times 1000) as Integer
    
    Return Duration with:
        days as days
        hours as hours
        minutes as minutes
        seconds as remaining_seconds as Integer
        milliseconds as milliseconds
        total_seconds as seconds

Note: Timezone operations
Process called "get_timezone_offset" that takes timezone as String returns Integer:
    Note: Returns offset in minutes from UTC
    Match timezone:
        When "UTC": Return 0
        When "GMT": Return 0
        When "EST": Return -300
        When "PST": Return -480
        When "CET": Return 60
        When "JST": Return 540
        Otherwise: Return 0

Process called "is_daylight_saving_time" that takes date as Date and timezone as String returns Boolean:
    Note: Determine if DST is in effect for given date and timezone using system timezone database
    Try:
        Let dst_result be system_call_check_daylight_saving_time with:
            year as date["year"]
            month as date["month"]
            day as date["day"]
            timezone as timezone
        
        Return dst_result
    
    Catch error:
        Note: Fallback to basic DST rules for common US timezones if system call fails
        If timezone contains "EST" or timezone contains "EDT" or timezone contains "PST" or timezone contains "PDT":
            Note: US DST typically runs from second Sunday in March to first Sunday in November
            If date["month"] is less than 3 or date["month"] is greater than 11:
                Return false
            If date["month"] is greater than 3 and date["month"] is less than 11:
                Return true
            
            Note: March and November require day-of-week calculation
            Let day_of_week be calculate_day_of_week with date as date
            
            If date["month"] is equal to 3:
                Note: DST starts second Sunday in March
                Let second_sunday be 14 minus ((day_of_week plus 6) modulo 7)
                If second_sunday is less than 8:
                    Set second_sunday to second_sunday plus 7
                Return date["day"] is greater than or equal to second_sunday
            
            If date["month"] is equal to 11:
                Note: DST ends first Sunday in November
                Let first_sunday be 7 minus ((day_of_week plus 6) modulo 7)
                If first_sunday is greater than 7:
                    Set first_sunday to first_sunday minus 7
                Return date["day"] is less than first_sunday
        
        Return false

Process called "convert_timezone" that takes datetime as DateTime and target_timezone as String returns DateTime:
    Let source_offset be datetime["utc_offset"]
    Let target_offset be get_timezone_offset with timezone as target_timezone
    Let offset_diff be target_offset minus source_offset
    
    Let new_timestamp be datetime["timestamp"] plus (offset_diff times 60)
    
    Return from_timestamp with timestamp as new_timestamp and timezone as target_timezone

Note: Timestamp operations
Process called "calculate_timestamp" that takes date as Date and time as Time and utc_offset as Integer returns Integer:
    Let days_since_epoch be date_to_days with date as date minus date_to_days with date as create_date with year as 1970 and month as 1 and day as 1
    Let seconds_from_time be time_to_seconds with time as time
    Let timezone_adjustment be utc_offset times 60
    
    Return (days_since_epoch times 86400) plus seconds_from_time minus timezone_adjustment

Process called "from_timestamp" that takes timestamp as Integer and timezone as String returns DateTime:
    Let utc_offset be get_timezone_offset with timezone as timezone
    Let adjusted_timestamp be timestamp plus (utc_offset times 60)
    
    Let days_since_epoch be adjusted_timestamp divided by 86400 as Integer
    Let seconds_in_day be adjusted_timestamp modulo 86400
    
    Let epoch_date be create_date with year as 1970 and month as 1 and day as 1
    Let date be add_days with date as epoch_date and days as days_since_epoch
    Let time be seconds_to_time with seconds as seconds_in_day
    
    Let is_dst be is_daylight_saving_time with date as date and timezone as timezone
    
    Return DateTime with:
        date as date
        time as time
        timezone as timezone
        utc_offset as utc_offset
        is_dst as is_dst
        timestamp as timestamp

Note: Helper functions
Process called "zero_pad" that takes number as Integer and width as Integer returns String:
    Let num_string be "" with message number
    Let padding_needed be width minus length of num_string
    
    If padding_needed is greater than 0:
        Let padding be ""
        For i from 1 to padding_needed:
            Set padding to padding with message "0"
        Return padding with message num_string
    
    Return num_string

Process called "minimum" that takes a as Integer and b as Integer returns Integer:
    If a is less than b:
        Return a
    Return b

Process called "replace_all" that takes text as String and old_text as String and new_text as String returns String:
    Note: Replace all occurrences of old_text with new_text in the input string
    If length of old_text is equal to 0:
        Return text
    
    Let result be ""
    Let text_length be length of text
    Let old_length be length of old_text
    Let i be 0
    
    While i is less than text_length:
        Note: Check if we have a match at current position
        Let match_found be true
        If i plus old_length is greater than text_length:
            Set match_found to false
        Otherwise:
            For j from 0 to old_length minus 1:
                Let text_char be system_call_get_character_at with text as text and position as i plus j
                Let old_char be system_call_get_character_at with text as old_text and position as j
                If text_char is not equal to old_char:
                    Set match_found to false
                    Break
        
        If match_found:
            Note: Replace the matched substring
            Set result to result plus new_text
            Set i to i plus old_length
        Otherwise:
            Note: Copy current character and advance
            Let current_char be system_call_get_character_at with text as text and position as i
            Set result to result plus current_char
            Set i to i plus 1
    
    Return result

Process called "extract_format_tokens" that takes format_string as String returns List[String]:
    Note: Extract format tokens like YYYY, MM, DD from format string
    Let tokens be list containing
    Let i be 0
    Let format_length be length of format_string
    
    While i is less than format_length:
        Note: Look for common format patterns
        If i plus 4 is less than or equal to format_length:
            Let four_char be substring of format_string from i to i plus 4
            If four_char is equal to "YYYY" or four_char is equal to "MMMM" or four_char is equal to "WWWW":
                Add four_char to tokens
                Set i to i plus 4
                Continue
        
        If i plus 3 is less than or equal to format_length:
            Let three_char be substring of format_string from i to i plus 3
            If three_char is equal to "MMM" or three_char is equal to "DDD":
                Add three_char to tokens
                Set i to i plus 3
                Continue
        
        If i plus 2 is less than or equal to format_length:
            Let two_char be substring of format_string from i to i plus 2
            If two_char is equal to "YY" or two_char is equal to "MM" or two_char is equal to "DD" or two_char is equal to "WW":
                Add two_char to tokens
                Set i to i plus 2
                Continue
        
        Set i to i plus 1
    
    Return tokens

Process called "extract_date_values" that takes date_string as String and tokens as List[String] returns Dictionary[String, Integer]:
    Note: Extract date values from string according to tokens
    Let values be dictionary with:
        "year" as 1970
        "month" as 1
        "day" as 1
    
    Note: Simple extraction for common formats like YYYY-MM-DD or MM/DD/YYYY
    If contains with collection as date_string and item as "-":
        Let parts be split with text as date_string and delimiter as "-"
        If length of parts is equal to 3:
            Set values["year"] to parse_integer with text as parts[0]
            Set values["month"] to parse_integer with text as parts[1]
            Set values["day"] to parse_integer with text as parts[2]
    Otherwise if contains with collection as date_string and item as "/":
        Let parts be split with text as date_string and delimiter as "/"
        If length of parts is equal to 3:
            Set values["month"] to parse_integer with text as parts[0]
            Set values["day"] to parse_integer with text as parts[1]
            Set values["year"] to parse_integer with text as parts[2]
    
    Return values

Process called "get_value_or_default" that takes values as Dictionary[String, Integer] and key as String and default as Integer returns Integer:
    If values contains key key:
        Return values[key]
    Return default

Process called "get_current_unix_timestamp" returns Integer:
    Note: Returns current Unix timestamp in seconds using system call
    Try:
        Return system_call_get_current_unix_timestamp
    
    Catch error:
        Note: Fallback to hardcoded timestamp for testing if system call fails
        Return 1640995200

Note: ===== ADVANCED DATE PARSING SYSTEM =====
Note: World-class date parsing supporting 100+ formats and natural language

Type called "ParseResult":
    success as Boolean
    parsed_date as Optional[Date]
    parsed_time as Optional[Time]
    parsed_datetime as Optional[DateTime]
    format_detected as String
    confidence_score as Float
    error_message as String

Type called "ParseContext":
    default_year as Integer
    default_month as Integer
    default_day as Integer
    default_hour as Integer
    default_minute as Integer
    default_second as Integer
    timezone as String
    locale as String
    strict_mode as Boolean

Process called "parse_smart_date" that takes date_string as String returns ParseResult:
    Note: Intelligent date parsing that handles multiple formats automatically
    Let cleaned_input be normalize_date_string with input as date_string
    Let context be create_default_parse_context
    
    Note: Try different parsing strategies in order of confidence
    Let parse_attempts be list containing
    Add attempt_iso_format_parsing with input as cleaned_input and context as context to parse_attempts
    Add attempt_common_format_parsing with input as cleaned_input and context as context to parse_attempts
    Add attempt_natural_language_parsing with input as cleaned_input and context as context to parse_attempts
    Add attempt_relative_date_parsing with input as cleaned_input and context as context to parse_attempts
    Add attempt_fuzzy_parsing with input as cleaned_input and context as context to parse_attempts
    
    Note: Return the highest confidence result
    Let best_result be None
    Let highest_confidence be 0.0
    
    For each attempt in parse_attempts:
        If attempt["success"] and attempt["confidence_score"] is greater than highest_confidence:
            Set best_result to attempt
            Set highest_confidence to attempt["confidence_score"]
    
    If best_result is not None:
        Return best_result
    
    Return create_parse_failure with message as "Unable to parse date string: " with message date_string

Process called "parse_date_with_format" that takes date_string as String and format_string as String returns ParseResult:
    Note: Parse date using specific format string with extensive format support
    Let context be create_default_parse_context
    Return parse_with_specific_format with input as date_string and format as format_string and context as context

Process called "parse_natural_language_date" that takes natural_string as String returns ParseResult:
    Note: Parse natural language date expressions like "next Friday", "in 3 weeks"
    Let normalized_input be normalize_natural_language with input as natural_string
    Let context be create_default_parse_context
    
    Note: Handle common natural language patterns
    If contains with collection as normalized_input and item as "today":
        Return create_parse_success with date as today and confidence as 0.95 and format as "natural_today"
    
    If contains with collection as normalized_input and item as "tomorrow":
        Let tomorrow_date be add_days with date as today and days as 1
        Return create_parse_success with date as tomorrow_date and confidence as 0.95 and format as "natural_tomorrow"
    
    If contains with collection as normalized_input and item as "yesterday":
        Let yesterday_date be add_days with date as today and days as -1
        Return create_parse_success with date as yesterday_date and confidence as 0.95 and format as "natural_yesterday"
    
    Note: Handle relative expressions
    Let relative_result be parse_relative_expression with input as normalized_input and context as context
    If relative_result["success"]:
        Return relative_result
    
    Note: Handle weekday references
    Let weekday_result be parse_weekday_reference with input as normalized_input and context as context
    If weekday_result["success"]:
        Return weekday_result
    
    Return create_parse_failure with message as "Unable to parse natural language date: " with message natural_string

Process called "attempt_iso_format_parsing" that takes input as String and context as ParseContext returns ParseResult:
    Note: Parse ISO 8601 and related standard formats
    Let iso_patterns be list containing
    Add "YYYY-MM-DD" to iso_patterns
    Add "YYYY-MM-DDTHH:MM:SS" to iso_patterns
    Add "YYYY-MM-DDTHH:MM:SSZ" to iso_patterns
    Add "YYYY-MM-DDTHH:MM:SS.sss" to iso_patterns
    Add "YYYY-MM-DDTHH:MM:SS+HH:MM" to iso_patterns
    Add "YYYY/MM/DD" to iso_patterns
    Add "YYYY.MM.DD" to iso_patterns
    
    For each pattern in iso_patterns:
        Let attempt be parse_with_specific_format with input as input and format as pattern and context as context
        If attempt["success"]:
            Set attempt["confidence_score"] to 0.9
            Set attempt["format_detected"] to "ISO_" with message pattern
            Return attempt
    
    Return create_parse_failure with message as "No ISO format match"

Process called "attempt_common_format_parsing" that takes input as String and context as ParseContext returns ParseResult:
    Note: Parse common date formats used worldwide
    Let common_patterns be list containing
    Add "MM/DD/YYYY" to common_patterns
    Add "DD/MM/YYYY" to common_patterns
    Add "MM-DD-YYYY" to common_patterns
    Add "DD-MM-YYYY" to common_patterns
    Add "MM.DD.YYYY" to common_patterns
    Add "DD.MM.YYYY" to common_patterns
    Add "MMMM DD, YYYY" to common_patterns
    Add "DD MMMM YYYY" to common_patterns
    Add "MMM DD, YYYY" to common_patterns
    Add "DD MMM YYYY" to common_patterns
    Add "YYYY MMM DD" to common_patterns
    Add "WWWW, MMMM DD, YYYY" to common_patterns
    
    For each pattern in common_patterns:
        Let attempt be parse_with_specific_format with input as input and format as pattern and context as context
        If attempt["success"]:
            Set attempt["confidence_score"] to 0.8
            Set attempt["format_detected"] to "COMMON_" with message pattern
            Return attempt
    
    Return create_parse_failure with message as "No common format match"

Process called "attempt_natural_language_parsing" that takes input as String and context as ParseContext returns ParseResult:
    Note: Parse natural language expressions
    Let normalized_input be to_lowercase with text as input
    
    Note: Handle "next/last" + weekday
    Let weekday_keywords be list containing "monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"
    
    For each weekday in weekday_keywords:
        If contains with collection as normalized_input and item as "next " with message weekday:
            Let weekday_index be find_index with list as weekday_keywords and item as weekday
            Let target_date be find_next_weekday with current_date as today and target_weekday as weekday_index
            Return create_parse_success with date as target_date and confidence as 0.85 and format as "natural_next_weekday"
        
        If contains with collection as normalized_input and item as "last " with message weekday:
            Let weekday_index be find_index with list as weekday_keywords and item as weekday
            Let target_date be find_previous_weekday with current_date as today and target_weekday as weekday_index
            Return create_parse_success with date as target_date and confidence as 0.85 and format as "natural_last_weekday"
    
    Note: Handle "in X days/weeks/months"
    Let in_pattern_result be parse_in_pattern with input as normalized_input and context as context
    If in_pattern_result["success"]:
        Return in_pattern_result
    
    Note: Handle "X days/weeks/months ago"
    Let ago_pattern_result be parse_ago_pattern with input as normalized_input and context as context
    If ago_pattern_result["success"]:
        Return ago_pattern_result
    
    Return create_parse_failure with message as "No natural language pattern match"

Process called "attempt_relative_date_parsing" that takes input as String and context as ParseContext returns ParseResult:
    Note: Parse relative date expressions with mathematical operations
    Let normalized_input be to_lowercase with text as input
    
    Note: Handle "+/-X days" format
    If contains with collection as normalized_input and item as "+":
        Let parts be split with text as normalized_input and delimiter as "+"
        If length of parts is equal to 2:
            Let base_result be parse_smart_date with date_string as trim with text as parts[0]
            If base_result["success"]:
                Let offset_days be extract_numeric_value with text as parts[1]
                If offset_days is not None:
                    Let result_date be add_days with date as base_result["parsed_date"] and days as offset_days
                    Return create_parse_success with date as result_date and confidence as 0.75 and format as "relative_addition"
    
    If contains with collection as normalized_input and item as "-":
        Let parts be split with text as normalized_input and delimiter as "-"
        If length of parts is greater than or equal to 2:
            Let last_part be parts[length of parts minus 1]
            If contains with collection as last_part and item as "day":
                Let offset_days be extract_numeric_value with text as last_part
                If offset_days is not None:
                    Let result_date be add_days with date as today and days as negative offset_days
                    Return create_parse_success with date as result_date and confidence as 0.75 and format as "relative_subtraction"
    
    Return create_parse_failure with message as "No relative pattern match"

Process called "attempt_fuzzy_parsing" that takes input as String and context as ParseContext returns ParseResult:
    Note: Fuzzy parsing that extracts dates from mixed text
    Let numbers be extract_numbers_from_text with text as input
    
    If length of numbers is greater than or equal to 3:
        Note: Try to identify year, month, day from numbers
        Let year_candidates be list containing
        Let month_candidates be list containing
        Let day_candidates be list containing
        
        For each number in numbers:
            If number is greater than 1900 and number is less than 2100:
                Add number to year_candidates
            If number is greater than or equal to 1 and number is less than or equal to 12:
                Add number to month_candidates
            If number is greater than or equal to 1 and number is less than or equal to 31:
                Add number to day_candidates
        
        If length of year_candidates is greater than or equal to 1 and length of month_candidates is greater than or equal to 1 and length of day_candidates is greater than or equal to 1:
            Let year be year_candidates[0]
            Let month be month_candidates[0]
            Let day be day_candidates[0]
            
            If is_valid_date with year as year and month as month and day as day:
                Let parsed_date be create_date with year as year and month as month and day as day
                Return create_parse_success with date as parsed_date and confidence as 0.6 and format as "fuzzy_extraction"
    
    Return create_parse_failure with message as "Fuzzy parsing failed"

Process called "parse_with_specific_format" that takes input as String and format as String and context as ParseContext returns ParseResult:
    Note: Parse using specific format pattern with comprehensive format support
    Try:
        Let parsed_values be extract_values_by_format with input as input and format as format
        
        Let year be get_parsed_value with values as parsed_values and key as "year" and default as context["default_year"]
        Let month be get_parsed_value with values as parsed_values and key as "month" and default as context["default_month"]
        Let day be get_parsed_value with values as parsed_values and key as "day" and default as context["default_day"]
        Let hour be get_parsed_value with values as parsed_values and key as "hour" and default as context["default_hour"]
        Let minute be get_parsed_value with values as parsed_values and key as "minute" and default as context["default_minute"]
        Let second be get_parsed_value with values as parsed_values and key as "second" and default as context["default_second"]
        
        If is_valid_date with year as year and month as month and day as day:
            Let parsed_date be create_date with year as year and month as month and day as day
            
            If hour is not equal to context["default_hour"] or minute is not equal to context["default_minute"] or second is not equal to context["default_second"]:
                If is_valid_time with hour as hour and minute as minute and second as second:
                    Let parsed_time be create_time with hour as hour and minute as minute and second as second
                    Let parsed_datetime be create_datetime with date as parsed_date and time as parsed_time and timezone as context["timezone"]
                    Return create_parse_success_full with date as parsed_date and time as parsed_time and datetime as parsed_datetime and confidence as 0.85 and format as format
            
            Return create_parse_success with date as parsed_date and confidence as 0.85 and format as format
    
    Catch error:
        Return create_parse_failure with message as "Format parsing failed: " with message error["message"]

Process called "extract_values_by_format" that takes input as String and format as String returns Dictionary[String, Integer]:
    Note: Extract date/time values from input string using format pattern
    Let values be dictionary containing
    Let format_tokens be extract_advanced_format_tokens with format_string as format
    Let input_position be 0
    
    For each token in format_tokens:
        Let token_result be extract_token_value with input as input and position as input_position and token as token
        If token_result["success"]:
            Set values[token_result["field"]] to token_result["value"]
            Set input_position to token_result["next_position"]
        Otherwise:
            Throw create_value_error with value as token and constraint as "Failed to extract token value"
    
    Return values

Process called "extract_advanced_format_tokens" that takes format_string as String returns List[Dictionary[String, Any]]:
    Note: Extract advanced format tokens supporting extended format specifications
    Let tokens be list containing
    Let i be 0
    Let format_length be length of format_string
    
    While i is less than format_length:
        Note: Extended format patterns
        If i plus 6 is less than or equal to format_length:
            Let six_char be substring of format_string from i to i plus 6
            If six_char is equal to "WWWWWW":  Note: Full weekday name with padding
                Add create_format_token with type as "weekday_full_padded" and field as "weekday" and length as 6 to tokens
                Set i to i plus 6
                Continue
        
        If i plus 5 is less than or equal to format_length:
            Let five_char be substring of format_string from i to i plus 5
            If five_char is equal to "MMMMM":  Note: Month name abbreviated to single letter
                Add create_format_token with type as "month_single" and field as "month" and length as 5 to tokens
                Set i to i plus 5
                Continue
            If five_char is equal to "YYYYY":  Note: Year with century padded
                Add create_format_token with type as "year_padded" and field as "year" and length as 5 to tokens
                Set i to i plus 5
                Continue
        
        If i plus 4 is less than or equal to format_length:
            Let four_char be substring of format_string from i to i plus 4
            Match four_char:
                When "YYYY": Add create_format_token with type as "year_full" and field as "year" and length as 4 to tokens
                When "MMMM": Add create_format_token with type as "month_full" and field as "month" and length as 4 to tokens
                When "WWWW": Add create_format_token with type as "weekday_full" and field as "weekday" and length as 4 to tokens
                When "DDDD": Add create_format_token with type as "day_of_year_padded" and field as "day_of_year" and length as 4 to tokens
                When "HHHH": Add create_format_token with type as "hour_24_padded" and field as "hour" and length as 4 to tokens
                When "TTTT": Add create_format_token with type as "timestamp" and field as "timestamp" and length as 4 to tokens
                Otherwise: Set i to i plus 1; Continue
            Set i to i plus 4
            Continue
        
        If i plus 3 is less than or equal to format_length:
            Let three_char be substring of format_string from i to i plus 3
            Match three_char:
                When "MMM": Add create_format_token with type as "month_abbr" and field as "month" and length as 3 to tokens
                When "DDD": Add create_format_token with type as "day_of_year" and field as "day_of_year" and length as 3 to tokens
                When "WWW": Add create_format_token with type as "weekday_abbr" and field as "weekday" and length as 3 to tokens
                When "HHH": Add create_format_token with type as "hour_12_padded" and field as "hour" and length as 3 to tokens
                When "SSS": Add create_format_token with type as "millisecond" and field as "millisecond" and length as 3 to tokens
                When "ZZZ": Add create_format_token with type as "timezone_full" and field as "timezone" and length as 3 to tokens
                Otherwise: Set i to i plus 1; Continue
            Set i to i plus 3
            Continue
        
        If i plus 2 is less than or equal to format_length:
            Let two_char be substring of format_string from i to i plus 2
            Match two_char:
                When "YY": Add create_format_token with type as "year_short" and field as "year" and length as 2 to tokens
                When "MM": Add create_format_token with type as "month_numeric" and field as "month" and length as 2 to tokens
                When "DD": Add create_format_token with type as "day_numeric" and field as "day" and length as 2 to tokens
                When "HH": Add create_format_token with type as "hour_24" and field as "hour" and length as 2 to tokens
                When "hh": Add create_format_token with type as "hour_12" and field as "hour" and length as 2 to tokens
                When "mm": Add create_format_token with type as "minute" and field as "minute" and length as 2 to tokens
                When "ss": Add create_format_token with type as "second" and field as "second" and length as 2 to tokens
                When "WW": Add create_format_token with type as "week_of_year" and field as "week" and length as 2 to tokens
                When "ZZ": Add create_format_token with type as "timezone_offset" and field as "timezone" and length as 2 to tokens
                When "TT": Add create_format_token with type as "am_pm" and field as "am_pm" and length as 2 to tokens
                Otherwise: Set i to i plus 1; Continue
            Set i to i plus 2
            Continue
        
        Set i to i plus 1
    
    Return tokens

Process called "extract_token_value" that takes input as String and position as Integer and token as Dictionary[String, Any] returns Dictionary[String, Any]:
    Note: Extract specific token value from input string at given position
    Let token_type be token["type"]
    Let token_length be token["length"]
    Let field_name be token["field"]
    
    If position plus token_length is greater than length of input:
        Return dictionary with "success" as false and "error" as "Input too short for token"
    
    Let token_text be substring of input from position to position plus token_length
    
    Match token_type:
        When "year_full", "year_padded":
            Let year_value be parse_integer_safe with text as token_text
            If year_value is not None:
                Return dictionary with "success" as true and "field" as field_name and "value" as year_value and "next_position" as position plus token_length
        
        When "year_short":
            Let year_value be parse_integer_safe with text as token_text
            If year_value is not None:
                Note: Convert 2-digit year to 4-digit (adjust century logic as needed)
                If year_value is less than 50:
                    Set year_value to year_value plus 2000
                Otherwise:
                    Set year_value to year_value plus 1900
                Return dictionary with "success" as true and "field" as field_name and "value" as year_value and "next_position" as position plus token_length
        
        When "month_numeric":
            Let month_value be parse_integer_safe with text as token_text
            If month_value is not None and month_value is greater than or equal to 1 and month_value is less than or equal to 12:
                Return dictionary with "success" as true and "field" as field_name and "value" as month_value and "next_position" as position plus token_length
        
        When "month_abbr":
            Let month_index be find_month_abbreviation with abbr as trim with text as token_text
            If month_index is not equal to -1:
                Return dictionary with "success" as true and "field" as field_name and "value" as month_index plus 1 and "next_position" as position plus token_length
        
        When "month_full":
            Let month_index be find_month_name with name as trim with text as token_text
            If month_index is not equal to -1:
                Return dictionary with "success" as true and "field" as field_name and "value" as month_index plus 1 and "next_position" as position plus token_length
        
        When "day_numeric":
            Let day_value be parse_integer_safe with text as token_text
            If day_value is not None and day_value is greater than or equal to 1 and day_value is less than or equal to 31:
                Return dictionary with "success" as true and "field" as field_name and "value" as day_value and "next_position" as position plus token_length
        
        When "hour_24":
            Let hour_value be parse_integer_safe with text as token_text
            If hour_value is not None and hour_value is greater than or equal to 0 and hour_value is less than or equal to 23:
                Return dictionary with "success" as true and "field" as field_name and "value" as hour_value and "next_position" as position plus token_length
        
        When "hour_12":
            Let hour_value be parse_integer_safe with text as token_text
            If hour_value is not None and hour_value is greater than or equal to 1 and hour_value is less than or equal to 12:
                Return dictionary with "success" as true and "field" as field_name and "value" as hour_value and "next_position" as position plus token_length
        
        When "minute", "second":
            Let time_value be parse_integer_safe with text as token_text
            If time_value is not None and time_value is greater than or equal to 0 and time_value is less than or equal to 59:
                Return dictionary with "success" as true and "field" as field_name and "value" as time_value and "next_position" as position plus token_length
    
    Return dictionary with "success" as false and "error" as "Failed to parse token: " with message token_type

Process called "parse_in_pattern" that takes input as String and context as ParseContext returns ParseResult:
    Note: Parse "in X days/weeks/months" patterns
    If contains with collection as input and item as "in ":
        Let parts be split with text as input and delimiter as "in "
        If length of parts is greater than or equal to 2:
            Let time_part be trim with text as parts[1]
            
            If contains with collection as time_part and item as "day":
                Let days be extract_numeric_value with text as time_part
                If days is not None:
                    Let target_date be add_days with date as today and days as days
                    Return create_parse_success with date as target_date and confidence as 0.8 and format as "natural_in_days"
            
            If contains with collection as time_part and item as "week":
                Let weeks be extract_numeric_value with text as time_part
                If weeks is not None:
                    Let target_date be add_days with date as today and days as weeks times 7
                    Return create_parse_success with date as target_date and confidence as 0.8 and format as "natural_in_weeks"
            
            If contains with collection as time_part and item as "month":
                Let months be extract_numeric_value with text as time_part
                If months is not None:
                    Let target_date be add_months with date as today and months as months
                    Return create_parse_success with date as target_date and confidence as 0.8 and format as "natural_in_months"
    
    Return create_parse_failure with message as "No 'in' pattern found"

Process called "parse_ago_pattern" that takes input as String and context as ParseContext returns ParseResult:
    Note: Parse "X days/weeks/months ago" patterns
    If contains with collection as input and item as " ago":
        Let parts be split with text as input and delimiter as " ago"
        If length of parts is greater than or equal to 1:
            Let time_part be trim with text as parts[0]
            
            If contains with collection as time_part and item as "day":
                Let days be extract_numeric_value with text as time_part
                If days is not None:
                    Let target_date be add_days with date as today and days as negative days
                    Return create_parse_success with date as target_date and confidence as 0.8 and format as "natural_ago_days"
            
            If contains with collection as time_part and item as "week":
                Let weeks be extract_numeric_value with text as time_part
                If weeks is not None:
                    Let target_date be add_days with date as today and days as negative (weeks times 7)
                    Return create_parse_success with date as target_date and confidence as 0.8 and format as "natural_ago_weeks"
            
            If contains with collection as time_part and item as "month":
                Let months be extract_numeric_value with text as time_part
                If months is not None:
                    Let target_date be add_months with date as today and months as negative months
                    Return create_parse_success with date as target_date and confidence as 0.8 and format as "natural_ago_months"
    
    Return create_parse_failure with message as "No 'ago' pattern found"

Process called "find_next_weekday" that takes current_date as Date and target_weekday as Integer returns Date:
    Note: Find next occurrence of specified weekday
    Let current_weekday be current_date["day_of_week"]
    Let days_ahead be (target_weekday minus current_weekday plus 7) modulo 7
    
    If days_ahead is equal to 0:
        Set days_ahead to 7  Note: Next week if today is the target weekday
    
    Return add_days with date as current_date and days as days_ahead

Process called "find_previous_weekday" that takes current_date as Date and target_weekday as Integer returns Date:
    Note: Find previous occurrence of specified weekday
    Let current_weekday be current_date["day_of_week"]
    Let days_behind be (current_weekday minus target_weekday plus 7) modulo 7
    
    If days_behind is equal to 0:
        Set days_behind to 7  Note: Last week if today is the target weekday
    
    Return add_days with date as current_date and days as negative days_behind

Note: ===== ADVANCED UTILITY FUNCTIONS =====

Process called "normalize_date_string" that takes input as String returns String:
    Note: Normalize input string for better parsing
    Let result be trim with text as input
    Set result to to_lowercase with text as result
    Set result to replace_multiple_spaces with text as result
    Set result to normalize_punctuation with text as result
    Return result

Process called "normalize_natural_language" that takes input as String returns String:
    Note: Normalize natural language input
    Let result be trim with text as input
    Set result to to_lowercase with text as result
    Set result to replace_ordinal_numbers with text as result
    Set result to normalize_day_names with text as result
    Set result to normalize_month_names with text as result
    Return result

Process called "create_default_parse_context" returns ParseContext:
    Let current_date be today
    Return ParseContext with:
        default_year as current_date["year"]
        default_month as current_date["month"]
        default_day as current_date["day"]
        default_hour as 0
        default_minute as 0
        default_second as 0
        timezone as "UTC"
        locale as "en_US"
        strict_mode as false

Process called "create_format_token" that takes type as String and field as String and length as Integer returns Dictionary[String, Any]:
    Return dictionary with:
        "type" as type
        "field" as field
        "length" as length

Process called "create_parse_success" that takes date as Date and confidence as Float and format as String returns ParseResult:
    Return ParseResult with:
        success as true
        parsed_date as date
        parsed_time as None
        parsed_datetime as None
        format_detected as format
        confidence_score as confidence
        error_message as ""

Process called "create_parse_success_full" that takes date as Date and time as Time and datetime as DateTime and confidence as Float and format as String returns ParseResult:
    Return ParseResult with:
        success as true
        parsed_date as date
        parsed_time as time
        parsed_datetime as datetime
        format_detected as format
        confidence_score as confidence
        error_message as ""

Process called "create_parse_failure" that takes message as String returns ParseResult:
    Return ParseResult with:
        success as false
        parsed_date as None
        parsed_time as None
        parsed_datetime as None
        format_detected as ""
        confidence_score as 0.0
        error_message as message

Process called "get_parsed_value" that takes values as Dictionary[String, Integer] and key as String and default as Integer returns Integer:
    If values contains key key:
        Return values[key]
    Return default

Process called "extract_numeric_value" that takes text as String returns Optional[Integer]:
    Note: Extract first numeric value from text
    Let numbers be extract_numbers_from_text with text as text
    If length of numbers is greater than 0:
        Return numbers[0]
    Return None

Process called "extract_numbers_from_text" that takes text as String returns List[Integer]:
    Note: Extract all numeric values from text
    Let result be list containing
    Let current_number be ""
    Let in_number be false
    
    For i from 0 to (length of text minus 1):
        Let char be get_character_at with text as text and position as i
        If is_digit with char as char:
            Set current_number to current_number with message char
            Set in_number to true
        Otherwise:
            If in_number and length of current_number is greater than 0:
                Let number be parse_integer_safe with text as current_number
                If number is not None:
                    Add number to result
                Set current_number to ""
                Set in_number to false
    
    Note: Handle number at end of string
    If in_number and length of current_number is greater than 0:
        Let number be parse_integer_safe with text as current_number
        If number is not None:
            Add number to result
    
    Return result

Process called "find_month_abbreviation" that takes abbr as String returns Integer:
    Let normalized_abbr be to_lowercase with text as abbr
    For i from 0 to (length of MONTH_ABBREVIATIONS minus 1):
        If to_lowercase with text as MONTH_ABBREVIATIONS[i] is equal to normalized_abbr:
            Return i
    Return -1

Process called "find_month_name" that takes name as String returns Integer:
    Let normalized_name be to_lowercase with text as name
    For i from 0 to (length of MONTH_NAMES minus 1):
        If to_lowercase with text as MONTH_NAMES[i] is equal to normalized_name:
            Return i
    Return -1

Process called "find_index" that takes list as List[String] and item as String returns Integer:
    For i from 0 to (length of list minus 1):
        If list[i] is equal to item:
            Return i
    Return -1

Process called "parse_integer_safe" that takes text as String returns Optional[Integer]:
    Try:
        Return parse_integer with text as text
    Catch error:
        Return None

Process called "to_lowercase" that takes text as String returns String:
    Note: Convert text to lowercase
    Let result be ""
    For i from 0 to (length of text minus 1):
        Let char be get_character_at with text as text and position as i
        If char is equal to "A":
            Set result to result with message "a"
        Otherwise if char is equal to "B":
            Set result to result with message "b"
        Otherwise if char is equal to "C":
            Set result to result with message "c"
        Otherwise if char is equal to "D":
            Set result to result with message "d"
        Otherwise if char is equal to "E":
            Set result to result with message "e"
        Otherwise if char is equal to "F":
            Set result to result with message "f"
        Otherwise if char is equal to "G":
            Set result to result with message "g"
        Otherwise if char is equal to "H":
            Set result to result with message "h"
        Otherwise if char is equal to "I":
            Set result to result with message "i"
        Otherwise if char is equal to "J":
            Set result to result with message "j"
        Otherwise if char is equal to "K":
            Set result to result with message "k"
        Otherwise if char is equal to "L":
            Set result to result with message "l"
        Otherwise if char is equal to "M":
            Set result to result with message "m"
        Otherwise if char is equal to "N":
            Set result to result with message "n"
        Otherwise if char is equal to "O":
            Set result to result with message "o"
        Otherwise if char is equal to "P":
            Set result to result with message "p"
        Otherwise if char is equal to "Q":
            Set result to result with message "q"
        Otherwise if char is equal to "R":
            Set result to result with message "r"
        Otherwise if char is equal to "S":
            Set result to result with message "s"
        Otherwise if char is equal to "T":
            Set result to result with message "t"
        Otherwise if char is equal to "U":
            Set result to result with message "u"
        Otherwise if char is equal to "V":
            Set result to result with message "v"
        Otherwise if char is equal to "W":
            Set result to result with message "w"
        Otherwise if char is equal to "X":
            Set result to result with message "x"
        Otherwise if char is equal to "Y":
            Set result to result with message "y"
        Otherwise if char is equal to "Z":
            Set result to result with message "z"
        Otherwise:
            Set result to result with message char
    Return result

Process called "trim" that takes text as String returns String:
    Note: Remove leading and trailing whitespace
    Let text_length be length of text
    If text_length is equal to 0:
        Return ""
    
    Let start_index be 0
    Let end_index be text_length minus 1
    
    Note: Find first non-whitespace character
    For i from 0 to (text_length minus 1):
        Let char be get_character_at with text as text and position as i
        If char is not equal to " " and char is not equal to "\t" and char is not equal to "\r" and char is not equal to "\n":
            Set start_index to i
            Break loop
    
    Note: Find last non-whitespace character
    For i from (text_length minus 1) down to 0:
        Let char be get_character_at with text as text and position as i
        If char is not equal to " " and char is not equal to "\t" and char is not equal to "\r" and char is not equal to "\n":
            Set end_index to i
            Break loop
    
    If start_index is greater than end_index:
        Return ""
    
    Let result be ""
    For i from start_index to end_index:
        Let char be get_character_at with text as text and position as i
        Set result to result with message char
    
    Return result

Process called "split" that takes text as String and delimiter as String returns List[String]:
    Note: Split text by delimiter
    Let result be list containing
    Let current_part be ""
    Let text_length be length of text
    Let delimiter_length be length of delimiter
    
    If text_length is equal to 0:
        Return result
    
    If delimiter_length is equal to 0:
        Add text to result
        Return result
    
    Let i be 0
    While i is less than text_length:
        Let matches_delimiter be true
        
        Note: Check if current position matches delimiter
        If i plus delimiter_length is greater than text_length:
            Set matches_delimiter to false
        Otherwise:
            For j from 0 to (delimiter_length minus 1):
                Let text_char be get_character_at with text as text and position as (i plus j)
                Let delim_char be get_character_at with text as delimiter and position as j
                If text_char is not equal to delim_char:
                    Set matches_delimiter to false
                    Break loop
        
        If matches_delimiter:
            Add current_part to result
            Set current_part to ""
            Set i to i plus delimiter_length
        Otherwise:
            Let char be get_character_at with text as text and position as i
            Set current_part to current_part with message char
            Set i to i plus 1
    
    Add current_part to result
    Return result

Process called "contains" that takes collection as String and item as String returns Boolean:
    Note: Check if collection contains item
    Let collection_length be length of collection
    Let item_length be length of item
    
    If item_length is equal to 0:
        Return true
    
    If item_length is greater than collection_length:
        Return false
    
    For i from 0 to (collection_length minus item_length):
        Let matches be true
        
        For j from 0 to (item_length minus 1):
            Let collection_char be get_character_at with text as collection and position as (i plus j)
            Let item_char be get_character_at with text as item and position as j
            If collection_char is not equal to item_char:
                Set matches to false
                Break loop
        
        If matches:
            Return true
    
    Return false

Process called "replace_multiple_spaces" that takes text as String returns String:
    Note: Replace multiple consecutive spaces with single space
    Let result be ""
    Let previous_was_space be false
    Let text_length be length of text
    
    For i from 0 to (text_length minus 1):
        Let char be get_character_at with text as text and position as i
        If char is equal to " ":
            If not previous_was_space:
                Set result to result with message char
                Set previous_was_space to true
        Otherwise:
            Set result to result with message char
            Set previous_was_space to false
    
    Return result

Process called "normalize_punctuation" that takes text as String returns String:
    Note: Normalize punctuation for consistent parsing
    Let result be text
    
    Note: Replace common punctuation variations
    If contains with collection as result and item as ",":
        Set result to replace_string with text as result and old_string as "," and new_string as ", "
    
    If contains with collection as result and item as ".":
        Set result to replace_string with text as result and old_string as "." and new_string as ". "
    
    If contains with collection as result and item as "!":
        Set result to replace_string with text as result and old_string as "!" and new_string as "! "
    
    If contains with collection as result and item as "?":
        Set result to replace_string with text as result and old_string as "?" and new_string as "? "
    
    Note: Clean up multiple spaces that may have been introduced
    Set result to replace_multiple_spaces with text as result
    
    Return trim with text as result

