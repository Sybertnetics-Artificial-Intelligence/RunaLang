Type called "CultureInfo":
    locale as Locale
    localized_strings as LocalizedStrings
    number_format as NumberFormat
    calendar_preferences as CalendarPreferences
    sorting_rules as SortingRules

Type called "NumberFormat":
    decimal_separator as String
    thousands_separator as String
    negative_sign as String
    positive_sign as String
    percent_symbol as String
    currency_symbol as String
    currency_decimal_digits as Integer

Process called "get_locale" that takes locale_code as String returns Locale:
    Note: Get comprehensive locale information
    Let locale_data be lookup_locale_database with code as locale_code
    
    If locale_data is None:
        Return create_default_locale with code as locale_code
    
    Return Locale with:
        language_code as locale_data["language_code"]
        country_code as locale_data["country_code"]
        script_code as locale_data["script_code"]
        variant as locale_data["variant"]
        display_name as locale_data["display_name"]
        native_name as locale_data["native_name"]
        text_direction as locale_data["text_direction"]
        decimal_separator as locale_data["decimal_separator"]
        thousands_separator as locale_data["thousands_separator"]
        currency_symbol as locale_data["currency_symbol"]
        date_format as locale_data["date_format"]
        time_format as locale_data["time_format"]
        first_day_of_week as locale_data["first_day_of_week"]

Process called "get_culture_info" that takes locale_code as String returns CultureInfo:
    Note: Get complete cultural information for locale
    Let locale be get_locale with locale_code as locale_code
    Let localized_strings be get_localized_strings with locale as locale
    Let number_format be get_number_format with locale as locale
    Let calendar_preferences be get_calendar_preferences with locale as locale
    Let sorting_rules be get_sorting_rules with locale as locale
    
    Return CultureInfo with:
        locale as locale
        localized_strings as localized_strings
        number_format as number_format
        calendar_preferences as calendar_preferences
        sorting_rules as sorting_rules

Process called "format_date_localized" that takes date as Date and locale_code as String and format_type as String returns String:
    Note: Format date according to locale-specific conventions
    Let culture_info be get_culture_info with locale_code as locale_code
    Let locale be culture_info["locale"]
    Let strings be culture_info["localized_strings"]
    
    Match format_type:
        When "short":
            Return format_date_with_locale_pattern with date as date and pattern as locale["date_format"] and strings as strings
        When "medium":
            Return format_date_medium_localized with date as date and locale as locale and strings as strings
        When "long":
            Return format_date_long_localized with date as date and locale as locale and strings as strings
        When "full":
            Return format_date_full_localized with date as date and locale as locale and strings as strings
        Otherwise:
            Return format_date_with_locale_pattern with date as date and pattern as format_type and strings as strings

Process called "format_time_localized" that takes time as Time and locale_code as String and format_type as String returns String:
    Note: Format time according to locale-specific conventions
    Let culture_info be get_culture_info with locale_code as locale_code
    Let locale be culture_info["locale"]
    Let strings be culture_info["localized_strings"]
    
    Match format_type:
        When "short":
            Return format_time_with_locale_pattern with time as time and pattern as locale["time_format"] and strings as strings
        When "medium":
            Return format_time_medium_localized with time as time and locale as locale and strings as strings
        When "long":
            Return format_time_long_localized with time as time and locale as locale and strings as strings
        Otherwise:
            Return format_time_with_locale_pattern with time as time and pattern as format_type and strings as strings

Process called "get_relative_time_expression" that takes datetime1 as DateTime and datetime2 as DateTime and locale_code as String returns String:
    Note: Generate localized relative time expressions like "2 hours ago", "in 3 days"
    Let culture_info be get_culture_info with locale_code as locale_code
    Let expressions be culture_info["localized_strings"]["relative_time_expressions"]
    
    Let diff_seconds be datetime1["timestamp"] minus datetime2["timestamp"]
    Let abs_diff be absolute with value as diff_seconds
    
    Note: Determine appropriate time unit and localize
    If abs_diff is less than 60:
        Let key be if diff_seconds is greater than 0 then "seconds_ago" else "in_seconds"
        Return replace_placeholder with template as expressions[key] and value as abs_diff
    
    If abs_diff is less than 3600:
        Let minutes be abs_diff divided by 60
        Let key be if diff_seconds is greater than 0 then "minutes_ago" else "in_minutes"
        Return replace_placeholder with template as expressions[key] and value as minutes
    
    If abs_diff is less than 86400:
        Let hours be abs_diff divided by 3600
        Let key be if diff_seconds is greater than 0 then "hours_ago" else "in_hours"
        Return replace_placeholder with template as expressions[key] and value as hours
    
    Let days be abs_diff divided by 86400
    Let key be if diff_seconds is greater than 0 then "days_ago" else "in_days"
    Return replace_placeholder with template as expressions[key] and value as days

Process called "get_weekday_name_localized" that takes weekday_index as Integer and locale_code as String and format_type as String returns String:
    Note: Get localized weekday name
    Let culture_info be get_culture_info with locale_code as locale_code
    Let strings be culture_info["localized_strings"]
    
    Match format_type:
        When "full":
            Return strings["weekday_names"][weekday_index]
        When "abbreviated":
            Return strings["weekday_abbreviations"][weekday_index]
        When "narrow":
            Return substring of strings["weekday_names"][weekday_index] from 0 to 1
        Otherwise:
            Return strings["weekday_names"][weekday_index]

Process called "get_month_name_localized" that takes month_index as Integer and locale_code as String and format_type as String returns String:
    Note: Get localized month name
    Let culture_info be get_culture_info with locale_code as locale_code
    Let strings be culture_info["localized_strings"]
    
    Match format_type:
        When "full":
            Return strings["month_names"][month_index minus 1]
        When "abbreviated":
            Return strings["month_abbreviations"][month_index minus 1]
        When "narrow":
            Return substring of strings["month_names"][month_index minus 1] from 0 to 1
        Otherwise:
            Return strings["month_names"][month_index minus 1]

