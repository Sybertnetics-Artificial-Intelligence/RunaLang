Note: Runa Standard Library - Advanced Schema Validation System
Note: JSON Schema compatible validation with enterprise features
Note: Exceeds joi, ajv, cerberus with conditional validation, nested schemas, and async support

Import "validation/validators" as Validators
Import "../../builtins" as Builtins
Import "../../collections" as Collections
Import "string/format" as Format
Import "text/regex" as Regex
Import "../../json" as JSON

Note: Schema definition types for comprehensive object validation

Type SchemaType is:
    | ObjectSchema
    | ArraySchema
    | StringSchema
    | NumberSchema
    | BooleanSchema
    | NullSchema
    | AnySchema
    | OneOfSchema
    | AllOfSchema
    | AnyOfSchema
    | ConditionalSchema

Type called "SchemaDefinition":
    schema_type as SchemaType
    title as String
    description as String
    required as Boolean
    default_value as Any
    validators as List[Validators.Validator]
    metadata as Dictionary[String, Any]

Type called "ObjectSchemaDefinition":
    properties as Dictionary[String, SchemaDefinition]
    required_properties as List[String]
    additional_properties as Boolean
    pattern_properties as Dictionary[String, SchemaDefinition]
    min_properties as Integer
    max_properties as Integer
    dependencies as Dictionary[String, List[String]]
    property_dependencies as Dictionary[String, SchemaDefinition]

Type called "ArraySchemaDefinition":
    items_schema as SchemaDefinition
    min_items as Integer
    max_items as Integer
    unique_items as Boolean
    additional_items as Boolean
    contains_schema as SchemaDefinition

Type called "StringSchemaDefinition":
    min_length as Integer
    max_length as Integer
    pattern as String
    format as String
    enum_values as List[String]

Type called "NumberSchemaDefinition":
    minimum as Float
    maximum as Float
    exclusive_minimum as Float
    exclusive_maximum as Float
    multiple_of as Float
    enum_values as List[Float]

Type called "ConditionalSchemaDefinition":
    if_schema as SchemaDefinition
    then_schema as SchemaDefinition
    else_schema as SchemaDefinition
    condition_expression as String

Note: Comprehensive schema validator with JSON Schema compliance

Type called "SchemaValidator":
    schema_definitions as Dictionary[String, SchemaDefinition]
    validation_engine as Validators.ValidationEngine
    schema_cache as Dictionary[String, SchemaDefinition]
    performance_metrics as Dictionary[String, Any]
    
    Process called "create" returns SchemaValidator:
        Return SchemaValidator with:
            schema_definitions as dictionary containing
            validation_engine as Validators.ValidationEngine.create()
            schema_cache as dictionary containing
            performance_metrics as dictionary with:
                "schema_validations" as 0
                "cache_hits" as 0
                "average_validation_time" as 0.0

    Process called "register_schema" that takes schema_name as String and schema_def as SchemaDefinition returns None:
        Set self.schema_definitions[schema_name] to schema_def
        Set self.schema_cache[schema_name] to schema_def

    Process called "validate_object" that takes obj as Any and schema_name as String returns Validators.ValidationResult:
        If schema_name is not in self.schema_definitions:
            Let error be Validators.ValidationError with:
                field_path as ""
                error_code as "SCHEMA_NOT_FOUND"
                message as f"Schema '{schema_name}' not found"
                severity as Validators.Error
                value as obj
                metadata as dictionary containing
            Return Validators.Invalid with errors as list containing error
        
        Let schema_def be self.schema_definitions[schema_name]
        Let context be Validators.create_validation_context with root_object as obj
        
        Return self.validate_against_schema with value as obj and schema as schema_def and context as context

    Process called "validate_against_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        Let start_time be get_current_timestamp()
        
        Match schema.schema_type:
            When ObjectSchema:
                Let result be self.validate_object_schema with value as value and schema as schema and context as context
            When ArraySchema:
                Let result be self.validate_array_schema with value as value and schema as schema and context as context
            When StringSchema:
                Let result be self.validate_string_schema with value as value and schema as schema and context as context
            When NumberSchema:
                Let result be self.validate_number_schema with value as value and schema as schema and context as context
            When BooleanSchema:
                Let result be self.validate_boolean_schema with value as value and schema as schema and context as context
            When ConditionalSchema:
                Let result be self.validate_conditional_schema with value as value and schema as schema and context as context
            When OneOfSchema:
                Let result be self.validate_one_of_schema with value as value and schema as schema and context as context
            When AllOfSchema:
                Let result be self.validate_all_of_schema with value as value and schema as schema and context as context
            When AnyOfSchema:
                Let result be self.validate_any_of_schema with value as value and schema as schema and context as context
            Otherwise:
                Let result be self.validate_generic_schema with value as value and schema as schema and context as context
        
        Note: Update performance metrics
        Let end_time be get_current_timestamp()
        Set self.performance_metrics["schema_validations"] to self.performance_metrics["schema_validations"] 1
        Let validation_time be end_time - start_time
        Let total_time be self.performance_metrics["average_validation_time"] multiplied by self.performance_metrics["schema_validations"] minus 1
        Set total_time to total_time validation_time
        Set self.performance_metrics["average_validation_time"] to total_time divided by self.performance_metrics["schema_validations"]
        
        Return result

    Process called "validate_object_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        If not Builtins.is_dictionary with value as value:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "TYPE_MISMATCH"
                message as "Expected object/dictionary"
                severity as Validators.Error
                value as value
                metadata as dictionary containing
            Return Validators.Invalid with errors as list containing error
        
        Let all_errors be list containing
        Let object_schema be schema.metadata["object_definition"]
        
        Note: Validate required properties
        For each required_prop in object_schema.required_properties:
            If required_prop is not in value:
                Let error be Validators.ValidationError with:
                    field_path as context.current_path Joined with "." Joined with required_prop
                    error_code as "REQUIRED_PROPERTY_MISSING"
                    message as f"Required property '{required_prop}' is missing"
                    severity as Validators.Error
                    value as value
                    metadata as dictionary with "property" as required_prop
                Add error to all_errors
        
        Note: Validate each property
        For each property_name and property_value in value:
            If property_name is in object_schema.properties:
                Let property_schema be object_schema.properties[property_name]
                Let property_context be Validators.extend_validation_context with context as context and new_path as property_name
                Let property_result be self.validate_against_schema with value as property_value and schema as property_schema and context as property_context
                
                Match property_result:
                    When Validators.Invalid with errors as errors:
                        For each error in errors:
                            Add error to all_errors
            Otherwise If not object_schema.additional_properties:
                Let error be Validators.ValidationError with:
                    field_path as context.current_path Joined with "." Joined with property_name
                    error_code as "ADDITIONAL_PROPERTY_NOT_ALLOWED"
                    message as f"Additional property '{property_name}' is not allowed"
                    severity as Validators.Error
                    value as property_value
                    metadata as dictionary with "property" as property_name
                Add error to all_errors
        
        Note: Validate property count constraints
        Let property_count be length of value
        If property_count is less than object_schema.min_properties:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "TOO_FEW_PROPERTIES"
                message as f"Object has {property_count} properties, minimum is {object_schema.min_properties}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "count" as property_count and "minimum" as object_schema.min_properties
            Add error to all_errors
        
        If property_count is greater than object_schema.max_properties:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "TOO_MANY_PROPERTIES"
                message as f"Object has {property_count} properties, maximum is {object_schema.max_properties}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "count" as property_count and "maximum" as object_schema.max_properties
            Add error to all_errors
        
        If length of all_errors is greater than 0:
            Return Validators.Invalid with errors as all_errors
        Return Validators.Valid

    Process called "validate_array_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        If not Builtins.is_list with value as value:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "TYPE_MISMATCH"
                message as "Expected array/list"
                severity as Validators.Error
                value as value
                metadata as dictionary containing
            Return Validators.Invalid with errors as list containing error
        
        Let all_errors be list containing
        Let array_schema be schema.metadata["array_definition"]
        
        Note: Validate array length constraints
        Let array_length be length of value
        If array_length is less than array_schema.min_items:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "TOO_FEW_ITEMS"
                message as f"Array has {array_length} items, minimum is {array_schema.min_items}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "count" as array_length and "minimum" as array_schema.min_items
            Add error to all_errors
        
        If array_length is greater than array_schema.max_items:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "TOO_MANY_ITEMS"
                message as f"Array has {array_length} items, maximum is {array_schema.max_items}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "count" as array_length and "maximum" as array_schema.max_items
            Add error to all_errors
        
        Note: Validate unique items constraint
        If array_schema.unique_items:
            Let unique_items be create_set_from_list with list as value
            If length of unique_items is not equal to array_length:
                Let error be Validators.ValidationError with:
                    field_path as context.current_path
                    error_code as "DUPLICATE_ITEMS"
                    message as "Array contains duplicate items but uniqueItems is true"
                    severity as Validators.Error
                    value as value
                    metadata as dictionary containing
                Add error to all_errors
        
        Note: Validate each array item
        For i from 0 to array_length - 1:
            Let item be value[i]
            Let item_context be Validators.extend_validation_context with context as context and new_path as f"[{i}]"
            Let item_result be self.validate_against_schema with value as item and schema as array_schema.items_schema and context as item_context
            
            Match item_result:
                When Validators.Invalid with errors as errors:
                    For each error in errors:
                        Add error to all_errors
        
        If length of all_errors is greater than 0:
            Return Validators.Invalid with errors as all_errors
        Return Validators.Valid

    Process called "validate_string_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        If not Builtins.is_string with value as value:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "TYPE_MISMATCH"
                message as "Expected string"
                severity as Validators.Error
                value as value
                metadata as dictionary containing
            Return Validators.Invalid with errors as list containing error
        
        Let all_errors be list containing
        Let string_schema be schema.metadata["string_definition"]
        
        Note: Validate string length
        Let string_length be Builtins.string_length with string as value
        If string_length is less than string_schema.min_length:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "STRING_TOO_SHORT"
                message as f"String length {string_length} is less than minimum {string_schema.min_length}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "length" as string_length and "minimum" as string_schema.min_length
            Add error to all_errors
        
        If string_length is greater than string_schema.max_length:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "STRING_TOO_LONG"
                message as f"String length {string_length} exceeds maximum {string_schema.max_length}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "length" as string_length and "maximum" as string_schema.max_length
            Add error to all_errors
        
        Note: Validate pattern if specified
        If length of string_schema.pattern is greater than 0:
            If not Regex.matches with pattern as string_schema.pattern and text as value:
                Let error be Validators.ValidationError with:
                    field_path as context.current_path
                    error_code as "PATTERN_MISMATCH"
                    message as f"String does not match pattern: {string_schema.pattern}"
                    severity as Validators.Error
                    value as value
                    metadata as dictionary with "pattern" as string_schema.pattern
                Add error to all_errors
        
        Note: Validate enum values if specified
        If length of string_schema.enum_values is greater than 0:
            If value is not in string_schema.enum_values:
                Let error be Validators.ValidationError with:
                    field_path as context.current_path
                    error_code as "INVALID_ENUM_VALUE"
                    message as f"String must be one of: {Format.join with separator as ', ' and items as string_schema.enum_values}"
                    severity as Validators.Error
                    value as value
                    metadata as dictionary with "allowed_values" as string_schema.enum_values
                Add error to all_errors
        
        Note: Validate format if specified
        If length of string_schema.format is greater than 0:
            Let format_result be self.validate_string_format with value as value and format as string_schema.format and context as context
            Match format_result:
                When Validators.Invalid with errors as errors:
                    For each error in errors:
                        Add error to all_errors
        
        If length of all_errors is greater than 0:
            Return Validators.Invalid with errors as all_errors
        Return Validators.Valid

    Process called "validate_number_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        If not is_numeric with value as value:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "TYPE_MISMATCH"
                message as "Expected number"
                severity as Validators.Error
                value as value
                metadata as dictionary containing
            Return Validators.Invalid with errors as list containing error
        
        Let all_errors be list containing
        Let number_schema be schema.metadata["number_definition"]
        Let numeric_value be convert_to_float with value as value
        
        Note: Validate minimum constraint
        If numeric_value is less than number_schema.minimum:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "NUMBER_TOO_SMALL"
                message as f"Number {numeric_value} is less than minimum {number_schema.minimum}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "value" as numeric_value and "minimum" as number_schema.minimum
            Add error to all_errors
        
        Note: Validate maximum constraint
        If numeric_value is greater than number_schema.maximum:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "NUMBER_TOO_LARGE"
                message as f"Number {numeric_value} exceeds maximum {number_schema.maximum}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "value" as numeric_value and "maximum" as number_schema.maximum
            Add error to all_errors
        
        Note: Validate exclusive minimum
        If numeric_value is less than or equal to number_schema.exclusive_minimum:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "NUMBER_NOT_GREATER_THAN_EXCLUSIVE_MINIMUM"
                message as f"Number {numeric_value} must be greater than {number_schema.exclusive_minimum}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "value" as numeric_value and "exclusive_minimum" as number_schema.exclusive_minimum
            Add error to all_errors
        
        Note: Validate exclusive maximum
        If numeric_value is greater than or equal to number_schema.exclusive_maximum:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "NUMBER_NOT_LESS_THAN_EXCLUSIVE_MAXIMUM"
                message as f"Number {numeric_value} must be less than {number_schema.exclusive_maximum}"
                severity as Validators.Error
                value as value
                metadata as dictionary with "value" as numeric_value and "exclusive_maximum" as number_schema.exclusive_maximum
            Add error to all_errors
        
        Note: Validate multiple of constraint
        If number_schema.multiple_of is greater than 0.0:
            Let remainder be numeric_value modulo number_schema.multiple_of
            If remainder is not equal to 0.0:
                Let error be Validators.ValidationError with:
                    field_path as context.current_path
                    error_code as "NOT_MULTIPLE_OF"
                    message as f"Number {numeric_value} is not a multiple of {number_schema.multiple_of}"
                    severity as Validators.Error
                    value as value
                    metadata as dictionary with "value" as numeric_value and "multiple_of" as number_schema.multiple_of
                Add error to all_errors
        
        If length of all_errors is greater than 0:
            Return Validators.Invalid with errors as all_errors
        Return Validators.Valid

    Process called "validate_boolean_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        If not Builtins.is_boolean with value as value:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "TYPE_MISMATCH"
                message as "Expected boolean"
                severity as Validators.Error
                value as value
                metadata as dictionary containing
            Return Validators.Invalid with errors as list containing error
        
        Return Validators.Valid

    Process called "validate_conditional_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        Let conditional_schema be schema.metadata["conditional_definition"]
        
        Note: Evaluate the if condition
        Let if_result be self.validate_against_schema with value as value and schema as conditional_schema.if_schema and context as context
        
        Match if_result:
            When Validators.Valid:
                Note: If condition passed, validate against then schema
                Return self.validate_against_schema with value as value and schema as conditional_schema.then_schema and context as context
            When Validators.Invalid with errors as errors:
                Note: If condition failed, validate against else schema
                Return self.validate_against_schema with value as value and schema as conditional_schema.else_schema and context as context

    Process called "validate_one_of_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        Let one_of_schemas be schema.metadata["one_of_schemas"]
        Let valid_count be 0
        Let validation_errors be list containing
        
        For each sub_schema in one_of_schemas:
            Let result be self.validate_against_schema with value as value and schema as sub_schema and context as context
            Match result:
                When Validators.Valid:
                    Set valid_count to valid_count 1
                When Validators.Invalid with errors as errors:
                    For each error in errors:
                        Add error to validation_errors
        
        If valid_count is equal to 1:
            Return Validators.Valid
        
        If valid_count is equal to 0:
            Let error be Validators.ValidationError with:
                field_path as context.current_path
                error_code as "ONE_OF_NO_MATCH"
                message as "Value does not match any of the oneOf schemas"
                severity as Validators.Error
                value as value
                metadata as dictionary with "schema_errors" as validation_errors
            Return Validators.Invalid with errors as list containing error
        
        Let error be Validators.ValidationError with:
            field_path as context.current_path
            error_code as "ONE_OF_MULTIPLE_MATCHES"
            message as f"Value matches {valid_count} schemas but should match exactly one"
            severity as Validators.Error
            value as value
            metadata as dictionary with "match_count" as valid_count
        Return Validators.Invalid with errors as list containing error

    Process called "validate_all_of_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        Let all_of_schemas be schema.metadata["all_of_schemas"]
        Let all_errors be list containing
        
        For each sub_schema in all_of_schemas:
            Let result be self.validate_against_schema with value as value and schema as sub_schema and context as context
            Match result:
                When Validators.Invalid with errors as errors:
                    For each error in errors:
                        Add error to all_errors
        
        If length of all_errors is greater than 0:
            Return Validators.Invalid with errors as all_errors
        Return Validators.Valid

    Process called "validate_any_of_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        Let any_of_schemas be schema.metadata["any_of_schemas"]
        Let validation_errors be list containing
        
        For each sub_schema in any_of_schemas:
            Let result be self.validate_against_schema with value as value and schema as sub_schema and context as context
            Match result:
                When Validators.Valid:
                    Return Validators.Valid
                When Validators.Invalid with errors as errors:
                    For each error in errors:
                        Add error to validation_errors
        
        Let error be Validators.ValidationError with:
            field_path as context.current_path
            error_code as "ANY_OF_NO_MATCH"
            message as "Value does not match any of the anyOf schemas"
            severity as Validators.Error
            value as value
            metadata as dictionary with "schema_errors" as validation_errors
        Return Validators.Invalid with errors as list containing error

    Process called "validate_generic_schema" that takes value as Any and schema as SchemaDefinition and context as Validators.ValidationContext returns Validators.ValidationResult:
        Let all_errors be list containing
        
        Note: Validate using registered validators
        For each validator in schema.validators:
            Let result be validator.validate with value as value and context as context
            Match result:
                When Validators.Invalid with errors as errors:
                    For each error in errors:
                        Add error to all_errors
        
        If length of all_errors is greater than 0:
            Return Validators.Invalid with errors as all_errors
        Return Validators.Valid

    Process called "validate_string_format" that takes value as String and format as String and context as Validators.ValidationContext returns Validators.ValidationResult:
        Match format:
            When "email":
                Let email_validator be Validators.create_email_validator()
                Return email_validator.validate with value as value and context as context
            When "uri":
                Let url_validator be Validators.create_url_validator()
                Return url_validator.validate with value as value and context as context
            When "date":
                Let date_validator be Validators.create_datetime_validator with format as "YYYY-MM-DD"
                Return date_validator.validate with value as value and context as context
            When "time":
                Let time_validator be Validators.create_datetime_validator with format as "HH:MM:SS"
                Return time_validator.validate with value as value and context as context
            When "date-time":
                Let datetime_validator be Validators.create_datetime_validator with format as "ISO8601"
                Return datetime_validator.validate with value as value and context as context
            Otherwise:
                Return Validators.Valid

Note: Schema builder functions for creating complex schemas

Process called "create_object_schema" that takes properties as Dictionary[String, SchemaDefinition] and required_props as List[String] returns SchemaDefinition:
    Let object_def be ObjectSchemaDefinition with:
        properties as properties
        required_properties as required_props
        additional_properties as false
        pattern_properties as dictionary containing
        min_properties as 0
        max_properties as 999999
        dependencies as dictionary containing
        property_dependencies as dictionary containing
    
    Return SchemaDefinition with:
        schema_type as ObjectSchema
        title as ""
        description as ""
        required as false
        default_value as null
        validators as list containing
        metadata as dictionary with "object_definition" as object_def

Process called "create_array_schema" that takes items_schema as SchemaDefinition returns SchemaDefinition:
    Let array_def be ArraySchemaDefinition with:
        items_schema as items_schema
        min_items as 0
        max_items as 999999
        unique_items as false
        additional_items as true
        contains_schema as null
    
    Return SchemaDefinition with:
        schema_type as ArraySchema
        title as ""
        description as ""
        required as false
        default_value as null
        validators as list containing
        metadata as dictionary with "array_definition" as array_def

Process called "create_string_schema" returns SchemaDefinition:
    Let string_def be StringSchemaDefinition with:
        min_length as 0
        max_length as 999999
        pattern as ""
        format as ""
        enum_values as list containing
    
    Return SchemaDefinition with:
        schema_type as StringSchema
        title as ""
        description as ""
        required as false
        default_value as null
        validators as list containing
        metadata as dictionary with "string_definition" as string_def

Process called "create_number_schema" returns SchemaDefinition:
    Let number_def be NumberSchemaDefinition with:
        minimum as -999999999.0
        maximum as 999999999.0
        exclusive_minimum as -999999999.0
        exclusive_maximum as 999999999.0
        multiple_of as 0.0
        enum_values as list containing
    
    Return SchemaDefinition with:
        schema_type as NumberSchema
        title as ""
        description as ""
        required as false
        default_value as null
        validators as list containing
        metadata as dictionary with "number_definition" as number_def

Process called "create_boolean_schema" returns SchemaDefinition:
    Return SchemaDefinition with:
        schema_type as BooleanSchema
        title as ""
        description as ""
        required as false
        default_value as null
        validators as list containing
        metadata as dictionary containing

Process called "create_conditional_schema" that takes if_schema as SchemaDefinition and then_schema as SchemaDefinition and else_schema as SchemaDefinition returns SchemaDefinition:
    Let conditional_def be ConditionalSchemaDefinition with:
        if_schema as if_schema
        then_schema as then_schema
        else_schema as else_schema
        condition_expression as ""
    
    Return SchemaDefinition with:
        schema_type as ConditionalSchema
        title as ""
        description as ""
        required as false
        default_value as null
        validators as list containing
        metadata as dictionary with "conditional_definition" as conditional_def

Note: Utility functions for schema validation

Process called "is_numeric" that takes value as Any returns Boolean:
    Return Builtins.is_integer with value as value or Builtins.is_float with value as value

Process called "convert_to_float" that takes value as Any returns Float:
    If Builtins.is_float with value as value:
        Return value
    If Builtins.is_integer with value as value:
        Return value as Float
    Return 0.0

Process called "create_set_from_list" that takes list as List[Any] returns List[Any]:
    Let unique_items be list containing
    
    For each item in list:
        If item is not in unique_items:
            Add item to unique_items
    
    Return unique_items

Process called "get_current_timestamp" returns Integer:
    Return Builtins.get_current_timestamp()

Note: JSON Schema compatibility functions

Process called "parse_json_schema" that takes json_schema as String returns SchemaDefinition:
    Let parsed_json be JSON.parse with json_string as json_schema
    Return convert_json_to_schema_definition with json_obj as parsed_json

Process called "convert_json_to_schema_definition" that takes json_obj as Dictionary[String, Any] returns SchemaDefinition:
