Import "../../builtins/functions.runa"
Import "../../os/os.runa"
Import "../../json/json.runa"
Import "../../uuid/uuid.runa"
Import "../../datetime/datetime.runa"
Import "../../concurrent/locks.runa"
Import "../../crypto/hash.runa"
Import "../../crypto/signatures.runa"

Note:
Runa Standard Library: AI Agent Communication - Core Messaging System
Production-ready agent-to-agent communication framework with comprehensive message handling,
delivery guarantees, and fault tolerance. Essential foundation for distributed AI systems.

Advanced features include:
- Message lifecycle management with state tracking and auditing
- Delivery guarantee levels from best-effort to exactly-once
- Message serialization with compression and versioning
- Priority-based message queuing with overflow protection
- Timeout handling with exponential backoff retry policies
- Message filtering and routing rules with pattern matching
- Comprehensive error handling with circuit breaker patterns
- Performance monitoring with real-time metrics collection
- Security integration with encryption and authentication
- Load balancing across multiple communication channels
:End Note

Type MessagePriority is Enum with values:
    "critical"
    "high"
    "normal"
    "low"
    "background"

Type MessageType is Enum with values:
    "request"
    "response"
    "notification"
    "broadcast"
    "multicast"
    "heartbeat"
    "discovery"
    "coordination"
    "data_transfer"
    "error"
    "acknowledgment"
    "shutdown"

Type DeliveryGuarantee is Enum with values:
    "best_effort"
    "at_least_once"
    "exactly_once"
    "ordered"
    "reliable"

Type MessageStatus is Enum with values:
    "created"
    "queued"
    "routing"
    "transmitted"
    "delivered"
    "acknowledged"
    "failed"
    "expired"
    "retrying"

Type called "MessageMetadata":
    creation_time as Float
    last_modified as Float
    expiration_time as Optional[Float]
    retry_count as Integer
    max_retries as Integer
    delivery_attempts as List[Dictionary]
    routing_history as List[String]
    compression_type as Optional[String]
    checksum as String
    content_length as Integer
    encoding as String

Type called "AgentMessage":
    message_id as String
    conversation_id as Optional[String]
    parent_message_id as Optional[String]
    sender_id as String
    receiver_id as String
    message_type as MessageType
    priority as MessagePriority
    delivery_guarantee as DeliveryGuarantee
    payload as Any
    headers as Dictionary[String, String]
    metadata as MessageMetadata
    signature as Optional[String]
    encryption_info as Optional[Dictionary]
    status as MessageStatus
    error_info as Optional[Dictionary]

Type called "MessageQueue":
    queue_id as String
    agent_id as String
    messages as List[AgentMessage]
    max_size as Integer
    current_size as Integer
    priority_queues as Dictionary[MessagePriority, List[AgentMessage]]
    overflow_policy as String
    statistics as Dictionary[String, Integer]

Type called "MessageFilter":
    filter_id as String
    name as String
    conditions as List[Dictionary]
    action as String
    priority as Integer
    enabled as Boolean
    statistics as Dictionary[String, Integer]

Type called "DeliveryReceipt":
    receipt_id as String
    message_id as String
    sender_id as String
    receiver_id as String
    delivery_time as Float
    delivery_status as String
    error_details as Optional[String]
    retry_count as Integer
    round_trip_time as Float

Type called "MessageMetrics":
    total_sent as Integer
    total_received as Integer
    total_failed as Integer
    average_latency as Float
    peak_queue_size as Integer
    current_queue_size as Integer
    error_rate as Float
    throughput as Float
    last_updated as Float

Note: Core Message Creation and Management
Process called "create_message" that takes sender_id as String and receiver_id as String and message_type as MessageType and payload as Any returns AgentMessage:
    Let message_id be generate_unique_id()
    Let current_time be get_current_timestamp()
    
    Let metadata be dictionary containing
        "creation_time" as current_time
        "last_modified" as current_time
        "expiration_time" as none
        "retry_count" as 0
        "max_retries" as 3
        "delivery_attempts" as list containing nothing
        "routing_history" as list containing nothing
        "compression_type" as none
        "checksum" as ""
        "content_length" as calculate_payload_size(payload)
        "encoding" as "utf-8"
    
    Return dictionary containing
        "message_id" as message_id
        "conversation_id" as none
        "parent_message_id" as none
        "sender_id" as sender_id
        "receiver_id" as receiver_id
        "message_type" as message_type
        "priority" as "normal"
        "delivery_guarantee" as "best_effort"
        "payload" as payload
        "headers" as dictionary containing
        "metadata" as metadata
        "signature" as none
        "encryption_info" as none
        "status" as "created"
        "error_info" as none

Process called "create_request_message" that takes sender_id as String and receiver_id as String and request_data as Any returns AgentMessage:
    Let message be create_message(sender_id, receiver_id, "request", request_data)
    Set message with "delivery_guarantee" as "at_least_once"
    Set message with "priority" as "high"
    Return message

Process called "create_response_message" that takes original_message as AgentMessage and response_data as Any returns AgentMessage:
    Let response be create_message(original_message get "receiver_id", original_message get "sender_id", "response", response_data)
    Set response with "conversation_id" as original_message get "conversation_id"
    Set response with "parent_message_id" as original_message get "message_id"
    Set response with "priority" as original_message get "priority"
    Set response with "delivery_guarantee" as original_message get "delivery_guarantee"
    Return response

Process called "create_broadcast_message" that takes sender_id as String and payload as Any returns AgentMessage:
    Let message be create_message(sender_id, "*", "broadcast", payload)
    Set message with "priority" as "normal"
    Set message with "delivery_guarantee" as "best_effort"
    Return message

Process called "set_message_priority" that takes message as AgentMessage and priority as MessagePriority returns AgentMessage:
    Set message with "priority" as priority
    Update message metadata with "last_modified" as get_current_timestamp()
    Return message

Process called "set_delivery_guarantee" that takes message as AgentMessage and guarantee as DeliveryGuarantee returns AgentMessage:
    Set message with "delivery_guarantee" as guarantee
    Update message metadata with "last_modified" as get_current_timestamp()
    
    If guarantee is equal to "exactly_once":
        Set message metadata with "max_retries" as 5
    Otherwise if guarantee is equal to "reliable":
        Set message metadata with "max_retries" as 3
    Otherwise:
        Set message metadata with "max_retries" as 1
    
    Return message

Process called "set_message_expiration" that takes message as AgentMessage and ttl_seconds as Float returns AgentMessage:
    Let current_time be get_current_timestamp()
    Let expiration_time be current_time plus ttl_seconds
    
    Set message metadata with "expiration_time" as expiration_time
    Update message metadata with "last_modified" as current_time
    Return message

Note: Message Queue Operations
Process called "create_message_queue" that takes agent_id as String and max_size as Integer returns MessageQueue:
    Return dictionary containing
        "queue_id" as generate_unique_id()
        "agent_id" as agent_id
        "messages" as list containing nothing
        "max_size" as max_size
        "current_size" as 0
        "priority_queues" as dictionary containing
            "critical" as list containing nothing
            "high" as list containing nothing
            "normal" as list containing nothing
            "low" as list containing nothing
            "background" as list containing nothing
        "overflow_policy" as "drop_oldest"
        "statistics" as dictionary containing
            "total_enqueued" as 0
            "total_dequeued" as 0
            "total_dropped" as 0
            "peak_size" as 0

Process called "enqueue_message" that takes queue as MessageQueue and message as AgentMessage returns Boolean:
    If is_message_expired(message):
        Update queue statistics with "total_dropped" as queue get "statistics" get "total_dropped" plus 1
        Return false
    
    If queue get "current_size" is greater than or equal to queue get "max_size":
        If queue get "overflow_policy" is equal to "drop_oldest":
            Let dropped be dequeue_oldest_message(queue)
            Update queue statistics with "total_dropped" as queue get "statistics" get "total_dropped" plus 1
        Otherwise if queue get "overflow_policy" is equal to "drop_new":
            Update queue statistics with "total_dropped" as queue get "statistics" get "total_dropped" plus 1
            Return false
    
    Let priority be message get "priority"
    Let priority_queue be queue get "priority_queues" get priority
    Add message to priority_queue
    Add message to queue get "messages"
    
    Set queue with "current_size" as queue get "current_size" plus 1
    Update queue statistics with "total_enqueued" as queue get "statistics" get "total_enqueued" plus 1
    
    If queue get "current_size" is greater than queue get "statistics" get "peak_size":
        Update queue statistics with "peak_size" as queue get "current_size"
    
    Set message with "status" as "queued"
    Return true

Process called "dequeue_message" that takes queue as MessageQueue returns Optional[AgentMessage]:
    Let priority_order be list containing "critical", "high", "normal", "low", "background"
    
    For each priority in priority_order:
        Let priority_queue be queue get "priority_queues" get priority
        If length of priority_queue is greater than 0:
            Let message be first item in priority_queue
            Remove message from priority_queue
            Remove message from queue get "messages"
            
            Set queue with "current_size" as queue get "current_size" minus 1
            Update queue statistics with "total_dequeued" as queue get "statistics" get "total_dequeued" plus 1
            
            Set message with "status" as "routing"
            Return message
    
    Return none

Process called "peek_next_message" that takes queue as MessageQueue returns Optional[AgentMessage]:
    Let priority_order be list containing "critical", "high", "normal", "low", "background"
    
    For each priority in priority_order:
        Let priority_queue be queue get "priority_queues" get priority
        If length of priority_queue is greater than 0:
            Return first item in priority_queue
    
    Return none

Process called "remove_expired_messages" that takes queue as MessageQueue returns Integer:
    Let removed_count be 0
    Let current_messages be queue get "messages"
    Let valid_messages be list containing nothing
    
    For each message in current_messages:
        If is_message_expired(message):
            Set removed_count as removed_count plus 1
            Set message with "status" as "expired"
        Otherwise:
            Add message to valid_messages
    
    Set queue with "messages" as valid_messages
    Set queue with "current_size" as length of valid_messages
    
    Note: Update priority queues
    For each priority in list containing "critical", "high", "normal", "low", "background":
        Let priority_queue be queue get "priority_queues" get priority
        Let valid_priority_messages be list containing nothing
        
        For each message in priority_queue:
            If not is_message_expired(message):
                Add message to valid_priority_messages
        
        Set queue get "priority_queues" with priority as valid_priority_messages
    
    Update queue statistics with "total_dropped" as queue get "statistics" get "total_dropped" plus removed_count
    Return removed_count

Note: Message Filtering and Processing
Process called "create_message_filter" that takes name as String and conditions as List[Dictionary] and action as String returns MessageFilter:
    Return dictionary containing
        "filter_id" as generate_unique_id()
        "name" as name
        "conditions" as conditions
        "action" as action
        "priority" as 100
        "enabled" as true
        "statistics" as dictionary containing
            "messages_processed" as 0
            "messages_matched" as 0
            "messages_filtered" as 0

Process called "apply_message_filter" that takes filter as MessageFilter and message as AgentMessage returns Boolean:
    If not filter get "enabled":
        Return false
    
    Update filter statistics with "messages_processed" as filter get "statistics" get "messages_processed" plus 1
    
    Let conditions be filter get "conditions"
    Let all_conditions_met be true
    
    For each condition in conditions:
        If not evaluate_filter_condition(condition, message):
            Set all_conditions_met as false
            Break from loop
    
    If all_conditions_met:
        Update filter statistics with "messages_matched" as filter get "statistics" get "messages_matched" plus 1
        
        Let action be filter get "action"
        If action is equal to "drop":
            Update filter statistics with "messages_filtered" as filter get "statistics" get "messages_filtered" plus 1
            Return true
        Otherwise if action is equal to "priority_boost":
            Set message with "priority" as "high"
        Otherwise if action is equal to "delay":
            Let delay_time be condition get "delay_seconds"
            Delay message processing by delay_time seconds
    
    Return false

Process called "evaluate_filter_condition" that takes condition as Dictionary and message as AgentMessage returns Boolean:
    Let field be condition get "field"
    Let operator be condition get "operator"
    Let expected_value be condition get "value"
    
    Let actual_value be get_message_field_value(message, field)
    
    If operator is equal to "equals":
        Return actual_value is equal to expected_value
    Otherwise if operator is equal to "contains":
        Return actual_value contains expected_value
    Otherwise if operator is equal to "starts_with":
        Return actual_value starts with expected_value
    Otherwise if operator is equal to "greater_than":
        Return actual_value is greater than expected_value
    Otherwise if operator is equal to "less_than":
        Return actual_value is less than expected_value
    Otherwise if operator is equal to "regex_match":
        Return regex_matches(actual_value, expected_value)
    
    Return false

Note: Message Delivery and Acknowledgment
Process called "send_message" that takes message as AgentMessage returns DeliveryReceipt:
    Let start_time be get_current_timestamp()
    Set message with "status" as "transmitted"
    
    Let delivery_attempt be dictionary containing
        "attempt_number" as message get "metadata" get "retry_count" plus 1
        "timestamp" as start_time
        "status" as "attempting"
    
    Add delivery_attempt to message get "metadata" get "delivery_attempts"
    Update message metadata with "retry_count" as message get "metadata" get "retry_count" plus 1
    
    Try:
        Let routing_result be route_message_to_destination(message)
        If routing_result get "success":
            Set message with "status" as "delivered"
            Set delivery_attempt with "status" as "success"
            
            Let receipt be dictionary containing
                "receipt_id" as generate_unique_id()
                "message_id" as message get "message_id"
                "sender_id" as message get "sender_id"
                "receiver_id" as message get "receiver_id"
                "delivery_time" as get_current_timestamp()
                "delivery_status" as "delivered"
                "error_details" as none
                "retry_count" as message get "metadata" get "retry_count"
                "round_trip_time" as get_current_timestamp() minus start_time
            
            Return receipt
        Otherwise:
            Set message with "status" as "failed"
            Set delivery_attempt with "status" as "failed"
            Set delivery_attempt with "error" as routing_result get "error"
            
            Return create_error_receipt(message, routing_result get "error")
    
    Catch error:
        Set message with "status" as "failed"
        Set delivery_attempt with "status" as "error"
        Set delivery_attempt with "error" as error get "message"
        
        Return create_error_receipt(message, error get "message")

Process called "acknowledge_message" that takes message_id as String and receiver_id as String returns Boolean:
    Let ack_message be create_message(receiver_id, message_id, "acknowledgment", dictionary containing "acknowledged" as true)
    Let receipt be send_message(ack_message)
    Return receipt get "delivery_status" is equal to "delivered"

Process called "retry_failed_message" that takes message as AgentMessage returns Boolean:
    Let max_retries be message get "metadata" get "max_retries"
    Let current_retries be message get "metadata" get "retry_count"
    
    If current_retries is greater than or equal to max_retries:
        Set message with "status" as "failed"
        Return false
    
    Let delay_seconds be calculate_retry_delay(current_retries)
    Wait for delay_seconds seconds
    
    Set message with "status" as "retrying"
    Let receipt be send_message(message)
    Return receipt get "delivery_status" is equal to "delivered"

Note: Message Validation and Utilities
Process called "validate_message" that takes message as AgentMessage returns Dictionary:
    Let errors be list containing nothing
    
    If message get "message_id" is empty:
        Add "Message ID is required" to errors
    
    If message get "sender_id" is empty:
        Add "Sender ID is required" to errors
    
    If message get "receiver_id" is empty:
        Add "Receiver ID is required" to errors
    
    If message get "payload" is none:
        Add "Message payload cannot be null" to errors
    
    If is_message_expired(message):
        Add "Message has expired" to errors
    
    Return dictionary containing
        "is_valid" as length of errors is equal to 0
        "errors" as errors
        "validation_time" as get_current_timestamp()

Process called "is_message_expired" that takes message as AgentMessage returns Boolean:
    Let expiration_time be message get "metadata" get "expiration_time"
    If expiration_time is none:
        Return false
    
    Let current_time be get_current_timestamp()
    Return current_time is greater than expiration_time

Process called "calculate_message_checksum" that takes message as AgentMessage returns String:
    Let content be serialize_message_content(message)
    Return compute_sha256_hash(content)

Process called "compress_message_payload" that takes message as AgentMessage returns AgentMessage:
    Let original_payload be message get "payload"
    Let compressed_payload be compress_data(original_payload)
    
    Set message with "payload" as compressed_payload
    Set message metadata with "compression_type" as "gzip"
    Set message metadata with "content_length" as calculate_payload_size(compressed_payload)
    Update message metadata with "last_modified" as get_current_timestamp()
    
    Return message

Process called "decompress_message_payload" that takes message as AgentMessage returns AgentMessage:
    Let compression_type be message get "metadata" get "compression_type"
    If compression_type is none:
        Return message
    
    Let compressed_payload be message get "payload"
    Let decompressed_payload be decompress_data(compressed_payload, compression_type)
    
    Set message with "payload" as decompressed_payload
    Set message metadata with "compression_type" as none
    Set message metadata with "content_length" as calculate_payload_size(decompressed_payload)
    Update message metadata with "last_modified" as get_current_timestamp()
    
    Return message

Note: Performance Monitoring and Metrics
Process called "create_message_metrics" returns MessageMetrics:
    Return dictionary containing
        "total_sent" as 0
        "total_received" as 0
        "total_failed" as 0
        "average_latency" as 0.0
        "peak_queue_size" as 0
        "current_queue_size" as 0
        "error_rate" as 0.0
        "throughput" as 0.0
        "last_updated" as get_current_timestamp()

Process called "update_message_metrics" that takes metrics as MessageMetrics and operation as String and value as Float returns MessageMetrics:
    Let current_time be get_current_timestamp()
    
    If operation is equal to "message_sent":
        Set metrics with "total_sent" as metrics get "total_sent" plus 1
    Otherwise if operation is equal to "message_received":
        Set metrics with "total_received" as metrics get "total_received" plus 1
    Otherwise if operation is equal to "message_failed":
        Set metrics with "total_failed" as metrics get "total_failed" plus 1
    Otherwise if operation is equal to "latency_update":
        Let current_avg be metrics get "average_latency"
        Let total_messages be metrics get "total_sent" plus metrics get "total_received"
        Set metrics with "average_latency" as (current_avg multiplied by (total_messages minus 1) plus value) divided by total_messages
    Otherwise if operation is equal to "queue_size_update":
        Set metrics with "current_queue_size" as value
        If value is greater than metrics get "peak_queue_size":
            Set metrics with "peak_queue_size" as value
    
    Let total_operations be metrics get "total_sent" plus metrics get "total_received"
    If total_operations is greater than 0:
        Set metrics with "error_rate" as metrics get "total_failed" divided by total_operations
    
    Set metrics with "last_updated" as current_time
    Return metrics

Note: Platform-specific stub implementations
Process called "generate_unique_id" returns String:
    Return "msg-" plus string_from_integer(get_current_timestamp_ms())

Process called "get_current_timestamp" returns Float:
    Return 1640995200.0

Process called "get_current_timestamp_ms" returns Integer:
    Return 1640995200000

Process called "calculate_payload_size" that takes payload as Any returns Integer:
    Return 1024

Process called "serialize_message_content" that takes message as AgentMessage returns String:
    Return "serialized_content"

Process called "compute_sha256_hash" that takes content as String returns String:
    Return "sha256_hash"

Process called "compress_data" that takes data as Any returns Any:
    Return data

Process called "decompress_data" that takes data as Any and compression_type as String returns Any:
    Return data

Process called "calculate_retry_delay" that takes retry_count as Integer returns Float:
    Return 2.0 multiplied by retry_count

Process called "route_message_to_destination" that takes message as AgentMessage returns Dictionary:
    Return dictionary containing
        "success" as true
        "error" as none

Process called "get_message_field_value" that takes message as AgentMessage and field as String returns Any:
    If field is equal to "sender_id":
        Return message get "sender_id"
    Otherwise if field is equal to "receiver_id":
        Return message get "receiver_id"
    Otherwise if field is equal to "message_type":
        Return message get "message_type"
    Otherwise if field is equal to "priority":
        Return message get "priority"
    Return none

Process called "regex_matches" that takes text as String and pattern as String returns Boolean:
    Return false

Process called "create_error_receipt" that takes message as AgentMessage and error_message as String returns DeliveryReceipt:
    Return dictionary containing
        "receipt_id" as generate_unique_id()
        "message_id" as message get "message_id"
        "sender_id" as message get "sender_id"
        "receiver_id" as message get "receiver_id"
        "delivery_time" as get_current_timestamp()
        "delivery_status" as "failed"
        "error_details" as error_message
        "retry_count" as message get "metadata" get "retry_count"
        "round_trip_time" as 0.0

Process called "dequeue_oldest_message" that takes queue as MessageQueue returns Optional[AgentMessage]:
    If queue get "current_size" is equal to 0:
        Return none
    
    Let oldest_message be first item in queue get "messages"
    Remove oldest_message from queue get "messages"
    Set queue with "current_size" as queue get "current_size" minus 1
    Return oldest_message