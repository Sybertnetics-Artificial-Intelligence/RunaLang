Process called "calculate_federation_resource_utilization" that takes federation as Federation returns Dictionary:
    Let total_cpu_allocated be 0.0
    Let total_memory_allocated be 0.0
    Let total_cpu_available be 0.0
    Let total_memory_available be 0.0
    
    Let member_nodes be federation get "member_nodes"
    For each node_id in member_nodes:
        Let node be get_federation_node(node_id, federation)
        If node is not none:
            Let resource_profile be node get "resource_profile"
            Set total_cpu_available as total_cpu_available plus resource_profile get "cpu_cores"
            Set total_memory_available as total_memory_available plus resource_profile get "memory_gb"
            Set total_cpu_allocated as total_cpu_allocated plus resource_profile get "cpu_allocated"
            Set total_memory_allocated as total_memory_allocated plus resource_profile get "memory_allocated"
    
    Let cpu_utilization be 0.0
    Let memory_utilization be 0.0
    
    If total_cpu_available is greater than 0.0:
        Set cpu_utilization as total_cpu_allocated divided by total_cpu_available
    
    If total_memory_available is greater than 0.0:
        Set memory_utilization as total_memory_allocated divided by total_memory_available
    
    Return dictionary containing
        "cpu" as cpu_utilization
        "memory" as memory_utilization
        "storage" as calculate_storage_utilization(federation)
        "network" as calculate_network_utilization(federation)

Process called "calculate_consensus_efficiency" that takes federation as Federation returns Float:
    Let recent_proposals be get_recent_consensus_proposals(federation, 30.0)
    
    If length of recent_proposals is equal to 0:
        Return 1.0
    
    Let total_consensus_time be 0.0
    Let successful_consensus_count be 0
    
    For each proposal in recent_proposals:
        If proposal get "consensus_reached":
            Set successful_consensus_count as successful_consensus_count plus 1
            Let consensus_time be proposal get "completion_time" minus proposal get "created_time"
            Set total_consensus_time as total_consensus_time plus consensus_time
    
    Let success_rate be successful_consensus_count divided by length of recent_proposals
    
    Let average_consensus_time be 0.0
    If successful_consensus_count is greater than 0:
        Set average_consensus_time as total_consensus_time divided by successful_consensus_count
    
    Let time_efficiency be 1.0
    If average_consensus_time is greater than 0.0:
        Let ideal_consensus_time be 3600.0
        Set time_efficiency as ideal_consensus_time divided by (average_consensus_time plus ideal_consensus_time)
    
    Return success_rate multiplied by 0.7 plus time_efficiency multiplied by 0.3

