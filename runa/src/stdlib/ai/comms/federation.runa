Process called "filter_recent_interactions" that takes history as List[Dictionary] and days as Float returns List[Dictionary]:
    Let cutoff_time be get_current_timestamp() minus (days multiplied by 86400.0)
    Let recent_interactions be list containing nothing
    
    For each interaction in history:
        If interaction get "timestamp" is greater than or equal to cutoff_time:
            Add interaction to recent_interactions
    
    Return recent_interactions

Process called "calculate_interaction_success_rate" that takes interactions as List[Dictionary] returns Float:
    If length of interactions is equal to 0:
        Return 0.5
    
    Let successful_interactions be 0
    For each interaction in interactions:
        If interaction get "outcome" is equal to "success":
            Set successful_interactions as successful_interactions plus 1
    
    Return successful_interactions divided by length of interactions

Process called "calculate_node_reliability" that takes node as FederationNode returns Float:
    Let uptime_factor be calculate_node_uptime_factor(node)
    Let response_factor be calculate_node_response_factor(node)
    Let consistency_factor be calculate_node_consistency_factor(node)
    
    Let reliability_score be (
        uptime_factor multiplied by 0.4 plus
        response_factor multiplied by 0.35 plus
        consistency_factor multiplied by 0.25
    )
    
    Return minimum_float(1.0, maximum_float(0.0, reliability_score))

Process called "calculate_contribution_impact" that takes node as FederationNode and federation as Federation returns Float:
    Let resource_contribution be calculate_resource_contribution_score(node, federation)
    Let service_contribution be calculate_service_contribution_score(node, federation)
    Let governance_participation be calculate_governance_participation_score(node, federation)
    
    Let contribution_impact be (
        resource_contribution multiplied by 0.4 plus
        service_contribution multiplied by 0.4 plus
        governance_participation multiplied by 0.2
    )
    
    Return minimum_float(1.0, maximum_float(0.0, contribution_impact))

