Process called "calculate_service_match_score" that takes service as FederationService and criteria as Dictionary returns Float:
    Let match_score be 0.0
    Let total_criteria be 0
    
    If criteria contains "service_type":
        Set total_criteria as total_criteria plus 1
        If service get "service_type" is equal to criteria get "service_type":
            Set match_score as match_score plus 1.0
    
    If criteria contains "required_capabilities":
        Set total_criteria as total_criteria plus 1
        Let capability_match be calculate_capability_overlap(service get "capabilities", criteria get "required_capabilities")
        Set match_score as match_score plus capability_match
    
    If criteria contains "min_availability":
        Set total_criteria as total_criteria plus 1
        If service get "availability" is greater than or equal to criteria get "min_availability":
            Set match_score as match_score plus 1.0
        Otherwise:
            Set match_score as match_score plus (service get "availability" divided by criteria get "min_availability")
    
    If criteria contains "max_response_time":
        Set total_criteria as total_criteria plus 1
        Let service_response_time be service get "performance_metrics" get "response_time_ms"
        If service_response_time is less than or equal to criteria get "max_response_time":
            Set match_score as match_score plus 1.0
        Otherwise:
            Set match_score as match_score plus (criteria get "max_response_time" divided by service_response_time)
    
    If criteria contains "max_cost":
        Set total_criteria as total_criteria plus 1
        Let service_cost be estimate_service_cost(service, criteria)
        If service_cost is less than or equal to criteria get "max_cost":
            Set match_score as match_score plus 1.0
        Otherwise:
            Set match_score as match_score plus (criteria get "max_cost" divided by service_cost)
    
    If total_criteria is equal to 0:
        Return 0.0
    
    Return match_score divided by total_criteria

