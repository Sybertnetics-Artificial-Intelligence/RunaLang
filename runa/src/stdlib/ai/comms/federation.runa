    resource_requirements as Dictionary[String, Float]
    availability as Float
    performance_metrics as Dictionary[String, Float]
    access_policies as List[Dictionary]
    cost_model as Dictionary[String, Any]
    discovery_metadata as Dictionary[String, Any]

