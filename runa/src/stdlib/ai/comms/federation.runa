Process called "calculate_required_votes" that takes federation as Federation and change_type as String returns Integer:
    Let total_members be length of federation get "member_nodes"
    Let governance_model be federation get "governance_model"
    
    If governance_model is equal to "unanimous":
        Return total_members
    Otherwise if governance_model is equal to "majority":
        Return (total_members divided by 2) plus 1
    Otherwise if governance_model is equal to "supermajority":
        Return ceiling((total_members multiplied by 2) divided by 3)
    Otherwise if governance_model is equal to "quorum":
        If change_type is equal to "critical":
            Return ceiling((total_members multiplied by 3) divided by 4)
        Otherwise:
            Return ceiling(total_members divided by 2)
    Otherwise:
        Return maximum(1, total_members divided by 3)

Process called "calculate_voting_weight" that takes voter_node as String and federation as Federation returns Float:
    Let node be get_federation_node(voter_node, federation)
    If node is none:
        Return 0.0
    
    Let base_weight be 1.0
    Let trust_factor be node get "trust_score"
    Let contribution_factor be minimum_float(2.0, node get "contribution_score" divided by 50.0)
    Let tenure_factor be calculate_tenure_factor(node)
    
    Let weighted_vote be base_weight multiplied by trust_factor multiplied by contribution_factor multiplied by tenure_factor
    
    Return minimum_float(3.0, maximum_float(0.1, weighted_vote))

Process called "calculate_vote_tally" that takes proposal as ConsensusProposal returns Dictionary:
    Let current_votes be proposal get "current_votes"
    Let federation be get_federation_by_id(proposal get "federation_id")
    
    Let total_weight_for be 0.0
    Let total_weight_against be 0.0
    Let total_weight_abstain be 0.0
    Let vote_count be 0
    
    For each voter_node and vote_decision in current_votes:
        Let vote_weight be calculate_voting_weight(voter_node, federation)
        Set vote_count as vote_count plus 1
        
        If vote_decision is equal to "for":
            Set total_weight_for as total_weight_for plus vote_weight
        Otherwise if vote_decision is equal to "against":
            Set total_weight_against as total_weight_against plus vote_weight
        Otherwise if vote_decision is equal to "abstain":
            Set total_weight_abstain as total_weight_abstain plus vote_weight
    
    Let total_weight be total_weight_for plus total_weight_against plus total_weight_abstain
    Let required_votes be proposal get "required_votes"
    
    Let result be "pending"
    If total_weight_for is greater than or equal to required_votes:
        Set result as "approved"
    Otherwise if total_weight_against is greater than or equal to required_votes:
        Set result as "rejected"
    Otherwise if get_current_timestamp() is greater than proposal get "voting_deadline":
        Set result as "expired"
    
    Return dictionary containing
        "total_votes" as vote_count
        "total_weight_for" as total_weight_for
        "total_weight_against" as total_weight_against
        "total_weight_abstain" as total_weight_abstain
        "required_votes" as required_votes
        "result" as result
        "participation_rate" as total_weight divided by calculate_total_eligible_voting_weight(federation)

