Import "../../builtins/functions.runa"
Import "../../os/os.runa"
Import "../../json/json.runa"

Note:
Runa Standard Library: AI Agent Communication - Configuration Module
Provides centralized configuration management for the agent communication framework.
:End Note

Type called "CommsConfig":
    messaging as Dictionary[String, Any]
    protocols as Dictionary[String, Any]
    encryption as Dictionary[String, Any]
    routing as Dictionary[String, Any]
    broadcast as Dictionary[String, Any]
    multicast as Dictionary[String, Any]
    federation as Dictionary[String, Any]
    channels as Dictionary[String, Any]

Process called "get_comms_config" returns CommsConfig:
    Note: In a real implementation, this would load from a file.
    Return _get_default_comms_config()

Process called "_get_default_comms_config" returns CommsConfig:
    Return CommsConfig with:
        messaging as Dictionary with:
            "default_max_retries" as 3
            "retry_delay" as Dictionary with:
                "base_seconds" as 1.0
                "max_seconds" as 300.0
            "queue" as Dictionary with:
                "default_max_size" as 1000
                "overflow_policy" as "drop_oldest"
        protocols as Dictionary with:
            "default_max_message_size_bytes" as 1048576
            "timeouts" as Dictionary with:
                "connection_seconds" as 30.0
                "message_seconds" as 10.0
                "heartbeat_seconds" as 60.0
                "negotiation_seconds" as 15.0
            "retry_policies" as Dictionary with:
                "connection" as Dictionary with:
                    "max_attempts" as 3
                    "backoff_strategy" as "exponential"
                    "base_delay_seconds" as 1.0
                "message" as Dictionary with:
                    "max_attempts" as 5
                    "backoff_strategy" as "linear"
                    "base_delay_seconds" as 0.5
            "flow_control" as Dictionary with:
                "sliding_window" as Dictionary with:
                    "window_size" as 64
                    "congestion_window" as 8
                    "slow_start_threshold" as 32
                "credit_based" as Dictionary with:
                    "max_credits" as 100
                    "credit_refresh_rate_hz" as 10.0
                "rate_limiting" as Dictionary with:
                    "messages_per_second" as 100.0
                    "bytes_per_second" as 1048576.0
            "qos" as Dictionary with:
                "scoring_weights" as Dictionary with:
                    "latency" as 0.4
                    "throughput" as 0.35
                    "error_rate" as 0.25
        encryption as Dictionary with:
            "default_algorithm" as "aes_256_gcm"
            "key_exchange_algorithm" as "x25519"
            "signature_algorithm" as "ed25519"
            "key_rotation_interval_hours" as 24
            "key_derivation" as Dictionary with:
                "pbkdf2_iterations" as 100000
                "salt_length" as 32
            "security_level" as "high"
        routing as Dictionary with:
            "default_strategy" as "shortest_path"
            "cost_weights" as Dictionary with:
                "latency" as 0.4
                "throughput" as 0.3
                "reliability" as 0.2
                "cost" as 0.1
            "table_refresh_interval_seconds" as 300
            "max_hops" as 10
        broadcast as Dictionary with:
            "max_broadcast_radius" as 5
            "duplicate_detection_window_seconds" as 60
            "flood_control" as Dictionary with:
                "max_broadcasts_per_second" as 10
                "burst_size" as 50
        multicast as Dictionary with:
            "default_ttl" as 64
            "group_management_interval_seconds" as 30
            "heartbeat_interval_seconds" as 15
        federation as Dictionary with:
            "consensus_algorithm" as "raft"
            "election_timeout_ms" as 5000
            "heartbeat_interval_ms" as 1000
            "trust_threshold" as 0.8
            "reputation_decay_rate" as 0.95
        channels as Dictionary with:
            "default_max_queue_size" as 1000
            "reconnect_attempts" as 3
            "heartbeat_interval_seconds" as 30.0
            "inactivity_threshold_seconds" as 300.0
