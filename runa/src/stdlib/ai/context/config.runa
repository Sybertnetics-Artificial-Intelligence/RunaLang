Process called "validate_context_config" that takes config as ContextConfig returns Dictionary[String, Any]:
    Let validation_result be Dictionary with:
        "valid" as true
        "errors" as list containing
        "warnings" as list containing
    
    Note: Validate state management configuration
    Let state_config be config with field "state_management"
    If not state_config contains "paradigm":
        Add "State management paradigm not specified" to validation_result["errors"]
        Set validation_result["valid"] to false
    
    If not state_config contains "storage_backends":
        Add "Storage backends not specified" to validation_result["errors"]
        Set validation_result["valid"] to false
    
    Note: Validate environment sensing configuration
    Let sensing_config be config with field "environment_sensing"
    If not sensing_config contains "sensor_types":
        Add "Sensor types not specified" to validation_result["errors"]
        Set validation_result["valid"] to false
    
    Note: Validate situation assessment configuration
    Let assessment_config be config with field "situation_assessment"
    If not assessment_config contains "threat_detection":
        Add "Threat detection configuration not specified" to validation_result["errors"]
        Set validation_result["valid"] to false
    
    Note: Validate context window configuration
    Let window_config be config with field "context_window"
    If not window_config contains "window_sizes":
        Add "Context window sizes not specified" to validation_result["errors"]
        Set validation_result["valid"] to false
    
    Note: Validate constraint system configuration
    Let constraint_config be config with field "constraint_system"
    If not constraint_config contains "solving_algorithms":
        Add "Constraint solving algorithms not specified" to validation_result["errors"]
        Set validation_result["valid"] to false
    
    Note: Validate adaptation configuration
    Let adaptation_config be config with field "adaptation"
    If not adaptation_config contains "learning_algorithms":
        Add "Learning algorithms not specified" to validation_result["errors"]
        Set validation_result["valid"] to false
    
    Return validation_result

Process called "update_context_config" that takes updates as Dictionary[String, Any] returns Boolean:
    Acquire _context_config_lock
    
    Try:
        Set _context_config_data to merge_configs with base as _context_config_data and overrides as updates
        
        Note: Validate updated configuration
        Let updated_config be _deserialize_context_config with data as _context_config_data
        Let validation_result be validate_context_config with config as updated_config
        
        If validation_result["valid"] is not equal to true:
            Release _context_config_lock
            Return false
        
        Note: Save updated configuration to file
        Let serialized_config be json_serialize with data as _context_config_data
        Let write_success be write_file_sync with path as _CONTEXT_CONFIG_FILE_PATH and content as serialized_config
        
        Release _context_config_lock
        Return write_success
    Catch error:
        Release _context_config_lock
        Return false

Process called "reload_context_config" returns Boolean:
    Acquire _context_config_lock
    
    Set _context_config_data to Dictionary[String, Any] containing
    Let reload_success be _load_context_config_from_file()
    
    Release _context_config_lock
    Return reload_success

Process called "get_performance_settings" returns Dictionary[String, Any]:
    Let config be get_context_config()
    Return config with field "performance"

Process called "get_security_settings" returns Dictionary[String, Any]:
    Let config be get_context_config()
    Return config with field "security"

Process called "get_monitoring_settings" returns Dictionary[String, Any]:
    Let config be get_context_config()
    Return config with field "monitoring"

Process called "get_global_settings" returns Dictionary[String, Any]:
    Let config be get_context_config()
    Return config with field "global_settings"

Process called "apply_environment_overrides" that takes config_key as String returns Any:
    Note: Check for environment variable overrides
    Let env_var_name be "RUNA_CONTEXT_" with string_to_upper with text as string_replace with text as config_key and pattern as "." and replacement as "_"
    Let env_value be get_environment_variable with name as env_var_name
    
    If env_value is not equal to null:
        Note: Try to parse as JSON first, then fall back to string
        Try:
            Return json_deserialize with json as env_value
        Catch error:
            Return env_value
    
    Return get_context_config_value with key as config_key and default as null

Process called "create_subsystem_config" that takes subsystem_name as String returns Dictionary[String, Any]:
    Let base_config be get_context_config()
    
    If subsystem_name is equal to "state_management":
        Return base_config["state_management"]
    
    If subsystem_name is equal to "environment_sensing":
        Return base_config["environment_sensing"]
    
    If subsystem_name is equal to "situation_assessment":
        Return base_config["situation_assessment"]
    
    If subsystem_name is equal to "context_window":
        Return base_config["context_window"]
    
    If subsystem_name is equal to "constraint_system":
        Return base_config["constraint_system"]
    
    If subsystem_name is equal to "adaptation":
        Return base_config["adaptation"]
    
    Note: Return global settings for unknown subsystems
    Return base_config["global_settings"]

Process called "export_context_config" that takes format as String returns String:
    Let config be get_context_config()
    
    If format is equal to "json":
        Return json_serialize with data as config
    
    If format is equal to "yaml":
        Note: In a production system, this would use a YAML serializer
        Return json_serialize with data as config
    
    Note: Default to JSON format
    Return json_serialize with data as config

Process called "import_context_config" that takes config_data as String and format as String returns Boolean:
    Try:
        Let parsed_config be Dictionary[String, Any] containing
        
        If format is equal to "json":
            Set parsed_config to json_deserialize with json as config_data
        Otherwise:
            Note: For other formats, assume JSON for now
            Set parsed_config to json_deserialize with json as config_data
        
        Let temp_config be _deserialize_context_config with data as parsed_config
        Let validation_result be validate_context_config with config as temp_config
        
        If validation_result["valid"] is not equal to true:
            Return false
        
        Return update_context_config with updates as parsed_config
    Catch error:
        Return false