Process called "merge_configs" that takes base as Dictionary[String, Any] and overrides as Dictionary[String, Any] returns Dictionary[String, Any]:
    Let merged be base
    For each key and value in overrides:
        If merged contains key and type_of with value as merged[key] is equal to "Dictionary" and type_of with value as value is equal to "Dictionary":
            Set merged[key] to merge_configs with base as merged[key] and overrides as value
        Otherwise:
            Set merged[key] to value
    Return merged

Process called "_deserialize_context_config" that takes data as Dictionary[String, Any] returns ContextConfig:
    Return ContextConfig with:
        state_management as data["state_management"]
        environment_sensing as data["environment_sensing"]
        situation_assessment as data["situation_assessment"]
        context_window as data["context_window"]
        constraint_system as data["constraint_system"]
        adaptation as data["adaptation"]
        global_settings as data["global_settings"]
        performance as data["performance"]
        security as data["security"]
        monitoring as data["monitoring"]

Process called "get_state_management_config" returns StateManagementConfig:
    Let config be get_context_config()
    Let state_config be config with field "state_management"
    
    Return StateManagementConfig with:
        paradigm as state_config["paradigm"]
        storage_backends as state_config["storage_backends"]
        consensus_algorithm as state_config["consensus_algorithm"]
        persistence_policy as state_config["persistence_policy"]
        validation_rules as state_config["validation_rules"]
        consistency_model as state_config["consistency_model"]
        synchronization_strategy as state_config["synchronization_strategy"]
        snapshot_settings as state_config["snapshot_settings"]
        temporal_settings as state_config["temporal_settings"]
        memory_management as state_config["memory_management"]

