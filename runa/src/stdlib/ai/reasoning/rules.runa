Note: Advanced Rule-Based Reasoning System for AI Agents
Note: Implements production-grade rule engines, forward/backward chaining, 
Note: conflict resolution, rule learning, and meta-reasoning capabilities

Note: Core rule system types
Type called "Rule":
    rule id as String
    condition as LogicalExpression  
    conclusion as LogicalExpression
    confidence as Float
    priority as Integer
    source as String
    metadata as Dictionary
    activation count as Integer
    last fired as String

Type called "LogicalExpression":
    expression type as String  # "atomic", "compound", "quantified"
    predicate as String
    arguments as List[String]
    operator as String  # "and", "or", "not", "implies", "iff"
    subexpressions as List[LogicalExpression]
    quantifier as String  # "forall", "exists", "none"
    variables as List[String]
    truth value as Float

Type called "RuleSet":
    rules as List[Rule]
    rule index as Dictionary  # Fast lookup by predicate/pattern
    dependency graph as Dictionary
    conflict groups as List[List[String]]
    rule statistics as Dictionary
    metadata as Dictionary

Type called "WorkingMemory":
    facts as List[LogicalExpression]
    fact index as Dictionary
    derived facts as List[LogicalExpression]
    fact sources as Dictionary  # Track derivation chains
    truth values as Dictionary
    uncertainty measures as Dictionary
    timestamp as String

Type called "RuleEngine":
    rule set as RuleSet
    working memory as WorkingMemory
    inference strategy as String  # "forward", "backward", "hybrid"
    conflict resolution as String  # "priority", "specificity", "recent"
    max iterations as Integer
    explanation mode as Boolean
    performance metrics as Dictionary
    rule learning enabled as Boolean

Type called "ConflictSet":
    conflicting rules as List[Rule]
    resolution strategy as String
    priority scores as Dictionary
    specificity scores as Dictionary
    recency scores as Dictionary
    combined scores as Dictionary

Type called "RuleTrace":
    fired rules as List[String]
    derived facts as List[LogicalExpression]
    conflict resolutions as List[Dictionary]
    inference path as List[String]
    explanation as String
    performance data as Dictionary

Type called "RuleLearner":
    learning algorithm as String  # "induction", "abduction", "association"
    confidence threshold as Float
    support threshold as Float
    example database as List[Dictionary]
    learned rules as List[Rule]
    validation metrics as Dictionary

Note: Advanced rule pattern matching
Process called "match_rule_conditions" that takes rule as Rule and working_memory as WorkingMemory and bindings as Dictionary returns List[Dictionary]:
    Let matches be empty list
    Let condition be rule with field condition
    Let fact_index be working_memory with field fact_index
    
    Note: Handle different expression types
    If condition with field expression_type is equal to "atomic":
        Let predicate_facts be fact_index with key (condition with field predicate) or empty list
        For each fact in predicate_facts:
            Let binding_result be create_atomic_binding with fact and condition and bindings
            If binding_result is not equal to null:
                Add binding_result to matches
    
    If condition with field expression_type is equal to "compound":
        Let compound_matches be match_compound_expression with condition and working_memory and bindings
        Add all compound_matches to matches
    
    If condition with field expression_type is equal to "quantified":
        Let quantified_matches be match_quantified_expression with condition and working_memory and bindings
        Add all quantified_matches to matches
    
    Return matches

Process called "create_atomic_binding" that takes fact as LogicalExpression and condition as LogicalExpression and existing_bindings as Dictionary returns Dictionary:
    Let bindings be copy of existing_bindings
    Let fact_args be fact with field arguments
    Let condition_args be condition with field arguments
    
    Note: Check argument count compatibility
    If length of fact_args is not equal to length of condition_args:
        Return null
    
    Note: Attempt to unify arguments
    For index from 0 to length of fact_args minus 1:
        Let fact_arg be fact_args with index index
        Let condition_arg be condition_args with index index
        
        If condition_arg starts with "?":  Note: Variable
            Let var_name be condition_arg
            If bindings contains key var_name:
                Let existing_value be bindings with key var_name
                If existing_value is not equal to fact_arg:
                    Return null  Note: Binding conflict
            Otherwise:
                Set bindings with key var_name to fact_arg
        Otherwise:  Note: Constant
            If condition_arg is not equal to fact_arg:
                Return null  Note: Constant mismatch
    
    Return bindings

Process called "match_compound_expression" that takes expression as LogicalExpression and working_memory as WorkingMemory and bindings as Dictionary returns List[Dictionary]:
    Let operator be expression with field operator
    Let subexpressions be expression with field subexpressions
    Let results be empty list
    
    If operator is equal to "and":
        Let and_results be match_conjunction with subexpressions and working_memory and bindings
        Add all and_results to results
    
    If operator is equal to "or":
        Let or_results be match_disjunction with subexpressions and working_memory and bindings
        Add all or_results to results
    
    If operator is equal to "not":
        Let not_results be match_negation with subexpressions and working_memory and bindings
        Add all not_results to results
    
    Return results

Process called "match_conjunction" that takes subexpressions as List[LogicalExpression] and working_memory as WorkingMemory and bindings as Dictionary returns List[Dictionary]:
    If length of subexpressions is equal to 0:
        Return list containing bindings
    
    Let first_expr be subexpressions with index 0
    Let remaining_exprs be subexpressions from index 1 to end
    Let first_matches be match_rule_conditions with create_temp_rule with first_expr and working_memory and bindings
    Let all_results be empty list
    
    For each first_binding in first_matches:
        Let remaining_matches be match_conjunction with remaining_exprs and working_memory and first_binding
        Add all remaining_matches to all_results
    
    Return all_results

Process called "match_disjunction" that takes subexpressions as List[LogicalExpression] and working_memory as WorkingMemory and bindings as Dictionary returns List[Dictionary]:
    Let all_results be empty list
    
    For each expr in subexpressions:
        Let expr_matches be match_rule_conditions with create_temp_rule with expr and working_memory and bindings
        Add all expr_matches to all_results
    
    Return all_results

Process called "match_negation" that takes subexpressions as List[LogicalExpression] and working_memory as WorkingMemory and bindings as Dictionary returns List[Dictionary]:
    If length of subexpressions is not equal to 1:
        Return empty list  # Negation should have exactly one subexpression
    
    Let negated_expr be subexpressions with index 0
    Let positive_matches be match_rule_conditions with create_temp_rule with negated_expr and working_memory and bindings
    
    Note: If no positive matches found, negation succeeds
    If length of positive_matches is equal to 0:
        Return list containing bindings
    
    Return empty list

Note: Forward chaining inference engine
Process called "perform_forward_chaining" that takes engine as RuleEngine and max_iterations as Integer returns RuleTrace:
    Let rule_set be engine with field rule_set
    Let working_memory be engine with field working_memory
    Let trace be create_empty_rule_trace
    Let iteration be 0
    Let rules_fired be true
    
    While rules_fired is equal to true and iteration is less than max_iterations:
        Set rules_fired to false
        Set iteration to iteration plus 1
        
        Let conflict_set be identify_applicable_rules with rule_set and working_memory
        If length of conflict_set is greater than 0:
            Let selected_rule be resolve_conflicts with conflict_set and engine
            Let firing_result be fire_rule with selected_rule and working_memory and trace
            
            If firing_result with field success is equal to true:
                Set rules_fired to true
                Update working_memory with firing_result with field new_facts
                Update trace with selected_rule and firing_result
    
    Set trace with field iterations to iteration
    Calculate performance metrics for trace
    Return trace

Process called "identify_applicable_rules" that takes rule_set as RuleSet and working_memory as WorkingMemory returns List[Rule]:
    Let applicable_rules be empty list
    Let rules be rule_set with field rules
    
    For each rule in rules:
        Let condition_matches be match_rule_conditions with rule and working_memory and empty dictionary
        If length of condition_matches is greater than 0:
            # Check if conclusion would be new
            Let would_add_new_facts be check_novelty with rule and condition_matches and working_memory
            If would_add_new_facts is equal to true:
                Add rule to applicable_rules
    
    Return applicable_rules

Process called "resolve_conflicts" that takes conflict_set as List[Rule] and engine as RuleEngine returns Rule:
    Let resolution_strategy be engine with field conflict_resolution
    Let rule_scores be empty dictionary
    
    # Calculate scores based on strategy
    For each rule in conflict_set:
        Let score be 0.0
        
        If resolution_strategy is equal to "priority":
            Set score to rule with field priority as Float
        
        If resolution_strategy is equal to "specificity":
            Set score to calculate_rule_specificity with rule
        
        If resolution_strategy is equal to "recent":
            Set score to calculate_recency_score with rule
        
        If resolution_strategy is equal to "combined":
            Let priority_score be rule with field priority as Float
            Let specificity_score be calculate_rule_specificity with rule
            Let recency_score be calculate_recency_score with rule
            Set score to (priority_score times 0.4) plus (specificity_score times 0.4) plus (recency_score times 0.2)
        
        Set rule_scores with key (rule with field rule_id) to score
    
    # Select rule with highest score
    Let best_rule be null
    Let best_score be -1000000.0
    
    For each rule in conflict_set:
        Let rule_score be rule_scores with key (rule with field rule_id)
        If rule_score is greater than best_score:
            Set best_score to rule_score
            Set best_rule to rule
    
    Return best_rule

Process called "fire_rule" that takes rule as Rule and working_memory as WorkingMemory and trace as RuleTrace returns Dictionary:
    Let condition_matches be match_rule_conditions with rule and working_memory and empty dictionary
    Let new_facts be empty list
    Let success be false
    
    For each binding in condition_matches:
        Let instantiated_conclusion be instantiate_conclusion with rule with field conclusion and binding
        
        # Check if this fact is already known
        Let is_novel be check_fact_novelty with instantiated_conclusion and working_memory
        If is_novel is equal to true:
            Add instantiated_conclusion to new_facts
            Set success to true
    
    # Update rule statistics
    If success is equal to true:
        Increment rule with field activation_count
        Set rule with field last_fired to current_timestamp
    
    Return dictionary with keys "success", "new_facts", "binding_count":
        "success" maps to success
        "new_facts" maps to new_facts  
        "binding_count" maps to length of condition_matches

# Backward chaining inference engine
Process called "perform_backward_chaining" that takes engine as RuleEngine and goal as LogicalExpression returns RuleTrace:
    Let rule_set be engine with field rule_set
    Let working_memory be engine with field working_memory
    Let trace be create_empty_rule_trace
    Let goal_stack be list containing goal
    Let visited_goals be empty set
    
    While length of goal_stack is greater than 0:
        Let current_goal be remove last item from goal_stack
        Let goal_signature be create_goal_signature with current_goal
        
        # Prevent infinite loops
        If visited_goals contains goal_signature:
            Continue to next iteration
        Add goal_signature to visited_goals
        
        # Check if goal is already proven
        If goal_is_proven with current_goal and working_memory:
            Add current_goal to trace with field derived_facts
            Continue to next iteration
        
        # Find rules that could prove this goal
        Let applicable_rules be find_goal_supporting_rules with current_goal and rule_set
        Let goal_proven be false
        
        For each rule in applicable_rules:
            Let subgoals be extract_rule_conditions with rule
            Let all_subgoals_provable be true
            
            # Add subgoals to stack
            For each subgoal in subgoals:
                If not goal_is_proven with subgoal and working_memory:
                    Add subgoal to goal_stack
                    Set all_subgoals_provable to false
            
            If all_subgoals_provable is equal to true:
                Let firing_result be fire_rule with rule and working_memory and trace
                If firing_result with field success is equal to true:
                    Set goal_proven to true
                    Update working_memory with firing_result with field new_facts
                    Update trace with rule and firing_result
                    Break from loop
        
        If goal_proven is equal to false:
            Add current_goal to trace with field failed_goals
    
    Return trace

Process called "find_goal_supporting_rules" that takes goal as LogicalExpression and rule_set as RuleSet returns List[Rule]:
    Let supporting_rules be empty list
    Let goal_predicate be goal with field predicate
    Let rules be rule_set with field rules
    
    For each rule in rules:
        Let conclusion be rule with field conclusion
        If conclusion with field predicate is equal to goal_predicate:
            # Check if conclusion could unify with goal
            Let unification_possible be check_unification_possibility with conclusion and goal
            If unification_possible is equal to true:
                Add rule to supporting_rules
    
    Return supporting_rules

# Rule learning and induction
Process called "learn_rules_from_examples" that takes learner as RuleLearner and examples as List[Dictionary] returns List[Rule]:
    Let algorithm be learner with field learning_algorithm
    Let learned_rules be empty list
    
    If algorithm is equal to "induction":
        Set learned_rules to perform_rule_induction with examples and learner
    
    If algorithm is equal to "abduction":
        Set learned_rules to perform_rule_abduction with examples and learner  
    
    If algorithm is equal to "association":
        Set learned_rules to perform_association_learning with examples and learner
    
    # Validate learned rules
    Let validated_rules be validate_learned_rules with learned_rules and examples and learner
    
    Return validated_rules

Process called "perform_rule_induction" that takes examples as List[Dictionary] and learner as RuleLearner returns List[Rule]:
    Let induced_rules be empty list
    Let confidence_threshold be learner with field confidence_threshold
    Let support_threshold be learner with field support_threshold
    
    # Generate candidate rules using covering algorithm
    Let uncovered_examples be copy of examples
    
    While length of uncovered_examples is greater than 0:
        Let candidate_rule be generate_covering_rule with uncovered_examples and learner
        
        If candidate_rule is not equal to null:
            # Calculate rule quality metrics
            Let support be calculate_rule_support with candidate_rule and examples
            Let confidence be calculate_rule_confidence with candidate_rule and examples
            
            If support is greater than or equal to support_threshold and confidence is greater than or equal to confidence_threshold:
                Add candidate_rule to induced_rules
                Remove covered examples from uncovered_examples
        Otherwise:
            Break from loop  # Cannot generate more useful rules
    
    Return induced_rules

Process called "generate_covering_rule" that takes examples as List[Dictionary] and learner as RuleLearner returns Rule:
    # Select most informative positive example
    Let seed_example be select_seed_example with examples
    If seed_example is equal to null:
        Return null
    
    # Generate initial rule from seed
    Let initial_conditions be extract_conditions_from_example with seed_example
    Let target_conclusion be extract_conclusion_from_example with seed_example
    
    # Generalize rule by removing conditions
    Let optimized_conditions be optimize_rule_conditions with initial_conditions and target_conclusion and examples and learner
    
    # Create final rule
    Let rule be create_rule_structure
    Set rule with field condition to create_compound_condition with optimized_conditions
    Set rule with field conclusion to target_conclusion
    Set rule with field confidence to calculate_rule_confidence with rule and examples
    Set rule with field priority to 100
    Set rule with field source to "induction"
    Set rule with field rule_id to generate_rule_id
    
    Return rule

Process called "optimize_rule_conditions" that takes conditions as List[LogicalExpression] and conclusion as LogicalExpression and examples as List[Dictionary] and learner as RuleLearner returns List[LogicalExpression]:
    Let optimized_conditions be copy of conditions
    Let best_score be calculate_rule_quality_score with optimized_conditions and conclusion and examples
    Let improved be true
    
    While improved is equal to true:
        Set improved to false
        
        # Try removing each condition
        For index from 0 to length of optimized_conditions minus 1:
            Let reduced_conditions be copy of optimized_conditions
            Remove item at index index from reduced_conditions
            
            Let score be calculate_rule_quality_score with reduced_conditions and conclusion and examples
            If score is greater than best_score:
                Set best_score to score
                Set optimized_conditions to reduced_conditions
                Set improved to true
                Break from loop
    
    Return optimized_conditions

# Meta-reasoning and rule management
Process called "analyze_rule_performance" that takes engine as RuleEngine and analysis_period as String returns Dictionary:
    Let rule_set be engine with field rule_set
    Let performance_data be empty dictionary
    Let rules be rule_set with field rules
    
    # Calculate per-rule statistics
    Let rule_stats be empty dictionary
    For each rule in rules:
        Let rule_id be rule with field rule_id
        Let activation_count be rule with field activation_count
        Let priority be rule with field priority
        Let confidence be rule with field confidence
        
        Let rule_performance be dictionary with keys "activations", "efficiency", "accuracy":
            "activations" maps to activation_count
            "efficiency" maps to calculate_rule_efficiency with rule and engine
            "accuracy" maps to calculate_rule_accuracy with rule and engine
        
        Set rule_stats with key rule_id to rule_performance
    
    # Calculate overall statistics
    Let total_activations be sum of activation counts for all rules
    Let average_confidence be average of confidence values for all rules
    Let conflict_rate be calculate_conflict_rate with engine and analysis_period
    
    Set performance_data with key "rule_statistics" to rule_stats
    Set performance_data with key "total_activations" to total_activations
    Set performance_data with key "average_confidence" to average_confidence
    Set performance_data with key "conflict_rate" to conflict_rate
    Set performance_data with key "analysis_timestamp" to current_timestamp
    
    Return performance_data

Process called "optimize_rule_set" that takes engine as RuleEngine and optimization_strategy as String returns RuleEngine:
    Let rule_set be engine with field rule_set
    Let optimized_engine be copy of engine
    
    If optimization_strategy is equal to "prune_unused":
        Let active_rules be filter_active_rules with rule_set
        Set optimized_engine with field rule_set with field rules to active_rules
    
    If optimization_strategy is equal to "merge_similar":
        Let merged_rules be merge_similar_rules with rule_set
        Set optimized_engine with field rule_set with field rules to merged_rules
    
    If optimization_strategy is equal to "reorder_priority":
        Let reordered_rules be reorder_rules_by_performance with rule_set and engine
        Set optimized_engine with field rule_set with field rules to reordered_rules
    
    If optimization_strategy is equal to "comprehensive":
        # Apply all optimization strategies in sequence
        Let temp_engine be optimize_rule_set with optimized_engine and "prune_unused"
        Set temp_engine to optimize_rule_set with temp_engine and "merge_similar"
        Set optimized_engine to optimize_rule_set with temp_engine and "reorder_priority"
    
    # Rebuild indices
    Rebuild rule indices for optimized_engine
    
    Return optimized_engine

Process called "explain_inference_chain" that takes trace as RuleTrace and goal as LogicalExpression returns String:
    Let explanation be empty string
    Let fired_rules be trace with field fired_rules
    Let derived_facts be trace with field derived_facts
    
    Set explanation to "Inference Explanation for Goal: " Joined with format_logical_expression with goal Joined with "\n\n"
    
    # Build explanation from trace
    For index from 0 to length of fired_rules minus 1:
        Let rule_id be fired_rules with index index
        Let derived_fact be derived_facts with index index
        
        Set explanation to explanation Joined with "Step " Joined with (index plus 1) as String Joined with ": "
        Set explanation to explanation Joined with "Applied rule " Joined with rule_id Joined with "\n"
        Set explanation to explanation Joined with "  Derived: " Joined with format_logical_expression with derived_fact Joined with "\n\n"
    
    # Add performance summary
    Let performance_summary be generate_performance_summary with trace
    Set explanation to explanation Joined with "\nPerformance Summary:\n" Joined with performance_summary
    
    Return explanation

# Main rule engine coordination
Process called "create_rule_engine" that takes rule_definitions as List[Dictionary] and inference_strategy as String returns RuleEngine:
    Let engine be create_rule_engine_structure
    Let rule_set be create_empty_rule_set
    Let working_memory be create_empty_working_memory
    
    # Parse and add rules
    For each rule_def in rule_definitions:
        Let parsed_rule be parse_rule_definition with rule_def
        Add parsed_rule to rule_set with field rules
    
    # Build rule indices for fast lookup
    Build rule indices for rule_set
    
    Set engine with field rule_set to rule_set
    Set engine with field working_memory to working_memory
    Set engine with field inference_strategy to inference_strategy
    Set engine with field conflict_resolution to "combined"
    Set engine with field max_iterations to 100
    Set engine with field explanation_mode to true
    Set engine with field performance_metrics to empty dictionary
    Set engine with field rule_learning_enabled to false
    
    Return engine

Process called "execute_rule_based_reasoning" that takes engine as RuleEngine and query as Dictionary returns Dictionary:
    Let query_type be query with key "type"
    Let query_goal be query with key "goal"
    Let reasoning_trace be null
    
    # Add initial facts to working memory
    If query contains key "facts":
        Let initial_facts be query with key "facts"
        Add initial facts to engine with field working_memory
    
    # Perform reasoning based on strategy
    If engine with field inference_strategy is equal to "forward":
        Set reasoning_trace to perform_forward_chaining with engine and engine with field max_iterations
    
    If engine with field inference_strategy is equal to "backward":
        Let goal_expression be parse_logical_expression with query_goal
        Set reasoning_trace to perform_backward_chaining with engine and goal_expression
    
    If engine with field inference_strategy is equal to "hybrid":
        # Try backward chaining first, then forward chaining
        Let goal_expression be parse_logical_expression with query_goal
        Set reasoning_trace to perform_backward_chaining with engine and goal_expression
        
        # If goal not proven, try forward chaining
        If not goal_is_proven with goal_expression and engine with field working_memory:
            Let forward_trace be perform_forward_chaining with engine and engine with field max_iterations
            Merge forward_trace into reasoning_trace
    
    # Generate explanation if requested
    Let explanation be ""
    If engine with field explanation_mode is equal to true:
        Set explanation to explain_inference_chain with reasoning_trace and parse_logical_expression with query_goal
    
    # Prepare result
    Let result be dictionary with keys "success", "derived_facts", "explanation", "trace", "performance":
        "success" maps to (length of reasoning_trace with field derived_facts is greater than 0)
        "derived_facts" maps to reasoning_trace with field derived_facts
        "explanation" maps to explanation
        "trace" maps to reasoning_trace
        "performance" maps to reasoning_trace with field performance_data
    
    Return result