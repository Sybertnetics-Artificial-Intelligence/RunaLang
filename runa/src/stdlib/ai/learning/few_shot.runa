Note: Advanced Few-Shot Learning System for AI Agents
Note: Implements prototypical networks, relation networks, matching networks,
Note: metric learning, and rapid adaptation from minimal examples
Note: Competitive with PyTorch Few-Shot, TensorFlow Few-Shot, and OpenAI Few-Shot API

Note: Core few-shot learning types
Type called "FewShotLearner":
    learner id as String
    few shot method as String  Note: "prototypical", "matching", "relation", "metric", "maml"
    embedding network as NeuralNetwork
    support set as Dataset
    query set as Dataset
    n way as Integer  Note: Number of classes
    k shot as Integer  Note: Number of examples per class
    distance metric as String
    prototype representations as Dictionary[String, Vector]
    adaptation parameters as Dictionary
    performance metrics as Dictionary

Type called "PrototypicalLearner":
    learner id as String
    embedding dimension as Integer
    embedding network as NeuralNetwork
    prototypes as Dictionary[String, Vector]
    support embeddings as Dictionary[String, List[Vector]]
    query embeddings as List[Vector]
    distance function as String
    temperature parameter as Float
    classification threshold as Float

Type called "MatchingNetwork":
    network id as String
    embedding network as NeuralNetwork
    attention mechanism as AttentionLayer
    support set encoder as NeuralNetwork
    query encoder as NeuralNetwork
    full context embeddings as Boolean
    attention weights as List[Float]
    matching confidence as Dictionary

Type called "RelationNetwork":
    network id as String
    feature extractor as NeuralNetwork
    relation module as NeuralNetwork
    feature dimension as Integer
    relation dimension as Integer
    concatenation strategy as String
    relation scores as Dictionary[String, Float]
    decision threshold as Float

Type called "MetricLearner":
    learner id as String
    metric type as String  Note: "cosine", "euclidean", "mahalanobis", "learned"
    embedding network as NeuralNetwork
    metric parameters as Dictionary
    distance matrix as Matrix
    similarity threshold as Float
    learned metric weights as Matrix
    triplet margin as Float

Type called "AttentionLayer":
    layer id as String
    attention type as String  Note: "additive", "multiplicative", "self", "cross"
    input dimension as Integer
    attention dimension as Integer
    attention weights as Matrix
    query weights as Matrix
    key weights as Matrix
    value weights as Matrix
    softmax temperature as Float

Type called "FewShotEpisode":
    episode id as String
    episode type as String  Note: "classification", "regression", "generation"
    n way as Integer
    k shot as Integer
    query size as Integer
    support samples as List[LabeledSample]
    query samples as List[LabeledSample]
    class labels as List[String]
    episode difficulty as Float
    domain as String

Type called "LabeledSample":
    sample id as String
    features as Vector
    label as String
    class index as Integer
    confidence as Float
    augmented versions as List[Vector]
    metadata as Dictionary

Type called "FewShotMetrics":
    accuracy as Float
    precision per class as Dictionary[String, Float]
    recall per class as Dictionary[String, Float]
    f1 score as Float
    confidence scores as List[Float]
    prediction certainty as Float
    episode difficulty as Float
    adaptation time as Float

Note: Prototypical Networks implementation
Process called "create_prototypical_learner" that takes config as Dictionary returns PrototypicalLearner:
    Let learner be create_prototypical_learner_structure
    Set learner with field learner_id to generate_prototypical_id
    
    Note: Initialize embedding network
    Let embedding_architecture be config with key "embedding_architecture"
    Set learner with field embedding_network to create_neural_network with embedding_architecture
    Set learner with field embedding_dimension to config with key "embedding_dim" or 64
    
    Set learner with field distance_function to config with key "distance" or "euclidean"
    Set learner with field temperature_parameter to config with key "temperature" or 1.0
    Set learner with field classification_threshold to config with key "threshold" or 0.5
    
    Set learner with field prototypes to empty dictionary
    Set learner with field support_embeddings to empty dictionary
    Set learner with field query_embeddings to empty list
    
    Return learner

Process called "compute_class_prototypes" that takes learner as PrototypicalLearner and support_set as Dataset returns Dictionary[String, Vector]:
    Let embedding_network be learner with field embedding_network
    Let prototypes be empty dictionary
    Let class_embeddings be empty dictionary
    
    Note: Group support samples by class
    Let samples_by_class be group_samples_by_class with support_set
    
    For each class_label in keys of samples_by_class:
        Let class_samples be samples_by_class with key class_label
        Let embeddings be empty list
        
        Note: Embed all samples for this class
        For each sample in class_samples:
            Let embedding be forward_pass with embedding_network and sample with field features
            Add embedding to embeddings
        
        Set class_embeddings with key class_label to embeddings
        
        Note: Compute prototype as class centroid
        Let prototype be compute_centroid with embeddings
        Set prototypes with key class_label to prototype
    
    Set learner with field prototypes to prototypes
    Set learner with field support_embeddings to class_embeddings
    
    Return prototypes

Process called "prototypical_classification" that takes learner as PrototypicalLearner and query_sample as Vector returns Dictionary:
    Let embedding_network be learner with field embedding_network
    Let prototypes be learner with field prototypes
    Let distance_function be learner with field distance_function
    Let temperature be learner with field temperature_parameter
    
    Note: Embed query sample
    Let query_embedding be forward_pass with embedding_network and query_sample
    
    Note: Compute distances to all prototypes
    Let distances be empty dictionary
    Let negative_distances be empty dictionary
    
    For each class_label in keys of prototypes:
        Let prototype be prototypes with key class_label
        Let distance be calculate_distance with query_embedding and prototype and distance_function
        Set distances with key class_label to distance
        Set negative_distances with key class_label to (0.0 minus distance)
    
    Note: Apply softmax with temperature to get probabilities
    let scaled_distances be empty dictionary
    For each class_label in keys of negative_distances:
        Let scaled_distance be negative_distances with key class_label divided by temperature
        Set scaled_distances with key class_label to scaled_distance
    
    Let class_probabilities be apply_softmax_to_dictionary with scaled_distances
    
    Note: Find predicted class
    Let predicted_class be find_maximum_key with class_probabilities
    Let confidence be class_probabilities with key predicted_class
    
    Return dictionary with keys "prediction", "confidence", "probabilities", "distances":
        "prediction" maps to predicted_class
        "confidence" maps to confidence
        "probabilities" maps to class_probabilities
        "distances" maps to distances

Note: Matching Networks implementation
Process called "create_matching_network" that takes config as Dictionary returns MatchingNetwork:
    Let network be create_matching_network_structure
    Set network with field network_id to generate_matching_id
    
    Note: Initialize embedding networks
    Let embedding_architecture be config with key "embedding_architecture"
    Set network with field embedding_network to create_neural_network with embedding_architecture
    
    Note: Initialize encoders for full context embeddings
    Set network with field full_context_embeddings to config with key "full_context" or true
    If network with field full_context_embeddings is equal to true:
        Let support_encoder_config be config with key "support_encoder"
        Let query_encoder_config be config with key "query_encoder"
        Set network with field support_set_encoder to create_neural_network with support_encoder_config
        Set network with field query_encoder to create_neural_network with query_encoder_config
    
    Note: Initialize attention mechanism
    Let attention_config be config with key "attention_config"
    Set network with field attention_mechanism to create_attention_layer with attention_config
    
    Set network with field attention_weights to empty list
    Set network with field matching_confidence to empty dictionary
    
    Return network

Process called "matching_network_classification" that takes network as MatchingNetwork and support_set as Dataset and query_sample as Vector returns Dictionary:
    Let embedding_network be network with field embedding_network
    Let attention_mechanism be network with field attention_mechanism
    
    Note: Embed support set
    Let support_embeddings be empty list
    Let support_labels be empty list
    
    For each sample in support_set with field data_samples:
        Let embedding be forward_pass with embedding_network and sample with field features
        Add embedding to support_embeddings
        Add sample with field label to support_labels
    
    Note: Embed query sample
    Let query_embedding be forward_pass with embedding_network and query_sample
    
    Note: Apply full context embeddings if enabled
    If network with field full_context_embeddings is equal to true:
        Let support_encoder be network with field support_set_encoder
        Let query_encoder be network with field query_encoder
        
        Set support_embeddings to encode_with_context with support_encoder and support_embeddings
        Set query_embedding to forward_pass with query_encoder and query_embedding
    
    Note: Compute attention weights between query and support
    Let attention_weights be empty list
    For each support_embedding in support_embeddings:
        Let attention_weight be compute_attention with attention_mechanism and query_embedding and support_embedding
        Add attention_weight to attention_weights
    
    Note: Normalize attention weights
    Let normalized_weights be apply_softmax with attention_weights
    Set network with field attention_weights to normalized_weights
    
    Note: Compute weighted predictions
    Let class_scores be empty dictionary
    For weight_index from 0 to length of normalized_weights minus 1:
        Let weight be normalized_weights with index weight_index
        Let label be support_labels with index weight_index
        
        If class_scores contains key label:
            Set class_scores with key label to (class_scores with key label) plus weight
        Otherwise:
            Set class_scores with key label to weight
    
    Let predicted_class be find_maximum_key with class_scores
    Let confidence be class_scores with key predicted_class
    
    Return dictionary with keys "prediction", "confidence", "class_scores", "attention_weights":
        "prediction" maps to predicted_class
        "confidence" maps to confidence
        "class_scores" maps to class_scores
        "attention_weights" maps to normalized_weights

Note: Relation Networks implementation
Process called "create_relation_network" that takes config as Dictionary returns RelationNetwork:
    Let network be create_relation_network_structure
    Set network with field network_id to generate_relation_id
    
    Note: Initialize feature extractor
    Let feature_architecture be config with key "feature_architecture"
    Set network with field feature_extractor to create_neural_network with feature_architecture
    Set network with field feature_dimension to config with key "feature_dim" or 64
    
    Note: Initialize relation module
    Let relation_architecture be config with key "relation_architecture"
    Set network with field relation_module to create_neural_network with relation_architecture
    Set network with field relation_dimension to config with key "relation_dim" or 8
    
    Set network with field concatenation_strategy to config with key "concatenation" or "element_wise"
    Set network with field decision_threshold to config with key "threshold" or 0.5
    Set network with field relation_scores to empty dictionary
    
    Return network

Process called "relation_network_classification" that takes network as RelationNetwork and support_set as Dataset and query_sample as Vector returns Dictionary:
    Let feature_extractor be network with field feature_extractor
    Let relation_module be network with field relation_module
    Let concatenation_strategy be network with field concatenation_strategy
    
    Note: Extract features from query sample
    Let query_features be forward_pass with feature_extractor and query_sample
    
    Note: Extract features from support samples and compute relations
    Let relation_scores be empty dictionary
    Let samples_by_class be group_samples_by_class with support_set
    
    For each class_label in keys of samples_by_class:
        Let class_samples be samples_by_class with key class_label
        Let class_relation_scores be empty list
        
        For each sample in class_samples:
            Note: Extract features from support sample
            Let support_features be forward_pass with feature_extractor and sample with field features
            
            Note: Combine query and support features
            Let combined_features be combine_features with query_features and support_features and concatenation_strategy
            
            Note: Compute relation score
            Let relation_score be forward_pass with relation_module and combined_features
            Add relation_score to class_relation_scores
        
        Note: Aggregate relation scores for this class
        Let aggregated_score be calculate_mean with class_relation_scores
        Set relation_scores with key class_label to aggregated_score
    
    Set network with field relation_scores to relation_scores
    
    Note: Find best matching class
    Let predicted_class be find_maximum_key with relation_scores
    Let confidence be relation_scores with key predicted_class
    
    Return dictionary with keys "prediction", "confidence", "relation_scores":
        "prediction" maps to predicted_class
        "confidence" maps to confidence
        "relation_scores" maps to relation_scores

Process called "combine_features" that takes query_features as Vector and support_features as Vector and strategy as String returns Vector:
    If strategy is equal to "concatenation":
        Return concatenate_vectors with query_features and support_features
    
    If strategy is equal to "element_wise":
        Return element_wise_multiply with query_features and support_features
    
    If strategy is equal to "sum":
        Return add_vectors with query_features and support_features
    
    If strategy is equal to "difference":
        Return subtract_vectors with query_features and support_features
    
    Return concatenate_vectors with query_features and support_features  Note: Default fallback

Note: Metric Learning for Few-Shot
Process called "create_metric_learner" that takes config as Dictionary returns MetricLearner:
    Let learner be create_metric_learner_structure
    Set learner with field learner_id to generate_metric_id
    Set learner with field metric_type to config with key "metric_type" or "cosine"
    
    Note: Initialize embedding network
    Let embedding_architecture be config with key "embedding_architecture"
    Set learner with field embedding_network to create_neural_network with embedding_architecture
    
    Set learner with field similarity_threshold to config with key "threshold" or 0.7
    Set learner with field triplet_margin to config with key "margin" or 0.3
    
    Note: Initialize metric parameters
    Let metric_params be empty dictionary
    If learner with field metric_type is equal to "learned":
        Let metric_dimension be config with key "metric_dimension" or 64
        Let metric_weights be create_matrix with metric_dimension and metric_dimension
        Set learner with field learned_metric_weights to initialize_xavier_weights with metric_weights
    
    Set learner with field metric_parameters to metric_params
    Set learner with field distance_matrix to create_empty_matrix
    
    Return learner

Process called "compute_metric_distance" that takes learner as MetricLearner and embedding1 as Vector and embedding2 as Vector returns Float:
    Let metric_type be learner with field metric_type
    
    If metric_type is equal to "cosine":
        Return cosine_distance with embedding1 and embedding2
    
    If metric_type is equal to "euclidean":
        Return euclidean_distance with embedding1 and embedding2
    
    If metric_type is equal to "manhattan":
        Return manhattan_distance with embedding1 and embedding2
    
    If metric_type is equal to "mahalanobis":
        Let covariance_matrix be learner with field metric_parameters with key "covariance"
        Return mahalanobis_distance with embedding1 and embedding2 and covariance_matrix
    
    If metric_type is equal to "learned":
        Let metric_weights be learner with field learned_metric_weights
        Return learned_metric_distance with embedding1 and embedding2 and metric_weights
    
    Return euclidean_distance with embedding1 and embedding2  Note: Default

Process called "train_metric_with_triplets" that takes learner as MetricLearner and triplet_data as List[Dictionary] and epochs as Integer returns Dictionary:
    Let embedding_network be learner with field embedding_network
    Let margin be learner with field triplet_margin
    Let training_losses be empty list
    
    For epoch from 1 to epochs:
        Let epoch_loss be 0.0
        Let batch_count be 0
        
        For each triplet in triplet_data:
            Let anchor_sample be triplet with key "anchor"
            Let positive_sample be triplet with key "positive"
            Let negative_sample be triplet with key "negative"
            
            Note: Embed samples
            Let anchor_embedding be forward_pass with embedding_network and anchor_sample
            Let positive_embedding be forward_pass with embedding_network and positive_sample
            Let negative_embedding be forward_pass with embedding_network and negative_sample
            
            Note: Compute distances
            Let positive_distance be compute_metric_distance with learner and anchor_embedding and positive_embedding
            Let negative_distance be compute_metric_distance with learner and anchor_embedding and negative_embedding
            
            Note: Compute triplet loss
            Let triplet_loss be maximum of (positive_distance minus negative_distance plus margin) and 0.0
            
            Note: Backpropagate and update
            If triplet_loss is greater than 0.0:
                Backpropagate loss with embedding_network and triplet_loss
                Update model parameters with embedding_network
            
            Set epoch_loss to epoch_loss plus triplet_loss
            Set batch_count to batch_count plus 1
        
        Let average_loss be epoch_loss divided by batch_count as Float
        Add average_loss to training_losses
    
    Return dictionary with keys "training_losses", "final_loss":
        "training_losses" maps to training_losses
        "final_loss" maps to training_losses with index (length of training_losses minus 1)

Note: Few-shot episode generation and management
Process called "generate_few_shot_episode" that takes dataset as Dataset and n_way as Integer and k_shot as Integer and query_size as Integer returns FewShotEpisode:
    Let episode be create_few_shot_episode_structure
    Set episode with field episode_id to generate_episode_id
    Set episode with field n_way to n_way
    Set episode with field k_shot to k_shot
    Set episode with field query_size to query_size
    
    Note: Sample classes for n-way classification
    Let available_classes be extract_unique_classes with dataset
    Let sampled_classes be sample_random_elements with available_classes and n_way
    Set episode with field class_labels to sampled_classes
    
    Note: Create support and query sets
    Let support_samples be empty list
    Let query_samples be empty list
    
    For each class_label in sampled_classes:
        Let class_samples be filter_samples_by_class with dataset and class_label
        
        Note: Sample k examples for support set
        Let support_class_samples be sample_random_elements with class_samples and k_shot
        Add all support_class_samples to support_samples
        
        Note: Sample remaining examples for query set
        Let remaining_samples be remove_samples with class_samples and support_class_samples
        Let query_class_samples be sample_random_elements with remaining_samples and query_size
        Add all query_class_samples to query_samples
    
    Set episode with field support_samples to support_samples
    Set episode with field query_samples to query_samples
    
    Note: Calculate episode difficulty
    Let difficulty be calculate_episode_difficulty with episode
    Set episode with field episode_difficulty to difficulty
    
    Return episode

Process called "evaluate_few_shot_episode" that takes learner as FewShotLearner and episode as FewShotEpisode returns FewShotMetrics:
    Let method be learner with field few_shot_method
    Let support_set be create_dataset with episode with field support_samples
    Let query_samples be episode with field query_samples
    
    Let predictions be empty list
    Let confidences be empty list
    Let true_labels be empty list
    
    Note: Classify each query sample
    For each query_sample in query_samples:
        Let classification_result be empty dictionary
        
        If method is equal to "prototypical":
            Let proto_learner be convert_to_prototypical with learner
            Let prototypes be compute_class_prototypes with proto_learner and support_set
            Set classification_result to prototypical_classification with proto_learner and query_sample with field features
        
        If method is equal to "matching":
            Let matching_network be convert_to_matching with learner
            Set classification_result to matching_network_classification with matching_network and support_set and query_sample with field features
        
        If method is equal to "relation":
            Let relation_network be convert_to_relation with learner
            Set classification_result to relation_network_classification with relation_network and support_set and query_sample with field features
        
        Add classification_result with key "prediction" to predictions
        Add classification_result with key "confidence" to confidences
        Add query_sample with field label to true_labels
    
    Note: Calculate metrics
    Let metrics be create_few_shot_metrics_structure
    Set metrics with field accuracy to calculate_accuracy with predictions and true_labels
    Set metrics with field precision_per_class to calculate_precision_per_class with predictions and true_labels
    Set metrics with field recall_per_class to calculate_recall_per_class with predictions and true_labels
    Set metrics with field f1_score to calculate_f1_score with predictions and true_labels
    Set metrics with field confidence_scores to confidences
    Set metrics with field prediction_certainty to calculate_mean with confidences
    Set metrics with field episode_difficulty to episode with field episode_difficulty
    
    Return metrics

Note: Data augmentation for few-shot learning
Process called "augment_support_set" that takes support_set as Dataset and augmentation_config as Dictionary returns Dataset:
    Let augmentation_methods be augmentation_config with key "methods"
    Let augmentation_factor be augmentation_config with key "factor" or 2
    Let augmented_samples be empty list
    
    Note: Add original samples
    Add all support_set with field data_samples to augmented_samples
    
    For each sample in support_set with field data_samples:
        For augmentation_count from 1 to augmentation_factor:
            Let augmented_sample be copy of sample
            
            Note: Apply augmentation methods
            For each method in augmentation_methods:
                If method is equal to "rotation":
                    Let rotation_angle be generate_random_float between negative 30.0 and 30.0
                    Set augmented_sample with field features to apply_rotation with augmented_sample with field features and rotation_angle
                
                If method is equal to "noise":
                    Let noise_level be augmentation_config with key "noise_level" or 0.1
                    Let noise to add_gaussian_noise with augmented_sample with field features and noise_level
                    Set augmented_sample with field features to noise
                
                If method is equal to "scaling":
                    Let scale_factor be generate_random_float between 0.8 and 1.2
                    Set augmented_sample with field features to apply_scaling with augmented_sample with field features and scale_factor
                
                If method is equal to "translation":
                    Let translation_offset be generate_random_vector with length 2 and range negative 0.1 to 0.1
                    Set augmented_sample with field features to apply_translation with augmented_sample with field features and translation_offset
            
            Set augmented_sample with field sample_id to generate_augmented_sample_id
            Add augmented_sample to augmented_samples
    
    Return create_dataset with augmented_samples

Note: Few-shot learning optimization
Process called "optimize_few_shot_hyperparameters" that takes learner as FewShotLearner and validation_episodes as List[FewShotEpisode] returns FewShotLearner:
    Let hyperparameter_space be define_few_shot_hyperparameter_space
    Let best_performance be 0.0
    Let best_config be empty dictionary
    Let best_learner be learner
    
    For each config in hyperparameter_space:
        Let test_learner be create_few_shot_learner_with_config with config
        
        Note: Evaluate on validation episodes
        Let validation_accuracies be empty list
        For each episode in validation_episodes:
            Let metrics be evaluate_few_shot_episode with test_learner and episode
            Add metrics with field accuracy to validation_accuracies
        
        Let average_accuracy be calculate_mean with validation_accuracies
        
        If average_accuracy is greater than best_performance:
            Set best_performance to average_accuracy
            Set best_config to config
            Set best_learner to test_learner
    
    Note: Update performance metrics
    Set best_learner with field performance_metrics with key "validation_accuracy" to best_performance
    Set best_learner with field performance_metrics with key "best_config" to best_config
    
    Return best_learner

Note: Cross-domain few-shot evaluation
Process called "evaluate_cross_domain_few_shot" that takes learner as FewShotLearner and source_domain as String and target_domains as List[String] returns Dictionary:
    Let cross_domain_results be empty dictionary
    
    For each target_domain in target_domains:
        Note: Generate few-shot episodes for target domain
        Let target_episodes be generate_domain_episodes with target_domain and 100
        
        Let domain_accuracies be empty list
        For each episode in target_episodes:
            Let metrics be evaluate_few_shot_episode with learner and episode
            Add metrics with field accuracy to domain_accuracies
        
        Let domain_performance be dictionary with keys "mean_accuracy", "std_accuracy", "episode_count":
            "mean_accuracy" maps to calculate_mean with domain_accuracies
            "std_accuracy" maps to calculate_standard_deviation with domain_accuracies
            "episode_count" maps to length of target_episodes
        
        Set cross_domain_results with key target_domain to domain_performance
    
    Note: Calculate domain transfer metrics
    Let transfer_analysis be analyze_domain_transfer with cross_domain_results
    Set cross_domain_results with key "transfer_analysis" to transfer_analysis
    
    Return cross_domain_results

Note: Main few-shot learning coordination
Process called "create_few_shot_learning_system" that takes configuration as Dictionary returns Dictionary:
    Let system be empty dictionary
    Set system with key "method" to configuration with key "method" or "prototypical"
    Set system with key "n_way" to configuration with key "n_way" or 5
    Set system with key "k_shot" to configuration with key "k_shot" or 1
    Set system with key "query_size" to configuration with key "query_size" or 15
    Set system with key "embedding_config" to configuration with key "embedding_config"
    Set system with key "augmentation_config" to configuration with key "augmentation_config"
    Set system with key "evaluation_config" to configuration with key "evaluation_config"
    
    Return system

Process called "execute_few_shot_learning" that takes system as Dictionary and query as Dictionary returns Dictionary:
    Let query_type be query with key "type"
    Let result be empty dictionary
    
    If query_type is equal to "train_few_shot_learner":
        Let learner_config be query with key "learner_config"
        Let training_episodes be query with key "training_episodes"
        Let learner be create_few_shot_learner_by_method with learner_config
        Let training_result be train_few_shot_learner with learner and training_episodes
        Set result with key "trained_learner" to learner
        Set result with key "training_metrics" to training_result
    
    If query_type is equal to "evaluate_episode":
        Let learner be query with key "learner"
        Let episode be query with key "episode"
        Let metrics be evaluate_few_shot_episode with learner and episode
        Set result with key "episode_metrics" to metrics
    
    If query_type is equal to "generate_episodes":
        Let dataset be query with key "dataset"
        Let n_way be system with key "n_way"
        Let k_shot be system with key "k_shot"
        Let episode_count be query with key "episode_count" or 100
        
        Let episodes be empty list
        For count from 1 to episode_count:
            Let episode be generate_few_shot_episode with dataset and n_way and k_shot and system with key "query_size"
            Add episode to episodes
        
        Set result with key "generated_episodes" to episodes
    
    If query_type is equal to "cross_domain_evaluation":
        Let learner be query with key "learner"
        Let source_domain be query with key "source_domain"
        Let target_domains be query with key "target_domains"
        Let cross_domain_result be evaluate_cross_domain_few_shot with learner and source_domain and target_domains
        Set result with key "cross_domain_results" to cross_domain_result
    
    If query_type is equal to "optimize_hyperparameters":
        Let learner be query with key "learner"
        Let validation_episodes be query with key "validation_episodes"
        Let optimized_learner be optimize_few_shot_hyperparameters with learner and validation_episodes
        Set result with key "optimized_learner" to optimized_learner
    
    Note: Add metadata
    Set result with key "few_shot_timestamp" to current_timestamp
    Set result with key "system_config" to extract_system_summary with system
    
    Return result