Note: Advanced Multi-Criteria Decision Analysis System for AI Agents
Note: Implements AHP, TOPSIS, ELECTRE, PROMETHEE, outranking methods,
Note: and complex multi-objective optimization with trade-off analysis
Note: Competitive with Expert Choice, DecisionTools, and multi-criteria analysis frameworks

Note: Core multi-criteria decision types
Type called "MultiCriteriaDecision":
    decision id as String
    decision name as String
    alternatives as List[Alternative]
    criteria as List[Criterion]
    decision matrix as Matrix
    criteria weights as List[Float]
    method as String  Note: "ahp", "topsis", "electre", "promethee", "weighted_sum"
    preference structure as PreferenceStructure
    ranking results as List[RankingResult]
    sensitivity analysis as SensitivityAnalysis

Type called "Alternative":
    alternative id as String
    alternative name as String
    alternative type as String
    performance values as Dictionary[String, Float]
    qualitative attributes as Dictionary[String, String]
    feasibility constraints as List[Constraint]
    cost as Float
    implementation complexity as Float

Type called "Criterion":
    criterion id as String
    criterion name as String
    criterion type as String  Note: "benefit", "cost", "target"
    weight as Float
    measurement scale as String  Note: "ratio", "interval", "ordinal", "nominal"
    preference direction as String  Note: "maximize", "minimize", "target_value"
    preference function as PreferenceFunction
    thresholds as Dictionary[String, Float]

Type called "PreferenceFunction":
    function id as String
    function type as String  Note: "usual", "u_shape", "v_shape", "level", "linear", "gaussian"
    parameters as Dictionary[String, Float]
    indifference threshold as Float
    preference threshold as Float
    veto threshold as Float

Type called "AHPMatrix":
    matrix id as String
    matrix type as String  Note: "criteria", "alternatives"
    pairwise comparisons as Matrix
    consistency ratio as Float
    consistency index as Float
    random index as Float
    principal eigenvector as Vector
    priority weights as Vector

Type called "TOPSISResult":
    result id as String
    normalized matrix as Matrix
    weighted matrix as Matrix
    ideal solution as Vector
    negative ideal solution as Vector
    separation measures as Dictionary[String, Dictionary[String, Float]]
    closeness coefficients as Dictionary[String, Float]
    ranking as List[String]

Type called "ELECTREResult":
    result id as String
    concordance matrix as Matrix
    discordance matrix as Matrix
    outranking matrix as Matrix
    kernel as List[String]
    dominated alternatives as List[String]
    preference graph as Dictionary[String, List[String]]

Type called "SensitivityAnalysis":
    analysis id as String
    weight sensitivity as Dictionary[String, Dictionary[String, Float]]
    threshold sensitivity as Dictionary[String, Float]
    rank stability as Dictionary[String, Float]
    critical weights as Dictionary[String, Float]
    robustness measures as Dictionary[String, Float]

Note: Analytic Hierarchy Process (AHP)
Process called "create_ahp_decision" that takes config as Dictionary returns MultiCriteriaDecision:
    Let decision be create_multi_criteria_decision_structure
    Set decision with field decision_id to generate_decision_id
    Set decision with field decision_name to config with key "name"
    Set decision with field method to "ahp"
    
    Note: Initialize alternatives and criteria
    Set decision with field alternatives to create_alternatives with config with key "alternatives"
    Set decision with field criteria to create_criteria with config with key "criteria"
    
    Note: Initialize AHP-specific structures
    Set decision with field preference_structure to create_ahp_preference_structure with config
    
    Return decision

Process called "create_ahp_pairwise_matrix" that takes elements as List[String] and comparisons as Dictionary returns AHPMatrix:
    Let matrix be create_ahp_matrix_structure
    Set matrix with field matrix_id to generate_matrix_id
    Set matrix with field matrix_type to "pairwise"
    
    Let n be length of elements
    Let pairwise_matrix be create_matrix with n and n
    
    Note: Fill pairwise comparison matrix
    For i from 0 to n minus 1:
        For j from 0 to n minus 1:
            If i is equal to j:
                Set pairwise_matrix with index i with index j to 1.0
            Otherwise:
                Let element_i be elements with index i
                Let element_j be elements with index j
                Let comparison_key be element_i concatenated with "_vs_" concatenated with element_j
                
                If comparisons contains key comparison_key:
                    Let comparison_value be comparisons with key comparison_key
                    Set pairwise_matrix with index i with index j to comparison_value
                    Set pairwise_matrix with index j with index i to 1.0 divided by comparison_value
                Otherwise:
                    Set pairwise_matrix with index i with index j to 1.0
                    Set pairwise_matrix with index j with index i to 1.0
    
    Set matrix with field pairwise_comparisons to pairwise_matrix
    
    Note: Calculate consistency metrics
    Let consistency_metrics be calculate_ahp_consistency with matrix
    Set matrix with field consistency_ratio to consistency_metrics with key "consistency_ratio"
    Set matrix with field consistency_index to consistency_metrics with key "consistency_index"
    Set matrix with field random_index to consistency_metrics with key "random_index"
    
    Note: Calculate priority weights
    Let priority_weights be calculate_ahp_weights with pairwise_matrix
    Set matrix with field priority_weights to priority_weights
    
    Return matrix

Process called "calculate_ahp_weights" that takes pairwise_matrix as Matrix returns Vector:
    Note: Calculate principal eigenvector (priority weights)
    Let n be length of pairwise_matrix
    Let weights be create_vector with n
    
    Note: Use iterative method to find principal eigenvector
    Let max_iterations be 100
    Let tolerance be 0.0001
    
    Note: Initialize weights to equal values
    For i from 0 to n minus 1:
        Set weights with index i to 1.0 divided by n as Float
    
    For iteration from 1 to max_iterations:
        Let new_weights be create_vector with n
        
        Note: Matrix multiplication: Aw
        For i from 0 to n minus 1:
            Let sum_value be 0.0
            For j from 0 to n minus 1:
                Set sum_value to sum_value plus (pairwise_matrix with index i with index j multiplied by weights with index j)
            Set new_weights with index i to sum_value
        
        Note: Normalize
        Let sum_new_weights be sum_vector_elements with new_weights
        For i from 0 to n minus 1:
            Set new_weights with index i to new_weights with index i divided by sum_new_weights
        
        Note: Check convergence
        Let max_change be 0.0
        For i from 0 to n minus 1:
            Let change be absolute_value of (new_weights with index i minus weights with index i)
            If change is greater than max_change:
                Set max_change to change
        
        Set weights to new_weights
        
        If max_change is less than tolerance:
            Break from loop
    
    Return weights

Process called "calculate_ahp_consistency" that takes ahp_matrix as AHPMatrix returns Dictionary:
    Let pairwise_matrix be ahp_matrix with field pairwise_comparisons
    Let weights be ahp_matrix with field priority_weights
    Let n be length of pairwise_matrix
    
    Note: Calculate maximum eigenvalue (lambda_max)
    Let lambda_max be 0.0
    For i from 0 to n minus 1:
        Let sum_value be 0.0
        For j from 0 to n minus 1:
            Set sum_value to sum_value plus (pairwise_matrix with index i with index j multiplied by weights with index j)
        Set lambda_max to lambda_max plus (sum_value divided by weights with index i)
    Set lambda_max to lambda_max divided by n as Float
    
    Note: Calculate consistency index
    Let consistency_index be (lambda_max minus n as Float) divided by (n minus 1) as Float
    
    Note: Get random index for matrix size
    Let random_indices be list containing 0.0, 0.0, 0.52, 0.89, 1.11, 1.25, 1.35, 1.40, 1.45, 1.49
    Let random_index be random_indices with index (n minus 1) or 1.0
    
    Note: Calculate consistency ratio
    Let consistency_ratio be consistency_index divided by random_index
    
    Return dictionary with keys "consistency_index", "consistency_ratio", "random_index", "lambda_max":
        "consistency_index" maps to consistency_index
        "consistency_ratio" maps to consistency_ratio
        "random_index" maps to random_index
        "lambda_max" maps to lambda_max

Note: TOPSIS (Technique for Order Performance by Similarity to Ideal Solution)
Process called "apply_topsis_method" that takes decision as MultiCriteriaDecision returns TOPSISResult:
    Let alternatives be decision with field alternatives
    Let criteria be decision with field criteria
    Let decision_matrix be decision with field decision_matrix
    Let criteria_weights be decision with field criteria_weights
    
    Note: Step 1: Normalize the decision matrix
    Let normalized_matrix be normalize_decision_matrix with decision_matrix
    
    Note: Step 2: Calculate weighted normalized matrix
    Let weighted_matrix be apply_criteria_weights with normalized_matrix and criteria_weights
    
    Note: Step 3: Determine ideal and negative ideal solutions
    Let ideal_solution be determine_ideal_solution with weighted_matrix and criteria
    Let negative_ideal_solution be determine_negative_ideal_solution with weighted_matrix and criteria
    
    Note: Step 4: Calculate separation measures
    Let separation_measures be calculate_separation_measures with weighted_matrix and ideal_solution and negative_ideal_solution
    
    Note: Step 5: Calculate closeness coefficients
    Let closeness_coefficients be calculate_closeness_coefficients with separation_measures
    
    Note: Step 6: Rank alternatives
    Let ranking be rank_alternatives_by_closeness with closeness_coefficients
    
    Let topsis_result be create_topsis_result_structure
    Set topsis_result with field result_id to generate_result_id
    Set topsis_result with field normalized_matrix to normalized_matrix
    Set topsis_result with field weighted_matrix to weighted_matrix
    Set topsis_result with field ideal_solution to ideal_solution
    Set topsis_result with field negative_ideal_solution to negative_ideal_solution
    Set topsis_result with field separation_measures to separation_measures
    Set topsis_result with field closeness_coefficients to closeness_coefficients
    Set topsis_result with field ranking to ranking
    
    Return topsis_result

Process called "normalize_decision_matrix" that takes matrix as Matrix returns Matrix:
    Let rows be length of matrix
    Let cols be length of matrix with index 0
    Let normalized_matrix be create_matrix with rows and cols
    
    Note: Vector normalization for each column
    For j from 0 to cols minus 1:
        Note: Calculate column sum of squares
        Let sum_of_squares be 0.0
        For i from 0 to rows minus 1:
            Let value be matrix with index i with index j
            Set sum_of_squares to sum_of_squares plus (value multiplied by value)
        
        Let column_norm be square_root of sum_of_squares
        
        Note: Normalize column
        For i from 0 to rows minus 1:
            Let original_value be matrix with index i with index j
            Let normalized_value be original_value divided by column_norm
            Set normalized_matrix with index i with index j to normalized_value
    
    Return normalized_matrix

Process called "determine_ideal_solution" that takes weighted_matrix as Matrix and criteria as List[Criterion] returns Vector:
    Let cols be length of weighted_matrix with index 0
    Let ideal_solution be create_vector with cols
    
    For j from 0 to cols minus 1:
        Let criterion be criteria with index j
        Let preference_direction be criterion with field preference_direction
        
        Note: Extract column values
        Let column_values be empty list
        For i from 0 to length of weighted_matrix minus 1:
            Add weighted_matrix with index i with index j to column_values
        
        If preference_direction is equal to "maximize":
            Set ideal_solution with index j to maximum in column_values
        Otherwise:
            Set ideal_solution with index j to minimum in column_values
    
    Return ideal_solution

Process called "calculate_separation_measures" that takes weighted_matrix as Matrix and ideal_solution as Vector and negative_ideal_solution as Vector returns Dictionary[String, Dictionary[String, Float]]:
    Let rows be length of weighted_matrix
    Let cols be length of weighted_matrix with index 0
    Let separation_measures be empty dictionary
    
    For i from 0 to rows minus 1:
        Let alternative_id be "alternative_" concatenated with i as String
        
        Note: Calculate distance to ideal solution
        Let distance_to_ideal be 0.0
        For j from 0 to cols minus 1:
            Let value be weighted_matrix with index i with index j
            let ideal_value be ideal_solution with index j
            Let diff be value minus ideal_value
            Set distance_to_ideal to distance_to_ideal plus (diff multiplied by diff)
        Set distance_to_ideal to square_root of distance_to_ideal
        
        Note: Calculate distance to negative ideal solution
        Let distance_to_negative_ideal be 0.0
        For j from 0 to cols minus 1:
            Let value be weighted_matrix with index i with index j
            Let negative_ideal_value be negative_ideal_solution with index j
            Let diff be value minus negative_ideal_value
            Set distance_to_negative_ideal to distance_to_negative_ideal plus (diff multiplied by diff)
        Set distance_to_negative_ideal to square_root of distance_to_negative_ideal
        
        Set separation_measures with key alternative_id to dictionary with keys "ideal", "negative_ideal":
            "ideal" maps to distance_to_ideal
            "negative_ideal" maps to distance_to_negative_ideal
    
    Return separation_measures

Process called "calculate_closeness_coefficients" that takes separation_measures as Dictionary[String, Dictionary[String, Float]] returns Dictionary[String, Float]:
    Let closeness_coefficients be empty dictionary
    
    For each alternative_id in keys of separation_measures:
        Let distances be separation_measures with key alternative_id
        Let distance_to_ideal be distances with key "ideal"
        Let distance_to_negative_ideal be distances with key "negative_ideal"
        
        Note: Closeness coefficient = distance to negative ideal / (distance to ideal + distance to negative ideal)
        Let denominator be distance_to_ideal plus distance_to_negative_ideal
        Let closeness_coefficient be distance_to_negative_ideal divided by denominator
        
        Set closeness_coefficients with key alternative_id to closeness_coefficient
    
    Return closeness_coefficients

Note: ELECTRE (ELimination Et Choix Traduisant la REalité)
Process called "apply_electre_method" that takes decision as MultiCriteriaDecision and thresholds as Dictionary returns ELECTREResult:
    Let alternatives be decision with field alternatives
    Let criteria be decision with field criteria
    Let decision_matrix be decision with field decision_matrix
    Let criteria_weights be decision with field criteria_weights
    
    Note: Calculate concordance matrix
    Let concordance_matrix be calculate_concordance_matrix with decision_matrix and criteria_weights and thresholds
    
    Note: Calculate discordance matrix
    Let discordance_matrix be calculate_discordance_matrix with decision_matrix and criteria and thresholds
    
    Note: Determine outranking relationships
    Let outranking_matrix be determine_outranking_relationships with concordance_matrix and discordance_matrix and thresholds
    
    Note: Find kernel (non-dominated alternatives)
    Let kernel be find_electre_kernel with outranking_matrix
    Let dominated_alternatives be find_dominated_alternatives with outranking_matrix
    
    Note: Create preference graph
    Let preference_graph be create_preference_graph with outranking_matrix
    
    Let electre_result be create_electre_result_structure
    Set electre_result with field result_id to generate_result_id
    Set electre_result with field concordance_matrix to concordance_matrix
    Set electre_result with field discordance_matrix to discordance_matrix
    Set electre_result with field outranking_matrix to outranking_matrix
    Set electre_result with field kernel to kernel
    Set electre_result with field dominated_alternatives to dominated_alternatives
    Set electre_result with field preference_graph to preference_graph
    
    Return electre_result

Process called "calculate_concordance_matrix" that takes decision_matrix as Matrix and weights as List[Float] and thresholds as Dictionary returns Matrix:
    Let n be length of decision_matrix
    Let m be length of decision_matrix with index 0
    Let concordance_matrix be create_matrix with n and n
    
    For a from 0 to n minus 1:
        For b from 0 to n minus 1:
            If a is equal to b:
                Set concordance_matrix with index a with index b to 1.0
            Otherwise:
                Let concordance_index be 0.0
                Let total_weight be 0.0
                
                For j from 0 to m minus 1:
                    Let weight be weights with index j
                    Let value_a be decision_matrix with index a with index j
                    Let value_b be decision_matrix with index b with index j
                    
                    Set total_weight to total_weight plus weight
                    
                    Note: Check if criterion j supports a over b
                    If value_a is greater than or equal to value_b:
                        Set concordance_index to concordance_index plus weight
                
                Set concordance_matrix with index a with index b to concordance_index divided by total_weight
    
    Return concordance_matrix

Process called "determine_outranking_relationships" that takes concordance_matrix as Matrix and discordance_matrix as Matrix and thresholds as Dictionary returns Matrix:
    Let n be length of concordance_matrix
    Let outranking_matrix be create_matrix with n and n
    Let concordance_threshold be thresholds with key "concordance" or 0.6
    Let discordance_threshold be thresholds with key "discordance" or 0.3
    
    For a from 0 to n minus 1:
        For b from 0 to n minus 1:
            Let concordance_value be concordance_matrix with index a with index b
            Let discordance_value be discordance_matrix with index a with index b
            
            Note: a outranks b if concordance is high and discordance is low
            If concordance_value is greater than or equal to concordance_threshold and discordance_value is less than or equal to discordance_threshold:
                Set outranking_matrix with index a with index b to 1.0
            Otherwise:
                Set outranking_matrix with index a with index b to 0.0
    
    Return outranking_matrix

Note: PROMETHEE (Preference Ranking Organization METHod for Enrichment Evaluations)
Process called "apply_promethee_method" that takes decision as MultiCriteriaDecision and preference_functions as List[PreferenceFunction] returns Dictionary:
    Let alternatives be decision with field alternatives
    Let criteria be decision with field criteria
    Let decision_matrix be decision with field decision_matrix
    Let criteria_weights be decision with field criteria_weights
    
    Note: Calculate preference indices
    Let preference_indices be calculate_preference_indices with decision_matrix and criteria and preference_functions
    
    Note: Calculate aggregated preference indices
    Let aggregated_preferences be aggregate_preference_indices with preference_indices and criteria_weights
    
    Note: Calculate positive and negative flows
    Let flows be calculate_promethee_flows with aggregated_preferences
    
    Note: PROMETHEE I partial ranking
    Let partial_ranking be create_promethee_partial_ranking with flows
    
    Note: PROMETHEE II complete ranking
    Let complete_ranking be create_promethee_complete_ranking with flows
    
    Return dictionary with keys "preference_indices", "flows", "partial_ranking", "complete_ranking":
        "preference_indices" maps to preference_indices
        "flows" maps to flows
        "partial_ranking" maps to partial_ranking
        "complete_ranking" maps to complete_ranking

Process called "calculate_preference_indices" that takes decision_matrix as Matrix and criteria as List[Criterion] and preference_functions as List[PreferenceFunction] returns Dictionary:
    Let n be length of decision_matrix
    Let m be length of decision_matrix with index 0
    Let preference_indices be empty dictionary
    
    For j from 0 to m minus 1:
        Let criterion be criteria with index j
        Let preference_function be preference_functions with index j
        Let criterion_preferences be create_matrix with n and n
        
        For a from 0 to n minus 1:
            For b from 0 to n minus 1:
                Let value_a be decision_matrix with index a with index j
                Let value_b be decision_matrix with index b with index j
                Let preference_value be calculate_preference_function_value with preference_function and value_a and value_b and criterion
                Set criterion_preferences with index a with index b to preference_value
        
        Set preference_indices with key (criterion with field criterion_id) to criterion_preferences
    
    Return preference_indices

Process called "calculate_promethee_flows" that takes aggregated_preferences as Matrix returns Dictionary:
    Let n be length of aggregated_preferences
    Let positive_flows be create_vector with n
    Let negative_flows be create_vector with n
    Let net_flows be create_vector with n
    
    For a from 0 to n minus 1:
        Note: Calculate positive flow (outgoing)
        Let positive_sum be 0.0
        For b from 0 to n minus 1:
            If a is not equal to b:
                Set positive_sum to positive_sum plus aggregated_preferences with index a with index b
        Set positive_flows with index a to positive_sum divided by (n minus 1) as Float
        
        Note: Calculate negative flow (incoming)
        Let negative_sum be 0.0
        For b from 0 to n minus 1:
            If a is not equal to b:
                Set negative_sum to negative_sum plus aggregated_preferences with index b with index a
        Set negative_flows with index a to negative_sum divided by (n minus 1) as Float
        
        Note: Calculate net flow
        Set net_flows with index a to positive_flows with index a minus negative_flows with index a
    
    Return dictionary with keys "positive", "negative", "net":
        "positive" maps to positive_flows
        "negative" maps to negative_flows
        "net" maps to net_flows

Note: Sensitivity Analysis
Process called "perform_sensitivity_analysis" that takes decision as MultiCriteriaDecision and base_results as Dictionary returns SensitivityAnalysis:
    Let sensitivity_analysis be create_sensitivity_analysis_structure
    Set sensitivity_analysis with field analysis_id to generate_sensitivity_id
    
    Note: Weight sensitivity analysis
    Let weight_sensitivity be analyze_weight_sensitivity with decision and base_results
    Set sensitivity_analysis with field weight_sensitivity to weight_sensitivity
    
    Note: Threshold sensitivity analysis
    Let threshold_sensitivity be analyze_threshold_sensitivity with decision and base_results
    Set sensitivity_analysis with field threshold_sensitivity to threshold_sensitivity
    
    Note: Rank stability analysis
    Let rank_stability be analyze_rank_stability with decision and base_results
    Set sensitivity_analysis with field rank_stability to rank_stability
    
    Return sensitivity_analysis

Process called "analyze_weight_sensitivity" that takes decision as MultiCriteriaDecision and base_results as Dictionary returns Dictionary[String, Dictionary[String, Float]]:
    Let criteria be decision with field criteria
    Let original_weights be decision with field criteria_weights
    Let weight_sensitivity be empty dictionary
    
    For criterion_index from 0 to length of criteria minus 1:
        Let criterion be criteria with index criterion_index
        Let criterion_id be criterion with field criterion_id
        Let criterion_sensitivity be empty dictionary
        
        Note: Test weight variations (±10%, ±20%, ±30%)
        Let variations be list containing negative 0.3, negative 0.2, negative 0.1, 0.1, 0.2, 0.3
        
        For each variation in variations:
            Let modified_weights be copy of original_weights
            Let original_weight be original_weights with index criterion_index
            Let new_weight be original_weight multiplied by (1.0 plus variation)
            
            Note: Ensure weight stays within [0,1] and renormalize
            Set new_weight to maximum of 0.01 and minimum of 0.99 and new_weight
            Set modified_weights with index criterion_index to new_weight
            
            Let normalized_weights be normalize_weights with modified_weights
            
            Note: Recalculate decision with new weights
            Let modified_decision be copy of decision
            Set modified_decision with field criteria_weights to normalized_weights
            let new_results be recalculate_decision_results with modified_decision
            
            Note: Measure impact on ranking
            Let ranking_change be measure_ranking_change with base_results and new_results
            Set criterion_sensitivity with key variation as String to ranking_change
        
        Set weight_sensitivity with key criterion_id to criterion_sensitivity
    
    Return weight_sensitivity

Note: Multi-Objective Optimization
Process called "solve_multi_objective_optimization" that takes objectives as List[Dictionary] and constraints as List[Constraint] and method as String returns Dictionary:
    If method is equal to "weighted_sum":
        Return solve_weighted_sum_optimization with objectives and constraints
    
    If method is equal to "epsilon_constraint":
        Return solve_epsilon_constraint_optimization with objectives and constraints
    
    If method is equal to "pareto_frontier":
        Return find_pareto_frontier with objectives and constraints
    
    If method is equal to "goal_programming":
        Return solve_goal_programming with objectives and constraints
    
    Return empty dictionary

Process called "find_pareto_frontier" that takes objectives as List[Dictionary] and constraints as List[Constraint] returns Dictionary:
    Let pareto_solutions be empty list
    Let dominated_solutions be empty list
    
    Note: Generate candidate solutions
    Let candidate_solutions be generate_candidate_solutions with objectives and constraints
    
    Note: Find non-dominated solutions
    For each solution_a in candidate_solutions:
        Let is_dominated be false
        
        For each solution_b in candidate_solutions:
            If solution_a is not equal to solution_b:
                Let dominates be check_dominance with solution_b and solution_a and objectives
                If dominates is equal to true:
                    Set is_dominated to true
                    Break from loop
        
        If is_dominated is equal to false:
            Add solution_a to pareto_solutions
        Otherwise:
            Add solution_a to dominated_solutions
    
    Return dictionary with keys "pareto_solutions", "dominated_solutions", "pareto_frontier":
        "pareto_solutions" maps to pareto_solutions
        "dominated_solutions" maps to dominated_solutions
        "pareto_frontier" maps to extract_pareto_frontier_data with pareto_solutions and objectives

Note: Main multi-criteria decision coordination
Process called "create_multi_criteria_system" that takes configuration as Dictionary returns Dictionary:
    Let system be empty dictionary
    Set system with key "supported_methods" to configuration with key "methods" or list containing "ahp", "topsis", "electre", "promethee"
    Set system with key "sensitivity_analysis" to configuration with key "sensitivity" or true
    Set system with key "multi_objective" to configuration with key "multi_objective" or false
    Set system with key "preference_elicitation" to configuration with key "preference_elicitation" or false
    
    Return system

Process called "execute_multi_criteria_analysis" that takes system as Dictionary and query as Dictionary returns Dictionary:
    Let query_type be query with key "type"
    Let result be empty dictionary
    
    If query_type is equal to "ahp_analysis":
        Let ahp_config be query with key "ahp_config"
        Let ahp_decision be create_ahp_decision with ahp_config
        
        Note: Perform AHP analysis
        Let criteria_matrix be create_ahp_pairwise_matrix with extract_criteria_names with ahp_decision and query with key "criteria_comparisons"
        let criteria_weights be criteria_matrix with field priority_weights
        Set ahp_decision with field criteria_weights to criteria_weights
        
        Set result with key "ahp_result" to ahp_decision
        Set result with key "consistency_check" to criteria_matrix
    
    If query_type is equal to "topsis_analysis":
        Let decision be query with key "decision"
        Let topsis_result be apply_topsis_method with decision
        Set result with key "topsis_result" to topsis_result
    
    If query_type is equal to "electre_analysis":
        Let decision be query with key "decision"
        Let thresholds be query with key "thresholds"
        Let electre_result be apply_electre_method with decision and thresholds
        Set result with key "electre_result" to electre_result
    
    If query_type is equal to "promethee_analysis":
        Let decision be query with key "decision"
        Let preference_functions be query with key "preference_functions"
        Let promethee_result be apply_promethee_method with decision and preference_functions
        Set result with key "promethee_result" to promethee_result
    
    If query_type is equal to "sensitivity_analysis":
        Let decision be query with key "decision"
        Let base_results be query with key "base_results"
        Let sensitivity_result be perform_sensitivity_analysis with decision and base_results
        Set result with key "sensitivity_analysis" to sensitivity_result
    
    If query_type is equal to "multi_objective_optimization":
        Let objectives be query with key "objectives"
        Let constraints be query with key "constraints"
        Let method be query with key "method" or "pareto_frontier"
        Let optimization_result be solve_multi_objective_optimization with objectives and constraints and method
        Set result with key "optimization_result" to optimization_result
    
    If query_type is equal to "comparative_analysis":
        Let decision be query with key "decision"
        Let methods be query with key "methods" or list containing "topsis", "electre"
        Let comparative_results be empty dictionary
        
        For each method in methods:
            If method is equal to "topsis":
                Set comparative_results with key "topsis" to apply_topsis_method with decision
            
            If method is equal to "electre":
                Let default_thresholds be dictionary with keys "concordance", "discordance":
                    "concordance" maps to 0.6
                    "discordance" maps to 0.3
                Set comparative_results with key "electre" to apply_electre_method with decision and default_thresholds
        
        Set result with key "comparative_analysis" to comparative_results
    
    Note: Add metadata
    Set result with key "multi_criteria_timestamp" to current_timestamp
    Set result with key "system_config" to extract_system_summary with system
    
    Return result