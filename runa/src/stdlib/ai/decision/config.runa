            relative_tolerance as 0.0001
        resource_limits as create_enhanced_resource_limits[]
        quality_requirements as create_financial_quality_requirements[]
        fallback_strategy as "historical_simulation"

Process called "create_utility_config" returns AlgorithmConfig:
