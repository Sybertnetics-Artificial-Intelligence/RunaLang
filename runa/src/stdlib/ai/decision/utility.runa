Note: Advanced Utility Function Optimization System for AI Agents
Note: Implements expected utility theory, multi-attribute utility, prospect theory,
Note: preference learning, and robust utility maximization under uncertainty
Note: Competitive with utility optimization frameworks, behavioral economics models, and decision analysis tools

Note: Core utility types
Type called "UtilityFunction":
    function id as String
    function type as String  Note: "linear", "exponential", "logarithmic", "piecewise", "learned"
    parameters as Dictionary
    domain as List[Float]
    range as List[Float]
    risk attitude as String  Note: "risk_averse", "risk_neutral", "risk_seeking"
    utility values as Dictionary[String, Float]
    derivative function as String
    concavity as String

Type called "MultiAttributeUtility":
    mau id as String
    attributes as List[Attribute]
    attribute weights as Dictionary[String, Float]
    aggregation function as String  Note: "additive", "multiplicative", "multilinear"
    value functions as Dictionary[String, ValueFunction]
    preference structure as PreferenceStructure
    trade off rates as Dictionary[String, Dictionary[String, Float]]

Type called "Attribute":
    attribute id as String
    attribute name as String
    attribute type as String  Note: "continuous", "discrete", "ordinal", "categorical"
    value range as List[Float]
    measurement scale as String
    importance weight as Float
    preference direction as String  Note: "increasing", "decreasing", "single_peaked"

Type called "ValueFunction":
    function id as String
    attribute id as String
    function form as String  Note: "linear", "exponential", "power", "piecewise_linear"
    parameters as List[Float]
    elicitation method as String
    scaling constants as Dictionary
    certainty equivalent as Float

Type called "PreferenceStructure":
    structure id as String
    preference relation as String  Note: "weak_order", "partial_order", "strict_order"
    preference matrix as Matrix
    indifference classes as List[List[String]]
    preference cycles as List[List[String]]
    transitivity violations as List[Dictionary]

Type called "ProspectTheoryModel":
    model id as String
    reference point as Vector
    value function as UtilityFunction
    probability weighting as ProbabilityWeighting
    loss aversion parameter as Float
    diminishing sensitivity as Float
    probability distortion as String
    framing effects as Dictionary

Type called "ProbabilityWeighting":
    weighting id as String
    weighting function as String  Note: "linear", "inverse_s", "prelec", "goldstein_einhorn"
    parameters as Dictionary
    overweighting threshold as Float
    underweighting threshold as Float
    decision weights as Dictionary[String, Float]

Type called "UtilityOptimizer":
    optimizer id as String
    optimization method as String  Note: "analytical", "numerical", "heuristic", "evolutionary"
    objective function as UtilityFunction
    constraints as List[Constraint]
    optimization state as Dictionary
    convergence criteria as Dictionary
    solution quality as Float

Note: Basic Utility Function Creation and Evaluation
Process called "create_utility_function" that takes config as Dictionary returns UtilityFunction:
    Let utility_function be create_utility_function_structure
    Set utility_function with field function_id to generate_utility_function_id
    Set utility_function with field function_type to config with key "type" or "linear"
    Set utility_function with field parameters to config with key "parameters" or empty dictionary
    Set utility_function with field domain to config with key "domain" or list containing 0.0, 1.0
    Set utility_function with field range to config with key "range" or list containing 0.0, 1.0
    Set utility_function with field risk_attitude to config with key "risk_attitude" or "risk_neutral"
    Set utility_function with field utility_values to empty dictionary
    
    Note: Set function-specific parameters
    Let function_type be utility_function with field function_type
    If function_type is equal to "exponential":
        Set utility_function with field concavity to determine_concavity_exponential with utility_function with field parameters
    
    If function_type is equal to "logarithmic":
        Set utility_function with field concavity to "concave"
        Set utility_function with field risk_attitude to "risk_averse"
    
    If function_type is equal to "power":
        Set utility_function with field concavity to determine_concavity_power with utility_function with field parameters
    
    Return utility_function

Process called "evaluate_utility" that takes utility_function as UtilityFunction and outcome as Float returns Float:
    Let function_type be utility_function with field function_type
    Let parameters be utility_function with field parameters
    
    If function_type is equal to "linear":
        Let slope be parameters with key "slope" or 1.0
        Let intercept be parameters with key "intercept" or 0.0
        Return slope multiplied by outcome plus intercept
    
    If function_type is equal to "exponential":
        Let risk_parameter be parameters with key "risk_parameter" or 1.0
        If risk_parameter is equal to 0.0:
            Return outcome  Note: Risk neutral case
        Return (1.0 minus exponential of (negative risk_parameter multiplied by outcome)) divided by risk_parameter
    
    If function_type is equal to "logarithmic":
        Let scale_parameter be parameters with key "scale" or 1.0
        If outcome is less than or equal to 0.0:
            Return negative_infinity
        Return scale_parameter multiplied by natural_logarithm of outcome
    
    If function_type is equal to "power":
        Let alpha be parameters with key "alpha" or 0.5
        If outcome is less than 0.0:
            Return negative_infinity
        Return power of outcome and alpha
    
    If function_type is equal to "piecewise":
        Return evaluate_piecewise_utility with utility_function and outcome
    
    Return outcome  Note: Default identity function

Process called "evaluate_piecewise_utility" that takes utility_function as UtilityFunction and outcome as Float returns Float:
    Let parameters be utility_function with field parameters
    Let breakpoints be parameters with key "breakpoints"
    Let slopes be parameters with key "slopes"
    Let intercepts be parameters with key "intercepts"
    
    Note: Find appropriate piece
    For piece_index from 0 to length of breakpoints minus 2:
        Let lower_bound be breakpoints with index piece_index
        Let upper_bound be breakpoints with index (piece_index plus 1)
        
        If outcome is greater than or equal to lower_bound and outcome is less than upper_bound:
            Let slope be slopes with index piece_index
            Let intercept be intercepts with index piece_index
            Return slope multiplied by outcome plus intercept
    
    Note: Handle boundary cases
    If outcome is less than breakpoints with index 0:
        Let slope be slopes with index 0
        Let intercept be intercepts with index 0
        Return slope multiplied by outcome plus intercept
    
    Let last_piece_index be length of slopes minus 1
    Let slope be slopes with index last_piece_index
    Let intercept be intercepts with index last_piece_index
    Return slope multiplied by outcome plus intercept

Note: Expected Utility Theory
Process called "calculate_expected_utility" that takes utility_function as UtilityFunction and lottery as Dictionary returns Float:
    Let outcomes be lottery with key "outcomes"
    Let probabilities be lottery with key "probabilities"
    Let expected_utility be 0.0
    
    Note: Sum utility of each outcome weighted by probability
    For outcome_index from 0 to length of outcomes minus 1:
        Let outcome be outcomes with index outcome_index
        Let probability be probabilities with index outcome_index
        Let outcome_utility be evaluate_utility with utility_function and outcome
        Set expected_utility to expected_utility plus (probability multiplied by outcome_utility)
    
    Return expected_utility

Process called "find_certainty_equivalent" that takes utility_function as UtilityFunction and lottery as Dictionary returns Float:
    Let expected_util be calculate_expected_utility with utility_function and lottery
    
    Note: Find outcome that gives same utility as lottery
    Return find_utility_inverse with utility_function and expected_util

Process called "find_utility_inverse" that takes utility_function as UtilityFunction and target_utility as Float returns Float:
    Let function_type be utility_function with field function_type
    Let parameters be utility_function with field parameters
    
    If function_type is equal to "linear":
        Let slope be parameters with key "slope" or 1.0
        Let intercept be parameters with key "intercept" or 0.0
        Return (target_utility minus intercept) divided by slope
    
    If function_type is equal to "exponential":
        Let risk_parameter be parameters with key "risk_parameter" or 1.0
        If risk_parameter is equal to 0.0:
            Return target_utility
        Return negative natural_logarithm of (1.0 minus risk_parameter multiplied by target_utility) divided by risk_parameter
    
    If function_type is equal to "logarithmic":
        Let scale_parameter be parameters with key "scale" or 1.0
        Return exponential of (target_utility divided by scale_parameter)
    
    If function_type is equal to "power":
        Let alpha be parameters with key "alpha" or 0.5
        Return power of target_utility and (1.0 divided by alpha)
    
    Note: For complex functions, use numerical methods
    Return numerical_utility_inverse with utility_function and target_utility

Note: Multi-Attribute Utility Theory
Process called "create_multi_attribute_utility" that takes config as Dictionary returns MultiAttributeUtility:
    Let mau be create_multi_attribute_utility_structure
    Set mau with field mau_id to generate_mau_id
    
    Note: Initialize attributes
    Let attribute_configs be config with key "attributes"
    Let attributes be empty list
    For each attribute_config in attribute_configs:
        Let attribute be create_attribute with attribute_config
        Add attribute to attributes
    Set mau with field attributes to attributes
    
    Note: Initialize attribute weights
    Let weight_config be config with key "weights"
    Set mau with field attribute_weights to normalize_weights with weight_config
    
    Set mau with field aggregation_function to config with key "aggregation" or "additive"
    
    Note: Create value functions for each attribute
    Let value_functions be empty dictionary
    For each attribute in attributes:
        Let attribute_id be attribute with field attribute_id
        Let value_function_config be config with key "value_functions" with key attribute_id
        Let value_function be create_value_function with attribute and value_function_config
        Set value_functions with key attribute_id to value_function
    Set mau with field value_functions to value_functions
    
    Set mau with field trade_off_rates to empty dictionary
    
    Return mau

Process called "create_attribute" that takes config as Dictionary returns Attribute:
    Let attribute be create_attribute_structure
    Set attribute with field attribute_id to config with key "id"
    Set attribute with field attribute_name to config with key "name"
    Set attribute with field attribute_type to config with key "type" or "continuous"
    Set attribute with field value_range to config with key "range"
    Set attribute with field measurement_scale to config with key "scale" or "ratio"
    Set attribute with field importance_weight to config with key "weight" or 1.0
    Set attribute with field preference_direction to config with key "direction" or "increasing"
    
    Return attribute

Process called "create_value_function" that takes attribute as Attribute and config as Dictionary returns ValueFunction:
    Let value_function be create_value_function_structure
    Set value_function with field function_id to generate_value_function_id
    Set value_function with field attribute_id to attribute with field attribute_id
    Set value_function with field function_form to config with key "form" or "linear"
    Set value_function with field parameters to config with key "parameters" or empty list
    Set value_function with field elicitation_method to config with key "elicitation" or "direct_rating"
    Set value_function with field scaling_constants to config with key "scaling" or empty dictionary
    
    Return value_function

Process called "evaluate_multi_attribute_utility" that takes mau as MultiAttributeUtility and alternative as Dictionary returns Float:
    Let aggregation_function be mau with field aggregation_function
    Let attributes be mau with field attributes
    let attribute_weights be mau with field attribute_weights
    Let value_functions be mau with field value_functions
    
    If aggregation_function is equal to "additive":
        Return evaluate_additive_utility with mau and alternative
    
    If aggregation_function is equal to "multiplicative":
        Return evaluate_multiplicative_utility with mau and alternative
    
    If aggregation_function is equal to "multilinear":
        Return evaluate_multilinear_utility with mau and alternative
    
    Return 0.0  Note: Default fallback

Process called "evaluate_additive_utility" that takes mau as MultiAttributeUtility and alternative as Dictionary returns Float:
    Let attributes be mau with field attributes
    Let attribute_weights be mau with field attribute_weights
    Let value_functions be mau with field value_functions
    Let total_utility be 0.0
    
    For each attribute in attributes:
        Let attribute_id be attribute with field attribute_id
        Let attribute_value be alternative with key attribute_id
        Let value_function be value_functions with key attribute_id
        Let weight be attribute_weights with key attribute_id
        
        Note: Evaluate single-attribute value function
        Let single_attribute_value be evaluate_single_attribute_value with value_function and attribute_value
        
        Note: Weight and accumulate
        Set total_utility to total_utility plus (weight multiplied by single_attribute_value)
    
    Return total_utility

Process called "evaluate_multiplicative_utility" that takes mau as MultiAttributeUtility and alternative as Dictionary returns Float:
    Let attributes be mau with field attributes
    Let attribute_weights be mau with field attribute_weights
    Let value_functions be mau with field value_functions
    Let utility_product be 1.0
    
    For each attribute in attributes:
        Let attribute_id be attribute with field attribute_id
        Let attribute_value be alternative with key attribute_id
        Let value_function be value_functions with key attribute_id
        Let weight be attribute_weights with key attribute_id
        
        Let single_attribute_value be evaluate_single_attribute_value with value_function and attribute_value
        Let weighted_value be 1.0 plus (weight multiplied by single_attribute_value)
        Set utility_product to utility_product multiplied by weighted_value
    
    Return utility_product minus 1.0

Note: Prospect Theory Implementation
Process called "create_prospect_theory_model" that takes config as Dictionary returns ProspectTheoryModel:
    Let model be create_prospect_theory_model_structure
    Set model with field model_id to generate_prospect_model_id
    Set model with field reference_point to config with key "reference_point"
    
    Note: Create value function (S-shaped)
    Let value_config be config with key "value_function"
    Set model with field value_function to create_prospect_value_function with value_config
    
    Note: Create probability weighting function
    Let weighting_config be config with key "probability_weighting"
    Set model with field probability_weighting to create_probability_weighting with weighting_config
    
    Set model with field loss_aversion_parameter to config with key "loss_aversion" or 2.25
    Set model with field diminishing_sensitivity to config with key "diminishing_sensitivity" or 0.88
    Set model with field probability_distortion to config with key "probability_distortion" or "inverse_s"
    Set model with field framing_effects to config with key "framing" or empty dictionary
    
    Return model

Process called "create_prospect_value_function" that takes config as Dictionary returns UtilityFunction:
    Let value_function be create_utility_function_structure
    Set value_function with field function_id to generate_utility_function_id
    Set value_function with field function_type to "prospect_value"
    
    Note: Prospect theory value function parameters
    Set value_function with field parameters to dictionary with keys "alpha", "beta", "lambda":
        "alpha" maps to config with key "alpha" or 0.88  Note: Diminishing sensitivity for gains
        "beta" maps to config with key "beta" or 0.88   Note: Diminishing sensitivity for losses
        "lambda" maps to config with key "lambda" or 2.25 Note: Loss aversion parameter
    
    Return value_function

Process called "evaluate_prospect_value" that takes model as ProspectTheoryModel and outcome as Float returns Float:
    Let reference_point be model with field reference_point with index 0  Note: Assuming single-attribute for simplicity
    Let value_function be model with field value_function
    Let parameters be value_function with field parameters
    Let alpha be parameters with key "alpha"
    Let beta be parameters with key "beta"
    Let lambda be parameters with key "lambda"
    
    Let deviation be outcome minus reference_point
    
    If deviation is greater than or equal to 0.0:
        Note: Gains domain
        Return power of deviation and alpha
    Otherwise:
        Note: Loss domain
        Let loss_magnitude be absolute_value of deviation
        Return negative lambda multiplied by (power of loss_magnitude and beta)

Process called "create_probability_weighting" that takes config as Dictionary returns ProbabilityWeighting:
    Let weighting be create_probability_weighting_structure
    Set weighting with field weighting_id to generate_weighting_id
    Set weighting with field weighting_function to config with key "function" or "inverse_s"
    Set weighting with field parameters to config with key "parameters" or empty dictionary
    Set weighting with field overweighting_threshold to config with key "overweight_threshold" or 0.3
    Set weighting with field underweighting_threshold to config with key "underweight_threshold" or 0.7
    Set weighting with field decision_weights to empty dictionary
    
    Return weighting

Process called "calculate_decision_weight" that takes weighting as ProbabilityWeighting and probability as Float returns Float:
    Let weighting_function be weighting with field weighting_function
    Let parameters be weighting with field parameters
    
    If weighting_function is equal to "linear":
        Return probability
    
    If weighting_function is equal to "inverse_s":
        Let gamma be parameters with key "gamma" or 0.61
        Return power of probability and gamma divided by power of ((power of probability and gamma) plus (power of (1.0 minus probability) and gamma)) and (1.0 divided by gamma)
    
    If weighting_function is equal to "prelec":
        Let alpha be parameters with key "alpha" or 0.69
        Let beta be parameters with key "beta" or 1.0
        Return exponential of (negative beta multiplied by (power of (negative natural_logarithm of probability) and alpha))
    
    Return probability  Note: Default to linear

Note: Utility Optimization
Process called "create_utility_optimizer" that takes config as Dictionary returns UtilityOptimizer:
    Let optimizer be create_utility_optimizer_structure
    Set optimizer with field optimizer_id to generate_optimizer_id
    Set optimizer with field optimization_method to config with key "method" or "numerical"
    Set optimizer with field objective_function to config with key "objective_function"
    Set optimizer with field constraints to config with key "constraints" or empty list
    
    Set optimizer with field convergence_criteria to dictionary with keys "tolerance", "max_iterations":
        "tolerance" maps to config with key "tolerance" or 0.001
        "max_iterations" maps to config with key "max_iterations" or 1000
    
    Set optimizer with field optimization_state to dictionary with keys "current_iteration", "best_solution", "best_value":
        "current_iteration" maps to 0
        "best_solution" maps to empty dictionary
        "best_value" maps to negative_infinity
    
    Set optimizer with field solution_quality to 0.0
    
    Return optimizer

Process called "optimize_utility" that takes optimizer as UtilityOptimizer and decision_variables as Dictionary returns Dictionary:
    Let optimization_method be optimizer with field optimization_method
    Let objective_function be optimizer with field objective_function
    Let constraints be optimizer with field constraints
    
    If optimization_method is equal to "analytical":
        Return solve_analytically with optimizer and decision_variables
    
    If optimization_method is equal to "numerical":
        Return solve_numerically with optimizer and decision_variables
    
    If optimization_method is equal to "evolutionary":
        Return solve_evolutionary with optimizer and decision_variables
    
    If optimization_method is equal to "gradient_ascent":
        Return solve_gradient_ascent with optimizer and decision_variables
    
    Return dictionary with keys "solution", "optimal_value", "convergence":
        "solution" maps to empty dictionary
        "optimal_value" maps to 0.0
        "convergence" maps to false

Process called "solve_gradient_ascent" that takes optimizer as UtilityOptimizer and initial_point as Dictionary returns Dictionary:
    Let objective_function be optimizer with field objective_function
    Let constraints be optimizer with field constraints
    Let convergence_criteria be optimizer with field convergence_criteria
    Let tolerance be convergence_criteria with key "tolerance"
    let max_iterations be convergence_criteria with key "max_iterations"
    
    Let current_point be copy of initial_point
    Let learning_rate be 0.01
    Let iteration be 0
    
    Note: Gradient ascent main loop
    While iteration is less than max_iterations:
        Note: Calculate gradient
        Let gradient be calculate_utility_gradient with objective_function and current_point
        
        Note: Check convergence
        Let gradient_magnitude be calculate_vector_magnitude with gradient
        If gradient_magnitude is less than tolerance:
            Break from loop
        
        Note: Update point
        For each variable_name in keys of current_point:
            Let current_value be current_point with key variable_name
            Let gradient_component be gradient with key variable_name
            Let new_value be current_value plus (learning_rate multiplied by gradient_component)
            
            Note: Apply constraints
            Set new_value to apply_variable_constraints with constraints and variable_name and new_value
            Set current_point with key variable_name to new_value
        
        Set iteration to iteration plus 1
    
    Let final_utility be evaluate_utility with objective_function and extract_outcome_from_point with current_point
    
    Return dictionary with keys "solution", "optimal_value", "iterations", "convergence":
        "solution" maps to current_point
        "optimal_value" maps to final_utility
        "iterations" maps to iteration
        "convergence" maps to (iteration is less than max_iterations)

Note: Preference Learning and Elicitation
Process called "learn_utility_from_preferences" that takes preference_data as List[Dictionary] and config as Dictionary returns UtilityFunction:
    Let learning_method be config with key "method" or "maximum_likelihood"
    Let function_form be config with key "function_form" or "linear"
    
    If learning_method is equal to "maximum_likelihood":
        Return learn_utility_maximum_likelihood with preference_data and function_form
    
    If learning_method is equal to "support_vector":
        Return learn_utility_svm with preference_data and function_form
    
    If learning_method is equal to "neural_network":
        Return learn_utility_neural with preference_data and function_form
    
    Return create_utility_function with config  Note: Default fallback

Process called "learn_utility_maximum_likelihood" that takes preference_data as List[Dictionary] and function_form as String returns UtilityFunction:
    Let utility_function be create_utility_function with dictionary with keys "type":
        "type" maps to function_form
    
    Note: Extract pairwise comparisons
    Let pairwise_comparisons be extract_pairwise_comparisons with preference_data
    
    Note: Set up likelihood function
    Let parameter_space be define_parameter_space with function_form
    Let best_parameters be empty dictionary
    Let best_likelihood be negative_infinity
    
    Note: Search parameter space
    For each parameter_set in parameter_space:
        Set utility_function with field parameters to parameter_set
        Let likelihood be calculate_likelihood with utility_function and pairwise_comparisons
        
        If likelihood is greater than best_likelihood:
            Set best_likelihood to likelihood
            Set best_parameters to parameter_set
    
    Set utility_function with field parameters to best_parameters
    Return utility_function

Process called "elicit_utility_function" that takes config as Dictionary returns UtilityFunction:
    Let elicitation_method be config with key "method" or "certainty_equivalent"
    Let attribute_range be config with key "attribute_range"
    
    If elicitation_method is equal to "certainty_equivalent":
        Return elicit_by_certainty_equivalent with attribute_range and config
    
    If elicitation_method is equal to "probability_equivalent":
        Return elicit_by_probability_equivalent with attribute_range and config
    
    If elicitation_method is equal to "trade_off":
        Return elicit_by_trade_off with attribute_range and config
    
    Return create_utility_function with config

Process called "elicit_by_certainty_equivalent" that takes attribute_range as List[Float] and config as Dictionary returns UtilityFunction:
    Let min_value be attribute_range with index 0
    Let max_value be attribute_range with index 1
    Let elicitation_points be config with key "elicitation_points" or list containing 0.25, 0.5, 0.75
    
    Let utility_points be empty list
    
    Note: Elicit certainty equivalents for lotteries
    For each probability in elicitation_points:
        Let lottery be dictionary with keys "outcomes", "probabilities":
            "outcomes" maps to list containing min_value, max_value
            "probabilities" maps to list containing probability, (1.0 minus probability)
        
        Note: Get certainty equivalent from user (simulated here)
        Let certainty_equivalent be simulate_certainty_equivalent_response with lottery
        
        Let utility_point be dictionary with keys "outcome", "utility":
            "outcome" maps to certainty_equivalent
            "utility" maps to probability  Note: Normalized utility
        Add utility_point to utility_points
    
    Note: Fit utility function to elicited points
    Return fit_utility_function_to_points with utility_points and config

Note: Main utility optimization coordination
Process called "create_utility_system" that takes configuration as Dictionary returns Dictionary:
    Let system be empty dictionary
    Set system with key "utility_types" to configuration with key "supported_utilities" or list containing "linear", "exponential", "prospect"
    Set system with key "multi_attribute" to configuration with key "multi_attribute" or false
    Set system with key "preference_learning" to configuration with key "preference_learning" or false
    Set system with key "optimization_methods" to configuration with key "optimization" or list containing "analytical", "numerical"
    
    Return system

Process called "execute_utility_optimization" that takes system as Dictionary and query as Dictionary returns Dictionary:
    Let query_type be query with key "type"
    Let result be empty dictionary
    
    If query_type is equal to "evaluate_utility":
        Let utility_function be query with key "utility_function"
        Let outcome be query with key "outcome"
        Let utility_value be evaluate_utility with utility_function and outcome
        Set result with key "utility_value" to utility_value
    
    If query_type is equal to "expected_utility":
        Let utility_function be query with key "utility_function"
        Let lottery be query with key "lottery"
        Let expected_util be calculate_expected_utility with utility_function and lottery
        Set result with key "expected_utility" to expected_util
        
        Let certainty_equivalent be find_certainty_equivalent with utility_function and lottery
        Set result with key "certainty_equivalent" to certainty_equivalent
    
    If query_type is equal to "multi_attribute_evaluation":
        Let mau be query with key "multi_attribute_utility"
        Let alternative be query with key "alternative"
        Let mau_value be evaluate_multi_attribute_utility with mau and alternative
        Set result with key "multi_attribute_value" to mau_value
    
    If query_type is equal to "prospect_theory":
        Let prospect_model be query with key "prospect_model"
        Let outcome be query with key "outcome"
        Let prospect_value be evaluate_prospect_value with prospect_model and outcome
        Set result with key "prospect_value" to prospect_value
    
    If query_type is equal to "utility_optimization":
        Let optimizer be query with key "optimizer"
        Let decision_variables be query with key "variables"
        Let optimization_result be optimize_utility with optimizer and decision_variables
        Set result with key "optimization_result" to optimization_result
    
    If query_type is equal to "preference_learning":
        Let preference_data be query with key "preference_data"
        Let learning_config be query with key "learning_config"
        Let learned_utility be learn_utility_from_preferences with preference_data and learning_config
        Set result with key "learned_utility" to learned_utility
    
    If query_type is equal to "utility_elicitation":
        Let elicitation_config be query with key "elicitation_config"
        Let elicited_utility be elicit_utility_function with elicitation_config
        Set result with key "elicited_utility" to elicited_utility
    
    Note: Add metadata
    Set result with key "utility_timestamp" to current_timestamp
    Set result with key "system_config" to extract_system_summary with system
    
    Return result