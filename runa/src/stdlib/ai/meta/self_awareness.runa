Note: Self-Awareness System for AI Agents
Implements introspective capabilities, cognitive state monitoring, capability assessment,
limitation recognition, performance evaluation, and metacognitive self-understanding
Competitive with advanced AI self-modeling and self-reflective systems :End Note

Type called "SelfAwarenessState":
    awareness id as String
    cognitive state as CognitiveState
    capability assessment as CapabilityAssessment
    limitation awareness as LimitationAwareness
    performance metrics as PerformanceMetrics
    self model as SelfModel
    temporal context as TemporalSelfContext
    confidence level as Float
    last update timestamp as Integer

Type called "CognitiveState":
    current focus as String
    attention allocation as AttentionAllocation
    working memory state as WorkingMemoryState
    processing load as ProcessingLoad
    cognitive resources as CognitiveResources
    mental fatigue level as Float
    emotional state as EmotionalState
    goal stack as List[Goal]

Type called "AttentionAllocation":
    primary focus as String
    secondary foci as List[String]
    attention distribution as Dictionary[String, Float]
    focus stability as Float
    distraction level as Float
    attention switching frequency as Float
    cognitive control strength as Float

Type called "WorkingMemoryState":
    active items as List[MemoryItem]
    memory capacity utilization as Float
    maintenance strength as Float
    interference level as Float
    rehearsal strategies as List[String]
    memory decay rate as Float
    chunking effectiveness as Float

Type called "ProcessingLoad":
    computational load as Float
    memory usage as Float
    network bandwidth utilization as Float
    concurrent task count as Integer
    processing complexity as Float
    resource bottlenecks as List[String]
    efficiency metrics as EfficiencyMetrics

Type called "CapabilityAssessment":
    core capabilities as List[Capability]
    learned skills as List[Skill]
    performance baselines as Dictionary[String, Float]
    improvement trajectories as Dictionary[String, List[Float]]
    capability gaps as List[CapabilityGap]
    strength areas as List[String]
    development potential as Dictionary[String, Float]

Type called "Capability":
    capability id as String
    capability name as String
    capability type as String  Note: "cognitive", "motor", "sensory", "linguistic", "analytical"
    proficiency level as Float
    consistency rating as Float
    reliability score as Float
    context dependencies as List[String]
    improvement trend as String  Note: "improving", "stable", "declining"

Type called "LimitationAwareness":
    known limitations as List[Limitation]
    unknown limitation indicators as List[String]
    limitation impact assessment as Dictionary[String, Float]
    workaround strategies as Dictionary[String, List[String]]
    limitation categories as Dictionary[String, List[String]]
    adaptive responses as List[AdaptiveResponse]

Type called "Limitation":
    limitation id as String
    limitation type as String  Note: "computational", "knowledge", "perceptual", "reasoning", "memory"
    description as String
    severity level as Float
    frequency of occurrence as Float
    contexts where apparent as List[String]
    impact on performance as Float
    mitigation strategies as List[String]

Type called "SelfModel":
    identity representation as IdentityRepresentation
    behavioral patterns as List[BehavioralPattern]
    personality traits as Dictionary[String, Float]
    value system as ValueSystem
    goal hierarchy as GoalHierarchy
    decision making style as DecisionMakingStyle
    learning preferences as LearningPreferences
    social interaction model as SocialInteractionModel

Type called "IdentityRepresentation":
    self concept as String
    role definitions as List[String]
    core attributes as Dictionary[String, Any]
    identity stability as Float
    identity coherence as Float
    self complexity as Float
    identity development stage as String

Type called "TemporalSelfContext":
    past self states as List[SelfAwarenessState]
    predicted future states as List[PredictedSelfState]
    temporal identity continuity as Float
    developmental trajectory as DevelopmentalTrajectory
    experience accumulation as ExperienceAccumulation
    temporal perspective as TemporalPerspective

Note: Self-Awareness Engine
Process called "create_self_awareness_system" that takes config as Dictionary returns Dictionary:
    Let self_awareness_system be create_self_awareness_structure
    Set self_awareness_system with key "system_id" to generate_self_awareness_id
    Set self_awareness_system with key "monitoring_frequency" to config with key "monitoring_frequency" or 1000
    Set self_awareness_system with key "introspection_depth" to config with key "introspection_depth" or 3
    Set self_awareness_system with key "capability_tracking" to config with key "capability_tracking" or true
    Set self_awareness_system with key "limitation_detection" to config with key "limitation_detection" or true
    Set self_awareness_system with key "performance_monitoring" to config with key "performance_monitoring" or true
    Set self_awareness_system with key "temporal_modeling" to config with key "temporal_modeling" or true
    Set self_awareness_system with key "metacognitive_processing" to config with key "metacognitive_processing" or true
    
    Note: Initialize self-monitoring components
    Let monitoring_components be initialize_self_monitoring_components with config
    Set self_awareness_system with key "monitoring_components" to monitoring_components
    
    Note: Initialize self-model
    Let initial_self_model be initialize_self_model with config
    Set self_awareness_system with key "self_model" to initial_self_model
    
    Note: Initialize awareness state
    Let initial_awareness_state be create_initial_awareness_state with self_awareness_system
    Set self_awareness_system with key "current_state" to initial_awareness_state
    
    Return self_awareness_system

Process called "monitor_self_awareness" that takes self_awareness_system as Dictionary and current_context as Dictionary returns Dictionary:
    Let awareness_result be empty dictionary
    Set awareness_result with key "monitoring_id" to generate_monitoring_id
    Set awareness_result with key "monitoring_timestamp" to current_timestamp
    
    Note: Phase 1: Monitor current cognitive state
    Let cognitive_monitoring_result be monitor_cognitive_state with self_awareness_system and current_context
    Set awareness_result with key "cognitive_monitoring" to cognitive_monitoring_result
    
    Note: Phase 2: Assess current capabilities and limitations
    Let capability_assessment_result be assess_current_capabilities with self_awareness_system and current_context
    Set awareness_result with key "capability_assessment" to capability_assessment_result
    
    Note: Phase 3: Evaluate performance and learning
    Let performance_evaluation_result be evaluate_current_performance with self_awareness_system and current_context
    Set awareness_result with key "performance_evaluation" to performance_evaluation_result
    
    Note: Phase 4: Update self-model
    Let self_model_update_result be update_self_model with self_awareness_system and awareness_result
    Set awareness_result with key "self_model_update" to self_model_update_result
    
    Note: Phase 5: Generate self-awareness insights
    Let awareness_insights be generate_self_awareness_insights with awareness_result and self_awareness_system
    Set awareness_result with key "awareness_insights" to awareness_insights
    
    Note: Update system state
    Let updated_awareness_state be create_updated_awareness_state with awareness_result and self_awareness_system
    Set self_awareness_system with key "current_state" to updated_awareness_state
    
    Return awareness_result

Process called "monitor_cognitive_state" that takes self_awareness_system as Dictionary and context as Dictionary returns Dictionary:
    Let cognitive_monitoring be empty dictionary
    Set cognitive_monitoring with key "monitoring_type" to "comprehensive_cognitive_monitoring"
    
    Note: Monitor attention allocation
    Let attention_monitoring be monitor_attention_allocation with self_awareness_system and context
    Set cognitive_monitoring with key "attention_monitoring" to attention_monitoring
    
    Note: Monitor working memory state
    Let memory_monitoring be monitor_working_memory_state with self_awareness_system and context
    Set cognitive_monitoring with key "memory_monitoring" to memory_monitoring
    
    Note: Monitor processing load
    Let load_monitoring be monitor_processing_load with self_awareness_system and context
    Set cognitive_monitoring with key "load_monitoring" to load_monitoring
    
    Note: Monitor cognitive resources
    Let resource_monitoring be monitor_cognitive_resources with self_awareness_system and context
    Set cognitive_monitoring with key "resource_monitoring" to resource_monitoring
    
    Note: Monitor emotional state
    Let emotional_monitoring be monitor_emotional_state with self_awareness_system and context
    Set cognitive_monitoring with key "emotional_monitoring" to emotional_monitoring
    
    Note: Monitor goal management
    Let goal_monitoring be monitor_goal_management with self_awareness_system and context
    Set cognitive_monitoring with key "goal_monitoring" to goal_monitoring
    
    Note: Generate cognitive state assessment
    Let cognitive_state be create_cognitive_state_structure
    Set cognitive_state with field current_focus to attention_monitoring with key "primary_focus"
    Set cognitive_state with field attention_allocation to attention_monitoring with key "attention_allocation"
    Set cognitive_state with field working_memory_state to memory_monitoring with key "memory_state"
    Set cognitive_state with field processing_load to load_monitoring with key "processing_load"
    Set cognitive_state with field cognitive_resources to resource_monitoring with key "resources"
    Set cognitive_state with field mental_fatigue_level to calculate_mental_fatigue with cognitive_monitoring
    Set cognitive_state with field emotional_state to emotional_monitoring with key "emotional_state"
    Set cognitive_state with field goal_stack to goal_monitoring with key "active_goals"
    
    Set cognitive_monitoring with key "cognitive_state" to cognitive_state
    
    Return cognitive_monitoring

Process called "monitor_attention_allocation" that takes self_awareness_system as Dictionary and context as Dictionary returns Dictionary:
    Let attention_monitoring be empty dictionary
    Set attention_monitoring with key "monitoring_method" to "attention_tracking_system"
    
    Note: Identify current primary focus
    Let primary_focus be identify_primary_attention_focus with context and self_awareness_system
    Set attention_monitoring with key "primary_focus" to primary_focus
    
    Note: Identify secondary attention targets
    Let secondary_foci be identify_secondary_attention_targets with context and self_awareness_system
    Set attention_monitoring with key "secondary_foci" to secondary_foci
    
    Note: Calculate attention distribution
    Let attention_distribution be calculate_attention_distribution with primary_focus and secondary_foci
    Set attention_monitoring with key "attention_distribution" to attention_distribution
    
    Note: Assess attention stability
    Let attention_stability be assess_attention_stability with self_awareness_system and context
    Set attention_monitoring with key "attention_stability" to attention_stability
    
    Note: Measure distraction level
    Let distraction_level be measure_current_distraction_level with context and self_awareness_system
    Set attention_monitoring with key "distraction_level" to distraction_level
    
    Note: Track attention switching
    Let switching_frequency be calculate_attention_switching_frequency with self_awareness_system
    Set attention_monitoring with key "switching_frequency" to switching_frequency
    
    Note: Evaluate cognitive control
    Let cognitive_control_strength be evaluate_cognitive_control_strength with attention_monitoring
    Set attention_monitoring with key "cognitive_control_strength" to cognitive_control_strength
    
    Note: Create attention allocation structure
    Let attention_allocation be create_attention_allocation_structure
    Set attention_allocation with field primary_focus to primary_focus
    Set attention_allocation with field secondary_foci to secondary_foci
    Set attention_allocation with field attention_distribution to attention_distribution
    Set attention_allocation with field focus_stability to attention_stability
    Set attention_allocation with field distraction_level to distraction_level
    Set attention_allocation with field attention_switching_frequency to switching_frequency
    Set attention_allocation with field cognitive_control_strength to cognitive_control_strength
    
    Set attention_monitoring with key "attention_allocation" to attention_allocation
    
    Return attention_monitoring

Process called "assess_current_capabilities" that takes self_awareness_system as Dictionary and context as Dictionary returns Dictionary:
    Let capability_assessment be empty dictionary
    Set capability_assessment with key "assessment_type" to "real_time_capability_assessment"
    
    Note: Assess core cognitive capabilities
    Let cognitive_capabilities be assess_cognitive_capabilities with self_awareness_system and context
    Set capability_assessment with key "cognitive_capabilities" to cognitive_capabilities
    
    Note: Assess learned skills and competencies
    Let learned_skills be assess_learned_skills with self_awareness_system and context
    Set capability_assessment with key "learned_skills" to learned_skills
    
    Note: Evaluate performance against baselines
    Let performance_comparison be compare_against_performance_baselines with self_awareness_system and context
    Set capability_assessment with key "performance_comparison" to performance_comparison
    
    Note: Identify capability gaps
    Let capability_gaps be identify_current_capability_gaps with self_awareness_system and context
    Set capability_assessment with key "capability_gaps" to capability_gaps
    
    Note: Assess strength areas
    Let strength_areas be identify_current_strength_areas with self_awareness_system and context
    Set capability_assessment with key "strength_areas" to strength_areas
    
    Note: Evaluate development potential
    Let development_potential be assess_development_potential with self_awareness_system and context
    Set capability_assessment with key "development_potential" to development_potential
    
    Note: Create comprehensive capability assessment
    Let capability_assessment_structure be create_capability_assessment_structure
    Set capability_assessment_structure with field core_capabilities to cognitive_capabilities
    Set capability_assessment_structure with field learned_skills to learned_skills
    Set capability_assessment_structure with field performance_baselines to performance_comparison with key "current_baselines"
    Set capability_assessment_structure with field improvement_trajectories to calculate_improvement_trajectories with self_awareness_system
    Set capability_assessment_structure with field capability_gaps to capability_gaps
    Set capability_assessment_structure with field strength_areas to strength_areas
    Set capability_assessment_structure with field development_potential to development_potential
    
    Set capability_assessment with key "capability_assessment" to capability_assessment_structure
    
    Return capability_assessment

Process called "assess_cognitive_capabilities" that takes self_awareness_system as Dictionary and context as Dictionary returns List[Capability]:
    Let cognitive_capabilities be empty list
    
    Note: Assess reasoning capabilities
    Let reasoning_capability be assess_reasoning_capability with self_awareness_system and context
    Add reasoning_capability to cognitive_capabilities
    
    Note: Assess memory capabilities
    Let memory_capability be assess_memory_capability with self_awareness_system and context
    Add memory_capability to cognitive_capabilities
    
    Note: Assess attention and focus capabilities
    Let attention_capability be assess_attention_capability with self_awareness_system and context
    Add attention_capability to cognitive_capabilities
    
    Note: Assess learning capabilities
    Let learning_capability be assess_learning_capability with self_awareness_system and context
    Add learning_capability to cognitive_capabilities
    
    Note: Assess problem-solving capabilities
    Let problem_solving_capability be assess_problem_solving_capability with self_awareness_system and context
    Add problem_solving_capability to cognitive_capabilities
    
    Note: Assess creativity capabilities
    Let creativity_capability be assess_creativity_capability with self_awareness_system and context
    Add creativity_capability to cognitive_capabilities
    
    Note: Assess communication capabilities
    Let communication_capability be assess_communication_capability with self_awareness_system and context
    Add communication_capability to cognitive_capabilities
    
    Note: Assess metacognitive capabilities
    Let metacognitive_capability be assess_metacognitive_capability with self_awareness_system and context
    Add metacognitive_capability to cognitive_capabilities
    
    Return cognitive_capabilities

Process called "assess_reasoning_capability" that takes self_awareness_system as Dictionary and context as Dictionary returns Capability:
    Let reasoning_capability be create_capability_structure
    Set reasoning_capability with field capability_id to generate_capability_id
    Set reasoning_capability with field capability_name to "Logical Reasoning"
    Set reasoning_capability with field capability_type to "cognitive"
    
    Note: Evaluate logical reasoning proficiency
    Let logical_reasoning_score be evaluate_logical_reasoning_proficiency with self_awareness_system and context
    
    Note: Evaluate analogical reasoning
    Let analogical_reasoning_score be evaluate_analogical_reasoning_proficiency with self_awareness_system and context
    
    Note: Evaluate causal reasoning
    Let causal_reasoning_score be evaluate_causal_reasoning_proficiency with self_awareness_system and context
    
    Note: Evaluate probabilistic reasoning
    Let probabilistic_reasoning_score be evaluate_probabilistic_reasoning_proficiency with self_awareness_system and context
    
    Note: Calculate overall reasoning proficiency
    Let overall_proficiency be (logical_reasoning_score plus analogical_reasoning_score plus causal_reasoning_score plus probabilistic_reasoning_score) divided by 4.0
    Set reasoning_capability with field proficiency_level to overall_proficiency
    
    Note: Assess consistency and reliability
    Let reasoning_consistency be assess_reasoning_consistency with self_awareness_system
    Set reasoning_capability with field consistency_rating to reasoning_consistency
    
    Let reasoning_reliability be assess_reasoning_reliability with self_awareness_system and context
    Set reasoning_capability with field reliability_score to reasoning_reliability
    
    Note: Identify context dependencies
    Let context_dependencies be identify_reasoning_context_dependencies with self_awareness_system
    Set reasoning_capability with field context_dependencies to context_dependencies
    
    Note: Determine improvement trend
    Let improvement_trend be determine_reasoning_improvement_trend with self_awareness_system
    Set reasoning_capability with field improvement_trend to improvement_trend
    
    Return reasoning_capability

Process called "detect_self_awareness_limitations" that takes self_awareness_system as Dictionary and context as Dictionary returns Dictionary:
    Let limitation_detection be empty dictionary
    Set limitation_detection with key "detection_method" to "comprehensive_limitation_detection"
    Set limitation_detection with key "detected_limitations" to empty list
    
    Note: Detect computational limitations
    Let computational_limitations be detect_computational_limitations with self_awareness_system and context
    Add computational_limitations to limitation_detection with key "detected_limitations"
    
    Note: Detect knowledge limitations
    Let knowledge_limitations be detect_knowledge_limitations with self_awareness_system and context
    Add knowledge_limitations to limitation_detection with key "detected_limitations"
    
    Note: Detect perceptual limitations
    Let perceptual_limitations be detect_perceptual_limitations with self_awareness_system and context
    Add perceptual_limitations to limitation_detection with key "detected_limitations"
    
    Note: Detect reasoning limitations
    Let reasoning_limitations be detect_reasoning_limitations with self_awareness_system and context
    Add reasoning_limitations to limitation_detection with key "detected_limitations"
    
    Note: Detect memory limitations
    Let memory_limitations be detect_memory_limitations with self_awareness_system and context
    Add memory_limitations to limitation_detection with key "detected_limitations"
    
    Note: Detect social interaction limitations
    Let social_limitations be detect_social_interaction_limitations with self_awareness_system and context
    Add social_limitations to limitation_detection with key "detected_limitations"
    
    Note: Assess impact of limitations
    Let limitation_impact_assessment be assess_limitation_impacts with limitation_detection with key "detected_limitations"
    Set limitation_detection with key "impact_assessment" to limitation_impact_assessment
    
    Note: Generate workaround strategies
    Let workaround_strategies be generate_limitation_workaround_strategies with limitation_detection with key "detected_limitations"
    Set limitation_detection with key "workaround_strategies" to workaround_strategies
    
    Note: Create limitation awareness structure
    Let limitation_awareness be create_limitation_awareness_structure
    Set limitation_awareness with field known_limitations to limitation_detection with key "detected_limitations"
    Set limitation_awareness with field limitation_impact_assessment to limitation_impact_assessment
    Set limitation_awareness with field workaround_strategies to workaround_strategies
    
    Set limitation_detection with key "limitation_awareness" to limitation_awareness
    
    Return limitation_detection

Process called "update_self_model" that takes self_awareness_system as Dictionary and awareness_result as Dictionary returns Dictionary:
    Let self_model_update be empty dictionary
    Set self_model_update with key "update_type" to "comprehensive_self_model_update"
    
    Let current_self_model be self_awareness_system with key "self_model"
    Let updated_self_model be copy of current_self_model
    
    Note: Update identity representation
    Let identity_updates be update_identity_representation with current_self_model and awareness_result
    Set updated_self_model with field identity_representation to identity_updates
    
    Note: Update behavioral patterns
    Let behavioral_pattern_updates be update_behavioral_patterns with current_self_model and awareness_result
    Set updated_self_model with field behavioral_patterns to behavioral_pattern_updates
    
    Note: Update personality traits
    Let personality_updates be update_personality_traits with current_self_model and awareness_result
    Set updated_self_model with field personality_traits to personality_updates
    
    Note: Update value system
    Let value_system_updates be update_value_system with current_self_model and awareness_result
    Set updated_self_model with field value_system to value_system_updates
    
    Note: Update goal hierarchy
    Let goal_hierarchy_updates be update_goal_hierarchy with current_self_model and awareness_result
    Set updated_self_model with field goal_hierarchy to goal_hierarchy_updates
    
    Note: Update decision making style
    Let decision_style_updates be update_decision_making_style with current_self_model and awareness_result
    Set updated_self_model with field decision_making_style to decision_style_updates
    
    Note: Update learning preferences
    Let learning_preference_updates be update_learning_preferences with current_self_model and awareness_result
    Set updated_self_model with field learning_preferences to learning_preference_updates
    
    Note: Calculate self-model coherence
    Let model_coherence be calculate_self_model_coherence with updated_self_model
    Set self_model_update with key "model_coherence" to model_coherence
    
    Note: Calculate self-model stability
    Let model_stability be calculate_self_model_stability with current_self_model and updated_self_model
    Set self_model_update with key "model_stability" to model_stability
    
    Set self_model_update with key "updated_self_model" to updated_self_model
    Set self_awareness_system with key "self_model" to updated_self_model
    
    Return self_model_update

Process called "generate_self_awareness_insights" that takes awareness_result as Dictionary and self_awareness_system as Dictionary returns Dictionary:
    Let insights_result be empty dictionary
    Set insights_result with key "insight_generation_method" to "comprehensive_self_awareness_analysis"
    Set insights_result with key "insights" to empty list
    
    Note: Generate cognitive state insights
    Let cognitive_insights be generate_cognitive_state_insights with awareness_result with key "cognitive_monitoring"
    Add cognitive_insights to insights_result with key "insights"
    
    Note: Generate capability insights
    Let capability_insights be generate_capability_insights with awareness_result with key "capability_assessment"
    Add capability_insights to insights_result with key "insights"
    
    Note: Generate performance insights
    Let performance_insights be generate_performance_insights with awareness_result with key "performance_evaluation"
    Add performance_insights to insights_result with key "insights"
    
    Note: Generate self-model insights
    Let self_model_insights be generate_self_model_insights with awareness_result with key "self_model_update"
    Add self_model_insights to insights_result with key "insights"
    
    Note: Generate temporal insights
    Let temporal_insights be generate_temporal_self_insights with self_awareness_system
    Add temporal_insights to insights_result with key "insights"
    
    Note: Generate metacognitive insights
    Let metacognitive_insights be generate_metacognitive_insights with awareness_result and self_awareness_system
    Add metacognitive_insights to insights_result with key "insights"
    
    Note: Generate actionable recommendations
    Let actionable_recommendations be generate_self_improvement_recommendations with insights_result and self_awareness_system
    Set insights_result with key "actionable_recommendations" to actionable_recommendations
    
    Note: Calculate insight confidence
    Let insight_confidence be calculate_insight_confidence with insights_result
    Set insights_result with key "insight_confidence" to insight_confidence
    
    Return insights_result

Process called "perform_self_reflection" that takes self_awareness_system as Dictionary and reflection_query as Dictionary returns Dictionary:
    Let reflection_result be empty dictionary
    Set reflection_result with key "reflection_type" to "guided_self_reflection"
    Set reflection_result with key "reflection_timestamp" to current_timestamp
    
    Let query_type be reflection_query with key "type"
    
    If query_type is equal to "capability_reflection":
        Let capability_reflection be reflect_on_capabilities with self_awareness_system and reflection_query
        Set reflection_result with key "capability_reflection" to capability_reflection
    
    If query_type is equal to "limitation_reflection":
        Let limitation_reflection be reflect_on_limitations with self_awareness_system and reflection_query
        Set reflection_result with key "limitation_reflection" to limitation_reflection
    
    If query_type is equal to "goal_reflection":
        Let goal_reflection be reflect_on_goals with self_awareness_system and reflection_query
        Set reflection_result with key "goal_reflection" to goal_reflection
    
    If query_type is equal to "identity_reflection":
        Let identity_reflection be reflect_on_identity with self_awareness_system and reflection_query
        Set reflection_result with key "identity_reflection" to identity_reflection
    
    If query_type is equal to "performance_reflection":
        Let performance_reflection be reflect_on_performance with self_awareness_system and reflection_query
        Set reflection_result with key "performance_reflection" to performance_reflection
    
    If query_type is equal to "learning_reflection":
        Let learning_reflection be reflect_on_learning with self_awareness_system and reflection_query
        Set reflection_result with key "learning_reflection" to learning_reflection
    
    Note: Generate reflection insights
    Let reflection_insights be generate_reflection_insights with reflection_result and self_awareness_system
    Set reflection_result with key "reflection_insights" to reflection_insights
    
    Note: Update self-awareness based on reflection
    Let reflection_updates be apply_reflection_updates with reflection_result and self_awareness_system
    Set reflection_result with key "self_awareness_updates" to reflection_updates
    
    Return reflection_result

Note: Main self-awareness system coordination
Process called "create_self_awareness_monitoring_system" that takes configuration as Dictionary returns Dictionary:
    Let system be empty dictionary
    Set system with key "monitoring_frequency" to configuration with key "monitoring_frequency" or 1000
    Set system with key "introspection_depth" to configuration with key "introspection_depth" or 3
    Set system with key "self_modeling" to configuration with key "self_modeling" or true
    Set system with key "capability_tracking" to configuration with key "capability_tracking" or true
    Set system with key "limitation_detection" to configuration with key "limitation_detection" or true
    Set system with key "temporal_awareness" to configuration with key "temporal_awareness" or true
    Set system with key "metacognitive_processing" to configuration with key "metacognitive_processing" or true
    Set system with key "reflection_capabilities" to configuration with key "reflection_capabilities" or true
    
    Return system

Process called "execute_self_awareness_analysis" that takes system as Dictionary and query as Dictionary returns Dictionary:
    Let query_type be query with key "type"
    Let result be empty dictionary
    
    If query_type is equal to "monitor_self_awareness":
        Let context be query with key "context"
        Let monitoring_config be query with key "monitoring_config"
        
        Let self_awareness_system be create_self_awareness_system with monitoring_config
        Let monitoring_result be monitor_self_awareness with self_awareness_system and context
        Set result with key "monitoring_result" to monitoring_result
    
    If query_type is equal to "assess_capabilities":
        Let context be query with key "context"
        Let assessment_config be query with key "assessment_config"
        
        Let self_awareness_system be create_self_awareness_system with assessment_config
        Let capability_assessment be assess_current_capabilities with self_awareness_system and context
        Set result with key "capability_assessment" to capability_assessment
    
    If query_type is equal to "detect_limitations":
        Let context be query with key "context"
        Let detection_config be query with key "detection_config"
        
        Let self_awareness_system be create_self_awareness_system with detection_config
        Let limitation_detection be detect_self_awareness_limitations with self_awareness_system and context
        Set result with key "limitation_detection" to limitation_detection
    
    If query_type is equal to "self_reflection":
        Let reflection_query be query with key "reflection_query"
        Let reflection_config be query with key "reflection_config"
        
        Let self_awareness_system be create_self_awareness_system with reflection_config
        Let reflection_result be perform_self_reflection with self_awareness_system and reflection_query
        Set result with key "reflection_result" to reflection_result
    
    If query_type is equal to "cognitive_monitoring":
        Let context be query with key "context"
        Let cognitive_config be query with key "cognitive_config"
        
        Let self_awareness_system be create_self_awareness_system with cognitive_config
        Let cognitive_monitoring_result be monitor_cognitive_state with self_awareness_system and context
        Set result with key "cognitive_monitoring_result" to cognitive_monitoring_result
    
    If query_type is equal to "self_model_update":
        Let awareness_data be query with key "awareness_data"
        Let update_config be query with key "update_config"
        
        Let self_awareness_system be create_self_awareness_system with update_config
        Let self_model_update be update_self_model with self_awareness_system and awareness_data
        Set result with key "self_model_update" to self_model_update
    
    Note: Add metadata
    Set result with key "self_awareness_timestamp" to current_timestamp
    Set result with key "system_config" to extract_system_summary with system
    
    Return result