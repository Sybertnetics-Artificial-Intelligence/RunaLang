Note: Advanced Hierarchical Task Network (HTN) Planning System for AI Agents
Note: Implements HTN planning, task decomposition, method selection,
Note: and hierarchical goal achievement with complex task networks
Note: Competitive with SHOP, SIPE, and hierarchical planning systems

Note: Core HTN types and structures
Type called "Task":
    task id as String
    task name as String
    task type as String  Note: "primitive", "compound", "abstract"
    task parameters as List[String]
    task preconditions as List[Condition]
    task effects as List[Condition]
    task constraints as List[Constraint]
    execution_duration as Integer
    execution_cost as Float
    resource_requirements as Dictionary[String, Float]

Type called "Method":
    method id as String
    method name as String
    compound_task as String
    method_parameters as List[String]
    method_preconditions as List[Condition]
    subtasks as List[Task]
    subtask_ordering as List[OrderingConstraint]
    method_priority as Float
    method_applicability as Dictionary[String, Any]

Type called "TaskNetwork":
    network id as String
    network name as String
    tasks as List[Task]
    ordering_constraints as List[OrderingConstraint]
    variable_bindings as Dictionary[String, Any]
    causal_links as List[CausalLink]
    network_status as String  Note: "partial", "complete", "invalid"

Type called "HTNPlan":
    htn_plan id as String
    htn_plan name as String
    task_network as TaskNetwork
    primitive_plan as List[Task]
    execution_sequence as List[String]
    plan_hierarchy as Dictionary
    plan_quality as Float
    plan_makespan as Integer
    plan_cost as Float

Type called "HTNDomain":
    domain id as String
    domain name as String
    primitive_tasks as List[Task]
    compound_tasks as List[Task]
    methods as List[Method]
    domain_axioms as List[Axiom]
    task_hierarchies as Dictionary[String, List[String]]

Type called "HTNProblem":
    problem id as String
    problem name as String
    domain as HTNDomain
    initial_state as State
    initial_task_network as TaskNetwork
    goal_conditions as List[Condition]
    problem_constraints as List[Constraint]

Type called "DecompositionResult":
    result id as String
    decomposition_type as String  Note: "success", "failure", "partial"
    resulting_networks as List[TaskNetwork]
    applied_methods as List[Method]
    decomposition_cost as Float
    decomposition_depth as Integer

Note: HTN Planning Engine
Process called "create_htn_planner" that takes config as Dictionary returns Dictionary:
    Let planner be create_htn_planner_structure
    Set planner with key "planner_id" to generate_htn_planner_id
    Set planner with key "decomposition_strategy" to config with key "strategy" or "depth_first"
    Set planner with key "method_selection" to config with key "method_selection" or "first_applicable"
    Set planner with key "conflict_resolution" to config with key "conflict_resolution" or "priority_based"
    Set planner with key "backtracking_enabled" to config with key "backtracking" or true
    Set planner with key "optimization_enabled" to config with key "optimization" or false
    Set planner with key "max_decomposition_depth" to config with key "max_depth" or 10
    
    Return planner

Process called "plan_with_htn" that takes planner as Dictionary and problem as HTNProblem returns Dictionary:
    Let start_time be current_timestamp
    Let initial_network be problem with field initial_task_network
    Let domain be problem with field domain
    Let initial_state be problem with field initial_state
    
    Note: Initialize HTN planning structures
    Let decomposition_stack be create_stack
    Let solution_networks be empty list
    Let search_statistics be empty dictionary
    
    Push initial_network to decomposition_stack
    
    Let max_iterations be 10000
    Let iterations be 0
    
    Note: HTN planning main loop
    While decomposition_stack is not empty and iterations is less than max_iterations:
        Set iterations to iterations plus 1
        Let current_network be pop from decomposition_stack
        
        Note: Check if network is fully decomposed
        If is_fully_primitive with current_network:
            Add current_network to solution_networks
            
            Note: If we only need one solution, return it
            If planner with key "optimization_enabled" is equal to false:
                Break from loop
        Otherwise:
            Note: Decompose compound tasks in the network
            Let decomposition_results be decompose_task_network with current_network and domain and planner
            
            For each result in decomposition_results:
                If result with field decomposition_type is equal to "success":
                    For each new_network in result with field resulting_networks:
                        Push new_network to decomposition_stack
    
    Note: Select best solution if multiple found
    Let best_plan be select_best_htn_plan with solution_networks and planner
    
    Let end_time be current_timestamp
    Set search_statistics with key "iterations" to iterations
    Set search_statistics with key "solutions_found" to length of solution_networks
    Set search_statistics with key "planning_time" to end_time minus start_time
    
    Return dictionary with keys "plan", "statistics", "success":
        "plan" maps to best_plan
        "statistics" maps to search_statistics
        "success" maps to (best_plan is not equal to null)

Process called "decompose_task_network" that takes network as TaskNetwork and domain as HTNDomain and planner as Dictionary returns List[DecompositionResult]:
    Let decomposition_results be empty list
    Let tasks be network with field tasks
    
    Note: Find first compound task to decompose
    Let compound_task be find_first_compound_task with tasks
    
    If compound_task is equal to null:
        Note: All tasks are primitive - network is complete
        Let result be create_decomposition_result_structure
        Set result with field result_id to generate_decomposition_id
        Set result with field decomposition_type to "success"
        Set result with field resulting_networks to list containing network
        Add result to decomposition_results
        Return decomposition_results
    
    Note: Find applicable methods for the compound task
    Let applicable_methods be find_applicable_methods with compound_task and domain and network
    
    If length of applicable_methods is equal to 0:
        Note: No applicable methods - decomposition failure
        Let result be create_decomposition_result_structure
        Set result with field result_id to generate_decomposition_id
        Set result with field decomposition_type to "failure"
        Set result with field resulting_networks to empty list
        Add result to decomposition_results
        Return decomposition_results
    
    Note: Apply each applicable method
    For each method in applicable_methods:
        Let decomposition_result be apply_method_to_task with method and compound_task and network and domain
        
        If decomposition_result with field decomposition_type is equal to "success":
            Add decomposition_result to decomposition_results
    
    Return decomposition_results

Process called "find_applicable_methods" that takes compound_task as Task and domain as HTNDomain and network as TaskNetwork returns List[Method]:
    Let applicable_methods be empty list
    Let domain_methods be domain with field methods
    Let current_state be extract_state_from_network with network
    
    For each method in domain_methods:
        Note: Check if method can decompose this compound task
        If method with field compound_task is equal to compound_task with field task_name:
            Note: Check method preconditions
            Let preconditions_satisfied be check_method_preconditions with method and current_state and network
            
            If preconditions_satisfied is equal to true:
                Add method to applicable_methods
    
    Note: Sort methods by priority if specified
    Let method_selection be planner with key "method_selection"
    If method_selection is equal to "priority_based":
        Set applicable_methods to sort_methods_by_priority with applicable_methods
    
    Return applicable_methods

Process called "apply_method_to_task" that takes method as Method and compound_task as Task and network as TaskNetwork and domain as HTNDomain returns DecompositionResult:
    Let result be create_decomposition_result_structure
    Set result with field result_id to generate_decomposition_id
    Set result with field applied_methods to list containing method
    
    Note: Create new task network by replacing compound task with subtasks
    Let new_network be copy of network
    Let subtasks be method with field subtasks
    Let subtask_ordering be method with field subtask_ordering
    
    Note: Remove compound task from network
    Let updated_tasks be remove_task_from_list with new_network with field tasks and compound_task
    
    Note: Add subtasks to network
    For each subtask in subtasks:
        Let instantiated_subtask be instantiate_task_with_parameters with subtask and compound_task with field task_parameters
        Add instantiated_subtask to updated_tasks
    
    Set new_network with field tasks to updated_tasks
    
    Note: Add ordering constraints from method
    Let existing_constraints be new_network with field ordering_constraints
    For each ordering_constraint in subtask_ordering:
        Add ordering_constraint to existing_constraints
    
    Set new_network with field ordering_constraints to existing_constraints
    
    Note: Update causal links if necessary
    Let updated_causal_links be update_causal_links_for_decomposition with new_network and method and compound_task
    Set new_network with field causal_links to updated_causal_links
    
    Note: Validate the new network
    Let validation_result be validate_task_network with new_network and domain
    
    If validation_result with key "valid" is equal to true:
        Set result with field decomposition_type to "success"
        Set result with field resulting_networks to list containing new_network
    Otherwise:
        Set result with field decomposition_type to "failure"
        Set result with field resulting_networks to empty list
    
    Return result

Process called "check_method_preconditions" that takes method as Method and current_state as State and network as TaskNetwork returns Boolean:
    Let preconditions be method with field method_preconditions
    Let state_facts be current_state with field facts
    
    For each precondition in preconditions:
        Let condition_satisfied be evaluate_condition_in_context with precondition and state_facts and network
        
        If condition_satisfied is equal to false:
            Return false
    
    Return true

Process called "instantiate_task_with_parameters" that takes task_template as Task and parameters as List[String] returns Task:
    Let instantiated_task be copy of task_template
    Set instantiated_task with field task_id to generate_task_id
    
    Let template_parameters be task_template with field task_parameters
    
    Note: Create parameter substitution mapping
    Let substitution_map be empty dictionary
    For param_index from 0 to minimum of length of template_parameters and length of parameters minus 1:
        Let template_param be template_parameters with index param_index
        Let actual_param be parameters with index param_index
        Set substitution_map with key template_param to actual_param
    
    Note: Apply parameter substitutions to task components
    Let updated_preconditions be substitute_parameters_in_conditions with instantiated_task with field task_preconditions and substitution_map
    Set instantiated_task with field task_preconditions to updated_preconditions
    
    Let updated_effects be substitute_parameters_in_conditions with instantiated_task with field task_effects and substitution_map
    Set instantiated_task with field task_effects to updated_effects
    
    Return instantiated_task

Process called "is_fully_primitive" that takes network as TaskNetwork returns Boolean:
    Let tasks be network with field tasks
    
    For each task in tasks:
        If task with field task_type is not equal to "primitive":
            Return false
    
    Return true

Process called "find_first_compound_task" that takes tasks as List[Task] returns Task:
    For each task in tasks:
        If task with field task_type is equal to "compound":
            Return task
    
    Return null

Process called "validate_task_network" that takes network as TaskNetwork and domain as HTNDomain returns Dictionary:
    Let validation_result be empty dictionary
    Set validation_result with key "valid" to true
    Set validation_result with key "issues" to empty list
    
    Let tasks be network with field tasks
    Let ordering_constraints be network with field ordering_constraints
    
    Note: Check for cyclic dependencies in ordering constraints
    Let cycle_check be check_for_cycles_in_ordering with ordering_constraints
    If cycle_check with key "has_cycle" is equal to true:
        Set validation_result with key "valid" to false
        Add "Cyclic ordering constraints detected" to validation_result with key "issues"
    
    Note: Check that all tasks are defined in domain
    For each task in tasks:
        Let task_defined be is_task_defined_in_domain with task and domain
        If task_defined is equal to false:
            Set validation_result with key "valid" to false
            Add ("Undefined task: " concatenated with task with field task_name) to validation_result with key "issues"
    
    Note: Check causal link consistency
    Let causal_links be network with field causal_links
    For each link in causal_links:
        Let link_valid be validate_causal_link with link and tasks
        If link_valid is equal to false:
            Set validation_result with key "valid" to false
            Add ("Invalid causal link: " concatenated with link with field link_id) to validation_result with key "issues"
    
    Return validation_result

Note: HTN Plan Optimization and Selection
Process called "select_best_htn_plan" that takes solution_networks as List[TaskNetwork] and planner as Dictionary returns HTNPlan:
    If length of solution_networks is equal to 0:
        Return null
    
    If length of solution_networks is equal to 1:
        Return convert_network_to_htn_plan with solution_networks with index 0
    
    Note: Evaluate each solution network
    Let best_network be null
    Let best_quality be negative_infinity
    
    For each network in solution_networks:
        Let quality_score be evaluate_network_quality with network and planner
        
        If quality_score is greater than best_quality:
            Set best_quality to quality_score
            Set best_network to network
    
    Return convert_network_to_htn_plan with best_network

Process called "evaluate_network_quality" that takes network as TaskNetwork and planner as Dictionary returns Float:
    Let quality_score be 0.0
    
    Note: Calculate cost-based quality (lower cost = higher quality)
    Let total_cost be calculate_network_total_cost with network
    Set quality_score to quality_score minus total_cost
    
    Note: Calculate makespan-based quality (shorter makespan = higher quality)
    Let makespan be calculate_network_makespan with network
    Set quality_score to quality_score minus (makespan as Float multiplied by 0.1)
    
    Note: Calculate resource efficiency
    Let resource_efficiency be calculate_resource_efficiency with network
    Set quality_score to quality_score plus resource_efficiency
    
    Note: Penalize complex hierarchies if simplicity is preferred
    Let hierarchy_complexity be calculate_hierarchy_complexity with network
    Set quality_score to quality_score minus (hierarchy_complexity multiplied by 0.05)
    
    Return quality_score

Process called "convert_network_to_htn_plan" that takes network as TaskNetwork returns HTNPlan:
    Let htn_plan be create_htn_plan_structure
    Set htn_plan with field htn_plan_id to generate_htn_plan_id
    Set htn_plan with field task_network to network
    
    Note: Extract primitive tasks for execution sequence
    Let primitive_tasks be extract_primitive_tasks with network
    Set htn_plan with field primitive_plan to primitive_tasks
    
    Note: Generate execution sequence respecting ordering constraints
    Let execution_sequence be generate_execution_sequence with primitive_tasks and network with field ordering_constraints
    Set htn_plan with field execution_sequence to execution_sequence
    
    Note: Calculate plan metrics
    Let plan_cost be calculate_network_total_cost with network
    Set htn_plan with field plan_cost to plan_cost
    
    Let plan_makespan be calculate_network_makespan with network
    Set htn_plan with field plan_makespan to plan_makespan
    
    Let plan_quality be evaluate_network_quality with network and empty dictionary
    Set htn_plan with field plan_quality to plan_quality
    
    Note: Build plan hierarchy representation
    Let hierarchy be build_plan_hierarchy with network
    Set htn_plan with field plan_hierarchy to hierarchy
    
    Return htn_plan

Process called "generate_execution_sequence" that takes primitive_tasks as List[Task] and ordering_constraints as List[OrderingConstraint] returns List[String]:
    Note: Topological sort to respect ordering constraints
    Let execution_sequence be empty list
    Let remaining_tasks be copy of primitive_tasks
    Let constraint_graph be build_constraint_graph with ordering_constraints
    
    While length of remaining_tasks is greater than 0:
        Note: Find tasks with no remaining dependencies
        Let ready_tasks be find_tasks_with_no_dependencies with remaining_tasks and constraint_graph
        
        If length of ready_tasks is equal to 0:
            Note: Circular dependency detected - break arbitrarily
            Add first element of remaining_tasks with field task_id to execution_sequence
            Set remaining_tasks to remove_first_element with remaining_tasks
        Otherwise:
            Note: Select first ready task (could be improved with heuristics)
            Let selected_task be ready_tasks with index 0
            Add selected_task with field task_id to execution_sequence
            Set remaining_tasks to remove_task_from_list with remaining_tasks and selected_task
            
            Note: Update constraint graph
            Set constraint_graph to remove_task_from_constraint_graph with constraint_graph and selected_task
    
    Return execution_sequence

Note: HTN Method Library and Task Hierarchies
Process called "create_standard_htn_methods" that takes domain_config as Dictionary returns List[Method]:
    Let methods be empty list
    
    Note: Transportation domain methods
    If domain_config contains key "transportation":
        Let transport_methods be create_transportation_methods
        Set methods to concatenate with methods and transport_methods
    
    Note: Logistics domain methods
    If domain_config contains key "logistics":
        Let logistics_methods be create_logistics_methods
        Set methods to concatenate with methods and logistics_methods
    
    Note: Resource allocation methods
    If domain_config contains key "resource_allocation":
        Let resource_methods be create_resource_allocation_methods
        Set methods to concatenate with methods and resource_methods
    
    Note: Communication and coordination methods
    If domain_config contains key "coordination":
        Let coordination_methods be create_coordination_methods
        Set methods to concatenate with methods and coordination_methods
    
    Return methods

Process called "create_transportation_methods" returns List[Method]:
    Let methods be empty list
    
    Note: Method: Transport package from A to B
    Let transport_method be create_method_structure
    Set transport_method with field method_id to "transport_package_method"
    Set transport_method with field method_name to "Transport Package"
    Set transport_method with field compound_task to "transport"
    Set transport_method with field method_parameters to list containing "package", "origin", "destination"
    
    Note: Method preconditions
    Set transport_method with field method_preconditions to list containing:
        create_condition with keys "predicate", "operator", "parameters":
            "predicate" maps to "at"
            "operator" maps to "equals"
            "parameters" maps to list containing "package", "origin"
    
    Note: Method subtasks
    Let load_task be create_task with keys "task_name", "task_type", "task_parameters":
        "task_name" maps to "load"
        "task_type" maps to "primitive"
        "task_parameters" maps to list containing "package", "origin"
    
    Let drive_task be create_task with keys "task_name", "task_type", "task_parameters":
        "task_name" maps to "drive"
        "task_type" maps to "primitive"
        "task_parameters" maps to list containing "origin", "destination"
    
    Let unload_task be create_task with keys "task_name", "task_type", "task_parameters":
        "task_name" maps to "unload"
        "task_type" maps to "primitive"
        "task_parameters" maps to list containing "package", "destination"
    
    Set transport_method with field subtasks to list containing load_task, drive_task, unload_task
    
    Note: Method ordering constraints
    Set transport_method with field subtask_ordering to list containing:
        create_ordering_constraint with "before" as load_task with field task_id and "after" as drive_task with field task_id,
        create_ordering_constraint with "before" as drive_task with field task_id and "after" as unload_task with field task_id
    
    Add transport_method to methods
    
    Return methods

Process called "create_logistics_methods" returns List[Method]:
    Let methods be empty list
    
    Note: Method: Deliver multiple packages
    Let multi_delivery_method be create_method_structure
    Set multi_delivery_method with field method_id to "multi_delivery_method"
    Set multi_delivery_method with field method_name to "Deliver Multiple Packages"
    Set multi_delivery_method with field compound_task to "deliver_all"
    Set multi_delivery_method with field method_parameters to list containing "package_list", "destination_list"
    
    Note: This method would decompose into individual transport tasks
    Note: Implementation depends on specific package and destination parameters
    
    Add multi_delivery_method to methods
    
    Return methods

Note: HTN Plan Execution and Monitoring
Process called "execute_htn_plan" that takes htn_plan as HTNPlan and initial_state as State and execution_config as Dictionary returns Dictionary:
    Let execution_result be empty dictionary
    Set execution_result with key "execution_id" to generate_execution_id
    Set execution_result with key "htn_plan" to htn_plan
    Set execution_result with key "start_time" to current_timestamp
    
    Let primitive_plan be htn_plan with field primitive_plan
    let execution_sequence be htn_plan with field execution_sequence
    Let current_state be copy of initial_state
    
    Let execution_trace be empty list
    Let hierarchical_trace be empty list
    
    Note: Execute primitive tasks according to sequence
    For each task_id in execution_sequence:
        Let task be find_task_by_id with primitive_plan and task_id
        
        If task is not equal to null:
            Note: Execute primitive task
            Let task_start_time be current_timestamp
            Let task_result be execute_primitive_task with task and current_state
            Let task_end_time be current_timestamp
            
            Note: Record execution trace
            Let trace_entry be dictionary with keys "task", "start_time", "end_time", "result", "state_before", "state_after":
                "task" maps to task
                "start_time" maps to task_start_time
                "end_time" maps to task_end_time
                "result" maps to task_result
                "state_before" maps to copy of current_state
                "state_after" maps to task_result with key "resulting_state"
            
            Add trace_entry to execution_trace
            
            Note: Update current state
            If task_result with key "success" is equal to true:
                Set current_state to task_result with key "resulting_state"
            Otherwise:
                Set execution_result with key "final_status" to "task_failure"
                Set execution_result with key "failed_task" to task
                Break from loop
    
    Note: Determine final execution status
    If execution_result does not contain key "final_status":
        Set execution_result with key "final_status" to "completed"
    
    Set execution_result with key "end_time" to current_timestamp
    Set execution_result with key "execution_trace" to execution_trace
    Set execution_result with key "final_state" to current_state
    
    Return execution_result

Note: Main HTN planning coordination
Process called "create_htn_planning_system" that takes configuration as Dictionary returns Dictionary:
    Let system be empty dictionary
    Set system with key "decomposition_strategies" to configuration with key "strategies" or list containing "depth_first", "breadth_first", "best_first"
    Set system with key "method_selection_modes" to configuration with key "method_selection" or list containing "first_applicable", "priority_based", "cost_based"
    Set system with key "backtracking_enabled" to configuration with key "backtracking" or true
    Set system with key "plan_optimization" to configuration with key "optimization" or false
    Set system with key "hierarchical_execution" to configuration with key "hierarchical_execution" or true
    
    Return system

Process called "execute_htn_planning_analysis" that takes system as Dictionary and query as Dictionary returns Dictionary:
    Let query_type be query with key "type"
    Let result be empty dictionary
    
    If query_type is equal to "create_htn_plan":
        Let problem be query with key "problem"
        Let planner_config be query with key "planner_config"
        
        Let planner be create_htn_planner with planner_config
        Let planning_result be plan_with_htn with planner and problem
        Set result with key "htn_planning_result" to planning_result
    
    If query_type is equal to "decompose_task":
        Let compound_task be query with key "compound_task"
        Let domain be query with key "domain"
        Let network be query with key "network"
        Let planner_config be query with key "planner_config"
        
        Let planner be create_htn_planner with planner_config
        Let decomposition_results be decompose_task_network with network and domain and planner
        Set result with key "decomposition_results" to decomposition_results
    
    If query_type is equal to "execute_htn_plan":
        Let htn_plan be query with key "htn_plan"
        Let initial_state be query with key "initial_state"
        Let execution_config be query with key "execution_config"
        
        Let execution_result be execute_htn_plan with htn_plan and initial_state and execution_config
        Set result with key "execution_result" to execution_result
    
    If query_type is equal to "validate_network":
        Let network be query with key "network"
        Let domain be query with key "domain"
        
        Let validation_result be validate_task_network with network and domain
        Set result with key "validation_result" to validation_result
    
    If query_type is equal to "optimize_plan":
        Let htn_plan be query with key "htn_plan"
        Let optimization_criteria be query with key "criteria"
        
        Let optimized_plan be optimize_htn_plan with htn_plan and optimization_criteria
        Set result with key "optimized_plan" to optimized_plan
    
    Note: Add metadata
    Set result with key "htn_planning_timestamp" to current_timestamp
    Set result with key "system_config" to extract_system_summary with system
    
    Return result