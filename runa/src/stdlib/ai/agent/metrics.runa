Process called "record_resource_contention" that takes swarm as Swarm, agent_id as String, outcome as String returns Swarm:
    Set swarm.metrics.resource_contention_count to swarm.metrics.resource_contention_count plus 1
    Let member be get_swarm_member with swarm as swarm and agent_id as agent_id
    If member is not "":
        Set member.resource_contention_count to member.resource_contention_count plus 1
    If outcome is equal to "success":
        Set swarm.metrics.resource_contention_success to swarm.metrics.resource_contention_success plus 1
        If member is not "":
            Set member.resource_contention_success to member.resource_contention_success plus 1
    Else:
        Set swarm.metrics.resource_contention_failure to swarm.metrics.resource_contention_failure plus 1
        If member is not "":
            Set member.resource_contention_failure to member.resource_contention_failure plus 1
    Return swarm

Process called "record_agent_creation" that takes swarm as Swarm, agent_id as String returns Swarm:
    Set swarm.metrics.agent_creation_count to swarm.metrics.agent_creation_count plus 1
    Set swarm.metrics.agent_lifespan[agent_id] to 0
    Return swarm

Process called "record_agent_retirement" that takes swarm as Swarm, agent_id as String returns Swarm:
    Set swarm.metrics.agent_retirement_count to swarm.metrics.agent_retirement_count plus 1
    Let lifespan as Number be get_current_timestamp - get_agent_creation_time with agent_id as agent_id
    Set swarm.metrics.agent_lifespan[agent_id] to lifespan
    Return swarm
