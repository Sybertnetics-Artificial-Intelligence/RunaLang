Note:
Runa Standard Library: AI Agent Hierarchical Module - Production Grade

Provides support for composite agents, sub-agent management, delegation, and aggregation. Enables hierarchical workflows and distributed task execution with advanced coordination, load balancing, and fault tolerance.

Advanced features include:
- Advanced composite agent architecture with dynamic composition
- Intelligent task delegation and load balancing
- Hierarchical workflow orchestration and management
- Sub-agent lifecycle management and monitoring
- Result aggregation and conflict resolution
- Performance optimization and resource allocation
- Fault tolerance and recovery mechanisms
- Advanced coordination patterns
:End Note

Type called "CompositeAgent":
    id as String
    name as String
    sub_agents as List[String]
    delegated_tasks as Dictionary[String, String]
    results as Dictionary[String, Any]
    status as String
    hierarchy_level as Integer
    parent_agent as String
    coordination_strategy as String
    load_balancing_config as Dictionary[String, Any]
    performance_metrics as Dictionary[String, Number]
    resource_allocation as Dictionary[String, Number]
    fault_tolerance_config as Dictionary[String, Any]
    audit_trail as List[Dictionary[String, Any]]

Type called "HierarchicalWorkflow":
    workflow_id as String
    root_agent as String
    workflow_structure as Dictionary[String, List[String]]
    execution_plan as List[Dictionary[String, Any]]
    current_step as Integer
    status as String
    results as Dictionary[String, Any]
    performance_metrics as Dictionary[String, Number]
    error_handlers as List[Process]
    recovery_strategies as Dictionary[String, Process]

Type called "DelegationContext":
    delegation_id as String
    source_agent as String
    target_agent as String
    task_description as String
    task_parameters as Dictionary[String, Any]
    priority as Integer
    deadline as Number
    resource_requirements as Dictionary[String, Number]
    monitoring_hooks as List[Process]
    success_criteria as List[String]

Type called "AggregationStrategy":
    strategy_type as String
    aggregation_rules as List[Process]
    conflict_resolution as String
    quality_threshold as Number
    validation_rules as List[Process]
    performance_targets as Dictionary[String, Number]

Type called "SubAgentManager":
    sub_agents as Dictionary[String, SubAgentInfo]
    health_status as Dictionary[String, Boolean]
    performance_metrics as Dictionary[String, Number]
    load_distribution as Dictionary[String, Number]
    failure_detection as Dictionary[String, Number]
    recovery_actions as Dictionary[String, Process]

Type called "SubAgentInfo":
    agent_id as String
    capabilities as List[String]
    current_load as Number
    max_capacity as Number
    performance_score as Number
    last_heartbeat as Number
    status as String
    assigned_tasks as List[String]

Type called "AgentHierarchy":
    parent_id as String
    children_ids as List[String]
    last_round_robin_index as Integer

Type called "HierarchyManager":
    agent_hierarchies as Dictionary[String, AgentHierarchy]

Note: Advanced Composite Agent Management
Process called "create_composite_agent" that takes name as String returns CompositeAgent:
    Return create_composite_agent_with_config with name as name and hierarchy_level as 0 and parent_agent as "" and coordination_strategy as "centralized" and load_balancing_config as dictionary containing

Process called "create_composite_agent_with_config" that takes name as String and hierarchy_level as Integer and parent_agent as String and coordination_strategy as String and load_balancing_config as Dictionary[String, Any] returns CompositeAgent:
    Return CompositeAgent with:
        id as generate_composite_agent_id
        name as name
        sub_agents as list containing
        delegated_tasks as dictionary containing
        results as dictionary containing
        status as "initializing"
        hierarchy_level as hierarchy_level
        parent_agent as parent_agent
        coordination_strategy as coordination_strategy
        load_balancing_config as load_balancing_config
        performance_metrics as Dictionary with:
            "total_delegations" as 0
            "successful_delegations" as 0
            "average_response_time" as 0.0
            "sub_agent_utilization" as 0.0
        resource_allocation as Dictionary with:
            "memory_mb" as 1024
            "cpu_percent" as 100
            "network_mbps" as 1000
        fault_tolerance_config as Dictionary with:
            "max_failures" as 3
            "recovery_timeout" as 60
            "backup_strategy" as "redundant"
        audit_trail as list containing

Process called "add_sub_agent" that takes agent as CompositeAgent and sub_agent_id as String returns CompositeAgent:
    If not agent.sub_agents contains sub_agent_id:
        Add sub_agent_id to agent.sub_agents
        
        Let audit_entry be Dictionary with:
            "timestamp" as get_current_timestamp
            "action" as "sub_agent_added"
            "sub_agent_id" as sub_agent_id
        Add audit_entry to agent.audit_trail
    
    Return agent

Process called "remove_sub_agent" that takes agent as CompositeAgent and sub_agent_id as String returns CompositeAgent:
    If agent.sub_agents contains sub_agent_id:
        Remove sub_agent_id from agent.sub_agents
        
        If agent.delegated_tasks contains sub_agent_id:
            Remove sub_agent_id from agent.delegated_tasks
        
        If agent.results contains sub_agent_id:
            Remove sub_agent_id from agent.results
        
        Let audit_entry be Dictionary with:
            "timestamp" as get_current_timestamp
            "action" as "sub_agent_removed"
            "sub_agent_id" as sub_agent_id
        Add audit_entry to agent.audit_trail
    
    Return agent

Process called "delegate_task" that takes agent as CompositeAgent and sub_agent_id as String and task_id as String returns CompositeAgent:
    If agent.sub_agents contains sub_agent_id:
        Set agent.delegated_tasks[sub_agent_id] to task_id
        
        Let audit_entry be Dictionary with:
            "timestamp" as get_current_timestamp
            "action" as "task_delegated"
            "sub_agent_id" as sub_agent_id
            "task_id" as task_id
        Add audit_entry to agent.audit_trail
        
        Let metrics be agent.performance_metrics
        Set metrics["total_delegations"] to metrics["total_delegations"] plus 1
    
    Return agent

Process called "collect_result" that takes agent as CompositeAgent and sub_agent_id as String and result as Any returns CompositeAgent:
    Set agent.results[sub_agent_id] to result
    
    Let audit_entry be Dictionary with:
        "timestamp" as get_current_timestamp
        "action" as "result_collected"
        "sub_agent_id" as sub_agent_id
        "result" as result
    Add audit_entry to agent.audit_trail
    
    Let metrics be agent.performance_metrics
    Set metrics["successful_delegations"] to metrics["successful_delegations"] plus 1
    
    Return agent

Process called "update_status" that takes agent as CompositeAgent and status as String returns CompositeAgent:
    Set agent.status to status
    
    Let audit_entry be Dictionary with:
        "timestamp" as get_current_timestamp
        "action" as "status_updated"
        "new_status" as status
    Add audit_entry to agent.audit_trail
    
    Return agent

Note: Advanced Task Delegation and Load Balancing
Process called "delegate_task_intelligently" that takes agent as CompositeAgent and task_description as String and task_parameters as Dictionary[String, Any] returns String:
    Let context be DelegationContext with:
        delegation_id as generate_delegation_id
        source_agent as agent.id
        target_agent as ""
        task_description as task_description
        task_parameters as task_parameters
        priority as 0
        deadline as get_current_timestamp plus calculate_task_deadline_offset()
        resource_requirements as Dictionary with:
            "memory_mb" as 100
            "cpu_percent" as 10
        monitoring_hooks as list containing
        success_criteria as list containing
    
    Let selected_agent be select_optimal_sub_agent with agent as agent and context as context
    If selected_agent is not equal to "":
        Set context.target_agent to selected_agent
        Let delegation_result be execute_delegation with agent as agent and context as context
        Return selected_agent
    
    Return ""

Process called "select_optimal_sub_agent" that takes agent as CompositeAgent and context as DelegationContext returns String:
    Let available_agents be list containing
    Let sub_agent_manager be get_sub_agent_manager with agent_id as agent.id
    
    For each sub_agent_id in agent.sub_agents:
        If sub_agent_manager.health_status contains sub_agent_id and sub_agent_manager.health_status[sub_agent_id]:
            Let sub_agent_info be sub_agent_manager.sub_agents[sub_agent_id]
            If sub_agent_info.current_load is less than sub_agent_info.max_capacity:
                Add sub_agent_id to available_agents
    
    If length of available_agents is equal to 0:
        Return ""
    
    Let best_agent as String be ""
    Let best_score as Number be 0.0
    
    For each sub_agent_id in available_agents:
        Let score be calculate_agent_fitness with sub_agent_id as sub_agent_id and context as context and manager as sub_agent_manager
        If score is greater than best_score:
            Set best_score to score
            Set best_agent to sub_agent_id
    
    Return best_agent

Process called "calculate_agent_fitness" that takes sub_agent_id as String and context as DelegationContext and manager as SubAgentManager returns Number:
    Let sub_agent_info be manager.sub_agents[sub_agent_id]
    Let load_factor be 1.0 minus (sub_agent_info.current_load divided by sub_agent_info.max_capacity)
    Let performance_factor be sub_agent_info.performance_score divided by 100.0
    Let capability_match be calculate_capability_match with agent_id as sub_agent_id and task_description as context.task_description
    
    Return (load_factor plus performance_factor plus capability_match) divided by 3.0

Process called "execute_delegation" that takes agent as CompositeAgent and context as DelegationContext returns Boolean:
    Let delegation_result be delegate_task with agent as agent and sub_agent_id as context.target_agent and task_id as context.delegation_id
    
    Let monitoring_hooks be context.monitoring_hooks
    For each hook in monitoring_hooks:
        Try:
            Let hook_result be hook with context as context
        Catch:
            Note: Ignore hook errors
    
    Return true

Process called "calculate_capability_match" that takes agent_id as String and task_description as String returns Number:
    Let agent_capabilities be get_agent_capabilities with agent_id as agent_id
    Let task_keywords be extract_task_keywords with description as task_description
    
    Let match_count as Integer be 0
    For each keyword in task_keywords:
        For each capability in agent_capabilities:
            If capability contains keyword:
                Set match_count to match_count plus 1
    
    Return match_count divided by length of task_keywords

Note: Advanced Result Aggregation and Conflict Resolution
Process called "aggregate_results" that takes agent as CompositeAgent and aggregation_strategy as AggregationStrategy returns Any:
    Let results be agent.results
    If length of results is equal to 0:
        Return ""
    
    If aggregation_strategy.strategy_type is equal to "consensus":
        Return aggregate_by_consensus with results as results and strategy as aggregation_strategy
    Otherwise if aggregation_strategy.strategy_type is equal to "weighted":
        Return aggregate_by_weighted_average with results as results and strategy as aggregation_strategy
    Otherwise if aggregation_strategy.strategy_type is equal to "majority":
        Return aggregate_by_majority with results as results and strategy as aggregation_strategy
    Otherwise:
        Return aggregate_by_default with results as results and strategy as aggregation_strategy

Process called "aggregate_by_consensus" that takes results as Dictionary[String, Any] and strategy as AggregationStrategy returns Any:
    Let consensus_threshold be strategy.quality_threshold
    Let result_counts be dictionary containing
    
    For each result in results.values():
        If not result_counts contains result:
            Set result_counts[result] to 0
        Set result_counts[result] to result_counts[result] plus 1
    
    Let total_results be length of results
    Let consensus_result as Any be ""
    
    For each result and count in result_counts:
        Let consensus_ratio be count divided by total_results
        If consensus_ratio is greater than or equal to consensus_threshold:
            Set consensus_result to result
            Break
    
    Return consensus_result

Process called "aggregate_by_weighted_average" that takes results as Dictionary[String, Any] and strategy as AggregationStrategy returns Any:
    Let weighted_sum as Number be 0.0
    Let total_weight as Number be 0.0
    
    For each agent_id and result in results:
        Let weight be get_agent_weight with agent_id as agent_id
        If is_numeric with value as result:
            Set weighted_sum to weighted_sum plus (result multiplied by weight)
            Set total_weight to total_weight plus weight
    
    If total_weight is greater than 0:
        Return weighted_sum divided by total_weight
    Return 0.0

Process called "aggregate_by_majority" that takes results as Dictionary[String, Any] and strategy as AggregationStrategy returns Any:
    Let result_counts be dictionary containing
    
    For each result in results.values():
        If not result_counts contains result:
            Set result_counts[result] to 0
        Set result_counts[result] to result_counts[result] plus 1
    
    Let majority_result as Any be ""
    Let max_count as Integer be 0
    
    For each result and count in result_counts:
        If count is greater than max_count:
            Set majority_result to result
            Set max_count to count
    
    Return majority_result

Process called "aggregate_by_default" that takes results as Dictionary[String, Any] and strategy as AggregationStrategy returns Any:
    Let result_list be list containing
    For each result in results.values():
        Add result to result_list
    
    If length of result_list is equal to 0:
        Return ""
    Otherwise if length of result_list is equal to 1:
        Return result_list[0]
    Otherwise:
        Return result_list

Note: Advanced Hierarchical Workflow Management
Process called "create_hierarchical_workflow" that takes root_agent as String returns HierarchicalWorkflow:
    Return HierarchicalWorkflow with:
        workflow_id as generate_workflow_id
        root_agent as root_agent
        workflow_structure as dictionary containing
        execution_plan as list containing
        current_step as 0
        status as "created"
        results as dictionary containing
        performance_metrics as Dictionary with:
            "total_steps" as 0
            "completed_steps" as 0
            "execution_time" as 0.0
            "success_rate" as 1.0
        error_handlers as list containing
        recovery_strategies as dictionary containing

Process called "add_workflow_step" that takes workflow as HierarchicalWorkflow and step_description as String and target_agents as List[String] returns HierarchicalWorkflow:
    Let step be Dictionary with:
        "step_id" as generate_step_id
        "description" as step_description
        "target_agents" as target_agents
        "status" as "pending"
        "result" as ""
        "execution_time" as 0.0
        "dependencies" as list containing
    
    Add step to workflow.execution_plan
    Set workflow.performance_metrics["total_steps"] to workflow.performance_metrics["total_steps"] plus 1
    
    Return workflow

Process called "execute_workflow" that takes workflow as HierarchicalWorkflow returns Boolean:
    Set workflow.status to "executing"
    Let start_time be get_current_timestamp
    
    For each step in workflow.execution_plan:
        If step.status is equal to "pending":
            Let step_result be execute_workflow_step with workflow as workflow and step as step
            If step_result:
                Set step.status to "completed"
                Set workflow.performance_metrics["completed_steps"] to workflow.performance_metrics["completed_steps"] plus 1
            Otherwise:
                Set step.status to "failed"
                Let recovery_result be execute_recovery_strategy with workflow as workflow and step as step
                If not recovery_result:
                    Set workflow.status to "failed"
                    Return false
    
    Set workflow.status to "completed"
    Let end_time be get_current_timestamp
    Set workflow.performance_metrics["execution_time"] to end_time minus start_time
    
    Return true

Process called "execute_workflow_step" that takes workflow as HierarchicalWorkflow and step as Dictionary[String, Any] returns Boolean:
    Let step_start_time be get_current_timestamp
    
    For each target_agent in step.target_agents:
        Try:
            Let delegation_result be delegate_task_to_agent with agent_id as target_agent and task_description as step.description
            If delegation_result:
                Set step.result to delegation_result
            Otherwise:
                Return false
        Catch error:
            Return false
    
    Let step_end_time be get_current_timestamp
    Set step.execution_time to step_end_time minus step_start_time
    
    Return true

Process called "execute_recovery_strategy" that takes workflow as HierarchicalWorkflow and step as Dictionary[String, Any] returns Boolean:
    Let recovery_strategy be workflow.recovery_strategies["default"]
    If recovery_strategy is not "":
        Return recovery_strategy with workflow as workflow and step as step
    Return false

Note: Advanced Sub-Agent Management and Monitoring
Process called "create_sub_agent_manager" that returns SubAgentManager:
    Return SubAgentManager with:
        sub_agents as dictionary containing
        health_status as dictionary containing
        performance_metrics as dictionary containing
        load_distribution as dictionary containing
        failure_detection as dictionary containing
        recovery_actions as dictionary containing

Process called "register_sub_agent" that takes manager as SubAgentManager and agent_id as String and capabilities as List[String] returns SubAgentManager:
    Let sub_agent_info be SubAgentInfo with:
        agent_id as agent_id
        capabilities as capabilities
        current_load as 0.0
        max_capacity as 100.0
        performance_score as 100.0
        last_heartbeat as get_current_timestamp
        status as "active"
        assigned_tasks as list containing
    
    Set manager.sub_agents[agent_id] to sub_agent_info
    Set manager.health_status[agent_id] to true
    Set manager.load_distribution[agent_id] to 0.0
    
    Return manager

Process called "update_sub_agent_health" that takes manager as SubAgentManager and agent_id as String and is_healthy as Boolean returns SubAgentManager:
    Set manager.health_status[agent_id] to is_healthy
    
    If manager.sub_agents contains agent_id:
        Let sub_agent_info be manager.sub_agents[agent_id]
        Set sub_agent_info.last_heartbeat to get_current_timestamp
        
        If is_healthy:
            Set sub_agent_info.status to "active"
        Otherwise:
            Set sub_agent_info.status to "unhealthy"
    
    Return manager

Process called "detect_sub_agent_failures" that takes manager as SubAgentManager returns List[String]:
    Let failed_agents be list containing
    Let current_time be get_current_timestamp
    
    For each agent_id in manager.sub_agents:
        Let sub_agent_info be manager.sub_agents[agent_id]
        Let heartbeat_age be current_time minus sub_agent_info.last_heartbeat
        
        If heartbeat_age is greater than 300:
            Add agent_id to failed_agents
            Set manager.failure_detection[agent_id] to current_time
    
    Return failed_agents

Process called "execute_recovery_action" that takes manager as SubAgentManager and agent_id as String returns Boolean:
    If manager.recovery_actions contains agent_id:
        Let recovery_action be manager.recovery_actions[agent_id]
        Return recovery_action with agent_id as agent_id
    Otherwise:
        Return execute_default_recovery with agent_id as agent_id

Note: Utility Functions for Advanced Hierarchical Management
Process called "generate_composite_agent_id" that returns String:
    Return generate_cryptographic_uuid

Process called "generate_delegation_id" that returns String:
    Return generate_cryptographic_uuid

Process called "generate_workflow_id" that returns String:
    Return generate_cryptographic_uuid

Process called "generate_step_id" that returns String:
    Return generate_cryptographic_uuid

Process called "get_sub_agent_manager" that takes agent_id as String returns SubAgentManager:
    Let manager_registry be get_sub_agent_manager_registry
    If manager_registry contains agent_id:
        Return manager_registry[agent_id]
    Return create_sub_agent_manager

Process called "get_agent_capabilities" that takes agent_id as String returns List[String]:
    Let agent_identity be get_agent_identity with agent_id as agent_id
    Return agent_identity.capabilities

Process called "extract_task_keywords" that takes description as String returns List[String]:
    Let keywords be list containing
    Let words be split_string with text as description and delimiter as " "
    
    For each word in words:
        If length of word is greater than 3:
            Add word to keywords
    
    Return keywords

Process called "get_agent_weight" that takes agent_id as String returns Number:
    Let agent_state be get_agent_state with agent_id as agent_id
    Return agent_state.health_score divided by 100.0

Process called "is_numeric" that takes value as Any returns Boolean:
    Return is_number with value as value

Process called "delegate_task_to_agent" that takes agent_id as String and task_description as String returns Any:
    Let agent_skill be get_agent_skill with agent_id as agent_id and skill_name as "task_execution"
    If agent_skill is not equal to "":
        Return agent_skill with task_description as task_description
    Return ""

Process called "execute_default_recovery" that takes agent_id as String returns Boolean:
    Let recovery_skill be get_agent_skill with agent_id as agent_id and skill_name as "recovery"
    If recovery_skill is not equal to "":
        Return recovery_skill with agent_id as agent_id
    Return false

Process called "split_string" that takes text as String and delimiter as String returns List[String]:
    Return string_split with text as text and delimiter as delimiter

Process called "is_numeric_value" that takes value as Any returns Boolean:
    Return true

Process called "get_registered_agent_identity" that takes agent_id as String returns AgentIdentity:
    Let agent_data be get_registered_agent with agent_id as agent_id
    If agent_data is not "":
        Let (identity, state, lifecycle) be agent_data
        Return identity
    Return create_agent_identity with name as "Agent " plus agent_id and description as "AI Agent"

Process called "get_registered_agent_state" that takes agent_id as String returns AgentState:
    Let agent_data be get_registered_agent with agent_id as agent_id
    If agent_data is not "":
        Let (identity, state, lifecycle) be agent_data
        Return state
    Return create_agent_state

Process called "get_global_skill_registry" that returns SkillRegistry:
    Return create_skill_registry

Process called "get_global_sub_agent_manager_registry" that returns Dictionary[String, SubAgentManager]:
    Return dictionary containing

Process called "calculate_task_deadline_offset" returns Number:
    Let system_load be get_cpu_usage()
    Return (system_load multiplied by 100) plus (system_load multiplied by 180)

Note: AgentIdentity, AgentState, SkillRegistry, AgentSkill, and CircuitBreaker types are imported from core.runa and capabilities.runa 

Process called "delegate_task_to_child_async" that takes manager as HierarchyManager, parent_agent_id as String, task_description as String, input_data as Dictionary[String, Any] returns String:
    Let hierarchy be get_agent_hierarchy with manager as manager, agent_id as parent_agent_id
    If length of hierarchy.children_ids is equal to 0:
        Return ""
    
    Let config be get_config()
    Let selection_strategy be config.hierarchical["default_child_selection_strategy"]
    
    Let child_agent_id be ""
    If selection_strategy is equal to "first_available":
        Set child_agent_id to hierarchy.children_ids[0]
    Otherwise if selection_strategy is equal to "round_robin":
        Set child_agent_id to select_child_round_robin with hierarchy as hierarchy and manager as manager and parent_agent_id as parent_agent_id
    Otherwise if selection_strategy is equal to "least_loaded":
        Set child_agent_id to select_child_least_loaded with hierarchy as hierarchy
    Otherwise if selection_strategy is equal to "best_capability_match":
        Set child_agent_id to select_child_best_capability with hierarchy as hierarchy and task_description as task_description
    Otherwise if selection_strategy is equal to "highest_performance":
        Set child_agent_id to select_child_highest_performance with hierarchy as hierarchy and task_description as task_description
    Otherwise if selection_strategy is equal to "weighted_random":
        Set child_agent_id to select_child_weighted_random with hierarchy as hierarchy
    Otherwise if selection_strategy is equal to "adaptive":
        Set child_agent_id to select_child_adaptive with hierarchy as hierarchy and task_description as task_description and input_data as input_data
    Otherwise:
        Note: Default to optimal selection if strategy unknown
        Set child_agent_id to select_optimal_child_agent with hierarchy as hierarchy and task_description as task_description and input_data as input_data
    
    Let task_manager be create_task_manager()
    Let config be get_config()
    Let default_priority be config.tasks["default_priority"]
    Let new_task be create_task_with_validation with manager as task_manager, description as task_description, priority as default_priority, metadata as Dictionary with "input_data" as input_data
    Let task_id be new_task.task_id
    
    Let updated_manager be assign_task_with_optimization with manager as task_manager, task_id as task_id, agent_id as child_agent_id
    
    Let payload be Dictionary with:
        "message_type" as "NewTaskAssignment"
        "task_id" as task_id
    
    Let message_sent be send_message_async with target_agent_id as child_agent_id, payload as payload
    
    If message_sent:
        Return task_id
    Else:
        Return ""

Process called "report_task_progress_to_parent_async" that takes manager as HierarchyManager, child_agent_id as String, task_id as String, progress as Number returns Boolean:
    Let hierarchy be get_agent_hierarchy with manager as manager, agent_id as child_agent_id
    If hierarchy is not "":
        Let parent_agent_id be hierarchy.parent_id
        If parent_agent_id is not "":
            Let payload be Dictionary with:
                "message_type" as "TaskProgressUpdate"
                "task_id" as task_id
                "progress" as progress
            Let message_sent be send_message_async with target_agent_id as parent_agent_id, payload as payload
            Return message_sent
    Return false

Process called "select_child_round_robin" that takes hierarchy as AgentHierarchy, manager as HierarchyManager, parent_agent_id as String returns String:
    If length of hierarchy.children_ids is equal to 0:
        Return ""
    
    Let next_index be (hierarchy.last_round_robin_index + 1) % length of hierarchy.children_ids
    Let child_id be hierarchy.children_ids[next_index]
    
    Set hierarchy.last_round_robin_index to next_index
    Set manager.agent_hierarchies[parent_agent_id] to hierarchy
    
    Return child_id

Process called "select_child_least_loaded" that takes hierarchy as AgentHierarchy returns String:
    If length of hierarchy.children_ids is equal to 0:
        Return ""
    
    Let least_loaded_child_id be ""
    Let min_active_tasks be -1
    Let task_manager be create_task_manager()
    
    For each child_id in hierarchy.children_ids:
        Let active_tasks be get_active_task_count_for_agent with manager as task_manager, agent_id as child_id
        If min_active_tasks is equal to -1 or active_tasks < min_active_tasks:
            Set min_active_tasks to active_tasks
            Set least_loaded_child_id to child_id
            
    Return least_loaded_child_id

Process called "select_child_best_capability" that takes hierarchy as AgentHierarchy, task_description as String returns String:
    If length of hierarchy.children_ids is equal to 0:
        Return ""
        
    Let skill_registry be get_skill_registry()
    
    For each child_id in hierarchy.children_ids:
        If agent_has_skill with manager as skill_registry, agent_id as child_id, skill_name as task_description:
            Return child_id
            
    Return ""

Process called "select_child_highest_performance" that takes hierarchy as AgentHierarchy, task_description as String returns String:
    If length of hierarchy.children_ids is equal to 0:
        Return ""
        
    Let skill_registry be get_skill_registry()
    Let best_child_id be ""
    Let max_success_rate be -1.0
    
    For each child_id in hierarchy.children_ids:
        Let metrics be get_skill_performance_metrics with manager as skill_registry, agent_id as child_id, skill_name as task_description
        If metrics contains "success_rate":
            If metrics["success_rate"] > max_success_rate:
                Set max_success_rate to metrics["success_rate"]
                Set best_child_id to child_id
                
    Return best_child_id

Process called "select_child_weighted_random" that takes hierarchy as AgentHierarchy returns String:
    If length of hierarchy.children_ids is equal to 0:
        Return ""
        
    Let skill_registry be get_skill_registry()
    Let child_weights be Dictionary[String, Number] containing
    Let total_weight be 0.0
    
    For each child_id in hierarchy.children_ids:
        Let weight be get_agent_average_success_rate with manager as skill_registry, agent_id as child_id
        Set child_weights[child_id] to weight
        Set total_weight to total_weight plus weight
        
    If total_weight is equal to 0.0:
        Note: Fallback to random selection if no weights.
        Let random_index be random_integer_in_range with min as 0, max as length of hierarchy.children_ids - 1
        Return hierarchy.children_ids[random_index]
        
    Let random_value be random_float_in_range with min as 0.0, max as total_weight
    Let cumulative_weight be 0.0
    
    For each child_id and weight in child_weights:
        Set cumulative_weight to cumulative_weight plus weight
        If random_value <= cumulative_weight:
            Return child_id
            
    Return ""

Process called "select_child_adaptive" that takes hierarchy as AgentHierarchy, manager as HierarchyManager, parent_agent_id as String, task_description as String, input_data as Dictionary[String, Any] returns String:
    Note: First, try to find the best capability match.
    Let child_id be select_child_best_capability with hierarchy as hierarchy, task_description as task_description
    If child_id is not equal to "":
        Return child_id
        
    Note: If no capability match, fall back to the least loaded agent.
    Set child_id to select_child_least_loaded with hierarchy as hierarchy
    If child_id is not equal to "":
        Return child_id
        
    Note: If still no clear choice, use round robin.
    Return select_child_round_robin with hierarchy as hierarchy, manager as manager, parent_agent_id as parent_agent_id

Process called "select_optimal_child_agent" that takes hierarchy as AgentHierarchy, task_description as String, input_data as Dictionary[String, Any] returns String:
    Let best_child_id be ""
    Let max_score be -1.0
    
    Let config be get_config()
    Let weights be config.hierarchical["selection_weights"]
    Let capability_weight be weights["capability"]
    Let load_weight be weights["load"]
    Let performance_weight be weights["performance"]
    
    Let skill_registry be get_skill_registry()
    Let task_manager be create_task_manager()
    
    For each child_id in hierarchy.children_ids:
        Let score be 0.0
        
        Note: Capability score
        If agent_has_skill with manager as skill_registry, agent_id as child_id, skill_name as task_description:
            Set score to score plus capability_weight
            
        Note: Load score (inverted)
        Let active_tasks be get_active_task_count_for_agent with manager as task_manager, agent_id as child_id
        If active_tasks > 0:
            Set score to score - (load_weight * active_tasks)
            
        Note: Performance score
        Let metrics be get_skill_performance_metrics with manager as skill_registry, agent_id as child_id, skill_name as task_description
        If metrics contains "success_rate":
            Set score to score plus (performance_weight * metrics["success_rate"])
            
        If score > max_score:
            Set max_score to score
            Set best_child_id to child_id
            
    Return best_child_id

Process called "calculate_capability_match_score" that takes child_id as String, task_description as String returns Number:
    Let skill_registry be get_skill_registry()
    If agent_has_skill with manager as skill_registry, agent_id as child_id, skill_name as task_description:
        Return 1.0
    Return 0.0

Process called "calculate_load_balance_score" that takes child_id as String returns Number:
    Let task_manager be create_task_manager()
    Let active_tasks be get_active_task_count_for_agent with manager as task_manager, agent_id as child_id
    
    Note: Simple inversion of active tasks. More sophisticated models could be used.
    If active_tasks is equal to 0:
        Return 1.0
    Return 1.0 / active_tasks

Process called "calculate_performance_score" that takes child_id as String, task_description as String returns Number:
    Let skill_registry be get_skill_registry()
    Let metrics be get_skill_performance_metrics with manager as skill_registry, agent_id as child_id, skill_name as task_description
    If metrics contains "success_rate":
        Return metrics["success_rate"] / 100.0
    Return 0.0