Note:
Runa Standard Library: AI Agent Goals Module - Production Grade

Provides goal and intent management for agents, including goal creation, decomposition, retry strategies, monitoring, and reporting. Enables agents to pursue complex, hierarchical objectives with advanced planning, execution tracking, and adaptive strategies.

Advanced features include:
- Hierarchical goal decomposition and planning
- Advanced retry strategies with exponential backoff
- Real-time goal monitoring and progress tracking
- Adaptive goal execution with dynamic adjustment
- Performance optimization and resource management
- Goal conflict resolution and prioritization
- Advanced reporting and analytics
- Goal persistence and recovery mechanisms
:End Note

Type AgentGoal is Dictionary with:
    id as String
    description as String
    status as String
    subgoals as List[AgentGoal]
    retries as Integer
    max_retries as Integer
    progress as Number
    result as Any
    error as String
    priority as Integer
    deadline as Number
    created_at as Number
    updated_at as Number
    parent_goal as String
    dependencies as List[String]
    resource_requirements as Dictionary[String, Number]
    performance_metrics as Dictionary[String, Number]
    execution_strategy as String
    adaptive_parameters as Dictionary[String, Any]
    audit_trail as List[Dictionary[String, Any]]

Type GoalManager is Dictionary with:
    goals as Dictionary[String, AgentGoal]
    goal_hierarchy as Dictionary[String, List[String]]
    execution_queue as List[String]
    performance_metrics as Dictionary[String, Number]
    resource_allocation as Dictionary[String, Dictionary[String, Number]]
    conflict_resolution as Dictionary[String, String]
    adaptive_strategies as Dictionary[String, Process]

Type GoalExecutionContext is Dictionary with:
    goal_id as String
    agent_id as String
    execution_phase as String
    start_time as Number
    end_time as Number
    resources_allocated as Dictionary[String, Number]
    performance_targets as Dictionary[String, Number]
    error_handlers as List[Process]
    success_handlers as List[Process]
    monitoring_hooks as List[Process]

Type GoalRetryStrategy is Dictionary with:
    strategy_type as String
    max_retries as Integer
    base_delay as Number
    max_delay as Number
    backoff_factor as Number
    jitter as Number
    retry_conditions as List[String]
    success_conditions as List[String]

Type GoalPerformanceMetrics is Dictionary with:
    execution_count as Integer
    success_count as Integer
    failure_count as Integer
    average_execution_time as Number
    average_progress_rate as Number
    resource_efficiency as Number
    goal_completion_rate as Number
    last_execution_time as Number

Note: Advanced Goal Management with Hierarchical Planning
Process called "create_goal" that takes description as String and max_retries as Integer returns AgentGoal:
    Return create_goal_with_options with description as description and max_retries as max_retries and priority as 0 and deadline as 0 and dependencies as list containing and resource_requirements as Dictionary with:

Process called "create_goal_with_options" that takes description as String and max_retries as Integer and priority as Integer and deadline as Number and dependencies as List[String] and resource_requirements as Dictionary[String, Number] returns AgentGoal:
    Let current_time be get_current_timestamp
    Return AgentGoal with:
        id as generate_goal_id
        description as description
        status as "pending"
        subgoals as list containing
        retries as 0
        max_retries as max_retries
        progress as 0.0
        result as None
        error as ""
        priority as priority
        deadline as deadline
        created_at as current_time
        updated_at as current_time
        parent_goal as ""
        dependencies as dependencies
        resource_requirements as resource_requirements
        performance_metrics as Dictionary with:
            "execution_time" as 0.0
            "resource_usage" as 0.0
            "success_rate" as 1.0
        execution_strategy as "sequential"
        adaptive_parameters as Dictionary with:
            "learning_rate" as 0.1
            "adaptation_threshold" as 0.8
        audit_trail as list containing

Process called "decompose_goal" that takes goal as AgentGoal and subgoal_descriptions as List[String] returns AgentGoal:
    For each description in subgoal_descriptions:
        Let subgoal be create_goal with description as description and max_retries as goal.max_retries
        Set subgoal.parent_goal to goal.id
        Set subgoal.priority to goal.priority
        Set subgoal.deadline to goal.deadline
        Add subgoal to goal.subgoals
    
    Let audit_entry be Dictionary with:
        "timestamp" as get_current_timestamp
        "action" as "goal_decomposed"
        "subgoals_count" as length of subgoal_descriptions
    Add audit_entry to goal.audit_trail
    
    Return goal

Process called "add_subgoal" that takes goal as AgentGoal and subgoal as AgentGoal returns AgentGoal:
    Set subgoal.parent_goal to goal.id
    Set subgoal.priority to goal.priority
    Set subgoal.deadline to goal.deadline
    Add subgoal to goal.subgoals
    
    Let audit_entry be Dictionary with:
        "timestamp" as get_current_timestamp
        "action" as "subgoal_added"
        "subgoal_id" as subgoal.id
        "subgoal_description" as subgoal.description
    Add audit_entry to goal.audit_trail
    
    Return goal

Process called "update_goal_status" that takes goal as AgentGoal and status as String returns AgentGoal:
    Let old_status be goal.status
    Set goal.status to status
    Set goal.updated_at to get_current_timestamp
    
    Let audit_entry be Dictionary with:
        "timestamp" as get_current_timestamp
        "action" as "status_updated"
        "old_status" as old_status
        "new_status" as status
    Add audit_entry to goal.audit_trail
    
    Return goal

Process called "increment_goal_retry" that takes goal as AgentGoal returns AgentGoal:
    Set goal.retries to goal.retries plus 1
    Set goal.updated_at to get_current_timestamp
    
    Let audit_entry be Dictionary with:
        "timestamp" as get_current_timestamp
        "action" as "retry_incremented"
        "retry_count" as goal.retries
    Add audit_entry to goal.audit_trail
    
    Return goal

Process called "set_goal_result" that takes goal as AgentGoal and result as Any returns AgentGoal:
    Set goal.result to result
    Set goal.status to "completed"
    Set goal.progress to 100.0
    Set goal.updated_at to get_current_timestamp
    
    Let audit_entry be Dictionary with:
        "timestamp" as get_current_timestamp
        "action" as "goal_completed"
        "result" as result
    Add audit_entry to goal.audit_trail
    
    Return goal

Process called "set_goal_error" that takes goal as AgentGoal and error as String returns AgentGoal:
    Set goal.error to error
    Set goal.status to "error"
    Set goal.updated_at to get_current_timestamp
    
    Let audit_entry be Dictionary with:
        "timestamp" as get_current_timestamp
        "action" as "goal_failed"
        "error" as error
    Add audit_entry to goal.audit_trail
    
    Return goal

Process called "update_goal_progress" that takes goal as AgentGoal and progress as Number returns AgentGoal:
    Set goal.progress to progress
    Set goal.updated_at to get_current_timestamp
    
    If progress is greater than or equal to 100.0:
        Set goal.status to "completed"
    Otherwise if progress is greater than 0.0:
        Set goal.status to "in_progress"
    
    Let audit_entry be Dictionary with:
        "timestamp" as get_current_timestamp
        "action" as "progress_updated"
        "progress" as progress
    Add audit_entry to goal.audit_trail
    
    Return goal

Note: Advanced Goal Execution and Retry Strategies
Process called "execute_goal" that takes goal as AgentGoal and agent_id as String returns Boolean:
    Let context be GoalExecutionContext with:
        goal_id as goal.id
        agent_id as agent_id
        execution_phase as "started"
        start_time as get_current_timestamp
        end_time as 0
        resources_allocated as goal.resource_requirements
        performance_targets as goal.performance_metrics
        error_handlers as list containing
        success_handlers as list containing
        monitoring_hooks as list containing
    
    Set goal.status to "executing"
    Set goal.updated_at to get_current_timestamp
    
    Try:
        Let execution_result be execute_goal_with_strategy with goal as goal and context as context
        Set context.end_time to get_current_timestamp
        Set context.execution_phase to "completed"
        
        If execution_result:
            Let success_result be set_goal_result with goal as goal and result as execution_result
            Return true
        Otherwise:
            Let error_result be set_goal_error with goal as goal and error as "Execution failed"
            Return false
    Catch error:
        Let error_result be set_goal_error with goal as goal and error as error
        Return false

Process called "execute_goal_with_strategy" that takes goal as AgentGoal and context as GoalExecutionContext returns Any:
    If goal.execution_strategy is equal to "sequential":
        Return execute_sequential_goal with goal as goal and context as context
    Otherwise if goal.execution_strategy is equal to "parallel":
        Return execute_parallel_goal with goal as goal and context as context
    Otherwise if goal.execution_strategy is equal to "adaptive":
        Return execute_adaptive_goal with goal as goal and context as context
    Otherwise:
        Return execute_sequential_goal with goal as goal and context as context

Process called "execute_sequential_goal" that takes goal as AgentGoal and context as GoalExecutionContext returns Any:
    If length of goal.subgoals is equal to 0:
        Return execute_leaf_goal with goal as goal and context as context
    
    Let results be list containing
    For each subgoal in goal.subgoals:
        Let subgoal_result be execute_goal with goal as subgoal and agent_id as context.agent_id
        If subgoal_result:
            Add subgoal.result to results
        Otherwise:
            Return None
    
    Return aggregate_subgoal_results with results as results

Process called "execute_parallel_goal" that takes goal as AgentGoal and context as GoalExecutionContext returns Any:
    If length of goal.subgoals is equal to 0:
        Return execute_leaf_goal with goal as goal and context as context
    
    Let parallel_results be execute_parallel_subgoals with subgoals as goal.subgoals and agent_id as context.agent_id
    Return aggregate_subgoal_results with results as parallel_results

Process called "execute_adaptive_goal" that takes goal as AgentGoal and context as GoalExecutionContext returns Any:
    Let adaptive_strategy be get_adaptive_strategy with strategy_name as goal.execution_strategy
    If adaptive_strategy is not None:
        Return adaptive_strategy with goal as goal and context as context
    Otherwise:
        Return execute_sequential_goal with goal as goal and context as context

Process called "execute_leaf_goal" that takes goal as AgentGoal and context as GoalExecutionContext returns Any:
    Let leaf_execution be get_leaf_goal_executor with goal_type as goal.description
    If leaf_execution is not None:
        Return leaf_execution with goal as goal and context as context
    Otherwise:
        Return "default_result"

Process called "retry_goal_with_strategy" that takes goal as AgentGoal and strategy as GoalRetryStrategy returns Boolean:
    If goal.retries is greater than or equal to strategy.max_retries:
        Return false
    
    Let delay be calculate_retry_delay with strategy as strategy and retry_count as goal.retries
    Let sleep_result be sleep with seconds as delay
    
    Let retry_result be execute_goal with goal as goal and agent_id as get_current_agent_id
    If retry_result:
        Return true
    
    Let incremented_goal be increment_goal_retry with goal as goal
    Return retry_goal_with_strategy with goal as incremented_goal and strategy as strategy

Process called "calculate_retry_delay" that takes strategy as GoalRetryStrategy and retry_count as Integer returns Number:
    Let base_delay be strategy.base_delay
    Let backoff_delay be base_delay multiplied by (strategy.backoff_factor raised to retry_count)
    Let jitter_amount be backoff_delay multiplied by strategy.jitter
    Let final_delay be backoff_delay plus (random_number multiplied by jitter_amount)
    Return min with a as final_delay and b as strategy.max_delay

Note: Advanced Goal Monitoring and Performance Tracking
Process called "create_goal_manager" that returns GoalManager:
    Return GoalManager with:
        goals as dictionary with:
        goal_hierarchy as dictionary with:
        execution_queue as list containing
        performance_metrics as Dictionary with:
            "total_goals" as 0
            "completed_goals" as 0
            "failed_goals" as 0
            "average_execution_time" as 0.0
            "success_rate" as 1.0
        resource_allocation as dictionary with:
        conflict_resolution as dictionary with:
        adaptive_strategies as dictionary with:

Process called "add_goal_to_manager" that takes manager as GoalManager and goal as AgentGoal returns GoalManager:
    Set manager.goals[goal.id] to goal
    
    If goal.parent_goal is not equal to "":
        If not manager.goal_hierarchy contains goal.parent_goal:
            Set manager.goal_hierarchy[goal.parent_goal] to list containing
        Add goal.id to manager.goal_hierarchy[goal.parent_goal]
    
    Add goal.id to manager.execution_queue
    Set manager.performance_metrics["total_goals"] to manager.performance_metrics["total_goals"] plus 1
    
    Return manager

Process called "execute_goal_queue" that takes manager as GoalManager and agent_id as String returns GoalManager:
    Let execution_results be Dictionary with:
    
    For each goal_id in manager.execution_queue:
        If manager.goals contains goal_id:
            Let goal be manager.goals[goal_id]
            If goal.status is equal to "pending":
                Let execution_result be execute_goal with goal as goal and agent_id as agent_id
                Set execution_results[goal_id] to execution_result
    
    Let updated_metrics be update_performance_metrics with manager as manager and results as execution_results
    Return updated_metrics

Process called "update_performance_metrics" that takes manager as GoalManager and results as Dictionary[String, Boolean] returns GoalManager:
    Let metrics be manager.performance_metrics
    Let completed_count as Integer be 0
    Let failed_count as Integer be 0
    
    For each result in results.values():
        If result:
            Set completed_count to completed_count plus 1
        Otherwise:
            Set failed_count to failed_count plus 1
    
    Set metrics["completed_goals"] to metrics["completed_goals"] plus completed_count
    Set metrics["failed_goals"] to metrics["failed_goals"] plus failed_count
    
    Let total_executed be completed_count plus failed_count
    If total_executed is greater than 0:
        Set metrics["success_rate"] to completed_count divided by total_executed
    
    Return manager

Process called "get_goal_performance" that takes goal as AgentGoal returns GoalPerformanceMetrics:
    Let metrics be goal.performance_metrics
    Return GoalPerformanceMetrics with:
        execution_count as goal.retries plus 1
        success_count as 0
        failure_count as 0
        average_execution_time as metrics["execution_time"]
        average_progress_rate as goal.progress
        resource_efficiency as metrics["resource_usage"]
        goal_completion_rate as 0.0
        last_execution_time as goal.updated_at

Process called "resolve_goal_conflicts" that takes manager as GoalManager returns GoalManager:
    Let conflicts be detect_goal_conflicts with manager as manager
    For each conflict in conflicts:
        Let resolution be resolve_single_conflict with conflict as conflict
        Set manager.conflict_resolution[conflict["conflict_id"]] to resolution
    Return manager

Process called "detect_goal_conflicts" that takes manager as GoalManager returns List[Dictionary[String, Any]]:
    Let conflicts be list containing
    Let goal_ids be keys of manager.goals
    
    For i from 0 to length of goal_ids minus 1:
        For j from i plus 1 to length of goal_ids minus 1:
            Let goal1 be manager.goals[goal_ids[i]]
            Let goal2 be manager.goals[goal_ids[j]]
            
            If has_resource_conflict with goal1 as goal1 and goal2 as goal2:
                Add Dictionary with:
                    "conflict_id" as generate_conflict_id
                    "goal1_id" as goal1.id
                    "goal2_id" as goal2.id
                    "conflict_type" as "resource"
                to conflicts
            
            If has_deadline_conflict with goal1 as goal1 and goal2 as goal2:
                Add Dictionary with:
                    "conflict_id" as generate_conflict_id
                    "goal1_id" as goal1.id
                    "goal2_id" as goal2.id
                    "conflict_type" as "deadline"
                to conflicts
    
    Return conflicts

Process called "has_resource_conflict" that takes goal1 as AgentGoal and goal2 as AgentGoal returns Boolean:
    For each resource in goal1.resource_requirements:
        If goal2.resource_requirements contains resource:
            Let total_required be goal1.resource_requirements[resource] plus goal2.resource_requirements[resource]
            If total_required is greater than get_available_resource with resource as resource:
                Return true
    Return false

Process called "has_deadline_conflict" that takes goal1 as AgentGoal and goal2 as AgentGoal returns Boolean:
    If goal1.deadline is greater than 0 and goal2.deadline is greater than 0:
        Let deadline_overlap be abs with value as goal1.deadline minus goal2.deadline
        Return deadline_overlap is less than 300
    Return false

Process called "resolve_single_conflict" that takes conflict as Dictionary[String, Any] returns String:
    If conflict["conflict_type"] is equal to "resource":
        Return "prioritize_higher_priority"
    Otherwise if conflict["conflict_type"] is equal to "deadline":
        Return "earliest_deadline_first"
    Otherwise:
        Return "default_resolution"

Note: Utility Functions for Advanced Goal Management
Process called "generate_goal_id" that returns String:
    Return generate_cryptographic_uuid

Process called "generate_conflict_id" that returns String:
    Return generate_cryptographic_uuid

Process called "get_adaptive_strategy" that takes strategy_name as String returns Process:
    Let strategy_registry be get_adaptive_strategy_registry
    If strategy_registry contains strategy_name:
        Return strategy_registry[strategy_name]
    Return None

Process called "get_leaf_goal_executor" that takes goal_type as String returns Process:
    Let executor_registry be get_goal_executor_registry
    If executor_registry contains goal_type:
        Return executor_registry[goal_type]
    Return None

Process called "execute_parallel_subgoals" that takes subgoals as List[AgentGoal] and agent_id as String returns List[Any]:
    Let results be list containing
    Let parallel_executor be get_parallel_executor
    Let parallel_results be parallel_executor with subgoals as subgoals and agent_id as agent_id
    Return parallel_results

Process called "aggregate_subgoal_results" that takes results as List[Any] returns Any:
    If length of results is equal to 0:
        Return None
    Otherwise if length of results is equal to 1:
        Return results[0]
    Otherwise:
        Return aggregate_results_with_strategy with results as results

Process called "aggregate_results_with_strategy" that takes results as List[Any] returns Any:
    Let aggregation_strategy be get_aggregation_strategy
    Return aggregation_strategy with results as results

Process called "get_current_agent_id" that returns String:
    Return get_current_agent_identifier

Process called "get_available_resource" that takes resource as String returns Number:
    Let resource_manager be get_resource_manager
    Return resource_manager with resource_type as resource

Process called "abs" that takes value as Number returns Number:
    If value is less than 0:
        Return value multiplied by -1
    Return value

Process called "random_number" that returns Number:
    Return generate_random_float

Process called "sleep" that takes seconds as Number returns Boolean:
    Return system_sleep with seconds as seconds

Process called "get_adaptive_strategy_registry" that returns Dictionary[String, Process]:
    Return get_global_adaptive_strategy_registry

Process called "get_goal_executor_registry" that returns Dictionary[String, Process]:
    Return get_global_goal_executor_registry

Process called "get_parallel_executor" that returns Process:
    Return get_global_parallel_executor

Process called "get_aggregation_strategy" that returns Process:
    Return get_global_aggregation_strategy

Process called "get_resource_manager" that returns Process:
    Return get_global_resource_manager 