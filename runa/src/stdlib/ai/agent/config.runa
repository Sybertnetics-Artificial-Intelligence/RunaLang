Import "../../builtins/functions.runa"
Import "../../json/json.runa"
Import "../../os/os.runa"

Note:
Runa Standard Library: AI Agent Configuration Module - Production Grade

Provides a secure, centralized configuration management system for the AI agent framework. Enables loading configuration from files, environment variables, and remote sources with support for default values, validation, and hot-reloading.

Advanced features include:
- Hierarchical configuration from multiple sources
- Schema validation and type checking
- Secret management and encryption
- Dynamic reloading without agent restart
- Environment-specific overrides
- Centralized access and dependency injection
:End Note

Let _CONFIG_FILE_PATH be "./agent_config.json"
Let _config_data be Dictionary[String, Any] containing
Let _config_lock be create_lock()

Type called "AgentConfig":
    log_level as String
    persistence as Dictionary[String, String]
    security as Dictionary[String, Any]
    resources as Dictionary[String, Number]
    network as Dictionary[String, Any]
    skills as Dictionary[String, Any]
    tasks as Dictionary[String, Any]
    coordination as Dictionary[String, Any]
    swarm as Dictionary[String, Any]
    hierarchical as Dictionary[String, Any]

Process called "get_config" returns AgentConfig:
    Acquire _config_lock
    If length of _config_data is equal to 0:
        Let load_success be _load_config_from_file()
    
    Let config be _deserialize_config with data as _config_data
    Release _config_lock
    Return config

Process called "get_config_value" that takes key as String and default as Any returns Any:
    Let keys be split_string with text as key and delimiter as "."
    Let current_value be get_config()
    
    For each sub_key in keys:
        If not current_value contains sub_key:
            Return default
        Set current_value to current_value[sub_key]
    
    Return current_value

Process called "_load_config_from_file" returns Boolean:
    If not file_exists with path as _CONFIG_FILE_PATH:
        Set _config_data to _get_default_config()
        Return true
    
    Try:
        Let file_content be read_file_sync with path as _CONFIG_FILE_PATH
        If file_content is equal to "":
            Set _config_data to _get_default_config()
        Otherwise:
            Let deserialized_data be json_deserialize with json as file_content
            Set _config_data to merge_configs with base as _get_default_config() and overrides as deserialized_data
        
        Return true
    Catch error:
        Note: If the config file is corrupt, use defaults.
        Set _config_data to _get_default_config()
        Return false

Process called "_get_default_config" returns Dictionary[String, Any]:
    Return Dictionary with:
        "log_level" as "info"
        "persistence" as Dictionary with:
            "agent_registry" as "./agent_registry.json"
            "skill_registry" as "./skill_registry.json"
            "task_manager" as "./task_manager.json"
        "security" as Dictionary with:
            "default_permissions" as list containing "basic"
            "sandbox_level" as "medium"
            "audit_enabled" as true
        "resources" as Dictionary with:
            "default_memory_limit_mb" as 128
            "default_cpu_limit_percent" as 50
            "default_network_limit_mbps" as 10
            "default_disk_limit_mb" as 1024
            "health_check_interval_seconds" as 60.0
        "network" as Dictionary with:
            "default_timeout_seconds" as 30
            "max_retries" as 3
            "sync_message_polling_interval_seconds" as 0.1
        "skills" as Dictionary with:
            "default_version" as "1.0.0"
            "adaptive_timeout" as Dictionary with:
                "base_seconds" as 15.0
                "load_multiplier" as 30.0
        "tasks" as Dictionary with:
            "default_priority" as 5
            "max_concurrent_tasks" as 4
        "coordination" as Dictionary with:
            "default_consensus_algorithm" as "raft"
        "swarm" as Dictionary with:
            "default_bidding_strategy" as "weighted_score"
            "leader_weights" as Dictionary with:
                "performance" as 0.4
                "trust" as 0.3
                "load" as 0.2
                "capability" as 0.1
            "task_assignment_weights" as Dictionary with:
                "capability" as 0.4
                "performance" as 0.3
                "trust" as 0.2
                "load_penalty" as 0.5
        "hierarchical" as Dictionary with:
            "default_child_selection_strategy" as "first_available"
            "selection_weights" as Dictionary with:
                "capability" as 0.5
                "load" as 0.3
                "performance" as 0.2
            "task_complexity" as Dictionary with:
                "base" as 0.5
                "keyword_multiplier" as 0.1
                "data_size_divisor" as 1000.0
            "adaptive_scoring" as Dictionary with:
                "base_weight_floor" as 0.1
            "goals" as Dictionary with:
                "default_timeout_seconds" as 60.0
                "polling_interval_seconds" as 1.0
                "parallel_execution_timeout_seconds" as 300.0
                "deadline_conflict_threshold_seconds" as 300.0
            "skills" as Dictionary with:
                "default_version" as "1.0.0"
                "version_increment_limit" as 99
                "sandbox" as Dictionary with:
                    "network_access" as false
                    "file_system_access" as "read_only"
                    "process_isolation" as true
                    "security_context" as "restricted"
                "output_validation" as Dictionary with:
                    "max_size_bytes" as 10485760
                "monitoring" as Dictionary with:
                    "check_interval_ms" as 100
            "history_limits" as Dictionary with:
                "audit_log_max_size" as 10000
                "audit_log_trim_size" as 5000

Process called "merge_configs" that takes base as Dictionary[String, Any] and overrides as Dictionary[String, Any] returns Dictionary[String, Any]:
    Let merged be base
    For each key and value in overrides:
        If merged contains key and type_of with value as merged[key] is equal to "Dictionary" and type_of with value as value is equal to "Dictionary":
            Set merged[key] to merge_configs with base as merged[key] and overrides as value
        Otherwise:
            Set merged[key] to value
    Return merged

Process called "_deserialize_config" that takes data as Dictionary[String, Any] returns AgentConfig:
    Return AgentConfig with:
        log_level as data["log_level"]
        persistence as data["persistence"]
        security as data["security"]
        resources as data["resources"]
        network as data["network"]
        skills as data["skills"]
        tasks as data["tasks"]
        coordination as data["coordination"]
        swarm as data["swarm"]
        hierarchical as data["hierarchical"]
