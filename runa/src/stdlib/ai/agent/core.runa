Process called "retry_operation" that takes context as ExecutionContext and backoff_time as Number returns Boolean:
    Let sleep_time be backoff_time
    Let max_retries be 3
    Let current_retry be 0
    
    While current_retry is less than max_retries:
        Let sleep_result be sleep with seconds as sleep_time
        Let retry_result be execute_skill_with_context with context as context
        If retry_result is not None:
            Return true
        Set current_retry to current_retry plus 1
        Set sleep_time to sleep_time multiplied by 2.0
    
    Return false

Process called "get_success_rate_for_agent" that takes agent_id as String returns Number:
    Let agent_state be get_agent_state with agent_id as agent_id
    Return get_success_rate with state as agent_state

Process called "get_average_response_time" that takes agent_id as String returns Number:
    Let performance_history be get_agent_performance_history with agent_id as agent_id
    Let total_time be 0.0
    Let count be 0
    
    For each entry in performance_history:
        If entry contains "execution_time_ms":
            Set total_time to total_time plus entry["execution_time_ms"]
            Set count to count plus 1
    
    If count is equal to 0:
        Return 0.0
    Return total_time divided by count

Process called "serialize_data" that takes data as Any returns String:
    Return json_serialize with data as data

Process called "sleep" that takes seconds as Number returns Boolean:
    Return system_sleep with seconds as seconds

