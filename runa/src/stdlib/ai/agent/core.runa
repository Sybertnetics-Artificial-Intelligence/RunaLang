    circuit_breaker_state as String
    circuit_breaker_failures as Integer
    circuit_breaker_threshold as Integer
    circuit_breaker_timeout as Number
    resource_usage as Dictionary[String, Number]
    memory_usage as Number
    cpu_usage as Number
    network_io as Dictionary[String, Number]
    error_history as List[Dictionary[String, Any]]
    performance_history as List[Dictionary[String, Any]]
    health_score as Number
    load_factor as Number
    priority as Integer
    tags as List[String]

