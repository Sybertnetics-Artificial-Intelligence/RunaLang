Note: Taxonomic Classification System for AI Agents
Implements comprehensive taxonomic hierarchies, automatic classification,
multi-faceted taxonomies, and hierarchical reasoning capabilities
Competitive with biological taxonomies, library classification systems, and leading taxonomic frameworks :End Note

Type called "TaxonomySystem":
    system id as String
    taxonomy type as String  Note: "hierarchical", "faceted", "polyhierarchical", "network", "hybrid"
    classification scheme as ClassificationScheme
    taxonomy structure as TaxonomyStructure
    classification engine as ClassificationEngine
    hierarchy manager as HierarchyManager
    validation framework as ValidationFramework
    evolution tracker as EvolutionTracker
    mapping system as MappingSystem
    system configuration as SystemConfiguration

Type called "ClassificationScheme":
    scheme id as String
    scheme name as String
    scheme type as String  Note: "dewey", "lcc", "udc", "biological", "custom", "domain_specific"
    classification levels as List[ClassificationLevel]
    classification criteria as List[ClassificationCriterion]
    notation system as NotationSystem
    scope definition as ScopeDefinition
    authority control as AuthorityControl
    scheme maintenance as SchemeMaintenance

Type called "TaxonomyStructure":
    structure id as String
    root nodes as List[TaxonomyNode]
    hierarchy depth as Integer
    branching factor as BranchingFactor
    node relationships as List[NodeRelationship]
    cross references as List[CrossReference]
    structural constraints as List[StructuralConstraint]
    structure statistics as StructureStatistics

Type called "TaxonomyNode":
    node id as String
    node label as String
    node type as String  Note: "category", "subcategory", "class", "subclass", "species", "variety"
    node level as Integer
    parent nodes as List[TaxonomyNode]
    child nodes as List[TaxonomyNode]
    sibling nodes as List[TaxonomyNode]
    node properties as Dictionary[String, Any]
    classification code as String
    scope notes as List[ScopeNote]
    authority information as AuthorityInformation

Type called "ClassificationEngine":
    engine id as String
    classification algorithms as List[ClassificationAlgorithm]
    feature extractors as List[FeatureExtractor]
    similarity measures as List[SimilarityMeasure]
    decision strategies as List[DecisionStrategy]
    confidence assessment as ConfidenceAssessment
    automatic classification as AutomaticClassification
    manual classification as ManualClassification

Type called "ClassificationAlgorithm":
    algorithm id as String
    algorithm name as String
    algorithm type as String  Note: "rule_based", "machine_learning", "statistical", "pattern_matching", "hybrid"
    algorithm implementation as AlgorithmImplementation
    training data as TrainingData
    performance metrics as PerformanceMetrics
    parameter configuration as ParameterConfiguration
    algorithm validation as AlgorithmValidation

Type called "FeatureExtractor":
    extractor id as String
    extraction type as String  Note: "textual", "structural", "semantic", "statistical", "domain_specific"
    feature types as List[FeatureType]
    extraction methods as List[ExtractionMethod]
    feature weighting as FeatureWeighting
    feature selection as FeatureSelection
    extraction performance as ExtractionPerformance

Type called "HierarchyManager":
    manager id as String
    hierarchy operations as List[HierarchyOperation]
    consistency maintenance as ConsistencyMaintenance
    hierarchy validation as HierarchyValidation
    structural optimization as StructuralOptimization
    relationship management as RelationshipManagement
    hierarchy evolution as HierarchyEvolution
    conflict resolution as ConflictResolution

Type called "ClassificationResult":
    result id as String
    classified item as ClassifiedItem
    assigned categories as List[AssignedCategory]
    classification confidence as Float
    classification reasoning as ClassificationReasoning
    alternative classifications as List[AlternativeClassification]
    classification metadata as ClassificationMetadata
    quality assessment as QualityAssessment

Type called "AssignedCategory":
    category id as String
    category path as List[TaxonomyNode]
    assignment confidence as Float
    assignment method as String  Note: "automatic", "manual", "hybrid", "inherited"
    supporting evidence as List[SupportingEvidence]
    assignment rationale as AssignmentRationale
    quality indicators as List[QualityIndicator]

Note: Taxonomy Management Engine
Process called "create_taxonomy_system" that takes config as Dictionary returns Dictionary:
    Let taxonomy_system be create_taxonomy_structure
    Set taxonomy_system with key "system_id" to generate_taxonomy_id
    Set taxonomy_system with key "taxonomy_type" to config with key "type" or "hierarchical"
    Set taxonomy_system with key "automatic_classification" to config with key "automatic" or true
    Set taxonomy_system with key "multi_faceted_support" to config with key "multi_faceted" or true
    Set taxonomy_system with key "cross_reference_support" to config with key "cross_references" or true
    Set taxonomy_system with key "hierarchy_validation" to config with key "validation" or true
    Set taxonomy_system with key "dynamic_evolution" to config with key "evolution" or true
    Set taxonomy_system with key "authority_control" to config with key "authority_control" or true
    Set taxonomy_system with key "mapping_support" to config with key "mapping" or true
    Set taxonomy_system with key "reasoning_support" to config with key "reasoning" or true
    Set taxonomy_system with key "performance_optimization" to config with key "optimization" or true
    
    Note: Initialize classification scheme
    Let classification_scheme be initialize_classification_scheme with config
    Set taxonomy_system with key "classification_scheme" to classification_scheme
    
    Note: Initialize taxonomy structure
    Let taxonomy_structure be initialize_taxonomy_structure with config
    Set taxonomy_system with key "taxonomy_structure" to taxonomy_structure
    
    Note: Initialize classification engine
    Let classification_engine be initialize_classification_engine with config
    Set taxonomy_system with key "classification_engine" to classification_engine
    
    Note: Initialize hierarchy manager
    Let hierarchy_manager be initialize_hierarchy_manager with config
    Set taxonomy_system with key "hierarchy_manager" to hierarchy_manager
    
    Note: Initialize validation framework
    Let validation_framework be initialize_validation_framework with config
    Set taxonomy_system with key "validation_framework" to validation_framework
    
    Note: Initialize evolution tracker
    Let evolution_tracker be initialize_evolution_tracker with config
    Set taxonomy_system with key "evolution_tracker" to evolution_tracker
    
    Note: Initialize mapping system
    Let mapping_system be initialize_mapping_system with config
    Set taxonomy_system with key "mapping_system" to mapping_system
    
    Return taxonomy_system

Process called "construct_taxonomy" that takes taxonomy_system as Dictionary and construction_context as Dictionary returns Dictionary:
    Let construction_result be empty dictionary
    Set construction_result with key "construction_id" to generate_construction_id
    Set construction_result with key "construction_timestamp" to current_timestamp
    
    Let domain_data be construction_context with key "domain_data"
    Let construction_strategy be construction_context with key "strategy"
    Let taxonomy_requirements be construction_context with key "requirements"
    
    Note: Phase 1: Analyze domain structure
    Let domain_analysis_result be analyze_domain_structure_for_taxonomy with taxonomy_system and domain_data
    Set construction_result with key "domain_analysis" to domain_analysis_result
    
    Note: Phase 2: Extract taxonomic entities
    Let entity_extraction_result be extract_taxonomic_entities with taxonomy_system and domain_analysis_result
    Set construction_result with key "entity_extraction" to entity_extraction_result
    
    Note: Phase 3: Identify hierarchical relationships
    Let relationship_identification_result be identify_hierarchical_relationships with taxonomy_system and entity_extraction_result
    Set construction_result with key "relationship_identification" to relationship_identification_result
    
    Note: Phase 4: Build taxonomy structure
    Let structure_building_result be build_taxonomy_structure with taxonomy_system and relationship_identification_result
    Set construction_result with key "structure_building" to structure_building_result
    
    Note: Phase 5: Validate taxonomy consistency
    Let consistency_validation_result be validate_taxonomy_consistency with taxonomy_system and construction_result
    Set construction_result with key "consistency_validation" to consistency_validation_result
    
    Note: Phase 6: Optimize taxonomy structure
    Let optimization_result be optimize_taxonomy_structure with taxonomy_system and construction_result
    Set construction_result with key "optimization" to optimization_result
    
    Note: Phase 7: Create classification scheme
    Let scheme_creation_result be create_classification_scheme_from_taxonomy with taxonomy_system and construction_result
    Set construction_result with key "scheme_creation" to scheme_creation_result
    
    Return construction_result

Process called "classify_item" that takes taxonomy_system as Dictionary and classification_context as Dictionary returns Dictionary:
    Let classification_result be empty dictionary
    Set classification_result with key "classification_id" to generate_classification_id
    Set classification_result with key "classification_timestamp" to current_timestamp
    
    Let item_to_classify be classification_context with key "item"
    Let classification_method be classification_context with key "method"
    Let confidence_threshold be classification_context with key "threshold"
    
    Let classification_engine be taxonomy_system with key "classification_engine"
    
    Note: Extract features from item
    Let feature_extraction_result be extract_classification_features with item_to_classify and classification_engine
    Set classification_result with key "feature_extraction" to feature_extraction_result
    
    Note: Perform classification based on method
    If classification_method is equal to "automatic":
        Let automatic_classification_result be perform_automatic_classification with feature_extraction_result and classification_engine and taxonomy_system
        Set classification_result with key "classification_execution" to automatic_classification_result
    
    If classification_method is equal to "rule_based":
        Let rule_based_classification_result be perform_rule_based_classification with feature_extraction_result and classification_engine and taxonomy_system
        Set classification_result with key "classification_execution" to rule_based_classification_result
    
    If classification_method is equal to "machine_learning":
        Let ml_classification_result be perform_ml_classification with feature_extraction_result and classification_engine and taxonomy_system
        Set classification_result with key "classification_execution" to ml_classification_result
    
    If classification_method is equal to "hybrid":
        Let hybrid_classification_result be perform_hybrid_classification with feature_extraction_result and classification_engine and taxonomy_system
        Set classification_result with key "classification_execution" to hybrid_classification_result
    
    Note: Validate classification results
    Let classification_validation be validate_classification_results with classification_result with key "classification_execution" and taxonomy_system
    Set classification_result with key "classification_validation" to classification_validation
    
    Note: Generate classification explanations
    Let classification_explanation be generate_classification_explanation with classification_result and taxonomy_system
    Set classification_result with key "classification_explanation" to classification_explanation
    
    Note: Assess classification confidence
    Let confidence_assessment be assess_classification_confidence with classification_result and taxonomy_system
    Set classification_result with key "confidence_assessment" to confidence_assessment
    
    Return classification_result

Process called "perform_automatic_classification" that takes feature_data as Dictionary and classification_engine as Dictionary and taxonomy_system as Dictionary returns Dictionary:
    Let automatic_result be empty dictionary
    Set automatic_result with key "classification_method" to "automatic_taxonomy_classification"
    
    Let extracted_features be feature_data with key "features"
    Let feature_weights be feature_data with key "weights"
    Let classification_algorithms be classification_engine with key "classification_algorithms"
    
    Let classification_candidates be empty list
    
    Note: Apply multiple classification algorithms
    For each algorithm in classification_algorithms:
        Let algorithm_result be apply_classification_algorithm with algorithm and extracted_features and taxonomy_system
        
        If algorithm_result with key "success" is equal to true:
            Let candidate_classifications be algorithm_result with key "classifications"
            
            For each candidate in candidate_classifications:
                Add candidate to classification_candidates
    
    Note: Aggregate classification results
    Let aggregated_results be aggregate_classification_results with classification_candidates and classification_engine
    Set automatic_result with key "aggregated_results" to aggregated_results
    
    Note: Select best classifications
    Let best_classifications be select_best_classifications with aggregated_results and taxonomy_system
    Set automatic_result with key "best_classifications" to best_classifications
    
    Note: Calculate classification confidence
    Let confidence_calculation be calculate_classification_confidence with best_classifications and classification_candidates
    Set automatic_result with key "confidence_calculation" to confidence_calculation
    
    Note: Generate alternative classifications
    Let alternative_classifications be generate_alternative_classifications with classification_candidates and best_classifications
    Set automatic_result with key "alternative_classifications" to alternative_classifications
    
    Return automatic_result

Process called "navigate_taxonomy" that takes taxonomy_system as Dictionary and navigation_context as Dictionary returns Dictionary:
    Let navigation_result be empty dictionary
    Set navigation_result with key "navigation_method" to "comprehensive_taxonomy_navigation"
    Set navigation_result with key "navigation_timestamp" to current_timestamp
    
    Let navigation_type be navigation_context with key "type"
    Let start_node be navigation_context with key "start_node"
    Let navigation_parameters be navigation_context with key "parameters"
    
    Let taxonomy_structure be taxonomy_system with key "taxonomy_structure"
    
    If navigation_type is equal to "ancestors":
        Let ancestor_navigation be navigate_to_ancestors with start_node and taxonomy_structure
        Set navigation_result with key "navigation_results" to ancestor_navigation
    
    If navigation_type is equal to "descendants":
        Let descendant_navigation be navigate_to_descendants with start_node and taxonomy_structure and navigation_parameters
        Set navigation_result with key "navigation_results" to descendant_navigation
    
    If navigation_type is equal to "siblings":
        Let sibling_navigation be navigate_to_siblings with start_node and taxonomy_structure
        Set navigation_result with key "navigation_results" to sibling_navigation
    
    If navigation_type is equal to "path_to_root":
        Let root_path_navigation be navigate_path_to_root with start_node and taxonomy_structure
        Set navigation_result with key "navigation_results" to root_path_navigation
    
    If navigation_type is equal to "subtree":
        Let subtree_navigation be navigate_subtree with start_node and taxonomy_structure and navigation_parameters
        Set navigation_result with key "navigation_results" to subtree_navigation
    
    If navigation_type is equal to "cross_references":
        Let cross_reference_navigation be navigate_cross_references with start_node and taxonomy_structure
        Set navigation_result with key "navigation_results" to cross_reference_navigation
    
    If navigation_type is equal to "semantic_neighbors":
        Let semantic_navigation be navigate_semantic_neighbors with start_node and taxonomy_structure and taxonomy_system
        Set navigation_result with key "navigation_results" to semantic_navigation
    
    Note: Generate navigation metadata
    Let navigation_metadata be generate_navigation_metadata with navigation_result and taxonomy_system
    Set navigation_result with key "navigation_metadata" to navigation_metadata
    
    Return navigation_result

Process called "validate_taxonomy_structure" that takes taxonomy_system as Dictionary and validation_context as Dictionary returns Dictionary:
    Let validation_result be empty dictionary
    Set validation_result with key "validation_method" to "comprehensive_taxonomy_validation"
    Set validation_result with key "validation_timestamp" to current_timestamp
    
    Let target_taxonomy be validation_context with key "taxonomy"
    Let validation_criteria be validation_context with key "criteria"
    Let validation_level be validation_context with key "level"
    
    Note: Validate hierarchical consistency
    Let hierarchy_validation be validate_hierarchical_consistency with target_taxonomy and taxonomy_system
    Set validation_result with key "hierarchy_validation" to hierarchy_validation
    
    Note: Check for cycles
    Let cycle_detection be detect_taxonomy_cycles with target_taxonomy and taxonomy_system
    Set validation_result with key "cycle_detection" to cycle_detection
    
    Note: Validate node relationships
    Let relationship_validation be validate_node_relationships with target_taxonomy and taxonomy_system
    Set validation_result with key "relationship_validation" to relationship_validation
    
    Note: Check classification scheme compliance
    Let scheme_compliance be check_classification_scheme_compliance with target_taxonomy and taxonomy_system
    Set validation_result with key "scheme_compliance" to scheme_compliance
    
    Note: Validate cross-references
    Let cross_reference_validation be validate_cross_references with target_taxonomy and taxonomy_system
    Set validation_result with key "cross_reference_validation" to cross_reference_validation
    
    Note: Assess taxonomy quality
    Let quality_assessment be assess_taxonomy_quality with target_taxonomy and validation_criteria
    Set validation_result with key "quality_assessment" to quality_assessment
    
    Note: Detect structural anomalies
    Let anomaly_detection be detect_structural_anomalies with target_taxonomy and taxonomy_system
    Set validation_result with key "anomaly_detection" to anomaly_detection
    
    Note: Generate validation report
    Let validation_report be generate_taxonomy_validation_report with validation_result and taxonomy_system
    Set validation_result with key "validation_report" to validation_report
    
    Return validation_result

Process called "evolve_taxonomy" that takes taxonomy_system as Dictionary and evolution_context as Dictionary returns Dictionary:
    Let evolution_result be empty dictionary
    Set evolution_result with key "evolution_method" to "systematic_taxonomy_evolution"
    Set evolution_result with key "evolution_timestamp" to current_timestamp
    
    Let target_taxonomy be evolution_context with key "taxonomy"
    Let evolution_triggers be evolution_context with key "triggers"
    Let evolution_strategy be evolution_context with key "strategy"
    
    Let evolution_tracker be taxonomy_system with key "evolution_tracker"
    
    Note: Analyze evolution requirements
    Let requirements_analysis be analyze_taxonomy_evolution_requirements with evolution_triggers and target_taxonomy
    Set evolution_result with key "requirements_analysis" to requirements_analysis
    
    Note: Plan taxonomy changes
    Let change_planning be plan_taxonomy_changes with requirements_analysis and evolution_strategy and evolution_tracker
    Set evolution_result with key "change_planning" to change_planning
    
    Note: Execute structural changes
    Let structural_changes be execute_taxonomy_structural_changes with change_planning and target_taxonomy and taxonomy_system
    Set evolution_result with key "structural_changes" to structural_changes
    
    Note: Update classification mappings
    Let mapping_updates be update_classification_mappings with structural_changes and taxonomy_system
    Set evolution_result with key "mapping_updates" to mapping_updates
    
    Note: Validate evolved taxonomy
    Let post_evolution_validation be validate_evolved_taxonomy with structural_changes and taxonomy_system
    Set evolution_result with key "post_evolution_validation" to post_evolution_validation
    
    Note: Update classification algorithms
    Let algorithm_updates be update_classification_algorithms with evolution_result and taxonomy_system
    Set evolution_result with key "algorithm_updates" to algorithm_updates
    
    Note: Document evolution process
    Let evolution_documentation be document_taxonomy_evolution with evolution_result and evolution_tracker
    Set evolution_result with key "evolution_documentation" to evolution_documentation
    
    Return evolution_result

Process called "map_taxonomies" that takes taxonomy_system as Dictionary and mapping_context as Dictionary returns Dictionary:
    Let mapping_result be empty dictionary
    Set mapping_result with key "mapping_method" to "comprehensive_taxonomy_mapping"
    Set mapping_result with key "mapping_timestamp" to current_timestamp
    
    Let source_taxonomy be mapping_context with key "source_taxonomy"
    Let target_taxonomy be mapping_context with key "target_taxonomy"
    Let mapping_strategy be mapping_context with key "strategy"
    Let similarity_threshold be mapping_context with key "threshold"
    
    Let mapping_system be taxonomy_system with key "mapping_system"
    
    Note: Analyze taxonomy structures
    Let structure_analysis be analyze_taxonomy_structures_for_mapping with source_taxonomy and target_taxonomy and mapping_system
    Set mapping_result with key "structure_analysis" to structure_analysis
    
    Note: Identify mapping candidates
    Let candidate_identification be identify_taxonomy_mapping_candidates with structure_analysis and mapping_system
    Set mapping_result with key "candidate_identification" to candidate_identification
    
    Note: Calculate mapping similarities
    Let similarity_calculation be calculate_taxonomy_mapping_similarities with candidate_identification and mapping_system
    Set mapping_result with key "similarity_calculation" to similarity_calculation
    
    Note: Generate initial mappings
    Let initial_mappings be generate_initial_taxonomy_mappings with similarity_calculation and similarity_threshold
    Set mapping_result with key "initial_mappings" to initial_mappings
    
    Note: Refine mappings
    Let mapping_refinement be refine_taxonomy_mappings with initial_mappings and mapping_system and taxonomy_system
    Set mapping_result with key "mapping_refinement" to mapping_refinement
    
    Note: Validate mappings
    Let mapping_validation be validate_taxonomy_mappings with mapping_refinement and taxonomy_system
    Set mapping_result with key "mapping_validation" to mapping_validation
    
    Note: Generate final mapping set
    Let final_mappings be generate_final_taxonomy_mappings with mapping_validation and mapping_system
    Set mapping_result with key "final_mappings" to final_mappings
    
    Return mapping_result

Process called "search_taxonomy" that takes taxonomy_system as Dictionary and search_context as Dictionary returns Dictionary:
    Let search_result be empty dictionary
    Set search_result with key "search_method" to "comprehensive_taxonomy_search"
    Set search_result with key "search_timestamp" to current_timestamp
    
    Let search_query be search_context with key "query"
    Let search_type be search_context with key "type"
    Let search_parameters be search_context with key "parameters"
    Let target_taxonomy be search_context with key "taxonomy"
    
    If search_type is equal to "keyword":
        Let keyword_search_result be perform_keyword_search with search_query and target_taxonomy and taxonomy_system
        Set search_result with key "search_execution" to keyword_search_result
    
    If search_type is equal to "concept":
        Let concept_search_result be perform_concept_search with search_query and target_taxonomy and taxonomy_system
        Set search_result with key "search_execution" to concept_search_result
    
    If search_type is equal to "semantic":
        Let semantic_search_result be perform_semantic_search with search_query and target_taxonomy and taxonomy_system
        Set search_result with key "search_execution" to semantic_search_result
    
    If search_type is equal to "structural":
        Let structural_search_result be perform_structural_search with search_query and target_taxonomy and taxonomy_system
        Set search_result with key "search_execution" to structural_search_result
    
    If search_type is equal to "pattern":
        Let pattern_search_result be perform_pattern_search with search_query and target_taxonomy and taxonomy_system
        Set search_result with key "search_execution" to pattern_search_result
    
    If search_type is equal to "fuzzy":
        Let fuzzy_search_result be perform_fuzzy_search with search_query and target_taxonomy and taxonomy_system
        Set search_result with key "search_execution" to fuzzy_search_result
    
    Note: Rank search results
    Let result_ranking be rank_taxonomy_search_results with search_result with key "search_execution" and search_parameters
    Set search_result with key "result_ranking" to result_ranking
    
    Note: Generate search explanations
    Let search_explanations be generate_taxonomy_search_explanations with search_result and taxonomy_system
    Set search_result with key "search_explanations" to search_explanations
    
    Return search_result

Note: Main taxonomy system coordination
Process called "create_taxonomy_monitoring_system" that takes configuration as Dictionary returns Dictionary:
    Let system be empty dictionary
    Set system with key "taxonomy_type" to configuration with key "type" or "hierarchical"
    Set system with key "automatic_classification" to configuration with key "automatic" or true
    Set system with key "multi_faceted_support" to configuration with key "multi_faceted" or true
    Set system with key "cross_reference_support" to configuration with key "cross_references" or true
    Set system with key "hierarchy_validation" to configuration with key "validation" or true
    Set system with key "dynamic_evolution" to configuration with key "evolution" or true
    Set system with key "authority_control" to configuration with key "authority_control" or true
    Set system with key "mapping_support" to configuration with key "mapping" or true
    Set system with key "reasoning_support" to configuration with key "reasoning" or true
    Set system with key "performance_optimization" to configuration with key "optimization" or true
    
    Return system

Process called "execute_taxonomy_analysis" that takes system as Dictionary and query as Dictionary returns Dictionary:
    Let query_type be query with key "type"
    Let result be empty dictionary
    
    If query_type is equal to "construct_taxonomy":
        Let construction_context be query with key "construction_context"
        Let taxonomy_config be query with key "taxonomy_config"
        
        Let taxonomy_system be create_taxonomy_system with taxonomy_config
        Let construction_result be construct_taxonomy with taxonomy_system and construction_context
        Set result with key "construction_result" to construction_result
    
    If query_type is equal to "classify_item":
        Let classification_context be query with key "classification_context"
        Let classification_config be query with key "classification_config"
        
        Let taxonomy_system be create_taxonomy_system with classification_config
        Let classification_result be classify_item with taxonomy_system and classification_context
        Set result with key "classification_result" to classification_result
    
    If query_type is equal to "navigate_taxonomy":
        Let navigation_context be query with key "navigation_context"
        Let navigation_config be query with key "navigation_config"
        
        Let taxonomy_system be create_taxonomy_system with navigation_config
        Let navigation_result be navigate_taxonomy with taxonomy_system and navigation_context
        Set result with key "navigation_result" to navigation_result
    
    If query_type is equal to "validate_structure":
        Let validation_context be query with key "validation_context"
        Let validation_config be query with key "validation_config"
        
        Let taxonomy_system be create_taxonomy_system with validation_config
        Let validation_result be validate_taxonomy_structure with taxonomy_system and validation_context
        Set result with key "validation_result" to validation_result
    
    If query_type is equal to "evolve_taxonomy":
        Let evolution_context be query with key "evolution_context"
        Let evolution_config be query with key "evolution_config"
        
        Let taxonomy_system be create_taxonomy_system with evolution_config
        Let evolution_result be evolve_taxonomy with taxonomy_system and evolution_context
        Set result with key "evolution_result" to evolution_result
    
    If query_type is equal to "map_taxonomies":
        Let mapping_context be query with key "mapping_context"
        Let mapping_config be query with key "mapping_config"
        
        Let taxonomy_system be create_taxonomy_system with mapping_config
        Let mapping_result be map_taxonomies with taxonomy_system and mapping_context
        Set result with key "mapping_result" to mapping_result
    
    If query_type is equal to "search_taxonomy":
        Let search_context be query with key "search_context"
        Let search_config be query with key "search_config"
        
        Let taxonomy_system be create_taxonomy_system with search_config
        Let search_result be search_taxonomy with taxonomy_system and search_context
        Set result with key "search_result" to search_result
    
    Note: Add metadata
    Set result with key "taxonomy_timestamp" to current_timestamp
    Set result with key "system_config" to extract_system_summary with system
    
    Return result