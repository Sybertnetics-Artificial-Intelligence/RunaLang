        max_connections as 5
        connection_timeout as driver.config.timeout as integer
        idle_timeout as 300
        max_lifetime as 3600
        acquire_timeout as 30
        health_check_interval as 60
        retry_attempts as 3
        retry_delay as 1
        enable_health_checks as true
        enable_monitoring as true
        pool_name as "sqlite_pool"

