Process called "execute_sqlite_simple_query" that takes connection_object as Any and query as String returns Any:
    Note: Execute a simple SQLite query without parameters
    Try:
        Note: Create and execute cursor with query
        Let cursor be create_raw_sqlite_cursor with connection as connection_object
        If cursor is none:
            Throw SQLiteQueryError with message as "Failed to create cursor"
        
        Call execute_raw_sqlite_query with cursor as cursor and query as query and parameters as empty list
        Let result be fetch_raw_sqlite_results with cursor as cursor
        Call close_raw_sqlite_cursor with cursor as cursor
        
        Return Dictionary with:
            "status" as "OK"
            "rows" as result.rows
            "affected_rows" as result.affected_rows
            "last_insert_id" as result.last_insert_rowid
    
    Catch error as Exception:
        Throw SQLiteQueryError with message as "Query execution failed: " plus error as string

