Note: Object-Relational Mapping (ORM) Framework Module
Note: Provides high-level database abstraction through object-oriented interfaces,
Note: model definitions, relationships, query builders, and automatic schema management.

Import "sql"
Import "postgresql"
Import "mysql"
Import "sqlite"
Import "mongodb"
Import "connection_pool"
Import "os"
Import "json"
Import "datetime"
Import "logging"
Import "concurrent"

Type FieldType as Enumeration containing:
    STRING
    INTEGER
    FLOAT
    BOOLEAN
    DATE
    DATETIME
    TIME
    TEXT
    BLOB
    JSON
    UUID
    DECIMAL

Type RelationshipType as Enumeration containing:
    ONE_TO_ONE
    ONE_TO_MANY
    MANY_TO_ONE
    MANY_TO_MANY

Type DatabaseEngine as Enumeration containing:
    POSTGRESQL
    MYSQL
    SQLITE
    MONGODB

Type FieldDefinition as Dictionary with:
    name as String
    field_type as FieldType
    primary_key as Boolean
    nullable as Boolean
    unique as Boolean
    default_value as Optional[Any]
    max_length as Optional[Integer]
    precision as Optional[Integer]
    scale as Optional[Integer]
    index as Boolean
    foreign_key as Optional[String]
    check_constraint as Optional[String]
    auto_increment as Boolean

Type RelationshipDefinition as Dictionary with:
    name as String
    relationship_type as RelationshipType
    target_model as String
    foreign_key as Optional[String]
    back_reference as Optional[String]
    cascade_delete as Boolean
    lazy_loading as Boolean
    join_table as Optional[String]

Type ModelDefinition as Dictionary with:
    name as String
    table_name as String
    fields as List[FieldDefinition]
    relationships as List[RelationshipDefinition]
    indexes as List[List[String]]
    constraints as List[String]
    soft_delete as Boolean
    timestamps as Boolean
    versioning as Boolean

Type QueryCondition as Dictionary with:
    field as String
    operator as String
    value as Any
    logical_operator as Optional[String]

Type QueryBuilder as Dictionary with:
    model as String
    select_fields as List[String]
    conditions as List[QueryCondition]
    joins as List[Dictionary[String, Any]]
    order_by as List[Tuple[String, String]]
    group_by as List[String]
    having as List[QueryCondition]
    limit_count as Optional[Integer]
    offset_count as Optional[Integer]
    distinct as Boolean

Type Model as Dictionary with:
    model_definition as ModelDefinition
    data as Dictionary[String, Any]
    original_data as Dictionary[String, Any]
    is_new as Boolean
    is_dirty as Boolean
    validation_errors as List[String]
    relationships_cache as Dictionary[String, Any]

Type ORMSession as Dictionary with:
    engine as DatabaseEngine
    connection as Any
    driver as Any
    models as Dictionary[String, ModelDefinition]
    identity_map as Dictionary[String, Dictionary[String, Model]]
    transaction as Optional[Any]
    auto_commit as Boolean
    logger as logging.Logger

Type ORMEngine as Dictionary with:
    engine_type as DatabaseEngine
    driver as Any
    session_factory as Any
    models as Dictionary[String, ModelDefinition]
    schema_manager as Any
    query_compiler as Any
    logger as logging.Logger

Process called "create_orm_engine" that takes engine_type as DatabaseEngine and connection_config as Dictionary[String, Any] returns ORMEngine:
    Note: Create an ORM engine with database connection
    Try:
        Let driver be none
        
        Note: Create appropriate database driver
        If engine_type is DatabaseEngine.POSTGRESQL:
            Let pg_config be create_postgresql_config_from_dict with config_dict as connection_config
            Set driver to postgresql.create_postgresql_driver with config as pg_config
        
        Otherwise if engine_type is DatabaseEngine.MYSQL:
            Let mysql_config be create_mysql_config_from_dict with config_dict as connection_config
            Set driver to mysql.create_mysql_driver with config as mysql_config
        
        Otherwise if engine_type is DatabaseEngine.SQLITE:
            Let sqlite_config be create_sqlite_config_from_dict with config_dict as connection_config
            Set driver to sqlite.create_sqlite_driver with config as sqlite_config
        
        Otherwise if engine_type is DatabaseEngine.MONGODB:
            Let mongodb_config be create_mongodb_config_from_dict with config_dict as connection_config
            Set driver to mongodb.create_mongodb_driver with config as mongodb_config
        
        Otherwise:
            Throw UnsupportedEngineError with message as "Database engine not supported: " plus engine_type as string
        
        Let engine be ORMEngine with:
            engine_type as engine_type
            driver as driver
            session_factory as create_session_factory with engine_type as engine_type and driver as driver
            models as empty dictionary
            schema_manager as create_schema_manager with engine_type as engine_type and driver as driver
            query_compiler as create_query_compiler with engine_type as engine_type
            logger as logging.get_logger with name as "orm_engine"
        
        Call engine.logger.info with message as "ORM engine created for " plus engine_type as string
        Return engine
        
    Catch error as Exception:
        Call logging.error with message as "Failed to create ORM engine: " plus error as string
        Throw ORMEngineError with message as "Engine creation failed: " plus error as string

Process called "define_model" that takes engine as ORMEngine and model_def as ModelDefinition returns Boolean:
    Note: Define a model in the ORM engine
    Try:
        Note: Validate model definition
        Call validate_model_definition with model_def as model_def
        
        Note: Register model with engine
        Set engine.models[model_def.name] to model_def
        
        Note: Create database schema if needed
        If engine.engine_type is not DatabaseEngine.MONGODB:
            Call create_table_for_model with engine as engine and model_def as model_def
        
        Call engine.logger.info with message as "Model defined: " plus model_def.name plus " (table: " plus model_def.table_name plus ")"
        Return true
        
    Catch error as Exception:
        Call engine.logger.error with message as "Failed to define model " plus model_def.name plus ": " plus error as string
        Return false

Process called "create_session" that takes engine as ORMEngine returns ORMSession:
    Note: Create a new ORM session
    Try:
        Let connection be acquire_engine_connection with engine as engine
        
        Let session be ORMSession with:
            engine as engine.engine_type
            connection as connection
            driver as engine.driver
            models as engine.models
            identity_map as empty dictionary
            transaction as none
            auto_commit as true
            logger as logging.get_logger with name as "orm_session"
        
        Note: Initialize identity map for each model
        For each model_name and model_def in engine.models:
            Set session.identity_map[model_name] to empty dictionary
        
        Call session.logger.debug with message as "ORM session created"
        Return session
        
    Catch error as Exception:
        Throw ORMSessionError with message as "Session creation failed: " plus error as string

Process called "create_model_instance" that takes session as ORMSession and model_name as String and data as Optional[Dictionary[String, Any]] returns Model:
    Note: Create a new model instance
    If model_name not in session.models:
        Throw ModelNotFoundError with message as "Model not defined: " plus model_name
    
    Let model_def be session.models[model_name]
    Let instance_data be data or empty dictionary
    
    Note: Apply default values for missing fields
    For each field_def in model_def.fields:
        If field_def.name not in instance_data and field_def.default_value is not none:
            Set instance_data[field_def.name] to field_def.default_value
    
    Note: Add timestamps if enabled
    If model_def.timestamps:
        Let now be datetime.now
        If "created_at" not in instance_data:
            Set instance_data["created_at"] to now
        Set instance_data["updated_at"] to now
    
    Let model be Model with:
        model_definition as model_def
        data as instance_data
        original_data as copy_dictionary with dictionary as instance_data
        is_new as data is none or get_primary_key_value with model_def as model_def and data as instance_data is none
        is_dirty as false
        validation_errors as empty list
        relationships_cache as empty dictionary
    
    Call session.logger.debug with message as "Model instance created: " plus model_name
    Return model

Process called "save_model" that takes session as ORMSession and model as Model returns Boolean:
    Note: Save a model instance to the database
    Try:
        Note: Validate model data
        Call validate_model_data with model as model
        If model.validation_errors size is greater than 0:
            Call session.logger.error with message as "Validation errors: " plus join_strings_with_separator with strings as model.validation_errors and separator as ", "
            Return false
        
        Let success be false
        
        If model.is_new:
            Set success to insert_model with session as session and model as model
        Otherwise if model.is_dirty:
            Set success to update_model with session as session and model as model
        Otherwise:
            Set success to true
        
        If success:
            Set model.original_data to copy_dictionary with dictionary as model.data
            Set model.is_new to false
            Set model.is_dirty to false
            
            Note: Add to identity map
            Let primary_key_value be get_primary_key_value with model_def as model.model_definition and data as model.data
            If primary_key_value is not none:
                Set session.identity_map[model.model_definition.name][primary_key_value as string] to model
        
        If session.auto_commit and session.transaction is none:
            Call commit_session with session as session
        
        Return success
        
    Catch error as Exception:
        Call session.logger.error with message as "Error saving model: " plus error as string
        If session.auto_commit and session.transaction is none:
            Call rollback_session with session as session
        Return false

Process called "delete_model" that takes session as ORMSession and model as Model returns Boolean:
    Note: Delete a model instance from the database
    Try:
        Let primary_key_value be get_primary_key_value with model_def as model.model_definition and data as model.data
        If primary_key_value is none:
            Call session.logger.error with message as "Cannot delete model without primary key"
            Return false
        
        Let success be false
        
        If model.model_definition.soft_delete:
            Set model.data["deleted_at"] to datetime.now
            Set model.is_dirty to true
            Set success to update_model with session as session and model as model
        Otherwise:
            Set success to hard_delete_model with session as session and model as model
        
        If success:
            Note: Remove from identity map
            If model.model_definition.name in session.identity_map and primary_key_value as string in session.identity_map[model.model_definition.name]:
                Call session.identity_map[model.model_definition.name].remove with key as primary_key_value as string
        
        If session.auto_commit and session.transaction is none:
            Call commit_session with session as session
        
        Return success
        
    Catch error as Exception:
        Call session.logger.error with message as "Error deleting model: " plus error as string
        If session.auto_commit and session.transaction is none:
            Call rollback_session with session as session
        Return false

Process called "find_by_id" that takes session as ORMSession and model_name as String and id as Any returns Optional[Model]:
    Note: Find a model instance by primary key
    If model_name not in session.models:
        Throw ModelNotFoundError with message as "Model not defined: " plus model_name
    
    Note: Check identity map first
    If id as string in session.identity_map[model_name]:
        Return session.identity_map[model_name][id as string]
    
    Try:
        Let model_def be session.models[model_name]
        Let primary_key_field be get_primary_key_field with model_def as model_def
        
        Let query_builder be QueryBuilder with:
            model as model_name
            select_fields as list containing "*"
            conditions as list containing QueryCondition with:
                field as primary_key_field.name
                operator as "="
                value as id
                logical_operator as none
            joins as empty list
            order_by as empty list
            group_by as empty list
            having as empty list
            limit_count as 1
            offset_count as none
            distinct as false
        
        Let results be execute_query with session as session and query_builder as query_builder
        
        If results size is greater than 0:
            Let model be create_model_from_data with session as session and model_name as model_name and data as results[0]
            Set session.identity_map[model_name][id as string] to model
            Return model
        
        Return none
        
    Catch error as Exception:
        Call session.logger.error with message as "Error finding model by ID: " plus error as string
        Return none

Process called "query" that takes session as ORMSession and model_name as String returns QueryBuilder:
    Note: Create a query builder for a model
    If model_name not in session.models:
        Throw ModelNotFoundError with message as "Model not defined: " plus model_name
    
    Return QueryBuilder with:
        model as model_name
        select_fields as list containing "*"
        conditions as empty list
        joins as empty list
        order_by as empty list
        group_by as empty list
        having as empty list
        limit_count as none
        offset_count as none
        distinct as false

Process called "filter_query" that takes query_builder as QueryBuilder and field as String and operator as String and value as Any returns QueryBuilder:
    Note: Add a filter condition to a query builder
    Let condition be QueryCondition with:
        field as field
        operator as operator
        value as value
        logical_operator as "AND" if query_builder.conditions size is greater than 0 otherwise none
    
    Call query_builder.conditions.append with item as condition
    Return query_builder

Process called "order_by_query" that takes query_builder as QueryBuilder and field as String and direction as Optional[String] returns QueryBuilder:
    Note: Add ordering to a query builder
    Let order_direction be direction or "ASC"
    Call query_builder.order_by.append with item as tuple containing field and order_direction
    Return query_builder

Process called "limit_query" that takes query_builder as QueryBuilder and limit as Integer and offset as Optional[Integer] returns QueryBuilder:
    Note: Add limit and offset to a query builder
    Set query_builder.limit_count to limit
    Set query_builder.offset_count to offset
    Return query_builder

Process called "execute_query" that takes session as ORMSession and query_builder as QueryBuilder returns List[Dictionary[String, Any]]:
    Note: Execute a query and return raw results
    Try:
        Let sql_query be compile_query_to_sql with session as session and query_builder as query_builder
        Let parameters be extract_query_parameters with query_builder as query_builder
        
        Let result be none
        If session.engine is DatabaseEngine.POSTGRESQL:
            Set result to postgresql.execute_query with driver as session.driver and query as sql_query and parameters as parameters
        
        Otherwise if session.engine is DatabaseEngine.MYSQL:
            Set result to mysql.execute_query with driver as session.driver and query as sql_query and parameters as parameters
        
        Otherwise if session.engine is DatabaseEngine.SQLITE:
            Set result to sqlite.execute_query with driver as session.driver and query as sql_query and parameters as parameters
        
        Otherwise if session.engine is DatabaseEngine.MONGODB:
            Return execute_mongodb_query with session as session and query_builder as query_builder
        
        Otherwise:
            Throw UnsupportedEngineError with message as "Query execution not supported for engine: " plus session.engine as string
        
        Return result.rows
        
    Catch error as Exception:
        Call session.logger.error with message as "Error executing query: " plus error as string
        Return empty list

Process called "all_query" that takes session as ORMSession and query_builder as QueryBuilder returns List[Model]:
    Note: Execute a query and return model instances
    Let results be execute_query with session as session and query_builder as query_builder
    Let models be empty list
    
    For each result_data in results:
        Let model be create_model_from_data with session as session and model_name as query_builder.model and data as result_data
        Call models.append with item as model
        
        Note: Add to identity map
        Let primary_key_value be get_primary_key_value with model_def as model.model_definition and data as model.data
        If primary_key_value is not none:
            Set session.identity_map[model.model_definition.name][primary_key_value as string] to model
    
    Return models

Process called "first_query" that takes session as ORMSession and query_builder as QueryBuilder returns Optional[Model]:
    Note: Execute a query and return the first model instance
    Set query_builder.limit_count to 1
    Let results be all_query with session as session and query_builder as query_builder
    
    If results size is greater than 0:
        Return results[0]
    
    Return none

Process called "count_query" that takes session as ORMSession and query_builder as QueryBuilder returns Integer:
    Note: Count the number of results for a query
    Try:
        Let count_query_builder be QueryBuilder with:
            model as query_builder.model
            select_fields as list containing "COUNT(*) as count"
            conditions as query_builder.conditions
            joins as query_builder.joins
            order_by as empty list
            group_by as empty list
            having as empty list
            limit_count as none
            offset_count as none
            distinct as false
        
        Let results be execute_query with session as session and query_builder as count_query_builder
        
        If results size is greater than 0:
            Return results[0]["count"] as integer
        
        Return 0
        
    Catch error as Exception:
        Call session.logger.error with message as "Error counting query results: " plus error as string
        Return 0

Process called "begin_transaction" that takes session as ORMSession returns Boolean:
    Note: Begin a database transaction
    Try:
        If session.transaction is not none:
            Call session.logger.warning with message as "Transaction already active"
            Return true
        
        If session.engine is DatabaseEngine.POSTGRESQL:
            Set session.transaction to postgresql.begin_transaction with connection as session.connection and isolation_level as "READ COMMITTED"
        
        Otherwise if session.engine is DatabaseEngine.MYSQL:
            Set session.transaction to mysql.begin_mysql_transaction with connection as session.connection and isolation_level as "REPEATABLE READ"
        
        Otherwise if session.engine is DatabaseEngine.SQLITE:
            Set session.transaction to sqlite.begin_sqlite_transaction with connection as session.connection and transaction_type as "DEFERRED"
        
        Otherwise if session.engine is DatabaseEngine.MONGODB:
            Set session.transaction to mongodb.start_transaction with driver as session.driver
        
        Set session.auto_commit to false
        Call session.logger.debug with message as "Transaction started"
        Return true
        
    Catch error as Exception:
        Call session.logger.error with message as "Error starting transaction: " plus error as string
        Return false

Process called "commit_session" that takes session as ORMSession returns Boolean:
    Note: Commit the current transaction
    Try:
        If session.transaction is none and session.auto_commit:
            Return true
        
        If session.engine is DatabaseEngine.POSTGRESQL:
            Call postgresql.commit_transaction with transaction as session.transaction
        
        Otherwise if session.engine is DatabaseEngine.MYSQL:
            Call mysql.commit_mysql_transaction with transaction as session.transaction
        
        Otherwise if session.engine is DatabaseEngine.SQLITE:
            Call sqlite.commit_sqlite_transaction with transaction as session.transaction
        
        Otherwise if session.engine is DatabaseEngine.MONGODB:
            Call mongodb.commit_transaction with transaction as session.transaction
        
        Set session.transaction to none
        Set session.auto_commit to true
        Call session.logger.debug with message as "Transaction committed"
        Return true
        
    Catch error as Exception:
        Call session.logger.error with message as "Error committing transaction: " plus error as string
        Return false

Process called "rollback_session" that takes session as ORMSession returns Boolean:
    Note: Rollback the current transaction
    Try:
        If session.transaction is none:
            Return true
        
        If session.engine is DatabaseEngine.POSTGRESQL:
            Call postgresql.rollback_transaction with transaction as session.transaction
        
        Otherwise if session.engine is DatabaseEngine.MYSQL:
            Call mysql.rollback_mysql_transaction with transaction as session.transaction
        
        Otherwise if session.engine is DatabaseEngine.SQLITE:
            Call sqlite.rollback_sqlite_transaction with transaction as session.transaction
        
        Otherwise if session.engine is DatabaseEngine.MONGODB:
            Call mongodb.abort_transaction with transaction as session.transaction
        
        Set session.transaction to none
        Set session.auto_commit to true
        Call session.logger.debug with message as "Transaction rolled back"
        Return true
        
    Catch error as Exception:
        Call session.logger.error with message as "Error rolling back transaction: " plus error as string
        Return false

Process called "close_session" that takes session as ORMSession returns None:
    Note: Close the ORM session and release resources
    Try:
        If session.transaction is not none:
            Call rollback_session with session as session
        
        Call release_engine_connection with connection as session.connection
        Call session.identity_map.clear
        
        Call session.logger.debug with message as "Session closed"
        
    Catch error as Exception:
        Call session.logger.error with message as "Error closing session: " plus error as string

Note: Model validation and data processing
Process called "validate_model_definition" that takes model_def as ModelDefinition returns None:
    Note: Validate a model definition
    If model_def.name is equal to "":
        Throw ModelValidationError with message as "Model name cannot be empty"
    
    If model_def.table_name is equal to "":
        Throw ModelValidationError with message as "Table name cannot be empty"
    
    If model_def.fields size is equal to 0:
        Throw ModelValidationError with message as "Model must have at least one field"
    
    Let primary_key_count be 0
    For each field_def in model_def.fields:
        If field_def.primary_key:
            Set primary_key_count to primary_key_count plus 1
    
    If primary_key_count is equal to 0:
        Throw ModelValidationError with message as "Model must have at least one primary key field"

Process called "validate_model_data" that takes model as Model returns None:
    Note: Validate model data against field definitions
    Call model.validation_errors.clear
    
    For each field_def in model.model_definition.fields:
        Let field_value be model.data.get with key as field_def.name
        
        Note: Check required fields
        If not field_def.nullable and field_value is none:
            Call model.validation_errors.append with item as "Field " plus field_def.name plus " is required"
        
        Note: Check field types
        If field_value is not none:
            Let type_valid be validate_field_type with field_def as field_def and value as field_value
            If not type_valid:
                Call model.validation_errors.append with item as "Field " plus field_def.name plus " has invalid type"
        
        Note: Check string length
        If field_def.field_type is FieldType.STRING and field_def.max_length is not none and field_value is not none:
            If field_value as string length is greater than field_def.max_length:
                Call model.validation_errors.append with item as "Field " plus field_def.name plus " exceeds maximum length"
        
        Note: Check unique constraints
        If field_def.unique and field_value is not none:
            Note: This would check database for uniqueness in a real implementation
            Pass

Process called "validate_field_type" that takes field_def as FieldDefinition and value as Any returns Boolean:
    Note: Validate that a value matches the expected field type
    If field_def.field_type is FieldType.STRING:
        Return value is string
    Otherwise if field_def.field_type is FieldType.INTEGER:
        Return value is integer
    Otherwise if field_def.field_type is FieldType.FLOAT:
        Return value is float or value is integer
    Otherwise if field_def.field_type is FieldType.BOOLEAN:
        Return value is boolean
    Otherwise if field_def.field_type is FieldType.DATE or field_def.field_type is FieldType.DATETIME:
        Return value is DateTime
    Otherwise if field_def.field_type is FieldType.JSON:
        Return value is dictionary or value is list
    Otherwise:
        Return true

Process called "get_primary_key_field" that takes model_def as ModelDefinition returns FieldDefinition:
    Note: Get the primary key field definition
    For each field_def in model_def.fields:
        If field_def.primary_key:
            Return field_def
    
    Throw ModelError with message as "No primary key field found"

Process called "get_primary_key_value" that takes model_def as ModelDefinition and data as Dictionary[String, Any] returns Optional[Any]:
    Note: Get the primary key value from data
    Let primary_key_field be get_primary_key_field with model_def as model_def
    Return data.get with key as primary_key_field.name

Process called "create_model_from_data" that takes session as ORMSession and model_name as String and data as Dictionary[String, Any] returns Model:
    Note: Create a model instance from database data
    Let model be create_model_instance with session as session and model_name as model_name and data as data
    Set model.is_new to false
    Set model.is_dirty to false
    Set model.original_data to copy_dictionary with dictionary as data
    Return model

Note: Database operations
Process called "insert_model" that takes session as ORMSession and model as Model returns Boolean:
    Note: Insert a new model instance into the database
    Try:
        If session.engine is DatabaseEngine.MONGODB:
            Return insert_mongodb_model with session as session and model as model
        
        Let insert_query be build_insert_query with session as session and model as model
        Let parameters be extract_insert_parameters with model as model
        
        Let result be none
        If session.engine is DatabaseEngine.POSTGRESQL:
            Set result to postgresql.execute_query with driver as session.driver and query as insert_query and parameters as parameters
        
        Otherwise if session.engine is DatabaseEngine.MYSQL:
            Set result to mysql.execute_query with driver as session.driver and query as insert_query and parameters as parameters
        
        Otherwise if session.engine is DatabaseEngine.SQLITE:
            Set result to sqlite.execute_query with driver as session.driver and query as insert_query and parameters as parameters
        
        Note: Handle auto-increment primary keys
        If result is not none and result.last_insert_id is not none:
            Let primary_key_field be get_primary_key_field with model_def as model.model_definition
            If primary_key_field.auto_increment:
                Set model.data[primary_key_field.name] to result.last_insert_id
        
        Call session.logger.debug with message as "Model inserted: " plus model.model_definition.name
        Return result is not none
        
    Catch error as Exception:
        Call session.logger.error with message as "Error inserting model: " plus error as string
        Return false

Process called "update_model" that takes session as ORMSession and model as Model returns Boolean:
    Note: Update an existing model instance in the database
    Try:
        If session.engine is DatabaseEngine.MONGODB:
            Return update_mongodb_model with session as session and model as model
        
        Let update_query be build_update_query with session as session and model as model
        Let parameters be extract_update_parameters with model as model
        
        Let result be none
        If session.engine is DatabaseEngine.POSTGRESQL:
            Set result to postgresql.execute_query with driver as session.driver and query as update_query and parameters as parameters
        
        Otherwise if session.engine is DatabaseEngine.MYSQL:
            Set result to mysql.execute_query with driver as session.driver and query as update_query and parameters as parameters
        
        Otherwise if session.engine is DatabaseEngine.SQLITE:
            Set result to sqlite.execute_query with driver as session.driver and query as update_query and parameters as parameters
        
        Call session.logger.debug with message as "Model updated: " plus model.model_definition.name
        Return result is not none
        
    Catch error as Exception:
        Call session.logger.error with message as "Error updating model: " plus error as string
        Return false

Process called "hard_delete_model" that takes session as ORMSession and model as Model returns Boolean:
    Note: Hard delete a model instance from the database
    Try:
        If session.engine is DatabaseEngine.MONGODB:
            Return delete_mongodb_model with session as session and model as model
        
        Let delete_query be build_delete_query with session as session and model as model
        Let parameters be extract_delete_parameters with model as model
        
        Let result be none
        If session.engine is DatabaseEngine.POSTGRESQL:
            Set result to postgresql.execute_query with driver as session.driver and query as delete_query and parameters as parameters
        
        Otherwise if session.engine is DatabaseEngine.MYSQL:
            Set result to mysql.execute_query with driver as session.driver and query as delete_query and parameters as parameters
        
        Otherwise if session.engine is DatabaseEngine.SQLITE:
            Set result to sqlite.execute_query with driver as session.driver and query as delete_query and parameters as parameters
        
        Call session.logger.debug with message as "Model deleted: " plus model.model_definition.name
        Return result is not none
        
    Catch error as Exception:
        Call session.logger.error with message as "Error deleting model: " plus error as string
        Return false

Note: Schema management
Process called "create_table_for_model" that takes engine as ORMEngine and model_def as ModelDefinition returns Boolean:
    Note: Create database table for a model
    Try:
        Let create_table_sql be build_create_table_sql with engine as engine and model_def as model_def
        
        Let result be none
        If engine.engine_type is DatabaseEngine.POSTGRESQL:
            Set result to postgresql.execute_query with driver as engine.driver and query as create_table_sql and parameters as empty list
        
        Otherwise if engine.engine_type is DatabaseEngine.MYSQL:
            Set result to mysql.execute_query with driver as engine.driver and query as create_table_sql and parameters as empty list
        
        Otherwise if engine.engine_type is DatabaseEngine.SQLITE:
            Set result to sqlite.execute_query with driver as engine.driver and query as create_table_sql and parameters as empty list
        
        Call engine.logger.info with message as "Table created: " plus model_def.table_name
        Return result is not none
        
    Catch error as Exception:
        Call engine.logger.error with message as "Error creating table: " plus error as string
        Return false

Note: Query compilation
Process called "compile_query_to_sql" that takes session as ORMSession and query_builder as QueryBuilder returns String:
    Note: Compile a query builder to SQL
    Let model_def be session.models[query_builder.model]
    Let sql be "SELECT " plus join_strings_with_separator with strings as query_builder.select_fields and separator as ", "
    Set sql to sql plus " FROM " plus model_def.table_name
    
    Note: Add WHERE conditions
    If query_builder.conditions size is greater than 0:
        Set sql to sql plus " WHERE "
        For each index and condition in query_builder.conditions:
            If index is greater than 0 and condition.logical_operator is not none:
                Set sql to sql plus " " plus condition.logical_operator plus " "
            Set sql to sql plus condition.field plus " " plus condition.operator plus " ?"
    
    Note: Add ORDER BY
    If query_builder.order_by size is greater than 0:
        Set sql to sql plus " ORDER BY "
        Let order_clauses be empty list
        For each field and direction in query_builder.order_by:
            Call order_clauses.append with item as field plus " " plus direction
        Set sql to sql plus join_strings_with_separator with strings as order_clauses and separator as ", "
    
    Note: Add LIMIT and OFFSET
    If query_builder.limit_count is not none:
        Set sql to sql plus " LIMIT " plus query_builder.limit_count as string
        If query_builder.offset_count is not none:
            Set sql to sql plus " OFFSET " plus query_builder.offset_count as string
    
    Return sql

Process called "extract_query_parameters" that takes query_builder as QueryBuilder returns List[Any]:
    Note: Extract parameters from query conditions
    Let parameters be empty list
    
    For each condition in query_builder.conditions:
        Call parameters.append with item as condition.value
    
    Return parameters

Note: Utility functions
Process called "copy_dictionary" that takes dictionary as Dictionary[String, Any] returns Dictionary[String, Any]:
    Note: Create a deep copy of a dictionary
    Let copied_dict be empty dictionary
    For each key and value in dictionary:
        Set copied_dict[key] to value
    Return copied_dict

Process called "join_strings_with_separator" that takes strings as List[String] and separator as String returns String:
    Note: Join a list of strings with a separator
    Let result be ""
    For each index and string in strings:
        If index is greater than 0:
            Set result to result plus separator
        Set result to result plus string
    Return result

