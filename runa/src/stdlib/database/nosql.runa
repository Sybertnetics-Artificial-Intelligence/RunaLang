Note: Generic NoSQL Database Operations Module
Note: Provides a unified interface for NoSQL database operations across different
Note: database types (MongoDB, Redis, etc.) with consistent APIs and abstractions.

Import "mongodb"
Import "redis"
Import "connection_pool"
Import "os"
Import "json"
Import "datetime"
Import "logging"

Type NoSQLDatabaseType as Enumeration containing:
    MONGODB
    REDIS
    COUCHDB
    CASSANDRA
    DYNAMODB
    NEO4J

Type NoSQLOperationType as Enumeration containing:
    CREATE
    READ
    UPDATE
    DELETE
    QUERY
    AGGREGATE
    INDEX

Type NoSQLQueryOperator as Enumeration containing:
    EQUALS
    NOT_EQUALS
    GREATER_THAN
    LESS_THAN
    GREATER_EQUAL
    LESS_EQUAL
    IN
    NOT_IN
    CONTAINS
    STARTS_WITH
    ENDS_WITH
    REGEX
    EXISTS
    NOT_EXISTS

Type NoSQLConfig as Dictionary with:
    database_type as NoSQLDatabaseType
    connection_config as Dictionary[String, Any]
    default_collection as Optional[String]
    auto_create_collections as Boolean
    default_timeout as Integer
    batch_size as Integer
    enable_transactions as Boolean
    consistency_level as String
    replication_factor as Integer
    enable_caching as Boolean
    cache_ttl as Integer

Type NoSQLDocument as Dictionary with:
    id as Optional[String]
    data as Dictionary[String, Any]
    metadata as Dictionary[String, Any]
    created_at as Optional[DateTime]
    updated_at as Optional[DateTime]
    version as Optional[Integer]

Type NoSQLQuery as Dictionary with:
    collection as String
    filter as Dictionary[String, Any]
    projection as Optional[Dictionary[String, Any]]
    sort as Optional[List[Tuple[String, Integer]]]
    limit as Optional[Integer]
    skip as Optional[Integer]
    timeout as Optional[Integer]

Type NoSQLIndex as Dictionary with:
    name as String
    collection as String
    fields as Dictionary[String, Integer]
    unique as Boolean
    sparse as Boolean
    partial_filter as Optional[Dictionary[String, Any]]
    expire_after as Optional[Integer]
    background as Boolean

Type NoSQLResult as Dictionary with:
    success as Boolean
    operation as NoSQLOperationType
    collection as String
    documents as List[NoSQLDocument]
    matched_count as Integer
    modified_count as Integer
    deleted_count as Integer
    inserted_count as Integer
    execution_time as Float
    error as Optional[String]
    metadata as Dictionary[String, Any]

Type NoSQLDatabase as Dictionary with:
    config as NoSQLConfig
    driver as Any
    logger as logging.Logger
    database_type as NoSQLDatabaseType
    connection_info as Dictionary[String, Any]
    collections as List[String]
    indexes as Dictionary[String, List[NoSQLIndex]]

Process called "create_nosql_database" that takes config as NoSQLConfig returns NoSQLDatabase:
    Note: Create a NoSQL database connection with unified interface
    Try:
        Let driver be none
        Let connection_info be empty dictionary
        
        Note: Create appropriate driver based on database type
        If config.database_type is NoSQLDatabaseType.MONGODB:
            Let mongodb_config be convert_to_mongodb_config with config as config
            Set driver to mongodb.create_mongodb_driver with config as mongodb_config
            Set connection_info to Dictionary with:
                "type" as "mongodb"
                "host" as mongodb_config.host
                "port" as mongodb_config.port
                "database" as mongodb_config.database
        
        Otherwise if config.database_type is NoSQLDatabaseType.REDIS:
            Let redis_config be convert_to_redis_config with config as config
            Set driver to redis.create_redis_driver with config as redis_config
            Set connection_info to Dictionary with:
                "type" as "redis"
                "host" as redis_config.host
                "port" as redis_config.port
                "database" as redis_config.database
        
        Otherwise:
            Throw UnsupportedDatabaseTypeError with message as "Database type not supported: " plus config.database_type as string
        
        Let database be NoSQLDatabase with:
            config as config
            driver as driver
            logger as logging.get_logger with name as "nosql_database"
            database_type as config.database_type
            connection_info as connection_info
            collections as empty list
            indexes as empty dictionary
        
        Note: Initialize database collections and indexes
        Call initialize_nosql_collections with database as database
        
        Call database.logger.info with message as "NoSQL database initialized: " plus config.database_type as string
        Return database
        
    Catch error as Exception:
        Call logging.error with message as "Failed to create NoSQL database: " plus error as string
        Throw NoSQLDatabaseError with message as "Database creation failed: " plus error as string

Process called "insert_document" that takes database as NoSQLDatabase and collection as String and document as NoSQLDocument returns NoSQLResult:
    Note: Insert a document into a NoSQL database collection
    Try:
        Let start_time be datetime.now
        
        Note: Prepare document with metadata
        Let prepared_document be prepare_document_for_insert with document as document
        
        Let result be none
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Set result to mongodb.insert_document with driver as database.driver and collection_name as collection and document as prepared_document.data
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            Let key be generate_redis_key with collection as collection and document_id as prepared_document.id
            Set result to redis.set_key with driver as database.driver and key as key and value as json.dumps with data as prepared_document.data
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Insert operation not supported for database type: " plus database.database_type as string
        
        Let end_time be datetime.now
        Let execution_time be (end_time minus start_time).total_seconds
        
        Let nosql_result be NoSQLResult with:
            success as result is not none and (result.success if "success" in result otherwise true)
            operation as NoSQLOperationType.CREATE
            collection as collection
            documents as list containing prepared_document
            matched_count as 0
            modified_count as 0
            deleted_count as 0
            inserted_count as 1
            execution_time as execution_time
            error as none
            metadata as Dictionary with:
                "document_id" as prepared_document.id
                "collection" as collection
        
        Call database.logger.debug with message as "Document inserted into " plus collection plus " in " plus execution_time as string plus " seconds"
        Return nosql_result
        
    Catch error as Exception:
        Return NoSQLResult with:
            success as false
            operation as NoSQLOperationType.CREATE
            collection as collection
            documents as empty list
            matched_count as 0
            modified_count as 0
            deleted_count as 0
            inserted_count as 0
            execution_time as 0.0
            error as error as string
            metadata as empty dictionary

Process called "insert_documents" that takes database as NoSQLDatabase and collection as String and documents as List[NoSQLDocument] returns NoSQLResult:
    Note: Insert multiple documents into a NoSQL database collection
    Try:
        Let start_time be datetime.now
        
        Note: Prepare documents with metadata
        Let prepared_documents be empty list
        For each document in documents:
            Let prepared_document be prepare_document_for_insert with document as document
            Call prepared_documents.append with item as prepared_document
        
        Let result be none
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Let document_data be empty list
            For each doc in prepared_documents:
                Call document_data.append with item as doc.data
            Set result to mongodb.insert_documents with driver as database.driver and collection_name as collection and documents as document_data
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            Note: Use pipeline for batch Redis operations
            Let pipeline be redis.create_pipeline with driver as database.driver and transaction as false
            For each doc in prepared_documents:
                Let key be generate_redis_key with collection as collection and document_id as doc.id
                Call add_pipeline_set_command with pipeline as pipeline and key as key and value as json.dumps with data as doc.data
            Set result to redis.execute_pipeline with pipeline as pipeline
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Batch insert operation not supported for database type: " plus database.database_type as string
        
        Let end_time be datetime.now
        Let execution_time be (end_time minus start_time).total_seconds
        
        Let nosql_result be NoSQLResult with:
            success as result is not none
            operation as NoSQLOperationType.CREATE
            collection as collection
            documents as prepared_documents
            matched_count as 0
            modified_count as 0
            deleted_count as 0
            inserted_count as prepared_documents size
            execution_time as execution_time
            error as none
            metadata as Dictionary with:
                "batch_size" as prepared_documents size
                "collection" as collection
        
        Call database.logger.debug with message as prepared_documents size as string plus " documents inserted into " plus collection
        Return nosql_result
        
    Catch error as Exception:
        Return NoSQLResult with:
            success as false
            operation as NoSQLOperationType.CREATE
            collection as collection
            documents as empty list
            matched_count as 0
            modified_count as 0
            deleted_count as 0
            inserted_count as 0
            execution_time as 0.0
            error as error as string
            metadata as empty dictionary

Process called "find_documents" that takes database as NoSQLDatabase and query as NoSQLQuery returns NoSQLResult:
    Note: Find documents in a NoSQL database collection
    Try:
        Let start_time be datetime.now
        
        Let result be none
        Let found_documents be empty list
        
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Set result to mongodb.find_documents with driver as database.driver and collection_name as query.collection and filter as query.filter and projection as query.projection and sort as query.sort and limit as query.limit and skip as query.skip
            
            For each doc_data in result.documents:
                Let nosql_doc be convert_to_nosql_document with data as doc_data
                Call found_documents.append with item as nosql_doc
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            Let pattern be generate_redis_pattern with collection as query.collection
            Let keys be redis.scan_keys with driver as database.driver and pattern as pattern and count as query.limit or 1000
            
            For each key in keys:
                Let redis_result be redis.get_key with driver as database.driver and key as key
                If redis_result.success and redis_result.value is not none:
                    Let doc_data be json.loads with data as redis_result.value
                    Let nosql_doc be convert_to_nosql_document with data as doc_data
                    Call found_documents.append with item as nosql_doc
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Find operation not supported for database type: " plus database.database_type as string
        
        Note: Apply client-side filtering for Redis
        If database.database_type is NoSQLDatabaseType.REDIS and query.filter size is greater than 0:
            Set found_documents to apply_client_side_filter with documents as found_documents and filter as query.filter
        
        Let end_time be datetime.now
        Let execution_time be (end_time minus start_time).total_seconds
        
        Let nosql_result be NoSQLResult with:
            success as true
            operation as NoSQLOperationType.READ
            collection as query.collection
            documents as found_documents
            matched_count as found_documents size
            modified_count as 0
            deleted_count as 0
            inserted_count as 0
            execution_time as execution_time
            error as none
            metadata as Dictionary with:
                "query_filter" as query.filter
                "collection" as query.collection
        
        Call database.logger.debug with message as found_documents size as string plus " documents found in " plus query.collection
        Return nosql_result
        
    Catch error as Exception:
        Return NoSQLResult with:
            success as false
            operation as NoSQLOperationType.READ
            collection as query.collection
            documents as empty list
            matched_count as 0
            modified_count as 0
            deleted_count as 0
            inserted_count as 0
            execution_time as 0.0
            error as error as string
            metadata as empty dictionary

Process called "find_one_document" that takes database as NoSQLDatabase and collection as String and filter as Dictionary[String, Any] returns Optional[NoSQLDocument]:
    Note: Find a single document in a NoSQL database collection
    Try:
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Let doc_data be mongodb.find_one_document with driver as database.driver and collection_name as collection and filter as filter
            If doc_data is not none:
                Return convert_to_nosql_document with data as doc_data
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            If "id" in filter:
                Let key be generate_redis_key with collection as collection and document_id as filter["id"]
                Let redis_result be redis.get_key with driver as database.driver and key as key
                If redis_result.success and redis_result.value is not none:
                    Let doc_data be json.loads with data as redis_result.value
                    Return convert_to_nosql_document with data as doc_data
        
        Return none
        
    Catch error as Exception:
        Call database.logger.error with message as "Error finding document: " plus error as string
        Return none

Process called "update_document" that takes database as NoSQLDatabase and collection as String and filter as Dictionary[String, Any] and update as Dictionary[String, Any] and upsert as Optional[Boolean] returns NoSQLResult:
    Note: Update a document in a NoSQL database collection
    Try:
        Let start_time be datetime.now
        
        Let result be none
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Set result to mongodb.update_document with driver as database.driver and collection_name as collection and filter as filter and update as update and upsert as upsert or false
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            If "id" in filter:
                Let key be generate_redis_key with collection as collection and document_id as filter["id"]
                Let existing_result be redis.get_key with driver as database.driver and key as key
                
                If existing_result.success and existing_result.value is not none:
                    Let existing_data be json.loads with data as existing_result.value
                    Let updated_data be apply_update_to_document with document as existing_data and update as update
                    Set updated_data["updated_at"] to datetime.now
                    Set result to redis.set_key with driver as database.driver and key as key and value as json.dumps with data as updated_data
                Otherwise if upsert or false:
                    Let new_data be apply_update_to_document with document as empty dictionary and update as update
                    Set new_data["created_at"] to datetime.now
                    Set new_data["updated_at"] to datetime.now
                    Set result to redis.set_key with driver as database.driver and key as key and value as json.dumps with data as new_data
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Update operation not supported for database type: " plus database.database_type as string
        
        Let end_time be datetime.now
        Let execution_time be (end_time minus start_time).total_seconds
        
        Let success be result is not none and (result.success if "success" in result otherwise true)
        Let modified_count be result.modified_count if "modified_count" in result otherwise (1 if success otherwise 0)
        
        Let nosql_result be NoSQLResult with:
            success as success
            operation as NoSQLOperationType.UPDATE
            collection as collection
            documents as empty list
            matched_count as result.matched_count if "matched_count" in result otherwise (1 if success otherwise 0)
            modified_count as modified_count
            deleted_count as 0
            inserted_count as 0
            execution_time as execution_time
            error as none
            metadata as Dictionary with:
                "filter" as filter
                "update" as update
                "collection" as collection
        
        Call database.logger.debug with message as "Document updated in " plus collection plus ": " plus modified_count as string plus " documents"
        Return nosql_result
        
    Catch error as Exception:
        Return NoSQLResult with:
            success as false
            operation as NoSQLOperationType.UPDATE
            collection as collection
            documents as empty list
            matched_count as 0
            modified_count as 0
            deleted_count as 0
            inserted_count as 0
            execution_time as 0.0
            error as error as string
            metadata as empty dictionary

Process called "delete_document" that takes database as NoSQLDatabase and collection as String and filter as Dictionary[String, Any] returns NoSQLResult:
    Note: Delete a document from a NoSQL database collection
    Try:
        Let start_time be datetime.now
        
        Let result be none
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Set result to mongodb.delete_document with driver as database.driver and collection_name as collection and filter as filter
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            If "id" in filter:
                Let key be generate_redis_key with collection as collection and document_id as filter["id"]
                Set result to redis.delete_key with driver as database.driver and key as key
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Delete operation not supported for database type: " plus database.database_type as string
        
        Let end_time be datetime.now
        Let execution_time be (end_time minus start_time).total_seconds
        
        Let success be result is not none and (result.success if "success" in result otherwise true)
        Let deleted_count be result.deleted_count if "deleted_count" in result otherwise (result.value if "value" in result otherwise 0)
        
        Let nosql_result be NoSQLResult with:
            success as success
            operation as NoSQLOperationType.DELETE
            collection as collection
            documents as empty list
            matched_count as 0
            modified_count as 0
            deleted_count as deleted_count
            inserted_count as 0
            execution_time as execution_time
            error as none
            metadata as Dictionary with:
                "filter" as filter
                "collection" as collection
        
        Call database.logger.debug with message as "Document deleted from " plus collection plus ": " plus deleted_count as string plus " documents"
        Return nosql_result
        
    Catch error as Exception:
        Return NoSQLResult with:
            success as false
            operation as NoSQLOperationType.DELETE
            collection as collection
            documents as empty list
            matched_count as 0
            modified_count as 0
            deleted_count as 0
            inserted_count as 0
            execution_time as 0.0
            error as error as string
            metadata as empty dictionary

Process called "count_documents" that takes database as NoSQLDatabase and collection as String and filter as Optional[Dictionary[String, Any]] returns Integer:
    Note: Count documents in a NoSQL database collection
    Try:
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Return mongodb.count_documents with driver as database.driver and collection_name as collection and filter as filter
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            Let pattern be generate_redis_pattern with collection as collection
            Let keys be redis.scan_keys with driver as database.driver and pattern as pattern and count as 10000
            
            If filter is none or filter size is equal to 0:
                Return keys size
            
            Note: Apply client-side filtering for count
            Let count be 0
            For each key in keys:
                Let redis_result be redis.get_key with driver as database.driver and key as key
                If redis_result.success and redis_result.value is not none:
                    Let doc_data be json.loads with data as redis_result.value
                    If document_matches_filter with document as doc_data and filter as filter:
                        Set count to count plus 1
            
            Return count
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Count operation not supported for database type: " plus database.database_type as string
        
    Catch error as Exception:
        Call database.logger.error with message as "Error counting documents: " plus error as string
        Return 0

Process called "create_index" that takes database as NoSQLDatabase and index as NoSQLIndex returns Boolean:
    Note: Create an index on a NoSQL database collection
    Try:
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Let mongodb_index be convert_to_mongodb_index with index as index
            Let index_name be mongodb.create_index with driver as database.driver and collection_name as index.collection and index as mongodb_index
            
            If index.collection not in database.indexes:
                Set database.indexes[index.collection] to empty list
            Call database.indexes[index.collection].append with item as index
            
            Call database.logger.info with message as "Index created: " plus index_name plus " on " plus index.collection
            Return true
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            Call database.logger.warning with message as "Index creation not natively supported for Redis, using client-side indexing"
            
            If index.collection not in database.indexes:
                Set database.indexes[index.collection] to empty list
            Call database.indexes[index.collection].append with item as index
            
            Return true
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Index creation not supported for database type: " plus database.database_type as string
        
    Catch error as Exception:
        Call database.logger.error with message as "Error creating index: " plus error as string
        Return false

Process called "drop_index" that takes database as NoSQLDatabase and collection as String and index_name as String returns Boolean:
    Note: Drop an index from a NoSQL database collection
    Try:
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Let result be mongodb.drop_index with driver as database.driver and collection_name as collection and index_name as index_name
            
            If collection in database.indexes:
                Let filtered_indexes be empty list
                For each index in database.indexes[collection]:
                    If index.name is not equal to index_name:
                        Call filtered_indexes.append with item as index
                Set database.indexes[collection] to filtered_indexes
            
            Call database.logger.info with message as "Index dropped: " plus index_name plus " from " plus collection
            Return result
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            If collection in database.indexes:
                Let filtered_indexes be empty list
                For each index in database.indexes[collection]:
                    If index.name is not equal to index_name:
                        Call filtered_indexes.append with item as index
                Set database.indexes[collection] to filtered_indexes
            
            Call database.logger.info with message as "Client-side index removed: " plus index_name plus " from " plus collection
            Return true
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Index dropping not supported for database type: " plus database.database_type as string
        
    Catch error as Exception:
        Call database.logger.error with message as "Error dropping index: " plus error as string
        Return false

Process called "list_collections" that takes database as NoSQLDatabase returns List[String]:
    Note: List all collections in the NoSQL database
    Try:
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Return mongodb.list_collections with driver as database.driver
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            Note: Redis doesn't have collections, derive from key patterns
            Let all_keys be redis.scan_keys with driver as database.driver and pattern as "*" and count as 10000
            Let collections be empty set
            
            For each key in all_keys:
                Let parts be key split by ":"
                If parts size is greater than 1:
                    Call collections.add with item as parts[0]
            
            Return collections as list
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Collection listing not supported for database type: " plus database.database_type as string
        
    Catch error as Exception:
        Call database.logger.error with message as "Error listing collections: " plus error as string
        Return empty list

Process called "drop_collection" that takes database as NoSQLDatabase and collection as String returns Boolean:
    Note: Drop a collection from the NoSQL database
    Try:
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Let result be mongodb.drop_collection with driver as database.driver and collection_name as collection
            
            If collection in database.indexes:
                Call database.indexes.remove with key as collection
            
            Call database.logger.warning with message as "Collection dropped: " plus collection
            Return result
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            Let pattern be generate_redis_pattern with collection as collection
            Let keys be redis.scan_keys with driver as database.driver and pattern as pattern and count as 10000
            
            Let deleted_count be 0
            For each key in keys:
                Let delete_result be redis.delete_key with driver as database.driver and key as key
                If delete_result.success:
                    Set deleted_count to deleted_count plus 1
            
            If collection in database.indexes:
                Call database.indexes.remove with key as collection
            
            Call database.logger.warning with message as "Collection dropped: " plus collection plus " (" plus deleted_count as string plus " keys deleted)"
            Return deleted_count is greater than 0
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Collection dropping not supported for database type: " plus database.database_type as string
        
    Catch error as Exception:
        Call database.logger.error with message as "Error dropping collection: " plus error as string
        Return false

Process called "aggregate" that takes database as NoSQLDatabase and collection as String and pipeline as List[Dictionary[String, Any]] returns NoSQLResult:
    Note: Execute an aggregation pipeline on a NoSQL database collection
    Try:
        Let start_time be datetime.now
        
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Let result be mongodb.aggregate with driver as database.driver and collection_name as collection and pipeline as pipeline
            
            Let nosql_documents be empty list
            For each doc_data in result.documents:
                Let nosql_doc be convert_to_nosql_document with data as doc_data
                Call nosql_documents.append with item as nosql_doc
            
            Let end_time be datetime.now
            Let execution_time be (end_time minus start_time).total_seconds
            
            Return NoSQLResult with:
                success as true
                operation as NoSQLOperationType.AGGREGATE
                collection as collection
                documents as nosql_documents
                matched_count as nosql_documents size
                modified_count as 0
                deleted_count as 0
                inserted_count as 0
                execution_time as execution_time
                error as none
                metadata as Dictionary with:
                    "pipeline" as pipeline
                    "collection" as collection
        
        Otherwise:
            Throw UnsupportedOperationError with message as "Aggregation not natively supported for database type: " plus database.database_type as string
        
    Catch error as Exception:
        Return NoSQLResult with:
            success as false
            operation as NoSQLOperationType.AGGREGATE
            collection as collection
            documents as empty list
            matched_count as 0
            modified_count as 0
            deleted_count as 0
            inserted_count as 0
            execution_time as 0.0
            error as error as string
            metadata as empty dictionary

Process called "close_database" that takes database as NoSQLDatabase returns Boolean:
    Note: Close the NoSQL database connection
    Try:
        Call database.logger.info with message as "Closing NoSQL database connection"
        
        If database.database_type is NoSQLDatabaseType.MONGODB:
            Return mongodb.close_driver with driver as database.driver
        
        Otherwise if database.database_type is NoSQLDatabaseType.REDIS:
            Return redis.close_driver with driver as database.driver
        
        Otherwise:
            Return true
        
    Catch error as Exception:
        Call database.logger.error with message as "Error closing NoSQL database: " plus error as string
        Return false

Note: Utility functions for document and query processing
Process called "prepare_document_for_insert" that takes document as NoSQLDocument returns NoSQLDocument:
    Note: Prepare a document for insertion with metadata
    Let now be datetime.now
    
    Let prepared_document be NoSQLDocument with:
        id as document.id or generate_document_id
        data as document.data
        metadata as document.metadata or empty dictionary
        created_at as now
        updated_at as now
        version as 1
    
    Note: Add metadata to document data
    Set prepared_document.data["_id"] to prepared_document.id
    Set prepared_document.data["_created_at"] to prepared_document.created_at
    Set prepared_document.data["_updated_at"] to prepared_document.updated_at
    Set prepared_document.data["_version"] to prepared_document.version
    
    Return prepared_document

Process called "convert_to_nosql_document" that takes data as Dictionary[String, Any] returns NoSQLDocument:
    Note: Convert raw data to NoSQLDocument format
    Return NoSQLDocument with:
        id as data.get with key as "_id" and default as generate_document_id
        data as data
        metadata as empty dictionary
        created_at as data.get with key as "_created_at"
        updated_at as data.get with key as "_updated_at"
        version as data.get with key as "_version"

Process called "apply_update_to_document" that takes document as Dictionary[String, Any] and update as Dictionary[String, Any] returns Dictionary[String, Any]:
    Note: Apply update operations to a document
    Let updated_document be copy_dictionary with dictionary as document
    
    For each operation and fields in update:
        If operation is equal to "$set":
            For each field and value in fields:
                Set updated_document[field] to value
        
        Otherwise if operation is equal to "$unset":
            For each field and value in fields:
                If field in updated_document:
                    Call updated_document.remove with key as field
        
        Otherwise if operation is equal to "$inc":
            For each field and value in fields:
                Let current_value be updated_document.get with key as field and default as 0
                Set updated_document[field] to current_value plus value
        
        Otherwise if operation is equal to "$push":
            For each field and value in fields:
                If field not in updated_document:
                    Set updated_document[field] to empty list
                If updated_document[field] is list:
                    Call updated_document[field].append with item as value
        
        Otherwise if operation is equal to "$pull":
            For each field and value in fields:
                If field in updated_document and updated_document[field] is list:
                    Let filtered_list be empty list
                    For each item in updated_document[field]:
                        If item is not equal to value:
                            Call filtered_list.append with item as item
                    Set updated_document[field] to filtered_list
    
    Return updated_document

Process called "apply_client_side_filter" that takes documents as List[NoSQLDocument] and filter as Dictionary[String, Any] returns List[NoSQLDocument]:
    Note: Apply filter criteria to documents on client side
    Let filtered_documents be empty list
    
    For each document in documents:
        If document_matches_filter with document as document.data and filter as filter:
            Call filtered_documents.append with item as document
    
    Return filtered_documents

Process called "document_matches_filter" that takes document as Dictionary[String, Any] and filter as Dictionary[String, Any] returns Boolean:
    Note: Check if a document matches filter criteria
    For each field and criteria in filter:
        If field not in document:
            Return false
        
        Let value be document[field]
        
        If criteria is dictionary:
            For each operator and operand in criteria:
                If operator is equal to "$eq" and value is not equal to operand:
                    Return false
                Otherwise if operator is equal to "$ne" and value is equal to operand:
                    Return false
                Otherwise if operator is equal to "$gt" and value is not greater than operand:
                    Return false
                Otherwise if operator is equal to "$lt" and value is not less than operand:
                    Return false
                Otherwise if operator is equal to "$gte" and value is not greater than or equal to operand:
                    Return false
                Otherwise if operator is equal to "$lte" and value is not less than or equal to operand:
                    Return false
                Otherwise if operator is equal to "$in" and value not in operand:
                    Return false
                Otherwise if operator is equal to "$nin" and value in operand:
                    Return false
        Otherwise:
            If value is not equal to criteria:
                Return false
    
    Return true

Process called "generate_document_id" that returns String:
    Note: Generate a unique document identifier
    Import "uuid"
    Return uuid.uuid4 as string

Process called "generate_redis_key" that takes collection as String and document_id as String returns String:
    Note: Generate a Redis key for a document
    Return collection plus ":" plus document_id

Process called "generate_redis_pattern" that takes collection as String returns String:
    Note: Generate a Redis key pattern for collection scanning
    Return collection plus ":*"

Process called "copy_dictionary" that takes dictionary as Dictionary[String, Any] returns Dictionary[String, Any]:
    Note: Create a deep copy of a dictionary
    Let copied_dict be empty dictionary
    For each key and value in dictionary:
        Set copied_dict[key] to value
    Return copied_dict

Note: Database-specific configuration converters
Process called "convert_to_mongodb_config" that takes config as NoSQLConfig returns mongodb.MongoDBConfig:
    Note: Convert NoSQL config to MongoDB-specific config
    Let conn_config be config.connection_config
    
    Return mongodb.MongoDBConfig with:
        host as conn_config.get with key as "host" and default as "localhost"
        port as conn_config.get with key as "port" and default as 27017
        database as conn_config.get with key as "database" and default as "test"
        username as conn_config.get with key as "username"
        password as conn_config.get with key as "password"
        replica_set as conn_config.get with key as "replica_set"
        auth_source as conn_config.get with key as "auth_source" and default as "admin"
        auth_mechanism as conn_config.get with key as "auth_mechanism" and default as "SCRAM-SHA-1"
        ssl as conn_config.get with key as "ssl" and default as false
        ssl_cert_reqs as conn_config.get with key as "ssl_cert_reqs" and default as "CERT_NONE"
        ssl_ca_certs as conn_config.get with key as "ssl_ca_certs"
        ssl_certfile as conn_config.get with key as "ssl_certfile"
        ssl_keyfile as conn_config.get with key as "ssl_keyfile"
        connect_timeout as conn_config.get with key as "connect_timeout" and default as 20000
        server_selection_timeout as conn_config.get with key as "server_selection_timeout" and default as 30000
        socket_timeout as conn_config.get with key as "socket_timeout" and default as 5000
        max_pool_size as conn_config.get with key as "max_pool_size" and default as 100
        min_pool_size as conn_config.get with key as "min_pool_size" and default as 0
        max_idle_time as conn_config.get with key as "max_idle_time" and default as 300000
        read_preference as conn_config.get with key as "read_preference" and default as "primary"
        write_concern as conn_config.get with key as "write_concern" and default as empty dictionary
        read_concern as conn_config.get with key as "read_concern" and default as empty dictionary
        retry_writes as conn_config.get with key as "retry_writes" and default as true
        retry_reads as conn_config.get with key as "retry_reads" and default as true
        compression as conn_config.get with key as "compression"

Process called "convert_to_redis_config" that takes config as NoSQLConfig returns redis.RedisConfig:
    Note: Convert NoSQL config to Redis-specific config
    Let conn_config be config.connection_config
    
    Return redis.RedisConfig with:
        host as conn_config.get with key as "host" and default as "localhost"
        port as conn_config.get with key as "port" and default as 6379
        database as conn_config.get with key as "database" and default as 0
        password as conn_config.get with key as "password"
        username as conn_config.get with key as "username"
        socket_timeout as conn_config.get with key as "socket_timeout" and default as 5.0
        socket_connect_timeout as conn_config.get with key as "socket_connect_timeout" and default as 5.0
        socket_keepalive as conn_config.get with key as "socket_keepalive" and default as false
        socket_keepalive_options as conn_config.get with key as "socket_keepalive_options" and default as empty dictionary
        connection_pool_class as conn_config.get with key as "connection_pool_class" and default as "ConnectionPool"
        max_connections as conn_config.get with key as "max_connections" and default as 50
        retry_on_timeout as conn_config.get with key as "retry_on_timeout" and default as false
        retry_on_error as conn_config.get with key as "retry_on_error" and default as empty list
        health_check_interval as conn_config.get with key as "health_check_interval" and default as 30
        ssl as conn_config.get with key as "ssl" and default as false
        ssl_keyfile as conn_config.get with key as "ssl_keyfile"
        ssl_certfile as conn_config.get with key as "ssl_certfile"
        ssl_cert_reqs as conn_config.get with key as "ssl_cert_reqs" and default as "required"
        ssl_ca_certs as conn_config.get with key as "ssl_ca_certs"
        encoding as conn_config.get with key as "encoding" and default as "utf-8"
        decode_responses as conn_config.get with key as "decode_responses" and default as true
        cluster_mode as conn_config.get with key as "cluster_mode" and default as false
        cluster_nodes as conn_config.get with key as "cluster_nodes" and default as empty list
        sentinel_mode as conn_config.get with key as "sentinel_mode" and default as false
        sentinel_service_name as conn_config.get with key as "sentinel_service_name"
        sentinel_nodes as conn_config.get with key as "sentinel_nodes" and default as empty list

Process called "convert_to_mongodb_index" that takes index as NoSQLIndex returns mongodb.MongoDBIndex:
    Note: Convert NoSQL index to MongoDB-specific index
    Return mongodb.MongoDBIndex with:
        name as index.name
        keys as index.fields
        unique as index.unique
        sparse as index.sparse
        partial_filter_expression as index.partial_filter
        expire_after_seconds as index.expire_after
        background as index.background
        text_index_version as none

Process called "initialize_nosql_collections" that takes database as NoSQLDatabase returns None:
    Note: Initialize collections and indexes for the NoSQL database
    Try:
        Set database.collections to list_collections with database as database
        
        For each collection in database.collections:
            Set database.indexes[collection] to empty list
        
        Call database.logger.debug with message as "Initialized " plus database.collections size as string plus " collections"
        
    Catch error as Exception:
        Call database.logger.warning with message as "Failed to initialize collections: " plus error as string

Process called "add_pipeline_set_command" that takes pipeline as redis.RedisPipeline and key as String and value as String returns None:
    Note: Add a SET command to Redis pipeline
    Note: This would be implemented by the Redis pipeline object
    Return

Note: Custom exceptions for NoSQL operations
Type NoSQLDatabaseError as Exception
Type UnsupportedDatabaseTypeError as Exception
Type UnsupportedOperationError as Exception
Type NoSQLQueryError as Exception