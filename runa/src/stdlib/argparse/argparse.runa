Note:
Runa Standard Library: ArgParse Module

Provides comprehensive command-line argument parsing and CLI utilities.
Supports positional/optional arguments, subcommands, type conversion, validation,
automatic help, advanced error handling, and extensibility for AI/interactive CLI scenarios.

Features:
- Positional and optional arguments (with types, defaults, required/optional)
- Subcommands and command groups
- Type conversion and validation
- Automatic help/usage generation
- Error handling (unknown args, missing required, type errors)
- Config file/env var overrides
- Mutually exclusive groups, dependencies, argument file expansion, custom actions
- Extensible for AI/interactive CLI
:End Note

Note: Core Types and Constants
Type ArgumentType is:
    | STRING
    | INTEGER
    | FLOAT
    | BOOLEAN
    | FILE
    | DIRECTORY
    | CHOICE with choices as List[String]
    | CUSTOM with process as Process

Type Argument is Dictionary with:
    name as String
    short_name as Optional[String]
    type as ArgumentType
    required as Boolean defaults to false
    default as Any
    help as String
    positional as Boolean defaults to false
    multiple as Boolean defaults to false
    choices as List[Any]
    env_var as Optional[String]
    config_key as Optional[String]
    mutually_exclusive_group as Optional[String]
    depends_on as List[String]
    action as Optional[Process]
    validator as Optional[Process]
    metavar as Optional[String]
    hidden as Boolean defaults to false

Type Subcommand is Dictionary with:
    name as String
    help as String
    arguments as List[Argument]
    handler as Process
    subcommands as List[Subcommand]
    parent as Optional[Subcommand]
    hidden as Boolean defaults to false

Type ArgParseResult is:
    | ParseSuccess with values as Dictionary[String, Any] and command as Optional[String]
    | ParseError with message as String and code as String

Type ArgParseOptions is Dictionary with:
    allow_unknown as Boolean defaults to false
    allow_abbrev as Boolean defaults to true
    help_flag as Boolean defaults to true
    version_flag as Boolean defaults to true
    env_prefix as Optional[String]
    config_file as Optional[String]
    exit_on_error as Boolean defaults to true
    color_output as Boolean defaults to true
    ai_mode as Boolean defaults to false

Note: Argument Parser Definition
Type ArgumentParser is Dictionary with:
    program_name as String
    description as String
    arguments as List[Argument]
    subcommands as List[Subcommand]
    options as ArgParseOptions
    version as Optional[String]
    epilog as Optional[String]
    usage as Optional[String]
    parent as Optional[ArgumentParser]
    metadata as Dictionary[String, Any]

Note: Core Parser Functions
Process called "create_parser" that takes program_name as String and description as String returns ArgumentParser:
    Return ArgumentParser with:
        program_name as program_name
        description as description
        arguments as list containing
        subcommands as list containing
        options as create_default_options
        version as None
        epilog as None
        usage as None
        parent as None
        metadata as dictionary containing

Process called "add_argument" that takes parser as ArgumentParser and argument as Argument returns ArgumentParser:
    Add argument to parser.arguments
    Return parser

Process called "add_subcommand" that takes parser as ArgumentParser and subcommand as Subcommand returns ArgumentParser:
    Add subcommand to parser.subcommands
    Return parser

Process called "set_version" that takes parser as ArgumentParser and version as String returns ArgumentParser:
    Set parser.version to version
    Return parser

Process called "set_epilog" that takes parser as ArgumentParser and epilog as String returns ArgumentParser:
    Set parser.epilog to epilog
    Return parser

Process called "set_usage" that takes parser as ArgumentParser and usage as String returns ArgumentParser:
    Set parser.usage to usage
    Return parser

Process called "set_options" that takes parser as ArgumentParser and options as ArgParseOptions returns ArgumentParser:
    Set parser.options to options
    Return parser

Note: Parsing and Validation
Process called "parse_args" that takes parser as ArgumentParser and argv as List[String] returns ArgParseResult:
    Return parse_args_with_options with parser as parser and argv as argv and options as parser.options

Process called "parse_args_with_options" that takes parser as ArgumentParser and argv as List[String] and options as ArgParseOptions returns ArgParseResult:
    Let result_values be dictionary containing
    Let current_command be None as Optional[String]
    Let current_parser be parser
    Let argv_index be 0
    Let positional_index be 0
    
    Note: Handle help and version flags first
    If "--help" is in argv or "-h" is in argv:
        If options["exit_on_error"]:
            display_help with parser as current_parser
            exit_program
        Otherwise:
            Return ParseError with message as generate_help with parser as current_parser and code as "HELP_REQUESTED"
    
    If "--version" is in argv and parser["version"] is not None:
        If options["exit_on_error"]:
            Display parser["version"]
            exit_program
        Otherwise:
            Return ParseError with message as parser["version"] and code as "VERSION_REQUESTED"
    
    Note: Parse each argument in argv
    While argv_index is less than length of argv:
        Let current_arg be argv at index argv_index
        
        Note: Handle subcommands
        If current_arg does not start with "-" and length of current_parser["subcommands"] is greater than 0:
            Let found_subcommand be find_subcommand with parser as current_parser and name as current_arg
            If found_subcommand is not None:
                Set current_command to current_arg
                Set current_parser to found_subcommand
                Set argv_index to argv_index plus 1
                Continue loop
        
        Note: Handle long options (--option)
        If current_arg starts with "--":
            Let option_name be substring of current_arg from index 2
            Let option_value be None as Optional[String]
            
            Note: Handle --option=value format
            If "=" is in option_name:
                Let parts be split string option_name by "="
                Set option_name to parts at index 0
                Set option_value to parts at index 1
            
            Let argument be find_argument_by_name with parser as current_parser and name as option_name
            If argument is None:
                If not options["allow_unknown"]:
                    Return ParseError with message as "Unknown argument: --" plus option_name and code as "UNKNOWN_ARGUMENT"
                Set argv_index to argv_index plus 1
                Continue loop
            
            Note: Get value for option
            If option_value is None:
                If argument["type"] is not BOOLEAN:
                    Set argv_index to argv_index plus 1
                    If argv_index is greater than or equal to length of argv:
                        Return ParseError with message as "Missing value for argument: --" plus option_name and code as "MISSING_VALUE"
                    Set option_value to argv at index argv_index
                Otherwise:
                    Set option_value to "true"
            
            Note: Convert and validate value
            Let converted_value be convert_type with value as option_value and arg_type as argument["type"]
            If converted_value is None:
                Return ParseError with message as "Invalid value for argument --" plus option_name plus ": " plus option_value and code as "INVALID_VALUE"
            
            If not validate_argument with argument as argument and value as converted_value:
                Return ParseError with message as "Validation failed for argument --" plus option_name plus ": " plus option_value and code as "VALIDATION_FAILED"
            
            Set result_values[option_name] to converted_value
        
        Note: Handle short options (-o)
        Otherwise if current_arg starts with "-" and length of current_arg is greater than 1:
            Let short_options be substring of current_arg from index 1
            Let option_index be 0
            
            While option_index is less than length of short_options:
                Let short_char be short_options at index option_index
                Let argument be find_argument_by_short_name with parser as current_parser and short_name as short_char
                
                If argument is None:
                    If not options["allow_unknown"]:
                        Return ParseError with message as "Unknown short argument: -" plus short_char and code as "UNKNOWN_ARGUMENT"
                    Set option_index to option_index plus 1
                    Continue loop
                
                Let option_value be None as Optional[String]
                If argument["type"] is not BOOLEAN:
                    Note: Check if value is attached (-ovalue)
                    If option_index plus 1 is less than length of short_options:
                        Set option_value to substring of short_options from index option_index plus 1
                        Set option_index to length of short_options
                    Otherwise:
                        Set argv_index to argv_index plus 1
                        If argv_index is greater than or equal to length of argv:
                            Return ParseError with message as "Missing value for argument: -" plus short_char and code as "MISSING_VALUE"
                        Set option_value to argv at index argv_index
                Otherwise:
                    Set option_value to "true"
                
                Let converted_value be convert_type with value as option_value and arg_type as argument["type"]
                If converted_value is None:
                    Return ParseError with message as "Invalid value for argument -" plus short_char plus ": " plus option_value and code as "INVALID_VALUE"
                
                If not validate_argument with argument as argument and value as converted_value:
                    Return ParseError with message as "Validation failed for argument -" plus short_char plus ": " plus option_value and code as "VALIDATION_FAILED"
                
                Set result_values[argument["name"]] to converted_value
                Set option_index to option_index plus 1
        
        Note: Handle positional arguments
        Otherwise:
            Let positional_args be filter_positional_arguments with parser as current_parser
            If positional_index is greater than or equal to length of positional_args:
                If not options["allow_unknown"]:
                    Return ParseError with message as "Too many positional arguments: " plus current_arg and code as "TOO_MANY_POSITIONAL"
                Set argv_index to argv_index plus 1
                Continue loop
            
            Let argument be positional_args at index positional_index
            Let converted_value be convert_type with value as current_arg and arg_type as argument["type"]
            If converted_value is None:
                Return ParseError with message as "Invalid value for positional argument " plus argument["name"] plus ": " plus current_arg and code as "INVALID_VALUE"
            
            If not validate_argument with argument as argument and value as converted_value:
                Return ParseError with message as "Validation failed for positional argument " plus argument["name"] plus ": " plus current_arg and code as "VALIDATION_FAILED"
            
            Set result_values[argument["name"]] to converted_value
            Set positional_index to positional_index plus 1
        
        Set argv_index to argv_index plus 1
    
    Note: Apply defaults for missing arguments
    For each argument in current_parser["arguments"]:
        If argument["name"] is not in result_values:
            Note: Check environment variable override
            If argument["env_var"] is not None:
                Let env_value be parse_env_var with env_var as argument["env_var"]
                If env_value is not None:
                    Let converted_value be convert_type with value as env_value and arg_type as argument["type"]
                    If converted_value is not None:
                        Set result_values[argument["name"]] to converted_value
                        Continue loop
            
            Note: Check config file override
            If argument["config_key"] is not None and options["config_file"] is not None:
                Let config be parse_config_file with config_file as options["config_file"]
                If argument["config_key"] is in config:
                    Let config_value be config[argument["config_key"]]
                    Let converted_value be convert_type with value as config_value and arg_type as argument["type"]
                    If converted_value is not None:
                        Set result_values[argument["name"]] to converted_value
                        Continue loop
            
            Note: Apply default value
            If argument["default"] is not None:
                Set result_values[argument["name"]] to argument["default"]
            Otherwise if argument["required"]:
                Return ParseError with message as "Missing required argument: " plus argument["name"] and code as "MISSING_REQUIRED"
    
    Note: Validate mutually exclusive groups
    Let validation_result be validate_mutually_exclusive_groups with parser as current_parser and values as result_values
    If validation_result is not None:
        Return ParseError with message as validation_result and code as "MUTUALLY_EXCLUSIVE"
    
    Note: Validate dependencies
    Let dependency_result be validate_argument_dependencies with parser as current_parser and values as result_values
    If dependency_result is not None:
        Return ParseError with message as dependency_result and code as "DEPENDENCY_FAILED"
    
    Return ParseSuccess with values as result_values and command as current_command

Note: Help and Usage Generation
Process called "generate_help" that takes parser as ArgumentParser returns String:
    Let help_str be parser.program_name plus ": " plus parser.description plus "\n\n"
    For each arg in parser.arguments:
        If not arg.hidden:
            Set help_str to help_str plus "  " plus arg.name plus " (" plus arg.type plus ")"
            If arg.required:
                Set help_str to help_str plus " [required]"
            If arg.default is not None:
                Set help_str to help_str plus " [default: " plus arg.default plus "]"
            If arg.help is not None:
                Set help_str to help_str plus " - " plus arg.help
            Set help_str to help_str plus "\n"
    If length of parser.subcommands is greater than 0:
        Set help_str to help_str plus "\nSubcommands:\n"
        For each sub in parser.subcommands:
            If not sub.hidden:
                Set help_str to help_str plus "  " plus sub.name plus ": " plus sub.help plus "\n"
    If parser.epilog is not None:
        Set help_str to help_str plus "\n" plus parser.epilog
    Return help_str

Process called "generate_usage" that takes parser as ArgumentParser returns String:
    If parser.usage is not None:
        Return parser.usage
    Let usage_str be "Usage: " plus parser.program_name
    For each arg in parser.arguments:
        If arg.positional:
            Set usage_str to usage_str plus " " plus arg.name
        Otherwise:
            Set usage_str to usage_str plus " [--" plus arg.name plus "]"
    If length of parser.subcommands is greater than 0:
        Set usage_str to usage_str plus " <command> [options]"
    Return usage_str

Note: Error Handling
Process called "print_error" that takes message as String and code as String returns None:
    Display "Error [" plus code plus "]: " plus message
    Return None

Process called "exit_with_error" that takes message as String and code as String returns None:
    Display "Fatal Error [" plus code plus "]: " plus message
    Exit program

Note: Utility Functions
Process called "create_default_options" returns ArgParseOptions:
    Return ArgParseOptions with:
        allow_unknown as false
        allow_abbrev as true
        help_flag as true
        version_flag as true
        env_prefix as None
        config_file as None
        exit_on_error as true
        color_output as true
        ai_mode as false

Process called "parse_env_var" that takes env_var as String returns Optional[String]:
    Try:
        Let env_value be environment_variable with name as env_var
        If env_value is not None and env_value is not "":
            Return env_value
        Otherwise:
            Return None
    Catch:
        Return None

Process called "parse_config_file" that takes config_file as String returns Dictionary[String, Any]:
    Try:
        Let file_content be read_file with path as config_file
        If config_file ends with ".json":
            Return parse_json with content as file_content
        Otherwise if config_file ends with ".yaml" or config_file ends with ".yml":
            Return parse_yaml with content as file_content
        Otherwise if config_file ends with ".toml":
            Return parse_toml with content as file_content
        Otherwise:
            Note: Try to parse as simple key=value format
            Let config be dictionary containing
            Let lines be split string file_content by "\n"
            For each line in lines:
                Let trimmed_line be trim string line
                If trimmed_line starts with "#" or trimmed_line is equal to "":
                    Continue loop
                If "=" is in trimmed_line:
                    Let parts be split string trimmed_line by "=" with limit as 2
                    Let key be trim string parts at index 0
                    Let value be trim string parts at index 1
                    Set config[key] to value
            Return config
    Catch:
        Return dictionary containing

Process called "expand_argument_file" that takes file_path as String returns List[String]:
    Try:
        Let file_content be read_file with path as file_path
        Let lines be split string file_content by "\n"
        Let expanded_args be list containing
        For each line in lines:
            Let trimmed_line be trim string line
            If trimmed_line is not equal to "" and not trimmed_line starts with "#":
                Note: Split line into individual arguments respecting quotes
                Let line_args be split_arguments with line as trimmed_line
                For each arg in line_args:
                    Add arg to expanded_args
        Return expanded_args
    Catch:
        Return list containing

Process called "split_arguments" that takes line as String returns List[String]:
    Let args be list containing
    Let current_arg be ""
    Let in_quotes be false
    Let quote_char be ""
    Let i be 0
    
    While i is less than length of line:
        Let char be line at index i
        
        If char is equal to "\"" or char is equal to "'":
            If not in_quotes:
                Set in_quotes to true
                Set quote_char to char
            Otherwise if char is equal to quote_char:
                Set in_quotes to false
                Set quote_char to ""
            Otherwise:
                Set current_arg to current_arg plus char
        Otherwise if char is equal to " " and not in_quotes:
            If current_arg is not equal to "":
                Add current_arg to args
                Set current_arg to ""
        Otherwise:
            Set current_arg to current_arg plus char
        
        Set i to i plus 1
    
    If current_arg is not equal to "":
        Add current_arg to args
    
    Return args

Process called "validate_argument" that takes argument as Argument and value as Any returns Boolean:
    If argument.validator is not None:
        Return argument.validator with value as value
    Otherwise:
        Return true

Process called "convert_type" that takes value as String and arg_type as ArgumentType returns Any:
    Match arg_type:
        When STRING:
            Return value
        When INTEGER:
            Return parse_integer with string as value
        When FLOAT:
            Return parse_float with string as value
        When BOOLEAN:
            Return value is equal to "true" or value is equal to "1"
        When FILE:
            Return value
        When DIRECTORY:
            Return value
        When CHOICE with choices as choices:
            If value is in choices:
                Return value
            Otherwise:
                Return None
        When CUSTOM with process as process:
            Return process with value as value

Process called "parse_integer" that takes string as String returns Optional[Integer]:
    Try:
        Let result be string as Integer
        Return result
    Catch:
        Return None

Process called "parse_float" that takes string as String returns Optional[Float]:
    Try:
        Let result be string as Float
        Return result
    Catch:
        Return None

Process called "find_subcommand" that takes parser as ArgumentParser and name as String returns Optional[Subcommand]:
    For each subcommand in parser["subcommands"]:
        If subcommand["name"] is equal to name:
            Return subcommand
    Return None

Process called "find_argument_by_name" that takes parser as ArgumentParser and name as String returns Optional[Argument]:
    For each argument in parser["arguments"]:
        If argument["name"] is equal to name:
            Return argument
        Note: Check for abbreviations if enabled
        If parser["options"]["allow_abbrev"] and name starts with argument["name"]:
            Return argument
    Return None

Process called "find_argument_by_short_name" that takes parser as ArgumentParser and short_name as String returns Optional[Argument]:
    For each argument in parser["arguments"]:
        If argument["short_name"] is not None and argument["short_name"] is equal to short_name:
            Return argument
    Return None

Process called "filter_positional_arguments" that takes parser as ArgumentParser returns List[Argument]:
    Let positional_args be list containing
    For each argument in parser["arguments"]:
        If argument["positional"]:
            Add argument to positional_args
    Return positional_args

Process called "validate_mutually_exclusive_groups" that takes parser as ArgumentParser and values as Dictionary[String, Any] returns Optional[String]:
    Let groups be dictionary containing
    
    Note: Group arguments by mutually exclusive group
    For each argument in parser["arguments"]:
        If argument["mutually_exclusive_group"] is not None and argument["name"] is in values:
            Let group_name be argument["mutually_exclusive_group"]
            If group_name is not in groups:
                Set groups[group_name] to list containing
            Add argument["name"] to groups[group_name]
    
    Note: Check each group has at most one argument set
    For each group_name in groups:
        Let group_args be groups[group_name]
        If length of group_args is greater than 1:
            Return "Arguments " plus group_args plus " are mutually exclusive"
    
    Return None

Process called "validate_argument_dependencies" that takes parser as ArgumentParser and values as Dictionary[String, Any] returns Optional[String]:
    For each argument in parser["arguments"]:
        If argument["name"] is in values and length of argument["depends_on"] is greater than 0:
            For each dependency in argument["depends_on"]:
                If dependency is not in values:
                    Return "Argument " plus argument["name"] plus " requires " plus dependency
    Return None

Process called "display_help" that takes parser as ArgumentParser returns None:
    Display generate_help with parser as parser
    Return None

Process called "display_usage" that takes parser as ArgumentParser returns None:
    Display generate_usage with parser as parser
    Return None

Process called "exit_program" returns None:
    system_exit with code as 0
    Return None

Process called "exit_with_code" that takes code as Integer returns None:
    system_exit with code as code
    Return None

Note: Helper functions for creating common argument types
Process called "create_string_argument" that takes name as String and help as String returns Argument:
    Return Argument with:
        name as name
        short_name as None
        type as STRING
        required as false
        default as None
        help as help
        positional as false
        multiple as false
        choices as list containing
        env_var as None
        config_key as None
        mutually_exclusive_group as None
        depends_on as list containing
        action as None
        validator as None
        metavar as None
        hidden as false

Process called "create_integer_argument" that takes name as String and help as String returns Argument:
    Return Argument with:
        name as name
        short_name as None
        type as INTEGER
        required as false
        default as None
        help as help
        positional as false
        multiple as false
        choices as list containing
        env_var as None
        config_key as None
        mutually_exclusive_group as None
        depends_on as list containing
        action as None
        validator as None
        metavar as None
        hidden as false

Process called "create_boolean_argument" that takes name as String and help as String returns Argument:
    Return Argument with:
        name as name
        short_name as None
        type as BOOLEAN
        required as false
        default as false
        help as help
        positional as false
        multiple as false
        choices as list containing
        env_var as None
        config_key as None
        mutually_exclusive_group as None
        depends_on as list containing
        action as None
        validator as None
        metavar as None
        hidden as false

Process called "create_choice_argument" that takes name as String and help as String and choices as List[String] returns Argument:
    Return Argument with:
        name as name
        short_name as None
        type as CHOICE with choices as choices
        required as false
        default as None
        help as help
        positional as false
        multiple as false
        choices as choices
        env_var as None
        config_key as None
        mutually_exclusive_group as None
        depends_on as list containing
        action as None
        validator as None
        metavar as None
        hidden as false

Process called "set_argument_short_name" that takes argument as Argument and short_name as String returns Argument:
    Set argument["short_name"] to short_name
    Return argument

Process called "set_argument_required" that takes argument as Argument and required as Boolean returns Argument:
    Set argument["required"] to required
    Return argument

Process called "set_argument_default" that takes argument as Argument and default as Any returns Argument:
    Set argument["default"] to default
    Return argument

Process called "set_argument_env_var" that takes argument as Argument and env_var as String returns Argument:
    Set argument["env_var"] to env_var
    Return argument 