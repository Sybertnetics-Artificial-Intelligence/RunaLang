Note:
Runa Standard Library: ArgParse Subcommands Module

Provides comprehensive subcommand functionality for building complex CLI applications
with nested commands, command groups, and enterprise-grade command management.

Features:
- Hierarchical subcommand structure
- Command groups and categorization
- Dynamic command loading and plugins
- Command aliases and shortcuts
- Auto-completion and help generation
- Command middleware and hooks
:End Note

Import "argparse.argparse" as argparse
Import "argparse.parser" as parser

Note: Advanced Subcommand Types
Type called "SubcommandGroup":
    name as String
    title as String
    description as String
    commands as List[Subcommand]
    parent as Optional[SubcommandGroup]
    hidden as Boolean defaults to false
    sort_order as Integer defaults to 0

Type called "CommandAlias":
    alias as String
    target_command as String
    description as String
    hidden as Boolean defaults to false

Type called "CommandMiddleware":
    name as String
    before_execute as Optional[Process]
    after_execute as Optional[Process]
    on_error as Optional[Process]
    priority as Integer defaults to 0

Type called "SubcommandRegistry":
    commands as Dictionary[String, Subcommand]
    groups as Dictionary[String, SubcommandGroup]
    aliases as Dictionary[String, CommandAlias]
    middleware as List[CommandMiddleware]
    plugins as Dictionary[String, Any]

Note: Subcommand Builder Functions
Process called "create_subcommand_builder" that takes name as String and help as String returns SubcommandBuilder:
    Return SubcommandBuilder with:
        name as name
        help as help
        arguments as list containing
        subcommands as list containing
        handler as None
        parent as None
        group as None
        aliases as list containing
        middleware as list containing
        hidden as false
        metadata as dictionary containing

Type called "SubcommandBuilder":
    name as String
    help as String
    arguments as List[Argument]
    subcommands as List[Subcommand]
    handler as Optional[Process]
    parent as Optional[Subcommand]
    group as Optional[String]
    aliases as List[String]
    middleware as List[String]
    hidden as Boolean
    metadata as Dictionary[String, Any]

Process called "add_subcommand_argument" that takes builder as SubcommandBuilder and argument as Argument returns SubcommandBuilder:
    Add argument to builder["arguments"]
    Return builder

Process called "add_nested_subcommand" that takes builder as SubcommandBuilder and subcommand as Subcommand returns SubcommandBuilder:
    Set subcommand["parent"] to builder
    Add subcommand to builder["subcommands"]
    Return builder

Process called "set_subcommand_handler" that takes builder as SubcommandBuilder and handler as Process returns SubcommandBuilder:
    Set builder["handler"] to handler
    Return builder

Process called "set_subcommand_group" that takes builder as SubcommandBuilder and group as String returns SubcommandBuilder:
    Set builder["group"] to group
    Return builder

Process called "add_subcommand_alias" that takes builder as SubcommandBuilder and alias as String returns SubcommandBuilder:
    Add alias to builder["aliases"]
    Return builder

Process called "add_subcommand_middleware" that takes builder as SubcommandBuilder and middleware_name as String returns SubcommandBuilder:
    Add middleware_name to builder["middleware"]
    Return builder

Process called "build_subcommand" that takes builder as SubcommandBuilder returns Subcommand:
    Return Subcommand with:
        name as builder["name"]
        help as builder["help"]
        arguments as builder["arguments"]
        handler as builder["handler"]
        subcommands as builder["subcommands"]
        parent as None
        hidden as builder["hidden"]
        group as builder["group"]
        aliases as builder["aliases"]
        middleware as builder["middleware"]
        metadata as builder["metadata"]

Note: Registry Management
Process called "create_subcommand_registry" returns SubcommandRegistry:
    Return SubcommandRegistry with:
        commands as dictionary containing
        groups as dictionary containing
        aliases as dictionary containing
        middleware as list containing
        plugins as dictionary containing

Process called "register_subcommand" that takes registry as SubcommandRegistry and subcommand as Subcommand returns SubcommandRegistry:
    Set registry["commands"][subcommand["name"]] to subcommand
    
    Note: Register aliases
    For each alias in subcommand["aliases"]:
        Set registry["aliases"][alias] to CommandAlias with:
            alias as alias
            target_command as subcommand["name"]
            description as "Alias for " plus subcommand["name"]
            hidden as false
    
    Return registry

Process called "register_command_group" that takes registry as SubcommandRegistry and group as SubcommandGroup returns SubcommandRegistry:
    Set registry["groups"][group["name"]] to group
    Return registry

Process called "register_middleware" that takes registry as SubcommandRegistry and middleware as CommandMiddleware returns SubcommandRegistry:
    Add middleware to registry["middleware"]
    
    Note: Sort middleware by priority
    Set registry["middleware"] to sort list registry["middleware"] by process middleware["priority"]
    
    Return registry

Process called "find_subcommand_by_name" that takes registry as SubcommandRegistry and name as String returns Optional[Subcommand]:
    Note: Check direct command name
    If name is in registry["commands"]:
        Return registry["commands"][name]
    
    Note: Check aliases
    If name is in registry["aliases"]:
        Let alias be registry["aliases"][name]
        Let target_command be alias["target_command"]
        If target_command is in registry["commands"]:
            Return registry["commands"][target_command]
    
    Note: Check for partial matches if abbreviation is allowed
    Let partial_matches be list containing
    For each command_name in registry["commands"]:
        If command_name starts with name:
            Add registry["commands"][command_name] to partial_matches
    
    If length of partial_matches is equal to 1:
        Return partial_matches at index 0
    Otherwise if length of partial_matches is greater than 1:
        Note: Ambiguous match - return None and let caller handle
        Return None
    
    Return None

Process called "get_commands_in_group" that takes registry as SubcommandRegistry and group_name as String returns List[Subcommand]:
    Let commands_in_group be list containing
    
    For each command_name in registry["commands"]:
        Let command be registry["commands"][command_name]
        If command["group"] is equal to group_name:
            Add command to commands_in_group
    
    Return commands_in_group

Note: Command Execution
Process called "execute_subcommand" that takes registry as SubcommandRegistry and subcommand as Subcommand and args as Dictionary[String, Any] returns Any:
    Note: Execute before middleware
    For each middleware in registry["middleware"]:
        If middleware["before_execute"] is not None:
            Try:
                middleware["before_execute"] with subcommand as subcommand and args as args
            Catch error:
                If middleware["on_error"] is not None:
                    middleware["on_error"] with error as error and subcommand as subcommand and args as args
                Otherwise:
                    Throw error
    
    Note: Execute the command handler
    Let result be None
    Try:
        If subcommand["handler"] is not None:
            Set result to subcommand["handler"] with args as args
        Otherwise:
            Display "No handler defined for command: " plus subcommand["name"]
            Set result to false
    Catch error:
        Note: Execute error middleware
        For each middleware in registry["middleware"]:
            If middleware["on_error"] is not None:
                middleware["on_error"] with error as error and subcommand as subcommand and args as args
        Throw error
    
    Note: Execute after middleware
    For each middleware in registry["middleware"]:
        If middleware["after_execute"] is not None:
            Try:
                middleware["after_execute"] with subcommand as subcommand and args as args and result as result
            Catch error:
                If middleware["on_error"] is not None:
                    middleware["on_error"] with error as error and subcommand as subcommand and args as args
                Otherwise:
                    Throw error
    
    Return result

Note: Help Generation for Subcommands
Process called "generate_subcommand_help" that takes registry as SubcommandRegistry and parent_command as Optional[String] returns String:
    Let help_text be ""
    
    If parent_command is None:
        Set help_text to "Available commands:\n\n"
    Otherwise:
        Set help_text to "Available subcommands for " plus parent_command plus ":\n\n"
    
    Note: Group commands by group
    Let grouped_commands be dictionary containing
    Let ungrouped_commands be list containing
    
    For each command_name in registry["commands"]:
        Let command be registry["commands"][command_name]
        If not command["hidden"]:
            If command["group"] is not None:
                If command["group"] is not in grouped_commands:
                    Set grouped_commands[command["group"]] to list containing
                Add command to grouped_commands[command["group"]]
            Otherwise:
                Add command to ungrouped_commands
    
    Note: Display grouped commands
    For each group_name in grouped_commands:
        If group_name is in registry["groups"]:
            Let group be registry["groups"][group_name]
            Set help_text to help_text plus group["title"] plus ":\n"
            If group["description"] is not equal to "":
                Set help_text to help_text plus "  " plus group["description"] plus "\n"
        Otherwise:
            Set help_text to help_text plus group_name plus ":\n"
        
        Let commands in group be grouped_commands[group_name]
        For each command in commands_in_group:
            Set help_text to help_text plus "  " plus command["name"]
            
            Note: Add aliases
            If length of command["aliases"] is greater than 0:
                Set help_text to help_text plus " (" plus command["aliases"] plus ")"
            
            Set help_text to help_text plus " - " plus command["help"] plus "\n"
        
        Set help_text to help_text plus "\n"
    
    Note: Display ungrouped commands
    If length of ungrouped_commands is greater than 0:
        Set help_text to help_text plus "Commands:\n"
        For each command in ungrouped_commands:
            Set help_text to help_text plus "  " plus command["name"]
            
            If length of command["aliases"] is greater than 0:
                Set help_text to help_text plus " (" plus command["aliases"] plus ")"
            
            Set help_text to help_text plus " - " plus command["help"] plus "\n"
    
    Return help_text

Process called "generate_command_help" that takes subcommand as Subcommand returns String:
    Let help_text be subcommand["name"] plus ": " plus subcommand["help"] plus "\n\n"
    
    Note: Add usage information
    Set help_text to help_text plus "Usage: " plus subcommand["name"]
    
    For each argument in subcommand["arguments"]:
        If argument["positional"]:
            If argument["required"]:
                Set help_text to help_text plus " <" plus argument["name"] plus ">"
            Otherwise:
                Set help_text to help_text plus " [" plus argument["name"] plus "]"
        Otherwise:
            Set help_text to help_text plus " [--" plus argument["name"] plus "]"
    
    If length of subcommand["subcommands"] is greater than 0:
        Set help_text to help_text plus " <subcommand>"
    
    Set help_text to help_text plus "\n\n"
    
    Note: Add arguments section
    If length of subcommand["arguments"] is greater than 0:
        Set help_text to help_text plus "Arguments:\n"
        For each argument in subcommand["arguments"]:
            If not argument["hidden"]:
                Set help_text to help_text plus "  " plus argument["name"]
                
                If argument["short_name"] is not None:
                    Set help_text to help_text plus ", -" plus argument["short_name"]
                
                If argument["required"]:
                    Set help_text to help_text plus " (required)"
                
                If argument["default"] is not None:
                    Set help_text to help_text plus " [default: " plus argument["default"] plus "]"
                
                Set help_text to help_text plus " - " plus argument["help"] plus "\n"
        
        Set help_text to help_text plus "\n"
    
    Note: Add subcommands section
    If length of subcommand["subcommands"] is greater than 0:
        Set help_text to help_text plus "Subcommands:\n"
        For each sub_command in subcommand["subcommands"]:
            If not sub_command["hidden"]:
                Set help_text to help_text plus "  " plus sub_command["name"] plus " - " plus sub_command["help"] plus "\n"
        
        Set help_text to help_text plus "\n"
    
    Note: Add aliases section
    If length of subcommand["aliases"] is greater than 0:
        Set help_text to help_text plus "Aliases: " plus subcommand["aliases"] plus "\n\n"
    
    Return help_text

Note: Command Line Completion
Process called "generate_completions" that takes registry as SubcommandRegistry and current_args as List[String] returns List[String]:
    Let completions be list containing
    
    Note: If no arguments provided, return all top-level commands
    If length of current_args is equal to 0:
        For each command_name in registry["commands"]:
            Let command be registry["commands"][command_name]
            If not command["hidden"]:
                Add command_name to completions
        
        Note: Add aliases
        For each alias_name in registry["aliases"]:
            Let alias be registry["aliases"][alias_name]
            If not alias["hidden"]:
                Add alias_name to completions
        
        Return completions
    
    Note: Find the command being completed
    Let command_path be list containing
    Let current_registry be registry
    Let i be 0
    
    While i is less than length of current_args:
        Let arg be current_args at index i
        Let found_command be find_subcommand_by_name with registry as current_registry and name as arg
        
        If found_command is not None:
            Add arg to command_path
            Note: Handle nested command registries if command has subcommands
            If found_command contains "subcommands" and found_command["subcommands"] is not None:
                Set current_registry to found_command["subcommands"]
            Set i to i plus 1
        Otherwise:
            Break loop
    
    Note: If we're at the end of known commands, complete arguments or subcommands
    If i is equal to length of current_args minus 1:
        Let last_arg be current_args at index length of current_args minus 1
        
        Note: Complete partial command names
        For each command_name in registry["commands"]:
            If command_name starts with last_arg:
                Add command_name to completions
        
        Note: Complete partial aliases
        For each alias_name in registry["aliases"]:
            If alias_name starts with last_arg:
                Add alias_name to completions
    
    Return completions

Note: Dynamic Command Loading
Process called "load_command_plugin" that takes registry as SubcommandRegistry and plugin_path as String returns SubcommandRegistry:
    Try:
        Let plugin_module be import_module with path as plugin_path
        
        Note: Look for standard plugin interface
        If "register_commands" is in plugin_module:
            plugin_module["register_commands"] with registry as registry
        
        Note: Look for command definitions
        If "commands" is in plugin_module:
            Let commands be plugin_module["commands"]
            For each command in commands:
                Set registry to register_subcommand with registry as registry and subcommand as command
        
        Note: Look for command groups
        If "groups" is in plugin_module:
            Let groups be plugin_module["groups"]
            For each group in groups:
                Set registry to register_command_group with registry as registry and group as group
        
        Note: Look for middleware
        If "middleware" is in plugin_module:
            Let middleware_list be plugin_module["middleware"]
            For each middleware in middleware_list:
                Set registry to register_middleware with registry as registry and middleware as middleware
        
        Set registry["plugins"][plugin_path] to plugin_module
        
    Catch error:
        Display "Failed to load command plugin: " plus plugin_path plus " - " plus error
    
    Return registry

Process called "discover_command_plugins" that takes registry as SubcommandRegistry and plugin_directory as String returns SubcommandRegistry:
    Try:
        Let plugin_files be list_directory_files with path as plugin_directory and pattern as "*.runa"
        
        For each plugin_file in plugin_files:
            Let plugin_path be join_paths with parts as list containing plugin_directory, plugin_file
            Set registry to load_command_plugin with registry as registry and plugin_path as plugin_path
        
    Catch error:
        Display "Failed to discover plugins in directory: " plus plugin_directory plus " - " plus error
    
    Return registry

Note: Advanced Command Features
Process called "create_command_middleware" that takes name as String returns CommandMiddleware:
    Return CommandMiddleware with:
        name as name
        before_execute as None
        after_execute as None
        on_error as None
        priority as 0

Process called "set_middleware_before" that takes middleware as CommandMiddleware and handler as Process returns CommandMiddleware:
    Set middleware["before_execute"] to handler
    Return middleware

Process called "set_middleware_after" that takes middleware as CommandMiddleware and handler as Process returns CommandMiddleware:
    Set middleware["after_execute"] to handler
    Return middleware

Process called "set_middleware_error" that takes middleware as CommandMiddleware and handler as Process returns CommandMiddleware:
    Set middleware["on_error"] to handler
    Return middleware

Process called "set_middleware_priority" that takes middleware as CommandMiddleware and priority as Integer returns CommandMiddleware:
    Set middleware["priority"] to priority
    Return middleware

Note: Common Command Patterns
Process called "create_help_command" that takes registry as SubcommandRegistry returns Subcommand:
    Let help_handler be Process called "handle_help_command" that takes args as Dictionary[String, Any] returns Boolean:
        If "command" is in args and args["command"] is not None:
            Let target_command be find_subcommand_by_name with registry as registry and name as args["command"]
            If target_command is not None:
                Display generate_command_help with subcommand as target_command
            Otherwise:
                Display "Unknown command: " plus args["command"]
                Return false
        Otherwise:
            Display generate_subcommand_help with registry as registry and parent_command as None
        Return true
    
    Let help_argument be argparse.create_string_argument with name as "command" and help as "Command to get help for"
    Set help_argument["required"] to false
    Set help_argument["positional"] to true
    
    Return Subcommand with:
        name as "help"
        help as "Show help information"
        arguments as list containing help_argument
        handler as help_handler
        subcommands as list containing
        parent as None
        hidden as false
        group as None
        aliases as list containing "h", "?"
        middleware as list containing
        metadata as dictionary containing

Process called "create_version_command" that takes version as String returns Subcommand:
    Let version_handler be Process called "handle_version_command" that takes args as Dictionary[String, Any] returns Boolean:
        Display version
        Return true
    
    Return Subcommand with:
        name as "version"
        help as "Show version information"
        arguments as list containing
        handler as version_handler
        subcommands as list containing
        parent as None
        hidden as false
        group as None
        aliases as list containing "v", "--version"
        middleware as list containing
        metadata as dictionary containing