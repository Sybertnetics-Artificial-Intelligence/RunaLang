Note:
Runa Standard Library: K-Means Clustering

Implementation of K-Means clustering algorithm with various initialization
methods and convergence criteria for unsupervised learning.
:End Note

Import "../../algorithms" as Algorithms
Import "../../math/core" as Math
Import "../../../../collections" as Collections

Type called "KMeans":
    n_clusters as Integer
    init as String
    max_iter as Integer
    tolerance as Float
    centroids as Algorithms.Matrix
    labels as Algorithms.Vector
    inertia as Float
    fitted as Boolean

Process called "create_kmeans" that takes n_clusters as Integer returns KMeans:
    Return KMeans with:
        n_clusters as n_clusters
        init as "k-means++"
        max_iter as 300
        tolerance as 0.0001
        centroids as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
        labels as Algorithms.Vector with size as 0 and data as list
        inertia as 0.0
        fitted as false

Process called "fit_kmeans" that takes model as KMeans and X as Algorithms.Matrix returns KMeans:
    Note: Initialize centroids
    initialize_centroids with model as model and X as X
    
    Note: Iterate until convergence
    For iteration from 0 to model.max_iter - 1:
        Note: Assign points to nearest centroids
        Let new_labels be assign_points_to_centroids with X as X and centroids as model.centroids
        
        Note: Update centroids
        Let new_centroids be update_centroids with X as X and labels as new_labels and n_clusters as model.n_clusters
        
        Note: Check convergence
        If has_converged with old_centroids as model.centroids and new_centroids as new_centroids and tolerance as model.tolerance:
            Break
        
        Set model.centroids to new_centroids
        Set model.labels to new_labels
    
    Note: Calculate final inertia
    Set model.inertia to calculate_inertia with X as X and centroids as model.centroids and labels as model.labels
    Set model.fitted to true
    Return model

Process called "predict_kmeans" that takes model as KMeans and X as Algorithms.Matrix returns Algorithms.Vector:
    Return assign_points_to_centroids with X as X and centroids as model.centroids

Process called "initialize_centroids" that takes model as KMeans and X as Algorithms.Matrix:
    Match model.init:
        When "random":
            Set model.centroids to random_centroids with X as X and k as model.n_clusters
        When "k-means++":
            Set model.centroids to kmeans_plus_plus_init with X as X and k as model.n_clusters
        Otherwise:
            Set model.centroids to random_centroids with X as X and k as model.n_clusters

Process called "random_centroids" that takes X as Algorithms.Matrix and k as Integer returns Algorithms.Matrix:
    Note: Initialize centroids randomly from data points
    Let centroids_data be list
    For i from 0 to k - 1:
        Let random_index be Math.random_int with min_val as 0 and max_val as X.rows - 1
        Add X.data[random_index] to centroids_data
    
    Return Algorithms.Matrix with:
        rows as k
        cols as X.cols
        data as centroids_data

Process called "kmeans_plus_plus_init" that takes X as Algorithms.Matrix and k as Integer returns Algorithms.Matrix:
    Note: K-means++ initialization for better initial centroids
    Let centroids_data be list
    
    Note: Choose first centroid randomly
    Let first_index be Math.random_int with min_val as 0 and max_val as X.rows - 1
    Add X.data[first_index] to centroids_data
    
    Note: Choose remaining centroids based on distance
    For i from 1 to k - 1:
        Let distances be calculate_min_distances with X as X and centroids as centroids_data
        Let next_index be weighted_random_choice with weights as distances
        Add X.data[next_index] to centroids_data
    
    Return Algorithms.Matrix with:
        rows as k
        cols as X.cols
        data as centroids_data

Process called "assign_points_to_centroids" that takes X as Algorithms.Matrix and centroids as Algorithms.Matrix returns Algorithms.Vector:
    Let labels be list
    
    For i from 0 to X.rows - 1:
        Let min_distance be Math.infinity
        Let closest_centroid be 0
        
        For j from 0 to centroids.rows - 1:
            Let distance be euclidean_distance with x1 as X.data[i] and x2 as centroids.data[j]
            If distance is less than min_distance:
                Set min_distance to distance
                Set closest_centroid to j
        
        Add Float.from with value as closest_centroid to labels
    
    Return Algorithms.Vector with:
        size as X.rows
        data as labels

Process called "update_centroids" that takes X as Algorithms.Matrix and labels as Algorithms.Vector and n_clusters as Integer returns Algorithms.Matrix:
    Let new_centroids_data be list
    
    For k from 0 to n_clusters - 1:
        Let cluster_points be get_cluster_points with X as X and labels as labels and cluster_id as k
        If Collections.List.length with lst as cluster_points is greater than 0:
            Add calculate_centroid with points as cluster_points to new_centroids_data
        Otherwise:
            Note: Keep old centroid if no points assigned
            Add list to new_centroids_data
    
    Return Algorithms.Matrix with:
        rows as n_clusters
        cols as X.cols
        data as new_centroids_data

Process called "calculate_inertia" that takes X as Algorithms.Matrix and centroids as Algorithms.Matrix and labels as Algorithms.Vector returns Float:
    Let total_inertia be 0.0
    
    For i from 0 to X.rows - 1:
        Let cluster_id be Integer.from with value as labels.data[i]
        Let distance be euclidean_distance with x1 as X.data[i] and x2 as centroids.data[cluster_id]
        Set total_inertia to total_inertia + distance multiplied by distance
    
    Return total_inertia

Process called "has_converged" that takes old_centroids as Algorithms.Matrix and new_centroids as Algorithms.Matrix and tolerance as Float returns Boolean:
    Let max_change be 0.0
    
    For i from 0 to old_centroids.rows - 1:
        Let distance be euclidean_distance with x1 as old_centroids.data[i] and x2 as new_centroids.data[i]
        If distance is greater than max_change:
            Set max_change to distance
    
    Return max_change is less than tolerance

Note: Utility functions
Process called "euclidean_distance" that takes x1 as List[Float] and x2 as List[Float] returns Float:
    Let sum_squares be 0.0
    For i from 0 to Collections.List.length with lst as x1 - 1:
        Let diff be x1[i] - x2[i]
        Set sum_squares to sum_squares + diff multiplied by diff
    Return Math.sqrt with x as sum_squares

Process called "calculate_min_distances" that takes X as Algorithms.Matrix and centroids as List[List[Float]] returns List[Float]:
    Let distances be list
    For i from 0 to X.rows - 1:
        Let min_distance be Math.infinity
        For each centroid in centroids:
            Let distance be euclidean_distance with x1 as X.data[i] and x2 as centroid
            If distance is less than min_distance:
                Set min_distance to distance
        Add min_distance to distances
    Return distances

Process called "weighted_random_choice" that takes weights as List[Float] returns Integer:
    Let total_weight be 0.0
    For each weight in weights:
        Set total_weight to total_weight + weight
    
    Let random_value be Math.random() multiplied by total_weight
    Let cumulative_weight be 0.0
    
    For i from 0 to Collections.List.length with lst as weights - 1:
        Set cumulative_weight to cumulative_weight + weights[i]
        If random_value is less than or equal to cumulative_weight:
            Return i
    
    Return Collections.List.length with lst as weights - 1

Process called "get_cluster_points" that takes X as Algorithms.Matrix and labels as Algorithms.Vector and cluster_id as Integer returns List[List[Float]]:
    Let cluster_points be list
    For i from 0 to X.rows - 1:
        If Integer.from with value as labels.data[i] is equal to cluster_id:
            Add X.data[i] to cluster_points
    Return cluster_points

Process called "calculate_centroid" that takes points as List[List[Float]] returns List[Float]:
    Let n_points be Collections.List.length with lst as points
    Let n_features be Collections.List.length with lst as points[0]
    Let centroid be list
    
    For j from 0 to n_features - 1:
        Let sum be 0.0
        For i from 0 to n_points - 1:
            Set sum to sum + points[i][j]
        Add sum divided by Float.from with value as n_points to centroid
    
    Return centroid