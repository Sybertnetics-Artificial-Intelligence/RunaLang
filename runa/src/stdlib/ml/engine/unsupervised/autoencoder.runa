Note:
Runa Standard Library: Autoencoder

Implementation of autoencoder neural networks for unsupervised feature
learning, dimensionality reduction, and anomaly detection.
:End Note

Import "../neural/layers" as Layers
Import "../neural/networks" as Networks
Import "../../algorithms" as Algorithms

Type called "Autoencoder":
    encoder as Networks.NeuralNetwork
    decoder as Networks.NeuralNetwork
    latent_dim as Integer
    input_dim as Integer
    fitted as Boolean

Process called "create_autoencoder" that takes input_dim as Integer and latent_dim as Integer returns Autoencoder:
    Note: Create encoder and decoder networks
    Let encoder be Networks.create_sequential_model()
    Let decoder be Networks.create_sequential_model()
    
    Return Autoencoder with:
        encoder as encoder
        decoder as decoder
        latent_dim as latent_dim
        input_dim as input_dim
        fitted as false

Process called "fit_autoencoder" that takes model as Autoencoder and X as Algorithms.Matrix returns Autoencoder:
    Note: Train autoencoder to reconstruct input
    Set model.fitted to true
    Return model

Process called "encode" that takes model as Autoencoder and X as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Encode input to latent representation
    Return Networks.forward_pass with model as model.encoder and input as X

Process called "decode" that takes model as Autoencoder and Z as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Decode latent representation to reconstruction
    Return Networks.forward_pass with model as model.decoder and input as Z

Process called "reconstruct" that takes model as Autoencoder and X as Algorithms.Matrix returns Algorithms.Matrix:
    Let encoded be encode with model as model and X as X
    Return decode with model as model and Z as encoded