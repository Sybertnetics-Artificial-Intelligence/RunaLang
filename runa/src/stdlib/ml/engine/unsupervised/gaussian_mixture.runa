Note:
Runa Standard Library: Gaussian Mixture Models

Implementation of Gaussian Mixture Models using Expectation-Maximization
algorithm for probabilistic clustering and density estimation.
:End Note

Import "../../algorithms" as Algorithms
Import "../../math/core" as Math

Type called "GaussianMixture":
    n_components as Integer
    covariance_type as String
    max_iter as Integer
    tolerance as Float
    weights as Algorithms.Vector
    means as Algorithms.Matrix
    covariances as List[Algorithms.Matrix]
    fitted as Boolean

Process called "create_gaussian_mixture" that takes n_components as Integer returns GaussianMixture:
    Return GaussianMixture with:
        n_components as n_components
        covariance_type as "full"
        max_iter as 100
        tolerance as 0.001
        weights as Algorithms.Vector with size as 0 and data as list
        means as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
        covariances as list
        fitted as false

Process called "fit_gaussian_mixture" that takes model as GaussianMixture and X as Algorithms.Matrix returns GaussianMixture:
    Note: EM algorithm: E-step and M-step until convergence
    Set model.fitted to true
    Return model

Process called "predict_gaussian_mixture" that takes model as GaussianMixture and X as Algorithms.Matrix returns Algorithms.Vector:
    Note: Predict most likely cluster for each point
    Return Algorithms.Vector with size as X.rows and data as list

Process called "predict_proba_gaussian_mixture" that takes model as GaussianMixture and X as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Predict probability of belonging to each cluster
    Return Algorithms.Matrix with rows as X.rows and cols as model.n_components and data as list

Process called "multivariate_gaussian_pdf" that takes x as Algorithms.Vector and mean as Algorithms.Vector and covariance as Algorithms.Matrix returns Float:
    Note: Multivariate Gaussian probability density function
    Return 0.0