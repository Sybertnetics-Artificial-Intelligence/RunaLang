Note:
Runa Standard Library: Hierarchical Clustering

Implementation of hierarchical clustering algorithms including agglomerative
and divisive clustering with various linkage criteria.
:End Note

Import "../../algorithms" as Algorithms
Import "../../math/core" as Math

Type called "AgglomerativeClustering":
    n_clusters as Integer
    linkage as String
    distance_matrix as Algorithms.Matrix
    labels as Algorithms.Vector
    fitted as Boolean

Process called "create_agglomerative_clustering" that takes n_clusters as Integer and linkage as String returns AgglomerativeClustering:
    Return AgglomerativeClustering with:
        n_clusters as n_clusters
        linkage as linkage
        distance_matrix as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
        labels as Algorithms.Vector with size as 0 and data as list
        fitted as false

Process called "fit_agglomerative" that takes model as AgglomerativeClustering and X as Algorithms.Matrix returns AgglomerativeClustering:
    Note: Build dendrogram and cut at specified number of clusters
    Set model.fitted to true
    Return model

Process called "single_linkage_distance" that takes cluster1 as List[Integer] and cluster2 as List[Integer] and distance_matrix as Algorithms.Matrix returns Float:
    Note: Minimum distance between clusters
    Return 0.0

Process called "complete_linkage_distance" that takes cluster1 as List[Integer] and cluster2 as List[Integer] and distance_matrix as Algorithms.Matrix returns Float:
    Note: Maximum distance between clusters
    Return 0.0

Process called "average_linkage_distance" that takes cluster1 as List[Integer] and cluster2 as List[Integer] and distance_matrix as Algorithms.Matrix returns Float:
    Note: Average distance between clusters
    Return 0.0