Note:
Runa Standard Library: Neural Network Optimizers

Implementation of various optimization algorithms for training neural networks
including SGD, Adam, RMSprop, AdaGrad, and more.
:End Note

Import "../../math/core" as Math
Import "../../algorithms" as Algorithms
Import "../../../../collections" as Collections

Note: Base optimizer type
Type called "Optimizer":
    learning_rate as Float
    iteration as Integer
    name as String

Note: Stochastic Gradient Descent (SGD)
Type called "SGDOptimizer":
    base as Optimizer
    momentum as Float
    nesterov as Boolean
    velocity as Dictionary[String, Algorithms.Matrix]

Process called "create_sgd" that takes learning_rate as Float and momentum as Float returns SGDOptimizer:
    Return SGDOptimizer with:
        base as Optimizer with:
            learning_rate as learning_rate
            iteration as 0
            name as "sgd"
        momentum as momentum
        nesterov as false
        velocity as dictionary

Process called "update_sgd" that takes optimizer as SGDOptimizer and params as Dictionary[String, Algorithms.Matrix] and gradients as Dictionary[String, Algorithms.Matrix] returns Dictionary[String, Algorithms.Matrix]:
    Let updated_params be dictionary
    
    For each param_name and param_value in params:
        Let grad be gradients[param_name]
        
        Note: Initialize velocity if needed
        If param_name not in optimizer.velocity:
            Set optimizer.velocity[param_name] to create_zero_matrix with shape as param_value.shape
        
        Let v be optimizer.velocity[param_name]
        
        Note: Update velocity
        Set v to scalar_multiply with scalar as optimizer.momentum and matrix as v
        Set v to matrix_subtract with a as v and b as scalar_multiply with scalar as optimizer.base.learning_rate and matrix as grad
        Set optimizer.velocity[param_name] to v
        
        Note: Update parameters
        If optimizer.nesterov:
            Let effective_grad be matrix_subtract with a as grad and b as scalar_multiply with scalar as optimizer.momentum and matrix as v
            Set updated_params[param_name] to matrix_subtract with a as param_value and b as scalar_multiply with scalar as optimizer.base.learning_rate and matrix as effective_grad
        Otherwise:
            Set updated_params[param_name] to matrix_add with a as param_value and b as v
    
    Set optimizer.base.iteration to optimizer.base.iteration + 1
    Return updated_params

Note: Adam (Adaptive Moment Estimation)
Type called "AdamOptimizer":
    base as Optimizer
    beta1 as Float
    beta2 as Float
    epsilon as Float
    m as Dictionary[String, Algorithms.Matrix]
    v as Dictionary[String, Algorithms.Matrix]

Process called "create_adam" that takes learning_rate as Float returns AdamOptimizer:
    Return AdamOptimizer with:
        base as Optimizer with:
            learning_rate as learning_rate
            iteration as 0
            name as "adam"
        beta1 as 0.9
        beta2 as 0.999
        epsilon as 0.00000001
        m as dictionary
        v as dictionary

Process called "update_adam" that takes optimizer as AdamOptimizer and params as Dictionary[String, Algorithms.Matrix] and gradients as Dictionary[String, Algorithms.Matrix] returns Dictionary[String, Algorithms.Matrix]:
    Let updated_params be dictionary
    Set optimizer.base.iteration to optimizer.base.iteration + 1
    Let t be Float.from with value as optimizer.base.iteration
    
    For each param_name and param_value in params:
        Let grad be gradients[param_name]
        
        Note: Initialize moments if needed
        If param_name not in optimizer.m:
            Set optimizer.m[param_name] to create_zero_matrix with shape as param_value.shape
            Set optimizer.v[param_name] to create_zero_matrix with shape as param_value.shape
        
        Let m be optimizer.m[param_name]
        Let v be optimizer.v[param_name]
        
        Note: Update biased first moment estimate
        Set m to matrix_add with a as scalar_multiply with scalar as optimizer.beta1 and matrix as m and b as scalar_multiply with scalar as 1.0 - optimizer.beta1 and matrix as grad
        
        Note: Update biased second raw moment estimate
        Set v to matrix_add with a as scalar_multiply with scalar as optimizer.beta2 and matrix as v and b as scalar_multiply with scalar as 1.0 - optimizer.beta2 and matrix as element_wise_square with matrix as grad
        
        Note: Compute bias-corrected first moment estimate
        Let m_hat be scalar_multiply with scalar as 1.0 divided by (1.0 - Math.pow with base as optimizer.beta1 and exponent as t) and matrix as m
        
        Note: Compute bias-corrected second raw moment estimate
        Let v_hat be scalar_multiply with scalar as 1.0 divided by (1.0 - Math.pow with base as optimizer.beta2 and exponent as t) and matrix as v
        
        Note: Update parameters
        Let update be element_wise_divide with a as scalar_multiply with scalar as optimizer.base.learning_rate and matrix as m_hat and b as matrix_add_scalar with matrix as element_wise_sqrt with matrix as v_hat and scalar as optimizer.epsilon
        Set updated_params[param_name] to matrix_subtract with a as param_value and b as update
        
        Note: Store updated moments
        Set optimizer.m[param_name] to m
        Set optimizer.v[param_name] to v
    
    Return updated_params

Note: RMSprop
Type called "RMSpropOptimizer":
    base as Optimizer
    decay_rate as Float
    epsilon as Float
    momentum as Float
    cache as Dictionary[String, Algorithms.Matrix]
    velocity as Dictionary[String, Algorithms.Matrix]

Process called "create_rmsprop" that takes learning_rate as Float returns RMSpropOptimizer:
    Return RMSpropOptimizer with:
        base as Optimizer with:
            learning_rate as learning_rate
            iteration as 0
            name as "rmsprop"
        decay_rate as 0.9
        epsilon as 0.00000001
        momentum as 0.0
        cache as dictionary
        velocity as dictionary

Process called "update_rmsprop" that takes optimizer as RMSpropOptimizer and params as Dictionary[String, Algorithms.Matrix] and gradients as Dictionary[String, Algorithms.Matrix] returns Dictionary[String, Algorithms.Matrix]:
    Let updated_params be dictionary
    
    For each param_name and param_value in params:
        Let grad be gradients[param_name]
        
        Note: Initialize cache if needed
        If param_name not in optimizer.cache:
            Set optimizer.cache[param_name] to create_zero_matrix with shape as param_value.shape
            If optimizer.momentum is greater than 0.0:
                Set optimizer.velocity[param_name] to create_zero_matrix with shape as param_value.shape
        
        Let cache be optimizer.cache[param_name]
        
        Note: Update cache (moving average of squared gradients)
        Set cache to matrix_add with a as scalar_multiply with scalar as optimizer.decay_rate and matrix as cache and b as scalar_multiply with scalar as 1.0 - optimizer.decay_rate and matrix as element_wise_square with matrix as grad
        Set optimizer.cache[param_name] to cache
        
        Note: Compute update
        Let update be element_wise_divide with a as scalar_multiply with scalar as optimizer.base.learning_rate and matrix as grad and b as matrix_add_scalar with matrix as element_wise_sqrt with matrix as cache and scalar as optimizer.epsilon
        
        Note: Apply momentum if enabled
        If optimizer.momentum is greater than 0.0:
            Let v be optimizer.velocity[param_name]
            Set v to matrix_add with a as scalar_multiply with scalar as optimizer.momentum and matrix as v and b as update
            Set optimizer.velocity[param_name] to v
            Set updated_params[param_name] to matrix_subtract with a as param_value and b as v
        Otherwise:
            Set updated_params[param_name] to matrix_subtract with a as param_value and b as update
    
    Set optimizer.base.iteration to optimizer.base.iteration + 1
    Return updated_params

Note: AdaGrad
Type called "AdaGradOptimizer":
    base as Optimizer
    epsilon as Float
    accumulated_grad as Dictionary[String, Algorithms.Matrix]

Process called "create_adagrad" that takes learning_rate as Float returns AdaGradOptimizer:
    Return AdaGradOptimizer with:
        base as Optimizer with:
            learning_rate as learning_rate
            iteration as 0
            name as "adagrad"
        epsilon as 0.00000001
        accumulated_grad as dictionary

Process called "update_adagrad" that takes optimizer as AdaGradOptimizer and params as Dictionary[String, Algorithms.Matrix] and gradients as Dictionary[String, Algorithms.Matrix] returns Dictionary[String, Algorithms.Matrix]:
    Let updated_params be dictionary
    
    For each param_name and param_value in params:
        Let grad be gradients[param_name]
        
        Note: Initialize accumulated gradient if needed
        If param_name not in optimizer.accumulated_grad:
            Set optimizer.accumulated_grad[param_name] to create_zero_matrix with shape as param_value.shape
        
        Let acc_grad be optimizer.accumulated_grad[param_name]
        
        Note: Accumulate squared gradients
        Set acc_grad to matrix_add with a as acc_grad and b as element_wise_square with matrix as grad
        Set optimizer.accumulated_grad[param_name] to acc_grad
        
        Note: Update parameters
        Let update be element_wise_divide with a as scalar_multiply with scalar as optimizer.base.learning_rate and matrix as grad and b as matrix_add_scalar with matrix as element_wise_sqrt with matrix as acc_grad and scalar as optimizer.epsilon
        Set updated_params[param_name] to matrix_subtract with a as param_value and b as update
    
    Set optimizer.base.iteration to optimizer.base.iteration + 1
    Return updated_params

Note: AdaDelta
Type called "AdaDeltaOptimizer":
    base as Optimizer
    rho as Float
    epsilon as Float
    accumulated_grad as Dictionary[String, Algorithms.Matrix]
    accumulated_update as Dictionary[String, Algorithms.Matrix]

Process called "create_adadelta" that takes rho as Float returns AdaDeltaOptimizer:
    Return AdaDeltaOptimizer with:
        base as Optimizer with:
            learning_rate as 1.0
            iteration as 0
            name as "adadelta"
        rho as rho
        epsilon as 0.00000001
        accumulated_grad as dictionary
        accumulated_update as dictionary

Process called "update_adadelta" that takes optimizer as AdaDeltaOptimizer and params as Dictionary[String, Algorithms.Matrix] and gradients as Dictionary[String, Algorithms.Matrix] returns Dictionary[String, Algorithms.Matrix]:
    Let updated_params be dictionary
    
    For each param_name and param_value in params:
        Let grad be gradients[param_name]
        
        Note: Initialize accumulators if needed
        If param_name not in optimizer.accumulated_grad:
            Set optimizer.accumulated_grad[param_name] to create_zero_matrix with shape as param_value.shape
            Set optimizer.accumulated_update[param_name] to create_zero_matrix with shape as param_value.shape
        
        Let acc_grad be optimizer.accumulated_grad[param_name]
        Let acc_update be optimizer.accumulated_update[param_name]
        
        Note: Accumulate gradient
        Set acc_grad to matrix_add with a as scalar_multiply with scalar as optimizer.rho and matrix as acc_grad and b as scalar_multiply with scalar as 1.0 - optimizer.rho and matrix as element_wise_square with matrix as grad
        
        Note: Compute update
        Let update be element_wise_multiply with a as element_wise_divide with a as element_wise_sqrt with matrix as matrix_add_scalar with matrix as acc_update and scalar as optimizer.epsilon and b as element_wise_sqrt with matrix as matrix_add_scalar with matrix as acc_grad and scalar as optimizer.epsilon and b as grad
        
        Note: Accumulate updates
        Set acc_update to matrix_add with a as scalar_multiply with scalar as optimizer.rho and matrix as acc_update and b as scalar_multiply with scalar as 1.0 - optimizer.rho and matrix as element_wise_square with matrix as update
        
        Note: Apply update
        Set updated_params[param_name] to matrix_subtract with a as param_value and b as update
        
        Note: Store accumulators
        Set optimizer.accumulated_grad[param_name] to acc_grad
        Set optimizer.accumulated_update[param_name] to acc_update
    
    Set optimizer.base.iteration to optimizer.base.iteration + 1
    Return updated_params

Note: Nadam (Nesterov Adam)
Type called "NadamOptimizer":
    base as Optimizer
    beta1 as Float
    beta2 as Float
    epsilon as Float
    m as Dictionary[String, Algorithms.Matrix]
    v as Dictionary[String, Algorithms.Matrix]

Process called "create_nadam" that takes learning_rate as Float returns NadamOptimizer:
    Return NadamOptimizer with:
        base as Optimizer with:
            learning_rate as learning_rate
            iteration as 0
            name as "nadam"
        beta1 as 0.9
        beta2 as 0.999
        epsilon as 0.00000001
        m as dictionary
        v as dictionary

Process called "update_nadam" that takes optimizer as NadamOptimizer and params as Dictionary[String, Algorithms.Matrix] and gradients as Dictionary[String, Algorithms.Matrix] returns Dictionary[String, Algorithms.Matrix]:
    Note: Nadam combines Adam with Nesterov momentum
    Let updated_params be dictionary
    Set optimizer.base.iteration to optimizer.base.iteration + 1
    Let t be Float.from with value as optimizer.base.iteration
    
    For each param_name and param_value in params:
        Let grad be gradients[param_name]
        
        Note: Initialize moments if needed
        If param_name not in optimizer.m:
            Set optimizer.m[param_name] to create_zero_matrix with shape as param_value.shape
            Set optimizer.v[param_name] to create_zero_matrix with shape as param_value.shape
        
        Let m be optimizer.m[param_name]
        Let v be optimizer.v[param_name]
        
        Note: Update moments
        Set m to matrix_add with a as scalar_multiply with scalar as optimizer.beta1 and matrix as m and b as scalar_multiply with scalar as 1.0 - optimizer.beta1 and matrix as grad
        Set v to matrix_add with a as scalar_multiply with scalar as optimizer.beta2 and matrix as v and b as scalar_multiply with scalar as 1.0 - optimizer.beta2 and matrix as element_wise_square with matrix as grad
        
        Note: Bias correction
        Let m_hat be scalar_multiply with scalar as 1.0 divided by (1.0 - Math.pow with base as optimizer.beta1 and exponent as t) and matrix as m
        Let v_hat be scalar_multiply with scalar as 1.0 divided by (1.0 - Math.pow with base as optimizer.beta2 and exponent as t) and matrix as v
        
        Note: Nesterov momentum
        Let m_bar be matrix_add with a as scalar_multiply with scalar as optimizer.beta1 and matrix as m_hat and b as scalar_multiply with scalar as (1.0 - optimizer.beta1) divided by (1.0 - Math.pow with base as optimizer.beta1 and exponent as t) and matrix as grad
        
        Note: Update parameters
        Let update be element_wise_divide with a as scalar_multiply with scalar as optimizer.base.learning_rate and matrix as m_bar and b as matrix_add_scalar with matrix as element_wise_sqrt with matrix as v_hat and scalar as optimizer.epsilon
        Set updated_params[param_name] to matrix_subtract with a as param_value and b as update
        
        Note: Store updated moments
        Set optimizer.m[param_name] to m
        Set optimizer.v[param_name] to v
    
    Return updated_params

Note: Utility functions
Process called "create_zero_matrix" that takes shape as List[Integer] returns Algorithms.Matrix:
    Let data be list
    For i from 0 to shape[0] - 1:
        Let row be list
        For j from 0 to shape[1] - 1:
            Add 0.0 to row
        Add row to data
    Return Algorithms.Matrix with:
        rows as shape[0]
        cols as shape[1]
        data as data

Process called "scalar_multiply" that takes scalar as Float and matrix as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would multiply each element by scalar
    Return matrix

Process called "matrix_add" that takes a as Algorithms.Matrix and b as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would add matrices element-wise
    Return a

Process called "matrix_subtract" that takes a as Algorithms.Matrix and b as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would subtract matrices element-wise
    Return a

Process called "element_wise_square" that takes matrix as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would square each element
    Return matrix

Process called "element_wise_sqrt" that takes matrix as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would take square root of each element
    Return matrix

Process called "element_wise_divide" that takes a as Algorithms.Matrix and b as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would divide element-wise
    Return a

Process called "element_wise_multiply" that takes a as Algorithms.Matrix and b as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would multiply element-wise
    Return a

Process called "matrix_add_scalar" that takes matrix as Algorithms.Matrix and scalar as Float returns Algorithms.Matrix:
    Note: Would add scalar to each element
    Return matrix