Note:
Runa Standard Library: Backpropagation Implementation

Core backpropagation algorithm for training neural networks including
automatic differentiation and gradient computation.
:End Note

Import "layers" as Layers
Import "activations" as Activations
Import "../../algorithms" as Algorithms
Import "../../math/core" as Math
Import "../../../../collections" as Collections

Note: Computation graph node for automatic differentiation
Type called "ComputationNode":
    value as Algorithms.Matrix
    gradient as Algorithms.Matrix
    operation as String
    inputs as List[ComputationNode]
    requires_grad as Boolean
    name as String

Process called "create_computation_node" that takes value as Algorithms.Matrix and requires_grad as Boolean returns ComputationNode:
    Return ComputationNode with:
        value as value
        gradient as create_zero_matrix_like with template as value
        operation as "leaf"
        inputs as list
        requires_grad as requires_grad
        name as ""

Note: Forward pass with gradient tape
Type called "GradientTape":
    nodes as List[ComputationNode]
    watching as Dictionary[String, ComputationNode]

Process called "create_gradient_tape" returns GradientTape:
    Return GradientTape with:
        nodes as list
        watching as dictionary

Process called "watch_variable" that takes tape as GradientTape and name as String and variable as ComputationNode:
    Set tape.watching[name] to variable
    Add variable to tape.nodes

Process called "record_operation" that takes tape as GradientTape and output as ComputationNode and operation as String and inputs as List[ComputationNode]:
    Set output.operation to operation
    Set output.inputs to inputs
    Add output to tape.nodes

Note: Backpropagation through layers
Process called "backpropagate_dense_layer" that takes layer as Layers.DenseLayer and input as Algorithms.Matrix and output_gradient as Algorithms.Matrix returns Dictionary[String, Algorithms.Matrix]:
    Note: Compute gradients for dense layer
    
    Note: Gradient w.r.t weights: dL/dW = input^T @ output_gradient
    Let weight_gradient be matrix_multiply_transpose with a as input and b as output_gradient
    
    Note: Gradient w.r.t bias: dL/db = sum(output_gradient, axis=0)
    Let bias_gradient be sum_along_axis with matrix as output_gradient and axis as 0
    
    Note: Gradient w.r.t input: dL/dx = output_gradient @ W^T
    Let input_gradient be matrix_multiply with a as output_gradient and b as transpose with matrix as layer.base.weights
    
    Note: Apply activation gradient
    Let activation_gradient be compute_activation_gradient with activation as layer.base.activation and input as input
    Set input_gradient to element_wise_multiply with a as input_gradient and b as activation_gradient
    
    Return dictionary with:
        "weight_gradient" as weight_gradient
        "bias_gradient" as bias_gradient
        "input_gradient" as input_gradient

Process called "backpropagate_conv2d_layer" that takes layer as Layers.Conv2DLayer and input as Algorithms.Matrix and output_gradient as Algorithms.Matrix returns Dictionary[String, Algorithms.Matrix]:
    Note: Compute gradients for convolutional layer
    
    Note: Gradient w.r.t kernels
    Let kernel_gradients be list
    For each kernel in layer.kernels:
        Let kernel_grad be compute_convolution_kernel_gradient with input as input and output_gradient as output_gradient and stride as layer.stride
        Add kernel_grad to kernel_gradients
    
    Note: Gradient w.r.t bias
    Let bias_gradient be sum_all_elements with matrix as output_gradient
    
    Note: Gradient w.r.t input
    Let input_gradient be compute_convolution_input_gradient with kernels as layer.kernels and output_gradient as output_gradient and stride as layer.stride
    
    Return dictionary with:
        "kernel_gradients" as kernel_gradients
        "bias_gradient" as bias_gradient
        "input_gradient" as input_gradient

Process called "backpropagate_lstm_layer" that takes layer as Layers.LSTMLayer and input_sequence as List[Algorithms.Matrix] and output_gradient as Algorithms.Matrix returns Dictionary[String, Algorithms.Matrix]:
    Note: Backpropagation through time for LSTM
    
    Let weight_gradients be dictionary
    Let input_gradients be list
    
    Note: Initialize gate weight gradients
    Set weight_gradients["forget_gate"] to create_zero_matrix_like with template as layer.forget_gate_weights
    Set weight_gradients["input_gate"] to create_zero_matrix_like with template as layer.input_gate_weights
    Set weight_gradients["candidate_gate"] to create_zero_matrix_like with template as layer.candidate_gate_weights
    Set weight_gradients["output_gate"] to create_zero_matrix_like with template as layer.output_gate_weights
    
    Note: Backpropagate through time
    Let next_hidden_gradient be output_gradient
    Let next_cell_gradient be create_zero_matrix_like with template as layer.cell_state
    
    For t from Collections.List.length with lst as input_sequence - 1 to 0 by negative 1:
        Let timestep_gradients be backpropagate_lstm_timestep with layer as layer and input as input_sequence[t] and hidden_gradient as next_hidden_gradient and cell_gradient as next_cell_gradient
        
        Note: Accumulate weight gradients
        accumulate_lstm_weight_gradients with weight_gradients as weight_gradients and timestep_gradients as timestep_gradients
        
        Note: Store input gradient
        Add timestep_gradients["input_gradient"] to input_gradients
        
        Note: Update gradients for next timestep
        Set next_hidden_gradient to timestep_gradients["prev_hidden_gradient"]
        Set next_cell_gradient to timestep_gradients["prev_cell_gradient"]
    
    Return dictionary with:
        "weight_gradients" as weight_gradients
        "input_gradients" as reverse_list with lst as input_gradients

Process called "backpropagate_lstm_timestep" that takes layer as Layers.LSTMLayer and input as Algorithms.Matrix and hidden_gradient as Algorithms.Matrix and cell_gradient as Algorithms.Matrix returns Dictionary[String, Algorithms.Matrix]:
    Note: Backpropagate through one LSTM timestep
    Return dictionary

Note: Batch normalization backpropagation
Process called "backpropagate_batchnorm_layer" that takes layer as Layers.BatchNormLayer and input as Algorithms.Matrix and output_gradient as Algorithms.Matrix returns Dictionary[String, Algorithms.Matrix]:
    Let batch_size be Float.from with value as input.rows
    Let features be input.cols
    
    Note: Gradient w.r.t gamma (scale)
    Let normalized_input be compute_normalized_input with input as input and mean as layer.moving_mean and variance as layer.moving_variance and epsilon as layer.epsilon
    Let gamma_gradient be element_wise_multiply with a as output_gradient and b as normalized_input
    Let gamma_gradient be sum_along_axis with matrix as gamma_gradient and axis as 0
    
    Note: Gradient w.r.t beta (shift)
    Let beta_gradient be sum_along_axis with matrix as output_gradient and axis as 0
    
    Note: Gradient w.r.t input
    Let input_gradient be compute_batchnorm_input_gradient with output_gradient as output_gradient and input as input and gamma as layer.gamma and mean as layer.moving_mean and variance as layer.moving_variance and epsilon as layer.epsilon
    
    Return dictionary with:
        "gamma_gradient" as gamma_gradient
        "beta_gradient" as beta_gradient
        "input_gradient" as input_gradient

Note: Activation function gradients
Process called "compute_activation_gradient" that takes activation as String and input as Algorithms.Matrix returns Algorithms.Matrix:
    Match activation:
        When "relu":
            Return compute_relu_gradient with input as input
        When "sigmoid":
            Return compute_sigmoid_gradient with input as input
        When "tanh":
            Return compute_tanh_gradient with input as input
        When "softmax":
            Return compute_softmax_gradient with input as input
        When "linear":
            Return create_ones_matrix_like with template as input
        Otherwise:
            Return create_ones_matrix_like with template as input

Process called "compute_relu_gradient" that takes input as Algorithms.Matrix returns Algorithms.Matrix:
    Let gradient be list
    For i from 0 to input.rows - 1:
        Let row be list
        For j from 0 to input.cols - 1:
            If input.data[i][j] is greater than 0.0:
                Add 1.0 to row
            Otherwise:
                Add 0.0 to row
        Add row to gradient
    Return Algorithms.Matrix with:
        rows as input.rows
        cols as input.cols
        data as gradient

Process called "compute_sigmoid_gradient" that takes input as Algorithms.Matrix returns Algorithms.Matrix:
    Let gradient be list
    For i from 0 to input.rows - 1:
        Let row be list
        For j from 0 to input.cols - 1:
            Let sig be Activations.sigmoid with x as input.data[i][j]
            Add sig multiplied by (1.0 - sig) to row
        Add row to gradient
    Return Algorithms.Matrix with:
        rows as input.rows
        cols as input.cols
        data as gradient

Process called "compute_tanh_gradient" that takes input as Algorithms.Matrix returns Algorithms.Matrix:
    Let gradient be list
    For i from 0 to input.rows - 1:
        Let row be list
        For j from 0 to input.cols - 1:
            Let tanh_val be Activations.tanh with x as input.data[i][j]
            Add 1.0 - tanh_val multiplied by tanh_val to row
        Add row to gradient
    Return Algorithms.Matrix with:
        rows as input.rows
        cols as input.cols
        data as gradient

Process called "compute_softmax_gradient" that takes input as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Softmax gradient is computed as part of cross-entropy loss
    Return create_ones_matrix_like with template as input

Note: Gradient clipping
Process called "clip_gradients" that takes gradients as Dictionary[String, Algorithms.Matrix] and max_norm as Float returns Dictionary[String, Algorithms.Matrix]:
    Let total_norm be compute_gradient_norm with gradients as gradients
    
    If total_norm is greater than max_norm:
        Let clip_coef be max_norm divided by total_norm
        Let clipped_gradients be dictionary
        For each name and gradient in gradients:
            Set clipped_gradients[name] to scalar_multiply with scalar as clip_coef and matrix as gradient
        Return clipped_gradients
    Otherwise:
        Return gradients

Process called "compute_gradient_norm" that takes gradients as Dictionary[String, Algorithms.Matrix] returns Float:
    Let total_norm be 0.0
    For each name and gradient in gradients:
        Let grad_norm be frobenius_norm with matrix as gradient
        Set total_norm to total_norm + grad_norm multiplied by grad_norm
    Return Math.sqrt with x as total_norm

Note: Utility functions
Process called "create_zero_matrix_like" that takes template as Algorithms.Matrix returns Algorithms.Matrix:
    Let data be list
    For i from 0 to template.rows - 1:
        Let row be list
        For j from 0 to template.cols - 1:
            Add 0.0 to row
        Add row to data
    Return Algorithms.Matrix with:
        rows as template.rows
        cols as template.cols
        data as data

Process called "create_ones_matrix_like" that takes template as Algorithms.Matrix returns Algorithms.Matrix:
    Let data be list
    For i from 0 to template.rows - 1:
        Let row be list
        For j from 0 to template.cols - 1:
            Add 1.0 to row
        Add row to data
    Return Algorithms.Matrix with:
        rows as template.rows
        cols as template.cols
        data as data

Process called "matrix_multiply_transpose" that takes a as Algorithms.Matrix and b as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Compute a^T @ b
    Return Algorithms.matrix_multiply with a as transpose with matrix as a and b as b

Process called "transpose" that takes matrix as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would transpose matrix
    Return matrix

Process called "sum_along_axis" that takes matrix as Algorithms.Matrix and axis as Integer returns Algorithms.Vector:
    Note: Would sum along specified axis
    Return Algorithms.Vector with size as 0 and data as list

Process called "sum_all_elements" that takes matrix as Algorithms.Matrix returns Float:
    Note: Would sum all elements
    Return 0.0

Process called "element_wise_multiply" that takes a as Algorithms.Matrix and b as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would multiply element-wise
    Return a

Process called "scalar_multiply" that takes scalar as Float and matrix as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would multiply by scalar
    Return matrix

Process called "frobenius_norm" that takes matrix as Algorithms.Matrix returns Float:
    Note: Would compute Frobenius norm
    Return 0.0

Process called "reverse_list" that takes lst as List[Any] returns List[Any]:
    Let reversed be list
    For i from Collections.List.length with lst as lst - 1 to 0 by negative 1:
        Add lst[i] to reversed
    Return reversed

Process called "compute_convolution_kernel_gradient" that takes input as Algorithms.Matrix and output_gradient as Algorithms.Matrix and stride as (Integer, Integer) returns Algorithms.Matrix:
    Note: Would compute gradient w.r.t convolution kernel
    Return create_zero_matrix_like with template as input

Process called "compute_convolution_input_gradient" that takes kernels as List[Algorithms.Matrix] and output_gradient as Algorithms.Matrix and stride as (Integer, Integer) returns Algorithms.Matrix:
    Note: Would compute gradient w.r.t convolution input
    Return output_gradient

Process called "accumulate_lstm_weight_gradients" that takes weight_gradients as Dictionary[String, Algorithms.Matrix] and timestep_gradients as Dictionary[String, Algorithms.Matrix]:
    Note: Would accumulate LSTM weight gradients
    Return

Process called "compute_normalized_input" that takes input as Algorithms.Matrix and mean as Algorithms.Vector and variance as Algorithms.Vector and epsilon as Float returns Algorithms.Matrix:
    Note: Would compute normalized input for batch norm
    Return input

Process called "compute_batchnorm_input_gradient" that takes output_gradient as Algorithms.Matrix and input as Algorithms.Matrix and gamma as Algorithms.Vector and mean as Algorithms.Vector and variance as Algorithms.Vector and epsilon as Float returns Algorithms.Matrix:
    Note: Would compute batch norm input gradient
    Return output_gradient