Note:
Runa Standard Library: Neural Network Regularization

Regularization techniques to prevent overfitting including L1/L2 regularization,
dropout, early stopping, and other methods.
:End Note

Import "../../math/core" as Math
Import "../../algorithms" as Algorithms
Import "../../../../collections" as Collections

Note: L1 Regularization (Lasso)
Process called "l1_regularization" that takes weights as Algorithms.Matrix and lambda as Float returns Float:
    Let penalty be 0.0
    For i from 0 to weights.rows - 1:
        For j from 0 to weights.cols - 1:
            Set penalty to penalty + Math.abs with x as weights.data[i][j]
    Return lambda multiplied by penalty

Process called "l1_gradient" that takes weights as Algorithms.Matrix and lambda as Float returns Algorithms.Matrix:
    Let gradient be list
    For i from 0 to weights.rows - 1:
        Let row be list
        For j from 0 to weights.cols - 1:
            If weights.data[i][j] is greater than 0.0:
                Add lambda to row
            Otherwise if weights.data[i][j] is less than 0.0:
                Add negative lambda to row
            Otherwise:
                Add 0.0 to row
        Add row to gradient
    Return Algorithms.Matrix with:
        rows as weights.rows
        cols as weights.cols
        data as gradient

Note: L2 Regularization (Ridge)
Process called "l2_regularization" that takes weights as Algorithms.Matrix and lambda as Float returns Float:
    Let penalty be 0.0
    For i from 0 to weights.rows - 1:
        For j from 0 to weights.cols - 1:
            Set penalty to penalty + weights.data[i][j] multiplied by weights.data[i][j]
    Return 0.5 multiplied by lambda multiplied by penalty

Process called "l2_gradient" that takes weights as Algorithms.Matrix and lambda as Float returns Algorithms.Matrix:
    Let gradient be list
    For i from 0 to weights.rows - 1:
        Let row be list
        For j from 0 to weights.cols - 1:
            Add lambda multiplied by weights.data[i][j] to row
        Add row to gradient
    Return Algorithms.Matrix with:
        rows as weights.rows
        cols as weights.cols
        data as gradient

Note: Elastic Net (L1 + L2)
Process called "elastic_net_regularization" that takes weights as Algorithms.Matrix and l1_lambda as Float and l2_lambda as Float returns Float:
    Let l1_penalty be l1_regularization with weights as weights and lambda as l1_lambda
    Let l2_penalty be l2_regularization with weights as weights and lambda as l2_lambda
    Return l1_penalty + l2_penalty

Process called "elastic_net_gradient" that takes weights as Algorithms.Matrix and l1_lambda as Float and l2_lambda as Float returns Algorithms.Matrix:
    Let l1_grad be l1_gradient with weights as weights and lambda as l1_lambda
    Let l2_grad be l2_gradient with weights as weights and lambda as l2_lambda
    Return matrix_add with a as l1_grad and b as l2_grad

Note: Dropout implementation
Type called "DropoutMask":
    mask as Algorithms.Matrix
    keep_prob as Float
    scale as Float

Process called "create_dropout_mask" that takes shape as List[Integer] and dropout_rate as Float and training as Boolean returns DropoutMask:
    Let keep_prob be 1.0 - dropout_rate
    Let scale be 1.0 divided by keep_prob
    
    If not training:
        Note: No dropout during inference
        Return DropoutMask with:
            mask as ones_matrix with shape as shape
            keep_prob as 1.0
            scale as 1.0
    
    Let mask_data be list
    For i from 0 to shape[0] - 1:
        Let row be list
        For j from 0 to shape[1] - 1:
            If Math.random() is less than keep_prob:
                Add scale to row
            Otherwise:
                Add 0.0 to row
        Add row to mask_data
    
    Return DropoutMask with:
        mask as Algorithms.Matrix with rows as shape[0] and cols as shape[1] and data as mask_data
        keep_prob as keep_prob
        scale as scale

Process called "apply_dropout" that takes input as Algorithms.Matrix and mask as DropoutMask returns Algorithms.Matrix:
    Return element_wise_multiply with a as input and b as mask.mask

Note: DropConnect (dropping connections instead of units)
Process called "create_dropconnect_mask" that takes weight_shape as List[Integer] and drop_rate as Float and training as Boolean returns Algorithms.Matrix:
    If not training:
        Return ones_matrix with shape as weight_shape
    
    Let mask_data be list
    For i from 0 to weight_shape[0] - 1:
        Let row be list
        For j from 0 to weight_shape[1] - 1:
            If Math.random() is less than 1.0 - drop_rate:
                Add 1.0 divided by (1.0 - drop_rate) to row
            Otherwise:
                Add 0.0 to row
        Add row to mask_data
    
    Return Algorithms.Matrix with:
        rows as weight_shape[0]
        cols as weight_shape[1]
        data as mask_data

Process called "apply_dropconnect" that takes weights as Algorithms.Matrix and mask as Algorithms.Matrix returns Algorithms.Matrix:
    Return element_wise_multiply with a as weights and b as mask

Note: Early Stopping
Type called "EarlyStopping":
    patience as Integer
    min_delta as Float
    best_loss as Float
    counter as Integer
    stopped as Boolean
    best_weights as Dictionary[String, Algorithms.Matrix]

Process called "create_early_stopping" that takes patience as Integer and min_delta as Float returns EarlyStopping:
    Return EarlyStopping with:
        patience as patience
        min_delta as min_delta
        best_loss as Math.infinity
        counter as 0
        stopped as false
        best_weights as dictionary

Process called "check_early_stopping" that takes early_stopping as EarlyStopping and validation_loss as Float and current_weights as Dictionary[String, Algorithms.Matrix] returns Boolean:
    If validation_loss is less than early_stopping.best_loss - early_stopping.min_delta:
        Note: Improvement found
        Set early_stopping.best_loss to validation_loss
        Set early_stopping.counter to 0
        Set early_stopping.best_weights to copy_weights with weights as current_weights
        Return false
    Otherwise:
        Note: No improvement
        Set early_stopping.counter to early_stopping.counter + 1
        If early_stopping.counter is greater than or equal to early_stopping.patience:
            Set early_stopping.stopped to true
            Return true
        Return false

Process called "restore_best_weights" that takes early_stopping as EarlyStopping returns Dictionary[String, Algorithms.Matrix]:
    Return early_stopping.best_weights

Note: Weight Decay
Process called "apply_weight_decay" that takes weights as Algorithms.Matrix and decay_rate as Float returns Algorithms.Matrix:
    Let decayed_weights be list
    For i from 0 to weights.rows - 1:
        Let row be list
        For j from 0 to weights.cols - 1:
            Add weights.data[i][j] multiplied by (1.0 - decay_rate) to row
        Add row to decayed_weights
    Return Algorithms.Matrix with:
        rows as weights.rows
        cols as weights.cols
        data as decayed_weights

Note: Max Norm Constraint
Process called "max_norm_constraint" that takes weights as Algorithms.Matrix and max_norm as Float returns Algorithms.Matrix:
    Let norm be compute_frobenius_norm with matrix as weights
    If norm is greater than max_norm:
        Let scale be max_norm divided by norm
        Return scalar_multiply with scalar as scale and matrix as weights
    Otherwise:
        Return weights

Note: Spectral Normalization
Process called "spectral_normalization" that takes weights as Algorithms.Matrix and n_iterations as Integer returns Algorithms.Matrix:
    Let spectral_norm be compute_spectral_norm with matrix as weights and n_iterations as n_iterations
    Return scalar_multiply with scalar as 1.0 divided by spectral_norm and matrix as weights

Process called "compute_spectral_norm" that takes matrix as Algorithms.Matrix and n_iterations as Integer returns Float:
    Note: Power iteration to estimate largest singular value
    Let v be random_vector with size as matrix.cols
    
    For iter from 0 to n_iterations - 1:
        Let u be matrix_vector_multiply with matrix as matrix and vector as v
        Set u to normalize_vector with vector as u
        Set v to matrix_transpose_vector_multiply with matrix as matrix and vector as u
        Set v to normalize_vector with vector as v
    
    Let u be matrix_vector_multiply with matrix as matrix and vector as v
    Let sigma be vector_dot_product with a as u and b as u
    Return Math.sqrt with x as sigma

Note: Noise injection
Process called "add_gaussian_noise" that takes input as Algorithms.Matrix and noise_std as Float and training as Boolean returns Algorithms.Matrix:
    If not training:
        Return input
    
    Let noisy_data be list
    For i from 0 to input.rows - 1:
        Let row be list
        For j from 0 to input.cols - 1:
            Let noise be random_normal with mean as 0.0 and std as noise_std
            Add input.data[i][j] + noise to row
        Add row to noisy_data
    
    Return Algorithms.Matrix with:
        rows as input.rows
        cols as input.cols
        data as noisy_data

Note: Label Smoothing
Process called "label_smoothing" that takes labels as Algorithms.Matrix and epsilon as Float returns Algorithms.Matrix:
    Let n_classes be labels.cols
    Let smoothed_labels be list
    
    For i from 0 to labels.rows - 1:
        Let row be list
        For j from 0 to labels.cols - 1:
            Let original_value be labels.data[i][j]
            Let smoothed_value be original_value multiplied by (1.0 - epsilon) + epsilon divided by Float.from with value as n_classes
            Add smoothed_value to row
        Add row to smoothed_labels
    
    Return Algorithms.Matrix with:
        rows as labels.rows
        cols as labels.cols
        data as smoothed_labels

Note: Mixup augmentation
Process called "mixup" that takes x1 as Algorithms.Matrix and x2 as Algorithms.Matrix and y1 as Algorithms.Vector and y2 as Algorithms.Vector and alpha as Float returns (Algorithms.Matrix, Algorithms.Vector):
    Let lambda be sample_beta with alpha as alpha and beta as alpha
    
    Note: Mix inputs
    Let mixed_x be matrix_add with a as scalar_multiply with scalar as lambda and matrix as x1 and b as scalar_multiply with scalar as 1.0 - lambda and matrix as x2
    
    Note: Mix labels
    Let mixed_y be vector_add with a as scalar_multiply_vector with scalar as lambda and vector as y1 and b as scalar_multiply_vector with scalar as 1.0 - lambda and vector as y2
    
    Return (mixed_x, mixed_y)

Note: Utility functions
Process called "matrix_add" that takes a as Algorithms.Matrix and b as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would add matrices element-wise
    Return a

Process called "element_wise_multiply" that takes a as Algorithms.Matrix and b as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would multiply matrices element-wise
    Return a

Process called "scalar_multiply" that takes scalar as Float and matrix as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would multiply matrix by scalar
    Return matrix

Process called "ones_matrix" that takes shape as List[Integer] returns Algorithms.Matrix:
    Let data be list
    For i from 0 to shape[0] - 1:
        Let row be list
        For j from 0 to shape[1] - 1:
            Add 1.0 to row
        Add row to data
    Return Algorithms.Matrix with:
        rows as shape[0]
        cols as shape[1]
        data as data

Process called "copy_weights" that takes weights as Dictionary[String, Algorithms.Matrix] returns Dictionary[String, Algorithms.Matrix]:
    Note: Would deep copy weights dictionary
    Return weights

Process called "compute_frobenius_norm" that takes matrix as Algorithms.Matrix returns Float:
    Let sum_squares be 0.0
    For i from 0 to matrix.rows - 1:
        For j from 0 to matrix.cols - 1:
            Set sum_squares to sum_squares + matrix.data[i][j] multiplied by matrix.data[i][j]
    Return Math.sqrt with x as sum_squares

Process called "random_vector" that takes size as Integer returns Algorithms.Vector:
    Let data be list
    For i from 0 to size - 1:
        Add Math.random() to data
    Return Algorithms.Vector with:
        size as size
        data as data

Process called "matrix_vector_multiply" that takes matrix as Algorithms.Matrix and vector as Algorithms.Vector returns Algorithms.Vector:
    Note: Would multiply matrix by vector
    Return vector

Process called "matrix_transpose_vector_multiply" that takes matrix as Algorithms.Matrix and vector as Algorithms.Vector returns Algorithms.Vector:
    Note: Would multiply matrix transpose by vector
    Return vector

Process called "normalize_vector" that takes vector as Algorithms.Vector returns Algorithms.Vector:
    Note: Would normalize vector to unit length
    Return vector

Process called "vector_dot_product" that takes a as Algorithms.Vector and b as Algorithms.Vector returns Float:
    Note: Would compute dot product
    Return 0.0

Process called "random_normal" that takes mean as Float and std as Float returns Float:
    Note: Would generate normal random number
    Return mean

Process called "sample_beta" that takes alpha as Float and beta as Float returns Float:
    Note: Would sample from beta distribution
    Return Math.random()

Process called "vector_add" that takes a as Algorithms.Vector and b as Algorithms.Vector returns Algorithms.Vector:
    Note: Would add vectors
    Return a

Process called "scalar_multiply_vector" that takes scalar as Float and vector as Algorithms.Vector returns Algorithms.Vector:
    Note: Would multiply vector by scalar
    Return vector