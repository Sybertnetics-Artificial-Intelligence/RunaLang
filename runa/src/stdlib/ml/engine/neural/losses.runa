Note:
Runa Standard Library: Neural Network Loss Functions

Collection of loss functions for training neural networks including
classification and regression losses with their gradients.
:End Note

Import "../../math/core" as Math
Import "../../algorithms" as Algorithms
Import "../../../../collections" as Collections

Note: Mean Squared Error (MSE)
Process called "mean_squared_error" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let n be Float.from with value as y_true.size
    Let sum_squared_error be 0.0
    
    For i from 0 to y_true.size - 1:
        Let error be y_true.data[i] - y_pred.data[i]
        Set sum_squared_error to sum_squared_error + error multiplied by error
    
    Return sum_squared_error divided by n

Process called "mse_gradient" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Algorithms.Vector:
    Let n be Float.from with value as y_true.size
    Let gradient be list
    
    For i from 0 to y_true.size - 1:
        Add 2.0 multiplied by (y_pred.data[i] - y_true.data[i]) divided by n to gradient
    
    Return Algorithms.Vector with:
        size as y_true.size
        data as gradient

Note: Mean Absolute Error (MAE)
Process called "mean_absolute_error" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let n be Float.from with value as y_true.size
    Let sum_absolute_error be 0.0
    
    For i from 0 to y_true.size - 1:
        Let error be Math.abs with x as y_true.data[i] - y_pred.data[i]
        Set sum_absolute_error to sum_absolute_error + error
    
    Return sum_absolute_error divided by n

Process called "mae_gradient" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Algorithms.Vector:
    Let n be Float.from with value as y_true.size
    Let gradient be list
    
    For i from 0 to y_true.size - 1:
        Let diff be y_pred.data[i] - y_true.data[i]
        If diff is greater than 0.0:
            Add 1.0 divided by n to gradient
        Otherwise if diff is less than 0.0:
            Add negative 1.0 divided by n to gradient
        Otherwise:
            Add 0.0 to gradient
    
    Return Algorithms.Vector with:
        size as y_true.size
        data as gradient

Note: Binary Cross-Entropy
Process called "binary_cross_entropy" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let n be Float.from with value as y_true.size
    Let loss be 0.0
    Let epsilon be 0.0000001
    
    For i from 0 to y_true.size - 1:
        Let y_pred_clipped be Math.max with a as epsilon and b as Math.min with a as 1.0 - epsilon and b as y_pred.data[i]
        Let term1 be y_true.data[i] multiplied by Math.log with x as y_pred_clipped
        Let term2 be (1.0 - y_true.data[i]) multiplied by Math.log with x as 1.0 - y_pred_clipped
        Set loss to loss - (term1 + term2)
    
    Return loss divided by n

Process called "binary_cross_entropy_gradient" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Algorithms.Vector:
    Let n be Float.from with value as y_true.size
    Let gradient be list
    Let epsilon be 0.0000001
    
    For i from 0 to y_true.size - 1:
        Let y_pred_clipped be Math.max with a as epsilon and b as Math.min with a as 1.0 - epsilon and b as y_pred.data[i]
        Let grad be (y_pred_clipped - y_true.data[i]) divided by (y_pred_clipped multiplied by (1.0 - y_pred_clipped))
        Add grad divided by n to gradient
    
    Return Algorithms.Vector with:
        size as y_true.size
        data as gradient

Note: Categorical Cross-Entropy
Process called "categorical_cross_entropy" that takes y_true as Algorithms.Matrix and y_pred as Algorithms.Matrix returns Float:
    Let n be Float.from with value as y_true.rows
    Let loss be 0.0
    Let epsilon be 0.0000001
    
    For i from 0 to y_true.rows - 1:
        For j from 0 to y_true.cols - 1:
            Let y_pred_clipped be Math.max with a as epsilon and b as Math.min with a as 1.0 - epsilon and b as y_pred.data[i][j]
            Set loss to loss - y_true.data[i][j] multiplied by Math.log with x as y_pred_clipped
    
    Return loss divided by n

Process called "categorical_cross_entropy_gradient" that takes y_true as Algorithms.Matrix and y_pred as Algorithms.Matrix returns Algorithms.Matrix:
    Let n be Float.from with value as y_true.rows
    Let gradient be list
    Let epsilon be 0.0000001
    
    For i from 0 to y_true.rows - 1:
        Let row_gradient be list
        For j from 0 to y_true.cols - 1:
            Let y_pred_clipped be Math.max with a as epsilon and b as Math.min with a as 1.0 - epsilon and b as y_pred.data[i][j]
            Add negative y_true.data[i][j] divided by y_pred_clipped divided by n to row_gradient
        Add row_gradient to gradient
    
    Return Algorithms.Matrix with:
        rows as y_true.rows
        cols as y_true.cols
        data as gradient

Note: Sparse Categorical Cross-Entropy
Process called "sparse_categorical_cross_entropy" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Matrix returns Float:
    Let n be Float.from with value as y_true.size
    Let loss be 0.0
    Let epsilon be 0.0000001
    
    For i from 0 to y_true.size - 1:
        Let true_class be Integer.from with value as y_true.data[i]
        Let y_pred_clipped be Math.max with a as epsilon and b as Math.min with a as 1.0 - epsilon and b as y_pred.data[i][true_class]
        Set loss to loss - Math.log with x as y_pred_clipped
    
    Return loss divided by n

Process called "sparse_categorical_cross_entropy_gradient" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Matrix returns Algorithms.Matrix:
    Let n be Float.from with value as y_true.size
    Let gradient be list
    
    For i from 0 to y_pred.rows - 1:
        Let row_gradient be list
        Let true_class be Integer.from with value as y_true.data[i]
        For j from 0 to y_pred.cols - 1:
            If j is equal to true_class:
                Add (y_pred.data[i][j] - 1.0) divided by n to row_gradient
            Otherwise:
                Add y_pred.data[i][j] divided by n to row_gradient
        Add row_gradient to gradient
    
    Return Algorithms.Matrix with:
        rows as y_pred.rows
        cols as y_pred.cols
        data as gradient

Note: Huber Loss
Process called "huber_loss" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector and delta as Float returns Float:
    Let n be Float.from with value as y_true.size
    Let loss be 0.0
    
    For i from 0 to y_true.size - 1:
        Let error be Math.abs with x as y_true.data[i] - y_pred.data[i]
        If error is less than or equal to delta:
            Set loss to loss + 0.5 multiplied by error multiplied by error
        Otherwise:
            Set loss to loss + delta multiplied by error - 0.5 multiplied by delta multiplied by delta
    
    Return loss divided by n

Process called "huber_loss_gradient" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector and delta as Float returns Algorithms.Vector:
    Let n be Float.from with value as y_true.size
    Let gradient be list
    
    For i from 0 to y_true.size - 1:
        Let error be y_pred.data[i] - y_true.data[i]
        Let abs_error be Math.abs with x as error
        If abs_error is less than or equal to delta:
            Add error divided by n to gradient
        Otherwise:
            If error is greater than 0.0:
                Add delta divided by n to gradient
            Otherwise:
                Add negative delta divided by n to gradient
    
    Return Algorithms.Vector with:
        size as y_true.size
        data as gradient

Note: Hinge Loss (for SVM)
Process called "hinge_loss" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let n be Float.from with value as y_true.size
    Let loss be 0.0
    
    For i from 0 to y_true.size - 1:
        Let margin be 1.0 - y_true.data[i] multiplied by y_pred.data[i]
        Set loss to loss + Math.max with a as 0.0 and b as margin
    
    Return loss divided by n

Process called "hinge_loss_gradient" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Algorithms.Vector:
    Let n be Float.from with value as y_true.size
    Let gradient be list
    
    For i from 0 to y_true.size - 1:
        Let margin be 1.0 - y_true.data[i] multiplied by y_pred.data[i]
        If margin is greater than 0.0:
            Add negative y_true.data[i] divided by n to gradient
        Otherwise:
            Add 0.0 to gradient
    
    Return Algorithms.Vector with:
        size as y_true.size
        data as gradient

Note: Squared Hinge Loss
Process called "squared_hinge_loss" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let n be Float.from with value as y_true.size
    Let loss be 0.0
    
    For i from 0 to y_true.size - 1:
        Let margin be Math.max with a as 0.0 and b as 1.0 - y_true.data[i] multiplied by y_pred.data[i]
        Set loss to loss + margin multiplied by margin
    
    Return loss divided by n

Process called "squared_hinge_loss_gradient" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Algorithms.Vector:
    Let n be Float.from with value as y_true.size
    Let gradient be list
    
    For i from 0 to y_true.size - 1:
        Let margin be 1.0 - y_true.data[i] multiplied by y_pred.data[i]
        If margin is greater than 0.0:
            Add negative 2.0 multiplied by margin multiplied by y_true.data[i] divided by n to gradient
        Otherwise:
            Add 0.0 to gradient
    
    Return Algorithms.Vector with:
        size as y_true.size
        data as gradient

Note: Kullback-Leibler Divergence
Process called "kl_divergence" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let loss be 0.0
    Let epsilon be 0.0000001
    
    For i from 0 to y_true.size - 1:
        Let y_true_clipped be Math.max with a as epsilon and b as y_true.data[i]
        Let y_pred_clipped be Math.max with a as epsilon and b as y_pred.data[i]
        Set loss to loss + y_true_clipped multiplied by Math.log with x as y_true_clipped divided by y_pred_clipped
    
    Return loss

Process called "kl_divergence_gradient" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Algorithms.Vector:
    Let gradient be list
    Let epsilon be 0.0000001
    
    For i from 0 to y_true.size - 1:
        Let y_true_clipped be Math.max with a as epsilon and b as y_true.data[i]
        Let y_pred_clipped be Math.max with a as epsilon and b as y_pred.data[i]
        Add negative y_true_clipped divided by y_pred_clipped to gradient
    
    Return Algorithms.Vector with:
        size as y_true.size
        data as gradient

Note: Cosine Similarity Loss
Process called "cosine_similarity_loss" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let dot_product be 0.0
    Let norm_true be 0.0
    Let norm_pred be 0.0
    
    For i from 0 to y_true.size - 1:
        Set dot_product to dot_product + y_true.data[i] multiplied by y_pred.data[i]
        Set norm_true to norm_true + y_true.data[i] multiplied by y_true.data[i]
        Set norm_pred to norm_pred + y_pred.data[i] multiplied by y_pred.data[i]
    
    Let cosine_sim be dot_product divided by (Math.sqrt with x as norm_true multiplied by Math.sqrt with x as norm_pred + 0.0000001)
    Return 1.0 - cosine_sim

Note: Loss function dispatcher
Process called "compute_loss" that takes loss_name as String and y_true as Any and y_pred as Any returns Float:
    Match loss_name:
        When "mse":
            Return mean_squared_error with y_true as y_true and y_pred as y_pred
        When "mae":
            Return mean_absolute_error with y_true as y_true and y_pred as y_pred
        When "binary_crossentropy":
            Return binary_cross_entropy with y_true as y_true and y_pred as y_pred
        When "categorical_crossentropy":
            Return categorical_cross_entropy with y_true as y_true and y_pred as y_pred
        When "sparse_categorical_crossentropy":
            Return sparse_categorical_cross_entropy with y_true as y_true and y_pred as y_pred
        When "huber":
            Return huber_loss with y_true as y_true and y_pred as y_pred and delta as 1.0
        When "hinge":
            Return hinge_loss with y_true as y_true and y_pred as y_pred
        When "squared_hinge":
            Return squared_hinge_loss with y_true as y_true and y_pred as y_pred
        When "kl_divergence":
            Return kl_divergence with y_true as y_true and y_pred as y_pred
        When "cosine_similarity":
            Return cosine_similarity_loss with y_true as y_true and y_pred as y_pred
        Otherwise:
            Return mean_squared_error with y_true as y_true and y_pred as y_pred

Process called "compute_loss_gradient" that takes loss_name as String and y_true as Any and y_pred as Any returns Any:
    Note: Would dispatch to appropriate gradient function
    Return y_pred