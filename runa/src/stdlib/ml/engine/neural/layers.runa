Note:
Runa Standard Library: Neural Network Layers

Core layer implementations for building neural networks including
dense layers, convolutional layers, pooling, normalization, and more.
:End Note

Import "../../algorithms" as Algorithms
Import "../../math/core" as Math
Import "../../../../collections" as Collections

Note: Base layer type
Type called "Layer":
    name as String
    input_shape as List[Integer]
    output_shape as List[Integer]
    trainable as Boolean
    weights as Algorithms.Matrix
    bias as Algorithms.Vector
    activation as String
    initialized as Boolean

Note: Dense (Fully Connected) Layer
Type called "DenseLayer":
    base as Layer
    units as Integer
    use_bias as Boolean
    weight_regularizer as String
    bias_regularizer as String

Process called "create_dense_layer" that takes units as Integer and activation as String returns DenseLayer:
    Return DenseLayer with:
        base as Layer with:
            name as "dense"
            input_shape as list
            output_shape as list
            trainable as true
            weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
            bias as Algorithms.Vector with size as 0 and data as list
            activation as activation
            initialized as false
        units as units
        use_bias as true
        weight_regularizer as "none"
        bias_regularizer as "none"

Process called "forward_dense" that takes layer as DenseLayer and input as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Compute dense layer forward pass: output = activation(input @ weights + bias)
    Let output be Algorithms.matrix_multiply with a as input and b as layer.base.weights
    If layer.use_bias:
        Set output to add_bias_to_matrix with matrix as output and bias as layer.base.bias
    Return apply_activation with x as output and activation as layer.base.activation

Note: Convolutional 2D Layer
Type called "Conv2DLayer":
    base as Layer
    filters as Integer
    kernel_size as (Integer, Integer)
    stride as (Integer, Integer)
    padding as String
    use_bias as Boolean
    kernels as List[Algorithms.Matrix]

Process called "create_conv2d_layer" that takes filters as Integer and kernel_size as (Integer, Integer) and activation as String returns Conv2DLayer:
    Return Conv2DLayer with:
        base as Layer with:
            name as "conv2d"
            input_shape as list
            output_shape as list
            trainable as true
            weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
            bias as Algorithms.Vector with size as 0 and data as list
            activation as activation
            initialized as false
        filters as filters
        kernel_size as kernel_size
        stride as (1, 1)
        padding as "valid"
        use_bias as true
        kernels as list

Process called "forward_conv2d" that takes layer as Conv2DLayer and input as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Compute 2D convolution forward pass
    Let output be perform_convolution with input as input and kernels as layer.kernels and stride as layer.stride
    If layer.use_bias:
        Set output to add_bias_to_matrix with matrix as output and bias as layer.base.bias
    Return apply_activation with x as output and activation as layer.base.activation

Note: Max Pooling 2D Layer
Type called "MaxPool2DLayer":
    base as Layer
    pool_size as (Integer, Integer)
    stride as (Integer, Integer)
    padding as String

Process called "create_maxpool2d_layer" that takes pool_size as (Integer, Integer) returns MaxPool2DLayer:
    Return MaxPool2DLayer with:
        base as Layer with:
            name as "maxpool2d"
            input_shape as list
            output_shape as list
            trainable as false
            weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
            bias as Algorithms.Vector with size as 0 and data as list
            activation as "none"
            initialized as false
        pool_size as pool_size
        stride as pool_size
        padding as "valid"

Process called "forward_maxpool2d" that takes layer as MaxPool2DLayer and input as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Compute max pooling forward pass
    Return perform_max_pooling with input as input and pool_size as layer.pool_size and stride as layer.stride

Note: Dropout Layer
Type called "DropoutLayer":
    base as Layer
    rate as Float
    training as Boolean
    mask as Algorithms.Matrix

Process called "create_dropout_layer" that takes rate as Float returns DropoutLayer:
    Return DropoutLayer with:
        base as Layer with:
            name as "dropout"
            input_shape as list
            output_shape as list
            trainable as false
            weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
            bias as Algorithms.Vector with size as 0 and data as list
            activation as "none"
            initialized as false
        rate as rate
        training as true
        mask as Algorithms.Matrix with rows as 0 and cols as 0 and data as list

Process called "forward_dropout" that takes layer as DropoutLayer and input as Algorithms.Matrix returns Algorithms.Matrix:
    If not layer.training:
        Return input
    Note: Apply dropout mask during training
    Let mask be generate_dropout_mask with shape as input.shape and rate as layer.rate
    Return element_wise_multiply with a as input and b as mask

Note: Batch Normalization Layer
Type called "BatchNormLayer":
    base as Layer
    momentum as Float
    epsilon as Float
    moving_mean as Algorithms.Vector
    moving_variance as Algorithms.Vector
    beta as Algorithms.Vector
    gamma as Algorithms.Vector
    training as Boolean

Process called "create_batchnorm_layer" that takes momentum as Float returns BatchNormLayer:
    Return BatchNormLayer with:
        base as Layer with:
            name as "batchnorm"
            input_shape as list
            output_shape as list
            trainable as true
            weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
            bias as Algorithms.Vector with size as 0 and data as list
            activation as "none"
            initialized as false
        momentum as momentum
        epsilon as 0.001
        moving_mean as Algorithms.Vector with size as 0 and data as list
        moving_variance as Algorithms.Vector with size as 0 and data as list
        beta as Algorithms.Vector with size as 0 and data as list
        gamma as Algorithms.Vector with size as 0 and data as list
        training as true

Process called "forward_batchnorm" that takes layer as BatchNormLayer and input as Algorithms.Matrix returns Algorithms.Matrix:
    If layer.training:
        Note: Compute batch statistics and normalize
        Let batch_mean be compute_batch_mean with input as input
        Let batch_variance be compute_batch_variance with input as input and mean as batch_mean
        Note: Update moving statistics
        update_moving_statistics with layer as layer and batch_mean as batch_mean and batch_variance as batch_variance
        Return batch_normalize with input as input and mean as batch_mean and variance as batch_variance and gamma as layer.gamma and beta as layer.beta
    Otherwise:
        Note: Use moving statistics for inference
        Return batch_normalize with input as input and mean as layer.moving_mean and variance as layer.moving_variance and gamma as layer.gamma and beta as layer.beta

Note: LSTM Layer
Type called "LSTMLayer":
    base as Layer
    units as Integer
    return_sequences as Boolean
    forget_gate_weights as Algorithms.Matrix
    input_gate_weights as Algorithms.Matrix
    candidate_gate_weights as Algorithms.Matrix
    output_gate_weights as Algorithms.Matrix
    hidden_state as Algorithms.Matrix
    cell_state as Algorithms.Matrix

Process called "create_lstm_layer" that takes units as Integer and return_sequences as Boolean returns LSTMLayer:
    Return LSTMLayer with:
        base as Layer with:
            name as "lstm"
            input_shape as list
            output_shape as list
            trainable as true
            weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
            bias as Algorithms.Vector with size as 0 and data as list
            activation as "tanh"
            initialized as false
        units as units
        return_sequences as return_sequences
        forget_gate_weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
        input_gate_weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
        candidate_gate_weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
        output_gate_weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
        hidden_state as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
        cell_state as Algorithms.Matrix with rows as 0 and cols as 0 and data as list

Process called "forward_lstm" that takes layer as LSTMLayer and input as Algorithms.Matrix returns Algorithms.Matrix:
    Note: LSTM forward pass implementation
    Let outputs be list
    For each timestep in input:
        Let gates be compute_lstm_gates with layer as layer and input as timestep and hidden as layer.hidden_state
        Let new_cell_state be update_cell_state with gates as gates and prev_cell as layer.cell_state
        Let new_hidden_state be compute_hidden_state with gates as gates and cell_state as new_cell_state
        Set layer.cell_state to new_cell_state
        Set layer.hidden_state to new_hidden_state
        If layer.return_sequences:
            Add new_hidden_state to outputs
    If layer.return_sequences:
        Return Algorithms.Matrix with rows as Collections.List.length with lst as outputs and cols as layer.units and data as outputs
    Otherwise:
        Return layer.hidden_state

Note: Flatten Layer
Type called "FlattenLayer":
    base as Layer

Process called "create_flatten_layer" returns FlattenLayer:
    Return FlattenLayer with:
        base as Layer with:
            name as "flatten"
            input_shape as list
            output_shape as list
            trainable as false
            weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
            bias as Algorithms.Vector with size as 0 and data as list
            activation as "none"
            initialized as false

Process called "forward_flatten" that takes layer as FlattenLayer and input as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Flatten multi-dimensional input to 1D
    Return flatten_matrix with matrix as input

Note: Embedding Layer
Type called "EmbeddingLayer":
    base as Layer
    input_dim as Integer
    output_dim as Integer
    embedding_matrix as Algorithms.Matrix

Process called "create_embedding_layer" that takes input_dim as Integer and output_dim as Integer returns EmbeddingLayer:
    Return EmbeddingLayer with:
        base as Layer with:
            name as "embedding"
            input_shape as list
            output_shape as list
            trainable as true
            weights as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
            bias as Algorithms.Vector with size as 0 and data as list
            activation as "none"
            initialized as false
        input_dim as input_dim
        output_dim as output_dim
        embedding_matrix as Algorithms.Matrix with rows as input_dim and cols as output_dim and data as list

Process called "forward_embedding" that takes layer as EmbeddingLayer and input as List[Integer] returns Algorithms.Matrix:
    Note: Look up embeddings for input indices
    Let embeddings be list
    For each index in input:
        Add layer.embedding_matrix.data[index] to embeddings
    Return Algorithms.Matrix with rows as Collections.List.length with lst as input and cols as layer.output_dim and data as embeddings

Note: Utility functions
Process called "apply_activation" that takes x as Algorithms.Matrix and activation as String returns Algorithms.Matrix:
    Note: Would apply specified activation function
    Return x

Process called "add_bias_to_matrix" that takes matrix as Algorithms.Matrix and bias as Algorithms.Vector returns Algorithms.Matrix:
    Note: Would add bias vector to each row of matrix
    Return matrix

Process called "perform_convolution" that takes input as Algorithms.Matrix and kernels as List[Algorithms.Matrix] and stride as (Integer, Integer) returns Algorithms.Matrix:
    Note: Would perform 2D convolution operation
    Return input

Process called "perform_max_pooling" that takes input as Algorithms.Matrix and pool_size as (Integer, Integer) and stride as (Integer, Integer) returns Algorithms.Matrix:
    Note: Would perform max pooling operation
    Return input

Process called "generate_dropout_mask" that takes shape as List[Integer] and rate as Float returns Algorithms.Matrix:
    Note: Would generate binary dropout mask
    Return Algorithms.Matrix with rows as shape[0] and cols as shape[1] and data as list

Process called "element_wise_multiply" that takes a as Algorithms.Matrix and b as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would perform element-wise multiplication
    Return a

Process called "compute_batch_mean" that takes input as Algorithms.Matrix returns Algorithms.Vector:
    Note: Would compute mean across batch dimension
    Return Algorithms.Vector with size as input.cols and data as list

Process called "compute_batch_variance" that takes input as Algorithms.Matrix and mean as Algorithms.Vector returns Algorithms.Vector:
    Note: Would compute variance across batch dimension
    Return Algorithms.Vector with size as input.cols and data as list

Process called "update_moving_statistics" that takes layer as BatchNormLayer and batch_mean as Algorithms.Vector and batch_variance as Algorithms.Vector:
    Note: Would update moving mean and variance with momentum
    Return

Process called "batch_normalize" that takes input as Algorithms.Matrix and mean as Algorithms.Vector and variance as Algorithms.Vector and gamma as Algorithms.Vector and beta as Algorithms.Vector returns Algorithms.Matrix:
    Note: Would perform batch normalization
    Return input

Process called "compute_lstm_gates" that takes layer as LSTMLayer and input as Algorithms.Vector and hidden as Algorithms.Matrix returns Dictionary[String, Algorithms.Vector]:
    Note: Would compute LSTM gate activations
    Return dictionary

Process called "update_cell_state" that takes gates as Dictionary[String, Algorithms.Vector] and prev_cell as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would update LSTM cell state
    Return prev_cell

Process called "compute_hidden_state" that takes gates as Dictionary[String, Algorithms.Vector] and cell_state as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would compute LSTM hidden state
    Return cell_state

Process called "flatten_matrix" that takes matrix as Algorithms.Matrix returns Algorithms.Matrix:
    Note: Would flatten matrix to 1D
    Return matrix