Note:
Runa Standard Library: K-Nearest Neighbors

Implementation of K-Nearest Neighbors for classification and regression
with various distance metrics and weighting schemes.
:End Note

Import "../../algorithms" as Algorithms
Import "../../math/core" as Math

Type called "KNearestNeighbors":
    k as Integer
    metric as String
    weights as String
    X_train as Algorithms.Matrix
    y_train as Algorithms.Vector
    fitted as Boolean

Process called "create_knn" that takes k as Integer and metric as String returns KNearestNeighbors:
    Return KNearestNeighbors with:
        k as k
        metric as metric
        weights as "uniform"
        X_train as Algorithms.Matrix with rows as 0 and cols as 0 and data as list
        y_train as Algorithms.Vector with size as 0 and data as list
        fitted as false

Process called "fit_knn" that takes model as KNearestNeighbors and X as Algorithms.Matrix and y as Algorithms.Vector returns KNearestNeighbors:
    Set model.X_train to X
    Set model.y_train to y
    Set model.fitted to true
    Return model

Process called "predict_knn" that takes model as KNearestNeighbors and X as Algorithms.Matrix returns Algorithms.Vector:
    Note: Find k nearest neighbors and vote/average
    Return Algorithms.Vector with size as X.rows and data as list

Process called "euclidean_distance" that takes x1 as Algorithms.Vector and x2 as Algorithms.Vector returns Float:
    Let sum_squares be 0.0
    For i from 0 to x1.size - 1:
        Let diff be x1.data[i] - x2.data[i]
        Set sum_squares to sum_squares + diff multiplied by diff
    Return Math.sqrt with x as sum_squares

Process called "manhattan_distance" that takes x1 as Algorithms.Vector and x2 as Algorithms.Vector returns Float:
    Let sum_abs be 0.0
    For i from 0 to x1.size - 1:
        Set sum_abs to sum_abs + Math.abs with x as x1.data[i] - x2.data[i]
    Return sum_abs