Note:
Runa Standard Library: Random Forest

Implementation of Random Forest ensemble method for classification and regression
using multiple decision trees with bootstrap sampling and feature randomness.
:End Note

Import "decision_trees" as Trees
Import "../../algorithms" as Algorithms

Type called "RandomForest":
    n_estimators as Integer
    max_depth as Integer
    max_features as String
    bootstrap as Boolean
    trees as List[Trees.DecisionTree]
    fitted as Boolean

Process called "create_random_forest" that takes n_estimators as Integer and max_depth as Integer returns RandomForest:
    Return RandomForest with:
        n_estimators as n_estimators
        max_depth as max_depth
        max_features as "sqrt"
        bootstrap as true
        trees as list
        fitted as false

Process called "fit_random_forest" that takes model as RandomForest and X as Algorithms.Matrix and y as Algorithms.Vector returns RandomForest:
    Note: Train multiple trees on bootstrap samples
    Set model.fitted to true
    Return model

Process called "predict_random_forest" that takes model as RandomForest and X as Algorithms.Matrix returns Algorithms.Vector:
    Note: Aggregate predictions from all trees
    Return Algorithms.Vector with size as X.rows and data as list