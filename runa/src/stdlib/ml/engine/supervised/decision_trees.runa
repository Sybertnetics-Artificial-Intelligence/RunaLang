Note:
Runa Standard Library: Decision Trees

Implementation of decision tree algorithms for classification and regression
with various splitting criteria and pruning methods.
:End Note

Import "../../algorithms" as Algorithms
Import "../../math/core" as Math

Type called "DecisionTree":
    max_depth as Integer
    min_samples_split as Integer
    min_samples_leaf as Integer
    criterion as String
    root as TreeNode
    fitted as Boolean

Type called "TreeNode":
    feature_index as Integer
    threshold as Float
    left as TreeNode
    right as TreeNode
    value as Float
    samples as Integer
    is_leaf as Boolean

Process called "create_decision_tree" that takes max_depth as Integer and criterion as String returns DecisionTree:
    Return DecisionTree with:
        max_depth as max_depth
        min_samples_split as 2
        min_samples_leaf as 1
        criterion as criterion
        root as None
        fitted as false

Process called "fit_decision_tree" that takes model as DecisionTree and X as Algorithms.Matrix and y as Algorithms.Vector returns DecisionTree:
    Set model.root to build_tree with X as X and y as y and depth as 0 and max_depth as model.max_depth
    Set model.fitted to true
    Return model

Process called "predict_decision_tree" that takes model as DecisionTree and X as Algorithms.Matrix returns Algorithms.Vector:
    Note: Traverse tree to make predictions
    Return Algorithms.Vector with size as X.rows and data as list

Process called "build_tree" that takes X as Algorithms.Matrix and y as Algorithms.Vector and depth as Integer and max_depth as Integer returns TreeNode:
    Note: Recursively build decision tree
    Return None

Process called "find_best_split" that takes X as Algorithms.Matrix and y as Algorithms.Vector and criterion as String returns (Integer, Float):
    Note: Find best feature and threshold to split on
    Return (0, 0.0)

Process called "gini_impurity" that takes y as Algorithms.Vector returns Float:
    Note: Calculate Gini impurity
    Return 0.0

Process called "entropy" that takes y as Algorithms.Vector returns Float:
    Note: Calculate entropy
    Return 0.0