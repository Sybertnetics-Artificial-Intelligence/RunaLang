Note:
Runa Standard Library: ML Preprocessing

Production-grade data preprocessing system providing comprehensive
data cleaning, transformation, and preparation capabilities.

Features:
- Missing value handling with multiple strategies
- Outlier detection and treatment
- Feature scaling and normalization
- Categorical encoding (one-hot, label, target)
- Data validation and quality assessment
- Imbalanced data handling (SMOTE, undersampling)
- Time series preprocessing
- Text preprocessing and tokenization
:End Note

Import "ml/algorithms" as Algorithms
Import "math/core" as Math
Import "../../collections" as Collections
Import "../../string" as String

Note: Core preprocessing types
Type called "MissingValueStrategy":
    strategy as String
    fill_value as Any
    fitted_values as Dictionary[String, Any]

Type called "OutlierDetector":
    method as String
    threshold as Float
    lower_bounds as List[Float]
    upper_bounds as List[Float]
    fitted as Boolean

Type called "FeatureScaler":
    scaling_method as String
    feature_means as List[Float]
    feature_stds as List[Float]
    feature_mins as List[Float]
    feature_maxs as List[Float]
    fitted as Boolean

Type called "CategoricalEncoder":
    encoding_method as String
    feature_mappings as Dictionary[String, Dictionary[String, Any]]
    categories as Dictionary[String, List[String]]
    fitted as Boolean

Note: Missing value handling
Process called "handle_missing_values" that takes dataset as Algorithms.Dataset and strategy as String returns Algorithms.Dataset:
    Let missing_handler be create_missing_value_handler with strategy as strategy
    Return fit_transform_missing_values with handler as missing_handler and dataset as dataset

Process called "create_missing_value_handler" that takes strategy as String returns MissingValueStrategy:
    Return MissingValueStrategy with:
    strategy as strategy
    fill_value as None
    fitted_values as dictionary

Process called "fit_transform_missing_values" that takes handler as MissingValueStrategy and dataset as Algorithms.Dataset returns Algorithms.Dataset:
    Let processed_data be list Note: Compute fill values for each feature
    For j from 0 to dataset.feature_count - 1:
    Let feature_values be extract_non_missing_values with dataset as dataset and column as j
    Let fill_value be compute_fill_value with values as feature_values and strategy as handler.strategy
    Set handler.fitted_values[String.from with value as j] to fill_value Note: Apply missing value imputation
    For i from 0 to dataset.sample_count - 1:
    Let processed_sample be list For j from 0 to dataset.feature_count - 1:
    Let original_value be dataset.features.data[i][j] If is_missing_value with value as original_value:
    Let fill_value be handler.fitted_values[String.from with value as j] as Float
    Add fill_value to processed_sample
    Otherwise:
    Add original_value to processed_sample Add processed_sample to processed_data Let processed_matrix be Algorithms.Matrix with:
    rows as dataset.sample_count
    cols as dataset.feature_count
    data as processed_data Return Algorithms.Dataset with:
    features as processed_matrix
    targets as dataset.targets
    feature_names as dataset.feature_names
    target_names as dataset.target_names
    sample_count as dataset.sample_count
    feature_count as dataset.feature_count

Process called "extract_non_missing_values" that takes dataset as Algorithms.Dataset and column as Integer returns List[Float]:
    Let non_missing_values be list For i from 0 to dataset.sample_count - 1:
    Let value be dataset.features.data[i][column]
    If not is_missing_value with value as value:
    Add value to non_missing_values Return non_missing_values

Process called "compute_fill_value" that takes values as List[Float] and strategy as String returns Float:
    If Collections.List.length with lst as values is equal to 0:
    Return 0.0 Match strategy:
    When "mean":
    Return Math.mean with values as values
    When "median":
    Return Math.median with values as values
    When "mode":
    Return Math.mode with values as values
    When "constant":
    Return 0.0
    When "forward_fill":
    Return values[Collections.List.length with lst as values - 1]
    When "backward_fill":
    Return values[0]
    Otherwise:
    Return Math.mean with values as values

Process called "is_missing_value" that takes value as Float returns Boolean:
    Return Math.is_nan with x as value or value is equal to Math.infinity or value is equal to Math.negative_infinity

Note: Outlier detection and treatment
Process called "remove_outliers" that takes dataset as Algorithms.Dataset and method as String returns Algorithms.Dataset:
    Let outlier_detector be create_outlier_detector with method as method
    fit_outlier_detector with detector as outlier_detector and dataset as dataset
    Return remove_outlier_samples with detector as outlier_detector and dataset as dataset

Process called "create_outlier_detector" that takes method as String returns OutlierDetector:
    Return OutlierDetector with:
    method as method
    threshold as get_default_outlier_threshold with method as method
    lower_bounds as list
    upper_bounds as list
    fitted as false

Process called "fit_outlier_detector" that takes detector as OutlierDetector and dataset as Algorithms.Dataset:
    Match detector.method:
    When "iqr":
    fit_iqr_outlier_detector with detector as detector and dataset as dataset
    When "z_score":
    fit_zscore_outlier_detector with detector as detector and dataset as dataset
    When "isolation_forest":
    fit_isolation_forest_outlier_detector with detector as detector and dataset as dataset
    Otherwise:
    fit_iqr_outlier_detector with detector as detector and dataset as dataset Set detector.fitted to true

Process called "fit_iqr_outlier_detector" that takes detector as OutlierDetector and dataset as Algorithms.Dataset:
    For j from 0 to dataset.feature_count - 1:
    Let feature_values be extract_feature_column_values with dataset as dataset and column as j
    Let q1 be compute_percentile with values as feature_values and percentile as 25.0
    Let q3 be compute_percentile with values as feature_values and percentile as 75.0
    Let iqr be q3 - q1 Let lower_bound be q1 - detector.threshold multiplied by iqr
    Let upper_bound be q3 detector.threshold multiplied by iqr Add lower_bound to detector.lower_bounds
    Add upper_bound to detector.upper_bounds

Process called "fit_zscore_outlier_detector" that takes detector as OutlierDetector and dataset as Algorithms.Dataset:
    For j from 0 to dataset.feature_count - 1:
    Let feature_values be extract_feature_column_values with dataset as dataset and column as j
    Let mean as Math.mean with values as feature_values
    Let std as Math.std_dev with values as feature_values Let lower_bound be mean - detector.threshold multiplied by std
    Let upper_bound be mean detector.threshold multiplied by std Add lower_bound to detector.lower_bounds
    Add upper_bound to detector.upper_bounds

Process called "remove_outlier_samples" that takes detector as OutlierDetector and dataset as Algorithms.Dataset returns Algorithms.Dataset:
    Let clean_features be list
    Let clean_targets be list For i from 0 to dataset.sample_count - 1:
    Let is_outlier be false For j from 0 to dataset.feature_count - 1:
    Let value be dataset.features.data[i][j]
    If value is less than detector.lower_bounds[j] or value is greater than detector.upper_bounds[j]:
    Set is_outlier to true
    Break If not is_outlier:
    Add dataset.features.data[i] to clean_features
    Add dataset.targets.data[i] to clean_targets Let clean_matrix be Algorithms.Matrix with:
    rows as Collections.List.length with lst as clean_features
    cols as dataset.feature_count
    data as clean_features Let clean_target_vector be Algorithms.Vector with:
    size as Collections.List.length with lst as clean_targets
    data as clean_targets Return Algorithms.Dataset with:
    features as clean_matrix
    targets as clean_target_vector
    feature_names as dataset.feature_names
    target_names as dataset.target_names
    sample_count as Collections.List.length with lst as clean_features
    feature_count as dataset.feature_count

Note: Feature scaling and normalization
Process called "standardize_features" that takes dataset as Algorithms.Dataset returns Algorithms.Dataset:
    Let scaler be create_standard_scaler()
    fit_scaler with scaler as scaler and dataset as dataset
    Return transform_features with scaler as scaler and dataset as dataset

Process called "normalize_features" that takes dataset as Algorithms.Dataset returns Algorithms.Dataset:
    Let scaler be create_min_max_scaler()
    fit_scaler with scaler as scaler and dataset as dataset
    Return transform_features with scaler as scaler and dataset as dataset

Process called "create_standard_scaler" returns FeatureScaler:
    Return FeatureScaler with:
    scaling_method as "standard"
    feature_means as list
    feature_stds as list
    feature_mins as list
    feature_maxs as list
    fitted as false

Process called "create_min_max_scaler" returns FeatureScaler:
    Return FeatureScaler with:
    scaling_method as "min_max"
    feature_means as list
    feature_stds as list
    feature_mins as list
    feature_maxs as list
    fitted as false

Process called "fit_scaler" that takes scaler as FeatureScaler and dataset as Algorithms.Dataset:
    For j from 0 to dataset.feature_count - 1:
    Let feature_values be extract_feature_column_values with dataset as dataset and column as j Add Math.mean with values as feature_values to scaler.feature_means
    Add Math.std_dev with values as feature_values to scaler.feature_stds
    Add find_min_value with values as feature_values to scaler.feature_mins
    Add find_max_value with values as feature_values to scaler.feature_maxs Set scaler.fitted to true

Process called "transform_features" that takes scaler as FeatureScaler and dataset as Algorithms.Dataset returns Algorithms.Dataset:
    Let transformed_data be list For i from 0 to dataset.sample_count - 1:
    Let transformed_sample be list For j from 0 to dataset.feature_count - 1:
    Let original_value be dataset.features.data[i][j]
    Let transformed_value be transform_single_feature with scaler as scaler and value as original_value and feature_index as j
    Add transformed_value to transformed_sample Add transformed_sample to transformed_data Let transformed_matrix be Algorithms.Matrix with:
    rows as dataset.sample_count
    cols as dataset.feature_count
    data as transformed_data Return Algorithms.Dataset with:
    features as transformed_matrix
    targets as dataset.targets
    feature_names as dataset.feature_names
    target_names as dataset.target_names
    sample_count as dataset.sample_count
    feature_count as dataset.feature_count

Process called "transform_single_feature" that takes scaler as FeatureScaler and value as Float and feature_index as Integer returns Float:
    Match scaler.scaling_method:
    When "standard":
    If scaler.feature_stds[feature_index] is greater than 0.0:
    Return value - scaler.feature_means[feature_index] divided by scaler.feature_stds[feature_index]
    Return 0.0
    When "min_max":
    Let range_val be scaler.feature_maxs[feature_index] minus scaler.feature_mins[feature_index]
    If range_val is greater than 0.0:
    Return value - scaler.feature_mins[feature_index] divided by range_val
    Return 0.0
    When "robust":
    Return value Note: Simplified - would use median and IQR
    Otherwise:
    Return value

Note: Categorical encoding
Process called "encode_categorical_features" that takes dataset as Algorithms.Dataset returns Algorithms.Dataset:
    Let encoder be create_one_hot_encoder()
    Return fit_transform_categorical with encoder as encoder and dataset as dataset

Process called "create_one_hot_encoder" returns CategoricalEncoder:
    Return CategoricalEncoder with:
    encoding_method as "one_hot"
    feature_mappings as dictionary
    categories as dictionary
    fitted as false

Process called "create_label_encoder" returns CategoricalEncoder:
    Return CategoricalEncoder with:
    encoding_method as "label"
    feature_mappings as dictionary
    categories as dictionary
    fitted as false

Process called "fit_transform_categorical" that takes encoder as CategoricalEncoder and dataset as Algorithms.Dataset returns Algorithms.Dataset:
    Note: Identify categorical features (simplified - assumes strings or limited unique values)
    Let categorical_columns be identify_categorical_columns with dataset as dataset If Collections.List.length with lst as categorical_columns is equal to 0:
    Return dataset Match encoder.encoding_method:
    When "one_hot":
    Return one_hot_encode_features with dataset as dataset and categorical_columns as categorical_columns and encoder as encoder
    When "label":
    Return label_encode_features with dataset as dataset and categorical_columns as categorical_columns and encoder as encoder
    Otherwise:
    Return dataset

Process called "identify_categorical_columns" that takes dataset as Algorithms.Dataset returns List[Integer]:
    Let categorical_columns be list For j from 0 to dataset.feature_count - 1:
    Let unique_values be count_unique_values_in_column with dataset as dataset and column as j
    If unique_values is less than or equal to 10: Note: Heuristic for categorical
    Add j to categorical_columns Return categorical_columns

Process called "one_hot_encode_features" that takes dataset as Algorithms.Dataset and categorical_columns as List[Integer] and encoder as CategoricalEncoder returns Algorithms.Dataset:
    Let encoded_features be list
    Let new_feature_names be list Note: Build category mappings first
    For each cat_col in categorical_columns:
    Let unique_values be get_unique_categorical_values with dataset as dataset and column as cat_col
    Set encoder.categories[String.from with value as cat_col] to unique_values Note: Process each sample
    For i from 0 to dataset.sample_count - 1:
    Let encoded_sample be list Note: Add non-categorical features
    For j from 0 to dataset.feature_count - 1:
    If j not in categorical_columns:
    Add dataset.features.data[i][j] to encoded_sample
    If i is equal to 0:
    Add dataset.feature_names[j] to new_feature_names Note: Add one-hot encoded categorical features
    For each cat_col in categorical_columns:
    Let category_value be Integer.from with value as dataset.features.data[i][cat_col]
    Let categories be encoder.categories[String.from with value as cat_col] For each category in categories:
    If category_value is equal to category:
    Add 1.0 to encoded_sample
    Otherwise:
    Add 0.0 to encoded_sample If i is equal to 0:
    Add dataset.feature_names[cat_col] followed by "_" followed by String.from with value as category to new_feature_names Add encoded_sample to encoded_features Let encoded_matrix be Algorithms.Matrix with:
    rows as dataset.sample_count
    cols as Collections.List.length with lst as new_feature_names
    data as encoded_features Return Algorithms.Dataset with:
    features as encoded_matrix
    targets as dataset.targets
    feature_names as new_feature_names
    target_names as dataset.target_names
    sample_count as dataset.sample_count
    feature_count as Collections.List.length with lst as new_feature_names

Note: Data validation and quality assessment
Process called "assess_data_quality" that takes dataset as Algorithms.Dataset returns Dictionary[String, Any]:
    Let quality_report be dictionary Set quality_report["sample_count"] to dataset.sample_count
    Set quality_report["feature_count"] to dataset.feature_count
    Set quality_report["missing_values"] to count_missing_values with dataset as dataset
    Set quality_report["duplicate_samples"] to count_duplicate_samples with dataset as dataset
    Set quality_report["feature_correlations"] to compute_feature_correlations with dataset as dataset
    Set quality_report["outlier_counts"] to count_outliers_per_feature with dataset as dataset
    Set quality_report["data_types"] to infer_feature_data_types with dataset as dataset Return quality_report

Process called "count_missing_values" that takes dataset as Algorithms.Dataset returns Dictionary[String, Integer]:
    Let missing_counts be dictionary For j from 0 to dataset.feature_count - 1:
    Let missing_count be 0
    For i from 0 to dataset.sample_count - 1:
    If is_missing_value with value as dataset.features.data[i][j]:
    Set missing_count to missing_count 1
    Set missing_counts[dataset.feature_names[j]] to missing_count Return missing_counts

Process called "count_duplicate_samples" that takes dataset as Algorithms.Dataset returns Integer:
    Let seen_samples be list
    Let duplicate_count be 0 For i from 0 to dataset.sample_count - 1:
    Let sample_signature be compute_sample_signature with sample as dataset.features.data[i]
    If sample_signature in seen_samples:
    Set duplicate_count to duplicate_count 1
    Otherwise:
    Add sample_signature to seen_samples Return duplicate_count

Note: Imbalanced data handling
Process called "balance_dataset" that takes dataset as Algorithms.Dataset and method as String returns Algorithms.Dataset:
    Match method:
    When "smote":
    Return apply_smote with dataset as dataset
    When "undersample":
    Return apply_random_undersampling with dataset as dataset
    When "oversample":
    Return apply_random_oversampling with dataset as dataset
    Otherwise:
    Return dataset

Process called "apply_smote" that takes dataset as Algorithms.Dataset returns Algorithms.Dataset:
    Note: Simplified SMOTE implementation
    Let class_counts be count_class_distribution with dataset as dataset
    Let majority_count be find_majority_class_count with class_counts as class_counts Let synthetic_features be list
    Let synthetic_targets be list Note: Generate synthetic samples for minority classes
    For each class_label and count in class_counts:
    If count is less than majority_count:
    Let samples_needed be majority_count - count
    For i from 0 to samples_needed - 1:
    Let synthetic_sample be generate_synthetic_sample with dataset as dataset and target_class as class_label
    Add synthetic_sample.features to synthetic_features
    Add synthetic_sample.target to synthetic_targets Note: Combine original and synthetic data
    Let combined_features be combine_feature_matrices with original as dataset.features and synthetic as create_matrix_from_list with data as synthetic_features
    Let combined_targets be combine_target_vectors with original as dataset.targets and synthetic as create_vector_from_list with data as synthetic_targets Return Algorithms.Dataset with:
    features as combined_features
    targets as combined_targets
    feature_names as dataset.feature_names
    target_names as dataset.target_names
    sample_count as combined_features.rows
    feature_count as dataset.feature_count

Note: Utility functions
Process called "get_default_outlier_threshold" that takes method as String returns Float:
    Match method:
    When "iqr":
    Return 1.5
    When "z_score":
    Return 3.0
    When "isolation_forest":
    Return 0.1
    Otherwise:
    Return 1.5

Process called "extract_feature_column_values" that takes dataset as Algorithms.Dataset and column as Integer returns List[Float]:
    Let column_values be list
    For i from 0 to dataset.sample_count - 1:
    Add dataset.features.data[i][column] to column_values
    Return column_values

Process called "compute_percentile" that takes values as List[Float] and percentile as Float returns Float:
    Note: Simplified percentile calculation
    Let sorted_values be sort_list with list as values
    Let index be Integer.from with value as percentile divided by 100.0 multiplied by Float.from with value as Collections.List.length with lst as sorted_values - 1
    Return sorted_values[index]

Process called "find_min_value" that takes values as List[Float] returns Float:
    Let min_val be values[0]
    For each value in values:
    If value is less than min_val:
    Set min_val to value
    Return min_val

Process called "find_max_value" that takes values as List[Float] returns Float:
    Let max_val be values[0]
    For each value in values:
    If value is greater than max_val:
    Set max_val to value
    Return max_val

Process called "count_unique_values_in_column" that takes dataset as Algorithms.Dataset and column as Integer returns Integer:
    Let unique_values be list
    For i from 0 to dataset.sample_count - 1:
    Let value be dataset.features.data[i][column]
    If value not in unique_values:
    Add value to unique_values
    Return Collections.List.length with lst as unique_values

Process called "get_unique_categorical_values" that takes dataset as Algorithms.Dataset and column as Integer returns List[Integer]:
    Let unique_values be list
    For i from 0 to dataset.sample_count - 1:
    Let value be Integer.from with value as dataset.features.data[i][column]
    If value not in unique_values:
    Add value to unique_values
    Return unique_values

Process called "compute_feature_correlations" that takes dataset as Algorithms.Dataset returns Dictionary[String, Float]:
    Note: Simplified correlation computation
    Return dictionary

Process called "count_outliers_per_feature" that takes dataset as Algorithms.Dataset returns Dictionary[String, Integer]:
    Let outlier_detector be create_outlier_detector with method as "iqr"
    fit_outlier_detector with detector as outlier_detector and dataset as dataset Let outlier_counts be dictionary
    For j from 0 to dataset.feature_count - 1:
    Let outlier_count be 0
    For i from 0 to dataset.sample_count - 1:
    Let value be dataset.features.data[i][j]
    If value is less than outlier_detector.lower_bounds[j] or value is greater than outlier_detector.upper_bounds[j]:
    Set outlier_count to outlier_count 1
    Set outlier_counts[dataset.feature_names[j]] to outlier_count Return outlier_counts

Process called "infer_feature_data_types" that takes dataset as Algorithms.Dataset returns Dictionary[String, String]:
    Let data_types be dictionary
    For j from 0 to dataset.feature_count - 1:
    Set data_types[dataset.feature_names[j]] to "numeric"
    Return data_types

Process called "compute_sample_signature" that takes sample as List[Float] returns String:
    Note: Create unique identifier for sample
    Let signature be ""
    For each value in sample:
    Set signature to signature followed by String.from with value as value followed by "_"
    Return signature

Process called "count_class_distribution" that takes dataset as Algorithms.Dataset returns Dictionary[Float, Integer]:
    Let class_counts be dictionary
    For i from 0 to dataset.sample_count - 1:
    Let class_label be dataset.targets.data[i]
    If class_label in class_counts:
    Set class_counts[class_label] to class_counts[class_label] 1
    Otherwise:
    Set class_counts[class_label] to 1
    Return class_counts

Process called "find_majority_class_count" that takes class_counts as Dictionary[Float, Integer] returns Integer:
    Let max_count be 0
    For each class_label and count in class_counts:
    If count is greater than max_count:
    Set max_count to count
    Return max_count

Process called "sort_list" that takes list as List[Float] returns List[Float]:
    Note: Would sort list in ascending order
    Return list

Process called "fit_isolation_forest_outlier_detector" that takes detector as OutlierDetector and dataset as Algorithms.Dataset:
    Note: Simplified isolation forest implementation
    For j from 0 to dataset.feature_count - 1:
    Add 0.0 to detector.lower_bounds
    Add 1.0 to detector.upper_bounds