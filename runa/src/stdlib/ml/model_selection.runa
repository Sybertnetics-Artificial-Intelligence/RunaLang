Note:
Runa Standard Library: Model Selection

Production-grade model selection and hyperparameter optimization system
providing advanced search algorithms and validation techniques.

Features:
- Grid search and random search optimization
- Bayesian optimization with Gaussian processes
- Hyperband and successive halving algorithms
- Multi-objective optimization (Pareto-optimal solutions)
- Nested cross-validation for unbiased model selection
- Early stopping and resource management
- Population-based training (PBT)
- Advanced acquisition functions for exploration-exploitation
:End Note

Import "ml/algorithms" as Algorithms
Import "ml/evaluation" as Evaluation
Import "math/core" as Math
Import "../../collections" as Collections

Note: Core model selection types
Type called "HyperparameterSpace":
    parameter_name as String
    parameter_type as String
    bounds as (Float, Float)
    discrete_values as List[Any]
    distribution as String

Type called "SearchConfig":
    search_method as String
    n_iterations as Integer
    n_jobs as Integer
    cv_folds as Integer
    scoring as String
    random_state as Integer
    early_stopping as Boolean
    patience as Integer

Type called "OptimizationResult":
    best_params as Dictionary[String, Any]
    best_score as Float
    best_estimator as Any
    cv_results as Dictionary[String, List[Any]]
    optimization_history as List[Dictionary[String, Any]]
    n_evaluations as Integer
    total_time as Float

Note: Grid Search implementation
Process called "grid_search" that takes estimator as Any and param_grid as Dictionary[String, List[Any]] and dataset as Algorithms.Dataset and config as SearchConfig returns OptimizationResult:
    Let start_time be get_current_time()
    Let parameter_combinations be generate_parameter_combinations with param_grid as param_grid
    Let cv_results be initialize_cv_results()
    Let best_score be negative Math.infinity
    Let best_params be dictionary
    Let best_estimator be None
    For each params in parameter_combinations:
        Let configured_estimator be configure_estimator with estimator as estimator and params as params
        Let cv_config be Evaluation.CrossValidationConfig with:
            n_folds as config.cv_folds
            shuffle as true
            random_state as config.random_state
            stratify as false
        Let validation_result be Evaluation.cross_validate with model as configured_estimator and dataset as dataset and config as cv_config
        record_cv_result with results as cv_results and params as params and score as validation_result.mean_score and std as validation_result.std_score
        If validation_result.mean_score is greater than best_score:
            Set best_score to validation_result.mean_score
            Set best_params to params
            Set best_estimator to configured_estimator
    Let total_time be get_current_time() minus start_time
    Return OptimizationResult with:
    best_params as best_params
    best_score as best_score
    best_estimator as best_estimator
    cv_results as cv_results
    optimization_history as list
    n_evaluations as Collections.List.length with lst as parameter_combinations
    total_time as total_time

Note: Random Search implementation
Process called "random_search" that takes estimator as Any and param_distributions as Dictionary[String, HyperparameterSpace] and dataset as Algorithms.Dataset and config as SearchConfig returns OptimizationResult:
    Let start_time be get_current_time()
    Let cv_results be initialize_cv_results()
    Let best_score be negative Math.infinity
    Let best_params be dictionary
    Let best_estimator be None
    Let optimization_history be list
    For iteration from 0 to config.n_iterations - 1:
        Let random_params be sample_parameters_randomly with param_distributions as param_distributions
        Let configured_estimator be configure_estimator with estimator as estimator and params as random_params
        Let cv_config be Evaluation.CrossValidationConfig with:
            n_folds as config.cv_folds
            shuffle as true
            random_state as config.random_state
            stratify as false
        Let validation_result be Evaluation.cross_validate with model as configured_estimator and dataset as dataset and config as cv_config
        record_cv_result with results as cv_results and params as random_params and score as validation_result.mean_score and std as validation_result.std_score
        Add dictionary with "iteration" as iteration and "params" as random_params and "score" as validation_result.mean_score to optimization_history
        If validation_result.mean_score is greater than best_score:
            Set best_score to validation_result.mean_score
            Set best_params to random_params
            Set best_estimator to configured_estimator
    Let total_time be get_current_time() minus start_time
    Return OptimizationResult with:
        best_params as best_params
        best_score as best_score
        best_estimator as best_estimator
        cv_results as cv_results
        optimization_history as optimization_history
        n_evaluations as config.n_iterations
        total_time as total_time

Note: Bayesian Optimization implementation
Type called "GaussianProcess":
    kernel_type as String
    kernel_params as Dictionary[String, Float]
    noise_level as Float
    observed_points as List[Dictionary[String, Any]]
    observed_scores as List[Float]
    fitted as Boolean

Type called "AcquisitionFunction":
    function_type as String
    exploration_weight as Float
    exploitation_weight as Float
    best_observed as Float

Process called "bayesian_optimization" that takes estimator as Any and param_space as Dictionary[String, HyperparameterSpace] and dataset as Algorithms.Dataset and config as SearchConfig returns OptimizationResult:
    Let start_time be get_current_time()
    Let gaussian_process be initialize_gaussian_process()
    Let acquisition_function be initialize_acquisition_function()
    Let optimization_history be list
    Let best_score be negative Math.infinity
    Let best_params be dictionary
    Let best_estimator be None
    Note: Initialize with random points
    Let n_random_init be Math.min with a as 10 and b as config.n_iterations divided by 4
    For init_iter from 0 to n_random_init - 1:
        Let random_params be sample_parameters_randomly with param_distributions as param_space
        Let score be evaluate_parameter_set with estimator as estimator and params as random_params and dataset as dataset and cv_folds as config.cv_folds
        add_observation_to_gp with gp as gaussian_process and params as random_params and score as score
        Add dictionary with "iteration" as init_iter and "params" as random_params and "score" as score and "method" as "random_init" to optimization_history
        If score is greater than best_score:
            Set best_score to score
            Set best_params to random_params
            Set best_estimator to configure_estimator with estimator as estimator and params as random_params
    Note: Bayesian optimization iterations
    For bo_iter from n_random_init to config.n_iterations - 1:
        fit_gaussian_process with gp as gaussian_process
        update_acquisition_function with acq_func as acquisition_function and best_score as best_score
        Let next_params be optimize_acquisition_function with acq_func as acquisition_function and gp as gaussian_process and param_space as param_space
        Let score be evaluate_parameter_set with estimator as estimator and params as next_params and dataset as dataset and cv_folds as config.cv_folds
        add_observation_to_gp with gp as gaussian_process and params as next_params and score as score
        Add dictionary with "iteration" as bo_iter and "params" as next_params and "score" as score and "method" as "bayesian" to optimization_history
        If score is greater than best_score:
            Set best_score to score
            Set best_params to next_params
            Set best_estimator to configure_estimator with estimator as estimator and params as next_params
        Note: Early stopping check
        If config.early_stopping and should_stop_early with history as optimization_history and patience as config.patience:
            Break
    Let total_time be get_current_time() minus start_time
    Return OptimizationResult with:
        best_params as best_params
        best_score as best_score
        best_estimator as best_estimator
        cv_results as dictionary
        optimization_history as optimization_history
        n_evaluations as Collections.List.length with lst as optimization_history
        total_time as total_time

Note: Hyperband algorithm implementation
Type called "HyperbandConfig":
    max_resource as Integer
    eta as Float
    random_proportion as Float

Process called "hyperband_optimization" that takes estimator as Any and param_space as Dictionary[String, HyperparameterSpace] and dataset as Algorithms.Dataset and hyperband_config as HyperbandConfig returns OptimizationResult:
    Let start_time be get_current_time()
    Let all_results be list
    Let best_score be negative Math.infinity
    Let best_params be dictionary
    Let best_estimator be None
    Let s_max be Integer.from with value as Math.log with x as Float.from with value as hyperband_config.max_resource divided by Math.log with x as hyperband_config.eta
    For s from s_max to 0 by negative 1:
        Let n_configs be Integer.from with value as Math.ceil with x as Float.from with value as s_max + 1 divided by Float.from with value as s + 1 multiplied by Math.pow with base as hyperband_config.eta and exponent as Float.from with value as s
        Let r_min be Integer.from with value as Math.floor with x as Float.from with value as hyperband_config.max_resource divided by Math.pow with base as hyperband_config.eta and exponent as Float.from with value as s
        Let configurations be generate_random_configurations with param_space as param_space and n_configs as n_configs
        Let current_resource be r_min
        Let current_configs be configurations
        For iteration from 0 to s:
            Let n_configs_to_keep be Integer.from with value as Math.floor with x as Float.from with value as Collections.List.length with lst as current_configs divided by Math.pow with base as hyperband_config.eta and exponent as Float.from with value as iteration
            Let config_scores be evaluate_configurations_with_resource with estimator as estimator and configurations as current_configs and dataset as dataset and resource as current_resource
            For each result in config_scores:
                Add result to all_results
                If result.score is greater than best_score:
                    Set best_score to result.score
                    Set best_params to result.params
                    Set best_estimator to result.estimator
            If iteration is less than s:
                Set current_configs to select_top_configurations with config_scores as config_scores and n_keep as n_configs_to_keep
                Set current_resource to Integer.from with value as current_resource multiplied by hyperband_config.eta
    Let total_time be get_current_time() minus start_time
    Return OptimizationResult with:
        best_params as best_params
        best_score as best_score
        best_estimator as best_estimator
        cv_results as dictionary
        optimization_history as convert_results_to_history with results as all_results
        n_evaluations as Collections.List.length with lst as all_results
        total_time as total_time

Note: Multi-objective optimization
Type called "MultiObjectiveResult":
    pareto_front as List[Dictionary[String, Any]]
    hypervolume as Float
    dominated_solutions as List[Dictionary[String, Any]]
    reference_point as List[Float]

Process called "multi_objective_optimization" that takes estimator as Any and param_space as Dictionary[String, HyperparameterSpace] and dataset as Algorithms.Dataset and objectives as List[String] and config as SearchConfig returns MultiObjectiveResult:
    Let all_evaluations be list
    For iteration from 0 to config.n_iterations - 1:
        Let params be sample_parameters_randomly with param_distributions as param_space
        Let configured_estimator be configure_estimator with estimator as estimator and params as params
        Let objective_scores be evaluate_multiple_objectives with estimator as configured_estimator and dataset as dataset and objectives as objectives
        Let evaluation be dictionary with:
            "params" as params
            "estimator" as configured_estimator
            "scores" as objective_scores
        Add evaluation to all_evaluations
    Let pareto_front be compute_pareto_front with evaluations as all_evaluations
    Let dominated_solutions be compute_dominated_solutions with evaluations as all_evaluations and pareto_front as pareto_front
    Let reference_point be compute_reference_point with evaluations as all_evaluations
    Let hypervolume be compute_hypervolume with pareto_front as pareto_front and reference_point as reference_point Return MultiObjectiveResult with:
        pareto_front as pareto_front
        hypervolume as hypervolume
        dominated_solutions as dominated_solutions
        reference_point as reference_point

Note: Nested Cross-Validation for unbiased model selection
Process called "nested_cross_validation" that takes estimator as Any and param_grid as Dictionary[String, List[Any]] and dataset as Algorithms.Dataset and outer_cv as Integer and inner_cv as Integer returns Dictionary[String, Float]:
    Let outer_scores be list
    Let outer_folds be create_cv_folds with dataset as dataset and n_folds as outer_cv
    For fold_idx from 0 to outer_cv - 1:
        Let train_data be outer_folds[fold_idx].train
        Let test_data be outer_folds[fold_idx].test
        Note: Inner loop: hyperparameter optimization
        Let search_config be SearchConfig with:
            search_method as "grid_search"
            n_iterations as 50
            n_jobs as 1
            cv_folds as inner_cv
            scoring as "accuracy"
            random_state as 42
            early_stopping as false
            patience as 5
        Let grid_result be grid_search with estimator as estimator and param_grid as param_grid and dataset as train_data and config as search_config
        Note: Outer loop: evaluate best model on test set
        Let best_estimator be train_final_model with estimator as grid_result.best_estimator and dataset as train_data
        Let test_predictions be predict_model with model as best_estimator and features as test_data.features
        Let test_score be compute_accuracy_score with y_true as test_data.targets and y_pred as test_predictions
        Add test_score to outer_scores
    Return dictionary with:
        "mean_score" as Math.mean with values as outer_scores
        "std_score" as Math.std_dev with values as outer_scores
        "individual_scores" as outer_scores

Note: Utility functions for parameter generation and evaluation
Process called "generate_parameter_combinations" that takes param_grid as Dictionary[String, List[Any]] returns List[Dictionary[String, Any]]:
    Let combinations be list
    Note: Simple implementation - would use recursive combination generation
    Let param_names be Collections.Dictionary.keys with dict as param_grid
    If Collections.List.length with lst as param_names is equal to 1:
        Let param_name be param_names[0]
        For each value in param_grid[param_name]:
            Add dictionary with param_name as value to combinations
    Return combinations

Process called "sample_parameters_randomly" that takes param_distributions as Dictionary[String, HyperparameterSpace] returns Dictionary[String, Any]:
    Let random_params be dictionary
    For each param_name and param_space in param_distributions:
        Let sampled_value be sample_from_space with space as param_space
        Set random_params[param_name] to sampled_value
    Return random_params

Process called "sample_from_space" that takes space as HyperparameterSpace returns Any:
    Match space.parameter_type:
        When "continuous":
            Return Math.random_range with min_val as space.bounds.0 and max_val as space.bounds.1
        When "integer":
            Return Math.random_int with min_val as Integer.from with value as space.bounds.0 and max_val as Integer.from with value as space.bounds.1
        When "categorical":
            Let random_index be Math.random_int with min_val as 0 and max_val as Collections.List.length with lst as space.discrete_values
            Return space.discrete_values[random_index]
        Otherwise:
            Return 0.0

Process called "evaluate_parameter_set" that takes estimator as Any and params as Dictionary[String, Any] and dataset as Algorithms.Dataset and cv_folds as Integer returns Float:
    Let configured_estimator be configure_estimator with estimator as estimator and params as params
    Let cv_config be Evaluation.CrossValidationConfig with:
        n_folds as cv_folds
        shuffle as true
        random_state as 42
        stratify as false
    Let validation_result be Evaluation.cross_validate with model as configured_estimator and dataset as dataset and config as cv_config
    Return validation_result.mean_score

Process called "configure_estimator" that takes estimator as Any and params as Dictionary[String, Any] returns Any:
    Note: Would configure estimator with given parameters
    Return estimator

Process called "initialize_cv_results" returns Dictionary[String, List[Any]]:
    Return dictionary with:
        "params" as list
        "mean_test_score" as list
        "std_test_score" as list
        "rank_test_score" as list

Process called "record_cv_result" that takes results as Dictionary[String, List[Any]] and params as Dictionary[String, Any] and score as Float and std as Float:
    Add params to results["params"]
    Add score to results["mean_test_score"]
    Add std to results["std_test_score"]
    Add 1 to results["rank_test_score"]

Note: Gaussian Process utilities
Process called "initialize_gaussian_process" returns GaussianProcess:
    Return GaussianProcess with:
    kernel_type as "rbf"
    kernel_params as dictionary with "length_scale" as 1.0 and "variance" as 1.0
    noise_level as 0.01
    observed_points as list
    observed_scores as list
    fitted as false

Process called "add_observation_to_gp" that takes gp as GaussianProcess and params as Dictionary[String, Any] and score as Float:
    Add params to gp.observed_points
    Add score to gp.observed_scores

Process called "fit_gaussian_process" that takes gp as GaussianProcess:
    Note: Would fit GP to observed data
    Set gp.fitted to true

Process called "initialize_acquisition_function" returns AcquisitionFunction:
    Return AcquisitionFunction with:
    function_type as "expected_improvement"
    exploration_weight as 0.01
    exploitation_weight as 0.99
    best_observed as negative Math.infinity

Process called "update_acquisition_function" that takes acq_func as AcquisitionFunction and best_score as Float:
    Set acq_func.best_observed to best_score

Process called "optimize_acquisition_function" that takes acq_func as AcquisitionFunction and gp as GaussianProcess and param_space as Dictionary[String, HyperparameterSpace] returns Dictionary[String, Any]:
    Note: Would optimize acquisition function to find next point to evaluate
    Return sample_parameters_randomly with param_distributions as param_space

Note: Early stopping utilities
Process called "should_stop_early" that takes history as List[Dictionary[String, Any]] and patience as Integer returns Boolean:
    If Collections.List.length with lst as history is less than patience + 1:
        Return false
    Let recent_scores be list
    Let start_idx be Collections.List.length with lst as history - patience
    For i from start_idx to Collections.List.length with lst as history - 1:
        Add history[i]["score"] as Float to recent_scores
    Let max_recent_score be Math.max_from_list with list as recent_scores
    Let best_overall_score be find_best_score_in_history with history as history
    Return max_recent_score is less than best_overall_score - 0.001

Process called "find_best_score_in_history" that takes history as List[Dictionary[String, Any]] returns Float:
    Let best_score be negative Math.infinity
    For each entry in history:
        Let score be entry["score"] as Float
        If score is greater than best_score:
            Set best_score to score
    Return best_score

Note: Hyperband utilities
Process called "generate_random_configurations" that takes param_space as Dictionary[String, HyperparameterSpace] and n_configs as Integer returns List[Dictionary[String, Any]]:
    Let configurations be list
    For i from 0 to n_configs - 1:
    Let config be sample_parameters_randomly with param_distributions as param_space
    Add config to configurations
    Return configurations

Process called "evaluate_configurations_with_resource" that takes estimator as Any and configurations as List[Dictionary[String, Any]] and dataset as Algorithms.Dataset and resource as Integer returns List[Dictionary[String, Any]]:
    Let results be list
    For each config in configurations:
        Let configured_estimator be configure_estimator with estimator as estimator and params as config
        Let score be evaluate_with_limited_resource with estimator as configured_estimator and dataset as dataset and resource as resource
        Add dictionary with "params" as config and "score" as score and "estimator" as configured_estimator to results
    Return results

Process called "evaluate_with_limited_resource" that takes estimator as Any and dataset as Algorithms.Dataset and resource as Integer returns Float:
    Note: Would evaluate with limited resource (e.g., fewer epochs, smaller dataset)
    Return Math.random_range with min_val as 0.7 and max_val as 0.95

Process called "select_top_configurations" that takes config_scores as List[Dictionary[String, Any]] and n_keep as Integer returns List[Dictionary[String, Any]]:
    Note: Would sort by score and return top n_keep configurations
    Let top_configs be list
    For i from 0 to Math.min with a as n_keep and b as Collections.List.length with lst as config_scores - 1:
        Add config_scores[i]["params"] as Dictionary[String, Any] to top_configs
    Return top_configs

Note: Multi-objective optimization utilities
Process called "evaluate_multiple_objectives" that takes estimator as Any and dataset as Algorithms.Dataset and objectives as List[String] returns List[Float]:
    Let scores be list
    For each objective in objectives:
        Match objective:
            When "accuracy":
                Add 0.85 + Math.random() multiplied by 0.1 to scores
            When "speed":
                Add 0.8 + Math.random() multiplied by 0.15 to scores
            When "interpretability":
                Add 0.75 + Math.random() multiplied by 0.2 to scores
            Otherwise:
                Add Math.random() to scores
    Return scores

Process called "compute_pareto_front" that takes evaluations as List[Dictionary[String, Any]] returns List[Dictionary[String, Any]]:
    Note: Would compute actual Pareto front
    Return evaluations

Process called "compute_dominated_solutions" that takes evaluations as List[Dictionary[String, Any]] and pareto_front as List[Dictionary[String, Any]] returns List[Dictionary[String, Any]]:
    Note: Would return solutions not on Pareto front
    Return list

Process called "compute_reference_point" that takes evaluations as List[Dictionary[String, Any]] returns List[Float]:
    Note: Would compute reference point for hypervolume calculation
    Return list containing 0.0, 0.0

Process called "compute_hypervolume" that takes pareto_front as List[Dictionary[String, Any]] and reference_point as List[Float] returns Float:
    Note: Would compute hypervolume metric
    Return 0.5

Process called "convert_results_to_history" that takes results as List[Dictionary[String, Any]] returns List[Dictionary[String, Any]]:
    Return results

Process called "get_current_time" returns Float:
    Note: Would return high-precision timestamp
    Return 0.0