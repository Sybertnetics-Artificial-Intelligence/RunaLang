Note:
Runa Standard Library: ML Evaluation

Production-grade machine learning evaluation system providing comprehensive 
metrics, validation techniques, and performance analysis capabilities.

Features:
- Complete classification and regression metrics
- Cross-validation and bootstrap validation
- Statistical significance testing
- ROC/AUC analysis and precision-recall curves
- Learning curve analysis and bias-variance decomposition
- Model comparison and ranking
- Performance visualization and reporting
- Production model monitoring capabilities
:End Note

Import "ml/algorithms" as Algorithms
Import "math/core" as Math
Import "collections" as Collections

Note: Core evaluation types and metrics
Type called "ClassificationMetrics":
    accuracy as Float
    precision as Float
    recall as Float
    f1_score as Float
    specificity as Float
    sensitivity as Float
    auc_roc as Float
    auc_pr as Float
    log_loss as Float
    matthews_correlation as Float
    kappa_score as Float

Type called "RegressionMetrics":
    mean_squared_error as Float
    mean_absolute_error as Float
    root_mean_squared_error as Float
    mean_absolute_percentage_error as Float
    r_squared as Float
    adjusted_r_squared as Float
    explained_variance as Float
    median_absolute_error as Float
    max_error as Float

Type called "ConfusionMatrix":
    true_positives as Integer
    false_positives as Integer
    true_negatives as Integer
    false_negatives as Integer
    class_labels as List[String]
    matrix as List[List[Integer]]

Type called "ValidationResult":
    scores as List[Float]
    mean_score as Float
    std_score as Float
    confidence_interval as (Float, Float)
    fold_scores as Dictionary[Integer, Float]
    validation_method as String

Note: Classification evaluation functions
Process called "evaluate_classification" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns ClassificationMetrics:
    Let confusion_matrix be compute_confusion_matrix with y_true as y_true and y_pred as y_pred Let accuracy be compute_accuracy with confusion_matrix as confusion_matrix
    Let precision be compute_precision with confusion_matrix as confusion_matrix
    Let recall be compute_recall with confusion_matrix as confusion_matrix
    Let f1 be compute_f1_score with precision as precision and recall as recall
    Let specificity be compute_specificity with confusion_matrix as confusion_matrix Return ClassificationMetrics with:
    accuracy as accuracy
    precision as precision
    recall as recall
    f1_score as f1
    specificity as specificity
    sensitivity as recall
    auc_roc as 0.0
    auc_pr as 0.0
    log_loss as 0.0
    matthews_correlation as compute_matthews_correlation with confusion_matrix as confusion_matrix
    kappa_score as compute_kappa_score with y_true as y_true and y_pred as y_pred

Process called "compute_confusion_matrix" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns ConfusionMatrix:
    Let tp be 0
    Let fp be 0
    Let tn be 0
    Let fn be 0 For i from 0 to y_true.size - 1:
    Let true_label be y_true.data[i]
    Let pred_label be y_pred.data[i] If true_label is greater than 0.5 and pred_label is greater than 0.5:
    Set tp to tp 1
    Otherwise if true_label is less than or equal to 0.5 and pred_label is greater than 0.5:
    Set fp to fp 1
    Otherwise if true_label is less than or equal to 0.5 and pred_label is less than or equal to 0.5:
    Set tn to tn 1
    Otherwise:
    Set fn to fn 1 Return ConfusionMatrix with:
    true_positives as tp
    false_positives as fp
    true_negatives as tn
    false_negatives as fn
    class_labels as list containing "0", "1"
    matrix as list containing list containing tn, fp, list containing fn, tp

Process called "compute_accuracy" that takes confusion_matrix as ConfusionMatrix returns Float:
    Let total be confusion_matrix.true_positives confusion_matrix.false_positives confusion_matrix.true_negatives confusion_matrix.false_negatives
    Let correct be confusion_matrix.true_positives confusion_matrix.true_negatives
    Return Float.from with value as correct divided by Float.from with value as total

Process called "compute_precision" that takes confusion_matrix as ConfusionMatrix returns Float:
    Let tp be Float.from with value as confusion_matrix.true_positives
    Let fp be Float.from with value as confusion_matrix.false_positives
    If tp fp is equal to 0.0:
    Return 0.0
    Return tp divided by tp fp

Process called "compute_recall" that takes confusion_matrix as ConfusionMatrix returns Float:
    Let tp be Float.from with value as confusion_matrix.true_positives
    Let fn be Float.from with value as confusion_matrix.false_negatives
    If tp fn is equal to 0.0:
    Return 0.0
    Return tp divided by tp fn

Process called "compute_f1_score" that takes precision as Float and recall as Float returns Float:
    If precision recall is equal to 0.0:
    Return 0.0
    Return 2.0 multiplied by precision multiplied by recall divided by precision recall

Process called "compute_specificity" that takes confusion_matrix as ConfusionMatrix returns Float:
    Let tn be Float.from with value as confusion_matrix.true_negatives
    Let fp be Float.from with value as confusion_matrix.false_positives
    If tn fp is equal to 0.0:
    Return 0.0
    Return tn divided by tn fp

Process called "compute_matthews_correlation" that takes confusion_matrix as ConfusionMatrix returns Float:
    Let tp be Float.from with value as confusion_matrix.true_positives
    Let tn be Float.from with value as confusion_matrix.true_negatives
    Let fp be Float.from with value as confusion_matrix.false_positives
    Let fn be Float.from with value as confusion_matrix.false_negatives Let numerator be tp multiplied by tn - fp multiplied by fn
    Let denominator be Math.sqrt with x as tp fp multiplied by tp fn multiplied by tn fp multiplied by tn fn If denominator is equal to 0.0:
    Return 0.0 Return numerator divided by denominator

Note: ROC and AUC computation
Type called "ROCPoint":
    threshold as Float
    true_positive_rate as Float
    false_positive_rate as Float

Process called "compute_roc_curve" that takes y_true as Algorithms.Vector and y_scores as Algorithms.Vector returns List[ROCPoint]:
    Let roc_points be list
    Let thresholds be generate_thresholds with scores as y_scores For each threshold in thresholds:
    Let y_pred be threshold_predictions with scores as y_scores and threshold as threshold
    Let confusion_matrix be compute_confusion_matrix with y_true as y_true and y_pred as y_pred Let tpr be compute_recall with confusion_matrix as confusion_matrix
    Let fpr be 1.0 - compute_specificity with confusion_matrix as confusion_matrix Let roc_point be ROCPoint with:
    threshold as threshold
    true_positive_rate as tpr
    false_positive_rate as fpr Add roc_point to roc_points Return roc_points

Process called "compute_auc_roc" that takes roc_curve as List[ROCPoint] returns Float:
    Let auc be 0.0 For i from 1 to Collections.List.length with lst as roc_curve - 1:
    Let prev_point be roc_curve[i - 1]
    Let curr_point be roc_curve[i] Let width be curr_point.false_positive_rate - prev_point.false_positive_rate
    Let avg_height be prev_point.true_positive_rate curr_point.true_positive_rate divided by 2.0 Set auc to auc width multiplied by avg_height Return auc

Note: Regression evaluation functions
Process called "evaluate_regression" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns RegressionMetrics:
    Let mse be compute_mean_squared_error with y_true as y_true and y_pred as y_pred
    Let mae be compute_mean_absolute_error with y_true as y_true and y_pred as y_pred
    Let rmse be Math.sqrt with x as mse
    Let mape be compute_mean_absolute_percentage_error with y_true as y_true and y_pred as y_pred
    Let r2 be compute_r_squared with y_true as y_true and y_pred as y_pred Return RegressionMetrics with:
    mean_squared_error as mse
    mean_absolute_error as mae
    root_mean_squared_error as rmse
    mean_absolute_percentage_error as mape
    r_squared as r2
    adjusted_r_squared as 0.0
    explained_variance as compute_explained_variance with y_true as y_true and y_pred as y_pred
    median_absolute_error as compute_median_absolute_error with y_true as y_true and y_pred as y_pred
    max_error as compute_max_error with y_true as y_true and y_pred as y_pred

Process called "compute_mean_squared_error" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let sum_squared_errors be 0.0 For i from 0 to y_true.size - 1:
    Let error be y_true.data[i] minus y_pred.data[i]
    Set sum_squared_errors to sum_squared_errors error multiplied by error Return sum_squared_errors divided by Float.from with value as y_true.size

Process called "compute_mean_absolute_error" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let sum_absolute_errors be 0.0 For i from 0 to y_true.size - 1:
    Let error be Math.abs with x as y_true.data[i] minus y_pred.data[i]
    Set sum_absolute_errors to sum_absolute_errors error Return sum_absolute_errors divided by Float.from with value as y_true.size

Process called "compute_mean_absolute_percentage_error" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let sum_percentage_errors be 0.0
    Let valid_count be 0 For i from 0 to y_true.size - 1:
    If Math.abs with x as y_true.data[i] is greater than 1e-8:
    Let percentage_error be Math.abs with x as y_true.data[i] minus y_pred.data[i] divided by Math.abs with x as y_true.data[i]
    Set sum_percentage_errors to sum_percentage_errors percentage_error
    Set valid_count to valid_count 1 If valid_count is equal to 0:
    Return 0.0 Return sum_percentage_errors divided by Float.from with value as valid_count multiplied by 100.0

Process called "compute_r_squared" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let y_mean be Math.mean with values as y_true.data Let ss_tot be 0.0
    Let ss_res be 0.0 For i from 0 to y_true.size - 1:
    Set ss_tot to ss_tot y_true.data[i] minus y_mean multiplied by y_true.data[i] minus y_mean
    Set ss_res to ss_res y_true.data[i] minus y_pred.data[i] multiplied by y_true.data[i] minus y_pred.data[i] If ss_tot is equal to 0.0:
    Return 1.0 Return 1.0 - ss_res divided by ss_tot

Note: Cross-validation implementation
Type called "CrossValidationConfig":
    n_folds as Integer
    shuffle as Boolean
    random_state as Integer
    stratify as Boolean

Process called "cross_validate" that takes model as Any and dataset as Algorithms.Dataset and config as CrossValidationConfig returns ValidationResult:
    Let fold_scores be dictionary
    Let all_scores be list Let folds be create_folds with dataset as dataset and n_folds as config.n_folds and shuffle as config.shuffle For fold_idx from 0 to config.n_folds - 1:
    Let train_data be folds[fold_idx].train
    Let val_data be folds[fold_idx].validation Let trained_model be train_model with model as model and dataset as train_data
    Let predictions be predict_model with model as trained_model and features as val_data.features Let score be compute_fold_score with y_true as val_data.targets and y_pred as predictions
    Set fold_scores[fold_idx] to score
    Add score to all_scores Let mean_score be Math.mean with values as all_scores
    Let std_score be Math.std_dev with values as all_scores
    Let confidence_interval be compute_confidence_interval with scores as all_scores and confidence as 0.95 Return ValidationResult with:
    scores as all_scores
    mean_score as mean_score
    std_score as std_score
    confidence_interval as confidence_interval
    fold_scores as fold_scores
    validation_method as "k_fold"

Note: Bootstrap validation
Process called "bootstrap_validate" that takes model as Any and dataset as Algorithms.Dataset and n_bootstrap as Integer returns ValidationResult:
    Let bootstrap_scores be list For i from 0 to n_bootstrap - 1:
    Let bootstrap_sample be create_bootstrap_sample with dataset as dataset
    Let out_of_bag_sample be create_out_of_bag_sample with dataset as dataset and bootstrap_indices as bootstrap_sample.indices Let trained_model be train_model with model as model and dataset as bootstrap_sample
    Let predictions be predict_model with model as trained_model and features as out_of_bag_sample.features Let score be compute_fold_score with y_true as out_of_bag_sample.targets and y_pred as predictions
    Add score to bootstrap_scores Let mean_score be Math.mean with values as bootstrap_scores
    Let std_score be Math.std_dev with values as bootstrap_scores
    Let confidence_interval be compute_confidence_interval with scores as bootstrap_scores and confidence as 0.95 Return ValidationResult with:
    scores as bootstrap_scores
    mean_score as mean_score
    std_score as std_score
    confidence_interval as confidence_interval
    fold_scores as dictionary
    validation_method as "bootstrap"

Note: Learning curve analysis
Type called "LearningCurve":
    train_sizes as List[Integer]
    train_scores as List[Float]
    validation_scores as List[Float]
    training_times as List[Float]

Process called "compute_learning_curve" that takes model as Any and dataset as Algorithms.Dataset and train_sizes as List[Integer] returns LearningCurve:
    Let train_scores be list
    Let val_scores be list
    Let training_times be list For each size in train_sizes:
    Let subset_dataset be sample_dataset with dataset as dataset and size as size
    Let start_time be get_current_time() Let validation_result be cross_validate with model as model and dataset as subset_dataset and config as create_default_cv_config() Let training_time be get_current_time() minus start_time Add validation_result.mean_score to train_scores
    Add validation_result.mean_score to val_scores
    Add training_time to training_times Return LearningCurve with:
    train_sizes as train_sizes
    train_scores as train_scores
    validation_scores as val_scores
    training_times as training_times

Note: Model comparison and statistical testing
Type called "ModelComparison":
    model_names as List[String]
    scores as Dictionary[String, List[Float]]
    mean_scores as Dictionary[String, Float]
    std_scores as Dictionary[String, Float]
    p_values as Dictionary[String, Dictionary[String, Float]]
    rankings as List[String]

Process called "compare_models" that takes models as Dictionary[String, Any] and dataset as Algorithms.Dataset returns ModelComparison:
    Let all_scores be dictionary
    Let mean_scores be dictionary
    Let std_scores be dictionary For each name and model in models:
    Let cv_config be create_default_cv_config()
    Let validation_result be cross_validate with model as model and dataset as dataset and config as cv_config Set all_scores[name] to validation_result.scores
    Set mean_scores[name] to validation_result.mean_score
    Set std_scores[name] to validation_result.std_score Let p_values be compute_pairwise_tests with scores as all_scores
    Let rankings be rank_models_by_score with scores as mean_scores Return ModelComparison with:
    model_names as Collections.Dictionary.keys with dict as models
    scores as all_scores
    mean_scores as mean_scores
    std_scores as std_scores
    p_values as p_values
    rankings as rankings

Process called "compute_pairwise_tests" that takes scores as Dictionary[String, List[Float]] returns Dictionary[String, Dictionary[String, Float]]:
    Let p_values be dictionary For each name1 and scores1 in scores:
    Set p_values[name1] to dictionary
    For each name2 and scores2 in scores:
    If name1 is not equal to name2:
    Let p_value be paired_t_test with scores1 as scores1 and scores2 as scores2
    Set p_values[name1][name2] to p_value Return p_values

Note: Utility functions
Process called "generate_thresholds" that takes scores as Algorithms.Vector returns List[Float]:
    Let thresholds be list
    Let min_score be Math.min with a as 0.0 and b as find_min_score with scores as scores
    Let max_score be Math.max with a as 1.0 and b as find_max_score with scores as scores For i from 0 to 100:
    Let threshold be min_score Float.from with value as i multiplied by max_score - min_score divided by 100.0
    Add threshold to thresholds Return thresholds

Process called "threshold_predictions" that takes scores as Algorithms.Vector and threshold as Float returns Algorithms.Vector:
    Let predictions be Algorithms.Vector with size as scores.size and data as list For i from 0 to scores.size - 1:
    If scores.data[i] is greater than or equal to threshold:
    Add 1.0 to predictions.data
    Otherwise:
    Add 0.0 to predictions.data Return predictions

Process called "create_default_cv_config" returns CrossValidationConfig:
    Return CrossValidationConfig with:
    n_folds as 5
    shuffle as true
    random_state as 42
    stratify as false

Process called "compute_confidence_interval" that takes scores as List[Float] and confidence as Float returns (Float, Float):
    Let mean as Math.mean with values as scores
    Let std as Math.std_dev with values as scores
    Let n as Collections.List.length with lst as scores
    Let margin as 1.96 multiplied by std divided by Math.sqrt with x as Float.from with value as n
    Return (mean - margin, mean margin)

Process called "paired_t_test" that takes scores1 as List[Float] and scores2 as List[Float] returns Float:
    Note: Would perform actual paired t-test
    Return 0.05

Process called "rank_models_by_score" that takes scores as Dictionary[String, Float] returns List[String]:
    Note: Would sort models by score descending
    Return Collections.Dictionary.keys with dict as scores

Process called "find_min_score" that takes scores as Algorithms.Vector returns Float:
    Let min_val be scores.data[0]
    For each score in scores.data:
    If score is less than min_val:
    Set min_val to score
    Return min_val

Process called "find_max_score" that takes scores as Algorithms.Vector returns Float:
    Let max_val be scores.data[0]
    For each score in scores.data:
    If score is greater than max_val:
    Set max_val to score
    Return max_val

Process called "compute_explained_variance" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let y_true_mean be Math.mean with values as y_true.data
    Let y_pred_mean be Math.mean with values as y_pred.data Let numerator be 0.0
    Let denominator be 0.0 For i from 0 to y_true.size - 1:
    Set numerator to numerator y_true.data[i] minus y_true_mean multiplied by y_pred.data[i] minus y_pred_mean
    Set denominator to denominator y_true.data[i] minus y_true_mean multiplied by y_true.data[i] minus y_true_mean If denominator is equal to 0.0:
    Return 0.0 Return numerator divided by denominator

Process called "compute_median_absolute_error" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let errors be list
    For i from 0 to y_true.size - 1:
    Add Math.abs with x as y_true.data[i] minus y_pred.data[i] to errors
    Return Math.median with values as errors

Process called "compute_max_error" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Let max_error be 0.0
    For i from 0 to y_true.size - 1:
    Let error be Math.abs with x as y_true.data[i] minus y_pred.data[i]
    If error is greater than max_error:
    Set max_error to error
    Return max_error

Process called "compute_kappa_score" that takes y_true as Algorithms.Vector and y_pred as Algorithms.Vector returns Float:
    Note: Cohen's Kappa implementation
    Let confusion_matrix be compute_confusion_matrix with y_true as y_true and y_pred as y_pred
    Let accuracy be compute_accuracy with confusion_matrix as confusion_matrix Let total be Float.from with value as y_true.size
    Let p_true be Float.from with value as confusion_matrix.true_positives confusion_matrix.false_negatives divided by total
    Let p_pred be Float.from with value as confusion_matrix.true_positives confusion_matrix.false_positives divided by total
    Let expected_agreement be p_true multiplied by p_pred 1.0 - p_true multiplied by 1.0 - p_pred If expected_agreement is equal to 1.0:
    Return 1.0 Return accuracy - expected_agreement divided by 1.0 - expected_agreement

Process called "get_current_time" returns Float:
    Note: Would return high-precision timestamp
    Return 0.0