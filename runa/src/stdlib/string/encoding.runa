Note: Base64 Encoding/Decoding Implementation

Let BASE64_ALPHABET be "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
Let BASE64_PADDING be "="

Process called "bytes_to_base64" that takes bytes as List[Integer] returns String:
    Note: Encode byte array to Base64 string per RFC 4648
    Try:
        Let result be ""
        Let length be length of bytes
        Let i be 0
        
        Note: Process groups of 3 bytes
        While i plus 2 is less than length:
            Let byte1 be bytes[i]
            Let byte2 be bytes[i plus 1]
            Let byte3 be bytes[i plus 2]
            
            Note: Convert 3 bytes to 4 Base64 characters
            Let combined be bitwise_or with a as bitwise_or with a as bitwise_left_shift with value as byte1 and bits as 16 and b as bitwise_left_shift with value as byte2 and bits as 8 and b as byte3
            
            Let char1 be character_at with string as BASE64_ALPHABET and index as bitwise_right_shift with value as combined and bits as 18
            Let char2 be character_at with string as BASE64_ALPHABET and index as bitwise_and with a as bitwise_right_shift with value as combined and bits as 12 and b as 63
            Let char3 be character_at with string as BASE64_ALPHABET and index as bitwise_and with a as bitwise_right_shift with value as combined and bits as 6 and b as 63
            Let char4 be character_at with string as BASE64_ALPHABET and index as bitwise_and with a as combined and b as 63
            
            Set result to result plus char1 plus char2 plus char3 plus char4
            Set i to i plus 3
        
        Note: Handle remaining bytes with padding
        If i is equal to length minus 1:
            Let byte1 be bytes[i]
            Let combined be bitwise_left_shift with value as byte1 and bits as 4
            Let char1 be character_at with string as BASE64_ALPHABET and index as bitwise_right_shift with value as combined and bits as 6
            Let char2 be character_at with string as BASE64_ALPHABET and index as bitwise_and with a as combined and b as 63
            Set result to result plus char1 plus char2 plus BASE64_PADDING plus BASE64_PADDING
        Otherwise if i is equal to length minus 2:
            Let byte1 be bytes[i]
            Let byte2 be bytes[i plus 1]
            Let combined be bitwise_or with a as bitwise_left_shift with value as byte1 and bits as 10 and b as bitwise_left_shift with value as byte2 and bits as 2
            Let char1 be character_at with string as BASE64_ALPHABET and index as bitwise_right_shift with value as combined and bits as 12
            Let char2 be character_at with string as BASE64_ALPHABET and index as bitwise_and with a as bitwise_right_shift with value as combined and bits as 6 and b as 63
            Let char3 be character_at with string as BASE64_ALPHABET and index as bitwise_and with a as combined and b as 63
            Set result to result plus char1 plus char2 plus char3 plus BASE64_PADDING
        
        Return result
        
    Catch error:
        Return ""

Process called "string_to_bytes" that takes data as String returns List[Integer]:
    Note: Convert string to UTF-8 byte array
    Try:
        Let result be list containing
        Let length be length of data
        Let i be 0
        
        While i is less than length:
            Let char be character_at with string as data and index as i
            Let code_point be character_to_code_point with char as char
            
            Note: Encode as UTF-8
            If code_point is less than 128:
                Set result to append_to_list with list as result and item as code_point
            Otherwise if code_point is less than 2048:
                Let byte1 be bitwise_or with a as 192 and b as bitwise_right_shift with value as code_point and bits as 6
                Let byte2 be bitwise_or with a as 128 and b as bitwise_and with a as code_point and b as 63
                Set result to append_to_list with list as result and item as byte1
                Set result to append_to_list with list as result and item as byte2
            Otherwise if code_point is less than 65536:
                Let byte1 be bitwise_or with a as 224 and b as bitwise_right_shift with value as code_point and bits as 12
                Let byte2 be bitwise_or with a as 128 and b as bitwise_and with a as bitwise_right_shift with value as code_point and bits as 6 and b as 63
                Let byte3 be bitwise_or with a as 128 and b as bitwise_and with a as code_point and b as 63
                Set result to append_to_list with list as result and item as byte1
                Set result to append_to_list with list as result and item as byte2
                Set result to append_to_list with list as result and item as byte3
            Otherwise:
                Let byte1 be bitwise_or with a as 240 and b as bitwise_right_shift with value as code_point and bits as 18
                Let byte2 be bitwise_or with a as 128 and b as bitwise_and with a as bitwise_right_shift with value as code_point and bits as 12 and b as 63
                Let byte3 be bitwise_or with a as 128 and b as bitwise_and with a as bitwise_right_shift with value as code_point and bits as 6 and b as 63
                Let byte4 be bitwise_or with a as 128 and b as bitwise_and with a as code_point and b as 63
                Set result to append_to_list with list as result and item as byte1
                Set result to append_to_list with list as result and item as byte2
                Set result to append_to_list with list as result and item as byte3
                Set result to append_to_list with list as result and item as byte4
            
            Set i to i plus 1
        
        Return result
        
    Catch error:
        Return list containing