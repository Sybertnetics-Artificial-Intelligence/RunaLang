    | INACTIVE
    | SUSPENDED
    | REVOKED

Type called "MultisigConfiguration":
    wallet_id as String
    required_signatures as Integer
    total_signers as Integer
    co_signers as Dictionary[String, CoSignerInfo]
    multisig_address as String
    redeem_script as List[Integer]
