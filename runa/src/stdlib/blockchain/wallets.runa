Note: Wallet System Initialization
Process called "create_wallet_system" that takes config as WalletConfiguration returns WalletSystem:
    Let wallet_registry be create_wallet_registry
    Let key_manager be create_key_manager with config as config
    Let transaction_coordinator be create_transaction_coordinator
    Let security_manager be create_security_manager with config as config
    Let multi_chain_manager be create_multi_chain_manager with networks as config["supported_networks"]
    Let hardware_integration be create_hardware_integration
    Let portfolio_tracker be create_portfolio_tracker
    Let address_manager be create_address_manager
    Let backup_system be create_backup_system with config as config
    
    Return WalletSystem with:
        wallet_config as config
        wallet_registry as wallet_registry
        key_manager as key_manager
        transaction_coordinator as transaction_coordinator
        security_manager as security_manager
        multi_chain_manager as multi_chain_manager
        hardware_integration as hardware_integration
        portfolio_tracker as portfolio_tracker
        address_manager as address_manager
        backup_system as backup_system

Process called "create_hd_wallet" that takes system as WalletSystem and wallet_request as HDWalletCreationRequest returns WalletCreationResult:
    Note: Validate wallet creation request
    Let validation_result be validate_wallet_request with request as wallet_request
    If not validation_result["valid"]:
        Return create_wallet_error with message as validation_result["error"]
    
    Note: Generate or import seed phrase
    Let seed_phrase be ""
    Let entropy be ""
    
    If wallet_request["import_seed"]:
        Set seed_phrase to wallet_request["seed_phrase"]
        Let seed_validation be validate_seed_phrase with phrase as seed_phrase
        If not seed_validation["valid"]:
            Return create_wallet_error with message as "Invalid seed phrase"
        Set entropy to convert_seed_to_entropy with seed as seed_phrase
    Otherwise:
        Set entropy to generate_secure_entropy with strength as wallet_request["entropy_strength"]
        Set seed_phrase to entropy_to_mnemonic with entropy as entropy
    
    Note: Create master key
    Let master_key_id be generate_master_key_id
    Let master_seed be pbkdf2_derive with password as seed_phrase and salt as "mnemonic" with message wallet_request["passphrase"] and iterations as 2048
    
    Let encrypted_seed be encrypt_data with data as master_seed and password as wallet_request["encryption_password"]
    
    Let master_key be MasterKey with:
        key_id as master_key_id
        encrypted_seed as encrypted_seed["ciphertext"]
        salt as encrypted_seed["salt"]
        derivation_function as "PBKDF2-SHA512"
        iterations as 2048
        key_strength as wallet_request["entropy_strength"]
        creation_timestamp as get_current_timestamp
        last_accessed as get_current_timestamp
        access_count as 0
    
    Note: Store master key
    Set system["key_manager"]["master_keys"][master_key_id] to master_key
    
    Note: Create wallet
    Let wallet_id be generate_wallet_id
    Let wallet be Wallet with:
        wallet_id as wallet_id
        wallet_name as wallet_request["wallet_name"]
        wallet_type as HD_WALLET
        creation_timestamp as get_current_timestamp
        master_key_id as master_key_id
        supported_networks as wallet_request["networks"]
        addresses as dictionary containing
        balance_cache as dictionary containing
        transaction_history as list containing
        security_settings as create_default_security_settings
        status as ACTIVE
    
    Note: Generate initial addresses for each network
    For each network in wallet_request["networks"]:
        Let addresses be generate_initial_addresses with system as system and wallet_id as wallet_id and network as network and master_key_id as master_key_id
        Set wallet["addresses"][network] to addresses
    
    Note: Register wallet
    Set system["wallet_registry"]["wallets"][wallet_id] to wallet
    Set system["wallet_registry"]["wallet_metadata"][wallet_id] to create_wallet_metadata with wallet as wallet and seed_phrase as seed_phrase
    
    Note: Create backup
    Set system to create_wallet_backup with system as system and wallet_id as wallet_id and seed_phrase as seed_phrase
    
    Return create_wallet_success with wallet_id as wallet_id and seed_phrase as seed_phrase

Type called "HDWalletCreationRequest":
    wallet_name as String
    networks as List[String]
    entropy_strength as Integer
    import_seed as Boolean
    seed_phrase as String
    passphrase as String
    encryption_password as String

Type called "WalletCreationResult":
    success as Boolean
    wallet_id as String
    seed_phrase as String
    addresses as Dictionary[String, List[String]]
    message as String

Note: Multi-Signature Wallet Management
Process called "create_multisig_wallet" that takes system as WalletSystem and multisig_request as MultisigWalletRequest returns MultisigCreationResult:
    Note: Validate multisig request
    Let validation_result be validate_multisig_request with request as multisig_request
    If not validation_result["valid"]:
        Return create_multisig_error with message as validation_result["error"]
    
    Note: Validate co-signer requirements
    If length of multisig_request["co_signers"] is less than multisig_request["required_signatures"]:
        Return create_multisig_error with message as "Not enough co-signers for required signatures"
    
    If multisig_request["required_signatures"] is less than 1:
        Return create_multisig_error with message as "At least one signature is required"
    
    Note: Generate multisig wallet address
    Let sorted_pubkeys be sort_public_keys with pubkeys as multisig_request["co_signer_pubkeys"]
    Let multisig_script be create_multisig_script with required_sigs as multisig_request["required_signatures"] and pubkeys as sorted_pubkeys
    Let multisig_address be script_to_address with script as multisig_script and network as multisig_request["network"]
    
    Note: Create multisig wallet
    Let wallet_id be generate_wallet_id
    Let multisig_wallet be Wallet with:
        wallet_id as wallet_id
        wallet_name as multisig_request["wallet_name"]
        wallet_type as MULTI_SIG_WALLET
        creation_timestamp as get_current_timestamp
        master_key_id as ""
        supported_networks as list containing multisig_request["network"]
        addresses as dictionary with multisig_request["network"] as list containing create_multisig_wallet_address with address as multisig_address
        balance_cache as dictionary containing
        transaction_history as list containing
        security_settings as create_multisig_security_settings with required_sigs as multisig_request["required_signatures"]
        status as ACTIVE
    
    Note: Create co-signer registry
    Let co_signer_registry be dictionary containing
    For each index from 0 to (length of multisig_request["co_signers"] minus 1):
        Let co_signer be multisig_request["co_signers"] at index index
        Let co_signer_info be CoSignerInfo with:
            signer_id as co_signer["signer_id"]
            public_key as multisig_request["co_signer_pubkeys"] at index index
            name as co_signer["name"]
            email as co_signer["email"]
            signing_status as ACTIVE
            last_signed as 0
        Set co_signer_registry[co_signer["signer_id"]] to co_signer_info
    
    Note: Store multisig configuration
    Let multisig_config be MultisigConfiguration with:
        wallet_id as wallet_id
        required_signatures as multisig_request["required_signatures"]
        total_signers as length of multisig_request["co_signers"]
        co_signers as co_signer_registry
        multisig_address as multisig_address
        redeem_script as multisig_script
        network as multisig_request["network"]
    
    Set system["wallet_registry"]["wallets"][wallet_id] to multisig_wallet
    Set system["wallet_registry"]["wallet_metadata"][wallet_id] to create_multisig_metadata with config as multisig_config
    
    Return create_multisig_success with wallet_id as wallet_id and address as multisig_address and co_signers as co_signer_registry

Type called "MultisigWalletRequest":
    wallet_name as String
    network as String
    required_signatures as Integer
    co_signers as List[CoSignerRequest]
    co_signer_pubkeys as List[List[Integer]]

Type called "CoSignerRequest":
    signer_id as String
    name as String
    email as String
    public_key as List[Integer]

Type called "CoSignerInfo":
    signer_id as String
    public_key as List[Integer]
    name as String
    email as String
    signing_status as SigningStatus
    last_signed as Integer

Type SigningStatus is:
