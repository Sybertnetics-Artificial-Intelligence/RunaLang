Note: Result Creation Helpers
Process called "create_server_error" that takes message as String returns ServerResult:
    Return ServerResult with:
        success as false
        message as message
        server_info as dictionary containing

Process called "create_server_success" that takes message as String returns ServerResult:
    Return ServerResult with:
        success as true
        message as message
        server_info as dictionary containing

Process called "create_rpc_error" that takes code as Integer and message as String returns RPCError:
    Return RPCError with:
        code as code
        message as message
        data as None

Process called "create_validation_error" that takes error as String returns ValidationResult:
    Return ValidationResult with:
        valid as false
        error as error

Process called "create_validation_success" returns ValidationResult:
    Return ValidationResult with:
        valid as true
        error as ""

Process called "create_auth_success" that takes user_context as UserContext returns AuthenticationResult:
    Return AuthenticationResult with:
        authenticated as true
        user_context as user_context
        error_message as ""

Process called "create_auth_failure" that takes message as String returns AuthenticationResult:
    Return AuthenticationResult with:
        authenticated as false
        user_context as None
        error_message as message

Process called "create_execution_success" that takes data as Any returns ExecutionResult:
    Return ExecutionResult with:
        success as true
        data as data
        error as ""

Process called "create_execution_failure" that takes error as String returns ExecutionResult:
