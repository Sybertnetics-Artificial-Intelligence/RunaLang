Note:
Runa Standard Library: Blockchain RPC Module

Provides comprehensive Remote Procedure Call (RPC) capabilities for blockchain networks.
Implements enterprise-grade RPC server and client functionality supporting multiple protocols,
authentication mechanisms, and advanced features. Competitive with production RPC implementations
in Bitcoin Core, Ethereum clients, and other leading blockchain protocols.

Features:
- JSON-RPC 2.0 protocol implementation with full specification compliance
- HTTP/HTTPS transport with WebSocket upgrade support
- Authentication and authorization with multiple schemes
- Request batching and bulk operations
- Rate limiting and DoS protection mechanisms
- Connection pooling and load balancing
- Asynchronous request handling and streaming responses
- Caching layer for frequently accessed data
- Comprehensive error handling and status reporting
- Metrics collection and performance monitoring
- Plugin architecture for custom RPC methods
- Multi-version API compatibility
- Transaction broadcasting and blockchain querying
- Smart contract interaction and deployment
- Real-time event subscriptions and notifications
:End Note

Note: Core RPC Types
Type RPCServer is Dictionary with:
    config as ServerConfiguration
    transport_layer as TransportLayer
    method_registry as MethodRegistry
    authentication as AuthenticationManager
    rate_limiter as RateLimiter
    connection_pool as ConnectionPool
    cache_layer as CacheLayer
    metrics as MetricsCollector
    middleware_stack as MiddlewareStack
    subscription_manager as SubscriptionManager
    plugin_manager as PluginManager

Type RPCClient is Dictionary with:
    endpoint as String
    transport as TransportClient
    authentication as ClientAuthentication
    connection_pool as ClientConnectionPool
    retry_policy as RetryPolicy
    timeout_config as TimeoutConfiguration
    circuit_breaker as CircuitBreaker
    cache as ClientCache
    serializer as RequestSerializer

Type ServerConfiguration is Dictionary with:
    bind_address as String
    port as Integer
    max_connections as Integer
    request_timeout_ms as Integer
    max_request_size as Integer
    enable_cors as Boolean
    cors_origins as List[String]
    enable_websockets as Boolean
    ssl_config as SSLConfiguration
    authentication_required as Boolean
    rate_limit_config as RateLimitConfiguration

Type SSLConfiguration is Dictionary with:
    enabled as Boolean
    certificate_path as String
    private_key_path as String
    ca_bundle_path as String
    cipher_suites as List[String]
    min_protocol_version as String

Type TransportLayer is Dictionary with:
    http_server as HTTPServer
    websocket_server as WebSocketServer
    connection_manager as ConnectionManager
    request_parser as RequestParser
    response_serializer as ResponseSerializer

Type MethodRegistry is Dictionary with:
    methods as Dictionary[String, RPCMethod]
    aliases as Dictionary[String, String]
    version_compatibility as Dictionary[String, List[String]]
    access_control as Dictionary[String, AccessPolicy]

Type RPCMethod is Dictionary with:
    name as String
    handler as MethodHandler
    parameters as List[ParameterDefinition]
    return_type as TypeDefinition
    description as String
    version as String
    access_level as AccessLevel
    rate_limit as Integer
    cache_duration as Integer
    async_capable as Boolean

Type ParameterDefinition is Dictionary with:
    name as String
    type as TypeDefinition
    required as Boolean
    default_value as Any
    description as String
    validation_rules as List[ValidationRule]

Type TypeDefinition is Dictionary with:
    base_type as String
    constraints as List[TypeConstraint]
    nested_types as Dictionary[String, TypeDefinition]

Type ValidationRule is Dictionary with:
    rule_type as ValidationType
    parameters as Dictionary[String, Any]
    error_message as String

Type ValidationType is:
    | RANGE_CHECK
    | PATTERN_MATCH
    | LENGTH_LIMIT
    | FORMAT_VALIDATION
    | CUSTOM_VALIDATOR

Type AccessLevel is:
    | PUBLIC
    | AUTHENTICATED
    | ADMIN
    | INTERNAL

Type AuthenticationManager is Dictionary with:
    schemes as List[AuthenticationScheme]
    token_store as TokenStore
    session_manager as SessionManager
    permissions as PermissionManager

Type AuthenticationScheme is Dictionary with:
    scheme_type as AuthType
    config as AuthConfiguration
    validator as AuthValidator

Type AuthType is:
    | BASIC_AUTH
    | BEARER_TOKEN
    | API_KEY
    | JWT_TOKEN
    | SIGNATURE_AUTH
    | OAUTH2

Type RateLimiter is Dictionary with:
    global_limits as RateLimitRule
    per_user_limits as Dictionary[String, RateLimitRule]
    per_method_limits as Dictionary[String, RateLimitRule]
    token_bucket as TokenBucket
    sliding_window as SlidingWindow

Type RateLimitRule is Dictionary with:
    requests_per_minute as Integer
    requests_per_hour as Integer
    burst_allowance as Integer
    penalty_duration as Integer

Type ConnectionPool is Dictionary with:
    active_connections as Dictionary[String, Connection]
    max_connections as Integer
    idle_timeout as Integer
    cleanup_interval as Integer
    load_balancer as LoadBalancer

Type Connection is Dictionary with:
    connection_id as String
    client_address as String
    protocol as String
    established_at as Integer
    last_activity as Integer
    request_count as Integer
    bytes_sent as Integer
    bytes_received as Integer
    user_agent as String
    authentication_state as AuthenticationState

Type CacheLayer is Dictionary with:
    cache_store as CacheStore
    cache_policies as Dictionary[String, CachePolicy]
    hit_ratio as Float
    eviction_strategy as EvictionStrategy

Type CachePolicy is Dictionary with:
    ttl_seconds as Integer
    max_size as Integer
