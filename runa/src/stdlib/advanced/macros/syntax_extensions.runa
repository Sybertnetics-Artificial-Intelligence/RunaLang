Note: Utility Functions
Process called "tokenize_with_extension_lexer" that takes lexer as ExtensionLexer and code as String returns Optional[List[Token]]:
    Try:
        Let tokens be list containing
        Let position be 0
        Let line be 1
        Let column be 1
        
        While position is less than length of code:
            Let matched be false
            
            For each token in lexer.tokens:
                Import "re"
Import "../utilities/common" as Common
                Let pattern be token.pattern
                Let match be re.match with pattern as pattern and string as code[position:]
                
                If match is not None:
                    Let token_value be match.group with number as 0
                    Let new_token be Token with:
                        type as token.token_type
                        value as token_value
                        position as Position with:
                            line as line
                            column as column
                            offset as position
                            metadata as dictionary containing
                        metadata as dictionary containing:
                            "extension_token" as true
                            "lexer_id" as lexer.lexer_id
                    
                    Add new_token to tokens
                    Set position to position plus length of token_value
                    
                    If "\n" in token_value:
                        Set line to line plus count_newlines with text as token_value
                        Set column to 1
                    Otherwise:
                        Set column to column plus length of token_value
                    
                    Set matched to true
                    Break
            
            If not matched:
                Set position to position plus 1
                Set column to column plus 1
        
        Return tokens
        
    Catch error:
        Return None

Process called "parse_with_extension_parser" that takes parser as ExtensionParser and tokens as List[Token] returns Optional[ASTNode]:
    Try:
        Let parse_stack be list containing
        Let state_stack be list containing 0
        Let token_index be 0
        
        While token_index is less than or equal to length of tokens:
            Let current_token be tokens[token_index] if token_index is less than length of tokens else Token with:
                type as "EOF"
                value as ""
                position as Position with:
                    line as 0
                    column as 0
                    offset as 0
                    metadata as dictionary containing
                metadata as dictionary containing
            
            Let current_state be state_stack[length of state_stack minus 1]
            Let action_key be current_state plus "_" plus current_token.type
            
            If parser.parser_engine.parse_table.actions contains action_key:
                Let action be parser.parser_engine.parse_table.actions[action_key]
                
                If action.action_type equals "shift":
                    Add current_token to parse_stack
                    Add action.target_state to state_stack
                    Set token_index to token_index plus 1
                
                Otherwise if action.action_type equals "reduce":
                    Let reduction_result be apply_extension_reduction with rule_id as action.action_code and parse_stack as parse_stack and state_stack as state_stack and parser as parser
                    
                    If reduction_result is not None:
                        Add reduction_result to parse_stack
                        Let goto_state be get_extension_goto_state with state as state_stack[length of state_stack minus 1] and nonterminal as reduction_result.node_type and parse_table as parser.parser_engine.parse_table
                        Add goto_state to state_stack
                
                Otherwise if action.action_type equals "accept":
                    If length of parse_stack is greater than 0:
                        Return parse_stack[length of parse_stack minus 1]
                    Otherwise:
                        Return ASTNode with:
                            node_type as "extension_root"
                            value as None
                            children as list containing
                            position as Position with:
                                line as 0
                                column as 0
                                offset as 0
                                metadata as dictionary containing
                            metadata as dictionary containing
            Otherwise:
                Let recovery_result be attempt_extension_error_recovery with parser as parser and current_token as current_token and parse_stack as parse_stack and state_stack as state_stack
                
                If recovery_result is not None:
                    Set parse_stack to recovery_result.parse_stack
                    Set state_stack to recovery_result.state_stack
                    Set token_index to recovery_result.token_index
                Otherwise:
                    Return None
        
        Return None
        
    Catch error:
        Return None

