Process called "create_type_checker" returns Dictionary[String, Any]:
    Try:
        Return dictionary containing:
            "type" as "type_checker"
            "enabled" as true
            "type_registry" as dictionary containing:
                "Integer" as dictionary containing "kind" as "primitive", "size" as 8
                "String" as dictionary containing "kind" as "primitive", "size" as -1
                "Boolean" as dictionary containing "kind" as "primitive", "size" as 1
                "Float" as dictionary containing "kind" as "primitive", "size" as 8
                "List" as dictionary containing "kind" as "generic", "parameters" as 1
                "Dictionary" as dictionary containing "kind" as "generic", "parameters" as 2
            "type_inference_engine" as dictionary containing:
                "enabled" as true
                "inference_rules" as list containing
                "constraints" as list containing
            "type_validation" as dictionary containing:
                "strict_mode" as true
                "allow_implicit_conversion" as false
                "check_generic_bounds" as true
            "check_type" as check_type_function
            "infer_type" as infer_type_function
            "validate_types" as validate_types_function
            "register_type" as register_type_function
            "lookup_type" as lookup_type_function
            "metadata" as dictionary containing:
                "creation_time" as get_current_time
                "rules_loaded" as 0
                "types_registered" as 5
    Catch error:
        Return dictionary containing "type" as "type_checker", "enabled" as false, "error" as error.message

Process called "create_cache_manager" that takes size as Integer returns Dictionary[String, Any]:
    Try:
        Return dictionary containing:
            "type" as "cache_manager"
            "size" as size
            "max_size" as size
            "current_size" as 0
            "entries" as dictionary containing
