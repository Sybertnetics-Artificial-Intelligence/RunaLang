Process called "build_parse_table" that takes grammar as DSLGrammar returns ParseTable:
    Try:
        Let states be list containing
        Let actions be dictionary containing
        Let state_counter be 0
        
        Let initial_state be ParseState with:
            state_id as "state_0"
            state_number as 0
            items as list containing
            actions as dictionary containing
            metadata as dictionary containing
        
        For each rule in grammar.rules:
            Let initial_item be ParseItem with:
                item_id as rule.rule_id plus "_item_0"
                rule_id as rule.rule_id
                position as 0
                lookahead as list containing "EOF"
                metadata as dictionary containing
            
            Add initial_item to initial_state.items
        
        Add initial_state to states
        
        For each state in states:
            For each item in state.items:
                Let rule be find_rule_by_id with grammar as grammar and rule_id as item.rule_id
                
                If rule is not None:
                    Let rule_tokens be split_rule_pattern with pattern as rule.pattern
                    
                    If item.position is less than length of rule_tokens:
                        Let next_token be rule_tokens[item.position]
                        Let action_key be state.state_number plus "_" plus next_token
                        
                        If not actions contains action_key:
                            Let target_state_number be state_counter plus 1
                            Set state_counter to target_state_number
                            
                            Let shift_action be ParseAction with:
                                action_id as "shift_" plus action_key
                                action_type as "shift"
                                target_state as target_state_number
                                action_code as "shift"
                                metadata as dictionary containing
                            
                            Set actions[action_key] to shift_action
                            
                            Let new_state be ParseState with:
                                state_id as "state_" plus target_state_number
                                state_number as target_state_number
                                items as list containing
                                actions as dictionary containing
                                metadata as dictionary containing
                            
                            Let advanced_item be ParseItem with:
                                item_id as item.item_id plus "_advanced"
                                rule_id as item.rule_id
                                position as item.position plus 1
                                lookahead as item.lookahead
                                metadata as dictionary containing
                            
                            Add advanced_item to new_state.items
                            Add new_state to states
                    Otherwise:
                        For each lookahead_token in item.lookahead:
                            Let reduce_action_key be state.state_number plus "_" plus lookahead_token
                            
                            Let reduce_action be ParseAction with:
                                action_id as "reduce_" plus reduce_action_key
                                action_type as "reduce"
                                target_state as 0
                                action_code as item.rule_id
                                metadata as dictionary containing
                            
                            Set actions[reduce_action_key] to reduce_action
        
        Let accept_action be ParseAction with:
            action_id as "accept_action"
            action_type as "accept"
            target_state as 0
            action_code as "accept"
            metadata as dictionary containing
        
        Set actions["0_EOF"] to accept_action
        
        Return ParseTable with:
            table_id as "lr_parse_table_" plus get_current_time
            states as states
            actions as actions
            metadata as dictionary containing:
                "total_states" as length of states
                "total_actions" as length of actions
                "algorithm" as "LR(1)"
                "creation_time" as get_current_time
        
    Catch error:
        Return ParseTable with:
            table_id as "error_parse_table"
            states as list containing
            actions as dictionary containing
            metadata as dictionary containing

