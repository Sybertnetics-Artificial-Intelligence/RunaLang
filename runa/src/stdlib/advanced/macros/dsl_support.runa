Process called "execute_dsl_validation" that takes validator as DSLValidator and code as String returns DSLValidationResult:
    Try:
        Let parse_result be parse_code_for_validation with code as code
        
        If parse_result is None:
            Return DSLValidationError with error as "Parsing failed during validation" and details as dictionary containing
        
        Let type_check_result be perform_type_checking with validator as validator and ast as parse_result
        
        If not type_check_result.passed:
            Return DSLValidationError with error as "Type checking failed" and details as dictionary containing
        
        Let semantic_check_result be perform_semantic_analysis with validator as validator and ast as parse_result
        
        If not semantic_check_result.passed:
            Return DSLValidationError with error as "Semantic analysis failed" and details as dictionary containing
        
        Return DSLValidationSuccess with ast as parse_result and metadata as dictionary containing
        
    Catch error:
        Return DSLValidationError with error as error.message and details as dictionary containing

Note: Utility Functions
Process called "tokenize_code" that takes lexer as DSLLexer and code as String returns Optional[List[Token]]:
    Try:
        Let tokens be list containing
        Let current_position be 0
        Let line_number be 1
        Let column_number be 1
        
        While current_position is less than length of code:
            Let matched be false
            
            For each token_pattern in lexer.tokenizer.token_patterns:
                Import "re"
                Let match_result be re.match with pattern as token_pattern.pattern_regex and string as code[current_position:]
                
                If match_result is not None:
                    Let token_value be match_result.group with number as 0
                    Let token be Token with:
                        type as token_pattern.token_type
                        value as token_value
                        position as Position with:
                            line as line_number
                            column as column_number
                            offset as current_position
                            metadata as dictionary containing
                        metadata as dictionary containing
                    
                    Add token to tokens
                    Set current_position to current_position plus length of token_value
                    Set column_number to column_number plus length of token_value
                    Set matched to true
                    
                    If token_value contains "\n":
                        Set line_number to line_number plus count_newlines with text as token_value
                        Set column_number to 1
                    
                    Break
            
            If not matched:
                Let error_token be Token with:
                    type as "ERROR"
                    value as code[current_position]
                    position as Position with:
                        line as line_number
                        column as column_number
                        offset as current_position
                        metadata as dictionary containing
                    metadata as dictionary containing
                
                Add error_token to tokens
                Set current_position to current_position plus 1
                Set column_number to column_number plus 1
        
        Return tokens
        
    Catch error:
        Return None

Process called "parse_tokens" that takes parser_engine as ParserEngine and tokens as List[Token] returns Optional[ASTNode]:
    Try:
        Let parse_stack be list containing
        Let state_stack be list containing 0
        Let token_index be 0
        
        While token_index is less than or equal to length of tokens:
            Let current_token be tokens[token_index] if token_index is less than length of tokens else Token with:
                type as "EOF"
                value as ""
                position as Position with:
                    line as 0
                    column as 0
                    offset as 0
                    metadata as dictionary containing
                metadata as dictionary containing
            
            Let current_state be state_stack[length of state_stack minus 1]
            Let action_key be current_state plus "_" plus current_token.type
            
            If parser_engine.parse_table.actions contains action_key:
                Let action be parser_engine.parse_table.actions[action_key]
                
                If action.action_type equals "shift":
                    Add current_token to parse_stack
                    Add action.target_state to state_stack
                    Set token_index to token_index plus 1
                
                Otherwise if action.action_type equals "reduce":
                    Let rule_id be action.action_code
                    Let reduction_result be apply_reduction_rule with rule_id as rule_id and parse_stack as parse_stack and state_stack as state_stack
                    
                    If reduction_result is not None:
                        Add reduction_result to parse_stack
                        Let goto_state be get_goto_state with state as state_stack[length of state_stack minus 1] and nonterminal as reduction_result.node_type and parse_table as parser_engine.parse_table
                        Add goto_state to state_stack
                
                Otherwise if action.action_type equals "accept":
                    If length of parse_stack is greater than 0:
                        Return parse_stack[length of parse_stack minus 1]
                    Otherwise:
                        Return ASTNode with:
                            node_type as "root"
                            value as None
                            children as list containing
                            position as Position with:
                                line as 0
                                column as 0
                                offset as 0
                                metadata as dictionary containing
                            metadata as dictionary containing
            Otherwise:
                Let recovery_result be attempt_error_recovery with parser_engine as parser_engine and current_token as current_token and parse_stack as parse_stack and state_stack as state_stack
                
                If recovery_result is not None:
                    Set parse_stack to recovery_result.parse_stack
                    Set state_stack to recovery_result.state_stack
                    Set token_index to recovery_result.token_index
                Otherwise:
                    Return None
        
        Return None
        
    Catch error:
        Return None

Process called "create_tokenizer" that takes tokens as List[GrammarToken] returns Tokenizer:
    Try:
        Let token_patterns be list containing
        Let token_actions be dictionary containing
        
        For each grammar_token in tokens:
            Let token_pattern be TokenPattern with:
                pattern_id as grammar_token.token_id plus "_pattern"
                pattern_type as "regex"
                pattern_regex as grammar_token.pattern
                token_type as grammar_token.token_type
                metadata as dictionary containing
            
            Add token_pattern to token_patterns
            
            Let token_action be TokenAction with:
                action_id as grammar_token.token_id plus "_action"
                action_type as "create_token"
                action_code as "return Token(type='" plus grammar_token.token_type plus "', value=match.group(0))"
                metadata as dictionary containing
            
            Set token_actions[grammar_token.token_id] to token_action
        
        Let whitespace_pattern be TokenPattern with:
            pattern_id as "whitespace_pattern"
            pattern_type as "regex"
            pattern_regex as "\\s+"
            token_type as "WHITESPACE"
            metadata as dictionary containing
        
        Add whitespace_pattern to token_patterns
        
        Let comment_pattern be TokenPattern with:
            pattern_id as "comment_pattern"
            pattern_type as "regex"
            pattern_regex as "#[^\\n]*"
            token_type as "COMMENT"
            metadata as dictionary containing
        
        Add comment_pattern to token_patterns
        
        Return Tokenizer with:
            tokenizer_id as "dsl_tokenizer_" plus get_current_time
            token_patterns as token_patterns
            token_actions as token_actions
            metadata as dictionary containing:
                "total_patterns" as length of token_patterns
                "creation_time" as get_current_time
        
    Catch error:
        Return Tokenizer with:
            tokenizer_id as "error_tokenizer"
            token_patterns as list containing
            token_actions as dictionary containing
            metadata as dictionary containing

Process called "create_lexer_error_handler" returns ErrorHandler:
