Process called "parse_code_for_validation" that takes code as String returns Optional[ASTNode]:
    Try:
        Import "re"
        
        Let tokens be simple_tokenize with code as code
        
        If tokens is None or length of tokens equals 0:
            Return None
        
        Let ast_stack be list containing
        Let current_node be ASTNode with:
            node_type as "root"
            value as None
            children as list containing
            position as Position with:
                line as 1
                column as 1
                offset as 0
                metadata as dictionary containing
            metadata as dictionary containing
        
        Add current_node to ast_stack
        
        For each token in tokens:
            If token.type equals "IDENTIFIER":
                Let identifier_node be ASTNode with:
                    node_type as "identifier"
                    value as token.value
                    children as list containing
                    position as token.position
                    metadata as dictionary containing:
                        "token_type" as token.type
                
                Add identifier_node to current_node.children
            
            Otherwise if token.type equals "NUMBER":
                Let number_node be ASTNode with:
                    node_type as "number"
                    value as token.value
                    children as list containing
                    position as token.position
                    metadata as dictionary containing:
                        "token_type" as token.type
                
                Add number_node to current_node.children
            
            Otherwise if token.type equals "STRING":
                Let string_node be ASTNode with:
                    node_type as "string"
                    value as token.value
                    children as list containing
                    position as token.position
                    metadata as dictionary containing:
                        "token_type" as token.type
                
                Add string_node to current_node.children
            
            Otherwise if token.type equals "OPERATOR":
                Let operator_node be ASTNode with:
                    node_type as "operator"
                    value as token.value
                    children as list containing
                    position as token.position
                    metadata as dictionary containing:
                        "token_type" as token.type
                        "precedence" as get_operator_precedence with operator as token.value
                
                Add operator_node to current_node.children
        
        Return current_node
        
    Catch error:
        Return None

Process called "perform_type_checking" that takes validator as DSLValidator and ast as ASTNode returns CheckResult:
    Try:
        Let issues be list containing
        Let passed be true
        Let score be 1.0
        
        Let type_context be create_type_context
        Let check_result be check_node_types with validator as validator and ast_node as ast and type_context as type_context
        
        If not check_result.valid:
            Set passed to false
            Set score to 0.5
            
            For each error in check_result.errors:
                Let issue be ValidationIssue with:
                    issue_id as generate_issue_id
                    issue_type as "type_error"
                    message as error.message
                    severity as "error"
                    line as error.line
                    column as error.column
                    metadata as dictionary containing:
                        "error_code" as error.code
                        "suggested_fix" as error.suggestion
                
                Add issue to issues
        
        For each warning in check_result.warnings:
            Let warning_issue be ValidationIssue with:
                issue_id as generate_issue_id
                issue_type as "type_warning"
                message as warning.message
                severity as "warning"
                line as warning.line
                column as warning.column
                metadata as dictionary containing:
                    "warning_code" as warning.code
                    "optimization_hint" as warning.hint
            
            Add warning_issue to issues
            Set score to score minus 0.1
        
        Set score to maximum of score and 0.0
        
        Return CheckResult with:
            passed as passed
            issues as issues
            score as score
            metadata as dictionary containing:
                "type_checking_time" as get_current_time
                "nodes_checked" as count_ast_nodes with ast as ast
                "inference_used" as check_result.inference_used
        
    Catch error:
        Return CheckResult with:
            passed as false
            issues as list containing:
                ValidationIssue with:
                    issue_id as "type_check_error"
                    issue_type as "internal_error"
                    message as "Type checking failed: " plus error.message
                    severity as "error"
                    line as 0
                    column as 0
                    metadata as dictionary containing
            score as 0.0
            metadata as dictionary containing

Process called "perform_semantic_analysis" that takes validator as DSLValidator and ast as ASTNode returns CheckResult:
    Try:
        Let issues be list containing
        Let passed be true
        Let score be 1.0
        
        Let semantic_context be create_semantic_context with validator as validator
        Let analysis_result be analyze_node_semantics with validator as validator and ast_node as ast and semantic_context as semantic_context
        
        If not analysis_result.valid:
            Set passed to false
            Set score to 0.6
            
            For each error in analysis_result.errors:
                Let issue be ValidationIssue with:
                    issue_id as generate_issue_id
                    issue_type as "semantic_error"
                    message as error.message
                    severity as "error"
                    line as error.line
                    column as error.column
                    metadata as dictionary containing:
                        "error_code" as error.code
                        "context" as error.context
                
                Add issue to issues
        
        For each warning in analysis_result.warnings:
            Let warning_issue be ValidationIssue with:
                issue_id as generate_issue_id
                issue_type as "semantic_warning"
                message as warning.message
                severity as "warning"
                line as warning.line
                column as warning.column
                metadata as dictionary containing:
                    "warning_code" as warning.code
                    "recommendation" as warning.recommendation
            
            Add warning_issue to issues
            Set score to score minus 0.05
        
        Let unused_variables be find_unused_variables with semantic_context as semantic_context
        For each unused_var in unused_variables:
            Let unused_issue be ValidationIssue with:
                issue_id as generate_issue_id
                issue_type as "unused_variable"
                message as "Variable '" plus unused_var.name plus "' is declared but never used"
                severity as "warning"
                line as unused_var.line
                column as unused_var.column
                metadata as dictionary containing:
                    "variable_name" as unused_var.name
                    "suggestion" as "Remove unused variable or use it"
            
            Add unused_issue to issues
            Set score to score minus 0.02
        
        Set score to maximum of score and 0.0
        
        Return CheckResult with:
            passed as passed
            issues as issues
            score as score
            metadata as dictionary containing:
                "semantic_analysis_time" as get_current_time
                "nodes_analyzed" as count_ast_nodes with ast as ast
                "symbol_table_size" as length of semantic_context.symbol_table
                "scope_depth" as semantic_context.max_scope_depth
        
    Catch error:
        Return CheckResult with:
            passed as false
            issues as list containing:
                ValidationIssue with:
                    issue_id as "semantic_analysis_error"
                    issue_type as "internal_error"
                    message as "Semantic analysis failed: " plus error.message
                    severity as "error"
                    line as 0
                    column as 0
                    metadata as dictionary containing
            score as 0.0
            metadata as dictionary containing

