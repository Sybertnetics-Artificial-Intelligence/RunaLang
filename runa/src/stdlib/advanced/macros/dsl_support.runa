Process called "create_optimization_passes_for_dsl" that takes dsl_def as DSLDefinition returns List[OptimizationPass]:
    Try:
        Let optimization_passes be list containing
        
        Let dead_code_pass be OptimizationPass with:
            pass_id as dsl_def.dsl_id plus "_dead_code_pass"
            pass_type as "dead_code_elimination"
            optimization_rules as list containing:
                OptimizationRule with:
                    rule_id as "remove_unused_variables"
                    rule_type as "dead_code_elimination"
                    pattern as "var\\s+\\w+\\s*=\\s*[^;]+;(?![\\s\\S]*\\1)"
                    replacement as ""
                    metadata as dictionary containing
                OptimizationRule with:
                    rule_id as "remove_unreachable_code"
                    rule_type as "dead_code_elimination"
                    pattern as "return\\s+[^;]+;[\\s\\S]*?}"
                    replacement as "return $1; }"
                    metadata as dictionary containing
            metadata as dictionary containing
        
        Add dead_code_pass to optimization_passes
        
        Let constant_folding_pass be OptimizationPass with:
            pass_id as dsl_def.dsl_id plus "_constant_folding_pass"
            pass_type as "constant_folding"
            optimization_rules as list containing:
                OptimizationRule with:
                    rule_id as "fold_arithmetic"
                    rule_type as "constant_folding"
                    pattern as "(\\d+)\\s*\\+\\s*(\\d+)"
                    replacement as "evaluate_arithmetic"
                    metadata as dictionary containing
                OptimizationRule with:
                    rule_id as "fold_boolean"
                    rule_type as "constant_folding"
                    pattern as "(true|false)\\s*&&\\s*(true|false)"
                    replacement as "evaluate_boolean"
                    metadata as dictionary containing
            metadata as dictionary containing
        
        Add constant_folding_pass to optimization_passes
        
        Let loop_optimization_pass be OptimizationPass with:
            pass_id as dsl_def.dsl_id plus "_loop_optimization_pass"
            pass_type as "loop_optimization"
            optimization_rules as list containing:
                OptimizationRule with:
                    rule_id as "loop_unrolling"
                    rule_type as "loop_optimization"
                    pattern as "for\\s*\\(.*?\\)\\s*\\{([^}]*)\\}"
                    replacement as "unroll_small_loops"
                    metadata as dictionary containing
                OptimizationRule with:
                    rule_id as "loop_invariant_motion"
                    rule_type as "loop_optimization"
                    pattern as "while\\s*\\([^)]*\\)\\s*\\{([^}]*)\\}"
                    replacement as "move_invariants"
                    metadata as dictionary containing
            metadata as dictionary containing
        
        Add loop_optimization_pass to optimization_passes
        
        Let inline_pass be OptimizationPass with:
            pass_id as dsl_def.dsl_id plus "_inline_pass"
            pass_type as "inline_expansion"
            optimization_rules as list containing:
                OptimizationRule with:
                    rule_id as "inline_small_functions"
                    rule_type as "inline_expansion"
                    pattern as "function\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[^}]{1,50}\\}"
                    replacement as "inline_function_body"
                    metadata as dictionary containing
            metadata as dictionary containing
        
        Add inline_pass to optimization_passes
        
        Return optimization_passes
        
    Catch error:
        Return list containing

Process called "generate_code_with_generator" that takes generator as DSLGenerator and ast as DSLParseResult and target_language as String returns Optional[String]:
    Try:
        If ast is DSLParseError:
            Return None
        
        Let parse_success be ast as DSLParseSuccess
        Let root_ast be parse_success.ast
        
        Let generated_code be generate_code_from_ast with generator as generator and ast_node as root_ast and target_language as target_language
        
        If generated_code is None:
            Return None
        
        Let formatted_code be format_generated_code with code as generated_code and target_language as target_language
        
        Return formatted_code
        
    Catch error:
        Return None

Process called "apply_optimization_passes" that takes generator as DSLGenerator and code as String returns String:
    Try:
        Let optimized_code be code
        
        For each optimization_pass in generator.optimization_passes:
            For each optimization_rule in optimization_pass.optimization_rules:
                If optimization_rule.rule_type equals "dead_code_elimination":
                    Set optimized_code to remove_dead_code with code as optimized_code
                
                Otherwise if optimization_rule.rule_type equals "constant_folding":
                    Set optimized_code to fold_constants with code as optimized_code
                
                Otherwise if optimization_rule.rule_type equals "loop_optimization":
                    Set optimized_code to optimize_loops with code as optimized_code
                
                Otherwise if optimization_rule.rule_type equals "inline_expansion":
                    Set optimized_code to expand_inlines with code as optimized_code
                
                Otherwise if optimization_rule.rule_type equals "strength_reduction":
                    Set optimized_code to reduce_strength with code as optimized_code
                
                Otherwise if optimization_rule.rule_type equals "pattern_replacement":
                    Import "re"
                    Set optimized_code to re.sub with pattern as optimization_rule.pattern and repl as optimization_rule.replacement and string as optimized_code
        
        Return optimized_code
        
    Catch error:
        Return code

