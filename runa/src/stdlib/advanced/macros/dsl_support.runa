Note: Core DSL Support Functions
Process called "create_dsl_support" that takes context as MacroContext returns DSLSupport:
    Let dsl_registry be create_dsl_registry
    Let parser_factory be create_dsl_parser_factory with context as context
    Let generator_factory be create_dsl_generator_factory with context as context
    Let validator_factory be create_dsl_validator_factory with context as context
    Let debug_tracer be create_dsl_debug_tracer
    Let performance_monitor be create_dsl_performance_monitor
    
    Return DSLSupport with:
        context as context
        dsl_registry as dsl_registry
        parser_factory as parser_factory
        generator_factory as generator_factory
        validator_factory as validator_factory
        debug_tracer as debug_tracer
        performance_monitor as performance_monitor
        metadata as dictionary containing

Process called "register_dsl" that takes support as DSLSupport and dsl_def as DSLDefinition returns Boolean:
    Let start_time be get_current_time
    
    Try:
        Let validation_result be validate_dsl_definition with dsl_def as dsl_def
        
        If not validation_result:
            Return false
        
        Let parser be create_dsl_parser with support as support and dsl_def as dsl_def
        Let generator be create_dsl_generator with support as support and dsl_def as dsl_def
        Let validator be create_dsl_validator with support as support and dsl_def as dsl_def
        
        Set support.dsl_registry.dsls[dsl_def.dsl_id] to dsl_def
        Set support.dsl_registry.parsers[dsl_def.dsl_id] to parser
        Set support.dsl_registry.generators[dsl_def.dsl_id] to generator
        Set support.dsl_registry.validators[dsl_def.dsl_id] to validator
        
        Let trace_entry be DSLTraceEntry with:
            timestamp as start_time
            level as "info"
            message as "Registered DSL: " plus dsl_def.name
            dsl_id as dsl_def.dsl_id
            action as "register_dsl"
            data as dictionary containing:
                "dsl_name" as dsl_def.name
                "version" as dsl_def.version
            metadata as dictionary containing
        
        Add trace_entry to support.debug_tracer.trace_output
        
        Let end_time be get_current_time
        Let performance_metric be DSLPerformanceMetric with:
            name as "dsl_registration_time"
            value as end_time minus start_time
            unit as "seconds"
            timestamp as end_time
            dsl_id as dsl_def.dsl_id
            metadata as dictionary containing
        
        Set support.performance_monitor.metrics["dsl_registration_time"] to performance_metric
        
        Return true
        
    Catch error:
        Return false

Process called "parse_dsl_code" that takes support as DSLSupport and dsl_id as String and code as String returns DSLParseResult:
    Let start_time be get_current_time
    
    Try:
        Let parser be support.dsl_registry.parsers[dsl_id] if support.dsl_registry.parsers contains dsl_id else None
        
        If parser is None:
            Return DSLParseError with error as "DSL parser not found: " plus dsl_id and details as dictionary containing
        
        Let parse_result be execute_dsl_parsing with parser as parser and code as code
        
        Let end_time be get_current_time
        Let performance_metric be DSLPerformanceMetric with:
            name as "dsl_parsing_time"
            value as end_time minus start_time
            unit as "seconds"
            timestamp as end_time
            dsl_id as dsl_id
            metadata as dictionary containing
        
        Set support.performance_monitor.metrics["dsl_parsing_time"] to performance_metric
        
        Return parse_result
        
    Catch error:
        Return DSLParseError with error as error.message and details as dictionary containing

Process called "generate_code_from_dsl" that takes support as DSLSupport and dsl_id as String and ast as DSLParseResult and target_language as String returns DSLGenerationResult:
    Let start_time be get_current_time
    
    Try:
        Let generator be support.dsl_registry.generators[dsl_id] if support.dsl_registry.generators contains dsl_id else None
        
        If generator is None:
            Return DSLGenerationError with error as "DSL generator not found: " plus dsl_id and details as dictionary containing
        
        Let generation_result be execute_dsl_generation with generator as generator and ast as ast and target_language as target_language
        
        Let end_time be get_current_time
        Let performance_metric be DSLPerformanceMetric with:
            name as "dsl_generation_time"
            value as end_time minus start_time
            unit as "seconds"
            timestamp as end_time
            dsl_id as dsl_id
            metadata as dictionary containing
        
        Set support.performance_monitor.metrics["dsl_generation_time"] to performance_metric
        
        Return generation_result
        
    Catch error:
        Return DSLGenerationError with error as error.message and details as dictionary containing

Process called "validate_dsl_code" that takes support as DSLSupport and dsl_id as String and code as String returns DSLValidationResult:
    Let start_time be get_current_time
    
    Try:
        Let validator be support.dsl_registry.validators[dsl_id] if support.dsl_registry.validators contains dsl_id else None
        
        If validator is None:
            Return DSLValidationError with error as "DSL validator not found: " plus dsl_id and details as dictionary containing
        
        Let validation_result be execute_dsl_validation with validator as validator and code as code
        
        Let end_time be get_current_time
        Let performance_metric be DSLPerformanceMetric with:
            name as "dsl_validation_time"
            value as end_time minus start_time
            unit as "seconds"
            timestamp as end_time
            dsl_id as dsl_id
            metadata as dictionary containing
        
        Set support.performance_monitor.metrics["dsl_validation_time"] to performance_metric
        
        Return validation_result
        
    Catch error:
        Return DSLValidationError with error as error.message and details as dictionary containing

Note: DSL Registry Management
Process called "create_dsl_registry" returns DSLRegistry:
    Return DSLRegistry with:
        dsls as dictionary containing
        parsers as dictionary containing
        generators as dictionary containing
        validators as dictionary containing
        metadata as dictionary containing

Process called "validate_dsl_definition" that takes dsl_def as DSLDefinition returns Boolean:
    Try:
        If dsl_def.dsl_id is empty:
            Return false
        
        If dsl_def.name is empty:
            Return false
        
        If dsl_def.grammar is None:
            Return false
        
        If dsl_def.semantics is None:
            Return false
        
        Let grammar_validation be validate_dsl_grammar with grammar as dsl_def.grammar
        If not grammar_validation:
            Return false
        
        Let semantics_validation be validate_dsl_semantics with semantics as dsl_def.semantics
        If not semantics_validation:
            Return false
        
        Return true
        
    Catch error:
        Return false

Process called "validate_dsl_grammar" that takes grammar as DSLGrammar returns Boolean:
    Try:
        If grammar.rules is None or length of grammar.rules equals 0:
            Return false
        
        If grammar.tokens is None or length of grammar.tokens equals 0:
            Return false
        
        Return true
        
    Catch error:
        Return false

Process called "validate_dsl_semantics" that takes semantics as DSLSemantics returns Boolean:
    Try:
        If semantics.type_system is None:
            Return false
        
        If semantics.evaluation_rules is None:
            Return false
        
        Return true
        
    Catch error:
        Return false

Note: DSL Parser Factory
Process called "create_dsl_parser_factory" that takes context as MacroContext returns DSLParserFactory:
    Return DSLParserFactory with:
        context as context
        metadata as dictionary containing

Process called "create_dsl_parser" that takes support as DSLSupport and dsl_def as DSLDefinition returns DSLParser:
    Try:
        Let lexer be create_dsl_lexer with dsl_def as dsl_def
        Let parser_engine be create_parser_engine with dsl_def as dsl_def
        Let error_handler be create_error_handler with dsl_def as dsl_def
        
        Return DSLParser with:
            parser_id as dsl_def.dsl_id plus "_parser"
            grammar as dsl_def.grammar
            lexer as lexer
            parser_engine as parser_engine
            error_handler as error_handler
            metadata as dictionary containing
        
    Catch error:
        Return DSLParser with:
            parser_id as "error_parser"
            grammar as DSLGrammar with:
                rules as list containing
                tokens as list containing
                precedence as list containing
                associativity as dictionary containing
                metadata as dictionary containing
            lexer as create_default_lexer
            parser_engine as create_default_parser_engine
            error_handler as create_default_error_handler
            metadata as dictionary containing

Process called "execute_dsl_parsing" that takes parser as DSLParser and code as String returns DSLParseResult:
    Try:
        Let tokens be tokenize_code with lexer as parser.lexer and code as code
        
        If tokens is None:
            Return DSLParseError with error as "Tokenization failed" and details as dictionary containing
        
        Let ast be parse_tokens with parser_engine as parser.parser_engine and tokens as tokens
        
        If ast is None:
            Return DSLParseError with error as "Parsing failed" and details as dictionary containing
        
        Return DSLParseSuccess with ast as ast and tokens as tokens and metadata as dictionary containing
        
    Catch error:
        Return DSLParseError with error as error.message and details as dictionary containing

Process called "create_dsl_lexer" that takes dsl_def as DSLDefinition returns DSLLexer:
    Try:
        Let tokenizer be create_tokenizer with tokens as dsl_def.grammar.tokens
        Let error_handler be create_lexer_error_handler
        
        Return DSLLexer with:
            lexer_id as dsl_def.dsl_id plus "_lexer"
            tokens as dsl_def.grammar.tokens
            tokenizer as tokenizer
            error_handler as error_handler
            metadata as dictionary containing
        
    Catch error:
        Return create_default_lexer

Process called "create_parser_engine" that takes dsl_def as DSLDefinition returns ParserEngine:
    Try:
        Let parse_table be build_parse_table with grammar as dsl_def.grammar
        Let error_recovery be create_error_recovery
        
        Return ParserEngine with:
            engine_id as dsl_def.dsl_id plus "_engine"
            parsing_strategy as "lr"
            parse_table as parse_table
            error_recovery as error_recovery
            metadata as dictionary containing
        
    Catch error:
        Return create_default_parser_engine

Process called "create_error_handler" that takes dsl_def as DSLDefinition returns ErrorHandler:
    Try:
        Let recovery_strategies be dictionary containing:
            "syntax_error" as RecoveryStrategy with:
                strategy_id as "syntax_recovery"
                strategy_type as "panic_mode"
                recovery_action as "skip_to_semicolon"
                metadata as dictionary containing
            "semantic_error" as RecoveryStrategy with:
                strategy_id as "semantic_recovery"
                strategy_type as "error_correction"
                recovery_action as "suggest_correction"
                metadata as dictionary containing
        
        Return ErrorHandler with:
            handler_id as dsl_def.dsl_id plus "_error_handler"
            error_types as list containing "syntax_error" and "semantic_error"
            recovery_strategies as recovery_strategies
            metadata as dictionary containing
        
    Catch error:
        Return create_default_error_handler

