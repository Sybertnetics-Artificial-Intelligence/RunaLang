Note:
Runa Advanced Standard Library: DSL Support Module

Provides comprehensive domain-specific language support for macros including:
- DSL definition and specification
- DSL parsing and interpretation
- DSL code generation and transformation
- DSL validation and verification
- Cross-DSL integration and interoperability
- DSL debugging and development tools
- AI/agent-friendly DSL development
- Production-ready DSL support with error handling

Features:
- Advanced DSL definition with grammar specification
- DSL parsing with custom lexers and parsers
- DSL code generation with multiple backends
- DSL validation with comprehensive error checking
- Cross-DSL integration with translation capabilities
- Comprehensive DSL debugging and development tools
- AI/agent-friendly DSL development and testing
- Production-ready DSL support with comprehensive error handling
:End Note

Note: DSL Types and Data Structures
Type DSLSupport is Dictionary with:
    context as MacroContext
    dsl_registry as DSLRegistry
    parser_factory as DSLParserFactory
    generator_factory as DSLGeneratorFactory
    validator_factory as DSLValidatorFactory
    debug_tracer as DSLDebugTracer
    performance_monitor as DSLPerformanceMonitor
    metadata as Dictionary[String, Any]

Type DSLRegistry is Dictionary with:
    dsls as Dictionary[String, DSLDefinition]
    parsers as Dictionary[String, DSLParser]
    generators as Dictionary[String, DSLGenerator]
    validators as Dictionary[String, DSLValidator]
    metadata as Dictionary[String, Any]

Type DSLDefinition is Dictionary with:
    dsl_id as String
    name as String
    version as String
    grammar as DSLGrammar
    semantics as DSLSemantics
    target_languages as List[String]
    metadata as Dictionary[String, Any]

Type DSLGrammar is Dictionary with:
    rules as List[GrammarRule]
    tokens as List[GrammarToken]
    precedence as List[PrecedenceRule]
    associativity as Dictionary[String, String]
    metadata as Dictionary[String, Any]

Type DSLSemantics is Dictionary with:
    type_system as TypeSystem
    evaluation_rules as List[EvaluationRule]
    transformation_rules as List[TransformationRule]
    metadata as Dictionary[String, Any]

Type DSLParser is Dictionary with:
    parser_id as String
    grammar as DSLGrammar
    lexer as DSLLexer
    parser_engine as ParserEngine
    error_handler as ErrorHandler
    metadata as Dictionary[String, Any]

Type DSLGenerator is Dictionary with:
    generator_id as String
    target_language as String
    code_generator as CodeGenerator
    template_engine as TemplateEngine
    optimization_passes as List[OptimizationPass]
    metadata as Dictionary[String, Any]

Type DSLValidator is Dictionary with:
    validator_id as String
    validation_rules as List[ValidationRule]
    type_checker as TypeChecker
    semantic_analyzer as SemanticAnalyzer
    metadata as Dictionary[String, Any]

Type DSLDebugTracer is Dictionary with:
    trace_level as String
    trace_output as List[DSLTraceEntry]
    dsl_events as List[DSLEvent]
    metadata as Dictionary[String, Any]

Type DSLPerformanceMonitor is Dictionary with:
    metrics as Dictionary[String, DSLPerformanceMetric]
    thresholds as Dictionary[String, Float]
    alerts as List[DSLPerformanceAlert]
    metadata as Dictionary[String, Any]

Type GrammarRule is Dictionary with:
    rule_id as String
    rule_name as String
