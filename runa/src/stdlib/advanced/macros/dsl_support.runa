Process called "create_dsl_generator" that takes support as DSLSupport and dsl_def as DSLDefinition returns DSLGenerator:
    Try:
        Let code_generator be create_code_generator_for_dsl with dsl_def as dsl_def
        Let template_engine be create_template_engine_for_dsl with dsl_def as dsl_def
        Let optimization_passes be create_optimization_passes_for_dsl with dsl_def as dsl_def
        
        Return DSLGenerator with:
            generator_id as dsl_def.dsl_id plus "_generator"
            target_language as "runa"
            code_generator as code_generator
            template_engine as template_engine
            optimization_passes as optimization_passes
            metadata as dictionary containing
        
    Catch error:
        Return create_default_dsl_generator

Process called "execute_dsl_generation" that takes generator as DSLGenerator and ast as DSLParseResult and target_language as String returns DSLGenerationResult:
    Try:
        Let generated_code be generate_code_with_generator with generator as generator and ast as ast and target_language as target_language
        
        If generated_code is None:
            Return DSLGenerationError with error as "Code generation failed" and details as dictionary containing
        
        Let optimized_code be apply_optimization_passes with generator as generator and code as generated_code
        
        Return DSLGenerationSuccess with code as optimized_code and metadata as dictionary containing
        
    Catch error:
        Return DSLGenerationError with error as error.message and details as dictionary containing

Note: DSL Validator Factory
Process called "create_dsl_validator_factory" that takes context as MacroContext returns DSLValidatorFactory:
    Return DSLValidatorFactory with:
        context as context
        metadata as dictionary containing

Process called "create_dsl_validator" that takes support as DSLSupport and dsl_def as DSLDefinition returns DSLValidator:
    Try:
        Let validation_rules be create_validation_rules_for_dsl with dsl_def as dsl_def
        Let type_checker be create_type_checker_for_dsl with dsl_def as dsl_def
        Let semantic_analyzer be create_semantic_analyzer_for_dsl with dsl_def as dsl_def
        
        Return DSLValidator with:
            validator_id as dsl_def.dsl_id plus "_validator"
            validation_rules as validation_rules
            type_checker as type_checker
            semantic_analyzer as semantic_analyzer
            metadata as dictionary containing
        
    Catch error:
        Return create_default_dsl_validator

Process called "execute_dsl_validation" that takes validator as DSLValidator and code as String returns DSLValidationResult:
    Try:
        Let parse_result be parse_code_for_validation with code as code
        
        If parse_result is None:
            Return DSLValidationError with error as "Parsing failed during validation" and details as dictionary containing
        
        Let type_check_result be perform_type_checking with validator as validator and ast as parse_result
        
        If not type_check_result.passed:
            Return DSLValidationError with error as "Type checking failed" and details as dictionary containing
        
        Let semantic_check_result be perform_semantic_analysis with validator as validator and ast as parse_result
        
        If not semantic_check_result.passed:
            Return DSLValidationError with error as "Semantic analysis failed" and details as dictionary containing
        
        Return DSLValidationSuccess with ast as parse_result and metadata as dictionary containing
        
    Catch error:
        Return DSLValidationError with error as error.message and details as dictionary containing

