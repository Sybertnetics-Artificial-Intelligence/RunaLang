Process called "create_code_generation_performance_monitor" returns CodeGenerationPerformanceMonitor:
    Return CodeGenerationPerformanceMonitor with:
        metrics as dictionary containing
        thresholds as dictionary containing:
            "generation_time" as 1.0
            "template_processing_time" as 0.1
            "ast_generation_time" as 0.1
        alerts as list containing
        metadata as dictionary containing

Process called "get_code_generation_trace" that takes generator as CodeGenerator returns List[CodeGenerationTraceEntry]:
    Return generator.debug_tracer.trace_output

Process called "get_code_generation_events" that takes generator as CodeGenerator returns List[CodeGenerationEvent]:
    Return generator.debug_tracer.generation_events

Process called "clear_code_generation_trace" that takes generator as CodeGenerator:
    Set generator.debug_tracer.trace_output to list containing
    Set generator.debug_tracer.generation_events to list containing

Process called "get_code_generation_performance_metrics" that takes generator as CodeGenerator returns Dictionary[String, CodeGenerationPerformanceMetric]:
    Return generator.performance_monitor.metrics

Process called "get_code_generation_performance_alerts" that takes generator as CodeGenerator returns List[CodeGenerationPerformanceAlert]:
    Return generator.performance_monitor.alerts

Process called "set_code_generation_performance_threshold" that takes generator as CodeGenerator and metric as String and threshold as Float returns Boolean:
    Try:
        Set generator.performance_monitor.thresholds[metric] to threshold
        Return true
        
    Catch error:
        Return false 