Process called "create_error_ast" that takes message as String returns ASTNode:
    Return ASTNode with:
        node_type as "error"
        value as message
        children as list containing
        position as Position with:
            line as 0
            column as 0
            offset as 0
            metadata as dictionary containing
        metadata as dictionary containing:
            "error_type" as "ast_generation_error"
            "timestamp" as Common.get_current_time

Process called "default_ast_generator" that takes ast_spec as ASTSpecification and context as Dictionary[String, Any] returns ASTNode:
    Try:
        Let child_nodes be list containing
        For each child_spec in ast_spec.children:
            Let child_node be generate_ast_from_specification_recursive with ast_spec as child_spec and context as context
            Add child_node to child_nodes
        
        Return ASTNode with:
            node_type as ast_spec.node_type
            value as ast_spec.properties.get with key as "value" and default as None
            children as child_nodes
            position as Position with:
                line as 0
                column as 0
                offset as 0
                metadata as dictionary containing
            metadata as ast_spec.properties
        
    Catch error:
        Return create_error_ast with message as "Default AST generation failed: " plus error.message

Process called "generate_ast_from_specification_recursive" that takes ast_spec as ASTSpecification and context as Dictionary[String, Any] returns ASTNode:
    Try:
        If ast_spec.node_type equals "function":
            Return function_ast_generator with ast_spec as ast_spec and context as context
        Otherwise if ast_spec.node_type equals "class":
            Return class_ast_generator with ast_spec as ast_spec and context as context
        Otherwise if ast_spec.node_type equals "variable":
            Return variable_ast_generator with ast_spec as ast_spec and context as context
        Otherwise if ast_spec.node_type equals "expression":
            Return expression_ast_generator with ast_spec as ast_spec and context as context
        Otherwise:
            Return default_ast_generator with ast_spec as ast_spec and context as context
        
    Catch error:
        Return create_error_ast with message as "Recursive AST generation failed: " plus error.message

Note: Nested Template Processing Utility Functions
Process called "extract_include_blocks" that takes template_code as String returns List[IncludeBlock]:
    Import "re"
    Try:
        Let blocks be list containing
        Let pattern be "\{%\s*include\s+['\"]([^'\"]+)['\"]\s*(?:with\s+([^%]+))?\s*%\}"
        Let matches be re.findall with pattern as pattern and string as template_code
        
        For each match in matches:
            Let include_variables be dictionary containing
            If length of match is greater than 1 and match[1] is not empty:
                Set include_variables to parse_include_variables with variable_string as match[1]
            
            Let block be IncludeBlock with:
                template_id as match[0]
                variables as include_variables
                full_block as match[0] plus (match[1] if length of match is greater than 1 else "")
                metadata as dictionary containing
            Add block to blocks
        
        Return blocks
        
    Catch error:
        Return list containing

Process called "parse_include_variables" that takes variable_string as String returns Dictionary[String, Any]:
    Try:
        Let variables be dictionary containing
        Let pairs be split_string with text as variable_string and delimiter as ","
        
        For each pair in pairs:
            Let key_value be split_string with text as trim_string with text as pair and delimiter as "="
            If length of key_value is equal to 2:
                Let key be trim_string with text as key_value[0]
                Let value be trim_string with text as key_value[1]
                Set variables[key] to value
        
        Return variables
        
    Catch error:
        Return dictionary containing

Process called "merge_dictionaries" that takes dict1 as Dictionary[String, Any] and dict2 as Dictionary[String, Any] returns Dictionary[String, Any]:
    Try:
        Let merged be dictionary containing dict1
        
        For each key in dict2:
            Set merged[key] to dict2[key]
        
        Return merged
        
    Catch error:
        Return dict1

