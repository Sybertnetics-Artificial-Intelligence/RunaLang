Process called "function_ast_generator" that takes ast_spec as ASTSpecification and context as Dictionary[String, Any] returns ASTNode:
    Try:
        Let function_name be ast_spec.properties["name"] if ast_spec.properties contains "name" else "anonymous_function"
        Let parameters be ast_spec.properties["parameters"] if ast_spec.properties contains "parameters" else list containing
        Let return_type be ast_spec.properties["return_type"] if ast_spec.properties contains "return_type" else "Any"
        Let body be ast_spec.properties["body"] if ast_spec.properties contains "body" else ""
        
        Let parameter_nodes be list containing
        For each param in parameters:
            Let param_node be ASTNode with:
                node_type as "parameter"
                value as param
                children as list containing
                position as Position with:
                    line as 0
                    column as 0
                    offset as 0
                    metadata as dictionary containing
                metadata as dictionary containing:
                    "parameter_type" as param.get with key as "type" and default as "Any"
            Add param_node to parameter_nodes
        
        Let body_node be ASTNode with:
            node_type as "block"
            value as body
            children as list containing
            position as Position with:
                line as 0
                column as 0
                offset as 0
                metadata as dictionary containing
            metadata as dictionary containing
        
        Let function_children be list containing
        Add parameter_nodes to function_children
        Add body_node to function_children
        
        Return ASTNode with:
            node_type as "function_definition"
            value as function_name
            children as function_children
            position as Position with:
                line as 0
                column as 0
                offset as 0
                metadata as dictionary containing
            metadata as dictionary containing:
                "function_name" as function_name
                "return_type" as return_type
                "parameter_count" as length of parameters
        
    Catch error:
        Return create_error_ast with message as "Function AST generation failed: " plus error.message

Process called "class_ast_generator" that takes ast_spec as ASTSpecification and context as Dictionary[String, Any] returns ASTNode:
    Try:
        Let class_name be ast_spec.properties["name"] if ast_spec.properties contains "name" else "AnonymousClass"
        Let base_classes be ast_spec.properties["base_classes"] if ast_spec.properties contains "base_classes" else list containing
        Let methods be ast_spec.properties["methods"] if ast_spec.properties contains "methods" else list containing
        Let fields be ast_spec.properties["fields"] if ast_spec.properties contains "fields" else list containing
        
        Let field_nodes be list containing
        For each field in fields:
            Let field_node be ASTNode with:
                node_type as "field"
                value as field.get with key as "name" and default as "unknown_field"
                children as list containing
                position as Position with:
                    line as 0
                    column as 0
                    offset as 0
                    metadata as dictionary containing
                metadata as dictionary containing:
                    "field_type" as field.get with key as "type" and default as "Any"
                    "visibility" as field.get with key as "visibility" and default as "public"
            Add field_node to field_nodes
        
        Let method_nodes be list containing
        For each method in methods:
            Let method_spec be ASTSpecification with:
                node_type as "function"
                properties as method
                children as list containing
                metadata as dictionary containing
            Let method_node be function_ast_generator with ast_spec as method_spec and context as context
            Add method_node to method_nodes
        
        Let base_class_nodes be list containing
        For each base_class in base_classes:
            Let base_node be ASTNode with:
                node_type as "base_class"
                value as base_class
                children as list containing
                position as Position with:
                    line as 0
                    column as 0
                    offset as 0
                    metadata as dictionary containing
                metadata as dictionary containing
            Add base_node to base_class_nodes
        
        Let class_children be list containing
        Add base_class_nodes to class_children
        Add field_nodes to class_children
        Add method_nodes to class_children
        
        Return ASTNode with:
            node_type as "class_definition"
            value as class_name
            children as class_children
            position as Position with:
                line as 0
                column as 0
                offset as 0
                metadata as dictionary containing
            metadata as dictionary containing:
                "class_name" as class_name
                "method_count" as length of methods
                "field_count" as length of fields
                "base_class_count" as length of base_classes
        
    Catch error:
        Return create_error_ast with message as "Class AST generation failed: " plus error.message

Process called "variable_ast_generator" that takes ast_spec as ASTSpecification and context as Dictionary[String, Any] returns ASTNode:
    Try:
        Let variable_name be ast_spec.properties["name"] if ast_spec.properties contains "name" else "unknown_variable"
        Let variable_type be ast_spec.properties["type"] if ast_spec.properties contains "type" else "Any"
        Let initial_value be ast_spec.properties["initial_value"] if ast_spec.properties contains "initial_value" else None
        Let is_constant be ast_spec.properties["is_constant"] if ast_spec.properties contains "is_constant" else false
        Let scope be ast_spec.properties["scope"] if ast_spec.properties contains "scope" else "local"
        
        Let variable_children be list containing
        
        If initial_value is not None:
            Let value_node be ASTNode with:
                node_type as "literal"
                value as initial_value
                children as list containing
                position as Position with:
                    line as 0
                    column as 0
                    offset as 0
                    metadata as dictionary containing
                metadata as dictionary containing:
                    "literal_type" as "initial_value"
            Add value_node to variable_children
        
        Return ASTNode with:
            node_type as "variable_declaration"
            value as variable_name
            children as variable_children
            position as Position with:
                line as 0
                column as 0
                offset as 0
                metadata as dictionary containing
            metadata as dictionary containing:
                "variable_name" as variable_name
                "variable_type" as variable_type
                "is_constant" as is_constant
                "scope" as scope
                "has_initial_value" as initial_value is not None
        
    Catch error:
        Return create_error_ast with message as "Variable AST generation failed: " plus error.message

Process called "expression_ast_generator" that takes ast_spec as ASTSpecification and context as Dictionary[String, Any] returns ASTNode:
    Try:
        Let expression_type be ast_spec.properties["expression_type"] if ast_spec.properties contains "expression_type" else "unknown"
        Let operator be ast_spec.properties["operator"] if ast_spec.properties contains "operator" else None
        Let operands be ast_spec.properties["operands"] if ast_spec.properties contains "operands" else list containing
        Let value be ast_spec.properties["value"] if ast_spec.properties contains "value" else None
        
        Let expression_children be list containing
        
        If expression_type equals "binary_operation":
            If length of operands is greater than or equal to 2:
                Let left_operand_spec be ASTSpecification with:
                    node_type as "expression"
                    properties as operands[0]
                    children as list containing
                    metadata as dictionary containing
                Let left_node be expression_ast_generator with ast_spec as left_operand_spec and context as context
                Add left_node to expression_children
                
                Let right_operand_spec be ASTSpecification with:
                    node_type as "expression"
                    properties as operands[1]
                    children as list containing
                    metadata as dictionary containing
                Let right_node be expression_ast_generator with ast_spec as right_operand_spec and context as context
                Add right_node to expression_children
        
        Otherwise if expression_type equals "unary_operation":
            If length of operands is greater than 0:
                Let operand_spec be ASTSpecification with:
                    node_type as "expression"
                    properties as operands[0]
                    children as list containing
                    metadata as dictionary containing
                Let operand_node be expression_ast_generator with ast_spec as operand_spec and context as context
                Add operand_node to expression_children
        
        Otherwise if expression_type equals "function_call":
            Let function_name be ast_spec.properties["function_name"] if ast_spec.properties contains "function_name" else "unknown_function"
            Let arguments be ast_spec.properties["arguments"] if ast_spec.properties contains "arguments" else list containing
            
            For each arg in arguments:
                Let arg_spec be ASTSpecification with:
                    node_type as "expression"
                    properties as arg
                    children as list containing
                    metadata as dictionary containing
                Let arg_node be expression_ast_generator with ast_spec as arg_spec and context as context
                Add arg_node to expression_children
        
        Return ASTNode with:
            node_type as expression_type
            value as operator if operator is not None else value
            children as expression_children
            position as Position with:
                line as 0
                column as 0
                offset as 0
                metadata as dictionary containing
            metadata as dictionary containing:
                "expression_type" as expression_type
                "operator" as operator
                "operand_count" as length of operands
        
    Catch error:
        Return create_error_ast with message as "Expression AST generation failed: " plus error.message

