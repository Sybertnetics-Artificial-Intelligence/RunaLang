Process called "complexity_analyzer" that takes expansion as ExpansionResult returns Float:
    Try:
        If expansion is ExpansionSuccess:
            Let complexity be 0.0
            
            Set complexity to complexity plus length of expansion.tokens multiplied by 0.1
            
            For each token in expansion.tokens:
                If token.type equals "operator":
                    Set complexity to complexity plus 1.0
                Otherwise if token.type equals "keyword":
                    Set complexity to complexity plus 2.0
                Otherwise if token.metadata contains "folded" and token.metadata["folded"]:
                    Set complexity to complexity minus 0.5
            
            Let nesting_depth be calculate_nesting_depth with tokens as expansion.tokens
            Set complexity to complexity plus nesting_depth multiplied by 3.0
            
            Return complexity
        Otherwise:
            Return 100.0
        
    Catch error:
        Return 50.0

