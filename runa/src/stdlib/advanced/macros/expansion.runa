Note: Pattern Matching Utility Functions
Process called "split_pattern_syntax" that takes pattern as MacroPattern returns List[String]:
    Try:
        Return pattern.syntax.split with sep as " "
    Catch error:
        Return list containing pattern.syntax

Process called "get_current_time" returns Float:
    Import "time"
    Try:
        Return time.time
    Catch error:
        Return 0.0

Process called "tokenize_code" that takes code as String returns List[Token]:
    Try:
        Let tokens be list containing
        Let words be code.split
        Let line be 1
        Let column be 0
        
        For each word in words:
            Let token be Token with:
                type as determine_token_type with word as word
                value as word
                position as Position with:
                    line as line
                    column as column
                    offset as column
                    metadata as dictionary containing
                metadata as dictionary containing
            Add token to tokens
            Set column to column plus length of word plus 1
        
        Return tokens
        
    Catch error:
        Return list containing create_error_token with message as "Tokenization failed"

Process called "determine_token_type" that takes word as String returns String:
    Try:
        If word.startswith with prefix as "\"" and word.endswith with suffix as "\"":
            Return "string"
        
        If word.isdigit:
            Return "number"
        
        If word in list containing "Let", "If", "Otherwise", "Process", "Return":
            Return "keyword"
        
        If word in list containing "+", "-", "*", "/", "==", "!=":
            Return "operator"
        
        If word in list containing "(", ")", "{", "}", "[", "]":
            Return "delimiter"
        
        Return "identifier"
        
    Catch error:
        Return "unknown"

Process called "create_error_token" that takes message as String returns Token:
    Return Token with:
        type as "error"
        value as message
        position as Position with:
            line as 0
            column as 0
            offset as 0
            metadata as dictionary containing
        metadata as dictionary containing:
            "error_type" as "expansion_error"

Note: Additional Utility Functions
Process called "substitute_variables_in_ast" that takes ast as ASTNode and bindings as Dictionary[String, Any] returns ASTNode:
    Try:
        Let new_value be ast.value
        If ast.value is not None and bindings contains ast.value:
            Set new_value to bindings[ast.value]
        
        Let new_children be list containing
        For each child in ast.children:
            Let processed_child be substitute_variables_in_ast with ast as child and bindings as bindings
            Add processed_child to new_children
        
        Return ASTNode with:
            node_type as ast.node_type
            value as new_value
            children as new_children
            position as ast.position
            metadata as ast.metadata
        
    Catch error:
        Return ast

Process called "convert_ast_to_tokens" that takes ast as ASTNode returns List[Token]:
    Try:
        Let tokens be list containing
        
        If ast.value is not None:
            Let token be Token with:
                type as ast.node_type
                value as ast.value
                position as ast.position
                metadata as ast.metadata
            Add token to tokens
        
        For each child in ast.children:
            Let child_tokens be convert_ast_to_tokens with ast as child
            Add child_tokens to tokens
        
        Return tokens
        
    Catch error:
        Return list containing

Process called "remove_duplicate_tokens" that takes tokens as List[Token] returns List[Token]:
    Try:
        Let unique_tokens be list containing
        Let seen_values be list containing
        
        For each token in tokens:
            Let token_key be token.type plus ":" plus token.value
            If not seen_values contains token_key:
                Add token to unique_tokens
                Add token_key to seen_values
        
        Return unique_tokens
        
    Catch error:
        Return tokens

Process called "get_value_type" that takes value as Any returns String:
    Try:
        Return type(value).__name__
    Catch error:
        Return "unknown"

Process called "parse_number" that takes text as String returns Float:
    Try:
        Return float(text)
    Catch error:
        Return 0.0

Process called "convert_to_string" that takes value as Any returns String:
    Try:
        Return str(value)
    Catch error:
        Return ""

Process called "evaluate_constant_operation" that takes left as String and operator as String and right as String returns String:
    Try:
        Let left_val be parse_number with text as left
        Let right_val be parse_number with text as right
        
        If operator equals "+":
            Return str(left_val plus right_val)
        Otherwise if operator equals "-":
            Return str(left_val minus right_val)
        Otherwise if operator equals "*":
            Return str(left_val multiplied by right_val)
        Otherwise if operator equals "/":
            If right_val is not equal to 0.0:
                Return str(left_val divided by right_val)
            Otherwise:
                Return left
        Otherwise:
            Return left plus operator plus right
        
    Catch error:
        Return left plus operator plus right

Process called "calculate_nesting_depth" that takes tokens as List[Token] returns Integer:
    Try:
        Let max_depth be 0
        Let current_depth be 0
        
        For each token in tokens:
            If token.value in list containing "(", "{", "[":
                Set current_depth to current_depth plus 1
                If current_depth is greater than max_depth:
                    Set max_depth to current_depth
            Otherwise if token.value in list containing ")", "}", "]":
                Set current_depth to current_depth minus 1
        
        Return max_depth
        
    Catch error:
        Return 0 