Note:
Runa Advanced Standard Library: Compile-Time Metaprogramming Module

Provides advanced compile-time metaprogramming capabilities for static analysis, code generation, and optimization.

Features:
- Compile-time evaluation and execution
- Static assertions and diagnostics
- Constant folding and propagation
- Type introspection and manipulation
- Compile-time code generation and macros
- Error handling, diagnostics, and reporting
- AI/agent-friendly APIs
- Production-ready, robust, and extensible
:End Note

Note: Compile-Time Types and Interfaces
Type called "CompileTimeContext":
    config as CompileTimeConfig
    stats as CompileTimeStats
    metadata as Dictionary[String, Any]

Type called "CompileTimeConfig":
    enable_constant_folding as Boolean
    enable_type_introspection as Boolean
    enable_static_assertions as Boolean
    enable_code_generation as Boolean
    enable_macros as Boolean
    ai_mode as Boolean
    metadata as Dictionary[String, Any]

Type called "CompileTimeStats":
    total_evaluated as Integer
    total_assertions as Integer
    total_errors as Integer
    total_warnings as Integer
    metadata as Dictionary[String, Any]

Type CompileTimeError is Exception with:
    message as String
    metadata as Dictionary[String, Any]

Type CompileTimeWarning is Exception with:
    message as String
    metadata as Dictionary[String, Any]

Type called "TypeInfo":
    type_id as String
    type_kind as String
    size as Integer
    alignment as Integer
    is_primitive as Boolean
    is_reference as Boolean
    metadata as Dictionary[String, Any]

Note: Hygienic Macro System Types
Type called "MacroDefinition":
    name as String
    parameters as List[MacroParameter]
    body as ASTNode
    hygiene_scope as HygieneScope
    metadata as Dictionary[String, Any]

Type called "MacroParameter":
    name as String
    parameter_type as MacroParameterType
    default_value as Optional[Any]
    metadata as Dictionary[String, Any]

Type MacroParameterType is:
    | Expr
    | Stmt
    | Type
    | Ident
    | Block
    | Literal

Type called "HygieneScope":
    scope_id as String
    parent_scope as Optional[String]
    bound_variables as Dictionary[String, String]
    introduced_variables as List[String]
    metadata as Dictionary[String, Any]

Type called "MacroExpansion":
    original_call as ASTNode
    expanded_ast as ASTNode
    hygiene_scope as HygieneScope
    expansion_context as CompileTimeContext
    metadata as Dictionary[String, Any]

Type called "MacroRegistry":
    macros as Dictionary[String, MacroDefinition]
    builtin_macros as Dictionary[String, Function]
    expansion_history as List[MacroExpansion]
    hygiene_counter as Integer
    metadata as Dictionary[String, Any]

Note: Core Compile-Time Functions
Process called "evaluate_at_compile_time" that takes context as CompileTimeContext and expr as Any returns Any:
    If context.config.enable_constant_folding:
        Let folded be constant_fold with context as context and expr as expr
        Return folded
    Return expr

Process called "static_assert" that takes context as CompileTimeContext and condition as Boolean and message as String returns None:
    If not condition:
        report_compile_time_error with context as context and error as message
    Set context.stats.total_assertions to context.stats.total_assertions plus 1

Process called "constant_fold" that takes context as CompileTimeContext and expr as Any returns Any:
    If expr is Integer or expr is Float or expr is Boolean or expr is String:
        Return expr
    If expr is List:
        Return [constant_fold with context as context and expr as item for each item in expr]
    If expr is Dictionary:
        Return {key: constant_fold with context as context and expr as value for each key, value in expr}
    If expr is BinaryOperation:
        Let left be constant_fold with context as context and expr as expr.left
        Let right be constant_fold with context as context and expr as expr.right
        If left and right are both Integer or both Float:
            If expr.op is "+":
                Return left plus right
            If expr.op is "-":
                Return left minus right
            If expr.op is "*":
                Return left multiplied by right
            If expr.op is "/":
                If right is 0:
                    report_compile_time_error with context as context and error as "Division by zero in constant folding"
                Return left divided by right
        Return BinaryOperation with left as left, right as right, op as expr.op
    Return expr

Process called "type_introspect" that takes context as CompileTimeContext and type_info as Any returns TypeInfo:
    If type_info is Integer:
        Return TypeInfo with type_id as "Integer", type_kind as "primitive", size as 8, alignment as 8, is_primitive as true, is_reference as false, metadata as dictionary containing
    If type_info is Float:
        Return TypeInfo with type_id as "Float", type_kind as "primitive", size as 8, alignment as 8, is_primitive as true, is_reference as false, metadata as dictionary containing
    If type_info is Boolean:
        Return TypeInfo with type_id as "Boolean", type_kind as "primitive", size as 1, alignment as 1, is_primitive as true, is_reference as false, metadata as dictionary containing
    If type_info is String:
        Return TypeInfo with type_id as "String", type_kind as "reference", size as 24, alignment as 8, is_primitive as false, is_reference as true, metadata as dictionary containing
    If type_info is List:
        Return TypeInfo with type_id as "List", type_kind as "collection", size as 24, alignment as 8, is_primitive as false, is_reference as true, metadata as dictionary containing
    If type_info is Dictionary:
        Return TypeInfo with type_id as "Dictionary", type_kind as "collection", size as 32, alignment as 8, is_primitive as false, is_reference as true, metadata as dictionary containing
    Return TypeInfo with type_id as "Unknown", type_kind as "unknown", size as 0, alignment as 0, is_primitive as false, is_reference as false, metadata as dictionary containing

Process called "generate_code_at_compile_time" that takes context as CompileTimeContext and spec as Any returns String:
    If context.config.enable_code_generation:
        If spec is String:
            Return spec
        If spec is List:
            Return join with separator as "\n" and items as [generate_code_at_compile_time with context as context and spec as item for each item in spec]
        If spec is Dictionary and spec contains "template":
            Return interpolate_template with template as spec["template"] and values as spec["values"]
        report_compile_time_warning with context as context and warning as "Unknown code generation spec type"
        Return ""
    report_compile_time_warning with context as context and warning as "Code generation is disabled"
    Return ""

Process called "report_compile_time_error" that takes context as CompileTimeContext and error as String returns None:
    Set context.stats.total_errors to context.stats.total_errors plus 1
    Raise CompileTimeError with message as error

Process called "report_compile_time_warning" that takes context as CompileTimeContext and warning as String returns None:
    Set context.stats.total_warnings to context.stats.total_warnings plus 1
    Raise CompileTimeWarning with message as warning

Process called "interpolate_template" that takes template as String and values as Dictionary[String, Any] returns String:
    Let result be template
    For each key, value in values:
        Set result to result.replace("{{" plus key plus "}}", to_string with value as value)
    Return result

Note: Hygienic Macro System Implementation
Process called "create_macro_registry" returns MacroRegistry:
    Let builtin_macros be dictionary containing
    Set builtin_macros["identity"] to builtin_identity_macro
    Set builtin_macros["debug_print"] to builtin_debug_print_macro
    Set builtin_macros["assert"] to builtin_assert_macro
    Set builtin_macros["let_binding"] to builtin_let_binding_macro
    Set builtin_macros["for_loop"] to builtin_for_loop_macro
    Return MacroRegistry with:
        macros as dictionary containing
        builtin_macros as builtin_macros
        expansion_history as list containing
        hygiene_counter as 0
        metadata as dictionary containing

Process called "register_macro" that takes registry as MacroRegistry and macro_def as MacroDefinition returns Boolean:
    If macro_def.name in registry.macros:
        Return false
    Set registry.macros[macro_def.name] to macro_def
    Return true

Process called "create_hygiene_scope" that takes registry as MacroRegistry and parent_scope as Optional[String] returns HygieneScope:
    Set registry.hygiene_counter to registry.hygiene_counter plus 1
    Let scope_id be "hygiene_" plus registry.hygiene_counter
    Return HygieneScope with:
        scope_id as scope_id
        parent_scope as parent_scope
        bound_variables as dictionary containing
        introduced_variables as list containing
        metadata as dictionary containing

Process called "bind_variable" that takes scope as HygieneScope and original_name as String and new_name as String returns None:
    Set scope.bound_variables[original_name] to new_name

Process called "introduce_variable" that takes scope as HygieneScope and var_name as String returns String:
    Let unique_name be var_name plus "_" plus scope.scope_id
    Add unique_name to scope.introduced_variables
    Return unique_name

Process called "resolve_variable" that takes scope as HygieneScope and var_name as String returns String:
    If var_name in scope.bound_variables:
        Return scope.bound_variables[var_name]
    If scope.parent_scope is not None:
        Let parent be get_scope_by_id with scope_id as scope.parent_scope
        If parent is not None:
            Return resolve_variable with scope as parent and var_name as var_name
    Return var_name

Process called "macro_expand" that takes context as CompileTimeContext and registry as MacroRegistry and macro_call as ASTNode returns MacroExpansion:
    If not context.config.enable_macros:
        report_compile_time_error with context as context and error as "Macros are disabled in this context"
    
    Let macro_name be macro_call.name
    Let args be macro_call.arguments
    
    If macro_name in registry.builtin_macros:
        Let builtin_macro be registry.builtin_macros[macro_name]
        Let result be builtin_macro with context as context and args as args
        Let hygiene_scope be create_hygiene_scope with registry as registry and parent_scope as None
        Return MacroExpansion with:
            original_call as macro_call
            expanded_ast as result
            hygiene_scope as hygiene_scope
            expansion_context as context
            metadata as dictionary containing
    
    If macro_name in registry.macros:
        Let macro_def be registry.macros[macro_name]
        Return expand_user_macro with context as context and registry as registry and macro_def as macro_def and args as args and original_call as macro_call
    
    report_compile_time_error with context as context and error as "Unknown macro: " plus macro_name
    Return None

Process called "expand_user_macro" that takes context as CompileTimeContext and registry as MacroRegistry and macro_def as MacroDefinition and args as List[ASTNode] and original_call as ASTNode returns MacroExpansion:
    If length of args is not length of macro_def.parameters:
        report_compile_time_error with context as context and error as "Macro " plus macro_def.name plus " expects " plus length of macro_def.parameters plus " arguments, got " plus length of args
    
    Let expansion_scope be create_hygiene_scope with registry as registry and parent_scope as macro_def.hygiene_scope.scope_id
    Let substitution_map be dictionary containing
    
    For i from 0 to length of macro_def.parameters minus 1:
        Let param be macro_def.parameters[i]
        Let arg be args[i]
        Let hygienized_arg be apply_hygiene_to_ast with ast as arg and scope as expansion_scope
        Set substitution_map[param.name] to hygienized_arg
    
    Let expanded_body be substitute_in_ast with ast as macro_def.body and substitutions as substitution_map
    Let final_ast be apply_hygiene_to_ast with ast as expanded_body and scope as expansion_scope
    
    Let expansion be MacroExpansion with:
        original_call as original_call
        expanded_ast as final_ast
        hygiene_scope as expansion_scope
        expansion_context as context
        metadata as dictionary containing
    
    Add expansion to registry.expansion_history
    Return expansion

Process called "apply_hygiene_to_ast" that takes ast as ASTNode and scope as HygieneScope returns ASTNode:
    If ast.node_type is "Identifier":
        Let resolved_name be resolve_variable with scope as scope and var_name as ast.name
        Return create_ast_node with:
            node_type as "Identifier"
            value as resolved_name
            children as list containing
            position as ast.position
            annotations as ast.annotations
            metadata as ast.metadata
    
    If ast.node_type is "LetStatement":
        Let new_var_name be introduce_variable with scope as scope and var_name as ast.identifier
        bind_variable with scope as scope and original_name as ast.identifier and new_name as new_var_name
        Let hygienized_value be apply_hygiene_to_ast with ast as ast.value and scope as scope
        Return create_ast_node with:
            node_type as "LetStatement"
            value as new_var_name
            children as list containing hygienized_value
            position as ast.position
            annotations as ast.annotations
            metadata as ast.metadata
    
    Let hygienized_children be list containing
    For each child in ast.children:
        Add apply_hygiene_to_ast with ast as child and scope as scope to hygienized_children
    
    Return create_ast_node with:
        node_type as ast.node_type
        value as ast.value
        children as hygienized_children
        position as ast.position
        annotations as ast.annotations
        metadata as ast.metadata

Process called "substitute_in_ast" that takes ast as ASTNode and substitutions as Dictionary[String, ASTNode] returns ASTNode:
    If ast.node_type is "Identifier" and ast.name in substitutions:
        Return deep_copy_ast_node with node as substitutions[ast.name]
    
    Let substituted_children be list containing
    For each child in ast.children:
        Add substitute_in_ast with ast as child and substitutions as substitutions to substituted_children
    
    Return create_ast_node with:
        node_type as ast.node_type
        value as ast.value
        children as substituted_children
        position as ast.position
        annotations as ast.annotations
        metadata as ast.metadata

Note: Built-in Macro Implementations
Process called "builtin_identity_macro" that takes context as CompileTimeContext and args as List[ASTNode] returns ASTNode:
    If length of args is not 1:
        report_compile_time_error with context as context and error as "Identity macro expects exactly 1 argument"
    Return deep_copy_ast_node with node as args[0]

Process called "builtin_debug_print_macro" that takes context as CompileTimeContext and args as List[ASTNode] returns ASTNode:
    If length of args is 0:
        report_compile_time_error with context as context and error as "Debug print macro expects at least 1 argument"
    Let print_statements be list containing
    For each arg in args:
        Let print_call be create_ast_node with:
            node_type as "FunctionCall"
            value as "Display"
            children as list containing arg
            position as arg.position
            annotations as list containing
            metadata as dictionary containing
        Add print_call to print_statements
    Return create_ast_node with:
        node_type as "Block"
        value as None
        children as print_statements
        position as args[0].position
        annotations as list containing
        metadata as dictionary containing

Process called "builtin_assert_macro" that takes context as CompileTimeContext and args as List[ASTNode] returns ASTNode:
    If length of args is not 1 and length of args is not 2:
        report_compile_time_error with context as context and error as "Assert macro expects 1 or 2 arguments"
    Let condition be args[0]
    Let message be args[1] if length of args is 2 else create_literal_ast with value as "Assertion failed"
    Return create_ast_node with:
        node_type as "IfStatement"
        value as None
        children as list containing condition, create_panic_statement with message as message
        position as condition.position
        annotations as list containing
        metadata as dictionary containing

Process called "builtin_let_binding_macro" that takes context as CompileTimeContext and args as List[ASTNode] returns ASTNode:
    If length of args is not 2:
        report_compile_time_error with context as context and error as "Let binding macro expects exactly 2 arguments (name, value)"
    Let name_ast be args[0]
    Let value_ast be args[1]
    If name_ast.node_type is not "Identifier":
        report_compile_time_error with context as context and error as "First argument to let binding macro must be an identifier"
    Return create_ast_node with:
        node_type as "LetStatement"
        value as name_ast.name
        children as list containing value_ast
        position as name_ast.position
        annotations as list containing
        metadata as dictionary containing

Process called "builtin_for_loop_macro" that takes context as CompileTimeContext and args as List[ASTNode] returns ASTNode:
    If length of args is not 3:
        report_compile_time_error with context as context and error as "For loop macro expects exactly 3 arguments (var, iterable, body)"
    Let var_ast be args[0]
    Let iterable_ast be args[1]
    Let body_ast be args[2]
    If var_ast.node_type is not "Identifier":
        report_compile_time_error with context as context and error as "First argument to for loop macro must be an identifier"
    Return create_ast_node with:
        node_type as "ForEachStatement"
        value as var_ast.name
        children as list containing iterable_ast, body_ast
        position as var_ast.position
        annotations as list containing
        metadata as dictionary containing

Note: Helper Functions
Process called "create_literal_ast" that takes value as Any returns ASTNode:
    Return create_ast_node with:
        node_type as "Literal"
        value as value
        children as list containing
        position as create_position with line as 0 and column as 0 and offset as 0
        annotations as list containing
        metadata as dictionary containing

Process called "create_panic_statement" that takes message as ASTNode returns ASTNode:
    Return create_ast_node with:
        node_type as "PanicStatement"
        value as None
        children as list containing message
        position as message.position
        annotations as list containing
        metadata as dictionary containing

Process called "get_scope_by_id" that takes scope_id as String returns Optional[HygieneScope]:
    Note: Look up scope in global scope registry with proper error handling
    Try:
        Let scope_registry be get_global_scope_registry
        If scope_registry contains scope_id:
            Let scope_data be scope_registry[scope_id]
            If scope_data is not equal to None and scope_data contains "type" and scope_data["type"] is equal to "hygiene_scope":
                Return HygieneScope with:
                    id as scope_data.get with key as "id" and default as scope_id
                    parent_id as scope_data.get with key as "parent_id" and default as None
                    bindings as scope_data.get with key as "bindings" and default as empty dictionary
                    metadata as scope_data.get with key as "metadata" and default as empty dictionary
    Catch Exception:
        Pass
    
    Return None  Note: Return None if scope lookup fails 