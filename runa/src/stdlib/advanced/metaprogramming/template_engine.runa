Note:
Runa Advanced Standard Library: Template Engine Module

Provides advanced, production-grade templating for code and text generation, metaprogramming, and automation. Supports robust template parsing, variable interpolation, control flow, partials, macros, inheritance, error handling, and debugging. All code and comments follow Runa conventions.
:End Note

Note: Template Engine Types and Interfaces
Type called "TemplateEngine":
    config as TemplateEngineConfig
    templates as Dictionary[String, Template]
    renderers as Dictionary[String, TemplateRenderer]
    stats as TemplateEngineStats
    metadata as Dictionary[String, Any]

Type called "TemplateEngineConfig":
    enable_inheritance as Boolean
    enable_macros as Boolean
    enable_partials as Boolean
    enable_control_flow as Boolean
    ai_mode as Boolean
    metadata as Dictionary[String, Any]

Type called "TemplateEngineStats":
    total_rendered as Integer
    total_errors as Integer
    metadata as Dictionary[String, Any]

Type called "Template":
    template_id as String
    template_type as String
    template_code as String
    variables as List[TemplateVariable]
    partials as List[String]
    macros as List[String]
    parent as Optional[String]
    metadata as Dictionary[String, Any]

Type called "TemplateVariable":
    name as String
    variable_type as String
    default_value as Any
    metadata as Dictionary[String, Any]

Type TemplateRenderer is Function that takes template as Template and context as Dictionary[String, Any] returns String

Type TemplateEngineError is Exception with:
    message as String
    metadata as Dictionary[String, Any]

Note: Core Template Engine Functions
Process called "register_template" that takes engine as TemplateEngine and template as Template returns Boolean:
    Set engine.templates[template.template_id] to template
    Return true

Process called "render_template" that takes engine as TemplateEngine and template_id as String and context as Dictionary[String, Any] returns String:
    Let template be engine.templates[template_id] if engine.templates contains template_id else None
    If template is None:
        Set engine.stats.total_errors to engine.stats.total_errors plus 1
        Raise TemplateEngineError with message as "Template not found: " plus template_id and metadata as dictionary containing
    Let renderer be engine.renderers[template.template_type] if engine.renderers contains template.template_type else default_template_renderer
    Let rendered as String be renderer with template as template and context as context
    Set engine.stats.total_rendered to engine.stats.total_rendered plus 1
    Return rendered

Process called "default_template_renderer" that takes template as Template and context as Dictionary[String, Any] returns String:
    Let code as String be template.template_code
    For each variable in template.variables:
        If variable.name in context:
            Set code to code.replace("{{" plus variable.name plus "}}", to_string with value as context[variable.name])
        Else if variable.default_value is not None:
            Set code to code.replace("{{" plus variable.name plus "}}", to_string with value as variable.default_value)
        Else:
            Set code to code.replace("{{" plus variable.name plus "}}", "")
    If template.parent is not None:
        Let parent_template be engine.templates[template.parent] if template.parent in engine.templates else None
        If parent_template is not None:
            Set code to parent_template.template_code.replace("{{content}}", code)
    Return code

Process called "render_partial" that takes engine as TemplateEngine and partial_id as String and context as Dictionary[String, Any] returns String:
    If not engine.config.enable_partials:
        Raise TemplateEngineError with message as "Partials are disabled" and metadata as dictionary containing
    If partial_id not in engine.templates:
        Raise TemplateEngineError with message as "Partial not found: " plus partial_id and metadata as dictionary containing
    Return render_template with engine as engine and template_id as partial_id and context as context

Process called "render_macro" that takes engine as TemplateEngine and macro_name as String and args as Dictionary[String, Any] returns String:
    If not engine.config.enable_macros:
        Raise TemplateEngineError with message as "Macros are disabled" and metadata as dictionary containing
    If macro_name not in engine.renderers:
        Raise TemplateEngineError with message as "Macro not found: " plus macro_name and metadata as dictionary containing
    Let macro_renderer be engine.renderers[macro_name]
    Return macro_renderer with template as None and context as args

Process called "render_with_control_flow" that takes template as Template and context as Dictionary[String, Any] returns String:
    If not engine.config.enable_control_flow:
        Return default_template_renderer with template as template and context as context
    Let code as String be template.template_code
    Note: Idiomatic Runa: parse and render if/else blocks
    Let output as ""
    Let lines as split code by "\n"
    Let i as 0
    While i is less than length of lines:
        Let line as lines[i]
        If line starts with "{{#if ":
            Let cond as substring of line from 6 to (length of line minus 2)
            Let block_lines as list containing
            Set i to i plus 1
            While i is less than length of lines and not lines[i] starts with "{{/if}}":
                Add lines[i] to block_lines
                Set i to i plus 1
            If cond in context and context[cond]:
                For each block_line in block_lines:
                    Set output to output plus block_line plus "\n"
            Set i to i plus 1
            Continue
        If line starts with "{{#for ":
            Let for_expr as substring of line from 7 to (length of line minus 2)
            Let parts as split for_expr by " in "
            If length of parts is 2:
                Let var as parts[0].strip()
                Let list_name as parts[1].strip()
                Let block_lines as list containing
                Set i to i plus 1
                While i is less than length of lines and not lines[i] starts with "{{/for}}":
                    Add lines[i] to block_lines
                    Set i to i plus 1
                If list_name in context:
                    For each item in context[list_name]:
                        Let local_context as copy of context
                        Set local_context[var] to item
                        For each block_line in block_lines:
                            Let rendered_line as render_template with engine as engine and template_id as template.template_id and context as local_context
                            Set output to output plus rendered_line plus "\n"
                Set i to i plus 1
                Continue
        Set output to output plus line plus "\n"
        Set i to i plus 1
    Return output 