Note:
Runa Advanced Standard Library: AST Manipulation Module

Provides advanced, production-grade Abstract Syntax Tree (AST) manipulation for metaprogramming, code analysis, and transformation. Supports robust construction, traversal, transformation, pattern matching, rewriting, annotation, validation, diffing, and merging. All code and comments follow Runa conventions.
:End Note


Import "../utilities/common" as Common
Note: AST Types and Interfaces
Type called "ASTNode":
    node_type as String
    value as Any
    children as List[ASTNode]
    position as Position
    annotations as List[Annotation]
    metadata as Dictionary[String, Any]

Type called "Position":
    line as Integer
    column as Integer
    offset as Integer
    metadata as Dictionary[String, Any]

Type called "Annotation":
    annotation_type as String
    value as Any
    metadata as Dictionary[String, Any]

Note: Core AST Manipulation Functions
Process called "create_ast_node" that takes node_type as String and value as Any and children as List[ASTNode] and position as Position returns ASTNode:
    Return ASTNode with:
        node_type as node_type
        value as value
        children as Common.copy_list with list as children
        position as copy_position with position as position
        annotations as list containing
        metadata as dictionary containing

Process called "traverse_ast" that takes node as ASTNode and visitor as Function returns None:
    visitor with node as node
    For each child in node.children:
        traverse_ast with node as child and visitor as visitor

Process called "transform_ast" that takes node as ASTNode and transformer as Function returns ASTNode:
    Let transformed_node be transformer with node as node
    Let new_children be list containing
    For each child in node.children:
        Add transform_ast with node as child and transformer as transformer to new_children
    Return create_ast_node with:
        node_type as transformed_node.node_type
        value as transformed_node.value
        children as new_children
        position as transformed_node.position
        annotations as Common.copy_list with list as transformed_node.annotations
        metadata as Common.copy_dictionary with dict as transformed_node.metadata

Process called "match_ast_pattern" that takes node as ASTNode and pattern as ASTPattern returns Boolean:
    If node.node_type is not pattern.pattern_type:
        Return false
    If pattern.value is not None and node.value is not pattern.value:
        Return false
    If length of node.children is not length of pattern.children:
        Return false
    For i from 0 to length of node.children minus 1:
        If not match_ast_pattern with node as node.children[i] and pattern as pattern.children[i]:
            Return false
    Return true

Process called "rewrite_ast" that takes node as ASTNode and rules as List[RewriteRule] returns ASTNode:
    For each rule in rules:
        If match_ast_pattern with node as node and pattern as rule.pattern:
            Return deep_copy_ast_node with node as rule.replacement
    Let new_children be list containing
    For each child in node.children:
        Add rewrite_ast with node as child and rules as rules to new_children
    Return create_ast_node with:
        node_type as node.node_type
        value as node.value
        children as new_children
        position as node.position
        annotations as Common.copy_list with list as node.annotations
        metadata as Common.copy_dictionary with dict as node.metadata

Process called "annotate_ast_node" that takes node as ASTNode and annotation as Annotation returns ASTNode:
    Add annotation to node.annotations
    Return node

Process called "validate_ast" that takes node as ASTNode returns Boolean:
    If node.node_type is None or node.children is None:
        Return false
    For each child in node.children:
        If not validate_ast with node as child:
            Return false
    Return true

Process called "diff_ast" that takes node1 as ASTNode and node2 as ASTNode returns ASTDiff:
    Let differences as list containing
    If node1.node_type is not node2.node_type or node1.value is not node2.value:
        Add ASTDifference with diff_type as "type_or_value", node1 as node1, node2 as node2, description as "Node type or value differs", metadata as dictionary containing to differences
    If length of node1.children is not length of node2.children:
        Add ASTDifference with diff_type as "children_count", node1 as node1, node2 as node2, description as "Children count differs", metadata as dictionary containing to differences
    For i from 0 to min(length of node1.children, length of node2.children) minus 1:
        Let child_diff as diff_ast with node1 as node1.children[i] and node2 as node2.children[i]
        Add all child_diff.differences to differences
    Return ASTDiff with:
        differences as differences
        metadata as dictionary containing

Process called "merge_ast" that takes base as ASTNode and other as ASTNode returns ASTNode:
    Let merged_children be base.children plus other.children
    Let merged_annotations be base.annotations plus other.annotations
    Let merged_metadata be merge_dictionaries with dict1 as base.metadata and dict2 as other.metadata
    Return create_ast_node with:
        node_type as base.node_type
        value as base.value
        children as merged_children
        position as base.position
        annotations as merged_annotations
        metadata as merged_metadata

Type called "ASTPattern":
    pattern_type as String
    value as Any
    children as List[ASTPattern]
    metadata as Dictionary[String, Any]

Type called "RewriteRule":
    rule_id as String
    pattern as ASTPattern
    replacement as ASTNode
    conditions as List[String]
    metadata as Dictionary[String, Any]

Type called "ASTDiff":
    differences as List[ASTDifference]
    metadata as Dictionary[String, Any]

Type called "ASTDifference":
    diff_type as String
    node1 as ASTNode
    node2 as ASTNode
    description as String
    metadata as Dictionary[String, Any]

Note: Immutable Helper Functions for Functional AST Operations
Process called "deep_copy_ast_node" that takes node as ASTNode returns ASTNode:
    Let copied_children be list containing
    For each child in node.children:
        Add deep_copy_ast_node with node as child to copied_children
    Let copied_annotations be list containing
    For each annotation in node.annotations:
        Add copy_annotation with annotation as annotation to copied_annotations
    Return create_ast_node with:
        node_type as node.node_type
        value as node.value
        children as copied_children
        position as copy_position with position as node.position
        annotations as copied_annotations
        metadata as Common.copy_dictionary with dict as node.metadata

Process called "copy_annotation" that takes annotation as Annotation returns Annotation:
    Return Annotation with:
        annotation_type as annotation.annotation_type
        value as annotation.value
        metadata as Common.copy_dictionary with dict as annotation.metadata

Process called "copy_position" that takes position as Position returns Position:
    Return Position with:
        line as position.line
        column as position.column
        offset as position.offset
        metadata as Common.copy_dictionary with dict as position.metadata

Note: Utility function moved to ../utilities/common.runa:
        Add item to new_list
    Return new_list

Note: Utility function moved to ../utilities/common.runa:
        Set new_dict[key] to value
    Return new_dict

Process called "merge_dictionaries" that takes dict1 as Dictionary[String, Any] and dict2 as Dictionary[String, Any] returns Dictionary[String, Any]:
    Let merged be dictionary containing
    For each key, value in dict1:
        Set merged[key] to value
    For each key, value in dict2:
        Set merged[key] to value
    Return merged

Process called "create_immutable_ast_node" that takes node_type as String and value as Any and children as List[ASTNode] and position as Position and annotations as List[Annotation] and metadata as Dictionary[String, Any] returns ASTNode:
    Return ASTNode with:
        node_type as node_type
        value as value
        children as Common.copy_list with list as children
        position as copy_position with position as position
        annotations as Common.copy_list with list as annotations
        metadata as Common.copy_dictionary with dict as metadata

Process called "update_ast_node" that takes node as ASTNode and node_type as Optional[String] and value as Optional[Any] and children as Optional[List[ASTNode]] and annotations as Optional[List[Annotation]] and metadata as Optional[Dictionary[String, Any]] returns ASTNode:
    Return create_ast_node with:
        node_type as node_type if node_type is not None else node.node_type
        value as value if value is not None else node.value
        children as children if children is not None else Common.copy_list with list as node.children
        position as copy_position with position as node.position
        annotations as annotations if annotations is not None else Common.copy_list with list as node.annotations
        metadata as metadata if metadata is not None else Common.copy_dictionary with dict as node.metadata 