Note:
Runa Advanced Standard Library: Hot Reload Dependency Tracking Module

Provides comprehensive dependency tracking and analysis for hot reloading systems, including:
- Dependency graph construction and maintenance
- Circular dependency detection and resolution
- Impact analysis for change propagation
- Dependency visualization and reporting
- Incremental dependency updates
- Cross-module dependency resolution
- Version compatibility tracking
- Performance optimization for large dependency graphs

Features:
- Real-time dependency graph updates with change detection
- Circular dependency detection with detailed reporting
- Impact analysis for determining affected modules
- Dependency visualization with graph algorithms
- Incremental updates to minimize computation overhead
- Cross-platform dependency resolution
- Version compatibility checking and conflict resolution
- Performance profiling for dependency operations
- AI/agent-friendly dependency analysis and suggestions
:End Note

Import "os"
Import "collections"
Import "datetime"
Import "logging"
Import "../utilities/common" as Common

Note: Core Types and Data Structures
Type called "DependencyGraph":
    nodes as Dictionary[String, DependencyNode]
    edges as Dictionary[String, List[String]]
    reverse_edges as Dictionary[String, List[String]]
    metadata as Dictionary[String, Any]
    last_updated as Float
    version as Integer

Type called "DependencyNode":
    module_name as String
    file_path as String
    dependencies as List[String]
    dependents as List[String]
    last_modified as Float
    checksum as String
    compilation_state as String
    error_count as Integer
    metadata as Dictionary[String, Any]

Type called "DependencyEdge":
    source as String
    target as String
    edge_type as String
    weight as Float
    metadata as Dictionary[String, Any]

Type called "CircularDependency":
    cycle as List[String]
    severity as String
    description as String
    suggestions as List[String]
    metadata as Dictionary[String, Any]

Type called "ImpactAnalysis":
    changed_module as String
    affected_modules as List[String]
    impact_level as String
    propagation_path as List[String]
    estimated_reload_time as Float
    metadata as Dictionary[String, Any]

Type called "DependencyResolution":
    | ResolutionSuccess with graph as DependencyGraph and metadata as Dictionary[String, Any]
    | ResolutionError with error as String and details as Dictionary[String, Any]
    | ResolutionWarning with warning as String and graph as DependencyGraph

Type called "DependencyConfig":
    base_reload_time as Float defaults to 0.1
    module_reload_factor as Float defaults to 0.05
    complexity_multiplier as Float defaults to 1.0
    high_dependency_threshold as Float defaults to 8.0
    max_depth_threshold as Integer defaults to 12
    critical_impact_threshold as Float defaults to 10.0
    refactoring_distance_threshold as Float defaults to 0.7
    isolated_module_ratio_threshold as Float defaults to 0.25
    scc_analysis_enabled as Boolean defaults to true
    advanced_metrics_enabled as Boolean defaults to true
    impact_analysis_low_threshold as Integer defaults to 10
    impact_analysis_medium_threshold as Integer defaults to 30
    complexity_threshold as Integer defaults to 10
    base_complexity_factor as Float defaults to 1.0
    min_complexity_factor as Float defaults to 0.1

Type called "DependencyStats":
    total_modules as Integer
    total_dependencies as Integer
    circular_dependencies as Integer
    max_depth as Integer
    avg_dependencies_per_module as Float
    isolated_modules as Integer
    strongly_connected_components as Integer
    metadata as Dictionary[String, Any]

Note: Core Dependency Tracking Functions
Process called "create_dependency_graph" returns DependencyGraph:
    Return DependencyGraph with:
        nodes as empty dictionary
        edges as empty dictionary
        reverse_edges as empty dictionary
        metadata as empty dictionary
        last_updated as Common.get_current_time
        version as 1

Process called "add_module_dependency" that takes graph as DependencyGraph and module_name as String and dependencies as List[String] returns Boolean:
    Try:
        Let node be DependencyNode with:
            module_name as module_name
            file_path as ""
            dependencies as dependencies
            dependents as empty list
            last_modified as Common.get_current_time
            checksum as ""
            compilation_state as "unknown"
            error_count as 0
            metadata as empty dictionary
        
        Set graph.nodes[module_name] to node
        Set graph.edges[module_name] to dependencies
        Set graph.reverse_edges[module_name] to empty list
        
        For each dep in dependencies:
            If graph.reverse_edges contains dep:
                Call graph.reverse_edges[dep].append with item as module_name
            Otherwise:
                Set graph.reverse_edges[dep] to list containing module_name
        
        Set graph.last_updated to Common.get_current_time
        Set graph.version to graph.version plus 1
        Return true
    Catch error as Exception:
        Return false

Process called "remove_module_dependency" that takes graph as DependencyGraph and module_name as String returns Boolean:
    Try:
        If graph.nodes contains module_name:
            Let dependencies be graph.edges[module_name]
            For each dep in dependencies:
                If graph.reverse_edges contains dep:
                    Call graph.reverse_edges[dep].remove with item as module_name
            
            Call graph.nodes.remove with key as module_name
            Call graph.edges.remove with key as module_name
            Call graph.reverse_edges.remove with key as module_name
            
            Set graph.last_updated to Common.get_current_time
            Set graph.version to graph.version plus 1
            
        Return true
    Catch error as Exception:
        Return false

Process called "update_module_dependencies" that takes graph as DependencyGraph and module_name as String and new_dependencies as List[String] returns Boolean:
    Try:
        Let old_dependencies be graph.edges[module_name] if graph.edges contains module_name otherwise empty list
        
        For each old_dep in old_dependencies:
            If graph.reverse_edges contains old_dep:
                Call graph.reverse_edges[old_dep].remove with item as module_name
        
        For each new_dep in new_dependencies:
            If graph.reverse_edges contains new_dep:
                Call graph.reverse_edges[new_dep].append with item as module_name
            Otherwise:
                Set graph.reverse_edges[new_dep] to list containing module_name
        
        Set graph.edges[module_name] to new_dependencies
        If graph.nodes contains module_name:
            Set graph.nodes[module_name].dependencies to new_dependencies
        
        Set graph.last_updated to Common.get_current_time
        Set graph.version to graph.version plus 1
        Return true
    Catch error as Exception:
        Return false

Note: Circular Dependency Detection
Process called "detect_circular_dependencies" that takes graph as DependencyGraph returns List[CircularDependency]:
    Let cycles be empty list
    Let visited be empty dictionary
    Let recursion_stack be empty dictionary
    
    For each module_name in graph.nodes:
        If not visited.get with key as module_name and default as false:
            Let cycle be detect_cycle_dfs with graph as graph and node as module_name and visited as visited and recursion_stack as recursion_stack
            If cycle is not none:
                Let circular_dep be analyze_circular_dependency with cycle as cycle
                Call cycles.append with item as circular_dep
    
    Return cycles

Process called "detect_cycle_dfs" that takes graph as DependencyGraph and node as String and visited as Dictionary[String, Boolean] and recursion_stack as Dictionary[String, Boolean] returns Optional[List[String]]:
    Set visited[node] to true
    Set recursion_stack[node] to true
    
    If graph.edges contains node:
        For each neighbor in graph.edges[node]:
            If not visited.get with key as neighbor and default as false:
                Let cycle be detect_cycle_dfs with graph as graph and node as neighbor and visited as visited and recursion_stack as recursion_stack
                If cycle is not none:
                    Call cycle.append with item as node
                    Return cycle
            Otherwise if recursion_stack.get with key as neighbor and default as false:
                Return list containing node, neighbor
    
    Set recursion_stack[node] to false
    Return none

Process called "analyze_circular_dependency" that takes cycle as List[String] returns CircularDependency:
    Let severity be "high" if cycle size is less than or equal to 2 otherwise "medium"
    Let description be "Circular dependency detected: " plus join_strings_with_arrow with modules as cycle
    
    Let suggestions be empty list
    Call suggestions.append with item as "Consider using dependency injection"
    Call suggestions.append with item as "Extract shared functionality to a separate module"
    Call suggestions.append with item as "Use interfaces to break direct dependencies"
    
    If cycle size is equal to 2:
        Call suggestions.append with item as "Consider merging the two modules"
    Otherwise if cycle size is greater than 5:
        Call suggestions.append with item as "This is a complex cycle - consider architectural refactoring"
    
    Return CircularDependency with:
        cycle as cycle
        severity as severity
        description as description
        suggestions as suggestions
        metadata as empty dictionary

Process called "join_strings_with_arrow" that takes modules as List[String] returns String:
    Let result be ""
    For each i from 0 to modules size minus 1:
        Set result to result plus modules[i]
        If i is less than modules size minus 1:
            Set result to result plus " -> "
    Set result to result plus " -> " plus modules[0]
    Return result

Note: Impact Analysis
Process called "analyze_change_impact" that takes graph as DependencyGraph and changed_module as String returns ImpactAnalysis:
    Let affected_modules be get_affected_modules with graph as graph and source as changed_module
    Let propagation_path be get_propagation_path with graph as graph and source as changed_module
    Let impact_level be calculate_impact_level with affected_count as affected_modules size
    
    Let estimated_reload_time be estimate_reload_time with affected_modules as affected_modules and graph as graph
    
    Return ImpactAnalysis with:
        changed_module as changed_module
        affected_modules as affected_modules
        impact_level as impact_level
        propagation_path as propagation_path
        estimated_reload_time as estimated_reload_time
        metadata as empty dictionary

Process called "get_affected_modules" that takes graph as DependencyGraph and source as String returns List[String]:
    Let affected be empty list
    Let visited be empty dictionary
    Let queue be list containing source
    
    While queue size is greater than 0:
        Let current be queue[0]
        Call queue.remove with index as 0
        
        If not visited.get with key as current and default as false:
            Set visited[current] to true
            Call affected.append with item as current
            
            If graph.reverse_edges contains current:
                For each dependent in graph.reverse_edges[current]:
                    Call queue.append with item as dependent
    
    Return affected

Process called "get_propagation_path" that takes graph as DependencyGraph and source as String returns List[String]:
    Let path be empty list
    Let visited be empty dictionary
    Let queue be list containing (list containing source)
    
    While queue size is greater than 0:
        Let current_path be queue[0]
        Call queue.remove with index as 0
        Let current be current_path[current_path size minus 1]
        
        If not visited.get with key as current and default as false:
            Set visited[current] to true
            Call path.append with item as current
            
            If graph.reverse_edges contains current:
                For each dependent in graph.reverse_edges[current]:
                    Let new_path be Common.copy_list with list as current_path
                    Call new_path.append with item as dependent
                    Call queue.append with item as new_path
    
    Return path

Process called "calculate_impact_level" that takes affected_count as Integer returns String:
    If affected_count is equal to 0:
        Return "none"
    Otherwise if affected_count is less than or equal to 3:
        Return "low"
    Let config be create_default_dependency_config
    Otherwise if affected_count is less than or equal to config.impact_analysis_low_threshold:
        Return "medium"
    Otherwise if affected_count is less than or equal to config.impact_analysis_medium_threshold:
        Return "high"
    Otherwise:
        Return "critical"

Process called "estimate_reload_time" that takes affected_modules as List[String] and graph as DependencyGraph returns Float:
    Let config be create_default_dependency_config
    
    Let complexity_score be calculate_graph_complexity with graph as graph and affected_modules as affected_modules
    Let base_time be config.base_reload_time
    Let module_time be affected_modules size multiplied by config.module_reload_factor
    Let complexity_adjustment be complexity_score multiplied by config.complexity_multiplier
    
    Let total_time be base_time plus module_time plus complexity_adjustment
    
    Return total_time

Note: Dependency Graph Analysis
Process called "get_dependency_stats" that takes graph as DependencyGraph returns DependencyStats:
    Let total_modules be graph.nodes size
    Let total_dependencies be 0
    Let max_depth be 0
    Let isolated_modules be 0
    
    For each module_name in graph.nodes:
        Let deps be graph.edges[module_name] if graph.edges contains module_name otherwise empty list
        Set total_dependencies to total_dependencies plus deps size
        
        If deps size is equal to 0:
            Set isolated_modules to isolated_modules plus 1
        
        Let depth be calculate_module_depth with graph as graph and module_name as module_name
        If depth is greater than max_depth:
            Set max_depth to depth
    
    Let avg_dependencies be total_dependencies divided by total_modules if total_modules is greater than 0 otherwise 0.0
    Let circular_deps_list be detect_circular_dependencies with graph as graph
    Let circular_deps be circular_deps_list size
    Let scc_count be count_strongly_connected_components with graph as graph
    
    Return DependencyStats with:
        total_modules as total_modules
        total_dependencies as total_dependencies
        circular_dependencies as circular_deps
        max_depth as max_depth
        avg_dependencies_per_module as avg_dependencies
        isolated_modules as isolated_modules
        strongly_connected_components as scc_count
        metadata as empty dictionary

Process called "calculate_module_depth" that takes graph as DependencyGraph and module_name as String returns Integer:
    Let visited be empty dictionary
    Let max_depth be 0
    
    Process called "dfs_depth" that takes node as String and depth as Integer returns None:
        If depth is greater than max_depth:
            Set max_depth to depth
        
        Set visited[node] to true
        
        If graph.edges contains node:
            For each dep in graph.edges[node]:
                If not visited.get with key as dep and default as false:
                    Call dfs_depth with node as dep and depth as depth plus 1
    
    Call dfs_depth with node as module_name and depth as 0
    Return max_depth

Process called "count_strongly_connected_components" that takes graph as DependencyGraph returns Integer:
    Let config be create_default_dependency_config
    If not config.scc_analysis_enabled:
        Return 0
    
    Return count_strongly_connected_components_tarjan with graph as graph

Process called "mark_scc_component" that takes graph as DependencyGraph and node as String and visited as Dictionary[String, Boolean] returns None:
    Set visited[node] to true
    
    If graph.edges contains node:
        For each dep in graph.edges[node]:
            If not visited.get with key as dep and default as false:
                Call mark_scc_component with graph as graph and node as dep and visited as visited

Note: Dependency Resolution and Validation
Process called "resolve_dependencies" that takes graph as DependencyGraph returns DependencyResolution:
    Try:
        Let cycles be detect_circular_dependencies with graph as graph
        If cycles size is greater than 0:
            Let details be dictionary with:
                "cycles" as cycles
                "cycle_count" as cycles size
            Return ResolutionError with error as "Circular dependencies detected" and details as details
        
        Let validation_result be validate_dependency_graph with graph as graph
        If validation_result is not none:
            Return ResolutionWarning with warning as validation_result and graph as graph
        
        Return ResolutionSuccess with graph as graph and metadata as empty dictionary
    Catch error as Exception:
        Return ResolutionError with error as error as string and details as empty dictionary

Process called "validate_dependency_graph" that takes graph as DependencyGraph returns Optional[String]:
    For each module_name in graph.nodes:
        If graph.edges contains module_name:
            For each dep in graph.edges[module_name]:
                If not graph.nodes contains dep:
                    Return "Module " plus module_name plus " depends on non-existent module " plus dep
    
    Return none

Note: Utility Functions
Note: Utility function moved to ../utilities/common.runa:
        Call copy.append with item as item
    Return copy

Note: Utility function moved to ../utilities/common.runaProcess called "find_root_modules" that takes graph as DependencyGraph returns List[String]:
    Let roots be empty list
    For each module_name in graph.nodes:
        If not graph.reverse_edges contains module_name or graph.reverse_edges[module_name] size is equal to 0:
            Call roots.append with item as module_name
    Return roots

Process called "find_leaf_modules" that takes graph as DependencyGraph returns List[String]:
    Let leaves be empty list
    For each module_name in graph.nodes:
        If not graph.edges contains module_name or graph.edges[module_name] size is equal to 0:
            Call leaves.append with item as module_name
    Return leaves

Process called "get_module_dependents" that takes graph as DependencyGraph and module_name as String returns List[String]:
    Return graph.reverse_edges[module_name] if graph.reverse_edges contains module_name otherwise empty list

Process called "get_module_dependencies" that takes graph as DependencyGraph and module_name as String returns List[String]:
    Return graph.edges[module_name] if graph.edges contains module_name otherwise empty list

Process called "is_module_isolated" that takes graph as DependencyGraph and module_name as String returns Boolean:
    Let deps be get_module_dependencies with graph as graph and module_name as module_name
    Let dependents be get_module_dependents with graph as graph and module_name as module_name
    Return deps size is equal to 0 and dependents size is equal to 0

Process called "get_dependency_path" that takes graph as DependencyGraph and source as String and target as String returns Optional[List[String]]:
    Let visited be empty dictionary
    Let queue be list containing (list containing source)
    
    While queue size is greater than 0:
        Let current_path be queue[0]
        Call queue.remove with index as 0
        Let current be current_path[current_path size minus 1]
        
        If current is equal to target:
            Return current_path
        
        If not visited.get with key as current and default as false:
            Set visited[current] to true
            
            If graph.edges contains current:
                For each dep in graph.edges[current]:
                    Let new_path be Common.copy_list with list as current_path
                    Call new_path.append with item as dep
                    Call queue.append with item as new_path
    
    Return none

Note: Performance Optimization
Process called "optimize_dependency_graph" that takes graph as DependencyGraph returns DependencyGraph:
    Let optimized be create_dependency_graph
    Let processed be empty dictionary
    
    For each module_name in graph.nodes:
        If not processed.get with key as module_name and default as false:
            Let optimized_deps be optimize_module_dependencies with graph as graph and module_name as module_name
            Call add_module_dependency with graph as optimized and module_name as module_name and dependencies as optimized_deps
            Set processed[module_name] to true
    
    Return optimized

Process called "optimize_module_dependencies" that takes graph as DependencyGraph and module_name as String returns List[String]:
    Let direct_deps be get_module_dependencies with graph as graph and module_name as module_name
    Let optimized_deps be empty list
    
    For each dep in direct_deps:
        If not is_transitive_dependency with graph as graph and source as module_name and target as dep:
            Call optimized_deps.append with item as dep
    
    Return optimized_deps

Process called "is_transitive_dependency" that takes graph as DependencyGraph and source as String and target as String returns Boolean:
    Let path be get_dependency_path with graph as graph and source as source and target as target
    Return path is not none and path size is greater than 2

Note: Advanced Analysis Functions
Process called "get_critical_path" that takes graph as DependencyGraph returns List[String]:
    Let stats be get_dependency_stats with graph as graph
    If stats.max_depth is equal to 0:
        Return empty list
    
    Let critical_path be empty list
    For each module_name in graph.nodes:
        Let depth be calculate_module_depth with graph as graph and module_name as module_name
        If depth is equal to stats.max_depth:
            Call critical_path.append with item as module_name
            Break
    
    Return critical_path

Process called "suggest_dependency_improvements" that takes graph as DependencyGraph returns List[String]:
    Let suggestions be empty list
    Let stats be get_dependency_stats with graph as graph
    
    If stats.circular_dependencies is greater than 0:
        Call suggestions.append with item as "Resolve " plus stats.circular_dependencies as string plus " circular dependencies to improve modularity"
    
    If stats.isolated_modules is greater than 0:
        Call suggestions.append with item as "Consider integrating " plus stats.isolated_modules as string plus " isolated modules"
    
    Let config be create_default_dependency_config
    If stats.avg_dependencies_per_module is greater than config.high_dependency_threshold:
        Call suggestions.append with item as "Average dependencies per module is high (" plus stats.avg_dependencies_per_module as string plus ") - consider breaking down large modules"
    
    If stats.max_depth is greater than config.max_depth_threshold:
        Call suggestions.append with item as "Dependency chain depth is high (" plus stats.max_depth as string plus ") - consider flattening the architecture"
    
    Return suggestions

Process called "export_dependency_graph" that takes graph as DependencyGraph and format as String returns String:
    Match format:
        When "dot":
            Return export_to_dot_format with graph as graph
        When "json":
            Return export_to_json_format with graph as graph
        When "csv":
            Return export_to_csv_format with graph as graph
        Otherwise:
            Return export_to_json_format with graph as graph

Process called "export_to_dot_format" that takes graph as DependencyGraph returns String:
    Let dot_content be "digraph Dependencies {\n"
    
    For each module_name in graph.nodes:
        Set dot_content to dot_content plus "  \"" plus module_name plus "\";\n"
    
    For each module_name in graph.edges:
        For each dep in graph.edges[module_name]:
            Set dot_content to dot_content plus "  \"" plus module_name plus "\" -> \"" plus dep plus "\";\n"
    
    Set dot_content to dot_content plus "}\n"
    Return dot_content

Process called "export_to_json_format" that takes graph as DependencyGraph returns String:
    Import "json"
    Let graph_data be dictionary with:
        "nodes" as list containing
        "edges" as empty list
    
    For each module_name in graph.nodes:
        Call graph_data["nodes"].append with item as module_name
    
    For each module_name in graph.edges:
        For each dep in graph.edges[module_name]:
            Call graph_data["edges"].append with item as dictionary with:
                "source" as module_name
                "target" as dep
    
    Return json.dumps with obj as graph_data and indent as 2

Process called "export_to_csv_format" that takes graph as DependencyGraph returns String:
    Let csv_content be "Source,Target\n"
    
    For each module_name in graph.edges:
        For each dep in graph.edges[module_name]:
            Set csv_content to csv_content plus module_name plus "," plus dep plus "\n"
    
    Return csv_content

Note: Advanced Dependency Analysis Functions
Process called "detect_dependency_cycles_advanced" that takes graph as DependencyGraph returns Dictionary[String, Any]:
    Let cycles_found be empty list
    Let cycle_statistics be empty dictionary
    Let visited be empty dictionary
    Let recursion_stack be empty dictionary
    
    For each module_name in graph.nodes:
        If not visited.get with key as module_name and default as false:
            Let cycle_path be empty list
            Let cycle_detected be detect_cycle_tarjan with:
                graph as graph
                node as module_name
                visited as visited
                recursion_stack as recursion_stack
                cycle_path as cycle_path
            
            If cycle_detected:
                Call cycles_found.append with item as cycle_path
    
    Set cycle_statistics["total_cycles"] to cycles_found size
    Set cycle_statistics["max_cycle_length"] to get_max_cycle_length with cycles as cycles_found
    Set cycle_statistics["cycle_complexity"] to calculate_cycle_complexity with cycles as cycles_found
    
    Return dictionary with:
        "cycles" as cycles_found
        "statistics" as cycle_statistics
        "has_cycles" as cycles_found size is greater than 0

Process called "detect_cycle_tarjan" that takes graph as DependencyGraph and node as String and visited as Dictionary[String, Boolean] and recursion_stack as Dictionary[String, Boolean] and cycle_path as List[String] returns Boolean:
    Set visited[node] to true
    Set recursion_stack[node] to true
    Call cycle_path.append with item as node
    
    If graph.edges contains node:
        For each neighbor in graph.edges[node]:
            If not visited.get with key as neighbor and default as false:
                Let cycle_found be detect_cycle_tarjan with:
                    graph as graph
                    node as neighbor
                    visited as visited
                    recursion_stack as recursion_stack
                    cycle_path as cycle_path
                If cycle_found:
                    Return true
            Otherwise if recursion_stack.get with key as neighbor and default as false:
                Call cycle_path.append with item as neighbor
                Return true
    
    Set recursion_stack[node] to false
    Call cycle_path.remove with item as node
    Return false

Process called "get_max_cycle_length" that takes cycles as List[List[String]] returns Integer:
    Let max_length be 0
    For each cycle in cycles:
        If cycle size is greater than max_length:
            Set max_length to cycle size
    Return max_length

Process called "calculate_cycle_complexity" that takes cycles as List[List[String]] returns Float:
    If cycles size is equal to 0:
        Return 0.0
    
    Let total_complexity be 0.0
    For each cycle in cycles:
        Let cycle_complexity be cycle size multiplied by cycle size
        Set total_complexity to total_complexity plus cycle_complexity
    
    Return total_complexity divided by cycles size

Process called "get_module_impact_score" that takes graph as DependencyGraph and module_name as String returns Float:
    Let direct_dependents be get_module_dependents with graph as graph and module_name as module_name
    Let transitive_dependents be get_transitive_dependents with graph as graph and module_name as module_name
    Let dependency_depth be calculate_module_depth with graph as graph and module_name as module_name
    
    Let impact_score be direct_dependents size multiplied by 2.0
    Set impact_score to impact_score plus transitive_dependents size
    Set impact_score to impact_score plus dependency_depth multiplied by 0.5
    
    Return impact_score

Process called "get_transitive_dependents" that takes graph as DependencyGraph and module_name as String returns List[String]:
    Let all_dependents be empty list
    Let visited be empty dictionary
    Let queue be list containing module_name
    
    While queue size is greater than 0:
        Let current be queue[0]
        Call queue.remove with index as 0
        
        If not visited.get with key as current and default as false:
            Set visited[current] to true
            
            If graph.reverse_edges contains current:
                For each dependent in graph.reverse_edges[current]:
                    If not all_dependents contains dependent:
                        Call all_dependents.append with item as dependent
                    Call queue.append with item as dependent
    
    Return all_dependents

Process called "analyze_module_stability" that takes graph as DependencyGraph and module_name as String returns Dictionary[String, Any]:
    Let dependencies be get_module_dependencies with graph as graph and module_name as module_name
    Let dependents be get_module_dependents with graph as graph and module_name as module_name
    Let instability be calculate_instability with dependencies as dependencies and dependents as dependents
    Let abstractness be calculate_abstractness with module_name as module_name and graph as graph
    Let distance_from_main_sequence be calculate_distance_from_main_sequence with instability as instability and abstractness as abstractness
    
    Return dictionary with:
        "instability" as instability
        "abstractness" as abstractness
        "distance" as distance_from_main_sequence
        "stability_score" as 1.0 minus instability

Process called "calculate_instability" that takes dependencies as List[String] and dependents as List[String] returns Float:
    Let fan_out be dependencies size
    Let fan_in be dependents size
    Let total_coupling be fan_out plus fan_in
    
    If total_coupling is equal to 0:
        Return 0.0
    
    Return fan_out divided by total_coupling

Process called "calculate_abstractness" that takes module_name as String and graph as DependencyGraph returns Float:
    Try:
        Let module_info be analyze_module_structure with module_name as module_name
        Let abstract_elements be module_info.interfaces plus module_info.abstract_classes plus module_info.traits
        Let concrete_elements be module_info.concrete_classes plus module_info.functions plus module_info.implementations
        Let total_elements be abstract_elements plus concrete_elements
        
        If total_elements is equal to 0:
            Return 0.5
        
        Let abstractness_ratio be abstract_elements divided by total_elements
        Return bound_float with value as abstractness_ratio and min_val as 0.0 and max_val as 1.0
    Catch error:
        Return calculate_abstractness_fallback with module_name as module_name

Process called "calculate_distance_from_main_sequence" that takes instability as Float and abstractness as Float returns Float:
    Let distance be absolute_value with value as abstractness plus instability minus 1.0
    Return distance

Process called "absolute_value" that takes value as Float returns Float:
    If value is less than 0.0:
        Return 0.0 minus value
    Return value

Process called "generate_dependency_insights" that takes graph as DependencyGraph returns Dictionary[String, Any]:
    Let insights be empty dictionary
    Let stats be get_dependency_stats with graph as graph
    
    Set insights["total_modules"] to stats.total_modules
    Set insights["complexity_level"] to determine_complexity_level with stats as stats
    Set insights["recommendations"] to generate_complexity_recommendations with stats as stats
    Set insights["critical_modules"] to find_critical_modules with graph as graph
    Set insights["refactoring_candidates"] to find_refactoring_candidates with graph as graph
    
    Return insights

Process called "determine_complexity_level" that takes stats as DependencyStats returns String:
    Let config be create_default_dependency_config
    If stats.total_modules is less than config.complexity_threshold:
        Return "simple"
    Otherwise if stats.total_modules is less than 50:
        Return "moderate"
    Otherwise if stats.total_modules is less than 200:
        Return "complex"
    Otherwise:
        Return "very_complex"

Process called "generate_complexity_recommendations" that takes stats as DependencyStats returns List[String]:
    Let recommendations be empty list
    
    If stats.circular_dependencies is greater than 0:
        Call recommendations.append with item as "Break circular dependencies to improve maintainability"
    
    Let config be create_default_dependency_config
    If stats.avg_dependencies_per_module is greater than config.high_dependency_threshold:
        Call recommendations.append with item as "Consider reducing module coupling - average dependencies per module is high"
    
    If stats.max_depth is greater than config.max_depth_threshold:
        Call recommendations.append with item as "Flatten dependency hierarchy - current depth is " plus stats.max_depth as string
    
    If stats.isolated_modules is greater than stats.total_modules divided by 4:
        Call recommendations.append with item as "Consider integrating isolated modules or removing unused code"
    
    Return recommendations

Process called "find_critical_modules" that takes graph as DependencyGraph returns List[String]:
    Let critical_modules be empty list
    
    For each module_name in graph.nodes:
        Let impact_score be get_module_impact_score with graph as graph and module_name as module_name
        Let config be create_default_dependency_config
        If impact_score is greater than config.critical_impact_threshold:
            Call critical_modules.append with item as module_name
    
    Return critical_modules

Process called "find_refactoring_candidates" that takes graph as DependencyGraph returns List[String]:
    Let candidates be empty list
    
    For each module_name in graph.nodes:
        Let stability_analysis be analyze_module_stability with graph as graph and module_name as module_name
        Let config be create_default_dependency_config
        If stability_analysis["distance"] is greater than config.refactoring_distance_threshold:
            Call candidates.append with item as module_name
    
    Return candidates

Note: Performance Optimizations
Process called "optimize_dependency_resolution" that takes graph as DependencyGraph returns DependencyGraph:
    Let optimized_graph be create_dependency_graph
    Let processed_modules be empty dictionary
    
    Let sorted_modules be topological_sort with graph as graph
    
    For each module_name in sorted_modules:
        If not processed_modules.get with key as module_name and default as false:
            Let optimized_deps be remove_redundant_dependencies with graph as graph and module_name as module_name
            Call add_module_dependency with graph as optimized_graph and module_name as module_name and dependencies as optimized_deps
            Set processed_modules[module_name] to true
    
    Return optimized_graph

Process called "topological_sort" that takes graph as DependencyGraph returns List[String]:
    Let sorted_modules be empty list
    Let visited be empty dictionary
    
    Process called "dfs_sort" that takes node as String returns None:
        Set visited[node] to true
        
        If graph.edges contains node:
            For each dep in graph.edges[node]:
                If not visited.get with key as dep and default as false:
                    Call dfs_sort with node as dep
        
        Call sorted_modules.append with item as node
    
    For each module_name in graph.nodes:
        If not visited.get with key as module_name and default as false:
            Call dfs_sort with node as module_name
    
    Return reverse_list with list as sorted_modules

Process called "remove_redundant_dependencies" that takes graph as DependencyGraph and module_name as String returns List[String]:
    Let direct_deps be get_module_dependencies with graph as graph and module_name as module_name
    Let necessary_deps be empty list
    
    For each dep in direct_deps:
        Let is_redundant be false
        For each other_dep in direct_deps:
            If dep is not equal to other_dep:
                Let path_exists be has_dependency_path with graph as graph and source as module_name and through as other_dep and target as dep
                If path_exists:
                    Set is_redundant to true
                    Break
        
        If not is_redundant:
            Call necessary_deps.append with item as dep
    
    Return necessary_deps

Process called "has_dependency_path" that takes graph as DependencyGraph and source as String and through as String and target as String returns Boolean:
    Let visited be empty dictionary
    Let queue be list containing through
    
    While queue size is greater than 0:
        Let current be queue[0]
        Call queue.remove with index as 0
        
        If current is equal to target:
            Return true
        
        If not visited.get with key as current and default as false:
            Set visited[current] to true
            
            If graph.edges contains current:
                For each neighbor in graph.edges[current]:
                    Call queue.append with item as neighbor
    
    Return false

Process called "reverse_list" that takes list as List[Any] returns List[Any]:
    Let reversed_list be empty list
    For each i from list size minus 1 down to 0:
        Call reversed_list.append with item as list[i]
    Return reversed_list

Note: Configuration and Helper Functions
Process called "create_default_dependency_config" returns DependencyConfig:
    Return DependencyConfig with:
        base_reload_time as 0.1
        module_reload_factor as 0.05
        complexity_multiplier as 1.0
        high_dependency_threshold as 8.0
        max_depth_threshold as 12
        critical_impact_threshold as 10.0
        refactoring_distance_threshold as 0.7
        isolated_module_ratio_threshold as 0.25
        scc_analysis_enabled as true
        advanced_metrics_enabled as true
        impact_analysis_low_threshold as 10
        impact_analysis_medium_threshold as 30
        complexity_threshold as 10
        base_complexity_factor as 1.0
        min_complexity_factor as 0.1

Process called "create_dependency_config" that takes base_reload_time as Float and module_reload_factor as Float and complexity_multiplier as Float and high_dependency_threshold as Float and max_depth_threshold as Integer and critical_impact_threshold as Float and refactoring_distance_threshold as Float and isolated_module_ratio_threshold as Float returns DependencyConfig:
    Let config be validate_config_parameters with:
        base_reload_time as base_reload_time
        module_reload_factor as module_reload_factor
        complexity_multiplier as complexity_multiplier
        high_dependency_threshold as high_dependency_threshold
        max_depth_threshold as max_depth_threshold
        critical_impact_threshold as critical_impact_threshold
        refactoring_distance_threshold as refactoring_distance_threshold
        isolated_module_ratio_threshold as isolated_module_ratio_threshold
    
    Return config

Process called "validate_config_parameters" that takes base_reload_time as Float and module_reload_factor as Float and complexity_multiplier as Float and high_dependency_threshold as Float and max_depth_threshold as Integer and critical_impact_threshold as Float and refactoring_distance_threshold as Float and isolated_module_ratio_threshold as Float returns DependencyConfig:
    Let validated_base_reload_time be bound_float with value as base_reload_time and min_val as 0.01 and max_val as 10.0
    Let validated_module_reload_factor be bound_float with value as module_reload_factor and min_val as 0.001 and max_val as 1.0
    Let validated_complexity_multiplier be bound_float with value as complexity_multiplier and min_val as 0.1 and max_val as 10.0
    Let validated_high_dependency_threshold be bound_float with value as high_dependency_threshold and min_val as 1.0 and max_val as 100.0
    Let validated_max_depth_threshold be bound_integer with value as max_depth_threshold and min_val as 1 and max_val as 1000
    Let validated_critical_impact_threshold be bound_float with value as critical_impact_threshold and min_val as 1.0 and max_val as 1000.0
    Let validated_refactoring_distance_threshold be bound_float with value as refactoring_distance_threshold and min_val as 0.1 and max_val as 1.0
    Let validated_isolated_module_ratio_threshold be bound_float with value as isolated_module_ratio_threshold and min_val as 0.0 and max_val as 1.0
    
    Return DependencyConfig with:
        base_reload_time as validated_base_reload_time
        module_reload_factor as validated_module_reload_factor
        complexity_multiplier as validated_complexity_multiplier
        high_dependency_threshold as validated_high_dependency_threshold
        max_depth_threshold as validated_max_depth_threshold
        critical_impact_threshold as validated_critical_impact_threshold
        refactoring_distance_threshold as validated_refactoring_distance_threshold
        isolated_module_ratio_threshold as validated_isolated_module_ratio_threshold
        scc_analysis_enabled as true
        advanced_metrics_enabled as true
        impact_analysis_low_threshold as 10
        impact_analysis_medium_threshold as 30
        complexity_threshold as 10
        base_complexity_factor as 1.0
        min_complexity_factor as 0.1

Note: Real Tarjan's Strongly Connected Components Algorithm
Type called "TarjanState":
    index as Integer
    lowlink as Integer
    on_stack as Boolean

Process called "count_strongly_connected_components_tarjan" that takes graph as DependencyGraph returns Integer:
    Let index_counter be 0
    Let stack be empty list
    Let node_states be empty dictionary
    Let scc_count be 0
    
    For each node in graph.nodes:
        If not node_states contains node:
            Call tarjan_strongconnect with:
                graph as graph
                node as node
                index_counter as index_counter
                stack as stack
                node_states as node_states
                scc_count as scc_count
    
    Return scc_count

Process called "tarjan_strongconnect" that takes graph as DependencyGraph and node as String and index_counter as Integer and stack as List[String] and node_states as Dictionary[String, TarjanState] and scc_count as Integer returns None:
    Set node_states[node] to TarjanState with:
        index as index_counter
        lowlink as index_counter
        on_stack as true
    
    Set index_counter to index_counter plus 1
    Call stack.append with item as node
    
    If graph.edges contains node:
        For each successor in graph.edges[node]:
            If not node_states contains successor:
                Call tarjan_strongconnect with:
                    graph as graph
                    node as successor
                    index_counter as index_counter
                    stack as stack
                    node_states as node_states
                    scc_count as scc_count
                
                Set node_states[node].lowlink to minimum_integer with:
                    a as node_states[node].lowlink
                    b as node_states[successor].lowlink
            Otherwise if node_states[successor].on_stack:
                Set node_states[node].lowlink to minimum_integer with:
                    a as node_states[node].lowlink
                    b as node_states[successor].index
    
    If node_states[node].lowlink is equal to node_states[node].index:
        Set scc_count to scc_count plus 1
        Let current_node be ""
        While current_node is not equal to node:
            Set current_node to stack[stack size minus 1]
            Call stack.remove with index as stack size minus 1
            Set node_states[current_node].on_stack to false

Note: Real Module Structure Analysis
Type called "ModuleStructureInfo":
    interfaces as Integer
    abstract_classes as Integer
    traits as Integer
    concrete_classes as Integer
    functions as Integer
    implementations as Integer
    total_lines as Integer
    complexity_score as Float

Process called "analyze_module_structure" that takes module_name as String returns ModuleStructureInfo:
    Try:
        Let file_content be read_module_file with module_name as module_name
        If file_content is none:
            Return create_default_module_info
        
        Note: Comprehensive pattern matching for multiple programming languages
        Let interfaces be count_pattern_in_content with content as file_content and pattern as "Type .* is.*Interface"
        Set interfaces to interfaces plus count_pattern_in_content with content as file_content and pattern as "interface"
        Set interfaces to interfaces plus count_pattern_in_content with content as file_content and pattern as "trait"
        
        Let abstract_classes be count_pattern_in_content with content as file_content and pattern as "Type .* is.*Abstract"
        Set abstract_classes to abstract_classes plus count_pattern_in_content with content as file_content and pattern as "abstract class"
        Set abstract_classes to abstract_classes plus count_pattern_in_content with content as file_content and pattern as "struct"
        
        Let traits be count_pattern_in_content with content as file_content and pattern as "Trait called"
        Set traits to traits plus count_pattern_in_content with content as file_content and pattern as "enum"
        
        Let concrete_classes be count_pattern_in_content with content as file_content and pattern as "Type called"
        Set concrete_classes to concrete_classes plus count_pattern_in_content with content as file_content and pattern as "class"
        
        Let functions be count_pattern_in_content with content as file_content and pattern as "Process called"
        Set functions to functions plus count_pattern_in_content with content as file_content and pattern as "function"
        Set functions to functions plus count_pattern_in_content with content as file_content and pattern as "def"
        Set functions to functions plus count_pattern_in_content with content as file_content and pattern as "fn"
        Set functions to functions plus count_pattern_in_content with content as file_content and pattern as "func"
        Set functions to functions plus count_pattern_in_content with content as file_content and pattern as "method"
        Set functions to functions plus count_pattern_in_content with content as file_content and pattern as "proc"
        
        Let implementations be count_pattern_in_content with content as file_content and pattern as "Implementation of"
        Set implementations to implementations plus count_pattern_in_content with content as file_content and pattern as "import"
        Set implementations to implementations plus count_pattern_in_content with content as file_content and pattern as "use"
        Set implementations to implementations plus count_pattern_in_content with content as file_content and pattern as "require"
        Set implementations to implementations plus count_pattern_in_content with content as file_content and pattern as "include"
        Set implementations to implementations plus count_pattern_in_content with content as file_content and pattern as "from"
        
        Note: Control flow patterns for complexity analysis
        Let control_flow_patterns be count_pattern_in_content with content as file_content and pattern as "if"
        Set control_flow_patterns to control_flow_patterns plus count_pattern_in_content with content as file_content and pattern as "for"
        Set control_flow_patterns to control_flow_patterns plus count_pattern_in_content with content as file_content and pattern as "while"
        Set control_flow_patterns to control_flow_patterns plus count_pattern_in_content with content as file_content and pattern as "match"
        Set control_flow_patterns to control_flow_patterns plus count_pattern_in_content with content as file_content and pattern as "switch"
        Set control_flow_patterns to control_flow_patterns plus count_pattern_in_content with content as file_content and pattern as "try"
        Set control_flow_patterns to control_flow_patterns plus count_pattern_in_content with content as file_content and pattern as "catch"
        
        Note: Variable declaration patterns
        Let variable_declarations be count_pattern_in_content with content as file_content and pattern as "let"
        Set variable_declarations to variable_declarations plus count_pattern_in_content with content as file_content and pattern as "var"
        Set variable_declarations to variable_declarations plus count_pattern_in_content with content as file_content and pattern as "const"
        Set variable_declarations to variable_declarations plus count_pattern_in_content with content as file_content and pattern as "final"
        
        Let lines be split_content_into_lines with content as file_content
        Let total_lines be lines size
        Let complexity_score be calculate_code_complexity with content as file_content
        
        Return ModuleStructureInfo with:
            interfaces as interfaces
            abstract_classes as abstract_classes
            traits as traits
            concrete_classes as concrete_classes
            functions as functions
            implementations as implementations
            total_lines as total_lines
            complexity_score as complexity_score
    Catch error:
        Return create_default_module_info

Process called "read_module_file" that takes module_name as String returns Optional[String]:
    Try:
        Import "os"
        Let potential_paths be list containing:
            module_name plus ".runa"
            "src/" plus module_name plus ".runa"
            "stdlib/" plus module_name plus ".runa"
            module_name plus "/mod.runa"
        
        For each path in potential_paths:
            If file_exists with path as path:
                Return read_file_content with path as path
        
        Return none
    Catch error:
        Return none

Process called "file_exists" that takes path as String returns Boolean:
    Try:
        Import "os"
        Return os.path.exists with path as path
    Catch error:
        Return false

Process called "read_file_content" that takes path as String returns String:
    Try:
        Let file_handle be open_file with path as path and mode as "r"
        Let content be file_handle.read
        Call file_handle.close
        Return content
    Catch error:
        Return ""

Process called "open_file" that takes path as String and mode as String returns FileHandle:
    Import "os"
    Return os.open with path as path and mode as mode

Process called "count_pattern_in_content" that takes content as String and pattern as String returns Integer:
    Try:
        Let lines be split_content_into_lines with content as content
        Let count be 0
        For each line in lines:
            If line_matches_pattern with line as line and pattern as pattern:
                Set count to count plus 1
        Return count
    Catch error:
        Return 0

Process called "line_matches_pattern" that takes line as String and pattern as String returns Boolean:
    Try:
        Let trimmed_line be trim_string with text as line
        Return trimmed_line contains pattern
    Catch error:
        Return false

Process called "split_content_into_lines" that takes content as String returns List[String]:
    Try:
        Return content.split with separator as "\n"
    Catch error:
        Return empty list

Process called "trim_string" that takes text as String returns String:
    Try:
        Return text.strip
    Catch error:
        Return text

Process called "calculate_code_complexity" that takes content as String returns Float:
    Try:
        Let config be create_default_dependency_config
        Let lines be split_content_into_lines with content as content
        Let complexity be 0.0
        
        For each line in lines:
            Let trimmed_line be trim_string with text as line
            Note: Enhanced complexity calculation with configurable factors
            If trimmed_line contains "If" or trimmed_line contains "While" or trimmed_line contains "For":
                Set complexity to complexity plus config.base_complexity_factor
            Otherwise if trimmed_line contains "if" or trimmed_line contains "while" or trimmed_line contains "for":
                Set complexity to complexity plus config.base_complexity_factor
            Otherwise if trimmed_line contains "Match" or trimmed_line contains "Try":
                Set complexity to complexity plus (config.base_complexity_factor multiplied by 2.0)
            Otherwise if trimmed_line contains "match" or trimmed_line contains "try" or trimmed_line contains "switch":
                Set complexity to complexity plus (config.base_complexity_factor multiplied by 2.0)
            Otherwise if trimmed_line contains "Process called" or trimmed_line contains "function" or trimmed_line contains "def" or trimmed_line contains "fn":
                Set complexity to complexity plus (config.base_complexity_factor multiplied by 0.5)
            Otherwise if trimmed_line contains "class" or trimmed_line contains "struct" or trimmed_line contains "interface":
                Set complexity to complexity plus (config.base_complexity_factor multiplied by 1.5)
            Otherwise if trimmed_line contains "import" or trimmed_line contains "use" or trimmed_line contains "require":
                Set complexity to complexity plus (config.base_complexity_factor multiplied by 0.2)
        
        Let base_complexity be lines size multiplied by config.min_complexity_factor
        Return complexity plus base_complexity
    Catch error:
        Let default_config be create_default_dependency_config
        Return default_config.base_complexity_factor

Process called "create_default_module_info" returns ModuleStructureInfo:
    Return ModuleStructureInfo with:
        interfaces as 0
        abstract_classes as 0
        traits as 0
        concrete_classes as 1
        functions as 1
        implementations as 0
        total_lines as 10
        complexity_score as 1.0

Process called "calculate_abstractness_fallback" that takes module_name as String returns Float:
    If module_name contains "interface" or module_name contains "abstract":
        Return 0.8
    Otherwise if module_name contains "impl" or module_name contains "concrete":
        Return 0.2
    Otherwise if module_name contains "test" or module_name contains "spec":
        Return 0.1
    Otherwise if module_name contains "util" or module_name contains "helper":
        Return 0.3
    Return 0.5

Process called "calculate_graph_complexity" that takes graph as DependencyGraph and affected_modules as List[String] returns Float:
    Let base_complexity be 0.0
    Let stats be get_dependency_stats with graph as graph
    
    Let config be create_default_dependency_config
    Set base_complexity to affected_modules size multiplied by config.min_complexity_factor
    Set base_complexity to base_complexity plus (stats.circular_dependencies multiplied by 2.0)
    Set base_complexity to base_complexity plus (stats.max_depth multiplied by 0.5)
    
    Let avg_impact be 0.0
    For each module_name in affected_modules:
        Let impact_score be get_module_impact_score with graph as graph and module_name as module_name
        Set avg_impact to avg_impact plus impact_score
    
    If affected_modules size is greater than 0:
        Set avg_impact to avg_impact divided by affected_modules size
        Set base_complexity to base_complexity plus (avg_impact multiplied by 0.2)
    
    Return base_complexity

Note: Utility Functions for Bounds Checking
Process called "bound_float" that takes value as Float and min_val as Float and max_val as Float returns Float:
    If value is less than min_val:
        Return min_val
    Otherwise if value is greater than max_val:
        Return max_val
    Return value

Process called "bound_integer" that takes value as Integer and min_val as Integer and max_val as Integer returns Integer:
    If value is less than min_val:
        Return min_val
    Otherwise if value is greater than max_val:
        Return max_val
    Return value

Process called "minimum_integer" that takes a as Integer and b as Integer returns Integer:
    If a is less than b:
        Return a
    Return b

Process called "maximum_integer" that takes a as Integer and b as Integer returns Integer:
    If a is greater than b:
        Return a
    Return b

Process called "minimum_float" that takes a as Float and b as Float returns Float:
    If a is less than b:
        Return a
    Return b

Process called "maximum_float" that takes a as Float and b as Float returns Float:
    If a is greater than b:
        Return a
    Return b