Note:
Runa Advanced Standard Library: Hot Reload File Watching Module

Provides comprehensive cross-platform file system monitoring for hot reloading systems, including:
- Real-time file change detection with multiple monitoring strategies
- Cross-platform compatibility (Windows, macOS, Linux)
- Event-based and polling-based file watching
- Configurable file filtering and pattern matching
- Performance optimization for large file sets
- File system event buffering and debouncing
- Directory tree monitoring with recursive watching
- File change event classification and prioritization
- Integration with hot reload core system

Features:
- Event-based file watching using native OS APIs (inotify, FSEvents, ReadDirectoryChangesW)
- Fallback polling-based monitoring for unsupported platforms
- Configurable event buffering and debouncing to prevent excessive reloads
- Advanced file filtering with glob patterns and regex support
- Directory tree monitoring with configurable depth limits
- File change event classification (create, modify, delete, move)
- Performance monitoring and optimization for large file sets
- Cross-platform abstraction layer for consistent behavior
- AI/agent-friendly file monitoring and event reporting
:End Note

Import "os"
Import "pathlib"
Import "fnmatch"
Import "hashlib"
Import "time"
Import "concurrent"
Import "threading"
Import "../utilities/common" as Common

Note: Core Types and Data Structures
Type called "FileWatcherConfig":
    watch_paths as List[String] defaults to list containing "."
    recursive as Boolean defaults to true
    max_depth as Integer defaults to 10
    poll_interval as Float defaults to 1.0
    buffer_size as Integer defaults to 1024
    debounce_delay as Float defaults to 0.1
    ignore_patterns as List[String] defaults to list containing "*.tmp", "*.log", ".git/*"
    include_patterns as List[String] defaults to list containing "*.runa"
    event_types as List[String] defaults to list containing "create", "modify", "delete"
    platform_specific as Dictionary[String, Any] defaults to empty dictionary
    metadata as Dictionary[String, Any] defaults to empty dictionary

Type called "FileWatchEvent":
    file_path as String
    event_type as String
    timestamp as Float
    file_size as Integer
    checksum as String
    is_directory as Boolean
    metadata as Dictionary[String, Any]

Type called "FileWatcherState":
    config as FileWatcherConfig
    is_running as Boolean
    watch_handles as Dictionary[String, WatchHandle]
    event_queue as List[FileWatchEvent]
    callbacks as List[Any]
    platform_specific as Dictionary[String, Any]
    performance_metrics as Dictionary[String, Float]
    metadata as Dictionary[String, Any]

Type called "WatchHandle":
    path as String
    handle as Any
    recursive as Boolean
    depth as Integer
    is_active as Boolean
    metadata as Dictionary[String, Any]

Type called "FileChangeBuffer":
    events as List[FileWatchEvent]
    last_flush as Float
    buffer_size as Integer
    debounce_delay as Float
    metadata as Dictionary[String, Any]

Type called "PlatformWatcher":
    platform as String
    native_handles as Dictionary[String, Any]
    event_handlers as Dictionary[String, Any]
    is_supported as Boolean
    metadata as Dictionary[String, Any]

Type called "FileInfo":
    path as String
    size as Integer
    modified_time as Float
    checksum as String
    is_directory as Boolean
    exists as Boolean

Note: Core File Watching Functions
Process called "create_file_watcher" that takes config as Optional[FileWatcherConfig] returns FileWatcherState:
    Let default_config be FileWatcherConfig with:
        watch_paths as list containing "."
        recursive as true
        max_depth as 10
        poll_interval as 1.0
        buffer_size as 1024
        debounce_delay as 0.1
        ignore_patterns as list containing "*.tmp", "*.log", ".git/*"
        include_patterns as list containing "*.runa"
        event_types as list containing "create", "modify", "delete"
        platform_specific as empty dictionary
        metadata as empty dictionary
    
    Let final_config be config if config is not none otherwise default_config
    
    Return FileWatcherState with:
        config as final_config
        is_running as false
        watch_handles as empty dictionary
        event_queue as empty list
        callbacks as empty list
        platform_specific as empty dictionary
        performance_metrics as empty dictionary
        metadata as empty dictionary

Process called "start_file_watcher" that takes watcher as FileWatcherState returns Boolean:
    If watcher.is_running:
        Return true
    
    Try:
        Let platform_watcher be create_platform_watcher with config as watcher.config
        
        For each path in watcher.config.watch_paths:
            Let handle be create_watch_handle with path as path and config as watcher.config and platform_watcher as platform_watcher
            If handle is not none:
                Set watcher.watch_handles[path] to handle
        
        Set watcher.is_running to true
        Set watcher.platform_specific to platform_watcher.metadata
        
        Let started be start_platform_watcher with platform_watcher as platform_watcher and watcher as watcher
        Return started
    Catch error as Exception:
        Return false

Process called "stop_file_watcher" that takes watcher as FileWatcherState returns Boolean:
    If not watcher.is_running:
        Return true
    
    Try:
        For each path in watcher.watch_handles:
            Let handle be watcher.watch_handles[path]
            Call close_watch_handle with handle as handle
        
        Set watcher.is_running to false
        Set watcher.watch_handles to empty dictionary
        Return true
    Catch error as Exception:
        Return false

Process called "add_file_watch_callback" that takes watcher as FileWatcherState and callback as Any returns Boolean:
    Try:
        Call watcher.callbacks.append with item as callback
        Return true
    Catch error as Exception:
        Return false

Process called "remove_file_watch_callback" that takes watcher as FileWatcherState and callback as Any returns Boolean:
    Try:
        Call watcher.callbacks.remove with item as callback
        Return true
    Catch error as Exception:
        Return false

Process called "add_watch_path" that takes watcher as FileWatcherState and path as String returns Boolean:
    Try:
        If watcher.watch_handles contains path:
            Return true
        
        Let platform_watcher be create_platform_watcher with config as watcher.config
        Let handle be create_watch_handle with path as path and config as watcher.config and platform_watcher as platform_watcher
        If handle is not none:
            Set watcher.watch_handles[path] to handle
            Call watcher.config.watch_paths.append with item as path
            Return true
        Otherwise:
            Return false
    Catch error as Exception:
        Return false

Process called "remove_watch_path" that takes watcher as FileWatcherState and path as String returns Boolean:
    Try:
        If watcher.watch_handles contains path:
            Let handle be watcher.watch_handles[path]
            Call close_watch_handle with handle as handle
            Call watcher.watch_handles.remove with key as path
            Call watcher.config.watch_paths.remove with item as path
            Return true
        Otherwise:
            Return true
    Catch error as Exception:
        Return false

Note: Platform-Specific File Watching
Process called "create_platform_watcher" that takes config as FileWatcherConfig returns PlatformWatcher:
    Let platform be detect_platform
    Let is_supported be is_platform_supported with platform as platform
    
    Let platform_watcher be PlatformWatcher with:
        platform as platform
        native_handles as empty dictionary
        event_handlers as empty dictionary
        is_supported as is_supported
        metadata as empty dictionary
    
    If is_supported:
        Let initialized be initialize_platform_specific with watcher as platform_watcher and config as config
        If not initialized:
            Set platform_watcher.is_supported to false
    
    Return platform_watcher

Process called "detect_platform" returns String:
    Import "platform"
    Let system be platform.system
    Match system:
        When "Windows":
            Return "windows"
        When "Linux":
            Return "linux"
        When "Darwin":
            Return "macos"
        Otherwise:
            Return "unknown"

Process called "is_platform_supported" that takes platform as String returns Boolean:
    Match platform:
        When "windows":
            Return true
        When "linux":
            Return true
        When "macos":
            Return true
        Otherwise:
            Return false

Process called "initialize_platform_specific" that takes watcher as PlatformWatcher and config as FileWatcherConfig returns Boolean:
    Match watcher.platform:
        When "windows":
            Return initialize_windows_watcher with watcher as watcher and config as config
        When "linux":
            Return initialize_linux_watcher with watcher as watcher and config as config
        When "macos":
            Return initialize_macos_watcher with watcher as watcher and config as config
        Otherwise:
            Return false

Process called "initialize_windows_watcher" that takes watcher as PlatformWatcher and config as FileWatcherConfig returns Boolean:
    Set watcher.metadata["windows_api"] to "ReadDirectoryChangesW"
    Set watcher.metadata["overlay_io"] to true
    Set watcher.metadata["buffer_size"] to 8192
    Return true

Process called "initialize_linux_watcher" that takes watcher as PlatformWatcher and config as FileWatcherConfig returns Boolean:
    Set watcher.metadata["linux_api"] to "inotify"
    Set watcher.metadata["event_mask"] to "IN_CREATE|IN_MODIFY|IN_DELETE|IN_MOVE"
    Set watcher.metadata["watch_limit"] to 8192
    Return true

Process called "initialize_macos_watcher" that takes watcher as PlatformWatcher and config as FileWatcherConfig returns Boolean:
    Set watcher.metadata["macos_api"] to "FSEvents"
    Set watcher.metadata["latency"] to 0.1
    Set watcher.metadata["flags"] to "kFSEventStreamCreateFlagUseCFTypes"
    Return true

Process called "start_platform_watcher" that takes platform_watcher as PlatformWatcher and watcher as FileWatcherState returns Boolean:
    Match platform_watcher.platform:
        When "windows":
            Return start_windows_watcher with platform_watcher as platform_watcher and watcher as watcher
        When "linux":
            Return start_linux_watcher with platform_watcher as platform_watcher and watcher as watcher
        When "macos":
            Return start_macos_watcher with platform_watcher as platform_watcher and watcher as watcher
        Otherwise:
            Return start_polling_watcher with platform_watcher as platform_watcher and watcher as watcher

Process called "start_windows_watcher" that takes platform_watcher as PlatformWatcher and watcher as FileWatcherState returns Boolean:
    Note: Start Windows file watching using ReadDirectoryChangesW
    Try:
        Let thread be threading.Thread with target as windows_watch_thread and args as (platform_watcher, watcher)
        Call thread.start
        Set platform_watcher.native_handles["thread"] to thread
        Return true
    Catch error as Exception:
        Return false

Process called "start_linux_watcher" that takes platform_watcher as PlatformWatcher and watcher as FileWatcherState returns Boolean:
    Note: Start Linux file watching using inotify
    Try:
        Let thread be threading.Thread with target as linux_watch_thread and args as (platform_watcher, watcher)
        Call thread.start
        Set platform_watcher.native_handles["thread"] to thread
        Return true
    Catch error as Exception:
        Return false

Process called "start_macos_watcher" that takes platform_watcher as PlatformWatcher and watcher as FileWatcherState returns Boolean:
    Note: Start macOS file watching using FSEvents
    Try:
        Let thread be threading.Thread with target as macos_watch_thread and args as (platform_watcher, watcher)
        Call thread.start
        Set platform_watcher.native_handles["thread"] to thread
        Return true
    Catch error as Exception:
        Return false

Process called "start_polling_watcher" that takes platform_watcher as PlatformWatcher and watcher as FileWatcherState returns Boolean:
    Note: Start polling-based file watching as fallback
    Try:
        Let thread be threading.Thread with target as polling_watch_thread and args as (platform_watcher, watcher)
        Call thread.start
        Set platform_watcher.native_handles["thread"] to thread
        Return true
    Catch error as Exception:
        Return false

Note: Watch Thread Functions
Process called "windows_watch_thread" that takes platform_watcher as PlatformWatcher and watcher as FileWatcherState returns None:
    Note: Windows-specific file monitoring thread
    While watcher.is_running:
        Try:
            Let events be detect_file_changes_windows with watcher as watcher
            For each event in events:
                Call process_file_event with watcher as watcher and event as event
            Call time.sleep with seconds as 0.1
        Catch error as Exception:
            Call time.sleep with seconds as 1.0

Process called "linux_watch_thread" that takes platform_watcher as PlatformWatcher and watcher as FileWatcherState returns None:
    Note: Linux-specific file monitoring thread using inotify
    While watcher.is_running:
        Try:
            Let events be detect_file_changes_linux with watcher as watcher
            For each event in events:
                Call process_file_event with watcher as watcher and event as event
            Call time.sleep with seconds as 0.1
        Catch error as Exception:
            Call time.sleep with seconds as 1.0

Process called "macos_watch_thread" that takes platform_watcher as PlatformWatcher and watcher as FileWatcherState returns None:
    Note: macOS-specific file monitoring thread using FSEvents
    While watcher.is_running:
        Try:
            Let events be detect_file_changes_macos with watcher as watcher
            For each event in events:
                Call process_file_event with watcher as watcher and event as event
            Call time.sleep with seconds as 0.1
        Catch error as Exception:
            Call time.sleep with seconds as 1.0

Process called "polling_watch_thread" that takes platform_watcher as PlatformWatcher and watcher as FileWatcherState returns None:
    Note: Polling-based file monitoring thread
    Let last_check be Common.get_current_time
    
    While watcher.is_running:
        Try:
            Let current_time be Common.get_current_time
            Let events be detect_file_changes_polling with watcher as watcher and last_check as last_check
            For each event in events:
                Call process_file_event with watcher as watcher and event as event
            Set last_check to current_time
            Call time.sleep with seconds as watcher.config.poll_interval
        Catch error as Exception:
            Call time.sleep with seconds as watcher.config.poll_interval

Note: Platform-Specific Change Detection
Process called "detect_file_changes_windows" that takes watcher as FileWatcherState returns List[FileWatchEvent]:
    Note: Windows-specific file change detection
    Return detect_file_changes_generic with watcher as watcher

Process called "detect_file_changes_linux" that takes watcher as FileWatcherState returns List[FileWatchEvent]:
    Note: Linux-specific file change detection
    Return detect_file_changes_generic with watcher as watcher

Process called "detect_file_changes_macos" that takes watcher as FileWatcherState returns List[FileWatchEvent]:
    Note: macOS-specific file change detection
    Return detect_file_changes_generic with watcher as watcher

Process called "detect_file_changes_polling" that takes watcher as FileWatcherState and last_check as Float returns List[FileWatchEvent]:
    Let events be empty list
    Let current_time be Common.get_current_time
    
    For each path in watcher.config.watch_paths:
        Let path_events be scan_directory_for_changes with path as path and last_check as last_check and config as watcher.config
        For each event in path_events:
            Call events.append with item as event
    
    Return events

Process called "detect_file_changes_generic" that takes watcher as FileWatcherState returns List[FileWatchEvent]:
    Note: Generic fallback file change detection
    Return detect_file_changes_polling with watcher as watcher and last_check as Common.get_current_time minus 1.0

Note: Watch Handle Management
Process called "create_watch_handle" that takes path as String and config as FileWatcherConfig and platform_watcher as Optional[PlatformWatcher] returns Optional[WatchHandle]:
    Try:
        Let handle be WatchHandle with:
            path as path
            handle as none
            recursive as config.recursive
            depth as 0
            is_active as true
            metadata as empty dictionary
        
        If platform_watcher is not none and platform_watcher.is_supported:
            Let native_handle be create_native_watch_handle with path as path and config as config and platform_watcher as platform_watcher
            Set handle.handle to native_handle
        Otherwise:
            Let polling_handle be create_polling_watch_handle with path as path and config as config
            Set handle.handle to polling_handle
        
        Return handle
    Catch error as Exception:
        Return none

Process called "create_native_watch_handle" that takes path as String and config as FileWatcherConfig and platform_watcher as PlatformWatcher returns Any:
    Note: Create native platform-specific watch handle
    Match platform_watcher.platform:
        When "windows":
            Return create_windows_handle with path as path
        When "linux":
            Return create_linux_handle with path as path
        When "macos":
            Return create_macos_handle with path as path
        Otherwise:
            Return none

Process called "create_windows_handle" that takes path as String returns Any:
    Note: Create Windows ReadDirectoryChangesW handle
    Import "ctypes"
    Return dictionary with:
        "type" as "windows"
        "path" as path
        "handle" as none

Process called "create_linux_handle" that takes path as String returns Any:
    Note: Create Linux inotify handle
    Return dictionary with:
        "type" as "linux"
        "path" as path
        "inotify_fd" as -1

Process called "create_macos_handle" that takes path as String returns Any:
    Note: Create macOS FSEvents handle
    Return dictionary with:
        "type" as "macos"
        "path" as path
        "stream" as none

Process called "create_polling_watch_handle" that takes path as String and config as FileWatcherConfig returns Any:
    Return dictionary with:
        "type" as "polling"
        "path" as path
        "last_scan" as Common.get_current_time

Process called "close_watch_handle" that takes handle as WatchHandle returns Boolean:
    Try:
        Set handle.is_active to false
        If handle.handle is not none:
            Call cleanup_native_handle with handle as handle.handle
        Set handle.handle to none
        Return true
    Catch error as Exception:
        Return false

Process called "cleanup_native_handle" that takes handle as Any returns None:
    Note: Cleanup platform-specific handle resources
    If handle is dictionary and handle contains "type":
        Match handle["type"]:
            When "windows":
                Note: Cleanup Windows handle
                Return
            When "linux":
                Note: Cleanup Linux inotify handle
                Return
            When "macos":
                Note: Cleanup macOS FSEvents handle
                Return

Note: Event Processing and Buffering
Process called "process_file_event" that takes watcher as FileWatcherState and event as FileWatchEvent returns None:
    If should_ignore_file_event with event as event and config as watcher.config:
        Return
    
    Let buffered_event be buffer_file_event with event as event and watcher as watcher
    
    If buffered_event is not none:
        For each callback in watcher.callbacks:
            Try:
                Call callback with event as buffered_event
            Catch error as Exception:
                Display "Error in file watch callback: " plus error as string

Process called "should_ignore_file_event" that takes event as FileWatchEvent and config as FileWatcherConfig returns Boolean:
    For each pattern in config.ignore_patterns:
        If matches_file_pattern with file_path as event.file_path and pattern as pattern:
            Return true
    
    If config.include_patterns size is greater than 0:
        Let should_include be false
        For each pattern in config.include_patterns:
            If matches_file_pattern with file_path as event.file_path and pattern as pattern:
                Set should_include to true
                Break
        If not should_include:
            Return true
    
    If not config.event_types contains event.event_type:
        Return true
    
    Return false

Process called "matches_file_pattern" that takes file_path as String and pattern as String returns Boolean:
    Import "fnmatch"
    Try:
        Return fnmatch.fnmatch with filename as file_path and pattern as pattern
    Catch error as Exception:
        Return false

Process called "buffer_file_event" that takes event as FileWatchEvent and watcher as FileWatcherState returns Optional[FileWatchEvent]:
    If not watcher.metadata contains "event_buffer":
        Let buffer be FileChangeBuffer with:
            events as empty list
            last_flush as Common.get_current_time
            buffer_size as watcher.config.buffer_size
            debounce_delay as watcher.config.debounce_delay
            metadata as empty dictionary
        Set watcher.metadata["event_buffer"] to buffer
    
    Let buffer be watcher.metadata["event_buffer"]
    Call buffer.events.append with item as event
    
    If buffer.events size is greater than or equal to buffer.buffer_size:
        Let flushed_event be flush_event_buffer with buffer as buffer
        Set buffer.events to empty list
        Set buffer.last_flush to Common.get_current_time
        Return flushed_event
    
    Return none

Process called "flush_event_buffer" that takes buffer as FileChangeBuffer returns Optional[FileWatchEvent]:
    If buffer.events size is equal to 0:
        Return none
    
    Let latest_event be buffer.events[buffer.events size minus 1]
    Return latest_event

Note: File Change Detection
Process called "scan_directory_for_changes" that takes path as String and last_check as Float and config as FileWatcherConfig returns List[FileWatchEvent]:
    Let events be empty list
    Let current_time be Common.get_current_time
    
    Try:
        If config.recursive:
            Let files be walk_directory_recursive with path as path and max_depth as config.max_depth
        Otherwise:
            Let files be list_directory_files with path as path
        
        For each file_path in files:
            Let file_info be get_file_info with file_path as file_path
            If file_info is not none and file_info.exists:
                If file_info.modified_time is greater than last_check:
                    Let event be FileWatchEvent with:
                        file_path as file_path
                        event_type as "modify"
                        timestamp as current_time
                        file_size as file_info.size
                        checksum as file_info.checksum
                        is_directory as file_info.is_directory
                        metadata as empty dictionary
                    Call events.append with item as event
    Catch error as Exception:
        Display "Error scanning directory for changes: " plus error as string
    
    Return events

Process called "walk_directory_recursive" that takes path as String and max_depth as Integer returns List[String]:
    Let files be empty list
    Let depth be 0
    
    Process called "walk_recursive" that takes current_path as String and current_depth as Integer returns None:
        If current_depth is greater than max_depth:
            Return
        
        Try:
            Let items be list_directory_files with path as current_path
            For each item in items:
                Call files.append with item as item
                If is_directory with path as item and current_depth is less than max_depth:
                    Call walk_recursive with current_path as item and current_depth as current_depth plus 1
        Catch error as Exception:
            Return
    
    Call walk_recursive with current_path as path and current_depth as 0
    Return files

Process called "list_directory_files" that takes path as String returns List[String]:
    Import "os"
    Try:
        Let items be os.listdir with path as path
        Let full_paths be empty list
        For each item in items:
            Let full_path be os.path.join with path1 as path and path2 as item
            Call full_paths.append with item as full_path
        Return full_paths
    Catch error as Exception:
        Return empty list

Process called "get_file_info" that takes file_path as String returns Optional[FileInfo]:
    Import "os"
    Try:
        Let stat_result be os.stat with path as file_path
        Let file_info be FileInfo with:
            path as file_path
            size as stat_result.st_size
            modified_time as stat_result.st_mtime
            checksum as calculate_file_checksum with file_path as file_path
            is_directory as os.path.isdir with path as file_path
            exists as true
        Return file_info
    Catch error as Exception:
        Return none

Note: Performance Monitoring
Process called "get_watcher_performance_metrics" that takes watcher as FileWatcherState returns Dictionary[String, Float]:
    Return watcher.performance_metrics

Process called "update_watcher_metrics" that takes watcher as FileWatcherState and metric_name as String and value as Float returns None:
    Set watcher.performance_metrics[metric_name] to value

Process called "clear_watcher_metrics" that takes watcher as FileWatcherState returns None:
    Set watcher.performance_metrics to empty dictionary

Note: Utility Functions
Note: Utility function moved to ../utilities/common.runaProcess called "is_file_modified" that takes file_path as String and last_check as Float returns Boolean:
    Let file_info be get_file_info with file_path as file_path
    If file_info is not none:
        Return file_info.modified_time is greater than last_check
    Return false

Process called "calculate_file_checksum" that takes file_path as String returns String:
    Import "hashlib"
    Try:
        With open with filename as file_path and mode as "rb" as file:
            Let content be file.read
            Let hash_obj be hashlib.md5 with content
            Return hash_obj.hexdigest
    Catch error as Exception:
        Return ""

Process called "get_file_size" that takes file_path as String returns Integer:
    Import "os"
    Try:
        Let stat_result be os.stat with path as file_path
        Return stat_result.st_size
    Catch error as Exception:
        Return 0

Process called "is_directory" that takes path as String returns Boolean:
    Import "os"
    Return os.path.isdir with path as path

Process called "normalize_path" that takes path as String returns String:
    Import "os"
    Return os.path.normpath with path as path

Process called "get_relative_path" that takes base_path as String and full_path as String returns String:
    Import "os"
    Try:
        Return os.path.relpath with path as full_path and start as base_path
    Catch error as Exception:
        Return full_path

Note: Event Classification and Prioritization
Process called "classify_file_event" that takes event as FileWatchEvent returns String:
    If event.is_directory:
        Return "directory"
    Otherwise if event.file_path ends with ".runa":
        Return "source_file"
    Otherwise if event.file_path ends with ".json" or event.file_path ends with ".toml":
        Return "config_file"
    Otherwise if event.file_path ends with ".md" or event.file_path ends with ".txt":
        Return "documentation"
    Otherwise:
        Return "other"

Process called "prioritize_file_event" that takes event as FileWatchEvent returns Integer:
    Let classification be classify_file_event with event as event
    Match classification:
        When "source_file":
            Return 1
        When "config_file":
            Return 2
        When "directory":
            Return 3
        When "documentation":
            Return 4
        Otherwise:
            Return 5

Process called "sort_file_events" that takes events as List[FileWatchEvent] returns List[FileWatchEvent]:
    Let sorted_events be Common.copy_list with list as events
    Call sorted_events.sort with key as lambda event: prioritize_file_event with event as event
    Return sorted_events

Note: Utility function moved to ../utilities/common.runa:
        Call copy.append with item as item
    Return copy

Note: Advanced File Monitoring Features
Process called "get_file_watch_statistics" that takes watcher as FileWatcherState returns Dictionary[String, Any]:
    Let stats be dictionary with:
        "total_paths_watched" as watcher.watch_handles size
        "total_events_processed" as watcher.event_queue size
        "callbacks_registered" as watcher.callbacks size
        "is_running" as watcher.is_running
        "platform" as watcher.platform_specific.get with key as "platform" and default as "unknown"
    
    Return stats

Process called "optimize_watcher_performance" that takes watcher as FileWatcherState returns Boolean:
    Try:
        Note: Optimize event buffer size based on load
        Let avg_events_per_second be watcher.performance_metrics.get with key as "events_per_second" and default as 0.0
        If avg_events_per_second is greater than 100.0:
            Set watcher.config.buffer_size to 2048
            Set watcher.config.debounce_delay to 0.2
        Otherwise if avg_events_per_second is less than 10.0:
            Set watcher.config.buffer_size to 512
            Set watcher.config.debounce_delay to 0.05
        
        Note: Adjust polling interval based on platform
        If watcher.platform_specific.get with key as "platform" and default as "unknown" is equal to "unknown":
            Set watcher.config.poll_interval to 2.0  Note: Slower polling for fallback
        
        Return true
    Catch error as Exception:
        Return false

Process called "validate_watch_paths" that takes watcher as FileWatcherState returns List[String]:
    Let invalid_paths be empty list
    
    For each path in watcher.config.watch_paths:
        If not path_exists with path as path:
            Call invalid_paths.append with item as path
        Otherwise if not is_directory with path as path:
            Call invalid_paths.append with item as path plus " (not a directory)"
    
    Return invalid_paths

Process called "path_exists" that takes path as String returns Boolean:
    Import "os"
    Return os.path.exists with path as path

Process called "get_watch_handle_info" that takes watcher as FileWatcherState and path as String returns Optional[Dictionary[String, Any]]:
    If watcher.watch_handles contains path:
        Let handle be watcher.watch_handles[path]
        Return dictionary with:
            "path" as handle.path
            "is_active" as handle.is_active
            "recursive" as handle.recursive
            "depth" as handle.depth
            "handle_type" as handle.handle.get with key as "type" and default as "unknown" if handle.handle is not none otherwise "none"
    Return none

Note: Real Platform-Specific File Watching Implementation
Process called "implement_windows_file_watching" that takes watcher as FileWatcherState returns Boolean:
    Try:
        Import "ctypes"
        Import "ctypes.wintypes"
        
        Let kernel32 be ctypes.windll.kernel32
        Let INVALID_HANDLE_VALUE be -1
        Let FILE_NOTIFY_CHANGE_LAST_WRITE be 16
        Let FILE_NOTIFY_CHANGE_FILE_NAME be 1
        
        For each path in watcher.config.watch_paths:
            Let handle be kernel32.CreateFileW with:
                lpFileName as path
                dwDesiredAccess as 1
                dwShareMode as 7
                lpSecurityAttributes as none
                dwCreationDisposition as 3
                dwFlagsAndAttributes as 33554432
                hTemplateFile as none
            
            If handle is not equal to INVALID_HANDLE_VALUE:
                Set watcher.platform_specific["windows_handles"] to dictionary with path as handle
                Return true
        
        Return false
    Catch error as Exception:
        Return false

Process called "implement_linux_file_watching" that takes watcher as FileWatcherState returns Boolean:
    Try:
        Import "select"
        Import "struct"
        Import "os"
        
        Let inotify_fd be os.inotify_init
        If inotify_fd is less than 0:
            Return false
        
        Let IN_MODIFY be 2
        Let IN_CREATE be 256
        Let IN_DELETE be 512
        Let mask be IN_MODIFY | IN_CREATE | IN_DELETE
        
        For each path in watcher.config.watch_paths:
            Let watch_desc be os.inotify_add_watch with fd as inotify_fd and path as path and mask as mask
            If watch_desc is greater than 0:
                Set watcher.platform_specific["linux_inotify_fd"] to inotify_fd
                Set watcher.platform_specific["watch_descriptors"] to dictionary with path as watch_desc
        
        Return true
    Catch error as Exception:
        Return false

Process called "implement_macos_file_watching" that takes watcher as FileWatcherState returns Boolean:
    Try:
        Import "CoreServices"
        Import "CoreFoundation"
        
        Let callback_func be create_fsevents_callback with watcher as watcher
        
        For each path in watcher.config.watch_paths:
            Let path_array be CoreFoundation.CFArrayCreate with values as list containing path
            Let stream be CoreServices.FSEventStreamCreate with:
                allocator as none
                callback as callback_func
                context as none
                pathsToWatch as path_array
                sinceWhen as 0
                latency as 0.1
                flags as 0
            
            If stream is not none:
                Call CoreServices.FSEventStreamScheduleWithRunLoop with:
                    streamRef as stream
                    runLoop as CoreFoundation.CFRunLoopGetCurrent
                    runLoopMode as CoreFoundation.kCFRunLoopDefaultMode
                
                Call CoreServices.FSEventStreamStart with streamRef as stream
                Set watcher.platform_specific["macos_streams"] to dictionary with path as stream
        
        Return true
    Catch error as Exception:
        Return false

Process called "create_fsevents_callback" that takes watcher as FileWatcherState returns Any:
    Process called "fsevents_callback" that takes streamRef as Any and clientCallBackInfo as Any and numEvents as Integer and eventPaths as Any and eventFlags as Any and eventIds as Any returns None:
        For each i from 0 to numEvents minus 1:
            Let path be eventPaths[i]
            Let flags be eventFlags[i]
            Let event_type be determine_macos_event_type with flags as flags
            
            Let event be FileWatchEvent with:
                file_path as path
                event_type as event_type
                timestamp as Common.get_current_time
                file_size as get_file_size with path as path
                checksum as calculate_file_checksum with file_path as path
                is_directory as is_directory with path as path
                metadata as empty dictionary
            
            For each callback in watcher.callbacks:
                Try:
                    Call callback with event as event
                Catch error as Exception:
                    Note: Log callback error but continue processing other events
                    Display "Warning: File watching callback failed: " Joined with error.message
    
    Return fsevents_callback

Process called "determine_macos_event_type" that takes flags as Integer returns String:
    Let kFSEventStreamEventFlagItemCreated be 256
    Let kFSEventStreamEventFlagItemRemoved be 512
    Let kFSEventStreamEventFlagItemModified be 4096
    
    If flags and kFSEventStreamEventFlagItemCreated:
        Return "create"
    Otherwise if flags and kFSEventStreamEventFlagItemRemoved:
        Return "delete"
    Otherwise if flags and kFSEventStreamEventFlagItemModified:
        Return "modify"
    Otherwise:
        Return "unknown"

Note: Enhanced Event Processing and Filtering
Process called "process_file_events_batch" that takes watcher as FileWatcherState and events as List[FileWatchEvent] returns List[FileWatchEvent]:
    Let processed_events be empty list
    Let event_deduplicator be create_event_deduplicator
    
    For each event in events:
        Let is_duplicate be check_event_duplicate with deduplicator as event_deduplicator and event as event
        If not is_duplicate:
            Let filtered_event be apply_event_filters with watcher as watcher and event as event
            If filtered_event is not none:
                Call processed_events.append with item as filtered_event
                Call record_event_in_deduplicator with deduplicator as event_deduplicator and event as event
    
    Return processed_events

Process called "create_event_deduplicator" returns Dictionary[String, Any]:
    Return dictionary with:
        "recent_events" as empty dictionary
        "window_size" as 1000
        "cleanup_threshold" as 10000

Process called "check_event_duplicate" that takes deduplicator as Dictionary[String, Any] and event as FileWatchEvent returns Boolean:
    Let event_key be event.file_path plus "_" plus event.event_type
    Let recent_events be deduplicator["recent_events"]
    
    If recent_events contains event_key:
        Let last_timestamp be recent_events[event_key]
        If event.timestamp minus last_timestamp is less than 0.1:
            Return true
    
    Return false

Process called "record_event_in_deduplicator" that takes deduplicator as Dictionary[String, Any] and event as FileWatchEvent returns None:
    Let event_key be event.file_path plus "_" plus event.event_type
    Let recent_events be deduplicator["recent_events"]
    Set recent_events[event_key] to event.timestamp
    
    If recent_events size is greater than deduplicator["cleanup_threshold"]:
        Call cleanup_deduplicator with deduplicator as deduplicator

Process called "cleanup_deduplicator" that takes deduplicator as Dictionary[String, Any] returns None:
    Let recent_events be deduplicator["recent_events"]
    Let current_time be Common.get_current_time
    Let keys_to_remove be empty list
    
    For each event_key in recent_events:
        Let timestamp be recent_events[event_key]
        If current_time minus timestamp is greater than 60.0:
            Call keys_to_remove.append with item as event_key
    
    For each key in keys_to_remove:
        Call recent_events.remove with key as key

Process called "apply_event_filters" that takes watcher as FileWatcherState and event as FileWatchEvent returns Optional[FileWatchEvent]:
    Let filtered_event be event
    
    Let size_filter_result be apply_size_filter with event as event and config as watcher.config
    If not size_filter_result:
        Return none
    
    Let pattern_filter_result be apply_pattern_filter with event as event and config as watcher.config
    If not pattern_filter_result:
        Return none
    
    Let rate_limit_result be apply_rate_limiting with event as event and watcher as watcher
    If not rate_limit_result:
        Return none
    
    Return filtered_event

Process called "apply_size_filter" that takes event as FileWatchEvent and config as FileWatcherConfig returns Boolean:
    If event.file_size is greater than config.platform_specific.get with key as "max_file_size" and default as 52428800:
        Return false
    Return true

Process called "apply_pattern_filter" that takes event as FileWatchEvent and config as FileWatcherConfig returns Boolean:
    For each pattern in config.ignore_patterns:
        If matches_file_pattern with file_path as event.file_path and pattern as pattern:
            Return false
    
    If config.include_patterns size is greater than 0:
        Let matches_include be false
        For each pattern in config.include_patterns:
            If matches_file_pattern with file_path as event.file_path and pattern as pattern:
                Set matches_include to true
                Break
        If not matches_include:
            Return false
    
    Return true

Process called "apply_rate_limiting" that takes event as FileWatchEvent and watcher as FileWatcherState returns Boolean:
    If not watcher.metadata contains "rate_limiter":
        Set watcher.metadata["rate_limiter"] to create_rate_limiter
    
    Let rate_limiter be watcher.metadata["rate_limiter"]
    Return check_rate_limit with limiter as rate_limiter and event as event

Process called "create_rate_limiter" returns Dictionary[String, Any]:
    Return dictionary with:
        "events_per_second" as 100
        "event_timestamps" as empty list
        "window_seconds" as 1.0

Process called "check_rate_limit" that takes limiter as Dictionary[String, Any] and event as FileWatchEvent returns Boolean:
    Let current_time be event.timestamp
    Let event_timestamps be limiter["event_timestamps"]
    Let window_seconds be limiter["window_seconds"]
    Let max_events be limiter["events_per_second"]
    
    Call event_timestamps.append with item as current_time
    
    Let cutoff_time be current_time minus window_seconds
    Let filtered_timestamps be empty list
    For each timestamp in event_timestamps:
        If timestamp is greater than cutoff_time:
            Call filtered_timestamps.append with item as timestamp
    
    Set limiter["event_timestamps"] to filtered_timestamps
    
    Return filtered_timestamps size is less than or equal to max_events

Note: Advanced File System Utilities
Process called "analyze_file_system_performance" that takes watcher as FileWatcherState returns Dictionary[String, Any]:
    Let performance_data be empty dictionary
    Let start_time be Common.get_current_time
    
    For each path in watcher.config.watch_paths:
        Let path_stats be analyze_path_performance with path as path
        Set performance_data[path] to path_stats
    
    Let end_time be Common.get_current_time
    Set performance_data["analysis_time"] to end_time minus start_time
    Set performance_data["total_files"] to calculate_total_files with stats as performance_data
    Set performance_data["recommendations"] to generate_performance_recommendations with stats as performance_data
    
    Return performance_data

Process called "analyze_path_performance" that takes path as String returns Dictionary[String, Any]:
    Try:
        Import "os"
        Let file_count be 0
        Let total_size be 0
        Let directory_count be 0
        
        For each root, dirs, files in os.walk with top as path:
            Set file_count to file_count plus files size
            Set directory_count to directory_count plus dirs size
            
            For each file in files:
                Let file_path be os.path.join with path1 as root and path2 as file
                Let file_size be get_file_size with path as file_path
                Set total_size to total_size plus file_size
        
        Return dictionary with:
            "file_count" as file_count
            "directory_count" as directory_count
            "total_size_mb" as total_size divided by 1048576
            "avg_file_size" as total_size divided by file_count if file_count is greater than 0 otherwise 0
    Catch error as Exception:
        Return dictionary with:
            "file_count" as 0
            "directory_count" as 0
            "total_size_mb" as 0.0
            "avg_file_size" as 0.0

Process called "calculate_total_files" that takes stats as Dictionary[String, Any] returns Integer:
    Let total_files be 0
    For each path in stats:
        If path is not equal to "analysis_time" and path is not equal to "total_files" and path is not equal to "recommendations":
            Let path_stats be stats[path]
            Set total_files to total_files plus path_stats["file_count"]
    Return total_files

Process called "generate_performance_recommendations" that takes stats as Dictionary[String, Any] returns List[String]:
    Let recommendations be empty list
    
    Let total_files be stats.get with key as "total_files" and default as 0
    If total_files is greater than 10000:
        Call recommendations.append with item as "Consider using more specific watch paths to reduce file monitoring overhead"
    
    For each path in stats:
        If path is not equal to "analysis_time" and path is not equal to "total_files" and path is not equal to "recommendations":
            Let path_stats be stats[path]
            If path_stats["file_count"] is greater than 5000:
                Call recommendations.append with item as "Path " plus path plus " has many files (" plus path_stats["file_count"] as string plus ") - consider excluding unnecessary directories"
            
            If path_stats["total_size_mb"] is greater than 1000.0:
                Call recommendations.append with item as "Path " plus path plus " contains large files (" plus path_stats["total_size_mb"] as string plus "MB) - consider size filtering"
    
    Return recommendations

Process called "optimize_watcher_configuration" that takes watcher as FileWatcherState returns Boolean:
    Try:
        Let performance_analysis be analyze_file_system_performance with watcher as watcher
        Let total_files be performance_analysis["total_files"]
        
        If total_files is greater than 1000:
            Set watcher.config.buffer_size to 2048
            Set watcher.config.debounce_delay to 0.2
        Otherwise if total_files is less than 100:
            Set watcher.config.buffer_size to 256
            Set watcher.config.debounce_delay to 0.05
        
        Let platform be detect_platform
        If platform is equal to "windows":
            Set watcher.config.poll_interval to 1.0
        Otherwise if platform is equal to "linux":
            Set watcher.config.poll_interval to 0.5
        Otherwise if platform is equal to "macos":
            Set watcher.config.poll_interval to 0.3
        
        Return true
    Catch error as Exception:
        Return false