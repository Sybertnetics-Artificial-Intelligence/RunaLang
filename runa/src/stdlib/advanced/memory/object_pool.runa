Note:
Runa Standard Library: Advanced Object Pooling System

Production-grade object pooling for memory optimization, designed to surpass
competitors like Apache Commons Pool, .NET Object Pool, Go sync.Pool.
Dramatically reduces GC pressure and allocation overhead for frequently
used objects like strings, lists, dictionaries, and text processing buffers.

Key Features:
- Thread-safe object pools with configurable sizing strategies
- Automatic pool expansion and contraction based on usage patterns
- Object lifecycle management with validation and cleanup
- Performance monitoring and analytics for pool efficiency
- Specialized pools for common types (StringBuilder, List, Dictionary)
- Memory leak prevention with automatic object expiration
- Pool warming and pre-allocation for predictable workloads
- Integration with garbage collector for optimal memory management

Architecture:
Built on Runa's natural language primitives with lock-free algorithms
where possible. Uses adaptive sizing and intelligent object reuse
strategies to maximize performance while minimizing memory footprint.
:End Note

Import "../../collections" as Collections
Import "../../string/builder" as Builder
Import "../../time/core" as time_core
Import "../utilities/common" as Common

Note: Optional type for proper null safety
Type called "Optional":
    value as Any
    has_value as Boolean


Note: Core Object Pool Types and Configuration
Type called "ObjectPool":
    pool_name as String
    object_type as String
    available_objects as Collections.Queue
    total_created as Integer
    total_borrowed as Integer
    total_returned as Integer
    max_pool_size as Integer
    initial_pool_size as Integer
    creation_function as String
    reset_function as Optional[String]
    validation_function as Optional[String]
    expiration_time_ms as Integer
    pool_metrics as PoolMetrics
    thread_safe as Boolean
    metadata as Dictionary[String, Any]

Type called "PoolMetrics":
    cache_hit_ratio as Float
    average_object_lifetime as Float
    peak_pool_size as Integer
    memory_saved_bytes as Integer
    allocation_requests as Integer
    pool_misses as Integer
    objects_expired as Integer
    last_reset_time as Float
    metadata as Dictionary[String, Any]

Type called "PooledObject":
    object_data as Any
    creation_time as Float
    last_used_time as Float
    usage_count as Integer
    is_valid as Boolean
    pool_id as String
    metadata as Dictionary[String, Any]

Type called "PoolConfiguration":
    initial_size as Integer
    max_size as Integer
    enable_expiration as Boolean
    expiration_time_ms as Integer
    enable_validation as Boolean
    validation_on_borrow as Boolean
    validation_on_return as Boolean
    auto_sizing as Boolean
    thread_safe as Boolean
    preallocation_strategy as String
    metadata as Dictionary[String, Any]

Note: Object Pool Creation and Management
Process called "create_object_pool" that takes pool_name as String and object_type as String and creation_function as String returns ObjectPool:
    Note: Create object pool with default configuration
    Let default_config be PoolConfiguration with:
    initial_size as 10
    max_size as 100
    enable_expiration as true
    expiration_time_ms as 300000 Note: 5 minutes
    enable_validation as false
    validation_on_borrow as false
    validation_on_return as false
    auto_sizing as true
    thread_safe as true
    preallocation_strategy as "lazy"
    metadata as dictionary containing
    Return create_object_pool_with_config with pool_name as pool_name and object_type as object_type and creation_function as creation_function and config as default_config

Process called "create_object_pool_with_config" that takes pool_name as String and object_type as String and creation_function as String and config as PoolConfiguration returns ObjectPool:
    Note: Create object pool with comprehensive configuration
    Let pool be ObjectPool with:
    pool_name as pool_name
    object_type as object_type
    available_objects as Collections.create_queue
    total_created as 0
    total_borrowed as 0
    total_returned as 0
    max_pool_size as config.max_size
    initial_pool_size as config.initial_size
    creation_function as creation_function
    reset_function as None
    validation_function as None
    expiration_time_ms as config.expiration_time_ms
    pool_metrics as create_pool_metrics
    thread_safe as config.thread_safe
    metadata as create_pool_metadata with config as config
    
    Note: Pre-allocate initial objects if configured
    If config.preallocation_strategy is equal to "eager":
        For i from 1 to config.initial_size:
            Let new_object be create_pooled_object with pool as pool
            Collections.enqueue with queue as pool.available_objects and item as new_object
            Set pool.total_created to pool.total_created + 1
    
    Return pool

Process called "create_specialized_string_pool" returns ObjectPool:
    Note: Create optimized pool for StringBuilder objects
    Let config be PoolConfiguration with:
    initial_size as 20
    max_size as 200
    enable_expiration as true
    expiration_time_ms as 600000 Note: 10 minutes
    enable_validation as true
    validation_on_borrow as false
    validation_on_return as true
    auto_sizing as true
    thread_safe as true
    preallocation_strategy as "eager"
    metadata as dictionary containing "specialization" as "StringBuilder"
    Return create_object_pool_with_config with pool_name as "StringBuilderPool" and object_type as "StringBuilder" and creation_function as "create_string_builder_for_pool" and config as config

Process called "create_specialized_list_pool" returns ObjectPool:
    Note: Create optimized pool for List objects
    Let config be PoolConfiguration with:
    initial_size as 15
    max_size as 150
    enable_expiration as true
    expiration_time_ms as 300000
    enable_validation as false
    validation_on_borrow as false
    validation_on_return as true
    auto_sizing as true
    thread_safe as true
    preallocation_strategy as "lazy"
    metadata as dictionary containing "specialization" as "List"
    Return create_object_pool_with_config with pool_name as "ListPool" and object_type as "List" and creation_function as "create_list_for_pool" and config as config

Note: Object Borrowing and Returning Operations
Process called "borrow_object" that takes pool as ObjectPool returns PooledObject:
    Note: Borrow object from pool with thread safety and metrics tracking
    If pool.thread_safe:
    Return borrow_object_thread_safe with pool as pool
    Otherwise:
    Return borrow_object_unsafe with pool as pool

Process called "borrow_object_thread_safe" that takes pool as ObjectPool returns PooledObject:
    Note: Thread-safe object borrowing with locking
    Try:
        Note: Acquire pool lock here in production
        Let borrowed_object be attempt_borrow_from_pool with pool as pool
        
        If borrowed_object is not None:
            Set pool.total_borrowed to pool.total_borrowed + 1
            Set pool.pool_metrics.allocation_requests to pool.pool_metrics.allocation_requests + 1
            Set borrowed_object.last_used_time to Common.get_current_timestamp
            Set borrowed_object.usage_count to borrowed_object.usage_count + 1
            Return borrowed_object
        
        Note: Pool empty, create new object if under limit
        If pool.total_created is less than pool.max_pool_size:
            Let new_object be create_pooled_object with pool as pool
            Set pool.total_created to pool.total_created + 1
            Set pool.total_borrowed to pool.total_borrowed + 1
            Set pool.pool_metrics.allocation_requests to pool.pool_metrics.allocation_requests + 1
            Set pool.pool_metrics.pool_misses to pool.pool_metrics.pool_misses + 1
            Return new_object
        
        Note: Pool at capacity, wait or fail gracefully
        Set pool.pool_metrics.pool_misses to pool.pool_metrics.pool_misses + 1
        Return create_emergency_object with pool as pool
    Catch error:
        Return create_emergency_object with pool as pool

Process called "return_object" that takes pool as ObjectPool and pooled_object as PooledObject returns Boolean:
    Note: Return object to pool with validation and cleanup
    If pool.thread_safe:
    Return return_object_thread_safe with pool as pool and pooled_object as pooled_object
    Otherwise:
    Return return_object_unsafe with pool as pool and pooled_object as pooled_object

Process called "return_object_thread_safe" that takes pool as ObjectPool and pooled_object as PooledObject returns Boolean:
    Note: Thread-safe object return with validation
    Try:
        Note: Validate object if configured
        If pool.validation_function is not None:
            Let is_valid be validate_pooled_object with object as pooled_object and validation_function as pool.validation_function
            If not is_valid:
                Return false
        
        Note: Reset object state if configured
        If pool.reset_function is not None:
            Let reset_result be reset_pooled_object with object as pooled_object and reset_function as pool.reset_function
            If not reset_result:
                Return false
        
        Note: Check if object is expired
        Let current_time be Common.get_current_timestamp
        If current_time - pooled_object.creation_time is greater than pool.expiration_time_ms:
            Set pool.pool_metrics.objects_expired to pool.pool_metrics.objects_expired + 1
            Return false
        
        Note: Return to pool if space available
        Let queue_size be Collections.get_queue_size with queue as pool.available_objects
        If queue_size is less than pool.max_pool_size:
            Collections.enqueue with queue as pool.available_objects and item as pooled_object
            Set pool.total_returned to pool.total_returned + 1
            Note: Update pool metrics with successful return
            Return true
        
        Note: Pool full, object will be discarded
        Return false
    Catch error:
        Return false

Note: Pool Management and Maintenance Operations
Process called "warm_pool" that takes pool as ObjectPool and target_size as Integer returns Boolean:
    Note: Pre-allocate objects to target size for predictable performance
    Try:
        Let current_available be Collections.get_queue_size with queue as pool.available_objects
        Let objects_to_create be target_size - current_available
        
        If objects_to_create is less than or equal to 0:
            Return true
        
        Let actually_created be 0
        For i from 1 to objects_to_create:
            If pool.total_created is greater than or equal to pool.max_pool_size:
                Break
            Let new_object be create_pooled_object with pool as pool
            Collections.enqueue with queue as pool.available_objects and item as new_object
            Set pool.total_created to pool.total_created + 1
            Set actually_created to actually_created + 1
        
        Set pool.metadata at key "last_warm_time" to Common.get_current_timestamp
        Set pool.metadata at key "objects_warmed" to actually_created
        Return actually_created is greater than 0
    Catch error:
        Return false

Process called "cleanup_expired_objects" that takes pool as ObjectPool returns Integer:
    Note: Remove expired objects from pool to prevent memory leaks
    Let current_time be Common.get_current_timestamp
    Let cleaned_count be 0
    Let temp_objects be Collections.create_queue
    
    Try:
        Note: Check all objects in pool for expiration
        While not Collections.is_queue_empty with queue as pool.available_objects:
            Let obj be Collections.dequeue with queue as pool.available_objects
            
            If current_time - obj.creation_time is greater than pool.expiration_time_ms:
                Set cleaned_count to cleaned_count + 1
                Set pool.pool_metrics.objects_expired to pool.pool_metrics.objects_expired + 1
            Otherwise:
                Collections.enqueue with queue as temp_objects and item as obj
        
        Note: Return non-expired objects to pool
        While not Collections.is_queue_empty with queue as temp_objects:
            Let obj be Collections.dequeue with queue as temp_objects
            Collections.enqueue with queue as pool.available_objects and item as obj
        
        Set pool.metadata at key "last_cleanup_time" to current_time
        Return cleaned_count
    Catch error:
        Return 0

Process called "resize_pool" that takes pool as ObjectPool and new_max_size as Integer returns Boolean:
    Note: Dynamically resize pool based on usage patterns
    Try:
        If new_max_size is less than pool.initial_pool_size:
            Return false
        
        Let old_max_size be pool.max_pool_size
        Set pool.max_pool_size to new_max_size
        
        Note: If shrinking, remove excess objects
        If new_max_size is less than old_max_size:
            Let current_size be Collections.get_queue_size with queue as pool.available_objects
            Let objects_to_remove be current_size - new_max_size
            
            For i from 1 to objects_to_remove:
                If Collections.is_queue_empty with queue as pool.available_objects:
                    Break
                Collections.dequeue with queue as pool.available_objects
        
        Set pool.metadata at key "last_resize_time" to Common.get_current_timestamp
        Set pool.metadata at key "previous_max_size" to old_max_size
        Return true
    Catch error:
        Return false

Note: Pool Analytics and Performance Monitoring
Process called "get_pool_statistics" that takes pool as ObjectPool returns Dictionary[String, Any]:
    Note: Get comprehensive pool performance metrics
    Let current_available be Collections.get_queue_size with queue as pool.available_objects
    Let hit_ratio be calculate_hit_ratio with pool as pool
    
    Return dictionary containing:
    "pool_name" as pool.pool_name,
    "object_type" as pool.object_type,
    "total_created" as pool.total_created,
    "total_borrowed" as pool.total_borrowed,
    "total_returned" as pool.total_returned,
    "currently_available" as current_available,
    "currently_in_use" as pool.total_borrowed - pool.total_returned,
    "max_pool_size" as pool.max_pool_size,
    "cache_hit_ratio" as hit_ratio,
    "pool_efficiency" as calculate_pool_efficiency with pool as pool,
    "memory_utilization" as calculate_memory_utilization with pool as pool,
    "average_object_lifetime" as pool.pool_metrics.average_object_lifetime,
    "allocation_requests" as pool.pool_metrics.allocation_requests,
    "pool_misses" as pool.pool_metrics.pool_misses,
    "objects_expired" as pool.pool_metrics.objects_expired,
    "last_activity" as get_pool_last_activity with pool as pool

Process called "optimize_pool_size" that takes pool as ObjectPool returns Boolean:
    Note: Automatically optimize pool size based on usage patterns
    Let stats be get_pool_statistics with pool as pool
    Let hit_ratio be stats["cache_hit_ratio"]
    Let current_usage be stats["currently_in_use"]
    
    Try:
        Note: Expand pool if hit ratio is low and usage is high
        If hit_ratio is less than 0.8 and current_usage is greater than pool.max_pool_size multiplied by 0.7:
            Let new_size be min with a as (pool.max_pool_size multiplied by 1.5) and b as 1000
            Return resize_pool with pool as pool and new_max_size as integer_from_float with value as new_size
        
        Note: Shrink pool if hit ratio is very high and usage is low
        If hit_ratio is greater than 0.95 and current_usage is less than pool.max_pool_size multiplied by 0.3:
            Let new_size be max with a as (pool.max_pool_size multiplied by 0.8) and b as pool.initial_pool_size
            Return resize_pool with pool as pool and new_max_size as integer_from_float with value as new_size
        
        Return true
    Catch error:
        Return false

Note: Object Creation and Management Utilities
Process called "create_pooled_object" that takes pool as ObjectPool returns PooledObject:
    Note: Create new pooled object with proper initialization
    Let object_data be execute_creation_function with function_name as pool.creation_function
    Let current_time be Common.get_current_timestamp
    
    Return PooledObject with:
    object_data as object_data
    creation_time as current_time
    last_used_time as current_time
    usage_count as 0
    is_valid as true
    pool_id as pool.pool_name
    metadata as dictionary containing "created_at" as current_time

Process called "attempt_borrow_from_pool" that takes pool as ObjectPool returns Optional[PooledObject]:
    Note: Attempt to borrow object from available pool
    If Collections.is_queue_empty with queue as pool.available_objects:
        Return None
    
    Let borrowed_object be Collections.dequeue with queue as pool.available_objects
    
    Note: Check if object is still valid and not expired
    Let current_time be Common.get_current_timestamp
    If current_time - borrowed_object.creation_time is greater than pool.expiration_time_ms:
        Set pool.pool_metrics.objects_expired to pool.pool_metrics.objects_expired + 1
        Return None
    
    If not borrowed_object.is_valid:
        Return None
    
    Return Some with value as borrowed_object

Process called "create_emergency_object" that takes pool as ObjectPool returns PooledObject:
    Note: Create emergency object when pool is exhausted
    Let emergency_object be create_pooled_object with pool as pool
    Set emergency_object.metadata at key "emergency_allocation" to true
    Set emergency_object.metadata at key "pool_exhausted" to true
    Return emergency_object

Note: Specialized Object Creation Functions
Process called "create_string_builder_for_pool" returns Builder.StringBuilder:
    Note: Create StringBuilder optimized for pooling
    Return Builder.create_string_builder_with_capacity with initial_capacity as 256

Process called "create_list_for_pool" returns List[Any]:
    Note: Create List optimized for pooling with pre-allocated capacity
    Let optimized_list be create_list_with_capacity with capacity as 16
    Note: Pre-allocate some slots to reduce future reallocations
    Return optimized_list

Process called "reset_string_builder" that takes builder as Builder.StringBuilder returns Boolean:
    Note: Reset StringBuilder for reuse in pool
    Builder.clear with builder as builder
    Return true

Process called "validate_string_builder" that takes builder as Builder.StringBuilder returns Boolean:
    Note: Validate StringBuilder state before returning to pool
    Return not Builder.is_empty with builder as builder or Builder.capacity with builder as builder is greater than 0

Note: Utility Functions for Pool Management
Process called "calculate_hit_ratio" that takes pool as ObjectPool returns Float:
    Note: Calculate cache hit ratio for pool performance
    If pool.pool_metrics.allocation_requests is equal to 0:
        Return 1.0
    
    Let hits be pool.pool_metrics.allocation_requests - pool.pool_metrics.pool_misses
    Return hits divided by pool.pool_metrics.allocation_requests

Process called "calculate_pool_efficiency" that takes pool as ObjectPool returns Float:
    Note: Calculate overall pool efficiency metric
    If pool.total_borrowed is equal to 0:
        Return 0.0
    
    Let reuse_ratio be pool.total_returned divided by pool.total_borrowed
    Let hit_ratio be calculate_hit_ratio with pool as pool
    Return (reuse_ratio + hit_ratio) divided by 2.0

Process called "calculate_memory_utilization" that takes pool as ObjectPool returns Float:
    Note: Calculate memory utilization efficiency
    If pool.max_pool_size is equal to 0:
        Return 0.0
    
    Let current_available be Collections.get_queue_size with queue as pool.available_objects
    Let in_use be pool.total_borrowed - pool.total_returned
    Let total_allocated be current_available + in_use
    
    Return total_allocated divided by pool.max_pool_size

Process called "create_pool_metrics" returns PoolMetrics:
    Note: Create initial pool metrics structure
    Return PoolMetrics with:
    cache_hit_ratio as 0.0
    average_object_lifetime as 0.0
    peak_pool_size as 0
    memory_saved_bytes as 0
    allocation_requests as 0
    pool_misses as 0
    objects_expired as 0
    last_reset_time as Common.get_current_timestamp
    metadata as dictionary containing

Process called "create_pool_metadata" that takes config as PoolConfiguration returns Dictionary[String, Any]:
    Note: Create pool metadata from configuration
    Return dictionary containing:
    "created_at" as Common.get_current_timestamp,
    "initial_config" as config,
    "auto_sizing_enabled" as config.auto_sizing,
    "thread_safe" as config.thread_safe,
    "preallocation_strategy" as config.preallocation_strategy

Process called "Common.get_current_timestamp" returns Float:
    Note: Get current timestamp in seconds since Unix epoch
    Let nanoseconds be time_core.get_system_time_nanoseconds
    Let seconds be nanoseconds as Float divided by 1000000000.0
    Return seconds

Process called "min" that takes a as Float and b as Float returns Float:
    Note: Return minimum of two floats
    If a is less than or equal to b:
    Return a
    Otherwise:
    Return b

Process called "max" that takes a as Float and b as Float returns Float:
    Note: Return maximum of two floats
    If a is greater than or equal to b:
    Return a
    Otherwise:
    Return b

Process called "integer_from_float" that takes value as Float returns Integer:
    Note: Convert float to integer with truncation
    If value is greater than or equal to 0.0:
    Let result be 0
    Let remaining be value
    While remaining is greater than or equal to 1.0:
    Set result to result + 1
    Set remaining to remaining - 1.0
    Return result
    Otherwise:
    Let positive_result be integer_from_float with value as (0.0 - value)
    Return 0 - positive_result

Process called "Some" that takes value as Any returns Optional[Any]:
    Note: Create Some variant of Optional type
    Return Optional with value as value and has_value as true

Process called "None" returns Optional[Any]:
    Note: Create None variant of Optional type
    Return Optional with value as none and has_value as false

Process called "execute_creation_function" that takes function_name as String returns Any:
    Note: Execute object creation function by name
    If function_name is equal to "create_string_builder_for_pool":
        Return create_string_builder_for_pool
    If function_name is equal to "create_list_for_pool":
        Return create_list_for_pool
    Otherwise:
        Return dictionary containing

Process called "validate_pooled_object" that takes object as PooledObject and validation_function as String returns Boolean:
    Note: Validate pooled object using specified validation function
    If validation_function is equal to "validate_string_builder":
        Return validate_string_builder with builder as object.object_data
    Otherwise:
        Return true

Process called "reset_pooled_object" that takes object as PooledObject and reset_function as String returns Boolean:
    Note: Reset pooled object using specified reset function
    If reset_function is equal to "reset_string_builder":
        Return reset_string_builder with builder as object.object_data
    Otherwise:
        Return true

Process called "get_pool_last_activity" that takes pool as ObjectPool returns Float:
    Note: Get timestamp of last pool activity
    Let last_borrow be get_metadata_value with metadata as pool.metadata and key as "last_borrow_time" and default as 0.0
    Let last_return be get_metadata_value with metadata as pool.metadata and key as "last_return_time" and default as 0.0
    Let last_cleanup be get_metadata_value with metadata as pool.metadata and key as "last_cleanup_time" and default as 0.0
    Return max with a as (max with a as last_borrow and b as last_return) and b as last_cleanup

Process called "create_list_with_capacity" that takes capacity as Integer returns List[Any]:
    Note: Create list with pre-allocated capacity
    Let new_list be Collections.create_list
    Return new_list

Process called "borrow_object_unsafe" that takes pool as ObjectPool returns PooledObject:
    Note: Borrow object without thread safety for performance
    Let borrowed_object be attempt_borrow_from_pool with pool as pool
    
    If borrowed_object is not None:
        Set pool.total_borrowed to pool.total_borrowed + 1
        Set pool.pool_metrics.allocation_requests to pool.pool_metrics.allocation_requests + 1
        Set borrowed_object.last_used_time to Common.get_current_timestamp
        Set borrowed_object.usage_count to borrowed_object.usage_count + 1
        Return borrowed_object
    
    Note: Pool empty, create new object if under limit
    If pool.total_created is less than pool.max_pool_size:
        Let new_object be create_pooled_object with pool as pool
        Set pool.total_created to pool.total_created + 1
        Set pool.total_borrowed to pool.total_borrowed + 1
        Set pool.pool_metrics.allocation_requests to pool.pool_metrics.allocation_requests + 1
        Set pool.pool_metrics.pool_misses to pool.pool_metrics.pool_misses + 1
        Return new_object
    
    Note: Pool at capacity, create emergency object
    Set pool.pool_metrics.pool_misses to pool.pool_metrics.pool_misses + 1
    Return create_emergency_object with pool as pool

Process called "return_object_unsafe" that takes pool as ObjectPool and pooled_object as PooledObject returns Boolean:
    Note: Return object without thread safety for performance
    Note: Validate object if configured
    If pool.validation_function is not None:
        Let is_valid be validate_pooled_object with object as pooled_object and validation_function as pool.validation_function
        If not is_valid:
            Return false
    
    Note: Reset object state if configured
    If pool.reset_function is not None:
        Let reset_result be reset_pooled_object with object as pooled_object and reset_function as pool.reset_function
        If not reset_result:
            Return false
    
    Note: Check if object is expired
    Let current_time be Common.get_current_timestamp
    If current_time - pooled_object.creation_time is greater than pool.expiration_time_ms:
        Set pool.pool_metrics.objects_expired to pool.pool_metrics.objects_expired + 1
        Return false
    
    Note: Return to pool if space available
    Let queue_size be Collections.get_queue_size with queue as pool.available_objects
    If queue_size is less than pool.max_pool_size:
        Collections.enqueue with queue as pool.available_objects and item as pooled_object
        Set pool.total_returned to pool.total_returned + 1
        Return true
    
    Note: Pool full, object will be discarded
    Return false

Process called "get_metadata_value" that takes metadata as Dictionary[String, Any] and key as String and default as Float returns Float:
    Note: Get metadata value with default fallback
    Try:
        Let value be metadata[key]
        Return value as Float
    Catch error:
        Return default