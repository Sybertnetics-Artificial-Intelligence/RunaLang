            "store_memory" as generate_x86_64_store_memory
            "binary_add" as generate_x86_64_binary_add
            "binary_sub" as generate_x86_64_binary_sub
            "binary_mul" as generate_x86_64_binary_mul
            "binary_div" as generate_x86_64_binary_div
            "function_call" as generate_x86_64_function_call
