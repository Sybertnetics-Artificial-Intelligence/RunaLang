    Return dictionary containing:
        "architecture" as "x86_64"
        "register_count" as 16
        "registers" as list containing "rax", "rbx", "rcx", "rdx", "rsi", "rdi", "rbp", "rsp", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15"
        "instruction_encoder" as create_x86_64_instruction_encoder
        "calling_convention" as "system_v"
        "pointer_size" as 8
        "alignment" as 8
        "features" as list containing "sse2", "sse3", "ssse3", "sse4_1", "sse4_2", "avx", "avx2"
        "code_generation_functions" as dictionary containing:
            "load_constant" as generate_x86_64_load_constant
