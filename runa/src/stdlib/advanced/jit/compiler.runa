Process called "generate_load_constant" that takes generator as Dictionary and operands as List[Any] returns Bytes:
    Let architecture be generator["architecture"]
    Let value be operands[0] if operands size is greater than 0 else 0
    Let target_register be operands[1] if operands size is greater than 1 else "rax"
    
    Match architecture:
        When "x86_64":
            Return generate_x86_64_mov_immediate with register as target_register and value as value
        When "arm64":
            Return generate_arm64_mov_immediate with register as target_register and value as value
        When "riscv64":
            Return generate_riscv64_li with register as target_register and value as value as integer
        Otherwise:
            Return encode_generic_load_immediate with register as target_register and value as value

Process called "generate_load_name" that takes generator as Dictionary and operands as List[Any] returns Bytes:
    Let architecture be generator["architecture"]
    Let name be operands[0] if operands size is greater than 0 else "unknown"
    Let target_register be operands[1] if operands size is greater than 1 else "rax"
    
    Match architecture:
        When "x86_64":
            Note: MOV reg, [name_address] - load from memory location
            Return generate_x86_64_load_memory with register as target_register and address as name
        When "arm64":
            Note: LDR Xd, [address] - load from memory
            Return generate_arm64_load_memory with register as target_register and address as name
        When "riscv64":
            Note: LD rd, offset(rs1) - load from memory
            Return generate_riscv64_load_memory with register as target_register and address as name
        Otherwise:
            Return encode_generic_load_memory with register as target_register and address as name

Process called "generate_store_name" that takes generator as Dictionary and operands as List[Any] returns Bytes:
    Let architecture be generator["architecture"]
    Let source_register be operands[0] if operands size is greater than 0 else "rax"
    Let name be operands[1] if operands size is greater than 1 else "unknown"
    
    Match architecture:
        When "x86_64":
            Note: MOV [name_address], reg - store to memory location
            Return generate_x86_64_store_memory with register as source_register and address as name
        When "arm64":
            Note: STR Xs, [address] - store to memory
            Return generate_arm64_store_memory with register as source_register and address as name
        When "riscv64":
            Note: SD rs2, offset(rs1) - store to memory
            Return generate_riscv64_store_memory with register as source_register and address as name
        Otherwise:
            Return encode_generic_store_memory with register as source_register and address as name

Process called "generate_binary_add" that takes generator as Dictionary and operands as List[Any] returns Bytes:
    Let architecture be generator["architecture"]
    Let src1 be operands[0] if operands size is greater than 0 else "rax"
    Let src2 be operands[1] if operands size is greater than 1 else "rbx"
    Let dst be operands[2] if operands size is greater than 2 else src1
    
    Match architecture:
        When "x86_64":
            If dst is equal to src1:
                Return generate_x86_64_add with dst as dst and src as src2
            Otherwise:
                Let move_instruction be generate_x86_64_mov with dst as dst and src as src1
                Let add_instruction be generate_x86_64_add with dst as dst and src as src2
                Return concatenate_bytes with bytes1 as move_instruction and bytes2 as add_instruction
        When "arm64":
            Return generate_arm64_add with dst as dst and src1 as src1 and src2 as src2
        When "riscv64":
            Return generate_riscv64_add with dst as dst and src1 as src1 and src2 as src2
        Otherwise:
            Return encode_generic_binary_op with op as "add" and dst as dst and src1 as src1 and src2 as src2

Process called "generate_binary_subtract" that takes generator as Dictionary and operands as List[Any] returns Bytes:
    Let architecture be generator["architecture"]
    Let src1 be operands[0] if operands size is greater than 0 else "rax"
    Let src2 be operands[1] if operands size is greater than 1 else "rbx"
    Let dst be operands[2] if operands size is greater than 2 else src1
    
    Match architecture:
        When "x86_64":
            If dst is equal to src1:
                Return generate_x86_64_sub with dst as dst and src as src2
            Otherwise:
                Let move_instruction be generate_x86_64_mov with dst as dst and src as src1
                Let sub_instruction be generate_x86_64_sub with dst as dst and src as src2
                Return concatenate_bytes with bytes1 as move_instruction and bytes2 as sub_instruction
        When "arm64":
            Return generate_arm64_sub with dst as dst and src1 as src1 and src2 as src2
        When "riscv64":
            Return generate_riscv64_sub with dst as dst and src1 as src1 and src2 as src2
        Otherwise:
            Return encode_generic_binary_op with op as "sub" and dst as dst and src1 as src1 and src2 as src2

Process called "generate_binary_multiply" that takes generator as Dictionary and operands as List[Any] returns Bytes:
    Let architecture be generator["architecture"]
    Let src1 be operands[0] if operands size is greater than 0 else "rax"
    Let src2 be operands[1] if operands size is greater than 1 else "rbx"
    Let dst be operands[2] if operands size is greater than 2 else src1
    
    Match architecture:
        When "x86_64":
            If dst is equal to src1:
                Return generate_x86_64_imul with dst as dst and src as src2
            Otherwise:
                Let move_instruction be generate_x86_64_mov with dst as dst and src as src1
                Let mul_instruction be generate_x86_64_imul with dst as dst and src as src2
                Return concatenate_bytes with bytes1 as move_instruction and bytes2 as mul_instruction
        When "arm64":
            Return generate_arm64_mul with dst as dst and src1 as src1 and src2 as src2
        When "riscv64":
            Return generate_riscv64_mul with dst as dst and src1 as src1 and src2 as src2
        Otherwise:
            Return encode_generic_binary_op with op as "mul" and dst as dst and src1 as src1 and src2 as src2

Process called "generate_binary_divide" that takes generator as Dictionary and operands as List[Any] returns Bytes:
    Let architecture be generator["architecture"]
    Let src1 be operands[0] if operands size is greater than 0 else "rax"
    Let src2 be operands[1] if operands size is greater than 1 else "rbx"
    Let dst be operands[2] if operands size is greater than 2 else src1
    
    Match architecture:
        When "x86_64":
            Return generate_x86_64_idiv with dividend as src1 and divisor as src2 and quotient as dst
        When "arm64":
            Return generate_arm64_sdiv with dst as dst and src1 as src1 and src2 as src2
        When "riscv64":
            Return generate_riscv64_div with dst as dst and src1 as src1 and src2 as src2
        Otherwise:
            Return encode_generic_binary_op with op as "div" and dst as dst and src1 as src1 and src2 as src2

Process called "generate_call_function" that takes generator as Dictionary and operands as List[Any] returns Bytes:
    Let architecture be generator["architecture"]
    Let function_address be operands[0] if operands size is greater than 0 else 0
    
    Match architecture:
        When "x86_64":
            Return generate_x86_64_call with address as function_address
        When "arm64":
            Return generate_arm64_bl with address as function_address
        When "riscv64":
            Return generate_riscv64_jal with address as function_address
        Otherwise:
            Return encode_generic_call with address as function_address

Process called "generate_return_value" that takes generator as Dictionary and operands as List[Any] returns Bytes:
    Let architecture be generator["architecture"]
    Let return_value_register be operands[0] if operands size is greater than 0 else "rax"
    
    Match architecture:
        When "x86_64":
            Note: Move return value to RAX if needed, then RET
            If return_value_register is not equal to "rax":
                Let move_instruction be generate_x86_64_mov with dst as "rax" and src as return_value_register
                Let ret_instruction be generate_x86_64_ret
                Return concatenate_bytes with bytes1 as move_instruction and bytes2 as ret_instruction
            Otherwise:
                Return generate_x86_64_ret
        When "arm64":
            Note: Move return value to X0 if needed, then RET
            If return_value_register is not equal to "x0":
                Let move_instruction be generate_arm64_mov_reg with dst as "x0" and src as return_value_register
                Let ret_instruction be generate_arm64_ret
                Return concatenate_bytes with bytes1 as move_instruction and bytes2 as ret_instruction
            Otherwise:
                Return generate_arm64_ret
        When "riscv64":
            Note: Move return value to A0 if needed, then RET
            If return_value_register is not equal to "a0":
                Let move_instruction be generate_riscv64_mv with dst as "a0" and src as return_value_register
                Let ret_instruction be generate_riscv64_ret
                Return concatenate_bytes with bytes1 as move_instruction and bytes2 as ret_instruction
            Otherwise:
                Return generate_riscv64_ret
        Otherwise:
            Return encode_generic_return with register as return_value_register

Process called "generate_generic_instruction" that takes generator as Dictionary and instruction as BytecodeInstruction returns Bytes:
    Let architecture be generator["architecture"]
    Let opcode be instruction.opcode
    
    Match opcode:
        When 10:  # NOP
            Return generate_nop_instruction with architecture as architecture
        When 11:  # MOVE
            Return generate_move_instruction with architecture as architecture and operands as instruction.operands
        When 12:  # COMPARE
            Return generate_compare_instruction with architecture as architecture and operands as instruction.operands
        When 13:  # BRANCH
            Return generate_branch_instruction with architecture as architecture and operands as instruction.operands
        Otherwise:
            Return encode_fallback_instruction with architecture as architecture and instruction as instruction

Note: Architecture-Specific X86-64 Code Generation Functions
Process called "generate_x86_64_mov_immediate" that takes register as String and value as Any returns Bytes:
    Let register_code be get_x86_64_register_code with register as register
    Let value_bytes be encode_immediate_value with value as value and size as 8
    
    Note: MOV reg, imm64 - REX.W + B8+ rd io64
    Let rex_prefix be 0x48 if is_64bit_register with register as register else 0x40
    Let opcode be 0xB8 plus register_code
    
    Return bytes containing rex_prefix, opcode, value_bytes

Process called "generate_x86_64_add" that takes dst as String and src as String returns Bytes:
    Let dst_code be get_x86_64_register_code with register as dst
    Let src_code be get_x86_64_register_code with register as src
    
    Note: ADD reg, reg - REX.W + 01 /r
    Let rex_prefix be 0x48
    Let opcode be 0x01
    Let modrm be 0xC0 plus (src_code * 8) plus dst_code
    
    Return bytes containing rex_prefix, opcode, modrm

Process called "generate_x86_64_mov" that takes dst as String and src as String returns Bytes:
    Let dst_code be get_x86_64_register_code with register as dst
    Let src_code be get_x86_64_register_code with register as src
    
    Note: MOV reg, reg - REX.W + 89 /r
    Let rex_prefix be 0x48
    Let opcode be 0x89
    Let modrm be 0xC0 plus (src_code * 8) plus dst_code
    
    Return bytes containing rex_prefix, opcode, modrm

Process called "get_x86_64_register_code" that takes register as String returns Integer:
    Match register:
        When "rax": Return 0
        When "rcx": Return 1
        When "rdx": Return 2
        When "rbx": Return 3
        When "rsp": Return 4
        When "rbp": Return 5
        When "rsi": Return 6
        When "rdi": Return 7
        When "r8": Return 8
        When "r9": Return 9
        When "r10": Return 10
        When "r11": Return 11
        When "r12": Return 12
        When "r13": Return 13
        When "r14": Return 14
        When "r15": Return 15
        Otherwise: Return 0

Note: Architecture-Specific ARM64 Code Generation Functions
Process called "generate_arm64_mov_immediate" that takes register as String and value as Any returns Bytes:
    Let register_code be get_arm64_register_code with register as register
    Let value_int be value as integer
    
    Note: MOV Xd, #imm16 - SF 10 100101 hw imm16 Rd
    Let instruction be 0xD2800000
    Set instruction to instruction bitwise_or (register_code)
    Set instruction to instruction bitwise_or ((value_int bitwise_and 0xFFFF) left_shift 5)
    
    Return encode_arm64_instruction with instruction as instruction

Process called "generate_arm64_add" that takes dst as String and src1 as String and src2 as String returns Bytes:
    Let dst_code be get_arm64_register_code with register as dst
    Let src1_code be get_arm64_register_code with register as src1
    Let src2_code be get_arm64_register_code with register as src2
    
    Note: ADD Xd, Xn, Xm - SF 0 0 01011 shift 0 Rm imm6 Rn Rd
    Let instruction be 0x8B000000
    Set instruction to instruction bitwise_or dst_code
    Set instruction to instruction bitwise_or (src1_code left_shift 5)
    Set instruction to instruction bitwise_or (src2_code left_shift 16)
    
    Return encode_arm64_instruction with instruction as instruction

Process called "get_arm64_register_code" that takes register as String returns Integer:
    Note: Extract register number from ARM64 register name
    If register starts_with "x":
        Return parse_integer with string as register substring from 1
    Otherwise if register starts_with "w":
        Return parse_integer with string as register substring from 1
    Otherwise:
        Return 0

Note: Utility Functions for Code Generation
Process called "encode_immediate_value" that takes value as Any and size as Integer returns Bytes:
    Let value_int be value as integer
    Let result be bytearray with size as size
    
    For i from 0 to size minus 1:
        Set result[i] to (value_int right_shift (i * 8)) bitwise_and 0xFF
    
    Return bytes with result

Process called "encode_arm64_instruction" that takes instruction as Integer returns Bytes:
    Let result be bytearray with size as 4
    
    For i from 0 to 3:
        Set result[i] to (instruction right_shift (i * 8)) bitwise_and 0xFF
    
    Return bytes with result

Process called "concatenate_bytes" that takes bytes1 as Bytes and bytes2 as Bytes returns Bytes:
    Let result be bytearray
    Call result.extend with bytes1
    Call result.extend with bytes2
    Return bytes with result

Process called "is_64bit_register" that takes register as String returns Boolean:
    Return register starts_with "r" or register starts_with "x"

Note: Advanced Optimization Helper Functions
Process called "has_external_effects" that takes instruction as BytecodeInstruction returns Boolean:
    Match instruction.opcode:
        When 3:  # STORE_NAME
            Return true
        When 8:  # CALL_FUNCTION
            Return true
        When 9:  # RETURN_VALUE
            Return true
        When 14: # STORE_GLOBAL
            Return true
        When 15: # SYSTEM_CALL
            Return true
        Otherwise:
            Return false

Process called "find_instruction_by_offset" that takes bytecode as BytecodeBlock and offset as Integer returns Optional[BytecodeInstruction]:
    For each instruction in bytecode.instructions:
        If instruction.offset is equal to offset:
            Return instruction
    Return None

Process called "find_definition" that takes bytecode as BytecodeBlock and register as Integer returns Optional[BytecodeInstruction]:
    Note: Find the instruction that defines a given register
    For each instruction in bytecode.instructions:
        If instruction_defines_register with instruction as instruction and register as register:
            Return instruction
    Return None

Process called "instruction_defines_register" that takes instruction as BytecodeInstruction and register as Integer returns Boolean:
    Note: Check if instruction defines the given register
    Match instruction.opcode:
        When 1, 2:  # LOAD_CONST, LOAD_NAME
            Return true  # These define their target register
        When 4, 5, 6, 7:  # Binary operations
            Return true  # These define their result register
        Otherwise:
            Return false

Process called "compute_dominance_tree" that takes bytecode as BytecodeBlock returns Dictionary:
    Let dominance_tree be empty dictionary
    Let blocks be bytecode.basic_blocks
    
    If blocks is empty:
        Return dominance_tree
    
    Let entry_block be blocks[0]
    Let all_block_ids be get_all_block_ids with blocks as blocks
    
    Note: Initialize entry block - it dominates only itself
    Set dominance_tree[entry_block.start_offset] to list containing entry_block.start_offset
    
    Note: Initialize all other blocks to be dominated by all blocks
    For each block in blocks:
        If block.start_offset is not equal to entry_block.start_offset:
            Set dominance_tree[block.start_offset] to Common.copy_list with list as all_block_ids
    
    Note: Iteratively compute dominators using dataflow analysis
    Let changed be true
    Let iteration_count be 0
    Let max_iterations be get_dominance_analysis_max_iterations
    
    While changed and iteration_count is less than max_iterations:
        Set changed to false
        Set iteration_count to iteration_count plus 1
        
        For each block in blocks:
            If block.start_offset is not equal to entry_block.start_offset:
                Let new_dominators be intersection_of_predecessor_dominators with block as block and dominance_tree as dominance_tree and blocks as blocks
                Add block.start_offset to new_dominators
                
                If not lists_equal with list1 as new_dominators and list2 as dominance_tree[block.start_offset]:
                    Set dominance_tree[block.start_offset] to new_dominators
                    Set changed to true
    
    Return dominance_tree

Process called "find_back_edges_in_cfg" that takes bytecode as BytecodeBlock and dominators as Dictionary returns List[Dictionary]:
    Let back_edges be list containing
    
    For each block in bytecode.basic_blocks:
        For each successor_id in block.successors:
            Note: A back edge exists if the target dominates the source
            If dominators contains successor_id and dominators[successor_id] contains block.start_offset:
                Add dictionary containing:
                    "source" as block.start_offset
                    "target" as successor_id
                    "type" as "back_edge"
                    "loop_header" as successor_id
                    "loop_tail" as block.start_offset
                to back_edges
    
    Return back_edges

Note: Missing Helper Functions Implementation
Process called "is_constant_operand" that takes operand as String returns Boolean:
    Note: Check if operand represents a constant value
    If operand starts with "#" or operand starts with "@":
        Return true
    Try:
        Let numeric_value be operand as float
        Return true
    Catch error:
        Return false

Process called "extract_constant_value" that takes operand as String returns Float:
    Note: Extract numeric value from constant operand
    Try:
        If operand starts with "#":
            Return substring of operand from 1 to length of operand as float
        Otherwise if operand starts with "@":
            Return substring of operand from 1 to length of operand as float
        Otherwise:
            Return operand as float
    Catch error:
        Return 0.0

Process called "calculate_sqrt_fast" that takes value as Float returns Float:
    Note: Fast square root using Newton-Raphson approximation
    If value is less than or equal to 0:
        Return 0.0
    
    Let x be value
    Let precision be 0.000001
    Let estimate be value divided by 2.0
    
    While absolute_value of (estimate multiplied by estimate minus value) is greater than precision:
        Set estimate to (estimate plus (value divided by estimate)) divided by 2.0
    
    Return estimate

Process called "absolute_value" that takes x as Float returns Float:
    If x is less than 0:
        Return x multiplied by -1
    Otherwise:
        Return x

Process called "create_constant_instruction" that takes value as Any returns BytecodeInstruction:
    Return BytecodeInstruction with:
        opcode as LoadConstant with value as value
        operands as list containing
        result_type as "Float"
        source_location as None
        execution_count as 0
        execution_time as 0.0
        optimization_hints as list containing
        metadata as dictionary containing "constant_folded" as true

Process called "calculate_trig_cordic" that takes value as Float and function_type as String returns Float:
    Note: CORDIC algorithm for trigonometric functions
    Let iterations be 16
    Let angles be list containing 0.7853981634, 0.4636476090, 0.2449786631, 0.1243549945, 0.0624188100, 0.0312398334, 0.0156237286, 0.0078123493
    
    Let x be 0.6072529350
    Let y be 0.0
    Let z be value
    
    For i from 0 to iterations minus 1:
        Let sigma be 1 if z is greater than or equal to 0 else -1
        Let power_of_two_i be power_of_two with exponent as i
        Let new_x be x minus (sigma multiplied by y divided by power_of_two_i)
        Let new_y be y plus (sigma multiplied by x divided by power_of_two_i)
        Let new_z be z minus (sigma multiplied by angles[i])
        
        Set x to new_x
        Set y to new_y
        Set z to new_z
    
    Match function_type:
        When "sin":
            Return y
        When "cos":
            Return x
        When "tan":
            Return y divided by x if x is not equal to 0 else 0.0
        Otherwise:
            Return 0.0

Process called "power_of_two" that takes exponent as Integer returns Float:
    Let result be 1.0
    For i from 0 to exponent minus 1:
        Set result to result multiplied by 2.0
    Return result

Process called "get_trig_function_type" that takes instruction as BytecodeInstruction returns String:
    Note: Determine trigonometric function type from instruction
    Match instruction.opcode:
        When CallBuiltin with function_name as name:
            If name contains "sin":
                Return "sin"
            Otherwise if name contains "cos":
                Return "cos"
            Otherwise if name contains "tan":
                Return "tan"
            Otherwise:
                Return "unknown"
        Otherwise:
            Return "unknown"

Process called "map_trig_to_cordic" that takes instruction as BytecodeInstruction returns String:
    Let function_type be get_trig_function_type with instruction as instruction
    Match function_type:
        When "sin":
            Return "cordic_sin"
        When "cos":
            Return "cordic_cos"
        When "tan":
            Return "cordic_tan"
        Otherwise:
            Return "cordic_generic"

Process called "calculate_log_fast" that takes value as Float returns Float:
    Note: Fast logarithm using range reduction and Taylor series
    If value is less than or equal to 0:
        Return 0.0  Note: Undefined for non-positive values
    
    If value is equal to 1.0:
        Return 0.0
    
    Let exponent be 0
    Let mantissa be value
    
    Note: Range reduction
    While mantissa is greater than 2.0:
        Set mantissa to mantissa divided by 2.0
        Set exponent to exponent plus 1
    
    While mantissa is less than 1.0:
        Set mantissa to mantissa multiplied by 2.0
        Set exponent to exponent minus 1
    
    Note: Taylor series for ln(1 + x) where x = mantissa - 1
    Let x be mantissa minus 1.0
    Let ln_mantissa be x minus (x multiplied by x divided by 2.0) plus (x multiplied by x multiplied by x divided by 3.0)
    
    Return ln_mantissa plus (exponent multiplied by 0.6931471806)  Note: ln(2)

Process called "calculate_relative_displacement" that takes target_address as Any and current_instruction_pointer as Any returns Integer:
    Note: Calculate relative displacement for jump/call instructions
    Try:
        Let target be target_address as integer
        Let current be current_instruction_pointer as integer
        Let displacement be target minus current minus 5  Note: 5 bytes for call instruction
        Return displacement
    Catch error:
        Return 0

Process called "get_current_ip" returns Integer:
    Note: Get current instruction pointer for relative addressing
    Return 0x1000000  Note: Default base address

Process called "find_basic_block_by_id" that takes blocks as List[BasicBlock] and id as Integer returns Optional[BasicBlock]:
    For each block in blocks:
        If block.start_offset is equal to id:
            Return block
    Return None

Process called "get_current_basic_blocks" returns List[BasicBlock]:
    Note: Get current basic blocks from compilation context
    Return list containing

Process called "analyze_instruction_for_induction_variable" that takes instruction as BytecodeInstruction returns Optional[String]:
    Note: Analyze instruction to detect induction variable patterns
    Match instruction.opcode:
        When BinaryOp with operation as Add:
            If instruction.operands length is equal to 2:
                Let operand1 be instruction.operands at index 0
                Let operand2 be instruction.operands at index 1
                If is_variable_operand with operand as operand1 and is_constant_operand with operand as operand2:
                    Return operand1
                Otherwise if is_constant_operand with operand as operand1 and is_variable_operand with operand as operand2:
                    Return operand2
        When BinaryOp with operation as Subtract:
            If instruction.operands length is greater than 0:
                Let operand1 be instruction.operands at index 0
                If is_variable_operand with operand as operand1:
                    Return operand1
        Otherwise:
            Pass
    Return None

Process called "is_variable_operand" that takes operand as String returns Boolean:
    Note: Check if operand is a variable (not constant)
    Return not is_constant_operand with operand as operand

Process called "generate_power_of_two_sequence" that takes base as String and exponent as Float returns BytecodeInstruction:
    Note: Generate efficient sequence for power-of-two exponents
    Let log_exp be log_base_2 with value as exponent
    Let square_count be log_exp as integer
    
    If square_count is equal to 1:
        Return BytecodeInstruction with:
            opcode as BinaryOp with operation as Multiply
            operands as list containing base, base
            result_type as "Float"
            source_location as None
            execution_count as 0
            execution_time as 0.0
            optimization_hints as list containing
            metadata as dictionary containing "power_of_two_optimized" as true
    Otherwise:
        Note: For higher powers, use repeated squaring
        Return BytecodeInstruction with:
            opcode as CallBuiltin with function_name as "fast_power_of_two"
            operands as list containing base, exponent as string
            result_type as "Float"
            source_location as None
            execution_count as 0
            execution_time as 0.0
            optimization_hints as list containing
            metadata as dictionary containing "repeated_squaring" as true

Process called "log_base_2" that takes value as Float returns Float:
    Note: Calculate log base 2 using natural logarithm
    If value is less than or equal to 0:
        Return 0.0
    Let ln_value be calculate_log_fast with value as value
    Let ln_2 be 0.6931471806
    Return ln_value divided by ln_2

Process called "substring" that takes string as String and start as Integer and end as Integer returns String:
    Note: Extract substring with bounds checking
    Try:
        If start is less than 0:
            Set start to 0
        If end is greater than string.length:
            Set end to string.length
        If start is greater than or equal to end:
            Return ""
        
        Let result be ""
        For i from start to end minus 1:
            Set result to result plus string[i]
        Return result
    Catch error:
        Return ""

Process called "starts_with" that takes string as String and prefix as String returns Boolean:
    If string.length is less than prefix.length:
        Return false
    Let prefix_part be substring of string from 0 to prefix.length
    Return prefix_part is equal to prefix

Process called "contains" that takes string as String and substring as String returns Boolean:
    Let string_length be string.length
    Let substring_length be substring.length
    
    If substring_length is greater than string_length:
        Return false
    
    For i from 0 to string_length minus substring_length:
        Let found be true
        For j from 0 to substring_length minus 1:
            If string[i plus j] is not equal to substring[j]:
                Set found to false
                Break
        If found:
            Return true
    
    Return false

Process called "parse_integer" that takes string as String returns Integer:
    Try:
        Return string as integer
    Catch error:
        Return 0 