    Return maximum with a as max_ab and b as c

Note: Cache Compression and Decompression
Process called "compress_value" that takes value as Any returns Dictionary:
    Try:
        Import "json"
        Import "gzip"
        
        Let serialized_value be json.dumps with obj as value
        Let original_size be serialized_value size
        
        Note: Only compress if size is worth the overhead
        If original_size is less than 1024:
            Return dictionary containing:
                "compressed_value" as value
                "compression_ratio" as 1.0
                "compression_type" as "none"
        
        Let compressed_bytes be gzip.compress with data as serialized_value.encode with encoding as "utf-8"
        Let compressed_size be compressed_bytes size
        Let compression_ratio be compressed_size divided by original_size
        
        Note: If compression doesn't help, return original
        If compression_ratio is greater than 0.9:
            Return dictionary containing:
                "compressed_value" as value
                "compression_ratio" as 1.0
                "compression_type" as "none"
        
        Return dictionary containing:
            "compressed_value" as compressed_bytes
            "compression_ratio" as compression_ratio
            "compression_type" as "gzip"
            "original_size" as original_size
            "compressed_size" as compressed_size
    Catch error:
        Return dictionary containing:
            "compressed_value" as value
            "compression_ratio" as 1.0
            "compression_type" as "none"

Process called "decompress_value" that takes compressed_data as Dictionary returns Any:
    Try:
        Let compression_type be compressed_data["compression_type"] if compressed_data contains "compression_type" else "none"
        
        Match compression_type:
            When "none":
                Return compressed_data["compressed_value"]
            When "gzip":
                Import "json"
                Import "gzip"
                
                Let compressed_bytes be compressed_data["compressed_value"]
                Let decompressed_bytes be gzip.decompress with data as compressed_bytes
                Let decompressed_string be decompressed_bytes.decode with encoding as "utf-8"
                Return json.loads with s as decompressed_string
            Otherwise:
                Return compressed_data["compressed_value"]
    Catch error:
        Return None

