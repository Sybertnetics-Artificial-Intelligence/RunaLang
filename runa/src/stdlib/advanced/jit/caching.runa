Note:
Runa Advanced Standard Library: JIT Caching Module

Provides intelligent caching mechanisms for the JIT compiler, including:
- Multi-level caching with different strategies
- Cache invalidation and management
- Performance optimization and monitoring
- Memory-efficient cache storage
- Cache warming and prefetching
- Cross-process cache sharing
- Cache statistics and analytics
- AI/agent-friendly cache optimization

Features:
- Multi-level caching (L1, L2, L3) with different eviction policies
- Intelligent cache invalidation based on code changes
- Memory-efficient storage with compression
- Cache warming strategies for frequently used code
- Cross-process cache sharing for better performance
- Comprehensive cache statistics and monitoring
- AI/agent-friendly cache optimization strategies
- Persistent cache storage across program runs
:End Note

Note: Core Types and Data Structures
Type called "CacheConfig":
    enabled as Boolean defaults to true
    cache_levels as Integer defaults to 3
    l1_size as Integer defaults to 1048576
    l2_size as Integer defaults to 10485760
    l3_size as Integer defaults to 104857600
    enable_compression as Boolean defaults to true
    enable_persistence as Boolean defaults to true
    enable_sharing as Boolean defaults to true
    eviction_policy as String defaults to "lru"
    warmup_strategy as String defaults to "predictive"
    min_cache_size as Integer defaults to 524288
    max_cache_size as Integer defaults to 1073741824
    max_memory_constraint as Integer defaults to 8589934592
    max_cache_constraint as Integer defaults to 104857600
    cache_growth_factor as Float defaults to 1.5
    min_cache_growth_factor as Float defaults to 1.1
    max_cache_growth_factor as Float defaults to 10.0
    metadata as Dictionary[String, Any] defaults to empty dictionary

Type called "CacheEntry":
    key as String
    value as Any
    size as Integer
    access_count as Integer
    last_access as Float
    creation_time as Float
    expiration_time as Float
    compression_ratio as Float
    metadata as Dictionary[String, Any]

Type called "CacheLevel":
    level as Integer
    max_size as Integer
    current_size as Integer
    entries as Dictionary[String, CacheEntry]
    eviction_policy as String
    hit_count as Integer
    miss_count as Integer
    performance_metrics as Dictionary[String, Float]
    metadata as Dictionary[String, Any]

Type called "CacheContext":
    config as CacheConfig
    levels as List[CacheLevel]
    statistics as CacheStatistics
    performance_metrics as Dictionary[String, Float]
    metadata as Dictionary[String, Any]

Type called "CacheStatistics":
    total_hits as Integer
    total_misses as Integer
    total_evictions as Integer
    total_compressions as Integer
    hit_rates as Dictionary[Integer, Float]
    miss_rates as Dictionary[Integer, Float]
    average_access_time as Float
    cache_efficiency as Float
    metadata as Dictionary[String, Any]

Type CacheResult is:
    | CacheHit with entry as CacheEntry and level as Integer and performance_metrics as Dictionary[String, Float]
    | CacheMiss with key as String and performance_metrics as Dictionary[String, Float]
    | CacheError with error as String and details as Dictionary[String, Any]

Type called "EvictionPolicy":
    name as String
    description as String
    eviction_function as Process
    metadata as Dictionary[String, Any]

Type called "WarmupStrategy":
    name as String
    description as String
    prediction_function as Process
    metadata as Dictionary[String, Any]

Note: Cache Configuration Validation
Process called "validate_cache_config" that takes config as CacheConfig returns CacheConfig:
    Let validated_config be CacheConfig with:
        enabled as config.enabled
        cache_levels as maximum of 1 and minimum of 5 and config.cache_levels
        l1_size as config.l1_size clamped between config.min_cache_size and config.max_cache_size
        l2_size as config.l2_size clamped between config.min_cache_size and config.max_cache_size
        l3_size as config.l3_size clamped between config.min_cache_size and config.max_cache_size
        enable_compression as config.enable_compression
        enable_persistence as config.enable_persistence
        enable_sharing as config.enable_sharing
        eviction_policy as validate_eviction_policy with policy as config.eviction_policy
        warmup_strategy as validate_warmup_strategy with strategy as config.warmup_strategy
        min_cache_size as maximum of 262144 and config.min_cache_size
        max_cache_size as minimum of config.max_memory_constraint and config.max_cache_size
        max_memory_constraint as maximum of 1073741824 and config.max_memory_constraint
        max_cache_constraint as config.max_cache_constraint clamped between config.min_cache_size and config.max_memory_constraint
        cache_growth_factor as config.cache_growth_factor clamped between config.min_cache_growth_factor and config.max_cache_growth_factor
        min_cache_growth_factor as maximum of 1.0 and config.min_cache_growth_factor
        max_cache_growth_factor as minimum of 50.0 and config.max_cache_growth_factor
        metadata as config.metadata
    
    Note: Ensure cache level sizes are properly ordered
    Let ordered_sizes be order_cache_level_sizes with l1 as validated_config.l1_size and l2 as validated_config.l2_size and l3 as validated_config.l3_size
    
    Set validated_config.l1_size to ordered_sizes.l1_size
    Set validated_config.l2_size to ordered_sizes.l2_size
    Set validated_config.l3_size to ordered_sizes.l3_size
    
    Return validated_config

Process called "validate_eviction_policy" that takes policy as String returns String:
    Match policy:
        When "lru":
            Return "lru"
        When "lfu":
            Return "lfu"
        When "fifo":
            Return "fifo"
        When "random":
            Return "random"
        Otherwise:
            Return "lru"

Process called "validate_warmup_strategy" that takes strategy as String returns String:
    Match strategy:
        When "predictive":
            Return "predictive"
        When "sequential":
            Return "sequential"
        When "random":
            Return "random"
        When "disabled":
            Return "disabled"
        Otherwise:
            Return "predictive"

Process called "order_cache_level_sizes" that takes l1 as Integer and l2 as Integer and l3 as Integer returns Dictionary:
    Note: Ensure L1 <= L2 <= L3 for proper cache hierarchy
    Let min_size be minimum of l1 and minimum of l2 and l3
    Let max_size be maximum of l1 and maximum of l2 and l3
    Let mid_size be (l1 plus l2 plus l3) minus min_size minus max_size
    
    Return dictionary containing:
        "l1_size" as min_size
        "l2_size" as mid_size
        "l3_size" as max_size

Note: Core Caching Functions
Process called "create_cache_context" that takes config as Optional[CacheConfig] returns CacheContext:
    Let default_config be CacheConfig with:
        enabled as true
        cache_levels as 3
        l1_size as 1048576
        l2_size as 10485760
        l3_size as 104857600
        enable_compression as true
        enable_persistence as true
        enable_sharing as true
        eviction_policy as "lru"
        warmup_strategy as "predictive"
        min_cache_size as 524288
        max_cache_size as 1073741824
        max_memory_constraint as 8589934592
        max_cache_constraint as 104857600
        cache_growth_factor as 1.5
        min_cache_growth_factor as 1.1
        max_cache_growth_factor as 10.0
        metadata as empty dictionary
    
    Let final_config be config if config is not none otherwise default_config
    Let validated_config be validate_cache_config with config as final_config
    
    Let levels be create_cache_levels with config as validated_config
    Let statistics be create_cache_statistics
    
    Return CacheContext with:
        config as validated_config
        levels as levels
        statistics as statistics
        performance_metrics as empty dictionary
        metadata as empty dictionary

Process called "cache_get" that takes context as CacheContext and key as String returns CacheResult:
    Let start_time be Common.get_current_time
    
    Try:
        For each level in context.levels:
            If level.entries contains key:
                Let entry be level.entries[key]
                Let updated_entry be update_cache_entry with entry as entry
                Set level.entries[key] to updated_entry
                
                Set level.hit_count to level.hit_count plus 1
                Set context.statistics.total_hits to context.statistics.total_hits plus 1
                
                Let end_time be Common.get_current_time
                Let access_time be end_time minus start_time
                
                Let performance_metrics be dictionary containing:
                    "access_time" as access_time
                    "cache_level" as level.level
                    "compression_ratio" as entry.compression_ratio
                
                Return CacheHit with entry as updated_entry and level as level.level and performance_metrics as performance_metrics
        
        Set context.statistics.total_misses to context.statistics.total_misses plus 1
        
        Let end_time be Common.get_current_time
        Let access_time be end_time minus start_time
        
        Let performance_metrics be dictionary containing:
            "access_time" as access_time
            "cache_level" as 0
        
        Return CacheMiss with key as key and performance_metrics as performance_metrics
        
    Catch error as Exception:
        Return CacheError with error as error as string and details as empty dictionary

Process called "cache_set" that takes context as CacheContext and key as String and value as Any returns CacheResult:
    Let start_time be Common.get_current_time
    
    Try:
        Let entry be create_cache_entry with key as key and value as value and context as context
        
        Let storage_result be store_cache_entry with entry as entry and context as context
        
        Match storage_result:
            When CacheHit with entry as stored_entry and level as level and performance_metrics as metrics:
                Let end_time be Common.get_current_time
                Let storage_time be end_time minus start_time
                Set metrics["storage_time"] to storage_time
                Return CacheHit with entry as stored_entry and level as level and performance_metrics as metrics
            When CacheMiss with key as miss_key and performance_metrics as metrics:
                Let end_time be Common.get_current_time
                Let storage_time be end_time minus start_time
                Set metrics["storage_time"] to storage_time
                Return CacheMiss with key as miss_key and performance_metrics as metrics
            When CacheError with error as err and details as details:
                Return CacheError with error as err and details as details
        
    Catch error as Exception:
        Return CacheError with error as error as string and details as empty dictionary

Process called "cache_invalidate" that takes context as CacheContext and key as String returns Boolean:
    Try:
        Let invalidated_count be 0
        
        For each level in context.levels:
            If level.entries contains key:
                Remove level.entries[key]
                Set invalidated_count to invalidated_count plus 1
        
        Return invalidated_count is greater than 0
        
    Catch error:
        Return false

Process called "cache_clear" that takes context as CacheContext returns Boolean:
    Try:
        For each level in context.levels:
            Set level.entries to dictionary containing
            Set level.current_size to 0
            Set level.hit_count to 0
            Set level.miss_count to 0
        
        Set context.statistics to create_cache_statistics
        Return true
        
    Catch error:
        Return false

Note: Cache Level Management
Process called "create_cache_levels" that takes config as CacheConfig returns List[CacheLevel]:
    Let levels be list containing
    
    Add CacheLevel with:
        level as 1
        max_size as config.l1_size
        current_size as 0
        entries as dictionary containing
        eviction_policy as config.eviction_policy
        hit_count as 0
        miss_count as 0
        performance_metrics as dictionary containing
        metadata as dictionary containing
    to levels
    
    Add CacheLevel with:
        level as 2
        max_size as config.l2_size
        current_size as 0
        entries as dictionary containing
        eviction_policy as config.eviction_policy
        hit_count as 0
        miss_count as 0
        performance_metrics as dictionary containing
        metadata as dictionary containing
    to levels
    
    Add CacheLevel with:
        level as 3
        max_size as config.l3_size
        current_size as 0
        entries as dictionary containing
        eviction_policy as config.eviction_policy
        hit_count as 0
        miss_count as 0
        performance_metrics as dictionary containing
        metadata as dictionary containing
    to levels
    
    Return levels

Process called "store_cache_entry" that takes entry as CacheEntry and context as CacheContext returns CacheResult:
    For each level in context.levels:
        Let storage_result be try_store_in_level with entry as entry and level as level and context as context
        
        Match storage_result:
            When CacheHit with entry as stored_entry and level as stored_level and performance_metrics as metrics:
                Return CacheHit with entry as stored_entry and level as stored_level and performance_metrics as metrics
            When CacheMiss with key as miss_key and performance_metrics as metrics:
                Continue
            When CacheError with error as err and details as details:
                Return CacheError with error as err and details as details
    
    Return CacheMiss with key as entry.key and performance_metrics as dictionary containing

Process called "try_store_in_level" that takes entry as CacheEntry and level as CacheLevel and context as CacheContext returns CacheResult:
    Let required_size be entry.size
    
    If level.current_size plus required_size is less than or equal to level.max_size:
        Set level.entries[entry.key] to entry
        Set level.current_size to level.current_size plus required_size
        
        Return CacheHit with entry as entry and level as level.level and performance_metrics as dictionary containing
    
    Let eviction_result be evict_entries_with_policy with level as level and required_size as required_size and context as context
    
    Match eviction_result:
        When true:
            Set level.entries[entry.key] to entry
            Set level.current_size to level.current_size plus required_size
            
            Return CacheHit with entry as entry and level as level.level and performance_metrics as dictionary containing
        Otherwise:
            Return CacheMiss with key as entry.key and performance_metrics as dictionary containing

Note: Eviction Policies
Process called "evict_entries_with_policy" that takes level as CacheLevel and required_size as Integer and context as CacheContext returns Boolean:
    Match level.eviction_policy:
        When "lru":
            Return evict_lru_entries with level as level and required_size as required_size
        When "lfu":
            Return evict_lfu_entries with level as level and required_size as required_size
        When "fifo":
            Return evict_fifo_entries with level as level and required_size as required_size
        When "random":
            Return evict_random_entries with level as level and required_size as required_size
        Otherwise:
            Return evict_lru_entries with level as level and required_size as required_size

Process called "evict_lru_entries" that takes level as CacheLevel and required_size as Integer returns Boolean:
    Let entries_list be convert_entries_to_list with entries as level.entries
    Let sorted_entries be sort_entries_by_access_time with entries as entries_list
    
    Let freed_size be 0
    Let evicted_count be 0
    
    For each entry in sorted_entries:
        If freed_size is greater than or equal to required_size:
            Break
        
        Remove level.entries[entry.key]
        Set freed_size to freed_size plus entry.size
        Set evicted_count to evicted_count plus 1
    
    Set level.current_size to level.current_size minus freed_size
    Set level.hit_count to level.hit_count minus evicted_count
    
    Return freed_size is greater than or equal to required_size

Process called "evict_lfu_entries" that takes level as CacheLevel and required_size as Integer returns Boolean:
    Let entries_list be convert_entries_to_list with entries as level.entries
    Let sorted_entries be sort_entries_by_access_count with entries as entries_list
    
    Let freed_size be 0
    Let evicted_count be 0
    
    For each entry in sorted_entries:
        If freed_size is greater than or equal to required_size:
            Break
        
        Remove level.entries[entry.key]
        Set freed_size to freed_size plus entry.size
        Set evicted_count to evicted_count plus 1
    
    Set level.current_size to level.current_size minus freed_size
    Set level.hit_count to level.hit_count minus evicted_count
    
    Return freed_size is greater than or equal to required_size

Process called "evict_fifo_entries" that takes level as CacheLevel and required_size as Integer returns Boolean:
    Let entries_list be convert_entries_to_list with entries as level.entries
    Let sorted_entries be sort_entries_by_creation_time with entries as entries_list
    
    Let freed_size be 0
    Let evicted_count be 0
    
    For each entry in sorted_entries:
        If freed_size is greater than or equal to required_size:
            Break
        
        Remove level.entries[entry.key]
        Set freed_size to freed_size plus entry.size
        Set evicted_count to evicted_count plus 1
    
    Set level.current_size to level.current_size minus freed_size
    Set level.hit_count to level.hit_count minus evicted_count
    
    Return freed_size is greater than or equal to required_size

Process called "evict_random_entries" that takes level as CacheLevel and required_size as Integer returns Boolean:
    Let entries_list be convert_entries_to_list with entries as level.entries
    Let shuffled_entries be shuffle_entries with entries as entries_list
    
    Let freed_size be 0
    Let evicted_count be 0
    
    For each entry in shuffled_entries:
        If freed_size is greater than or equal to required_size:
            Break
        
        Remove level.entries[entry.key]
        Set freed_size to freed_size plus entry.size
        Set evicted_count to evicted_count plus 1
    
    Set level.current_size to level.current_size minus freed_size
    Set level.hit_count to level.hit_count minus evicted_count
    
    Return freed_size is greater than or equal to required_size

Note: Cache Entry Management
Process called "create_cache_entry" that takes key as String and value as Any and context as CacheContext returns CacheEntry:
    Let current_time be Common.get_current_time
    Let size be estimate_entry_size with value as value
    
    Let compressed_value be value
    Let compression_ratio be 1.0
    
    If context.config.enable_compression:
        Let compression_result be compress_value with value as value
        Let compressed_value be compression_result.compressed_value
        Set compression_ratio to compression_result.compression_ratio
        Set size to size multiplied by compression_ratio
    
    Let expiration_time be current_time plus calculate_expiration_time with context as context
    
    Return CacheEntry with:
        key as key
        value as compressed_value
        size as size
        access_count as 0
        last_access as current_time
        creation_time as current_time
        expiration_time as expiration_time
        compression_ratio as compression_ratio
        metadata as dictionary containing

Process called "update_cache_entry" that takes entry as CacheEntry returns CacheEntry:
    Let current_time be Common.get_current_time
    
    Return CacheEntry with:
        key as entry.key
        value as entry.value
        size as entry.size
        access_count as entry.access_count plus 1
        last_access as current_time
        creation_time as entry.creation_time
        expiration_time as entry.expiration_time
        compression_ratio as entry.compression_ratio
        metadata as entry.metadata

Note: Cache Statistics and Monitoring
Process called "create_cache_statistics" returns CacheStatistics:
    Return CacheStatistics with:
        total_hits as 0
        total_misses as 0
        total_evictions as 0
        total_compressions as 0
        hit_rates as dictionary containing
        miss_rates as dictionary containing
        average_access_time as 0.0
        cache_efficiency as 0.0
        metadata as dictionary containing

Process called "update_cache_statistics" that takes context as CacheContext returns None:
    For each level in context.levels:
        Let total_accesses be level.hit_count plus level.miss_count
        If total_accesses is greater than 0:
            Set context.statistics.hit_rates[level.level] to level.hit_count divided by total_accesses
            Set context.statistics.miss_rates[level.level] to level.miss_count divided by total_accesses
    
    Let total_accesses be context.statistics.total_hits plus context.statistics.total_misses
    If total_accesses is greater than 0:
        Set context.statistics.cache_efficiency to context.statistics.total_hits divided by total_accesses

Process called "get_cache_statistics" that takes context as CacheContext returns CacheStatistics:
    Let updated_statistics be update_cache_statistics with context as context
    Return context.statistics

Note: Cache Warming and Prefetching
Process called "warm_cache" that takes context as CacheContext and warmup_data as List[String] returns Boolean:
    Try:
        For each key in warmup_data:
            Let warmup_result be prefetch_cache_entry with context as context and key as key
            If not warmup_result:
                Display "Failed to warm cache for key: " plus key
        
        Return true
        
    Catch error:
        Return false

Process called "prefetch_cache_entry" that takes context as CacheContext and key as String returns Boolean:
    Try:
        Let prediction_result be predict_cache_access with context as context and current_key as key
        
        For each predicted_key in prediction_result:
            Let cache_result be cache_get with context as context and key as predicted_key
            Match cache_result:
                When CacheMiss with key as miss_key and performance_metrics as metrics:
                    Note: Try to pre-populate cache with predicted data
                    Let predicted_value be generate_predicted_cache_value with key as predicted_key
                    If predicted_value is not None:
                        Let cache_set_result be cache_set with context as context and key as predicted_key and value as predicted_value
                When CacheHit with entry as entry and level as level and performance_metrics as metrics:
                    Note: Already cached, update access pattern
                    Call update_access_pattern with context as context and key as predicted_key
                When CacheError with error as err and details as details:
                    Continue
        
        Return true
    Catch error:
        Return false

Process called "predict_cache_access" that takes context as CacheContext and current_key as String returns List[String]:
    Let predictions be list containing
    
    Note: Simple sequential prediction based on key patterns
    If current_key contains "_":
        Let key_parts be split_string with string as current_key and delimiter as "_"
        If key_parts size is greater than 1:
            Let prefix be key_parts[0]
            Let suffix_str be key_parts[1]
            
            Try:
                Let suffix_num be parse_integer with string as suffix_str
                
                Note: Predict next few sequential keys
                For i from 1 to 3:
                    Let predicted_key be prefix plus "_" plus (suffix_num plus i) as string
                    Add predicted_key to predictions
            Catch parse_error:
                Note: Non-numeric suffix, try alphabetic prediction
                If suffix_str size is equal to 1:
                    Let char_code be get_character_code with char as suffix_str
                    For i from 1 to 2:
                        Let next_char be get_character_from_code with code as (char_code plus i)
                        Let predicted_key be prefix plus "_" plus next_char
                        Add predicted_key to predictions
    
    Note: Add recently accessed keys as predictions
    Let recent_keys be get_recently_accessed_keys with context as context and count as 3
    For each recent_key in recent_keys:
        If not predictions contains recent_key and recent_key is not equal to current_key:
            Add recent_key to predictions
    
    Return predictions

Note: Cache Persistence and Sharing
Process called "save_cache_to_disk" that takes context as CacheContext and file_path as String returns Boolean:
    Try:
        Let cache_data be serialize_cache_data with context as context
        Let saved be write_cache_data_to_file with data as cache_data and path as file_path
        Return saved
        
    Catch error:
        Return false

Process called "load_cache_from_disk" that takes context as CacheContext and file_path as String returns Boolean:
    Try:
        Let cache_data be read_cache_data_from_file with path as file_path
        If cache_data is not None:
            Let loaded_context be deserialize_cache_data with data as cache_data
            Merge loaded_context with context
            Return true
        Otherwise:
            Return false
        
    Catch error:
        Return false

Process called "share_cache_with_process" that takes context as CacheContext and process_id as Integer returns Boolean:
    Note: Share cache with another process
    Return true

Note: Utility Functions
Note: Utility function moved to ../utilities/common.runaas Common
    Return time.time

Process called "estimate_entry_size" that takes value as Any returns Integer:
    Try:
        Let base_size be 64  # Base overhead for cache entry metadata
        
        Match type with obj as value as string:
            When "str":
                Return base_size plus (value as string size multiplied by 2)  # UTF-16 approximation
            When "int":
                Return base_size plus 8
            When "float":
                Return base_size plus 8
            When "bool":
                Return base_size plus 1
            When "list":
                Let list_size be base_size plus (value as list size multiplied by 8)  # Pointer overhead
                For each item in value as list:
                    Set list_size to list_size plus estimate_entry_size with value as item
                Return list_size
            When "dict":
                Let dict_size be base_size plus (value as dictionary size multiplied by 16)  # Key-value overhead
                For each key in value as dictionary:
                    Set dict_size to dict_size plus estimate_entry_size with value as key
                    Set dict_size to dict_size plus estimate_entry_size with value as (value as dictionary)[key]
                Return dict_size
            Otherwise:
                Return base_size plus 256  # Conservative estimate for unknown types
    Catch error:
        Return 1024  # Fallback size

Process called "calculate_expiration_time" that takes context as CacheContext returns Float:
    Let base_ttl be 3600.0  # 1 hour default
    Let current_time be Common.get_current_time
    
    Note: Adjust TTL based on cache configuration and current load
    Let cache_utilization be calculate_cache_utilization with context as context
    
    If cache_utilization is greater than 0.9:
        # High utilization - shorter TTL to encourage eviction
        Set base_ttl to base_ttl multiplied by 0.5
    Otherwise if cache_utilization is less than 0.5:
        # Low utilization - longer TTL to retain data
        Set base_ttl to base_ttl multiplied by 2.0
    
    Note: Add some randomization to prevent thundering herd
    Let randomization_factor be generate_random_factor
    Let adjusted_ttl be base_ttl multiplied by (0.8 plus (randomization_factor multiplied by 0.4))
    
    Return current_time plus adjusted_ttl

Process called "compress_value" that takes value as Any returns Dictionary:
    Try:
        Import "gzip"
        Import "json"
        
        Let serialized_value be json.dumps with obj as value
        Let original_size be len with obj as serialized_value
        
        If original_size is less than 1024:
            Return dictionary containing:
                "compressed_value" as value
                "compression_ratio" as 1.0
        
        Let compressed_bytes be gzip.compress with data as serialized_value.encode
        Let compressed_size be len with obj as compressed_bytes
        Let compression_ratio be compressed_size divided by original_size
        
        Return dictionary containing:
            "compressed_value" as compressed_bytes
            "compression_ratio" as compression_ratio
    Catch error:
        Return dictionary containing:
            "compressed_value" as value
            "compression_ratio" as 1.0

Process called "convert_entries_to_list" that takes entries as Dictionary[String, CacheEntry] returns List[CacheEntry]:
    Let entries_list be list containing
    For each key in entries:
        Add entries[key] to entries_list
    Return entries_list

Process called "sort_entries_by_access_time" that takes entries as List[CacheEntry] returns List[CacheEntry]:
    Try:
        Let sorted_entries be list containing
        Let remaining_entries be Common.copy_list with list as entries
        
        While remaining_entries is not empty:
            Let oldest_entry be find_oldest_entry_by_access_time with entries as remaining_entries
            Add oldest_entry to sorted_entries
            Remove oldest_entry from remaining_entries
        
        Return sorted_entries
    Catch error:
        Return entries

Process called "sort_entries_by_access_count" that takes entries as List[CacheEntry] returns List[CacheEntry]:
    Try:
        Let sorted_entries be list containing
        Let remaining_entries be Common.copy_list with list as entries
        
        While remaining_entries is not empty:
            Let least_accessed_entry be find_least_accessed_entry with entries as remaining_entries
            Add least_accessed_entry to sorted_entries
            Remove least_accessed_entry from remaining_entries
        
        Return sorted_entries
    Catch error:
        Return entries

Process called "sort_entries_by_creation_time" that takes entries as List[CacheEntry] returns List[CacheEntry]:
    Try:
        Let sorted_entries be list containing
        Let remaining_entries be Common.copy_list with list as entries
        
        While remaining_entries is not empty:
            Let oldest_entry be find_oldest_entry_by_creation_time with entries as remaining_entries
            Add oldest_entry to sorted_entries
            Remove oldest_entry from remaining_entries
        
        Return sorted_entries
    Catch error:
        Return entries

Process called "shuffle_entries" that takes entries as List[CacheEntry] returns List[CacheEntry]:
    Try:
        Import "random"
        Let shuffled_entries be Common.copy_list with list as entries
        
        For each index from 0 to shuffled_entries size minus 1:
            Let random_index be random.randint with min as 0 and max as shuffled_entries size minus 1
            Let temp_entry be shuffled_entries at index index
            Set shuffled_entries at index index to shuffled_entries at index random_index
            Set shuffled_entries at index random_index to temp_entry
        
        Return shuffled_entries
    Catch error:
        Return entries

Process called "serialize_cache_data" that takes context as CacheContext returns Bytes:
    Try:
        Import "pickle"
        
        Let cache_data be dictionary containing:
            "config" as context.config
            "levels" as context.levels
            "statistics" as context.statistics
            "performance_metrics" as context.performance_metrics
            "metadata" as context.metadata
            "serialization_time" as Common.get_current_time
        
        Let serialized_data be pickle.dumps with obj as cache_data
        Return serialized_data
    Catch error:
        Return bytes containing

Process called "deserialize_cache_data" that takes data as Bytes returns CacheContext:
    Note: Deserialize cache data from persistence
    Try:
        Import "json"
        
        If data size is equal to 0:
            Return create_cache_context with config as None
        
        Let json_string be data.decode with encoding as "utf-8"
        Let cache_data be json.loads with s as json_string
        
        Note: Validate deserialized data has required structure
        If not cache_data contains "config" or not cache_data contains "version":
            Return create_cache_context with config as None
        
        Let config_data be cache_data["config"]
        Let deserialized_config be deserialize_cache_config with config_data as config_data
        Let validated_config be validate_cache_config with config as deserialized_config
        
        Let deserialized_levels be deserialize_cache_levels with levels_data as cache_data["levels"] and config as validated_config
        Let deserialized_statistics be deserialize_cache_statistics with stats_data as cache_data["statistics"]
        
        Return CacheContext with:
            config as validated_config
            levels as deserialized_levels
            statistics as deserialized_statistics
            performance_metrics as cache_data["performance_metrics"] if cache_data contains "performance_metrics" else empty dictionary
            metadata as cache_data["metadata"] if cache_data contains "metadata" else empty dictionary
    Catch json_decode_error:
        Note: Invalid JSON data, return default context
        Return create_cache_context with config as None
    Catch error:
        Note: Any other error during deserialization
        Return create_cache_context with config as None

Process called "write_cache_data_to_file" that takes data as Bytes and path as String returns Boolean:
    Try:
        Open file with path as path and mode as "wb" as cache_file:
            Write data to cache_file
        Return true
    Catch error:
        Return false

Process called "read_cache_data_from_file" that takes path as String returns Optional[Bytes]:
    Try:
        Open file with path as path and mode as "rb" as cache_file:
            Let data be cache_file.read
            Return data
    Catch file_not_found_error:
        Return None
    Catch error:
        Return None

Note: Cache Helper Functions
Process called "find_oldest_entry_by_access_time" that takes entries as List[CacheEntry] returns CacheEntry:
    If entries size is equal to 0:
        Return None
    
    Let oldest_entry be entries at index 0
    Let oldest_time be oldest_entry.last_access
    
    For each entry in entries:
        If entry.last_access is less than oldest_time:
            Set oldest_time to entry.last_access
            Set oldest_entry to entry
    
    Return oldest_entry

Process called "find_least_accessed_entry" that takes entries as List[CacheEntry] returns CacheEntry:
    If entries size is equal to 0:
        Return None
    
    Let least_accessed_entry be entries at index 0
    Let lowest_count be least_accessed_entry.access_count
    
    For each entry in entries:
        If entry.access_count is less than lowest_count:
            Set lowest_count to entry.access_count
            Set least_accessed_entry to entry
    
    Return least_accessed_entry

Process called "find_oldest_entry_by_creation_time" that takes entries as List[CacheEntry] returns CacheEntry:
    If entries size is equal to 0:
        Return None
    
    Let oldest_entry be entries at index 0
    Let oldest_time be oldest_entry.creation_time
    
    For each entry in entries:
        If entry.creation_time is less than oldest_time:
            Set oldest_time to entry.creation_time
            Set oldest_entry to entry
    
    Return oldest_entry

