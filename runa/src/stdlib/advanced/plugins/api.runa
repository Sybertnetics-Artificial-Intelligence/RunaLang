Note:
Runa Advanced Standard Library: Plugin API Module

Provides a robust, production-grade API for plugin development, registration, and communication.

Features:
- Plugin interface and contract definition
- Registration, discovery, and lifecycle management
- Plugin communication and messaging
- Versioning, compatibility, and metadata
- Error handling, validation, and debugging
- AI/agent-friendly APIs
- Production-ready, robust, and extensible
:End Note

Note: Plugin API Types and Interfaces
Type called "Plugin":
    plugin_id as String
    name as String
    version as String
    author as String
    description as String
    entry_point as Function that takes context as PluginContext returns Any
    lifecycle as PluginLifecycle
    metadata as Dictionary[String, Any]

Type called "PluginLifecycle":
    initialize as Function that takes context as PluginContext returns Boolean
    start as Function that takes context as PluginContext returns Boolean
    stop as Function that takes context as PluginContext returns Boolean
    reload as Optional[Function that takes context as PluginContext returns Boolean]
    metadata as Dictionary[String, Any]

Type called "PluginContext":
    config as PluginConfig
    state as Dictionary[String, Any]
    communication as PluginCommunication
    metadata as Dictionary[String, Any]

Type called "PluginConfig":
    settings as Dictionary[String, Any]
    environment as Dictionary[String, Any]
    metadata as Dictionary[String, Any]

Type called "PluginCommunication":
    send_message as Function that takes message as PluginMessage returns None
    receive_message as Function that takes handler as Function returns None
    metadata as Dictionary[String, Any]

Type called "PluginMessage":
    message_id as String
    sender as String
    recipient as String
    payload as Any
    timestamp as Float
    metadata as Dictionary[String, Any]

Note: Internal State for Plugin Management
Let _plugin_registry be Dictionary[String, Plugin] containing
Let _plugin_message_queues be Dictionary[String, List[PluginMessage]] containing
Let _plugin_event_subscribers be Dictionary[String, List[EventSubscription]] containing
Let _plugin_service_registry be Dictionary[String, PluginService] containing
Let _plugin_service_types be Dictionary[String, List[String]] containing
Let _plugin_locks be Dictionary[String, Lock] containing

Note: Core Plugin API Functions
Process called "register_plugin" that takes plugin as Plugin returns Boolean:
    If plugin.plugin_id in _plugin_registry:
        Throw PluginRegistrationError with message "Plugin ID already registered"
    If not validate_plugin_metadata(plugin):
        Throw PluginRegistrationError with message "Invalid plugin metadata"
    Acquire _plugin_locks[plugin.plugin_id]
    Set _plugin_registry[plugin.plugin_id] to plugin
    Release _plugin_locks[plugin.plugin_id]
    Try:
        plugin.lifecycle.initialize with context as create_plugin_context(plugin)
    Catch error:
        unregister_plugin(plugin.plugin_id)
        Throw PluginRegistrationError with message "Initialization failed: " plus error.message
    Return true

Process called "unregister_plugin" that takes plugin_id as String returns Boolean:
    If plugin_id not in _plugin_registry:
        Return false
    Acquire _plugin_locks[plugin_id]
    Let plugin be _plugin_registry[plugin_id]
    Try:
        plugin.lifecycle.stop with context as create_plugin_context(plugin)
    Catch error:
        Note: Log error but continue
    Remove _plugin_registry[plugin_id]
    Remove _plugin_message_queues[plugin_id]
    Remove _plugin_event_subscribers[plugin_id]
    Release _plugin_locks[plugin_id]
    Return true

Process called "get_plugin" that takes plugin_id as String returns Optional[Plugin]:
    Return _plugin_registry.get(plugin_id)

Process called "list_plugins" returns List[Plugin]:
    Return list of values in _plugin_registry

Process called "send_plugin_message" that takes plugin_id as String and message as PluginMessage returns Boolean:
    If plugin_id not in _plugin_registry:
        Return false
    Acquire _plugin_locks[plugin_id]
    If plugin_id not in _plugin_message_queues:
        Set _plugin_message_queues[plugin_id] to list containing
    Append message to _plugin_message_queues[plugin_id]
    Release _plugin_locks[plugin_id]
    Return true

Process called "receive_plugin_message" that takes plugin_id as String and handler as Function returns None:
    If plugin_id not in _plugin_registry:
        Throw PluginNotFoundError with message "Plugin not found"
    Acquire _plugin_locks[plugin_id]
    Let queue be _plugin_message_queues.get(plugin_id, list containing)
    For each message in queue:
        handler with message as message
    Set _plugin_message_queues[plugin_id] to list containing
    Release _plugin_locks[plugin_id]
    Return None

Note: Event-Driven Plugin Communication
Type PluginEventBus is Dictionary with:
    subscribe as Function that takes plugin_id as String and event_type as String and handler as Function returns EventSubscription
    unsubscribe as Function that takes subscription as EventSubscription returns Boolean
    publish as Function that takes event as PluginEvent returns Boolean
    get_subscribers as Function that takes event_type as String returns List[String]
    metadata as Dictionary[String, Any]

Type PluginEvent is Dictionary with:
    event_id as String
    event_type as String
    source_plugin as String
    timestamp as Float
    data as Any
    metadata as Dictionary[String, Any]

Type EventSubscription is Dictionary with:
    subscription_id as String
    plugin_id as String
    event_type as String
    handler as Function
    priority as Integer
    active as Boolean
    metadata as Dictionary[String, Any]

Process called "create_plugin_event_bus" returns PluginEventBus:
    Let event_bus be PluginEventBus with:
        subscribe as function(plugin_id, event_type, handler):
            Let subscription be EventSubscription with:
                subscription_id as generate_uuid()
                plugin_id as plugin_id
                event_type as event_type
                handler as handler
                priority as 0
                active as true
                metadata as dictionary containing
            If event_type not in _plugin_event_subscribers:
                Set _plugin_event_subscribers[event_type] to list containing
            Append subscription to _plugin_event_subscribers[event_type]
            Return subscription
        unsubscribe as function(subscription):
            If subscription.event_type in _plugin_event_subscribers:
                Remove subscription from _plugin_event_subscribers[subscription.event_type]
                Return true
            Return false
        publish as function(event):
            If event.event_type in _plugin_event_subscribers:
                For each subscription in _plugin_event_subscribers[event.event_type]:
                    If subscription.active:
                        subscription.handler with event as event
                Return true
            Return false
        get_subscribers as function(event_type):
            If event_type in _plugin_event_subscribers:
                Return list of plugin_id for each subscription in _plugin_event_subscribers[event_type]
            Return list containing
        metadata as dictionary containing
    Return event_bus

Note: Service Discovery and Registration
Type PluginServiceRegistry is Dictionary with:
    register_service as Function that takes plugin_id as String and service as PluginService returns Boolean
    unregister_service as Function that takes service_id as String returns Boolean
    discover_services as Function that takes service_type as String returns List[PluginService]
    get_service as Function that takes service_id as String returns Optional[PluginService]
    metadata as Dictionary[String, Any]

Type PluginService is Dictionary with:
    service_id as String
    service_type as String
    plugin_id as String
    interface as ServiceInterface
    metadata as Dictionary[String, Any]

Process called "create_plugin_service_registry" returns PluginServiceRegistry:
    Let registry be PluginServiceRegistry with:
        register_service as function(plugin_id, service):
            If not validate_service_interface(service.interface):
                Return false
            If service.service_id in _plugin_service_registry:
                Throw ServiceRegistrationError with message "Service ID already exists"
            Set _plugin_service_registry[service.service_id] to service
            If service.service_type not in _plugin_service_types:
                Set _plugin_service_types[service.service_type] to list containing
            Append service.service_id to _plugin_service_types[service.service_type]
            Return true
        unregister_service as function(service_id):
            If service_id in _plugin_service_registry:
                Let service be _plugin_service_registry[service_id]
                Remove _plugin_service_registry[service_id]
                Remove service_id from _plugin_service_types[service.service_type]
                Return true
            Return false
        discover_services as function(service_type):
            If service_type in _plugin_service_types:
                Return list of _plugin_service_registry[service_id] for each service_id in _plugin_service_types[service_type]
            Return list containing
        get_service as function(service_id):
            Return _plugin_service_registry.get(service_id)
        metadata as dictionary containing
    Return registry

