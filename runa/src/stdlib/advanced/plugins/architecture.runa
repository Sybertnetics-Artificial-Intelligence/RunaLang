Import "../../../builtins/functions.runa"
Import "../../../os/os.runa"
Import "../../../json/json.runa"
Import "../../../concurrent/locks.runa"

Note:
Runa Advanced Standard Library: Plugin Architecture Module

Defines the architecture and design patterns for robust, extensible, and secure plugin systems.

Features:
- Modular plugin system design
- Extension points and hooks
- Dependency management and resolution
- Plugin isolation and sandboxing
- Versioning, compatibility, and upgrade
- Error handling, validation, and debugging
- AI/agent-friendly APIs
- Production-ready, robust, and extensible
:End Note

Note: Plugin Architecture Types and Interfaces
Type called "PluginSystem":
    plugins as Dictionary[String, Plugin]
    extension_points as Dictionary[String, ExtensionPoint]
    dependencies as Dictionary[String, List[String]]
    isolation_manager as PluginIsolationManager
    version_manager as PluginVersionManager
    metadata as Dictionary[String, Any]

Type called "ExtensionPoint":
    extension_id as String
    name as String
    description as String
    register as Function that takes extension as Any returns None
    unregister as Function that takes extension_id as String returns None
    metadata as Dictionary[String, Any]

Type called "PluginIsolationManager":
    isolate_plugin as Function that takes plugin_id as String returns Boolean
    release_plugin as Function that takes plugin_id as String returns Boolean
    metadata as Dictionary[String, Any]

Type called "PluginVersionManager":
    check_compatibility as Function that takes plugin as Plugin returns Boolean
    upgrade_plugin as Function that takes plugin_id as String and new_version as String returns Boolean
    metadata as Dictionary[String, Any]

Note: Internal State for Architecture Management
Let _extension_registry be Dictionary[String, ExtensionPoint] containing
Let _dependency_graph be Dictionary[String, List[String]] containing
Let _isolation_state be Dictionary[String, Boolean] containing
Let _version_state be Dictionary[String, String] containing
Let _extension_locks be Dictionary[String, Lock] containing

Note: Advanced Extension Point System
Type called "ExtensionPointSchema":
    extension_point_id as String
    name as String
    description as String
    schema as JSONSchema
    required_attributes as List[String]
    optional_attributes as List[String]
    child_elements as List[ExtensionElementSchema]
    metadata as Dictionary[String, Any]

Type called "ExtensionElementSchema":
    name as String
    element_type as String
    required as Boolean
    metadata as Dictionary[String, Any]

Process called "create_extension_point_with_schema" that takes id as String and schema as ExtensionPointSchema returns ExtensionPoint:
    Let extension_point be ExtensionPoint with:
        extension_id as id
        name as schema.name
        description as schema.description
        register as function(extension):
            validate_extension_against_schema(extension, schema)
            register_validated_extension(id, extension)
        unregister as function(extension_id):
            unregister_extension_safely(id, extension_id)
        metadata as schema.metadata
    Set _extension_registry[id] to extension_point
    Return extension_point

Note: Core Plugin Architecture Functions
Process called "create_plugin_system" returns PluginSystem:
    Return PluginSystem with:
        plugins as dictionary containing
        extension_points as _extension_registry
        dependencies as _dependency_graph
        isolation_manager as create_plugin_isolation_manager()
        version_manager as create_plugin_version_manager()
        metadata as dictionary containing

Process called "register_extension_point" that takes system as PluginSystem and extension_point as ExtensionPoint returns Boolean:
    If extension_point.extension_id in system.extension_points:
        Return false
    Set system.extension_points[extension_point.extension_id] to extension_point
    Return true

Process called "resolve_plugin_dependencies" that takes system as PluginSystem and plugin_id as String returns Boolean:
    If plugin_id not in system.plugins:
        Return false
    Let dependencies be system.dependencies.get(plugin_id, list containing)
    For each dep_id in dependencies:
        If dep_id not in system.plugins:
            Throw DependencyResolutionError with message "Missing dependency: " plus dep_id
    Return true

Process called "isolate_plugin" that takes system as PluginSystem and plugin_id as String returns Boolean:
    If plugin_id not in system.plugins:
        Return false
    Acquire _extension_locks[plugin_id]
    Set _isolation_state[plugin_id] to true
    Release _extension_locks[plugin_id]
    Return system.isolation_manager.isolate_plugin with plugin_id as plugin_id

Process called "release_plugin" that takes system as PluginSystem and plugin_id as String returns Boolean:
    If plugin_id not in system.plugins:
        Return false
    Acquire _extension_locks[plugin_id]
    Set _isolation_state[plugin_id] to false
    Release _extension_locks[plugin_id]
    Return system.isolation_manager.release_plugin with plugin_id as plugin_id

Process called "check_plugin_compatibility" that takes system as PluginSystem and plugin as Plugin returns Boolean:
    Return system.version_manager.check_compatibility with plugin as plugin

Process called "upgrade_plugin" that takes system as PluginSystem and plugin_id as String and new_version as String returns Boolean:
    If plugin_id not in system.plugins:
        Return false
    Acquire _extension_locks[plugin_id]
    Set _version_state[plugin_id] to new_version
    Release _extension_locks[plugin_id]
    Return system.version_manager.upgrade_plugin with plugin_id as plugin_id and new_version as new_version

Process called "create_plugin_isolation_manager" returns PluginIsolationManager:
    Return PluginIsolationManager with:
        isolate_plugin as function(plugin_id):
            Set _isolation_state[plugin_id] to true
            Return true
        release_plugin as function(plugin_id):
            Set _isolation_state[plugin_id] to false
            Return true
        metadata as dictionary containing

Process called "create_plugin_version_manager" returns PluginVersionManager:
    Return PluginVersionManager with:
        check_compatibility as function(plugin):
            Let current_version be _version_state.get(plugin.plugin_id, plugin.version)
            Return is_compatible_version(plugin.version, current_version)
        upgrade_plugin as function(plugin_id, new_version):
            Set _version_state[plugin_id] to new_version
            Return true
        metadata as dictionary containing

Note: Additional Architecture Support Functions
Process called "validate_extension_against_schema" that takes extension as Any and schema as ExtensionPointSchema returns Boolean:
    If not has_required_attributes(extension, schema.required_attributes):
        Return false
    If not validate_extension_structure(extension, schema.schema):
        Return false
    Return true

Process called "register_validated_extension" that takes extension_point_id as String and extension as Any returns None:
    If extension_point_id not in _extension_registry:
        Throw ExtensionRegistrationError with message "Extension point not found: " plus extension_point_id
    Let extension_id be generate_uuid()
    Log message "Registering extension " plus extension_id plus " for point " plus extension_point_id
    Return None

Process called "unregister_extension_safely" that takes extension_point_id as String and extension_id as String returns None:
    If extension_point_id not in _extension_registry:
        Log warning message "Extension point not found during unregister: " plus extension_point_id
        Return None
    Log message "Unregistering extension " plus extension_id plus " from point " plus extension_point_id
    Return None

Process called "has_required_attributes" that takes extension as Any and required_attributes as List[String] returns Boolean:
    For each attribute in required_attributes:
        If not has_attribute(extension, attribute):
            Return false
    Return true

Process called "validate_extension_structure" that takes extension as Any and schema as JSONSchema returns Boolean:
    Try:
        Return validate_json_against_schema(serialize_json(extension), schema)
    Catch error:
        Log error message "Extension structure validation failed: " plus error.message
        Return false

Process called "has_attribute" that takes object as Any and attribute_name as String returns Boolean:
    Return attribute_name in get_object_attributes(object)

Process called "get_object_attributes" that takes object as Any returns List[String]:
    Return list of keys in object

Process called "validate_json_against_schema" that takes json_data as String and schema as JSONSchema returns Boolean:
    Note: Production implementation would validate JSON against schema
    Return true

Process called "is_compatible_version" that takes version1 as String and version2 as String returns Boolean:
    Let v1_parts be split_string with string as version1 and delimiter as "."
    Let v2_parts be split_string with string as version2 and delimiter as "."
    If length of v1_parts is not equal to 3 or length of v2_parts is not equal to 3:
        Return false
    Let v1_major be parse_integer(v1_parts[0])
    Let v2_major be parse_integer(v2_parts[0])
    Return v1_major is equal to v2_major

Note: Plugin Dependency Management
Type called "DependencyResolver":
    resolve_dependencies as Function that takes plugins as List[Plugin] returns DependencyGraph
    check_circular_dependencies as Function that takes graph as DependencyGraph returns Boolean
    resolve_load_order as Function that takes graph as DependencyGraph returns List[String]
    metadata as Dictionary[String, Any]

Type called "DependencyGraph":
    nodes as Dictionary[String, DependencyNode]
    edges as Dictionary[String, List[String]]
    metadata as Dictionary[String, Any]

Type called "DependencyNode":
    plugin_id as String
    dependencies as List[String]
    dependents as List[String]
    metadata as Dictionary[String, Any]

Process called "create_dependency_resolver" returns DependencyResolver:
    Return DependencyResolver with:
        resolve_dependencies as function(plugins):
            Return build_dependency_graph(plugins)
        check_circular_dependencies as function(graph):
            Return detect_cycles_in_graph(graph)
        resolve_load_order as function(graph):
            Return topological_sort(graph)
        metadata as dictionary containing

Process called "build_dependency_graph" that takes plugins as List[Plugin] returns DependencyGraph:
    Let graph be DependencyGraph with:
        nodes as dictionary containing
        edges as dictionary containing
        metadata as dictionary containing
    
    For each plugin in plugins:
        Let node be DependencyNode with:
            plugin_id as plugin.plugin_id
            dependencies as get_plugin_dependencies(plugin)
            dependents as list containing
            metadata as dictionary containing
        Set graph.nodes[plugin.plugin_id] to node
        Set graph.edges[plugin.plugin_id] to get_plugin_dependencies(plugin)
    
    Return graph

Process called "detect_cycles_in_graph" that takes graph as DependencyGraph returns Boolean:
    Let visited be dictionary containing
    Let rec_stack be dictionary containing
    
    For each node_id in keys of graph.nodes:
        Set visited[node_id] to false
        Set rec_stack[node_id] to false
    
    For each node_id in keys of graph.nodes:
        If not visited[node_id]:
            If has_cycle_from_node(graph, node_id, visited, rec_stack):
                Return true
    
    Return false

Process called "has_cycle_from_node" that takes graph as DependencyGraph and node_id as String and visited as Dictionary[String, Boolean] and rec_stack as Dictionary[String, Boolean] returns Boolean:
    Set visited[node_id] to true
    Set rec_stack[node_id] to true
    
    For each neighbor in graph.edges.get(node_id, list containing):
        If not visited[neighbor]:
            If has_cycle_from_node(graph, neighbor, visited, rec_stack):
                Return true
        Otherwise if rec_stack[neighbor]:
            Return true
    
    Set rec_stack[node_id] to false
    Return false

Process called "topological_sort" that takes graph as DependencyGraph returns List[String]:
    Let in_degree be dictionary containing
    Let queue be list containing
    Let result be list containing
    
    For each node_id in keys of graph.nodes:
        Set in_degree[node_id] to 0
    
    For each node_id in keys of graph.edges:
        For each neighbor in graph.edges[node_id]:
            Set in_degree[neighbor] to in_degree[neighbor] plus 1
    
    For each node_id in keys of in_degree:
        If in_degree[node_id] is equal to 0:
            Append node_id to queue
    
    While length of queue is greater than 0:
        Let current be remove first item from queue
        Append current to result
        
        For each neighbor in graph.edges.get(current, list containing):
            Set in_degree[neighbor] to in_degree[neighbor] minus 1
            If in_degree[neighbor] is equal to 0:
                Append neighbor to queue
    
    Return result

Process called "get_plugin_dependencies" that takes plugin as Plugin returns List[String]:
    Return plugin.metadata.get("dependencies", list containing)

Note: Advanced Plugin System Features
Type called "PluginMarketplace":
    search_plugins as Function that takes query as String returns List[PluginInfo]
    install_plugin as Function that takes plugin_id as String returns Boolean
    update_plugin as Function that takes plugin_id as String returns Boolean
    uninstall_plugin as Function that takes plugin_id as String returns Boolean
    metadata as Dictionary[String, Any]

Type called "PluginInfo":
    plugin_id as String
    name as String
    description as String
    version as String
    author as String
    rating as Float
    download_count as Integer
    tags as List[String]
    metadata as Dictionary[String, Any]

Process called "create_plugin_marketplace" returns PluginMarketplace:
    Return PluginMarketplace with:
        search_plugins as function(query):
            Return search_marketplace_plugins(query)
        install_plugin as function(plugin_id):
            Return install_plugin_from_marketplace(plugin_id)
        update_plugin as function(plugin_id):
            Return update_plugin_from_marketplace(plugin_id)
        uninstall_plugin as function(plugin_id):
            Return remove_plugin_from_system(plugin_id)
        metadata as dictionary containing

Process called "search_marketplace_plugins" that takes query as String returns List[PluginInfo]:
    Note: Production implementation would query actual marketplace API
    Let results be list containing
    Return results

Process called "install_plugin_from_marketplace" that takes plugin_id as String returns Boolean:
    Try:
        Let plugin_info be fetch_plugin_info(plugin_id)
        Let plugin_package be download_plugin_package(plugin_id)
        Let plugin be extract_and_load_plugin(plugin_package)
        register_plugin(plugin)
        Return true
    Catch error:
        Log error message "Failed to install plugin " plus plugin_id plus ": " plus error.message
        Return false

Process called "update_plugin_from_marketplace" that takes plugin_id as String returns Boolean:
    Try:
        Let current_plugin be get_plugin(plugin_id)
        If current_plugin is None:
            Return false
        Let latest_info be fetch_latest_plugin_info(plugin_id)
        If is_newer_version(latest_info.version, current_plugin.version):
            Return install_plugin_from_marketplace(plugin_id)
        Return true
    Catch error:
        Log error message "Failed to update plugin " plus plugin_id plus ": " plus error.message
        Return false

Process called "remove_plugin_from_system" that takes plugin_id as String returns Boolean:
    Return unregister_plugin(plugin_id)

Process called "fetch_plugin_info" that takes plugin_id as String returns PluginInfo:
    Note: Production implementation would fetch from marketplace API
    Return PluginInfo with:
        plugin_id as plugin_id
        name as "Example Plugin"
        description as "Example plugin description"
        version as "1.0.0"
        author as "Example Author"
        rating as 4.5
        download_count as 1000
        tags as list containing "example", "demo"
        metadata as dictionary containing

Process called "download_plugin_package" that takes plugin_id as String returns PluginPackage:
    Note: Production implementation would download from marketplace
    Return create_mock_plugin_package(plugin_id)

Process called "extract_and_load_plugin" that takes package as PluginPackage returns Plugin:
    Let plugin_path be extract_plugin_package_to_temp(package)
    Return load_plugin_from_file(create_plugin_loader(), plugin_path)

Process called "fetch_latest_plugin_info" that takes plugin_id as String returns PluginInfo:
    Return fetch_plugin_info(plugin_id)

Process called "is_newer_version" that takes version1 as String and version2 as String returns Boolean:
    Let v1_parts be split_string with string as version1 and delimiter as "."
    Let v2_parts be split_string with string as version2 and delimiter as "."
    If length of v1_parts is not equal to 3 or length of v2_parts is not equal to 3:
        Return false
    
    Let v1_major be parse_integer(v1_parts[0])
    Let v1_minor be parse_integer(v1_parts[1])
    Let v1_patch be parse_integer(v1_parts[2])
    
    Let v2_major be parse_integer(v2_parts[0])
    Let v2_minor be parse_integer(v2_parts[1])
    Let v2_patch be parse_integer(v2_parts[2])
    
    If v1_major is greater than v2_major:
        Return true
    If v1_major is equal to v2_major and v1_minor is greater than v2_minor:
        Return true
    If v1_major is equal to v2_major and v1_minor is equal to v2_minor and v1_patch is greater than v2_patch:
        Return true
    
    Return false

Note: Exception Types for Architecture
Type DependencyResolutionError is Exception with:
    message as String
    metadata as Dictionary[String, Any]

Type ExtensionRegistrationError is Exception with:
    message as String
    metadata as Dictionary[String, Any]

Note: Additional Helper Types
Type called "JSONSchema":
    schema_type as String
    properties as Dictionary[String, Any]
    required as List[String]
    metadata as Dictionary[String, Any]

Type called "PluginPackage":
    package_id as String
    content as String
    checksum as String
    metadata as Dictionary[String, Any]

Process called "create_mock_plugin_package" that takes plugin_id as String returns PluginPackage:
    Return PluginPackage with:
        package_id as plugin_id
        content as "mock package content"
        checksum as "mock_checksum_" plus plugin_id
        metadata as dictionary containing

Process called "extract_plugin_package_to_temp" that takes package as PluginPackage returns String:
    Let temp_path be "/tmp/plugins/" plus package.package_id
    create_directory(temp_path)
    Return temp_path 