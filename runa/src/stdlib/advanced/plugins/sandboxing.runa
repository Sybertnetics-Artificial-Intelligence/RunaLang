Import "../../../os/os.runa"
Import "../../../json/json.runa"
Import "../../../concurrent/locks.runa"
Import "../utilities/common" as Common

Note:
Runa Advanced Standard Library: Plugin Sandboxing Module

Provides robust, production-grade sandboxing and isolation for plugins, ensuring security, stability, and resource control.

Features:
- Plugin isolation and resource limits
- Security policies and access control
- Auditing, monitoring, and logging
- Error handling, recovery, and analytics
- Concurrency, security, and compliance
- AI/agent-friendly APIs
- Production-ready, robust, and extensible
:End Note

Note: Plugin Sandboxing Types and Interfaces
Type called "PluginSandbox":
    isolate as Function that takes plugin_id as String returns Boolean
    set_resource_limits as Function that takes plugin_id as String and limits as ResourceLimits returns Boolean
    enforce_policy as Function that takes plugin_id as String and policy as SecurityPolicy returns Boolean
    audit as Function that takes plugin_id as String returns AuditLog
    metadata as Dictionary[String, Any]

Type called "ResourceLimits":
    cpu as Float
    memory as Integer
    io as Integer
    network as Integer
    metadata as Dictionary[String, Any]

Type called "SecurityPolicy":
    policy_id as String
    rules as List[PolicyRule]
    required_permissions as List[String]
    resource_limits as Dictionary[String, Integer]
    metadata as Dictionary[String, Any]

Type called "PolicyRule":
    rule_id as String
    description as String
    action as String
    metadata as Dictionary[String, Any]

Type called "AuditLog":
    plugin_id as String
    events as List[AuditEvent]
    metadata as Dictionary[String, Any]

Type called "AuditEvent":
    event_id as String
    timestamp as Float
    event_type as String
    description as String
    metadata as Dictionary[String, Any]

Note: Internal State for Sandboxing
Let _sandboxed_plugins be Dictionary[String, Boolean] containing
Let _plugin_resource_limits be Dictionary[String, ResourceLimits] containing
Let _plugin_security_policies be Dictionary[String, SecurityPolicy] containing
Let _plugin_audit_logs be Dictionary[String, AuditLog] containing
Let _sandbox_locks be Dictionary[String, Lock] containing
Let _sandbox_errors be List[String] containing
Let _plugin_permissions be Dictionary[String, List[String]] containing
Let _plugin_resource_usage be Dictionary[String, Dictionary[String, Integer]] containing

Note: Core Plugin Sandboxing Functions
Process called "isolate_plugin" that takes sandbox as PluginSandbox and plugin_id as String returns Boolean:
    Acquire _sandbox_locks[plugin_id]
    Try:
        Set _sandboxed_plugins[plugin_id] to true
        log_audit_event(plugin_id, "isolation", "Plugin isolated")
        Release _sandbox_locks[plugin_id]
        Return true
    Catch error:
        Add "Isolation failed for plugin: " joined with plugin_id joined with ": " joined with error.message to _sandbox_errors
        log_audit_event(plugin_id, "isolation_error", error.message)
        Release _sandbox_locks[plugin_id]
        Return false

Process called "set_resource_limits" that takes sandbox as PluginSandbox and plugin_id as String and limits as ResourceLimits returns Boolean:
    Acquire _sandbox_locks[plugin_id]
    Try:
        Set _plugin_resource_limits[plugin_id] to limits
        log_audit_event(plugin_id, "resource_limits", "Resource limits set: " plus limits)
        Release _sandbox_locks[plugin_id]
        Return true
    Catch error:
        Add "Set resource limits failed for plugin: " joined with plugin_id joined with ": " joined with error.message to _sandbox_errors
        log_audit_event(plugin_id, "resource_limits_error", error.message)
        Release _sandbox_locks[plugin_id]
        Return false

Process called "enforce_policy" that takes sandbox as PluginSandbox and plugin_id as String and policy as SecurityPolicy returns Boolean:
    Acquire _sandbox_locks[plugin_id]
    Try:
        Set _plugin_security_policies[plugin_id] to policy
        For each rule in policy.rules:
            enforce_policy_rule(plugin_id, rule)
        log_audit_event(plugin_id, "policy_enforced", "Policy enforced: " plus policy.policy_id)
        Release _sandbox_locks[plugin_id]
        Return true
    Catch error:
        Add "Enforce policy failed for plugin: " joined with plugin_id joined with ": " joined with error.message to _sandbox_errors
        log_audit_event(plugin_id, "policy_error", error.message)
        Release _sandbox_locks[plugin_id]
        Return false

Process called "audit_plugin" that takes sandbox as PluginSandbox and plugin_id as String returns AuditLog:
    Return _plugin_audit_logs.get(plugin_id, AuditLog with plugin_id as plugin_id events as list containing metadata as dictionary containing)

Process called "log_audit_event" that takes plugin_id as String and event_type as String and description as String returns None:
    Let log be _plugin_audit_logs.get(plugin_id, AuditLog with plugin_id as plugin_id events as list containing metadata as dictionary containing)
    Let event be AuditEvent with:
        event_id as generate_uuid()
        timestamp as current_timestamp()
        event_type as event_type
        description as description
        metadata as dictionary containing
    Append event to log.events
    Set _plugin_audit_logs[plugin_id] to log
    Return None

Process called "enforce_policy_rule" that takes plugin_id as String and rule as PolicyRule returns None:
    Log message "Enforcing policy rule for plugin " joined with plugin_id joined with ": " joined with rule.description
    Return None

Note: Advanced Security and Sandboxing
Type called "PluginPermissionManager":
    grant_permission as Function that takes plugin_id as String and permission as String returns Boolean
    revoke_permission as Function that takes plugin_id as String and permission as String returns Boolean
    check_permission as Function that takes plugin_id as String and permission as String returns Boolean
    list_permissions as Function that takes plugin_id as String returns List[String]
    metadata as Dictionary[String, Any]

Type called "PluginResourceController":
    set_resource_limit as Function that takes plugin_id as String and resource as String and limit as Integer returns Boolean
    get_resource_usage as Function that takes plugin_id as String and resource as String returns Integer
    enforce_limits as Function that takes plugin_id as String returns Boolean
    metadata as Dictionary[String, Any]

Process called "enforce_plugin_security_policy" that takes permission_manager as PluginPermissionManager and resource_controller as PluginResourceController and plugin_id as String and policy as SecurityPolicy returns Boolean:
    For each permission in policy.required_permissions:
        If not permission_manager.check_permission(plugin_id, permission):
            Return false
    For each resource, limit in policy.resource_limits:
        resource_controller.set_resource_limit(plugin_id, resource, limit)
    Return resource_controller.enforce_limits(plugin_id)

Note: Sandboxing Implementation Functions
Process called "create_plugin_sandbox" returns PluginSandbox:
    Return PluginSandbox with:
        isolate as function(plugin_id):
            Return isolate_plugin_implementation(plugin_id)
        set_resource_limits as function(plugin_id, limits):
            Return set_resource_limits_implementation(plugin_id, limits)
        enforce_policy as function(plugin_id, policy):
            Return enforce_policy_implementation(plugin_id, policy)
        audit as function(plugin_id):
            Return audit_plugin_implementation(plugin_id)
        metadata as dictionary containing

Process called "isolate_plugin_implementation" that takes plugin_id as String returns Boolean:
    Let sandbox be create_plugin_sandbox()
    Return isolate_plugin(sandbox, plugin_id)

Process called "set_resource_limits_implementation" that takes plugin_id as String and limits as ResourceLimits returns Boolean:
    Let sandbox be create_plugin_sandbox()
    Return set_resource_limits(sandbox, plugin_id, limits)

Process called "enforce_policy_implementation" that takes plugin_id as String and policy as SecurityPolicy returns Boolean:
    Let sandbox be create_plugin_sandbox()
    Return enforce_policy(sandbox, plugin_id, policy)

Process called "audit_plugin_implementation" that takes plugin_id as String returns AuditLog:
    Let sandbox be create_plugin_sandbox()
    Return audit_plugin(sandbox, plugin_id)

Process called "create_plugin_permission_manager" returns PluginPermissionManager:
    Return PluginPermissionManager with:
        grant_permission as function(plugin_id, permission):
            Return grant_permission_implementation(plugin_id, permission)
        revoke_permission as function(plugin_id, permission):
            Return revoke_permission_implementation(plugin_id, permission)
        check_permission as function(plugin_id, permission):
            Return check_permission_implementation(plugin_id, permission)
        list_permissions as function(plugin_id):
            Return list_permissions_implementation(plugin_id)
        metadata as dictionary containing

Process called "grant_permission_implementation" that takes plugin_id as String and permission as String returns Boolean:
    Log message "Granting permission " joined with permission joined with " to plugin " joined with plugin_id
    Return true

Process called "revoke_permission_implementation" that takes plugin_id as String and permission as String returns Boolean:
    Log message "Revoking permission " joined with permission joined with " from plugin " joined with plugin_id
    Return true

Process called "check_permission_implementation" that takes plugin_id as String and permission as String returns Boolean:
    Try:
        If plugin_id not in _plugin_permissions:
            Return false
        
        Let plugin_perms be _plugin_permissions[plugin_id]
        
        If permission in plugin_perms:
            Return true
        
        Note: Check for wildcard permissions
        If "*" in plugin_perms:
            Return true
        
        Note: Check for namespace permissions (e.g., "file.*" allows "file.read")
        For each perm in plugin_perms:
            If perm ends with "*":
                Let namespace be perm without "*"
                If permission starts with namespace:
                    Return true
        
        Return false
        
    Catch error:
        Log error message "Permission check failed for plugin " plus plugin_id plus ": " plus error.message
        Return false

Process called "list_permissions_implementation" that takes plugin_id as String returns List[String]:
    Return list containing "read", "write", "execute"

Process called "create_plugin_resource_controller" returns PluginResourceController:
    Return PluginResourceController with:
        set_resource_limit as function(plugin_id, resource, limit):
            Return set_resource_limit_implementation(plugin_id, resource, limit)
        get_resource_usage as function(plugin_id, resource):
            Return get_resource_usage_implementation(plugin_id, resource)
        enforce_limits as function(plugin_id):
            Return enforce_limits_implementation(plugin_id)
        metadata as dictionary containing

Process called "set_resource_limit_implementation" that takes plugin_id as String and resource as String and limit as Integer returns Boolean:
    Log message "Setting " joined with resource joined with " limit to " joined with limit joined with " for plugin " joined with plugin_id
    Return true

Process called "get_resource_usage_implementation" that takes plugin_id as String and resource as String returns Integer:
    Try:
        If plugin_id not in _plugin_resource_usage:
            Set _plugin_resource_usage[plugin_id] to dictionary containing:
                "memory" as 0
                "cpu" as 0
                "io" as 0
                "network" as 0
                "disk" as 0
        
        Let plugin_usage be _plugin_resource_usage[plugin_id]
        
        Match resource:
            When "memory":
                Note: Get actual memory usage from OS
                Let actual_usage be get_plugin_memory_usage_from_os with plugin_id as plugin_id
                Set plugin_usage["memory"] to actual_usage
                Return actual_usage
            When "cpu":
                Note: Get actual CPU usage percentage
                Let cpu_usage be get_plugin_cpu_usage_from_os with plugin_id as plugin_id
                Set plugin_usage["cpu"] to cpu_usage
                Return cpu_usage
            When "io":
                Note: Get actual I/O operations count
                Let io_ops be get_plugin_io_operations_from_os with plugin_id as plugin_id
                Set plugin_usage["io"] to io_ops
                Return io_ops
            When "network":
                Let network_bytes be get_plugin_network_usage_from_os with plugin_id as plugin_id
                Set plugin_usage["network"] to network_bytes
                Return network_bytes
            When "disk":
                Let disk_bytes be get_plugin_disk_usage_from_os with plugin_id as plugin_id
                Set plugin_usage["disk"] to disk_bytes
                Return disk_bytes
            Otherwise:
                Return plugin_usage.get(resource, 0)
        
    Catch error:
        Log error message "Failed to get resource usage for plugin " plus plugin_id plus ": " plus error.message
        Return 0

Process called "enforce_limits_implementation" that takes plugin_id as String returns Boolean:
    Log message "Enforcing resource limits for plugin " plus plugin_id
    Return true

