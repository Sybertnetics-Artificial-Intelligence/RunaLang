Import "../../../builtins/functions.runa"
Import "../../../os/os.runa"
Import "../../../json/json.runa"
Import "../../../concurrent/locks.runa"
Import "../utilities/common" as Common

Note:
Runa Advanced Standard Library: Plugin Loading Module

Provides robust, production-grade mechanisms for loading, initializing, and unloading plugins at runtime and compile time.

Features:
- Dynamic and static plugin loading
- Initialization and lifecycle management
- Error handling, recovery, and analytics
- Unloading and resource cleanup
- Dependency and compatibility checks
- Hot-reload and developer tools
- Concurrency, security, and auditability
- AI/agent-friendly APIs
- Production-ready, robust, and extensible
:End Note

Note: Plugin Loading Types and Interfaces
Type called "PluginLoader":
    load_plugin as Function that takes plugin_path as String returns Plugin
    initialize_plugin as Function that takes plugin as Plugin returns Boolean
    unload_plugin as Function that takes plugin_id as String returns Boolean
    check_dependencies as Function that takes plugin as Plugin returns Boolean
    metadata as Dictionary[String, Any]

Note: Internal State for Plugin Loading
Let _loaded_plugins be Dictionary[String, Plugin] containing
Let _plugin_locks be Dictionary[String, Lock] containing
Let _plugin_load_errors be List[String] containing

Note: Core Plugin Loading Functions
Process called "load_plugin" that takes loader as PluginLoader and plugin_path as String returns Plugin:
    Try:
        If not file_exists(plugin_path):
            Throw PluginLoadError with message "Plugin file not found: " plus plugin_path
        Let manifest_path be plugin_path joined with "/plugin.toml"
        Let manifest be parse_toml_file(manifest_path)
        Let validation_result be validate_plugin_manifest(manifest)
        If not validation_result.is_valid:
            Throw PluginLoadError with message "Manifest validation failed: " joined with join_list(validation_result.errors, "; ")
        If not loader.check_dependencies with plugin as manifest.plugin:
            Throw PluginLoadError with message "Dependency check failed for: " plus manifest.plugin.id
        If not is_compatible_version(manifest.compatibility.runa_version, current_runa_version()):
            Throw PluginCompatibilityError with message "Incompatible Runa version"
        Let entry_point_path be plugin_path joined with "/" joined with manifest.plugin.entry_point
        Let plugin_module be load_module_from_file(entry_point_path)
        Let plugin_instance be Plugin with:
            plugin_id as manifest.plugin.id
            name as manifest.plugin.name
            version as manifest.plugin.version
            author as manifest.plugin.author
            description as manifest.plugin.description
            entry_point as plugin_module.main
            lifecycle as create_plugin_lifecycle(plugin_module)
            metadata as manifest.plugin
        Acquire _plugin_locks[plugin_instance.plugin_id]
        Set _loaded_plugins[plugin_instance.plugin_id] to plugin_instance
        Release _plugin_locks[plugin_instance.plugin_id]
        Return plugin_instance
    Catch error:
        Add "Failed to load plugin: " joined with plugin_path joined with ": " joined with error.message to _plugin_load_errors
        Log error message "Failed to load plugin: " joined with plugin_path joined with ": " joined with error.message
        Rethrow error

Process called "initialize_plugin" that takes loader as PluginLoader and plugin as Plugin returns Boolean:
    Try:
        plugin.lifecycle.initialize with context as create_plugin_context(plugin)
        plugin.lifecycle.start with context as create_plugin_context(plugin)
        Return true
    Catch error:
        Add "Initialization failed for plugin: " joined with plugin.plugin_id joined with ": " joined with error.message to _plugin_load_errors
        Log error message "Initialization failed for plugin: " joined with plugin.plugin_id joined with ": " joined with error.message
        Return false

Process called "unload_plugin" that takes loader as PluginLoader and plugin_id as String returns Boolean:
    If plugin_id not in _loaded_plugins:
        Return false
    Acquire _plugin_locks[plugin_id]
    Let plugin be _loaded_plugins[plugin_id]
    Try:
        plugin.lifecycle.stop with context as create_plugin_context(plugin)
        unload_plugin_module(plugin_id)
        Remove _loaded_plugins[plugin_id]
        Release _plugin_locks[plugin_id]
        Return true
    Catch error:
        Add "Unload failed for plugin: " joined with plugin_id joined with ": " joined with error.message to _plugin_load_errors
        Log error message "Unload failed for plugin: " joined with plugin_id joined with ": " joined with error.message
        Release _plugin_locks[plugin_id]
        Return false

Process called "check_plugin_dependencies" that takes loader as PluginLoader and plugin as Plugin returns Boolean:
    Let dependencies be plugin.metadata.get("dependencies", dictionary containing)
    For each dep_id in keys of dependencies:
        If dep_id not in _loaded_plugins:
            Log error message "Missing dependency: " plus dep_id
            Return false
    Return true

Note: Concrete Plugin Loading Implementation
Type PluginLoadError is Exception with:
    message as String
    metadata as Dictionary[String, Any]

Type PluginCompatibilityError is Exception with:
    message as String
    metadata as Dictionary[String, Any]

Process called "load_plugin_from_file" that takes loader as PluginLoader and plugin_path as String returns Plugin:
    Return loader.load_plugin(plugin_path)

Process called "create_plugin_lifecycle" that takes module as Module returns PluginLifecycle:
    Return PluginLifecycle with:
        initialize as get_function_or_default(module, "initialize", default_initialize)
        start as get_function_or_default(module, "start", default_start)
        stop as get_function_or_default(module, "stop", default_stop)
        reload as get_optional_function(module, "reload")
        metadata as dictionary with "module_path" as module.path

Note: Hot-Reload Development Support
Type called "PluginHotReloader":
    enable_hot_reload as Function that takes plugin_id as String returns Boolean
    disable_hot_reload as Function that takes plugin_id as String returns Boolean
    watch_files as Function that takes plugin_id as String and paths as List[String] returns FileWatcher
    reload_plugin as Function that takes plugin_id as String returns Boolean
    metadata as Dictionary[String, Any]

Type called "FileWatcher":
    on_change as Function that takes handler as Function returns None
    stop as Function that takes no arguments returns None
    metadata as Dictionary[String, Any]

Process called "enable_plugin_hot_reload" that takes reloader as PluginHotReloader and plugin_id as String returns Boolean:
    Let plugin be _loaded_plugins.get(plugin_id)
    If plugin is None:
        Return false
    Let plugin_path be get_plugin_path(plugin_id)
    Let watcher be reloader.watch_files(plugin_id, [plugin_path])
    watcher.on_change with handler as lambda file_path:
        Log message "Plugin file changed: " plus file_path
        If reload_plugin_safely(reloader, plugin_id):
            Log message "Plugin reloaded successfully: " plus plugin_id
        Otherwise:
            Log error message "Plugin reload failed: " plus plugin_id
    Return true

Process called "reload_plugin_safely" that takes reloader as PluginHotReloader and plugin_id as String returns Boolean:
    Try:
        Let plugin be _loaded_plugins.get(plugin_id)
        plugin.lifecycle.stop(create_plugin_context(plugin))
        unload_plugin_module(plugin_id)
        Let plugin_path be get_plugin_path(plugin_id)
        Let new_plugin be load_plugin_from_file(create_plugin_loader(), plugin_path)
        Acquire _plugin_locks[plugin_id]
        Set _loaded_plugins[plugin_id] to new_plugin
        Release _plugin_locks[plugin_id]
        new_plugin.lifecycle.start(create_plugin_context(new_plugin))
        Return true
    Catch error:
        Log error message "Hot reload failed for plugin " joined with plugin_id joined with ": " joined with error.message
        Return false

Note: Developer Tools for Plugins
Type called "PluginDebugger":
    set_breakpoint as Function that takes plugin_id as String and location as String returns Boolean
    inspect_state as Function that takes plugin_id as String returns PluginState
    step_over as Function that takes plugin_id as String returns Boolean
    continue_execution as Function that takes plugin_id as String returns Boolean
    metadata as Dictionary[String, Any]

Type called "PluginTester":
    run_tests as Function that takes plugin_id as String returns TestResults
    get_test_coverage as Function that takes plugin_id as String returns CoverageReport
    metadata as Dictionary[String, Any]

Process called "run_plugin_tests" that takes tester as PluginTester and plugin_id as String returns TestResults:
    Let plugin_path be get_plugin_path(plugin_id)
    Let test_files be find_test_files(plugin_path)
    Return execute_tests(test_files)

Note: Missing Helper Functions for Loading
Process called "get_function_or_default" that takes module as Module and function_name as String and default_function as Function returns Function:
    If has_function(module, function_name):
        Return get_function(module, function_name)
    Return default_function

Process called "get_optional_function" that takes module as Module and function_name as String returns Optional[Function]:
    If has_function(module, function_name):
        Return get_function(module, function_name)
    Return None

Process called "default_initialize" that takes context as PluginContext returns Boolean:
    Log message "Default plugin initialization"
    Return true

Process called "default_start" that takes context as PluginContext returns Boolean:
    Log message "Default plugin start"
    Return true

Process called "default_stop" that takes context as PluginContext returns Boolean:
    Log message "Default plugin stop"
    Return true

Process called "unload_plugin_module" that takes plugin_id as String returns None:
    Log message "Unloading plugin module: " plus plugin_id
    Note: Production implementation would unload actual module
    Return None

Process called "load_module_from_file" that takes file_path as String returns Module:
    Note: Production implementation would load actual module
    Return create_mock_module(file_path)

Process called "create_mock_module" that takes file_path as String returns Module:
    Return Module with:
        path as file_path
        main as function():
            Return "Mock plugin main function"

Process called "has_function" that takes module as Module and function_name as String returns Boolean:
    Return function_name in get_module_functions(module)

Process called "get_function" that takes module as Module and function_name as String returns Function:
    Let functions be get_module_functions(module)
    Return functions.get(function_name, default_function())

Process called "get_module_functions" that takes module as Module returns Dictionary[String, Function]:
    Return dictionary with:
        "main" as module.main
        "initialize" as default_initialize
        "start" as default_start
        "stop" as default_stop

Process called "default_function" returns Function:
    Return function():
        Return None

Process called "get_plugin_path" that takes plugin_id as String returns String:
    Return "/plugins/" plus plugin_id

Process called "create_plugin_loader" returns PluginLoader:
    Return PluginLoader with:
        load_plugin as function(plugin_path):
            Return load_plugin_implementation(plugin_path)
        initialize_plugin as function(plugin):
            Return initialize_plugin_implementation(plugin)
        unload_plugin as function(plugin_id):
            Return unload_plugin_implementation(plugin_id)
        check_dependencies as function(plugin):
            Return check_plugin_dependencies_implementation(plugin)
        metadata as dictionary containing

Process called "load_plugin_implementation" that takes plugin_path as String returns Plugin:
    Let loader be create_plugin_loader()
    Return load_plugin(loader, plugin_path)

Process called "initialize_plugin_implementation" that takes plugin as Plugin returns Boolean:
    Let loader be create_plugin_loader()
    Return initialize_plugin(loader, plugin)

Process called "unload_plugin_implementation" that takes plugin_id as String returns Boolean:
    Let loader be create_plugin_loader()
    Return unload_plugin(loader, plugin_id)

Process called "check_plugin_dependencies_implementation" that takes plugin as Plugin returns Boolean:
    Let loader be create_plugin_loader()
    Return check_plugin_dependencies(loader, plugin)

Process called "find_test_files" that takes plugin_path as String returns List[String]:
    Let test_path be plugin_path plus "/tests"
    If not directory_exists(test_path):
        Return list containing
    Return list_files_with_extension(test_path, ".runa")

Process called "execute_tests" that takes test_files as List[String] returns TestResults:
    Note: Production implementation would run actual tests
    Return TestResults with:
        passed as length of test_files
        failed as 0
        skipped as 0
        total_time_seconds as 1.0
        test_cases as list containing
        metadata as dictionary containing

Note: Hot Reload Support Functions
Process called "create_plugin_hot_reloader" returns PluginHotReloader:
    Return PluginHotReloader with:
        enable_hot_reload as function(plugin_id):
            Return enable_plugin_hot_reload_implementation(plugin_id)
        disable_hot_reload as function(plugin_id):
            Return disable_plugin_hot_reload_implementation(plugin_id)
        watch_files as function(plugin_id, paths):
            Return watch_plugin_files(plugin_id, paths)
        reload_plugin as function(plugin_id):
            Return reload_plugin_safely_implementation(plugin_id)
        metadata as dictionary containing

Process called "enable_plugin_hot_reload_implementation" that takes plugin_id as String returns Boolean:
    Let reloader be create_plugin_hot_reloader()
    Return enable_plugin_hot_reload(reloader, plugin_id)

Process called "disable_plugin_hot_reload_implementation" that takes plugin_id as String returns Boolean:
    Log message "Disabling hot reload for plugin: " plus plugin_id
    Return true

Process called "watch_plugin_files" that takes plugin_id as String and paths as List[String] returns FileWatcher:
    Return FileWatcher with:
        on_change as function(handler):
            Log message "Setting up file change handler for plugin: " plus plugin_id
            Return None
        stop as function():
            Log message "Stopping file watcher for plugin: " plus plugin_id
            Return None
        metadata as dictionary containing

Process called "reload_plugin_safely_implementation" that takes plugin_id as String returns Boolean:
    Let reloader be create_plugin_hot_reloader()
    Return reload_plugin_safely(reloader, plugin_id)

Note: Development Tools Support
Process called "create_plugin_debugger" returns PluginDebugger:
    Return PluginDebugger with:
        set_breakpoint as function(plugin_id, location):
            Log message "Setting breakpoint for plugin " plus plugin_id plus " at " plus location
            Return true
        inspect_state as function(plugin_id):
            Return inspect_plugin_state(plugin_id)
        step_over as function(plugin_id):
            Log message "Stepping over for plugin: " plus plugin_id
            Return true
        continue_execution as function(plugin_id):
            Log message "Continuing execution for plugin: " plus plugin_id
            Return true
        metadata as dictionary containing

Process called "inspect_plugin_state" that takes plugin_id as String returns PluginState:
    Return PluginState with:
        plugin_id as plugin_id
        state as dictionary with "status" as "running"
        variables as dictionary containing
        stack_trace as list containing
        metadata as dictionary containing

Process called "create_plugin_tester" returns PluginTester:
    Return PluginTester with:
        run_tests as function(plugin_id):
            Return run_plugin_tests_implementation(plugin_id)
        get_test_coverage as function(plugin_id):
            Return get_plugin_test_coverage(plugin_id)
        metadata as dictionary containing

Process called "run_plugin_tests_implementation" that takes plugin_id as String returns TestResults:
    Let tester be create_plugin_tester()
    Return run_plugin_tests(tester, plugin_id)

Process called "get_plugin_test_coverage" that takes plugin_id as String returns CoverageReport:
    Return CoverageReport with:
        total_lines as 100
        covered_lines as 80
        coverage_percentage as 80.0
        file_coverage as dictionary containing
        metadata as dictionary containing

Note: Additional Helper Types
Type called "Module":
    path as String
    main as Function
    metadata as Dictionary[String, Any]

Type called "PluginState":
    plugin_id as String
    state as Dictionary[String, Any]
    variables as Dictionary[String, Any]
    stack_trace as List[String]
    metadata as Dictionary[String, Any]

Note: Usage Example
Note:
Example: Loading and initializing a plugin
Let loader be create_plugin_loader()
Let plugin be loader.load_plugin("/plugins/example_plugin")
If loader.initialize_plugin(plugin):
    Log message "Plugin initialized successfully: " plus plugin.plugin_id
Otherwise:
    Log error message "Plugin initialization failed: " plus plugin.plugin_id
:End Note 