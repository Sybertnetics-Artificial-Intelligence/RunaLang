Import "../../../builtins/functions.runa"
Import "../../../os/os.runa"
Import "../../../json/json.runa"
Import "../utilities/common" as Common

Note:
Runa Advanced Standard Library: Plugin Discovery Module

Provides mechanisms for discovering, scanning, and validating plugins at runtime and compile time.

Features:
- Plugin scanning and enumeration
- Metadata extraction and validation
- Compatibility and version checks
- Dynamic and static discovery
- Error handling and debugging
- AI/agent-friendly APIs
- Production-ready, robust, and extensible
:End Note

Note: Plugin Discovery Types and Interfaces
Type called "PluginDiscovery":
    scan_plugins as Function that takes path as String returns List[Plugin]
    extract_metadata as Function that takes plugin_path as String returns PluginMetadata
    check_compatibility as Function that takes plugin as Plugin returns Boolean
    dynamic_discovery as Boolean
    metadata as Dictionary[String, Any]

Type called "PluginMetadata":
    plugin_id as String
    name as String
    version as String
    author as String
    description as String
    entry_point as String
    compatible_versions as List[String]
    metadata as Dictionary[String, Any]

Note: Internal State for Discovery
Let _discovered_plugins be Dictionary[String, PluginMetadata] containing
Let _discovery_errors be List[String] containing

Note: Core Plugin Discovery Functions
Process called "scan_plugins" that takes discovery as PluginDiscovery and path as String returns List[Plugin]:
    Let plugin_files be list_plugin_files(path)
    Let plugins be list containing
    For each file in plugin_files:
        Try:
            Let metadata be discovery.extract_metadata with plugin_path as file
            If metadata.plugin_id in _discovered_plugins:
                Add "Duplicate plugin ID: " plus metadata.plugin_id to _discovery_errors
                Continue
            Set _discovered_plugins[metadata.plugin_id] to metadata
            If discovery.check_compatibility with plugin as metadata:
                Let plugin be load_plugin_from_metadata(metadata)
                Append plugin to plugins
            Else:
                Add "Incompatible plugin: " plus metadata.plugin_id to _discovery_errors
        Catch error:
            Add "Error loading plugin from " plus file plus ": " plus error.message to _discovery_errors
    Return plugins

Process called "extract_plugin_metadata" that takes discovery as PluginDiscovery and plugin_path as String returns PluginMetadata:
    Let manifest_path be plugin_path plus "/plugin.toml"
    Let manifest be parse_toml_file with path as manifest_path
    If not manifest:
        Throw PluginDiscoveryError with message "Missing or invalid manifest at " plus manifest_path
    Return PluginMetadata with:
        plugin_id as manifest.plugin.id
        name as manifest.plugin.name
        version as manifest.plugin.version
        author as manifest.plugin.author
        description as manifest.plugin.description
        entry_point as manifest.plugin.entry_point
        compatible_versions as manifest.compatibility.platform
        metadata as manifest.plugin

Process called "check_plugin_compatibility" that takes discovery as PluginDiscovery and plugin as Plugin returns Boolean:
    If not is_valid_semver(plugin.version):
        Return false
    If not is_compatible_runa_version(plugin.compatible_versions):
        Return false
    Return true

Note: Plugin Manifest Structure (plugin.toml format)
Type called "PluginManifest":
    plugin as PluginInfo
    compatibility as CompatibilityInfo
    dependencies as Dictionary[String, String]
    capabilities as CapabilityInfo
    configuration as ConfigurationInfo
    build as BuildInfo

Type called "PluginInfo":
    id as String
    name as String
    version as String
    author as String
    description as String
    license as String
    repository as Optional[String]
    homepage as Optional[String]
    entry_point as String

Type called "CompatibilityInfo":
    runa_version as String
    platform as List[String]
    architecture as List[String]

Type called "CapabilityInfo":
    requires as List[String]
    provides as List[String]

Type called "ConfigurationInfo":
    default_config as Optional[String]
    schema as Optional[String]

Type called "BuildInfo":
    build_script as Optional[String]
    assets as List[String]
    exclude as List[String]

Type called "ValidationResult":
    is_valid as Boolean
    errors as List[String]

Process called "parse_toml_file" that takes path as String returns PluginManifest:
    Try:
        Let toml_data be read_toml(path)
        Return map_toml_to_manifest(toml_data)
    Catch error:
        Throw PluginDiscoveryError with message "Failed to parse TOML: " plus error.message

Process called "validate_plugin_manifest" that takes manifest as PluginManifest returns ValidationResult:
    Let errors be list containing
    If manifest.plugin.id is empty:
        Add "Plugin ID is required" to errors
    If not is_valid_semver(manifest.plugin.version):
        Add "Invalid semantic version format" to errors
    If not is_compatible_runa_version(manifest.compatibility.runa_version):
        Add "Incompatible Runa version requirement" to errors
    For each dependency_name and version_spec in manifest.dependencies:
        If not is_valid_version_spec(version_spec):
            Add "Invalid version specification for dependency: " plus dependency_name to errors
    For each capability in manifest.capabilities.requires:
        If not is_known_capability(capability):
            Add "Unknown capability required: " plus capability to errors
    Return ValidationResult with:
        is_valid as (length of errors is equal to 0)
        errors as errors

Note: Additional Discovery Functions  
Process called "list_plugin_files" that takes path as String returns List[String]:
    Let plugin_files be list containing
    Let directories be list_directories(path)
    For each directory in directories:
        Let manifest_path be directory plus "/plugin.toml"
        If file_exists(manifest_path):
            Append directory to plugin_files
    Return plugin_files

Process called "load_plugin_from_metadata" that takes metadata as PluginMetadata returns Plugin:
    Return Plugin with:
        plugin_id as metadata.plugin_id
        name as metadata.name
        version as metadata.version
        author as metadata.author
        description as metadata.description
        entry_point as create_dummy_entry_point()
        lifecycle as create_default_lifecycle()
        metadata as dictionary with "metadata" as metadata

Process called "is_valid_semver" that takes version as String returns Boolean:
    Let parts be split_string with string as version and delimiter as "."
    If length of parts is not equal to 3:
        Return false
    For each part in parts:
        If not is_valid_integer(part):
            Return false
        If parse_integer(part) is less than 0:
            Return false
    Return true

Process called "is_compatible_runa_version" that takes version_spec as String returns Boolean:
    Let current_version be current_runa_version()
    Return is_version_compatible(current_version, version_spec)

Process called "is_valid_version_spec" that takes version_spec as String returns Boolean:
    If version_spec contains ">=":
        Let version be split_string with string as version_spec and delimiter as ">="[1]
        Return is_valid_semver(version)
    If version_spec contains "<=":
        Let version be split_string with string as version_spec and delimiter as "<="[1]
        Return is_valid_semver(version)
    If version_spec contains "=":
        Let version be split_string with string as version_spec and delimiter as "="[1]
        Return is_valid_semver(version)
    Return is_valid_semver(version_spec)

Process called "is_known_capability" that takes capability as String returns Boolean:
    Let known_capabilities be list containing "ui.commands", "editor.languages", "debug.adapters", "file.watchers", "network.protocols"
    Return capability in known_capabilities

Process called "map_toml_to_manifest" that takes toml_data as Dictionary[String, Any] returns PluginManifest:
    Return PluginManifest with:
        plugin as PluginInfo with:
            id as toml_data["plugin"]["id"]
            name as toml_data["plugin"]["name"]
            version as toml_data["plugin"]["version"]
            author as toml_data["plugin"]["author"]
            description as toml_data["plugin"]["description"]
            license as toml_data["plugin"].get("license", "MIT")
            repository as toml_data["plugin"].get("repository")
            homepage as toml_data["plugin"].get("homepage")
            entry_point as toml_data["plugin"]["entry_point"]
        compatibility as CompatibilityInfo with:
            runa_version as toml_data["compatibility"]["runa_version"]
            platform as toml_data["compatibility"].get("platform", list containing)
            architecture as toml_data["compatibility"].get("architecture", list containing)
        dependencies as toml_data.get("dependencies", dictionary containing)
        capabilities as CapabilityInfo with:
            requires as toml_data["capabilities"].get("requires", list containing)
            provides as toml_data["capabilities"].get("provides", list containing)
        configuration as ConfigurationInfo with:
            default_config as toml_data["configuration"].get("default_config")
            schema as toml_data["configuration"].get("schema")
        build as BuildInfo with:
            build_script as toml_data["build"].get("build_script")
            assets as toml_data["build"].get("assets", list containing)
            exclude as toml_data["build"].get("exclude", list containing)

Process called "read_toml" that takes path as String returns Dictionary[String, Any]:
    Let content be read_file_content(path)
    Return parse_toml_string(content)

Process called "parse_toml_string" that takes content as String returns Dictionary[String, Any]:
    Note: Production implementation would use actual TOML parser
    Return create_mock_toml_data()

Process called "create_mock_toml_data" returns Dictionary[String, Any]:
    Return dictionary with:
        "plugin" as dictionary with:
            "id" as "example.plugin"
            "name" as "Example Plugin"
            "version" as "1.0.0"
            "author" as "Example Author"
            "description" as "An example plugin"
            "entry_point" as "main.runa"
        "compatibility" as dictionary with:
            "runa_version" as ">=1.0.0"
            "platform" as list containing "linux", "windows", "macos"
            "architecture" as list containing "x86_64", "arm64"
        "dependencies" as dictionary containing
        "capabilities" as dictionary with:
            "requires" as list containing "ui.commands"
            "provides" as list containing "example.service"
        "configuration" as dictionary containing
        "build" as dictionary containing

Process called "current_runa_version" returns String:
    Return "1.0.0"

Process called "is_version_compatible" that takes current_version as String and version_spec as String returns Boolean:
    If version_spec contains ">=":
        Let required_version be split_string with string as version_spec and delimiter as ">="[1]
        Return is_version_greater_or_equal(current_version, required_version)
    If version_spec contains "<=":
        Let required_version be split_string with string as version_spec and delimiter as "<="[1]
        Return is_version_less_or_equal(current_version, required_version)
    If version_spec contains "=":
        Let required_version be split_string with string as version_spec and delimiter as "="[1]
        Return current_version is equal to required_version
    Return current_version is equal to version_spec

Process called "is_version_greater_or_equal" that takes version1 as String and version2 as String returns Boolean:
    Let v1_parts be split_string with string as version1 and delimiter as "."
    Let v2_parts be split_string with string as version2 and delimiter as "."
    If length of v1_parts is not equal to 3 or length of v2_parts is not equal to 3:
        Return false
    
    Let v1_major be parse_integer(v1_parts[0])
    Let v1_minor be parse_integer(v1_parts[1])
    Let v1_patch be parse_integer(v1_parts[2])
    
    Let v2_major be parse_integer(v2_parts[0])
    Let v2_minor be parse_integer(v2_parts[1])
    Let v2_patch be parse_integer(v2_parts[2])
    
    If v1_major is greater than v2_major:
        Return true
    If v1_major is equal to v2_major and v1_minor is greater than v2_minor:
        Return true
    If v1_major is equal to v2_major and v1_minor is equal to v2_minor and v1_patch is greater than or equal to v2_patch:
        Return true
    
    Return false

Process called "is_version_less_or_equal" that takes version1 as String and version2 as String returns Boolean:
    Let v1_parts be split_string with string as version1 and delimiter as "."
    Let v2_parts be split_string with string as version2 and delimiter as "."
    If length of v1_parts is not equal to 3 or length of v2_parts is not equal to 3:
        Return false
    
    Let v1_major be parse_integer(v1_parts[0])
    Let v1_minor be parse_integer(v1_parts[1])
    Let v1_patch be parse_integer(v1_parts[2])
    
    Let v2_major be parse_integer(v2_parts[0])
    Let v2_minor be parse_integer(v2_parts[1])
    Let v2_patch be parse_integer(v2_parts[2])
    
    If v1_major is less than v2_major:
        Return true
    If v1_major is equal to v2_major and v1_minor is less than v2_minor:
        Return true
    If v1_major is equal to v2_major and v1_minor is equal to v2_minor and v1_patch is less than or equal to v2_patch:
        Return true
    
    Return false

Process called "create_dummy_entry_point" returns Function:
    Return function():
        Return "Hello from plugin"

Process called "create_default_lifecycle" returns PluginLifecycle:
    Return PluginLifecycle with:
        initialize as function(context):
            Return true
        start as function(context):
            Return true  
        stop as function(context):
            Return true
        reload as None
        metadata as dictionary containing

Process called "list_directories" that takes path as String returns List[String]:
    Let directories be list containing
    Let entries be list_directory_entries(path)
    For each entry in entries:
        If is_directory(entry):
            Append entry to directories
    Return directories

Process called "create_plugin_discovery" returns PluginDiscovery:
    Return PluginDiscovery with:
        scan_plugins as function(path):
            Return scan_plugins_implementation(path)
        extract_metadata as function(plugin_path):
            Return extract_plugin_metadata_implementation(plugin_path)
        check_compatibility as function(plugin):
            Return check_plugin_compatibility_implementation(plugin)
        dynamic_discovery as true
        metadata as dictionary containing

Process called "scan_plugins_implementation" that takes path as String returns List[Plugin]:
    Let discovery be create_plugin_discovery()
    Return scan_plugins(discovery, path)

Process called "extract_plugin_metadata_implementation" that takes plugin_path as String returns PluginMetadata:
    Let discovery be create_plugin_discovery()
    Return extract_plugin_metadata(discovery, plugin_path)

Process called "check_plugin_compatibility_implementation" that takes plugin as Plugin returns Boolean:
    Let discovery be create_plugin_discovery()
    Return check_plugin_compatibility(discovery, plugin)

Note: Exception Types for Discovery
Type PluginDiscoveryError is Exception with:
    message as String
    metadata as Dictionary[String, Any] 