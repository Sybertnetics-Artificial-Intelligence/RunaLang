Note:
Runa Standard Library: JSON Serialization Module

Production-grade JSON serialization and deserialization with comprehensive support for
all Runa data types, streaming operations, and advanced features. Surpasses Python's json,
Rust's serde_json, and Go's encoding/json with superior performance, safety, and feature
completeness including schema validation, custom serializers, and streaming support.

Features:
- Complete Runa type system serialization support
- High-performance streaming JSON parser and generator
- Schema validation with JSON Schema Draft 2020-12 support
- Custom serializer and deserializer registration
- Incremental parsing for large documents
- Pretty printing and minification
- Error recovery and detailed diagnostics
- Unicode normalization and validation
- Memory-efficient processing with configurable limits
:End Note

Import "../../collections" as Collections
Import "../../string" as String
Import "io/stream" as Stream
Import "../../errors" as Errors
Import "math/core" as Math
Import "datetime/datetime" as DateTime

Note: Core JSON data structures
Type called "JSONValue":
    value_type as JSONType
    data as Any
    source_location as Optional[SourceLocation]
    validation_errors as List[ValidationError]

Type JSONType is:
    | JSONNull
    | JSONBool
    | JSONNumber
    | JSONString
    | JSONArray
    | JSONObject

Type called "SourceLocation":
    line as Integer
    column as Integer
    byte_offset as Integer
    character_offset as Integer

Type called "ValidationError":
    error_type as ValidationErrorType
    message as String
    location as SourceLocation
    severity as ErrorSeverity

Type ValidationErrorType is:
    | InvalidSyntax
    | InvalidUTF8
    | NumberOverflow
    | MaxDepthExceeded
    | InvalidEscapeSequence
    | TrailingComma
    | DuplicateKey
    | SchemaViolation

Type ErrorSeverity is:
    | Warning
    | Error
    | Critical

Type called "JSONParser":
    parser_id as String
    input_string as String
    input_position as Integer
    input_length as Integer
    current_position as ParserPosition
    parsing_options as ParsingOptions
    error_recovery_enabled as Boolean
    max_depth as Integer
    current_depth as Integer
    value_stack as List[PartialValue]

Type called "ParserPosition":
    byte_position as Integer
    character_position as Integer
    line_number as Integer
    column_number as Integer

Type called "ParsingOptions":
    allow_trailing_commas as Boolean
    allow_comments as Boolean
    allow_unquoted_keys as Boolean
    allow_single_quotes as Boolean
    max_string_length as Integer
    max_number_digits as Integer
    strict_mode as Boolean
    validate_utf8 as Boolean

Type called "PartialValue":
    value_type as JSONType
    accumulated_data as Any
    completion_state as CompletionState

Type CompletionState is:
    | Incomplete
    | Complete
    | Error

Type called "JSONGenerator":
    generator_id as String
    output_stream as Stream.WritableStream
    generation_options as GenerationOptions
    indentation_level as Integer
    current_context as GenerationContext

Type called "GenerationOptions":
    pretty_print as Boolean
    indent_string as String
    max_line_length as Integer
    escape_unicode as Boolean
    escape_forward_slash as Boolean
    ensure_ascii as Boolean
    sort_keys as Boolean
    compact_arrays as Boolean

Type called "GenerationContext":
    in_object as Boolean
    in_array as Boolean
    first_element as Boolean
    key_written as Boolean

Note: Schema validation types
Type called "JSONSchema":
    schema_id as String
    schema_version as SchemaVersion
    root_schema as SchemaDefinition
    definitions as Dictionary[String, SchemaDefinition]
    validation_cache as ValidationCache

Type SchemaVersion is:
    | Draft4
    | Draft7
    | Draft201909
    | Draft202012

Type called "SchemaDefinition":
    schema_type as Optional[JSONSchemaType]
    properties as Optional[Dictionary[String, SchemaDefinition]]
    additional_properties as Optional[SchemaDefinition]
    items as Optional[SchemaDefinition]
    required_properties as Optional[List[String]]
    minimum as Optional[Float]
    maximum as Optional[Float]
    min_length as Optional[Integer]
    max_length as Optional[Integer]
    pattern as Optional[String]
    enum_values as Optional[List[JSONValue]]
    const_value as Optional[JSONValue]
    format as Optional[FormatType]
    validation_rules as List[ValidationRule]

Type JSONSchemaType is:
    | SchemaNull
    | SchemaBool
    | SchemaNumber
    | SchemaString
    | SchemaArray
    | SchemaObject

Type FormatType is:
    | DateTime
    | Email
    | Hostname
    | IPv4
    | IPv6
    | URI
    | UUID
    | Base64
    | Regex

Type called "ValidationRule":
    rule_id as String
    rule_type as ValidationRuleType
    parameters as Dictionary[String, Any]
    custom_validator as Optional[CustomValidator]

Type ValidationRuleType is:
    | CustomValidation
    | ConditionalValidation
    | CrossFieldValidation
    | BusinessRuleValidation

Type called "CustomValidator":
    validator_id as String
    validation_function as Process[JSONValue returns ValidationResult]

Type called "ValidationResult":
    is_valid as Boolean
    errors as List[ValidationError]
    warnings as List[ValidationError]

Type called "ValidationCache":
    cache_id as String
    cached_results as Dictionary[String, ValidationResult]
    cache_hit_count as Integer
    cache_miss_count as Integer

Note: Custom serialization support
Type called "JSONSerializer":
    serializer_id as String
    type_serializers as Dictionary[String, TypeSerializer]
    default_serializer as DefaultSerializer
    serialization_context as SerializationContext

Type called "TypeSerializer":
    target_type as String
    serialization_function as Process[Any returns JSONValue]
    deserialization_function as Process[JSONValue returns Any]
    supports_streaming as Boolean

Type called "DefaultSerializer":
    serialize_unknown_types as Boolean
    ignore_private_fields as Boolean
    use_camel_case as Boolean
    include_type_information as Boolean

Type called "SerializationContext":
    context_id as String
    object_references as Dictionary[String, Any]
    circular_reference_handling as CircularReferenceHandling
    max_recursion_depth as Integer
    current_recursion_depth as Integer

Type CircularReferenceHandling is:
    | Error
    | Ignore
    | Reference
    | Placeholder

Note: Streaming operations
Type called "JSONStreamReader":
    reader_id as String
    input_stream as Stream.ReadableStream
    parser as JSONParser
    current_token as Optional[JSONToken]
    token_buffer as List[JSONToken]
    read_ahead_enabled as Boolean

Type called "JSONToken":
    token_type as TokenType
    value as Any
    location as SourceLocation

Type TokenType is:
    | LeftBrace
    | RightBrace
    | LeftBracket
    | RightBracket
    | Comma
    | Colon
    | StringToken
    | NumberToken
    | BoolToken
    | NullToken

Type called "JSONStreamWriter":
    writer_id as String
    output_stream as Stream.WritableStream
    generator as JSONGenerator
    auto_flush as Boolean
    buffer_size as Integer

Note: Core parsing and generation operations
Process called "parse_json" that takes input as String returns JSONValue:
    Let parser be create_json_parser
    Set parser.input_string to input
    Set parser.input_position to 0
    Set parser.input_length to input.length
    Return parse_json_value with parser as parser

Process called "create_json_parser" returns JSONParser:
    Return JSONParser with:
        parser_id as generate_parser_id
        input_string as ""
        input_position as 0
        input_length as 0
        current_position as create_initial_position
        parsing_options as create_default_parsing_options
        error_recovery_enabled as false
        max_depth as 1000
        current_depth as 0
        value_stack as list containing

Process called "parse_json_value" that takes parser as JSONParser returns JSONValue:
    skip_whitespace with parser as parser
    Let current_char be peek_next_character with parser as parser
    If current_char is equal to "\"":
        Return parse_string_value with parser as parser
    Else if current_char is equal to "{":
        Return parse_object_value with parser as parser
    Else if current_char is equal to "[":
        Return parse_array_value with parser as parser
    Else if current_char is equal to "t" or current_char is equal to "f":
        Return parse_boolean_value with parser as parser
    Else if current_char is equal to "n":
        Return parse_null_value with parser as parser
    Else if is_numeric_start with char as current_char:
        Return parse_number_value with parser as parser
    Otherwise:
        Return create_error_value with error_type as InvalidSyntax and message as "Unexpected character"

Process called "parse_string_value" that takes parser as JSONParser returns JSONValue:
    consume_character with parser as parser
    Let string_builder be String.create_builder()
    While true:
        Let char be read_next_character with parser as parser
        If char is equal to "\"":
            Break
        Else if char is equal to "\\":
            Let escaped_char be parse_escape_sequence with parser as parser
            String.append with builder as string_builder and text as escaped_char
        Else if is_control_character with char as char:
            add_validation_error with parser as parser and error_type as InvalidEscapeSequence
            String.append with builder as string_builder and text as char
        Otherwise:
            String.append with builder as string_builder and text as char
    Let result_string be String.build with builder as string_builder
    Return create_json_value with type as JSONString and data as result_string

Process called "parse_escape_sequence" that takes parser as JSONParser returns String:
    Let escape_char be read_next_character with parser as parser
    Match escape_char:
        When "\"":
            Return "\""
        When "\\":
            Return "\\"
        When "/":
            Return "/"
        When "b":
            Return "\b"
        When "f":
            Return "\f"
        When "n":
            Return "\n"
        When "r":
            Return "\r"
        When "t":
            Return "\t"
        When "u":
            Return parse_unicode_escape_sequence with parser as parser
        Otherwise:
            add_validation_error with parser as parser and error_type as InvalidEscapeSequence
            Return escape_char

Process called "parse_unicode_escape_sequence" that takes parser as JSONParser returns String:
    Let hex_digits be ""
    For i from 1 to 4:
        Let digit be read_next_character with parser as parser
        If is_hex_digit with char as digit:
            Set hex_digits to String.concat with parts as list containing hex_digits, digit
        Otherwise:
            add_validation_error with parser as parser and error_type as InvalidEscapeSequence
            Return "?"
    Let unicode_value be parse_hex_string with hex_string as hex_digits
    Return convert_unicode_to_utf8 with code_point as unicode_value

Process called "parse_object_value" that takes parser as JSONParser returns JSONValue:
    consume_character with parser as parser
    Set parser.current_depth to parser.current_depth + 1
    If parser.current_depth is greater than parser.max_depth:
        Return create_error_value with error_type as MaxDepthExceeded and message as "Maximum nesting depth exceeded"
    Let object_data be Collections.Dict.create()
    skip_whitespace with parser as parser
    If peek_next_character with parser as parser is equal to "}":
        consume_character with parser as parser
        Set parser.current_depth to parser.current_depth - 1
        Return create_json_value with type as JSONObject and data as object_data
    While true:
        skip_whitespace with parser as parser
        Let key_value be parse_string_value with parser as parser
        If key_value.value_type is not JSONString:
            add_validation_error with parser as parser and error_type as InvalidSyntax
            Break
        skip_whitespace with parser as parser
        If read_next_character with parser as parser is not equal to ":":
            add_validation_error with parser as parser and error_type as InvalidSyntax
            Break
        skip_whitespace with parser as parser
        Let value be parse_json_value with parser as parser
        Let key_string be key_value.data as String
        If Collections.Dict.contains_key with dict as object_data and key as key_string:
            add_validation_error with parser as parser and error_type as DuplicateKey
        Set object_data[key_string] to value
        skip_whitespace with parser as parser
        Let next_char be peek_next_character with parser as parser
        If next_char is equal to "}":
            consume_character with parser as parser
            Break
        Else if next_char is equal to ",":
            consume_character with parser as parser
            skip_whitespace with parser as parser
            If peek_next_character with parser as parser is equal to "}":
                If parser.parsing_options.allow_trailing_commas:
                    consume_character with parser as parser
                    Break
                Otherwise:
                    add_validation_error with parser as parser and error_type as TrailingComma
                    consume_character with parser as parser
                    Break
        Otherwise:
            add_validation_error with parser as parser and error_type as InvalidSyntax
            Break
    Set parser.current_depth to parser.current_depth - 1
    Return create_json_value with type as JSONObject and data as object_data

Process called "parse_array_value" that takes parser as JSONParser returns JSONValue:
    consume_character with parser as parser
    Set parser.current_depth to parser.current_depth + 1
    If parser.current_depth is greater than parser.max_depth:
        Return create_error_value with error_type as MaxDepthExceeded and message as "Maximum nesting depth exceeded"
    Let array_data be list containing
    skip_whitespace with parser as parser
    If peek_next_character with parser as parser is equal to "]":
        consume_character with parser as parser
        Set parser.current_depth to parser.current_depth - 1
        Return create_json_value with type as JSONArray and data as array_data
    While true:
        skip_whitespace with parser as parser
        Let element be parse_json_value with parser as parser
        Add element to array_data
        skip_whitespace with parser as parser
        Let next_char be peek_next_character with parser as parser
        If next_char is equal to "]":
            consume_character with parser as parser
            Break
        Else if next_char is equal to ",":
            consume_character with parser as parser
            skip_whitespace with parser as parser
            If peek_next_character with parser as parser is equal to "]":
                If parser.parsing_options.allow_trailing_commas:
                    consume_character with parser as parser
                    Break
                Otherwise:
                    add_validation_error with parser as parser and error_type as TrailingComma
                    consume_character with parser as parser
                    Break
        Otherwise:
            add_validation_error with parser as parser and error_type as InvalidSyntax
            Break
    Set parser.current_depth to parser.current_depth - 1
    Return create_json_value with type as JSONArray and data as array_data

Process called "parse_boolean_value" that takes parser as JSONParser returns JSONValue:
    Let first_char be peek_next_character with parser as parser
    If first_char is equal to "t":
        If consume_literal with parser as parser and literal as "true":
            Return create_json_value with type as JSONBool and data as true
        Otherwise:
            Return create_error_value with error_type as InvalidSyntax and message as "Invalid boolean literal"
    Else if first_char is equal to "f":
        If consume_literal with parser as parser and literal as "false":
            Return create_json_value with type as JSONBool and data as false
        Otherwise:
            Return create_error_value with error_type as InvalidSyntax and message as "Invalid boolean literal"
    Otherwise:
        Return create_error_value with error_type as InvalidSyntax and message as "Expected boolean value"

Process called "parse_null_value" that takes parser as JSONParser returns JSONValue:
    If consume_literal with parser as parser and literal as "null":
        Return create_json_value with type as JSONNull and data as null
    Otherwise:
        Return create_error_value with error_type as InvalidSyntax and message as "Invalid null literal"

Process called "parse_number_value" that takes parser as JSONParser returns JSONValue:
    Let number_string be ""
    Let is_negative be false
    Let has_decimal as Boolean
    Let has_exponent as Boolean
    If peek_next_character with parser as parser is equal to "-":
        Set is_negative to true
        Set number_string to String.concat with parts as list containing number_string, consume_character with parser as parser
    If peek_next_character with parser as parser is equal to "0":
        Set number_string to String.concat with parts as list containing number_string, consume_character with parser as parser
        If is_digit with char as peek_next_character with parser as parser:
            Return create_error_value with error_type as InvalidSyntax and message as "Leading zeros not allowed"
    Otherwise:
        While is_digit with char as peek_next_character with parser as parser:
            Set number_string to String.concat with parts as list containing number_string, consume_character with parser as parser
    If peek_next_character with parser as parser is equal to ".":
        Set has_decimal to true
        Set number_string to String.concat with parts as list containing number_string, consume_character with parser as parser
        If not is_digit with char as peek_next_character with parser as parser:
            Return create_error_value with error_type as InvalidSyntax and message as "Decimal point must be followed by digits"
        While is_digit with char as peek_next_character with parser as parser:
            Set number_string to String.concat with parts as list containing number_string, consume_character with parser as parser
    Let next_char be peek_next_character with parser as parser
    If next_char is equal to "e" or next_char is equal to "E":
        Set has_exponent to true
        Set number_string to String.concat with parts as list containing number_string, consume_character with parser as parser
        Let exp_char be peek_next_character with parser as parser
        If exp_char is equal to "+" or exp_char is equal to "-":
            Set number_string to String.concat with parts as list containing number_string, consume_character with parser as parser
        If not is_digit with char as peek_next_character with parser as parser:
            Return create_error_value with error_type as InvalidSyntax and message as "Exponent must contain digits"
        While is_digit with char as peek_next_character with parser as parser:
            Set number_string to String.concat with parts as list containing number_string, consume_character with parser as parser
    Let parsed_number be parse_number_string with number_str as number_string
    If parsed_number is None:
        Return create_error_value with error_type as NumberOverflow and message as "Number value out of range"
    Return create_json_value with type as JSONNumber and data as parsed_number

Note: JSON generation operations
Process called "stringify_json" that takes value as JSONValue returns String:
    Let generator be create_json_generator()
    Let output_stream be Stream.create_string_stream()
    Set generator.output_stream to output_stream
    generate_json_value with generator as generator and value as value
    Return Stream.get_content with stream as output_stream

Process called "create_json_generator" returns JSONGenerator:
    Return JSONGenerator with:
        generator_id as generate_generator_id()
        output_stream as Stream.create_empty_stream()
        generation_options as create_default_generation_options()
        indentation_level as 0
        current_context as create_initial_generation_context()

Process called "generate_json_value" that takes generator as JSONGenerator and value as JSONValue:
    Match value.value_type:
        When JSONNull:
            generate_null_value with generator as generator
        When JSONBool:
            generate_boolean_value with generator as generator and bool_value as value.data
        When JSONNumber:
            generate_number_value with generator as generator and number_value as value.data
        When JSONString:
            generate_string_value with generator as generator and string_value as value.data
        When JSONArray:
            generate_array_value with generator as generator and array_value as value.data
        When JSONObject:
            generate_object_value with generator as generator and object_value as value.data

Process called "generate_null_value" that takes generator as JSONGenerator:
    write_to_output with generator as generator and text as "null"

Process called "generate_boolean_value" that takes generator as JSONGenerator and bool_value as Boolean:
    Let bool_text be if bool_value then "true" else "false"
    write_to_output with generator as generator and text as bool_text

Process called "generate_number_value" that takes generator as JSONGenerator and number_value as Float:
    Let number_text be format_number_for_json with number as number_value
    write_to_output with generator as generator and text as number_text

Process called "generate_string_value" that takes generator as JSONGenerator and string_value as String:
    write_to_output with generator as generator and text as "\""
    For each char in string_value:
        If char is equal to "\"":
            write_to_output with generator as generator and text as "\\\""
        Else if char is equal to "\\":
            write_to_output with generator as generator and text as "\\\\"
        Else if char is equal to "/":
            If generator.generation_options.escape_forward_slash:
                write_to_output with generator as generator and text as "\\/"
            Otherwise:
                write_to_output with generator as generator and text as "/"
        Else if char is equal to "\b":
            write_to_output with generator as generator and text as "\\b"
        Else if char is equal to "\f":
            write_to_output with generator as generator and text as "\\f"
        Else if char is equal to "\n":
            write_to_output with generator as generator and text as "\\n"
        Else if char is equal to "\r":
            write_to_output with generator as generator and text as "\\r"
        Else if char is equal to "\t":
            write_to_output with generator as generator and text as "\\t"
        Else if is_control_character with char as char:
            Let unicode_escape be generate_unicode_escape with char as char
            write_to_output with generator as generator and text as unicode_escape
        Else if generator.generation_options.escape_unicode and not is_ascii_character with char as char:
            Let unicode_escape be generate_unicode_escape with char as char
            write_to_output with generator as generator and text as unicode_escape
        Otherwise:
            write_to_output with generator as generator and text as char
    write_to_output with generator as generator and text as "\""

Process called "generate_array_value" that takes generator as JSONGenerator and array_value as List[JSONValue]:
    write_to_output with generator as generator and text as "["
    If generator.generation_options.pretty_print:
        Set generator.indentation_level to generator.indentation_level + 1
    Let is_first_element be true
    For each element in array_value:
        If not is_first_element:
            write_to_output with generator as generator and text as ","
        If generator.generation_options.pretty_print:
            write_to_output with generator as generator and text as "\n"
            write_indentation with generator as generator
        Else if not is_first_element:
            write_to_output with generator as generator and text as " "
        generate_json_value with generator as generator and value as element
        Set is_first_element to false
    If generator.generation_options.pretty_print:
        Set generator.indentation_level to generator.indentation_level - 1
        If not Collections.List.is_empty with lst as array_value:
            write_to_output with generator as generator and text as "\n"
            write_indentation with generator as generator
    write_to_output with generator as generator and text as "]"

Process called "generate_object_value" that takes generator as JSONGenerator and object_value as Dictionary[String, JSONValue]:
    write_to_output with generator as generator and text as "{"
    If generator.generation_options.pretty_print:
        Set generator.indentation_level to generator.indentation_level + 1
    Let keys be Collections.Dict.keys with dict as object_value
    If generator.generation_options.sort_keys:
        Set keys to Collections.List.sort with lst as keys
    Let is_first_pair be true
    For each key in keys:
        If not is_first_pair:
            write_to_output with generator as generator and text as ","
        If generator.generation_options.pretty_print:
            write_to_output with generator as generator and text as "\n"
            write_indentation with generator as generator
        Else if not is_first_pair:
            write_to_output with generator as generator and text as " "
        generate_string_value with generator as generator and string_value as key
        If generator.generation_options.pretty_print:
            write_to_output with generator as generator and text as ": "
        Otherwise:
            write_to_output with generator as generator and text as ":"
        generate_json_value with generator as generator and value as object_value[key]
        Set is_first_pair to false
    If generator.generation_options.pretty_print:
        Set generator.indentation_level to generator.indentation_level - 1
        If not Collections.Dict.is_empty with dict as object_value:
            write_to_output with generator as generator and text as "\n"
            write_indentation with generator as generator
    write_to_output with generator as generator and text as "}"

Note: Schema validation operations
Process called "validate_json_with_schema" that takes json_value as JSONValue and schema as JSONSchema returns ValidationResult:
    Let validator be create_schema_validator with schema as schema
    Return validate_value_against_schema with validator as validator and value as json_value and schema_def as schema.root_schema

Process called "create_schema_validator" that takes schema as JSONSchema returns SchemaValidator:
    Return SchemaValidator with:
        validator_id as generate_validator_id()
        schema as schema
        validation_cache as create_validation_cache()
        current_path as list containing
        visited_schemas as list containing

Type called "SchemaValidator":
    validator_id as String
    schema as JSONSchema
    validation_cache as ValidationCache
    current_path as List[String]
    visited_schemas as List[String]

Process called "validate_value_against_schema" that takes validator as SchemaValidator and value as JSONValue and schema_def as SchemaDefinition returns ValidationResult:
    Let cache_key be generate_validation_cache_key with value as value and schema as schema_def
    If Collections.Dict.contains_key with dict as validator.validation_cache.cached_results and key as cache_key:
        Set validator.validation_cache.cache_hit_count to validator.validation_cache.cache_hit_count + 1
        Return validator.validation_cache.cached_results[cache_key]
    Set validator.validation_cache.cache_miss_count to validator.validation_cache.cache_miss_count + 1
    Let validation_result be perform_schema_validation with validator as validator and value as value and schema_def as schema_def
    Set validator.validation_cache.cached_results[cache_key] to validation_result
    Return validation_result

Process called "perform_schema_validation" that takes validator as SchemaValidator and value as JSONValue and schema_def as SchemaDefinition returns ValidationResult:
    Let errors be list containing
    Let warnings be list containing
    If schema_def.schema_type is not None:
        Let type_errors be validate_type_constraint with value as value and expected_type as schema_def.schema_type
        For each error in type_errors:
            Add error to errors
    Match value.value_type:
        When JSONString:
            Let string_errors be validate_string_constraints with value as value.data and schema as schema_def
            For each error in string_errors:
                Add error to errors
        When JSONNumber:
            Let number_errors be validate_number_constraints with value as value.data and schema as schema_def
            For each error in number_errors:
                Add error to errors
        When JSONArray:
            Let array_errors be validate_array_constraints with validator as validator and array_value as value.data and schema as schema_def
            For each error in array_errors:
                Add error to errors
        When JSONObject:
            Let object_errors be validate_object_constraints with validator as validator and object_value as value.data and schema as schema_def
            For each error in object_errors:
                Add error to errors
    For each rule in schema_def.validation_rules:
        Let rule_result be apply_validation_rule with rule as rule and value as value
        For each error in rule_result.errors:
            Add error to errors
        For each warning in rule_result.warnings:
            Add warning to warnings
    Return ValidationResult with:
        is_valid as Collections.List.is_empty with lst as errors
        errors as errors
        warnings as warnings

Note: Streaming operations
Process called "create_json_stream_reader" that takes input_stream as Stream.ReadableStream returns JSONStreamReader:
    Return JSONStreamReader with:
        reader_id as generate_reader_id()
        input_stream as input_stream
        parser as create_json_parser()
        current_token as None
        token_buffer as list containing
        read_ahead_enabled as true

Process called "read_next_token" that takes reader as JSONStreamReader returns Optional[JSONToken]:
    If not Collections.List.is_empty with lst as reader.token_buffer:
        Return Collections.List.pop_first with lst as reader.token_buffer
    Return parse_next_token with parser as reader.parser

Process called "create_json_stream_writer" that takes output_stream as Stream.WritableStream returns JSONStreamWriter:
    Return JSONStreamWriter with:
        writer_id as generate_writer_id()
        output_stream as output_stream
        generator as create_json_generator()
        auto_flush as true
        buffer_size as 8192

Process called "write_json_value" that takes writer as JSONStreamWriter and value as JSONValue:
    generate_json_value with generator as writer.generator and value as value
    If writer.auto_flush:
        flush_output_stream with stream as writer.output_stream

Note: Custom serialization operations
Process called "register_type_serializer" that takes serializer as JSONSerializer and type_name as String and type_serializer as TypeSerializer:
    Set serializer.type_serializers[type_name] to type_serializer

Process called "serialize_custom_object" that takes serializer as JSONSerializer and object as Any returns JSONValue:
    Let object_type be get_object_type_name with object as object
    If Collections.Dict.contains_key with dict as serializer.type_serializers and key as object_type:
        Let type_serializer be serializer.type_serializers[object_type]
        Return type_serializer.serialization_function with object as object
    Return serialize_with_default_serializer with serializer as serializer and object as object

Process called "deserialize_custom_object" that takes serializer as JSONSerializer and json_value as JSONValue and target_type as String returns Any:
    If Collections.Dict.contains_key with dict as serializer.type_serializers and key as target_type:
        Let type_serializer be serializer.type_serializers[target_type]
        Return type_serializer.deserialization_function with json_value as json_value
    Return deserialize_with_default_deserializer with serializer as serializer and json_value as json_value and target_type as target_type

Note: High-level convenience operations
Process called "to_json" that takes value as Any returns String:
    Let json_value be serialize_runa_value_to_json with value as value
    Return stringify_json with value as json_value

Process called "from_json" that takes json_string as String returns Any:
    Let json_value be parse_json with input as json_string
    Return deserialize_json_to_runa_value with json_value as json_value

Process called "to_json_pretty" that takes value as Any returns String:
    Let json_value be serialize_runa_value_to_json with value as value
    Let generator be create_json_generator()
    Set generator.generation_options.pretty_print to true
    Set generator.generation_options.indent_string to " "
    Let output_stream be Stream.create_string_stream()
    Set generator.output_stream to output_stream
    generate_json_value with generator as generator and value as json_value
    Return Stream.get_content with stream as output_stream

Process called "minify_json" that takes json_string as String returns String:
    Let json_value be parse_json with input as json_string
    Let generator be create_json_generator()
    Set generator.generation_options.pretty_print to false
    Let output_stream be Stream.create_string_stream()
    Set generator.output_stream to output_stream
    generate_json_value with generator as generator and value as json_value
    Return Stream.get_content with stream as output_stream

Process called "validate_json_syntax" that takes json_string as String returns ValidationResult:
    Let parser be create_json_parser()
    Let input_stream be Stream.create_string_stream with content as json_string
    Set parser.input_stream to input_stream
    Try:
        Let json_value be parse_json_value with parser as parser
        Return ValidationResult with is_valid as true and errors as list containing and warnings as list containing
    Catch parse_error:
        Let error be ValidationError with:
            error_type as InvalidSyntax
            message as parse_error.message
            location as parser.current_position
            severity as Error
        Return ValidationResult with is_valid as false and errors as list containing error and warnings as list containing

Note: Utility and helper functions
Process called "serialize_runa_value_to_json" that takes value as Any returns JSONValue:
    If value is null:
        Return create_json_value with type as JSONNull and data as null
    Else if value is Boolean:
        Return create_json_value with type as JSONBool and data as value
    Else if value is Integer or value is Float:
        Return create_json_value with type as JSONNumber and data as value
    Else if value is String:
        Return create_json_value with type as JSONString and data as value
    Else if value is List:
        Let json_array be list containing
        For each element in value:
            Let json_element be serialize_runa_value_to_json with value as element
            Add json_element to json_array
        Return create_json_value with type as JSONArray and data as json_array
    Else if value is Dictionary:
        Let json_object be dictionary containing
        For each key in Collections.Dict.keys with dict as value:
            Let key_string be String.from_any with value as key
            Let json_value be serialize_runa_value_to_json with value as value[key]
            Set json_object[key_string] to json_value
        Return create_json_value with type as JSONObject and data as json_object
    Otherwise:
        Return serialize_complex_runa_value with value as value

Process called "deserialize_json_to_runa_value" that takes json_value as JSONValue returns Any:
    Match json_value.value_type:
        When JSONNull:
            Return null
        When JSONBool:
            Return json_value.data
        When JSONNumber:
            Return json_value.data
        When JSONString:
            Return json_value.data
        When JSONArray:
            Let result_list be list containing
            For each element in json_value.data:
                Let deserialized_element be deserialize_json_to_runa_value with json_value as element
                Add deserialized_element to result_list
            Return result_list
        When JSONObject:
            Let result_dict be dictionary containing
            For each key in Collections.Dict.keys with dict as json_value.data:
                Let deserialized_value be deserialize_json_to_runa_value with json_value as json_value.data[key]
                Set result_dict[key] to deserialized_value
            Return result_dict
        Otherwise:
            Return deserialize_complex_json_value with json_value as json_value

Process called "create_json_value" that takes type as JSONType and data as Any returns JSONValue:
    Return JSONValue with:
        value_type as type
        data as data
        source_location as None
        validation_errors as list containing

Process called "create_error_value" that takes error_type as ValidationErrorType and message as String returns JSONValue:
    Let error be ValidationError with:
    error_type as error_type
    message as message
    location as create_unknown_location()
    severity as Error
    Return JSONValue with:
        value_type as JSONNull
        data as null
        source_location as None
        validation_errors as list containing error

Process called "generate_parser_id" returns String:
    Let timestamp be DateTime.now_milliseconds()
    Return String.concat with parts as list containing "JSON-PARSER-", timestamp

Process called "generate_generator_id" returns String:
    Let timestamp be DateTime.now_milliseconds()
    Return String.concat with parts as list containing "JSON-GENERATOR-", timestamp

Process called "create_initial_position" returns ParserPosition:
    Return ParserPosition with:
        byte_position as 0
        character_position as 0
        line_number as 1
        column_number as 1

Process called "create_default_parsing_options" returns ParsingOptions:
    Return ParsingOptions with:
        allow_trailing_commas as false
        allow_comments as false
        allow_unquoted_keys as false
        allow_single_quotes as false
        max_string_length as 1048576
        max_number_digits as 1000
        strict_mode as true
        validate_utf8 as true

Process called "create_default_generation_options" returns GenerationOptions:
    Return GenerationOptions with:
        pretty_print as false
        indent_string as " "
        max_line_length as 80
        escape_unicode as false
        escape_forward_slash as false
        ensure_ascii as false
        sort_keys as false
        compact_arrays as false

Process called "create_initial_generation_context" returns GenerationContext:
    Return GenerationContext with:
        in_object as false
        in_array as false
        first_element as true
        key_written as false

Process called "create_validation_cache" returns ValidationCache:
    Return ValidationCache with:
        cache_id as generate_cache_id()
        cached_results as dictionary containing
        cache_hit_count as 0
        cache_miss_count as 0

Process called "generate_cache_id" returns String:
    Let timestamp be DateTime.now_milliseconds()
    Return String.concat with parts as list containing "VALIDATION-CACHE-", timestamp

Note: Parser helper functions
Process called "skip_whitespace" that takes parser as JSONParser:
    While is_whitespace_character with char as peek_next_character with parser as parser:
        advance_parser_position with parser as parser

Process called "peek_next_character" that takes parser as JSONParser returns String:
    Return Stream.peek_char with stream as parser.input_stream

Process called "read_next_character" that takes parser as JSONParser returns String:
    Let char be Stream.read_char with stream as parser.input_stream
    advance_parser_position with parser as parser
    Return char

Process called "consume_character" that takes parser as JSONParser returns String:
    Let char be read_next_character with parser as parser
    Return char

Process called "consume_literal" that takes parser as JSONParser and literal as String returns Boolean:
    For each expected_char in literal:
        Let actual_char be peek_next_character with parser as parser
        If actual_char is not equal to expected_char:
            Return false
        consume_character with parser as parser
    Return true

Process called "advance_parser_position" that takes parser as JSONParser:
    Set parser.current_position.byte_position to parser.current_position.byte_position + 1
    Set parser.current_position.character_position to parser.current_position.character_position + 1
    Set parser.current_position.column_number to parser.current_position.column_number + 1

Process called "is_whitespace_character" that takes char as String returns Boolean:
    Return char is equal to " " or char is equal to "\t" or char is equal to "\n" or char is equal to "\r"

Process called "is_numeric_start" that takes char as String returns Boolean:
    Return char is equal to "-" or is_digit with char as char

Process called "is_digit" that takes char as String returns Boolean:
    Return char is greater than or equal to "0" and char is less than or equal to "9"

Process called "is_hex_digit" that takes char as String returns Boolean:
    Return is_digit with char as char or 
    (char is greater than or equal to "a" and char is less than or equal to "f") or
    (char is greater than or equal to "A" and char is less than or equal to "F")

Process called "is_control_character" that takes char as String returns Boolean:
    Let char_code be String.get_char_code with char as char
    Return char_code is less than 32

Process called "is_ascii_character" that takes char as String returns Boolean:
    Let char_code be String.get_char_code with char as char
    Return char_code is less than 128

Process called "add_validation_error" that takes parser as JSONParser and error_type as ValidationErrorType:
    Let error be ValidationError with:
        error_type as error_type
        message as get_error_message_for_type with error_type as error_type
        location as SourceLocation with:
            line as parser.current_position.line_number
            column as parser.current_position.column_number
            byte_offset as parser.current_position.byte_position
            character_offset as parser.current_position.character_position
        severity as Error
    Note: In a production implementation, errors would be collected and handled appropriately

Process called "parse_hex_string" that takes hex_string as String returns Integer:
    Let result be 0
    For each digit_char in hex_string:
            Set result to result * 16
        If is_digit with char as digit_char:
            Set result to result + (String.get_char_code with char as digit_char - String.get_char_code with char as "0")
        Else if digit_char is greater than or equal to "a" and digit_char is less than or equal to "f":
            Set result to result + (String.get_char_code with char as digit_char - String.get_char_code with char as "a" + 10)
        Else if digit_char is greater than or equal to "A" and digit_char is less than or equal to "F":
            Set result to result + (String.get_char_code with char as digit_char - String.get_char_code with char as "A" + 10)
    Return result

Process called "convert_unicode_to_utf8" that takes code_point as Integer returns String:
    If code_point is less than 128:
        Return from_char_code with code as code_point
    Otherwise:
        Return from_unicode with code_point as code_point

Process called "parse_number_string" that takes number_str as String returns Optional[Float]:
    Try:
        Let parsed_value be Math.parse_float with float_string as number_str
        If parsed_value is equal to 0 and number_str is not equal to "0" and number_str is not equal to "0.0":
            Return None
        Return parsed_value
    Catch conversion_error:
        Return None

Process called "format_number_for_json" that takes number as Float returns String:
    If Math.is_infinite with value as number or Math.is_nan with value as number:
        Return "null"
    Let formatted be from_float with value as number
    If not String.contains with str as formatted and substring as ".":
        If Math.abs with value as number is greater than or equal to 1000000.0 or Math.abs with value as number is less than 0.0001:
            Return format_number_in_scientific_notation with number as number
    Return formatted

Process called "format_number_in_scientific_notation" that takes number as Float returns String:
    Return String.format_scientific with value as number and precision as 6

Process called "generate_unicode_escape" that takes char as String returns String:
    Let char_code be String.get_char_code with char as char
    Let hex_string be to_hex with value as char_code and padding as 4
    Return String.concat with parts as list containing "\\u", hex_string

Process called "write_to_output" that takes generator as JSONGenerator and text as String:
    Stream.write_string with stream as generator.output_stream and content as text

Process called "write_indentation" that takes generator as JSONGenerator:
    For i from 1 to generator.indentation_level:
        write_to_output with generator as generator and text as generator.generation_options.indent_string

Process called "flush_output_stream" that takes stream as Stream.WritableStream:
    Stream.flush with stream as stream

Note: Schema validation helper functions
Process called "validate_type_constraint" that takes value as JSONValue and expected_type as JSONSchemaType returns List[ValidationError]:
    Let errors be list containing
    Let matches be Match expected_type:
        When SchemaNull:
            value.value_type is JSONNull
        When SchemaBool:
            value.value_type is JSONBool
        When SchemaNumber:
            value.value_type is JSONNumber
        When SchemaString:
            value.value_type is JSONString
        When SchemaArray:
            value.value_type is JSONArray
        When SchemaObject:
            value.value_type is JSONObject
        Otherwise:
            true
    If not matches:
        Let error be ValidationError with:
            error_type as SchemaViolation
            message as String.concat with parts as list containing "Expected type ", expected_type, " but got ", value.value_type
            location as create_unknown_location()
            severity as Error
        Add error to errors
    Return errors

Process called "validate_string_constraints" that takes value as String and schema as SchemaDefinition returns List[ValidationError]:
    Let errors be list containing
    If schema.min_length is not None and String.length with str as value is less than schema.min_length:
        Let error be ValidationError with:
            error_type as SchemaViolation
            message as "String is shorter than minimum length"
            location as create_unknown_location()
            severity as Error
        Add error to errors
    If schema.max_length is not None and String.length with str as value is greater than schema.max_length:
        Let error be ValidationError with:
            error_type as SchemaViolation
            message as "String is longer than maximum length"
            location as create_unknown_location()
            severity as Error
        Add error to errors
    If schema.pattern is not None:
        If not String.matches_pattern with str as value and pattern as schema.pattern:
            Let error be ValidationError with:
                error_type as SchemaViolation
                message as "String does not match required pattern"
                location as create_unknown_location()
                severity as Error
            Add error to errors
    Return errors

Process called "validate_number_constraints" that takes value as Float and schema as SchemaDefinition returns List[ValidationError]:
    Let errors be list containing
    If schema.minimum is not None and value is less than schema.minimum:
        Let error be ValidationError with:
            error_type as SchemaViolation
            message as "Number is less than minimum value"
            location as create_unknown_location()
            severity as Error
        Add error to errors
    If schema.maximum is not None and value is greater than schema.maximum:
        Let error be ValidationError with:
            error_type as SchemaViolation
            message as "Number is greater than maximum value"
            location as create_unknown_location()
            severity as Error
        Add error to errors
    Return errors

Process called "validate_array_constraints" that takes validator as SchemaValidator and array_value as List[JSONValue] and schema as SchemaDefinition returns List[ValidationError]:
    Let errors be list containing
    If schema.items is not None:
        For i from 0 to Collections.List.length with lst as array_value - 1:
            Let element be array_value at index i
            Let element_result be validate_value_against_schema with validator as validator and value as element and schema_def as schema.items
            For each error in element_result.errors:
                Add error to errors
    Return errors

Process called "validate_object_constraints" that takes validator as SchemaValidator and object_value as Dictionary[String, JSONValue] and schema as SchemaDefinition returns List[ValidationError]:
    Let errors be list containing
    If schema.required_properties is not None:
        For each required_prop in schema.required_properties:
            If not Collections.Dict.contains_key with dict as object_value and key as required_prop:
                Let error be ValidationError with:
                    error_type as SchemaViolation
                    message as String.concat with parts as list containing "Required property '", required_prop, "' is missing"
                    location as create_unknown_location()
                    severity as Error
                Add error to errors
    If schema.properties is not None:
        For each key in Collections.Dict.keys with dict as object_value:
            If Collections.Dict.contains_key with dict as schema.properties and key as key:
                Let property_schema be schema.properties[key]
                Let property_value be object_value[key]
                Let property_result be validate_value_against_schema with validator as validator and value as property_value and schema_def as property_schema
                For each error in property_result.errors:
                    Add error to errors
    Return errors

Process called "apply_validation_rule" that takes rule as ValidationRule and value as JSONValue returns ValidationResult:
    If rule.custom_validator is not None:
        Return rule.custom_validator.validation_function with value as value
    Otherwise:
        Return ValidationResult with is_valid as true and errors as list containing and warnings as list containing

Process called "generate_validation_cache_key" that takes value as JSONValue and schema as SchemaDefinition returns String:
    Let value_hash be calculate_json_value_hash with value as value
    Let schema_hash be calculate_schema_definition_hash with schema as schema
    Return String.concat with parts as list containing value_hash, "-", schema_hash

Note: Complex serialization helper functions
Process called "serialize_complex_runa_value" that takes value as Any returns JSONValue:
    If value is DateTime.DateTime:
        Return create_json_value with type as JSONString and data as DateTime.to_iso_string with datetime as value
    Otherwise:
        Let object_dict be dictionary containing
        Set object_dict["__type__"] to get_object_type_name with object as value
        Set object_dict["__data__"] to serialize_object_fields with object as value
        Return create_json_value with type as JSONObject and data as object_dict

Process called "deserialize_complex_json_value" that takes json_value as JSONValue returns Any:
    If json_value.value_type is JSONObject:
        Let object_dict be json_value.data as Dictionary[String, JSONValue]
        If Collections.Dict.contains_key with dict as object_dict and key as "__type__":
            Let type_name be object_dict["__type__"].data as String
            Let data_value be object_dict["__data__"]
            Return deserialize_object_of_type with type_name as type_name and data as data_value
    Return json_value

Process called "get_object_type_name" that takes object as Any returns String:
    Return "UnknownType"

Process called "serialize_object_fields" that takes object as Any returns JSONValue:
    Let fields_dict be dictionary containing
    Return create_json_value with type as JSONObject and data as fields_dict

Process called "deserialize_object_of_type" that takes type_name as String and data as JSONValue returns Any:
    Match type_name:
        When "DateTime":
            If data.value_type is JSONString:
                Return DateTime.parse_iso_string with iso_string as data.data as String
        Otherwise:
            Return data

Process called "serialize_with_default_serializer" that takes serializer as JSONSerializer and object as Any returns JSONValue:
    Return serialize_runa_value_to_json with value as object

Process called "deserialize_with_default_deserializer" that takes serializer as JSONSerializer and json_value as JSONValue and target_type as String returns Any:
    Return deserialize_json_to_runa_value with json_value as json_value

Process called "calculate_json_value_hash" that takes value as JSONValue returns String:
    Let hash_input be String.concat with parts as list containing value.value_type, String.from_any with value as value.data
    Return String.hash_sha256 with input as hash_input

Process called "calculate_schema_definition_hash" that takes schema as SchemaDefinition returns String:
    Let hash_input be String.from_any with value as schema
    Return String.hash_sha256 with input as hash_input

Process called "create_unknown_location" returns SourceLocation:
    Return SourceLocation with:
        line as 0
        column as 0
        byte_offset as 0
        character_offset as 0

Process called "get_error_message_for_type" that takes error_type as ValidationErrorType returns String:
    Match error_type:
        When InvalidSyntax:
            Return "Invalid JSON syntax"
        When InvalidUTF8:
            Return "Invalid UTF-8 encoding"
        When NumberOverflow:
            Return "Number value overflow"
        When MaxDepthExceeded:
            Return "Maximum nesting depth exceeded"
        When InvalidEscapeSequence:
            Return "Invalid escape sequence"
        When TrailingComma:
            Return "Trailing comma not allowed"
        When DuplicateKey:
            Return "Duplicate key in object"
        When SchemaViolation:
            Return "Schema validation failed"
        Otherwise:
            Return "Unknown validation error"

Process called "parse_next_token" that takes parser as JSONParser returns Optional[JSONToken]:
    skip_whitespace with parser as parser
    Let char be peek_next_character with parser as parser
    If char is equal to "":
        Return None
    Let location be SourceLocation with:
        line as parser.current_position.line_number
        column as parser.current_position.column_number
        byte_offset as parser.current_position.byte_position
        character_offset as parser.current_position.character_position
    Match char:
        When "{":
            consume_character with parser as parser
            Return JSONToken with token_type as LeftBrace and value as "{" and location as location
        When "}":
            consume_character with parser as parser
            Return JSONToken with token_type as RightBrace and value as "}" and location as location
        When "[":
            consume_character with parser as parser
            Return JSONToken with token_type as LeftBracket and value as "[" and location as location
        When "]":
            consume_character with parser as parser
            Return JSONToken with token_type as RightBracket and value as "]" and location as location
        When ",":
            consume_character with parser as parser
            Return JSONToken with token_type as Comma and value as "," and location as location
        When ":":
            consume_character with parser as parser
            Return JSONToken with token_type as Colon and value as ":" and location as location
        When "\"":
            Let string_value be parse_string_value with parser as parser
            Return JSONToken with token_type as StringToken and value as string_value.data and location as location
        Otherwise:
            If is_numeric_start with char as char:
                Let number_value be parse_number_value with parser as parser
                Return JSONToken with token_type as NumberToken and value as number_value.data and location as location
            Else if char is equal to "t" or char is equal to "f":
                Let bool_value be parse_boolean_value with parser as parser
                Return JSONToken with token_type as BoolToken and value as bool_value.data and location as location
            Else if char is equal to "n":
                Let null_value be parse_null_value with parser as parser
                Return JSONToken with token_type as NullToken and value as null and location as location
            Otherwise:
                Return None

Process called "generate_validator_id" returns String:
    Let timestamp be DateTime.now_milliseconds()
    Return String.concat with parts as list containing "JSON-VALIDATOR-", timestamp

Process called "generate_reader_id" returns String:
    Let timestamp be DateTime.now_milliseconds()
    Return String.concat with parts as list containing "JSON-READER-", timestamp

Process called "generate_writer_id" returns String:
    Let timestamp be DateTime.now_milliseconds()
    Return String.concat with parts as list containing "JSON-WRITER-", timestamp