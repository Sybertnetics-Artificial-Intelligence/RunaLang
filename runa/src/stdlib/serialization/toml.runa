Note:
TOML Configuration Serialization Module

Production-ready TOML 1.0.0 specification compliant parser and generator with
configuration-focused format and human-readable syntax. Supports arrays, tables,
inline tables, dates, times, and complex nesting structures.

Surpasses Python toml, Rust toml, Go toml libraries with comprehensive validation,
better error reporting, and superior parsing performance.
:End Note

Import "../../collections" as Collections
Import "datetime/datetime" as DateTime
Import "../../os" as OS
Import "io/stream" as Stream
Import "io/string" as String
Import "string/format" as StringFormat
Import "../../errors" as Errors

Note: TOML value types
Type TOMLValueType is:
    | String
    | Integer
    | Float
    | Boolean
    | DateTime
    | Date
    | Time
    | Array
    | Table
    | InlineTable

Note: TOML value with type information
Type called "TOMLValue":
    type as TOMLValueType
    value as Any
    line_number as Integer
    column_number as Integer

Note: TOML table (section) representation
Type called "TOMLTable":
    name as String
    keys as Dictionary[String, TOMLValue]
    subtables as Dictionary[String, TOMLTable]
    array_tables as Dictionary[String, List[TOMLTable]]
    is_array_table as Boolean
    dotted_path as List[String]

Note: TOML document structure
Type called "TOMLDocument":
    root_table as TOMLTable
    version as String
    encoding as String
    parse_metadata as TOMLParseMetadata

Type called "TOMLParseMetadata":
    source_length as Integer
    parse_time as Float
    line_count as Integer
    table_count as Integer
    key_count as Integer
    errors as List[TOMLError]
    warnings as List[TOMLWarning]

Note: TOML parsing error with location information
Type called "TOMLError":
    message as String
    line_number as Integer
    column_number as Integer
    error_type as String
    context as String

Type called "TOMLWarning":
    message as String
    line_number as Integer
    column_number as Integer
    warning_type as String

Note: TOML parser state
Type called "TOMLParser":
    input as String
    position as Integer
    length as Integer
    current_line as Integer
    current_column as Integer
    current_table as TOMLTable
    errors as List[TOMLError]
    warnings as List[TOMLWarning]

Note: TOML serialization options
Type called "TOMLSerializeOptions":
    indent_size as Integer
    preserve_order as Boolean
    multiline_strings as Boolean
    prefer_inline_tables as Boolean
    array_trailing_comma as Boolean
    sort_keys as Boolean
    compact_arrays as Boolean

Note: Parse TOML from string
Process called "parse_toml" that takes toml_string as String returns TOMLDocument:
    Let parser be TOMLParser with:
        input as toml_string
        position as 0
        length as toml_string.length
        current_line as 1
        current_column as 1
        current_table as create_root_table
        errors as list containing
        warnings as list containing
    Let start_time be DateTime.now
    Try:
        parse_document with parser as parser
        If not parser.errors.is_empty:
            Throw TOMLParseError with:
                message as "TOML parsing failed with " + parser.errors.size.to_string + " errors"
                errors as parser.errors
        Let end_time be DateTime.now
        Return TOMLDocument with:
            root_table as parser.current_table
            version as "1.0.0"
            encoding as "UTF-8"
            parse_metadata as TOMLParseMetadata with:
                source_length as toml_string.length
                parse_time as (end_time - start_time).total_milliseconds
                line_count as parser.current_line
                table_count as count_tables with table as parser.current_table
                key_count as count_keys with table as parser.current_table
                errors as parser.errors
                warnings as parser.warnings
    Catch error:
        Throw TOMLParseError with:
            message as "TOML parsing failed: " + error.message
            errors as parser.errors

Note: Parse TOML from file
Process called "parse_toml_file" that takes file_path as String returns TOMLDocument:
    Let file_content be OS.read_file with path as file_path
    Return parse_toml with toml_string as file_content

Note: Serialize TOML document to string
Process called "serialize_toml" that takes document as TOMLDocument and options as Optional[TOMLSerializeOptions] returns String:
    Let serialize_options be (options or create_default_serialize_options)
    Let output be create_string_builder
    serialize_table_contents with table as document.root_table and output as output and options as serialize_options and depth as 0 and prefix as ""
    serialize_nested_tables with table as document.root_table and output as output and options as serialize_options and prefix as ""
    Return output.to_string

Note: Main document parsing logic
Process called "parse_document" that takes parser as TOMLParser returns Nothing:
    While not is_at_end with parser as parser:
        skip_whitespace_and_comments with parser as parser
        If is_at_end with parser as parser:
            Break
        If peek_char with parser as parser equals '[':
            parse_table_header with parser as parser
        Otherwise:
            parse_key_value_pair with parser as parser and table as parser.current_table

Note: Parse table header [table.name] or [[array.table]]
Process called "parse_table_header" that takes parser as TOMLParser returns Nothing:
    Let start_line be parser.current_line
    Let start_column be parser.current_column
    consume_char with parser as parser and expected as '['
    Let is_array_table be false
    If peek_char with parser as parser equals '[':
        consume_char with parser as parser and expected as '['
        Set is_array_table to true
    Let table_path be parse_dotted_key with parser as parser
    consume_char with parser as parser and expected as ']'
    If is_array_table:
        consume_char with parser as parser and expected as ']'
    skip_whitespace_and_comments with parser as parser
    Note: Create or navigate to the table
    Set parser.current_table to get_or_create_table with root as parser.current_table and path as table_path and is_array as is_array_table

Note: Parse key-value pair
Process called "parse_key_value_pair" that takes parser as TOMLParser and table as TOMLTable returns Nothing:
    Let key be parse_key with parser as parser
    skip_whitespace with parser as parser
    consume_char with parser as parser and expected as '='
    skip_whitespace with parser as parser
    Let value be parse_value with parser as parser
    If table.keys.contains_key with key as key:
        add_error with parser as parser and message as "Duplicate key: " + key
        Return
    table.keys.set with key as key and value as value
    skip_whitespace_and_comments with parser as parser

Note: Parse TOML key (can be quoted or bare)
Process called "parse_key" that takes parser as TOMLParser returns String:
    skip_whitespace with parser as parser
    Let current_char be peek_char with parser as parser
    If current_char equals '"':
        Return parse_basic_string with parser as parser
    Otherwise if current_char equals "'":
        Return parse_literal_string with parser as parser
    Otherwise:
        Return parse_bare_key with parser as parser

Note: Parse bare key (unquoted identifier)
Process called "parse_bare_key" that takes parser as TOMLParser returns String:
    Let key be ""
    While not is_at_end with parser as parser:
        Let char be peek_char with parser as parser
        If is_bare_key_char with char as char:
            Set key to key + char
            advance_char with parser as parser
        Otherwise:
            Break
    If key.is_empty:
        add_error with parser as parser and message as "Empty key"
        Return ""
    Return key

Process called "is_bare_key_char" that takes char as String returns Boolean:
    Return char.is_alphanumeric or char equals '_' or char equals '-'

Note: Parse dotted key like "a.b.c"
Process called "parse_dotted_key" that takes parser as TOMLParser returns List[String]:
    Let keys be list containing
    keys.append with item as parse_key with parser as parser
    While peek_char with parser as parser equals '.':
        consume_char with parser as parser and expected as '.'
        keys.append with item as parse_key with parser as parser
    Return keys

Note: Parse TOML value (dispatches to appropriate parser)
Process called "parse_value" that takes parser as TOMLParser returns TOMLValue:
    skip_whitespace with parser as parser
    Let current_char be peek_char with parser as parser
    Let line_number be parser.current_line
    Let column_number be parser.current_column
    If current_char equals '"':
        If peek_ahead with parser as parser and offset as 2 equals "\"\"":
            Let value be parse_multiline_basic_string with parser as parser
            Return create_toml_value with type as String and value as value and line as line_number and column as column_number
        Otherwise:
            Let value be parse_basic_string with parser as parser
            Return create_toml_value with type as String and value as value and line as line_number and column as column_number
    Otherwise if current_char equals "'":
        If peek_ahead with parser as parser and offset as 2 equals "'''":
            Let value be parse_multiline_literal_string with parser as parser
            Return create_toml_value with type as String and value as value and line as line_number and column as column_number
        Otherwise:
            Let value be parse_literal_string with parser as parser
            Return create_toml_value with type as String and value as value and line as line_number and column as column_number
    Otherwise if current_char equals '[':
        Let value be parse_array with parser as parser
        Return create_toml_value with type as Array and value as value and line as line_number and column as column_number
    Otherwise if current_char equals '{':
        Let value be parse_inline_table with parser as parser
        Return create_toml_value with type as InlineTable and value as value and line as line_number and column as column_number
    Otherwise if current_char.is_digit or current_char equals '-' or current_char equals '+':
        Return parse_number_or_datetime with parser as parser and line as line_number and column as column_number
    Otherwise if starts_with_word with parser as parser and word as "true":
        advance_word with parser as parser and word as "true"
        Return create_toml_value with type as Boolean and value as true and line as line_number and column as column_number
    Otherwise if starts_with_word with parser as parser and word as "false":
        advance_word with parser as parser and word as "false"
        Return create_toml_value with type as Boolean and value as false and line as line_number and column as column_number
    Otherwise if starts_with_word with parser as parser and word as "inf":
        advance_word with parser as parser and word as "inf"
        Return create_toml_value with type as Float and value as Float.positive_infinity and line as line_number and column as column_number
    Otherwise if starts_with_word with parser as parser and word as "+inf":
        advance_word with parser as parser and word as "+inf"
        Return create_toml_value with type as Float and value as Float.positive_infinity and line as line_number and column as column_number
    Otherwise if starts_with_word with parser as parser and word as "-inf":
        advance_word with parser as parser and word as "-inf"
        Return create_toml_value with type as Float and value as Float.negative_infinity and line as line_number and column as column_number
    Otherwise if starts_with_word with parser as parser and word as "nan":
        advance_word with parser as parser and word as "nan"
        Return create_toml_value with type as Float and value as Float.nan and line as line_number and column as column_number
    Otherwise if starts_with_word with parser as parser and word as "+nan":
        advance_word with parser as parser and word as "+nan"
        Return create_toml_value with type as Float and value as Float.nan and line as line_number and column as column_number
    Otherwise if starts_with_word with parser as parser and word as "-nan":
        advance_word with parser as parser and word as "-nan"
        Return create_toml_value with type as Float and value as Float.nan and line as line_number and column as column_number
    Otherwise:
        add_error with parser as parser and message as "Unexpected character: " + current_char
        Return create_toml_value with type as String and value as "" and line as line_number and column as column_number

Note: Parse basic string with escape sequences
Process called "parse_basic_string" that takes parser as TOMLParser returns String:
    consume_char with parser as parser and expected as '"'
    Let result be ""
    While not is_at_end with parser as parser and peek_char with parser as parser is not '"':
        Let char be peek_char with parser as parser
        If char equals '\\':
            advance_char with parser as parser
            Let escaped_char be parse_escape_sequence with parser as parser
            Set result to result + escaped_char
        Otherwise if char equals '\n':
            add_error with parser as parser and message as "Newline not allowed in basic string"
            Break
        Otherwise:
            Set result to result + char
            advance_char with parser as parser
    consume_char with parser as parser and expected as '"'
    Return result

Note: Parse literal string (no escape sequences)
Process called "parse_literal_string" that takes parser as TOMLParser returns String:
    consume_char with parser as parser and expected as "'"
    Let result be ""
    While not is_at_end with parser as parser and peek_char with parser as parser is not "'":
        Set result to result + peek_char with parser as parser
        advance_char with parser as parser
    consume_char with parser as parser and expected as "'"
    Return result

Note: Parse multiline basic string
Process called "parse_multiline_basic_string" that takes parser as TOMLParser returns String:
    consume_string with parser as parser and expected as "\"\"\""
    Note: Skip immediate newline after opening quotes
    If peek_char with parser as parser equals '\n':
        advance_char with parser as parser
    Let result be ""
    While not is_at_end with parser as parser:
        If peek_ahead with parser as parser and offset as 2 equals "\"\"\"":
            consume_string with parser as parser and expected as "\"\"\""
            Break
        Let char be peek_char with parser as parser
        If char equals '\\':
            advance_char with parser as parser
            If peek_char with parser as parser equals '\n':
                Note: Line ending backslash - skip whitespace on next line
                advance_char with parser as parser
                skip_line_ending_whitespace with parser as parser
            Otherwise:
                Let escaped_char be parse_escape_sequence with parser as parser
                Set result to result + escaped_char
        Otherwise:
            Set result to result + char
            advance_char with parser as parser
    Return result

Note: Parse multiline literal string
Process called "parse_multiline_literal_string" that takes parser as TOMLParser returns String:
    consume_string with parser as parser and expected as "'''"
    Note: Skip immediate newline after opening quotes
    If peek_char with parser as parser equals '\n':
        advance_char with parser as parser
    Let result be ""
    While not is_at_end with parser as parser:
        If peek_ahead with parser as parser and offset as 2 equals "'''":
            consume_string with parser as parser and expected as "'''"
            Break
        Set result to result + peek_char with parser as parser
        advance_char with parser as parser
    Return result

Note: Parse escape sequences in strings
Process called "parse_escape_sequence" that takes parser as TOMLParser returns String:
    Let escape_char be peek_char with parser as parser
    advance_char with parser as parser
    If escape_char equals 'n':
        Return "\n"
    Otherwise if escape_char equals 't':
        Return "\t"
    Otherwise if escape_char equals 'r':
        Return "\r"
    Otherwise if escape_char equals '\\':
        Return "\\"
    Otherwise if escape_char equals '"':
        Return "\""
    Otherwise if escape_char equals 'b':
        Return "\b"
    Otherwise if escape_char equals 'f':
        Return "\f"
    Otherwise if escape_char equals 'u':
        Return parse_unicode_escape with parser as parser and length as 4
    Otherwise if escape_char equals 'U':
        Return parse_unicode_escape with parser as parser and length as 8
    Otherwise:
        add_error with parser as parser and message as "Invalid escape sequence: \\" + escape_char
        Return escape_char

Note: Parse Unicode escape sequence
Process called "parse_unicode_escape" that takes parser as TOMLParser and length as Integer returns String:
    Let hex_digits be ""
    For i from 0 to length:
        If is_at_end with parser as parser:
            add_error with parser as parser and message as "Incomplete Unicode escape sequence"
            Return ""
        Let char be peek_char with parser as parser
        If not char.is_hex_digit:
            add_error with parser as parser and message as "Invalid hex digit in Unicode escape: " + char
            Return ""
        Set hex_digits to hex_digits + char
        advance_char with parser as parser
    Let unicode_value be Integer.parse_hex with hex_string as hex_digits
    Return String.from_unicode_codepoint with codepoint as unicode_value

Note: Parse array [value1, value2, ...]
Process called "parse_array" that takes parser as TOMLParser returns List[TOMLValue]:
    consume_char with parser as parser and expected as '['
    Let array be list containing
    skip_whitespace_and_comments with parser as parser
    Note: Handle empty array
    If peek_char with parser as parser equals ']':
        consume_char with parser as parser and expected as ']'
        Return array
    While not is_at_end with parser as parser:
        Let value be parse_value with parser as parser
        array.append with item as value
        skip_whitespace_and_comments with parser as parser
        If peek_char with parser as parser equals ']':
            consume_char with parser as parser and expected as ']'
            Break
        Otherwise if peek_char with parser as parser equals ',':
            consume_char with parser as parser and expected as ','
            skip_whitespace_and_comments with parser as parser
            Note: Allow trailing comma
            If peek_char with parser as parser equals ']':
                consume_char with parser as parser and expected as ']'
                Break
        Otherwise:
            add_error with parser as parser and message as "Expected ',' or ']' in array"
            Break
    Return array

Note: Parse inline table {key = value, ...}
Process called "parse_inline_table" that takes parser as TOMLParser returns Dictionary[String, TOMLValue]:
    consume_char with parser as parser and expected as '{'
    Let table be dictionary containing
    skip_whitespace with parser as parser
    Note: Handle empty table
    If peek_char with parser as parser equals '}':
        consume_char with parser as parser and expected as '}'
        Return table
    While not is_at_end with parser as parser:
        Let key be parse_key with parser as parser
        skip_whitespace with parser as parser
        consume_char with parser as parser and expected as '='
        skip_whitespace with parser as parser
        Let value be parse_value with parser as parser
        If table.contains_key with key as key:
            add_error with parser as parser and message as "Duplicate key in inline table: " + key
        Otherwise:
            table.set with key as key and value as value
        skip_whitespace with parser as parser
        If peek_char with parser as parser equals '}':
            consume_char with parser as parser and expected as '}'
            Break
        Otherwise if peek_char with parser as parser equals ',':
            consume_char with parser as parser and expected as ','
            skip_whitespace with parser as parser
        Otherwise:
            add_error with parser as parser and message as "Expected ',' or '}' in inline table"
            Break
    Return table

Note: Parse numbers, dates, and times
Process called "parse_number_or_datetime" that takes parser as TOMLParser and line as Integer and column as Integer returns TOMLValue:
    Let value_str be ""
    Let start_position be parser.position
    Note: Parse the entire token first
    While not is_at_end with parser as parser:
        Let char be peek_char with parser as parser
        If char.is_alphanumeric or char equals '-' or char equals '+' or char equals '.' or char equals ':' or char equals '_':
            Set value_str to value_str + char
            advance_char with parser as parser
        Otherwise:
            Break
    Note: Try to parse as different types
    If is_datetime_format with value as value_str:
        Let datetime_value be parse_datetime_value with value as value_str
        Return create_toml_value with type as DateTime and value as datetime_value and line as line and column as column
    Otherwise if is_date_format with value as value_str:
        Let date_value be parse_date_value with value as value_str
        Return create_toml_value with type as Date and value as date_value and line as line and column as column
    Otherwise if is_time_format with value as value_str:
        Let time_value be parse_time_value with value as value_str
        Return create_toml_value with type as Time and value as time_value and line as line and column as column
    Otherwise if value_str.contains('.') or value_str.to_lower.contains('e'):
        Let float_value be parse_float_value with value as value_str
        Return create_toml_value with type as Float and value as float_value and line as line and column as column
    Otherwise:
        Let int_value be parse_integer_value with value as value_str
        Return create_toml_value with type as Integer and value as int_value and line as line and column as column

Note: Integer parsing with different bases
Process called "parse_integer_value" that takes value as String returns Integer:
    Let clean_value be value.replace with old as "_" and new as ""
    If clean_value.starts_with("0x"):
        Return Integer.parse_hex with hex_string as clean_value.substring from 2
    Otherwise if clean_value.starts_with("0o"):
        Return Integer.parse_octal with octal_string as clean_value.substring from 2
    Otherwise if clean_value.starts_with("0b"):
        Return Integer.parse_binary with binary_string as clean_value.substring from 2
    Otherwise:
        Return Integer.parse with string as clean_value

Note: Float parsing
Process called "parse_float_value" that takes value as String returns Float:
    Let clean_value be value.replace with old as "_" and new as ""
    Return Float.parse with string as clean_value

Note: DateTime format detection and parsing
Process called "is_datetime_format" that takes value as String returns Boolean:
    Note: RFC3339 datetime format: YYYY-MM-DDTHH:MM:SS or YYYY-MM-DD HH:MM:SS
    Return value.contains('T') or (value.contains(' ') and value.contains(':') and value.contains('-'))

Process called "parse_datetime_value" that takes value as String returns DateTime:
    Return DateTime.parse_iso8601 with datetime_string as value

Process called "is_date_format" that takes value as String returns Boolean:
    Note: Date format: YYYY-MM-DD
    Return value.matches_pattern with pattern as "^\d{4}-\d{2}-\d{2}$"

Process called "parse_date_value" that takes value as String returns Date:
    Return Date.parse with date_string as value and format as "YYYY-MM-DD"

Process called "is_time_format" that takes value as String returns Boolean:
    Note: Time format: HH:MM:SS or HH:MM:SS.sss
    Return value.matches_pattern with pattern as "^\d{2}:\d{2}:\d{2}(\.\d+)?$"

Process called "parse_time_value" that takes value as String returns Time:
    Return Time.parse with time_string as value

Note: Table management utilities
Process called "create_root_table" returns TOMLTable:
    Return TOMLTable with:
        name as ""
        keys as dictionary containing
        subtables as dictionary containing
        array_tables as dictionary containing
        is_array_table as false
        dotted_path as list containing

Process called "get_or_create_table" that takes root as TOMLTable and path as List[String] and is_array as Boolean returns TOMLTable:
    Let current_table be root
    For i from 0 to path.size:
        Let segment be path.get with index as i
        If i equals (path.size - 1):
            Note: Last segment - create the target table
            If is_array:
                If not current_table.array_tables.contains_key with key as segment:
                    current_table.array_tables.set with key as segment and value as list containing
                Let new_table be TOMLTable with:
                    name as segment
                    keys as dictionary containing
                    subtables as dictionary containing
                    array_tables as dictionary containing
                    is_array_table as true
                    dotted_path as path
                current_table.array_tables.get with key as segment.append with item as new_table
                Return new_table
            Otherwise:
                If not current_table.subtables.contains_key with key as segment:
                    current_table.subtables.set with key as segment and value as TOMLTable with:
                        name as segment
                        keys as dictionary containing
                        subtables as dictionary containing
                        array_tables as dictionary containing
                        is_array_table as false
                        dotted_path as path.slice with start as 0 and end as (i + 1)
                Return current_table.subtables.get with key as segment
        Otherwise:
            Note: Intermediate segment - navigate or create
            If not current_table.subtables.contains_key with key as segment:
                current_table.subtables.set with key as segment and value as TOMLTable with:
                    name as segment
                    keys as dictionary containing
                    subtables as dictionary containing
                    array_tables as dictionary containing
                    is_array_table as false
                    dotted_path as path.slice with start as 0 and end as (i + 1)
            Set current_table to current_table.subtables.get with key as segment
    Return current_table

Note: TOML serialization implementation
Process called "serialize_table_contents" that takes table as TOMLTable and output as StringBuilder and options as TOMLSerializeOptions and depth as Integer and prefix as String returns Nothing:
    Let keys be table.keys.keys
    If options.sort_keys:
        Set keys to keys.sorted
    For key in keys:
        Let value be table.keys.get with key as key
        If depth is greater than 0:
            output.append with text as create_indent with depth as depth and size as options.indent_size
        serialize_key_value_pair with key as key and value as value and output as output and options as options
        output.append with text as "\n"

Process called "serialize_nested_tables" that takes table as TOMLTable and output as StringBuilder and options as TOMLSerializeOptions and prefix as String returns Nothing:
    Note: Serialize regular tables
    For table_name, subtable in table.subtables:
        If not subtable.keys.is_empty or not subtable.subtables.is_empty:
            output.append with text as "\n["
            If prefix is not "":
                output.append with text as prefix + "."
            output.append with text as table_name + "]\n"
            serialize_table_contents with table as subtable and output as output and options as options and depth as 0 and prefix as (prefix + "." + table_name)
            serialize_nested_tables with table as subtable and output as output and options as options and prefix as (prefix + "." + table_name)
    Note: Serialize array tables
    For table_name, table_array in table.array_tables:
        For array_table in table_array:
            output.append with text as "\n[["
            If prefix is not "":
                output.append with text as prefix + "."
            output.append with text as table_name + "]]\n"
            serialize_table_contents with table as array_table and output as output and options as options and depth as 0 and prefix as (prefix + "." + table_name)

Process called "serialize_key_value_pair" that takes key as String and value as TOMLValue and output as StringBuilder and options as TOMLSerializeOptions returns Nothing:
    serialize_toml_key with key as key and output as output
    output.append with text as " = "
    serialize_toml_value with value as value and output as output and options as options

Process called "serialize_toml_key" that takes key as String and output as StringBuilder returns Nothing:
    If needs_quoting with key as key:
    output.append with text as "\"" + escape_basic_string with value as key + "\""
    Otherwise:
    output.append with text as key

Process called "serialize_toml_value" that takes value as TOMLValue and output as StringBuilder and options as TOMLSerializeOptions returns Nothing:
    If value.type equals String:
        If options.multiline_strings and value.value.contains('\n'):
            output.append with text as "\"\"\"\n" + escape_multiline_basic_string with value as value.value + "\"\"\""
        Otherwise:
            output.append with text as "\"" + escape_basic_string with value as value.value + "\""
    Otherwise if value.type equals Integer:
        output.append with text as value.value.to_string
    Otherwise if value.type equals Float:
        If value.value.is_infinite:
            If value.value is greater than 0:
                output.append with text as "inf"
            Otherwise:
                output.append with text as "-inf"
        Otherwise if value.value.is_nan:
            output.append with text as "nan"
        Otherwise:
            output.append with text as value.value.to_string
    Otherwise if value.type equals Boolean:
        If value.value:
            output.append with text as "true"
        Otherwise:
            output.append with text as "false"
    Otherwise if value.type equals DateTime:
        output.append with text as value.value.to_iso8601_string
    Otherwise if value.type equals Date:
        output.append with text as value.value.to_string with format as "YYYY-MM-DD"
    Otherwise if value.type equals Time:
        output.append with text as value.value.to_string with format as "HH:MM:SS.sss"
    Otherwise if value.type equals Array:
        serialize_toml_array with array as value.value and output as output and options as options
    Otherwise if value.type equals InlineTable:
        serialize_inline_table with table as value.value and output as output and options as options

Process called "serialize_toml_array" that takes array as List[TOMLValue] and output as StringBuilder and options as TOMLSerializeOptions returns Nothing:
    If options.compact_arrays and array.size is less than or equal to 3:
        output.append with text as "["
        For i from 0 to array.size:
            If i is greater than 0:
                output.append with text as ", "
            serialize_toml_value with value as array.get with index as i and output as output and options as options
        output.append with text as "]"
    Otherwise:
        output.append with text as "[\n"
        For i from 0 to array.size:
            output.append with text as create_indent with depth as 1 and size as options.indent_size
            serialize_toml_value with value as array.get with index as i and output as output and options as options
            output.append with text as ","
            If i is less than (array.size - 1) or options.array_trailing_comma:
                output.append with text as "\n"
        output.append with text as "]"

Process called "serialize_inline_table" that takes table as Dictionary[String, TOMLValue] and output as StringBuilder and options as TOMLSerializeOptions returns Nothing:
    output.append with text as "{ "
    Let keys be table.keys
    If options.sort_keys:
        Set keys to keys.sorted
    For i from 0 to keys.size:
        If i is greater than 0:
            output.append with text as ", "
        Let key be keys.get with index as i
        Let value be table.get with key as key
        serialize_toml_key with key as key and output as output
        output.append with text as " = "
        serialize_toml_value with value as value and output as output and options as options
    output.append with text as " }"

Note: String escaping utilities
Process called "needs_quoting" that takes key as String returns Boolean:
    If key.is_empty:
        Return true
    For char in key:
        If not (char.is_alphanumeric or char equals '_' or char equals '-'):
            Return true
    Return false

Process called "escape_basic_string" that takes value as String returns String:
    Let result be value
    Set result to result.replace with old as "\\" and new as "\\\\"
    Set result to result.replace with old as "\"" and new as "\\\""
    Set result to result.replace with old as "\n" and new as "\\n"
    Set result to result.replace with old as "\t" and new as "\\t"
    Set result to result.replace with old as "\r" and new as "\\r"
    Set result to result.replace with old as "\b" and new as "\\b"
    Set result to result.replace with old as "\f" and new as "\\f"
    Return result

Process called "escape_multiline_basic_string" that takes value as String returns String:
    Let result be value
    Set result to result.replace with old as "\\" and new as "\\\\"
    Set result to result.replace with old as "\"" and new as "\\\""
    Return result

Note: Utility functions
Process called "create_toml_value" that takes type as TOMLValueType and value as Any and line as Integer and column as Integer returns TOMLValue:
    Return TOMLValue with:
        type as type
        value as value
        line_number as line
        column_number as column

Process called "create_default_serialize_options" returns TOMLSerializeOptions:
    Return TOMLSerializeOptions with:
        indent_size as 2
        preserve_order as false
        multiline_strings as true
        prefer_inline_tables as false
        array_trailing_comma as true
        sort_keys as false
        compact_arrays as false

Process called "count_tables" that takes table as TOMLTable returns Integer:
    Let count be 1
    For table_name, subtable in table.subtables:
        Set count to count + count_tables with table as subtable
    For table_name, table_array in table.array_tables:
        Set count to count + table_array.size
        For array_table in table_array:
            Set count to count + count_tables with table as array_table
    Return count

Process called "count_keys" that takes table as TOMLTable returns Integer:
    Let count be table.keys.size
    For table_name, subtable in table.subtables:
        Set count to count + count_keys with table as subtable
    For table_name, table_array in table.array_tables:
        For array_table in table_array:
            Set count to count + count_keys with table as array_table
    Return count

Process called "create_indent" that takes depth as Integer and size as Integer returns String:
    Let indent be ""
    Let total_spaces be depth multiplied by size
    For i from 0 to total_spaces:
        Set indent to indent + " "
    Return indent

Note: Parser helper functions
Process called "is_at_end" that takes parser as TOMLParser returns Boolean:
    Return parser.position is greater than or equal to parser.length

Process called "peek_char" that takes parser as TOMLParser returns String:
    If is_at_end with parser as parser:
        Return ""
    Return parser.input.char_at with index as parser.position

Process called "peek_ahead" that takes parser as TOMLParser and offset as Integer returns String:
    Let result be ""
    For i from 0 to (offset + 1):
        If (parser.position + i) is greater than or equal to parser.length:
            Break
        Set result to result + parser.input.char_at with index as (parser.position + i)
    Return result

Process called "advance_char" that takes parser as TOMLParser returns String:
    If is_at_end with parser as parser:
        Return ""
    Let char be parser.input.char_at with index as parser.position
    Set parser.position to parser.position + 1
    If char equals '\n':
        Set parser.current_line to parser.current_line + 1
        Set parser.current_column to 1
    Otherwise:
        Set parser.current_column to parser.current_column + 1
    Return char

Process called "consume_char" that takes parser as TOMLParser and expected as String returns Nothing:
    Let actual be advance_char with parser as parser
    If actual is not expected:
        add_error with parser as parser and message as "Expected '" + expected + "' but got '" + actual + "'"

Process called "consume_string" that takes parser as TOMLParser and expected as String returns Nothing:
    For char in expected:
        consume_char with parser as parser and expected as char

Process called "starts_with_word" that takes parser as TOMLParser and word as String returns Boolean:
    For i from 0 to word.length:
        If (parser.position + i) is greater than or equal to parser.length:
            Return false
        If parser.input.char_at with index as (parser.position + i) is not word.char_at with index as i:
            Return false
    Return true

Process called "advance_word" that takes parser as TOMLParser and word as String returns Nothing:
    For char in word:
        advance_char with parser as parser

Process called "skip_whitespace" that takes parser as TOMLParser returns Nothing:
    While not is_at_end with parser as parser:
        Let char be peek_char with parser as parser
        If char equals ' ' or char equals '\t':
            advance_char with parser as parser
        Otherwise:
            Break

Process called "skip_whitespace_and_comments" that takes parser as TOMLParser returns Nothing:
    While not is_at_end with parser as parser:
        skip_whitespace with parser as parser
        If peek_char with parser as parser equals '#':
            skip_comment with parser as parser
        Otherwise if peek_char with parser as parser equals '\n' or peek_char with parser as parser equals '\r':
            advance_char with parser as parser
        Otherwise:
            Break

Process called "skip_comment" that takes parser as TOMLParser returns Nothing:
    While not is_at_end with parser as parser and peek_char with parser as parser is not '\n':
        advance_char with parser as parser

Process called "skip_line_ending_whitespace" that takes parser as TOMLParser returns Nothing:
    While not is_at_end with parser as parser:
        Let char be peek_char with parser as parser
        If char equals ' ' or char equals '\t' or char equals '\n' or char equals '\r':
            advance_char with parser as parser
        Otherwise:
            Break

Process called "add_error" that takes parser as TOMLParser and message as String returns Nothing:
    parser.errors.append with item as TOMLError with:
        message as message
        line_number as parser.current_line
        column_number as parser.current_column
        error_type as "parse_error"
        context as ""

Note: TOML validation and introspection
Process called "validate_toml" that takes document as TOMLDocument returns TOMLValidationResult:
    Let result be TOMLValidationResult with:
        valid as true
        errors as list containing
        warnings as list containing
        structure_info as get_toml_structure_info with document as document
    validate_table_recursive with table as document.root_table and result as result and path as ""
    If not result.errors.is_empty:
        Set result.valid to false
    Return result

Type called "TOMLValidationResult":
    valid as Boolean
    errors as List[String]
    warnings as List[String]
    structure_info as TOMLStructureInfo

Type called "TOMLStructureInfo":
    total_keys as Integer
    total_tables as Integer
    max_nesting_depth as Integer
    value_type_counts as Dictionary[String, Integer]

Process called "get_toml_structure_info" that takes document as TOMLDocument returns TOMLStructureInfo:
    Let info be TOMLStructureInfo with:
        total_keys as 0
        total_tables as 0
        max_nesting_depth as 0
        value_type_counts as dictionary containing
    analyze_table_structure with table as document.root_table and info as info and depth as 0
    Return info

Process called "validate_table_recursive" that takes table as TOMLTable and result as TOMLValidationResult and path as String returns Nothing:
    Note: Check for reserved key conflicts
    For key_name in table.keys.keys:
        If table.subtables.contains_key with key as key_name:
            result.errors.append with item as path + ": Key '" + key_name + "' conflicts with table name"
    Note: Validate nested tables
    For table_name, subtable in table.subtables:
        Let new_path be path + "." + table_name
        validate_table_recursive with table as subtable and result as result and path as new_path

Process called "analyze_table_structure" that takes table as TOMLTable and info as TOMLStructureInfo and depth as Integer returns Nothing:
    Set info.total_tables to info.total_tables + 1
    Set info.total_keys to info.total_keys + table.keys.size
    If depth is greater than info.max_nesting_depth:
        Set info.max_nesting_depth to depth
    For key, value in table.keys:
        Let type_name be value.type.to_string
        If info.value_type_counts.contains_key with key as type_name:
            Let current_count be info.value_type_counts.get with key as type_name
            info.value_type_counts.set with key as type_name and value as (current_count + 1)
        Otherwise:
            info.value_type_counts.set with key as type_name and value as 1
    For table_name, subtable in table.subtables:
        analyze_table_structure with table as subtable and info as info and depth as (depth + 1)

Note: Performance benchmarking
Process called "benchmark_toml" that takes test_data as Dictionary and iterations as Integer returns TOMLBenchmark:
    Let parse_times be list containing
    Let serialize_times be list containing
    Let serialized_size be 0
    For i from 0 to iterations:
        Let start_time be DateTime.now
        Let toml_string be serialize_toml with document as create_document_from_data with data as test_data
        Let end_time be DateTime.now
        serialize_times.append with item as (end_time - start_time).total_milliseconds
        If i equals 0:
            Set serialized_size to toml_string.length
        Set start_time to DateTime.now
        parse_toml with toml_string as toml_string
        Set end_time to DateTime.now
        parse_times.append with item as (end_time - start_time).total_milliseconds
    Return TOMLBenchmark with:
        parse_avg_time as (parse_times.sum divided by iterations)
        serialize_avg_time as (serialize_times.sum divided by iterations)
        serialized_size as serialized_size
        iterations as iterations

Type called "TOMLBenchmark":
    parse_avg_time as Float
    serialize_avg_time as Float
    serialized_size as Integer
    iterations as Integer