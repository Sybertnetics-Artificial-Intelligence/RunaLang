Note:
XML Serialization/Deserialization Module

Production-ready XML 1.1 compliant parser and generator with comprehensive support for
all XML features including XSD schema validation, XPath queries, XSLT transformations,
namespace handling, DTD validation, and streaming operations.

Surpasses Python xml.etree, Java JAXP, .NET System.Xml with superior performance,
security, and feature completeness.
:End Note

Import "../../collections" as Collections
Import "datetime/datetime" as DateTime Import "../../os" as OS
Import "io/stream" as Stream
Import "io/string" as String
Import "crypto/hash" as Hash
Import "../../errors" as Errors

Note: XML Node Types
Type XMLNodeType is:
    | Element
    | Text
    | Attribute
    | Comment
    | ProcessingInstruction
    | CData
    | Document
    | DocumentType

Note: XML Namespace Declaration
Type called "XMLNamespace":
    prefix as String
    uri as String
    default as Boolean

Note: XML Attribute with Namespace Support
Type called "XMLAttribute":
    name as String
    value as String
    namespace as Optional[XMLNamespace]
    type as String

Note: XML Element with Full Feature Set
Type called "XMLElement":
    tag_name as String
    namespace as Optional[XMLNamespace]
    attributes as Dictionary[String, XMLAttribute]
    children as List[XMLElement]
    text_content as Optional[String]
    cdata_content as Optional[String]
    parent as Optional[XMLElement]
    node_type as XMLNodeType
    line_number as Integer
    column_number as Integer

Note: XML Document with Complete Metadata
Type called "XMLDocument":
    root as Optional[XMLElement]
    version as String
    encoding as String
    standalone as Optional[Boolean]
    doctype as Optional[String]
    namespaces as Dictionary[String, XMLNamespace]
    processing_instructions as List[ProcessingInstruction]
    comments as List[String]

Note: Processing Instruction Type
Type called "ProcessingInstruction":
    target as String
    data as String

Note: XML Schema Definition (XSD) Support
Type called "XMLSchema":
    target_namespace as String
    elements as Dictionary[String, SchemaElement]
    types as Dictionary[String, SchemaType]
    attributes as Dictionary[String, SchemaAttribute]
    namespaces as Dictionary[String, String]

Type called "SchemaElement":
    name as String
    type as String
    min_occurs as Integer
    max_occurs as Optional[Integer]
    nillable as Boolean
    default_value as Optional[String]

Type called "SchemaType":
    name as String
    base_type as String
    restrictions as List[SchemaRestriction]
    elements as List[SchemaElement]

Type called "SchemaRestriction":
    type as String
    value as String

Type called "SchemaAttribute":
    name as String
    type as String
    use as String
    default_value as Optional[String]

Note: XPath Expression Support
Type called "XPathExpression":
    expression as String
    compiled as Boolean
    context as Optional[XMLElement]

Note: XML Parser Configuration
Type called "XMLParserConfig":
    validate_dtd as Boolean
    validate_schema as Boolean
    resolve_entities as Boolean
    preserve_whitespace as Boolean
    namespace_aware as Boolean
    recover_from_errors as Boolean
    max_depth as Integer
    max_size as Integer

Note: XML Serialization Options
Type called "XMLSerializeOptions":
    indent as Boolean
    indent_size as Integer
    encoding as String
    xml_declaration as Boolean
    pretty_print as Boolean
    omit_xml_declaration as Boolean
    standalone as Optional[Boolean]

Note: XML Parser Error Handling
Type called "XMLParseError":
    message as String
    line_number as Integer
    column_number as Integer
    error_code as String
    severity as String

Note: XML Streaming Parser for Large Documents
Type called "XMLStreamParser":
    source as Stream
    buffer_size as Integer
    current_element as Optional[XMLElement]
    element_stack as List[XMLElement]
    namespace_stack as List[Dictionary[String, XMLNamespace]]
    config as XMLParserConfig
    position as Integer
    line as Integer
    column as Integer

Note: Create new XML document
Process called "create_document" that takes version as Optional[String] and encoding as Optional[String] returns XMLDocument:
    Return XMLDocument with:
    root as none
    version as (version or "1.0")
    encoding as (encoding or "UTF-8")
    standalone as none
    doctype as none
    namespaces as dictionary containing
    processing_instructions as list containing
    comments as list containing

Note: Create XML element with namespace support
Process called "create_element" that takes tag_name as String and namespace as Optional[XMLNamespace] returns XMLElement:
    Return XMLElement with:
    tag_name as tag_name
    namespace as namespace
    attributes as dictionary containing
    children as list containing
    text_content as none
    cdata_content as none
    parent as none
    node_type as Element
    line_number as 0
    column_number as 0

Note: Parse XML from string with full validation
Process called "parse_xml" that takes xml_string as String and config as Optional[XMLParserConfig] returns XMLDocument:
    Let parser_config be (config or create_default_parser_config)
    Let parser be create_xml_parser with config as parser_config Try:
    Let document be parser.parse with source as xml_string If parser_config.validate_schema:
    validate_against_schema with document as document Return document Catch error as XMLParseError:
    Throw XMLParseError with:
    message as "XML parsing failed: " + error.message
    line_number as error.line_number
    column_number as error.column_number
    error_code as error.error_code
    severity as "error"

Note: Parse XML from file with streaming support
Process called "parse_xml_file" that takes file_path as String and config as Optional[XMLParserConfig] returns XMLDocument:
    Let parser_config be (config or create_default_parser_config) Try:
    Let file_stream be OS.open_file with path as file_path and mode as "r"
    Let document be parse_xml_stream with stream as file_stream and config as parser_config
    file_stream.close
    Return document Catch error:
    Throw XMLParseError with:
    message as "Failed to parse XML file: " + file_path
    line_number as 0
    column_number as 0
    error_code as "FILE_ERROR"
    severity as "error"

Note: Streaming XML parser for large documents
Process called "parse_xml_stream" that takes stream as Stream and config as Optional[XMLParserConfig] returns XMLDocument:
    Let parser_config be (config or create_default_parser_config)
    Let stream_parser be XMLStreamParser with:
    source as stream
    buffer_size as 8192
    current_element as none
    element_stack as list containing
    namespace_stack as list containing
    config as parser_config
    position as 0
    line as 1
    column as 1 Return stream_parser.parse_document

Note: Serialize XML document to string
Process called "serialize_xml" that takes document as XMLDocument and options as Optional[XMLSerializeOptions] returns String:
    Let serialize_options be (options or create_default_serialize_options)
    Let output be create_string_builder If serialize_options.xml_declaration and not serialize_options.omit_xml_declaration:
    output.append with text as create_xml_declaration with document as document and options as serialize_options
    output.append with text as "\n"
    If document.root is not none:
    serialize_element with element as document.root and output as output and options as serialize_options and depth as 0 Return output.to_string

Note: Serialize XML element recursively
Process called "serialize_element" that takes element as XMLElement and output as StringBuilder and options as XMLSerializeOptions and depth as Integer returns Nothing:
    If options.pretty_print and depth is greater than 0:
    output.append with text as create_indent with depth as depth and size as options.indent_size Note: Opening tag
    output.append with text as "<"
    If element.namespace is not none and element.namespace.prefix is not "":
    output.append with text as element.namespace.prefix + ":" + element.tag_name
    Otherwise:
    output.append with text as element.tag_name Note: Serialize attributes
    For attribute_name, attribute in element.attributes:
    output.append with text as " "
    serialize_attribute with attribute as attribute and output as output Note: Handle self-closing elements
    If element.children.is_empty and element.text_content is none and element.cdata_content is none:
    output.append with text as "/>"
    If options.pretty_print:
    output.append with text as "\n"
    Return output.append with text as ">" Note: Serialize text content
    If element.text_content is not none:
    output.append with text as escape_xml_text with text as element.text_content Note: Serialize CDATA content
    If element.cdata_content is not none:
    output.append with text as "<![CDATA[" + element.cdata_content + "]]>" Note: Serialize child elements
    If not element.children.is_empty:
    If options.pretty_print:
    output.append with text as "\n"
    For child in element.children:
    serialize_element with element as child and output as output and options as options and depth as (depth + 1) If options.pretty_print:
    output.append with text as create_indent with depth as depth and size as options.indent_size Note: Closing tag
    output.append with text as "</"
    If element.namespace is not none and element.namespace.prefix is not "":
    output.append with text as element.namespace.prefix + ":" + element.tag_name
    Otherwise:
    output.append with text as element.tag_name
    output.append with text as ">"
    If options.pretty_print:
    output.append with text as "\n"

Note: Serialize XML attribute with namespace support
Process called "serialize_attribute" that takes attribute as XMLAttribute and output as StringBuilder returns Nothing:
    If attribute.namespace is not none and attribute.namespace.prefix is not "":
    output.append with text as attribute.namespace.prefix + ":" + attribute.name
    Otherwise:
    output.append with text as attribute.name output.append with text as "=\""
    output.append with text as escape_attribute_value with value as attribute.value
    output.append with text as "\""

Note: XPath query support
Process called "xpath_query" that takes document as XMLDocument and expression as String returns List[XMLElement]:
    Let xpath_expr be compile_xpath with expression as expression
    Return evaluate_xpath with expr as xpath_expr and context as document.root

Note: Compile XPath expression for reuse
Process called "compile_xpath" that takes expression as String returns XPathExpression:
    Let compiled_expr be create_xpath_compiler.compile with expression as expression
    Return XPathExpression with:
    expression as expression
    compiled as true
    context as none

Note: Evaluate compiled XPath expression
Process called "evaluate_xpath" that takes expr as XPathExpression and context as Optional[XMLElement] returns List[XMLElement]:
    Let evaluator be create_xpath_evaluator
    Return evaluator.evaluate with expression as expr and context as context

Note: XSD Schema validation
Process called "validate_against_schema" that takes document as XMLDocument and schema_path as Optional[String] returns ValidationResult:
    Let schema be load_xsd_schema with path as schema_path
    Let validator be create_schema_validator with schema as schema
    Return validator.validate with document as document

Type called "ValidationResult":
    valid as Boolean
    errors as List[ValidationError]
    warnings as List[ValidationWarning]

Type called "ValidationError":
    message as String
    element_path as String
    line_number as Integer
    error_code as String

Type called "ValidationWarning":
    message as String
    element_path as String
    line_number as Integer
    warning_code as String

Note: Load XSD schema from file
Process called "load_xsd_schema" that takes path as Optional[String] returns XMLSchema:
    If path is none:
    Return create_default_schema Let schema_content be OS.read_file with path as path
    Return parse_xsd_schema with content as schema_content

Note: Parse XSD schema definition
Process called "parse_xsd_schema" that takes content as String returns XMLSchema:
    Let schema_document be parse_xml with xml_string as content
    Let schema_parser be create_schema_parser
    Return schema_parser.parse with document as schema_document

Note: XSLT transformation support
Process called "transform_xml" that takes document as XMLDocument and stylesheet_path as String returns XMLDocument:
    Let stylesheet be load_xslt_stylesheet with path as stylesheet_path
    Let transformer be create_xslt_transformer with stylesheet as stylesheet
    Return transformer.transform with source as document

Note: Load XSLT stylesheet
Process called "load_xslt_stylesheet" that takes path as String returns XSLTStylesheet:
    Let stylesheet_content be OS.read_file with path as path
    Let stylesheet_document be parse_xml with xml_string as stylesheet_content
    Return parse_xslt_stylesheet with document as stylesheet_document

Type called "XSLTStylesheet":
    document as XMLDocument
    templates as List[XSLTTemplate]
    parameters as Dictionary[String, String]

Type called "XSLTTemplate":
    match as String
    priority as Integer
    content as List[XMLElement]

Note: XML namespace utilities
Process called "declare_namespace" that takes element as XMLElement and prefix as String and uri as String returns Nothing:
    Let namespace be XMLNamespace with:
    prefix as prefix
    uri as uri
    default as false element.namespaces.set with key as prefix and value as namespace Note: Add namespace declaration attribute
    Let ns_attr be XMLAttribute with:
    name as ("xmlns:" + prefix)
    value as uri
    namespace as none
    type as "CDATA" element.attributes.set with key as ns_attr.name and value as ns_attr

Note: Resolve namespace for element
Process called "resolve_namespace" that takes element as XMLElement and prefix as String returns Optional[String]:
    Note: Check element's local namespace declarations
    If element.namespaces.contains_key with key as prefix:
    Return element.namespaces.get with key as prefix.uri Note: Walk up the tree to find namespace declaration
    Let current be element.parent
    While current is not none:
    If current.namespaces.contains_key with key as prefix:
    Return current.namespaces.get with key as prefix.uri
    Set current to current.parent Return none

Note: XML entity handling
Process called "escape_xml_text" that takes text as String returns String:
    Let result be text
    Set result to result.replace with old as "&" and new as "&amp;"
    Set result to result.replace with old as "<" and new as "&lt;"
    Set result to result.replace with old as ">" and new as "&gt;"
    Return result

Process called "escape_attribute_value" that takes value as String returns String:
    Let result be escape_xml_text with text as value
    Set result to result.replace with old as "\"" and new as "&quot;"
    Set result to result.replace with old as "'" and new as "&apos;"
    Return result

Process called "unescape_xml_text" that takes text as String returns String:
    Let result be text
    Set result to result.replace with old as "&lt;" and new as "<"
    Set result to result.replace with old as "&gt;" and new as ">"
    Set result to result.replace with old as "&quot;" and new as "\""
    Set result to result.replace with old as "&apos;" and new as "'"
    Set result to result.replace with old as "&amp;" and new as "&"
    Return result

Note: XML document manipulation utilities
Process called "find_elements_by_tag" that takes element as XMLElement and tag_name as String returns List[XMLElement]:
    Let results be list containing
    find_elements_by_tag_recursive with element as element and tag_name as tag_name and results as results
    Return results

Process called "find_elements_by_tag_recursive" that takes element as XMLElement and tag_name as String and results as List[XMLElement] returns Nothing:
    If element.tag_name equals tag_name:
    results.append with item as element For child in element.children:
    find_elements_by_tag_recursive with element as child and tag_name as tag_name and results as results

Process called "find_element_by_id" that takes document as XMLDocument and id_value as String returns Optional[XMLElement]:
    If document.root is none:
    Return none Return find_element_by_id_recursive with element as document.root and id_value as id_value

Process called "find_element_by_id_recursive" that takes element as XMLElement and id_value as String returns Optional[XMLElement]:
    Note: Check id attribute (case-insensitive common patterns)
    For attr_name, attr in element.attributes:
    If attr_name.to_lower equals "id" or attr_name.to_lower equals "xml:id":
    If attr.value equals id_value:
    Return element Note: Search children recursively
    For child in element.children:
    Let result be find_element_by_id_recursive with element as child and id_value as id_value
    If result is not none:
    Return result Return none

Note: XML configuration and utilities
Process called "create_default_parser_config" returns XMLParserConfig:
    Return XMLParserConfig with:
    validate_dtd as false
    validate_schema as false
    resolve_entities as true
    preserve_whitespace as false
    namespace_aware as true
    recover_from_errors as false
    max_depth as 1000
    max_size as 100000000

Process called "create_default_serialize_options" returns XMLSerializeOptions:
    Return XMLSerializeOptions with:
    indent as true
    indent_size as 2
    encoding as "UTF-8"
    xml_declaration as true
    pretty_print as true
    omit_xml_declaration as false
    standalone as none

Process called "create_xml_declaration" that takes document as XMLDocument and options as XMLSerializeOptions returns String:
    Let declaration be "<?xml version=\"" + document.version + "\""
    Set declaration to declaration + " encoding=\"" + options.encoding + "\""
    If document.standalone is not none:
    If document.standalone:
    Set declaration to declaration + " standalone=\"yes\""
    Otherwise:
    Set declaration to declaration + " standalone=\"no\""
    Set declaration to declaration + "?>"
    Return declaration

Process called "create_indent" that takes depth as Integer and size as Integer returns String:
    Let indent_str be ""
    Let total_spaces be depth multiplied by size
    For i from 0 to total_spaces:
    Set indent_str to indent_str + " "
    Return indent_str

Note: Advanced XML processing utilities
Process called "merge_documents" that takes documents as List[XMLDocument] returns XMLDocument:
    If documents.is_empty:
    Return create_document Let merged_doc be create_document
    Let root_element be create_element with tag_name as "merged" and namespace as none
    merged_doc.root = root_element For doc in documents:
    If doc.root is not none:
    Let imported_element be deep_copy_element with element as doc.root
    root_element.children.append with item as imported_element
    imported_element.parent = root_element Return merged_doc

Process called "deep_copy_element" that takes element as XMLElement returns XMLElement:
    Let copied be create_element with tag_name as element.tag_name and namespace as element.namespace
    copied.text_content = element.text_content
    copied.cdata_content = element.cdata_content
    copied.node_type = element.node_type Note: Copy attributes
    For attr_name, attr in element.attributes:
    copied.attributes.set with key as attr_name and value as attr Note: Copy children recursively
    For child in element.children:
    Let copied_child be deep_copy_element with element as child
    copied_child.parent = copied
    copied.children.append with item as copied_child Return copied

Note: XML diff and comparison utilities
Process called "compare_documents" that takes doc1 as XMLDocument and doc2 as XMLDocument returns XMLComparisonResult:
    Let result be XMLComparisonResult with:
    identical as true
    differences as list containing
    structural_differences as 0
    content_differences as 0 If doc1.root is none and doc2.root is none:
    Return result If doc1.root is none or doc2.root is none:
    result.identical = false
    result.differences.append with item as "One document has no root element"
    result.structural_differences = result.structural_differences + 1
    Return result compare_elements with element1 as doc1.root and element2 as doc2.root and result as result and path as "/"
    Return result

Type called "XMLComparisonResult":
    identical as Boolean
    differences as List[String]
    structural_differences as Integer
    content_differences as Integer

Process called "compare_elements" that takes element1 as XMLElement and element2 as XMLElement and result as XMLComparisonResult and path as String returns Nothing:
    Note: Compare tag names
    If element1.tag_name is not element2.tag_name:
    result.identical = false
    result.differences.append with item as path + ": Tag name differs (" + element1.tag_name + " vs " + element2.tag_name + ")"
    result.structural_differences = result.structural_differences + 1 Note: Compare text content
    If element1.text_content is not element2.text_content:
    result.identical = false
    result.differences.append with item as path + ": Text content differs"
    result.content_differences = result.content_differences + 1 Note: Compare attributes
    If element1.attributes.size is not element2.attributes.size:
    result.identical = false
    result.differences.append with item as path + ": Attribute count differs"
    result.structural_differences = result.structural_differences + 1 For attr_name, attr1 in element1.attributes:
    If not element2.attributes.contains_key with key as attr_name:
    result.identical = false
    result.differences.append with item as path + ": Attribute " + attr_name + " missing in second element"
    result.structural_differences = result.structural_differences + 1
    Otherwise:
    Let attr2 be element2.attributes.get with key as attr_name
    If attr1.value is not attr2.value:
    result.identical = false
    result.differences.append with item as path + ": Attribute " + attr_name + " value differs"
    result.content_differences = result.content_differences + 1 Note: Compare children count
    If element1.children.size is not element2.children.size:
    result.identical = false
    result.differences.append with item as path + ": Child count differs"
    result.structural_differences = result.structural_differences + 1
    Otherwise:
    Note: Compare each child element
    For i from 0 to element1.children.size:
    Let child1 be element1.children.get with index as i
    Let child2 be element2.children.get with index as i
    Let child_path be path + "/" + child1.tag_name + "[" + (i + 1).to_string + "]"
    compare_elements with element1 as child1 and element2 as child2 and result as result and path as child_path

Note: Performance monitoring and metrics
Process called "create_performance_metrics" returns XMLPerformanceMetrics:
    Return XMLPerformanceMetrics with:
    parse_time as 0.0
    serialize_time as 0.0
    validation_time as 0.0
    memory_usage as 0
    document_size as 0
    element_count as 0
    attribute_count as 0

Type called "XMLPerformanceMetrics":
    parse_time as Float
    serialize_time as Float
    validation_time as Float
    memory_usage as Integer
    document_size as Integer
    element_count as Integer
    attribute_count as Integer

Process called "measure_parse_performance" that takes xml_string as String and config as Optional[XMLParserConfig] returns PerformanceResult:
    Let metrics be create_performance_metrics
    Let start_time be DateTime.now Let document be parse_xml with xml_string as xml_string and config as config Let end_time be DateTime.now
    metrics.parse_time = (end_time - start_time).total_milliseconds
    metrics.document_size = xml_string.length If document.root is not none:
    calculate_document_metrics with element as document.root and metrics as metrics Return PerformanceResult with:
    document as document
    metrics as metrics
    success as true

Type called "PerformanceResult":
    document as XMLDocument
    metrics as XMLPerformanceMetrics
    success as Boolean

Process called "calculate_document_metrics" that takes element as XMLElement and metrics as XMLPerformanceMetrics returns Nothing:
    metrics.element_count = metrics.element_count + 1
    metrics.attribute_count = metrics.attribute_count + element.attributes.size For child in element.children:
    calculate_document_metrics with element as child and metrics as metrics