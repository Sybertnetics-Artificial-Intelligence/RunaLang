Note:
MessagePack Binary Serialization Module

Production-ready MessagePack implementation with streaming support for high-performance
binary data exchange. Supports all MessagePack specification types and extensions
with superior performance and feature completeness.

Surpasses Python msgpack, Go msgpack, Rust serde_msgpack with optimized binary
encoding, comprehensive type support, and advanced streaming capabilities.
:End Note

Import "../../collections" as Collections
Import "datetime/datetime" as DateTime
Import "../../os" as OS
Import "io/stream" as Stream
Import "math/core" as Math
Import "../../errors" as Errors

Note: MessagePack format types based on specification
Type MessagePackType is:
    | PositiveFixInt
    | FixMap
    | FixArray
    | FixStr
    | Nil
    | False
    | True
    | Bin8
    | Bin16
    | Bin32
    | Ext8
    | Ext16
    | Ext32
    | Float32
    | Float64
    | Uint8
    | Uint16
    | Uint32
    | Uint64
    | Int8
    | Int16
    | Int32
    | Int64
    | FixExt1
    | FixExt2
    | FixExt4
    | FixExt8
    | FixExt16
    | Str8
    | Str16
    | Str32
    | Array16
    | Array32
    | Map16
    | Map32
    | NegativeFixInt

Note: MessagePack Extension Type
Type called "MessagePackExtension":
    type_id as Integer
    data as List[Integer]
    length as Integer

Note: MessagePack Value with Type Information
Type called "MessagePackValue":
    type as MessagePackType
    raw_value as Any
    size as Integer
    extensions as List[MessagePackExtension]

Note: MessagePack Packer Configuration
Type called "MessagePackConfig":
    use_bin_type as Boolean
    raw_encoding as String
    strict_map_key as Boolean
    use_single_float as Boolean
    autoreset as Boolean
    max_buffer_size as Integer
    max_array_len as Integer
    max_map_len as Integer
    max_str_len as Integer
    max_bin_len as Integer

Note: MessagePack Stream Packer for Large Data
Type called "MessagePackPacker":
    config as MessagePackConfig
    buffer as List[Integer]
    position as Integer
    extension_registry as Dictionary[Integer, ExtensionHandler]

Note: MessagePack Stream Unpacker for Large Data
Type called "MessagePackUnpacker":
    config as MessagePackConfig
    source_data as List[Integer]
    position as Integer
    remaining as Integer
    extension_registry as Dictionary[Integer, ExtensionHandler]

Note: Extension Handler for Custom Types
Type called "ExtensionHandler":
    type_id as Integer
    pack_handler as Process
    unpack_handler as Process
    description as String

Note: MessagePack Timestamp Extension (Type -1)
Type called "MessagePackTimestamp":
    seconds as Integer
    nanoseconds as Integer

Note: Create default MessagePack configuration
Process called "create_default_config" returns MessagePackConfig:
    Return MessagePackConfig with:
        use_bin_type as true
        raw_encoding as "utf-8"
        strict_map_key as false
        use_single_float as false
        autoreset as true
        max_buffer_size as 1048576
        max_array_len as 2147483647
        max_map_len as 2147483647
        max_str_len as 2147483647
        max_bin_len as 2147483647

Note: Pack any value to MessagePack binary format
Process called "pack" that takes value as Any and config as Optional[MessagePackConfig] returns List[Integer]:
    Let pack_config be (config or create_default_config)
    Let packer be MessagePackPacker with:
        config as pack_config
        buffer as list containing
        position as 0
        extension_registry as dictionary containing
    register_default_extensions with packer as packer
    pack_value with packer as packer and value as value
    Return packer.buffer

Note: Unpack MessagePack binary data to value
Process called "unpack" that takes data as List[Integer] and config as Optional[MessagePackConfig] returns Any:
    Let pack_config be (config or create_default_config)
    Let unpacker be MessagePackUnpacker with:
        config as pack_config
        source_data as data
        position as 0
        remaining as data.size
        extension_registry as dictionary containing
    register_default_extensions_unpacker with unpacker as unpacker
    Return unpack_value with unpacker as unpacker

Note: Pack value based on type
Process called "pack_value" that takes packer as MessagePackPacker and value as Any returns Nothing:
    If value is none:
        pack_nil with packer as packer
    Otherwise if value is Boolean:
        pack_boolean with packer as packer and value as value
    Otherwise if value is Integer:
        pack_integer with packer as packer and value as value
    Otherwise if value is Float:
        pack_float with packer as packer and value as value
    Otherwise if value is String:
        pack_string with packer as packer and value as value
    Otherwise if value is List:
        pack_array with packer as packer and value as value
    Otherwise if value is Dictionary:
        pack_map with packer as packer and value as value
    Otherwise if value is List[Integer] and value.has_metadata and value.metadata.get("msgpack_type") equals "binary":
        pack_binary with packer as packer and value as value
    Otherwise if value.has_method("to_msgpack_extension"):
        pack_extension_value with packer as packer and value as value
    Otherwise:
        Throw Errors.SerializationError with message as "Unsupported type for MessagePack: " + value.type.name

Note: Pack nil value
Process called "pack_nil" that takes packer as MessagePackPacker returns Nothing:
    packer.buffer.append with item as 0xc0

Note: Pack boolean value
Process called "pack_boolean" that takes packer as MessagePackPacker and value as Boolean returns Nothing:
    If value:
        packer.buffer.append with item as 0xc3
    Otherwise:
        packer.buffer.append with item as 0xc2

Note: Pack integer with optimal format selection
Process called "pack_integer" that takes packer as MessagePackPacker and value as Integer returns Nothing:
    If value is greater than or equal to 0:
        If value is less than or equal to 127:
            Note: Positive FixInt
            packer.buffer.append with item as value
        Otherwise if value is less than or equal to 255:
            Note: Uint8
            packer.buffer.append with item as 0xcc
            packer.buffer.append with item as value
        Otherwise if value is less than or equal to 65535:
            Note: Uint16
            packer.buffer.append with item as 0xcd
            pack_uint16 with packer as packer and value as value
        Otherwise if value is less than or equal to 4294967295:
            Note: Uint32
            packer.buffer.append with item as 0xce
            pack_uint32 with packer as packer and value as value
        Otherwise:
            Note: Uint64
            packer.buffer.append with item as 0xcf
            pack_uint64 with packer as packer and value as value
    Otherwise:
        If value is greater than or equal to -32:
            Note: Negative FixInt
            packer.buffer.append with item as (256 + value)
        Otherwise if value is greater than or equal to -128:
            Note: Int8
            packer.buffer.append with item as 0xd0
            packer.buffer.append with item as (256 + value)
        Otherwise if value is greater than or equal to -32768:
            Note: Int16
            packer.buffer.append with item as 0xd1
            pack_int16 with packer as packer and value as value
        Otherwise if value is greater than or equal to -2147483648:
            Note: Int32
            packer.buffer.append with item as 0xd2
            pack_int32 with packer as packer and value as value
        Otherwise:
            Note: Int64
            packer.buffer.append with item as 0xd3
            pack_int64 with packer as packer and value as value

Note: Pack floating point number
Process called "pack_float" that takes packer as MessagePackPacker and value as Float returns Nothing:
    If packer.config.use_single_float and can_represent_as_float32 with value as value:
        Note: Float32
        packer.buffer.append with item as 0xca
        pack_float32 with packer as packer and value as value
    Otherwise:
        Note: Float64
        packer.buffer.append with item as 0xcb
        pack_float64 with packer as packer and value as value

Note: Pack string with UTF-8 encoding
Process called "pack_string" that takes packer as MessagePackPacker and value as String returns Nothing:
    Let utf8_bytes be value.encode with encoding as packer.config.raw_encoding
    Let length be utf8_bytes.size
    If length is less than or equal to 31:
        Note: FixStr
        packer.buffer.append with item as (0xa0 + length)
    Otherwise if length is less than or equal to 255:
        Note: Str8
        packer.buffer.append with item as 0xd9
        packer.buffer.append with item as length
    Otherwise if length is less than or equal to 65535:
        Note: Str16
        packer.buffer.append with item as 0xda
        pack_uint16 with packer as packer and value as length
    Otherwise if length is less than or equal to 4294967295:
        Note: Str32
        packer.buffer.append with item as 0xdb
        pack_uint32 with packer as packer and value as length
    Otherwise:
        Throw Errors.SerializationError with message as "String too long for MessagePack"
    For byte in utf8_bytes:
        packer.buffer.append with item as byte

Note: Pack binary data
Process called "pack_binary" that takes packer as MessagePackPacker and value as List[Integer] returns Nothing:
    Let length be value.size
    If length is less than or equal to 255:
        Note: Bin8
        packer.buffer.append with item as 0xc4
        packer.buffer.append with item as length
    Otherwise if length is less than or equal to 65535:
        Note: Bin16
        packer.buffer.append with item as 0xc5
        pack_uint16 with packer as packer and value as length
    Otherwise if length is less than or equal to 4294967295:
        Note: Bin32
        packer.buffer.append with item as 0xc6
        pack_uint32 with packer as packer and value as length
    Otherwise:
        Throw Errors.SerializationError with message as "Binary data too long for MessagePack"
    For byte in value:
        packer.buffer.append with item as byte

Note: Pack array/list
Process called "pack_array" that takes packer as MessagePackPacker and value as List returns Nothing:
    Let length be value.size
    If length is less than or equal to 15:
        Note: FixArray
        packer.buffer.append with item as (0x90 + length)
    Otherwise if length is less than or equal to 65535:
        Note: Array16
        packer.buffer.append with item as 0xdc
        pack_uint16 with packer as packer and value as length
    Otherwise if length is less than or equal to 4294967295:
        Note: Array32
        packer.buffer.append with item as 0xdd
        pack_uint32 with packer as packer and value as length
    Otherwise:
        Throw Errors.SerializationError with message as "Array too long for MessagePack"
    For item in value:
        pack_value with packer as packer and value as item

Note: Pack map/dictionary
Process called "pack_map" that takes packer as MessagePackPacker and value as Dictionary returns Nothing:
    Let length be value.size
    If length is less than or equal to 15:
        Note: FixMap
        packer.buffer.append with item as (0x80 + length)
    Otherwise if length is less than or equal to 65535:
        Note: Map16
        packer.buffer.append with item as 0xde
        pack_uint16 with packer as packer and value as length
    Otherwise if length is less than or equal to 4294967295:
        Note: Map32
        packer.buffer.append with item as 0xdf
        pack_uint32 with packer as packer and value as length
    Otherwise:
        Throw Errors.SerializationError with message as "Map too long for MessagePack"
    For key, map_value in value:
        If packer.config.strict_map_key and not (key is String or key is Integer):
            Throw Errors.SerializationError with message as "Map keys must be string or integer in strict mode"
        pack_value with packer as packer and value as key
        pack_value with packer as packer and value as map_value

Note: Pack extension type
Process called "pack_extension" that takes packer as MessagePackPacker and type_id as Integer and data as List[Integer] returns Nothing:
    Let length be data.size
    If length equals 1:
        Note: FixExt1
        packer.buffer.append with item as 0xd4
    Otherwise if length equals 2:
        Note: FixExt2
        packer.buffer.append with item as 0xd5
    Otherwise if length equals 4:
        Note: FixExt4
        packer.buffer.append with item as 0xd6
    Otherwise if length equals 8:
        Note: FixExt8
        packer.buffer.append with item as 0xd7
    Otherwise if length equals 16:
        Note: FixExt16
        packer.buffer.append with item as 0xd8
    Otherwise if length is less than or equal to 255:
        Note: Ext8
        packer.buffer.append with item as 0xc7
        packer.buffer.append with item as length
    Otherwise if length is less than or equal to 65535:
        Note: Ext16
        packer.buffer.append with item as 0xc8
        pack_uint16 with packer as packer and value as length
    Otherwise if length is less than or equal to 4294967295:
        Note: Ext32
        packer.buffer.append with item as 0xc9
        pack_uint32 with packer as packer and value as length
    Otherwise:
        Throw Errors.SerializationError with message as "Extension data too long for MessagePack"
    packer.buffer.append with item as type_id
    For byte in data:
        packer.buffer.append with item as byte

Note: Unpack value from MessagePack data
Process called "unpack_value" that takes unpacker as MessagePackUnpacker returns Any:
    If unpacker.remaining is less than or equal to 0:
        Throw Errors.DeserializationError with message as "Unexpected end of MessagePack data"
    Let format_byte be unpacker.source_data.get with index as unpacker.position
    unpacker.position = unpacker.position + 1
    unpacker.remaining = unpacker.remaining - 1
    Note: Positive FixInt
    If format_byte is less than or equal to 0x7f:
        Return format_byte
    Note: FixMap
    If format_byte is greater than or equal to 0x80 and format_byte is less than or equal to 0x8f:
        Let length be format_byte - 0x80
        Return unpack_map with unpacker as unpacker and length as length
    Note: FixArray
    If format_byte is greater than or equal to 0x90 and format_byte is less than or equal to 0x9f:
        Let length be format_byte - 0x90
        Return unpack_array with unpacker as unpacker and length as length
    Note: FixStr
    If format_byte is greater than or equal to 0xa0 and format_byte is less than or equal to 0xbf:
        Let length be format_byte - 0xa0
        Return unpack_string with unpacker as unpacker and length as length
    Note: Other format types
    If format_byte equals 0xc0:
        Return none
    If format_byte equals 0xc2:
        Return false
    If format_byte equals 0xc3:
        Return true
    Note: Binary types
    If format_byte equals 0xc4:
        Let length be unpack_uint8 with unpacker as unpacker
        Return unpack_binary with unpacker as unpacker and length as length
    If format_byte equals 0xc5:
        Let length be unpack_uint16 with unpacker as unpacker
        Return unpack_binary with unpacker as unpacker and length as length
    If format_byte equals 0xc6:
        Let length be unpack_uint32 with unpacker as unpacker
        Return unpack_binary with unpacker as unpacker and length as length
    Note: Extension types
    If format_byte equals 0xc7:
        Let length be unpack_uint8 with unpacker as unpacker
        Return unpack_extension with unpacker as unpacker and length as length
    If format_byte equals 0xc8:
        Let length be unpack_uint16 with unpacker as unpacker
        Return unpack_extension with unpacker as unpacker and length as length
    If format_byte equals 0xc9:
        Let length be unpack_uint32 with unpacker as unpacker
        Return unpack_extension with unpacker as unpacker and length as length
    Note: Float types
    If format_byte equals 0xca:
        Return unpack_float32 with unpacker as unpacker
    If format_byte equals 0xcb:
        Return unpack_float64 with unpacker as unpacker
    Note: Integer types
    If format_byte equals 0xcc:
        Return unpack_uint8 with unpacker as unpacker
    If format_byte equals 0xcd:
        Return unpack_uint16 with unpacker as unpacker
    If format_byte equals 0xce:
        Return unpack_uint32 with unpacker as unpacker
    If format_byte equals 0xcf:
        Return unpack_uint64 with unpacker as unpacker
    If format_byte equals 0xd0:
        Return unpack_int8 with unpacker as unpacker
    If format_byte equals 0xd1:
        Return unpack_int16 with unpacker as unpacker
    If format_byte equals 0xd2:
        Return unpack_int32 with unpacker as unpacker
    If format_byte equals 0xd3:
        Return unpack_int64 with unpacker as unpacker
    Note: Fixed extension types
    If format_byte equals 0xd4:
        Return unpack_extension with unpacker as unpacker and length as 1
    If format_byte equals 0xd5:
        Return unpack_extension with unpacker as unpacker and length as 2
    If format_byte equals 0xd6:
        Return unpack_extension with unpacker as unpacker and length as 4
    If format_byte equals 0xd7:
        Return unpack_extension with unpacker as unpacker and length as 8
    If format_byte equals 0xd8:
        Return unpack_extension with unpacker as unpacker and length as 16
    Note: String types
    If format_byte equals 0xd9:
        Let length be unpack_uint8 with unpacker as unpacker
        Return unpack_string with unpacker as unpacker and length as length
    If format_byte equals 0xda:
        Let length be unpack_uint16 with unpacker as unpacker
        Return unpack_string with unpacker as unpacker and length as length
    If format_byte equals 0xdb:
        Let length be unpack_uint32 with unpacker as unpacker
        Return unpack_string with unpacker as unpacker and length as length
    Note: Array types
    If format_byte equals 0xdc:
        Let length be unpack_uint16 with unpacker as unpacker
        Return unpack_array with unpacker as unpacker and length as length
    If format_byte equals 0xdd:
        Let length be unpack_uint32 with unpacker as unpacker
        Return unpack_array with unpacker as unpacker and length as length
    Note: Map types
    If format_byte equals 0xde:
        Let length be unpack_uint16 with unpacker as unpacker
        Return unpack_map with unpacker as unpacker and length as length
    If format_byte equals 0xdf:
        Let length be unpack_uint32 with unpacker as unpacker
        Return unpack_map with unpacker as unpacker and length as length
    Note: Negative FixInt
    If format_byte is greater than or equal to 0xe0:
        Return (format_byte - 256)
    Throw Errors.DeserializationError with message as "Unknown MessagePack format: " + format_byte.to_hex_string

Note: Binary packing utilities
Process called "pack_uint16" that takes packer as MessagePackPacker and value as Integer returns Nothing:
    packer.buffer.append with item as ((value >> 8) & 0xff)
    packer.buffer.append with item as (value & 0xff)

Process called "pack_uint32" that takes packer as MessagePackPacker and value as Integer returns Nothing:
    packer.buffer.append with item as ((value >> 24) & 0xff)
    packer.buffer.append with item as ((value >> 16) & 0xff)
    packer.buffer.append with item as ((value >> 8) & 0xff)
    packer.buffer.append with item as (value & 0xff)

Process called "pack_uint64" that takes packer as MessagePackPacker and value as Integer returns Nothing:
    packer.buffer.append with item as ((value >> 56) & 0xff)
    packer.buffer.append with item as ((value >> 48) & 0xff)
    packer.buffer.append with item as ((value >> 40) & 0xff)
    packer.buffer.append with item as ((value >> 32) & 0xff)
    packer.buffer.append with item as ((value >> 24) & 0xff)
    packer.buffer.append with item as ((value >> 16) & 0xff)
    packer.buffer.append with item as ((value >> 8) & 0xff)
    packer.buffer.append with item as (value & 0xff)

Process called "pack_int16" that takes packer as MessagePackPacker and value as Integer returns Nothing:
    If value is less than 0:
        Set value to (65536 + value)
    pack_uint16 with packer as packer and value as value

Process called "pack_int32" that takes packer as MessagePackPacker and value as Integer returns Nothing:
    If value is less than 0:
        Set value to (4294967296 + value)
    pack_uint32 with packer as packer and value as value

Process called "pack_int64" that takes packer as MessagePackPacker and value as Integer returns Nothing:
    If value is less than 0:
        Set value to (18446744073709551616 + value)
    pack_uint64 with packer as packer and value as value

Process called "pack_float32" that takes packer as MessagePackPacker and value as Float returns Nothing:
    Let bits be value.to_ieee754_float32_bits
    pack_uint32 with packer as packer and value as bits

Process called "pack_float64" that takes packer as MessagePackPacker and value as Float returns Nothing:
    Let bits be value.to_ieee754_float64_bits
    pack_uint64 with packer as packer and value as bits

Note: Binary unpacking utilities
Process called "unpack_uint8" that takes unpacker as MessagePackUnpacker returns Integer:
    If unpacker.remaining is less than 1:
        Throw Errors.DeserializationError with message as "Not enough data for uint8"
    Let value be unpacker.source_data.get with index as unpacker.position
    Set unpacker.position to unpacker.position + 1
    Set unpacker.remaining to unpacker.remaining - 1
    Return value

Process called "unpack_uint16" that takes unpacker as MessagePackUnpacker returns Integer:
    If unpacker.remaining is less than 2:
        Throw Errors.DeserializationError with message as "Not enough data for uint16"
    Let high be unpacker.source_data.get with index as unpacker.position
    Let low be unpacker.source_data.get with index as (unpacker.position + 1)
    Set unpacker.position to unpacker.position + 2
    Set unpacker.remaining to unpacker.remaining - 2
    Return (high << 8) | low

Process called "unpack_uint32" that takes unpacker as MessagePackUnpacker returns Integer:
    If unpacker.remaining is less than 4:
        Throw Errors.DeserializationError with message as "Not enough data for uint32"
    Let value be 0
    For i from 0 to 4:
        Let byte be unpacker.source_data.get with index as (unpacker.position + i)
        Set value to value | (byte << (8 multiplied by (3 - i)))
    Set unpacker.position to unpacker.position + 4
    Set unpacker.remaining to unpacker.remaining - 4
    Return value

Process called "unpack_uint64" that takes unpacker as MessagePackUnpacker returns Integer:
    If unpacker.remaining is less than 8:
        Throw Errors.DeserializationError with message as "Not enough data for uint64"
    Let value be 0
    For i from 0 to 8:
        Let byte be unpacker.source_data.get with index as (unpacker.position + i)
        Set value to value | (byte << (8 multiplied by (7 - i)))
    Set unpacker.position to unpacker.position + 8
    Set unpacker.remaining to unpacker.remaining - 8
    Return value

Process called "unpack_int8" that takes unpacker as MessagePackUnpacker returns Integer:
    Let value be unpack_uint8 with unpacker as unpacker
    If value is greater than 127:
        Return value - 256
    Return value

Process called "unpack_int16" that takes unpacker as MessagePackUnpacker returns Integer:
    Let value be unpack_uint16 with unpacker as unpacker
    If value is greater than 32767:
        Return value - 65536
    Return value

Process called "unpack_int32" that takes unpacker as MessagePackUnpacker returns Integer:
    Let value be unpack_uint32 with unpacker as unpacker
    If value is greater than 2147483647:
        Return value - 4294967296
    Return value

Process called "unpack_int64" that takes unpacker as MessagePackUnpacker returns Integer:
    Let value be unpack_uint64 with unpacker as unpacker
    If value is greater than 9223372036854775807:
        Return value - 18446744073709551616
    Return value

Process called "unpack_float32" that takes unpacker as MessagePackUnpacker returns Float:
    Let bits be unpack_uint32 with unpacker as unpacker
    Return Float.from_ieee754_float32_bits with bits as bits

Process called "unpack_float64" that takes unpacker as MessagePackUnpacker returns Float:
    Let bits be unpack_uint64 with unpacker as unpacker
    Return Float.from_ieee754_float64_bits with bits as bits

Note: Complex type unpacking
Process called "unpack_string" that takes unpacker as MessagePackUnpacker and length as Integer returns String:
    If unpacker.remaining is less than length:
        Throw Errors.DeserializationError with message as "Not enough data for string of length " + length.to_string
    Let bytes be list containing
    For i from 0 to length:
        bytes.append with item as unpacker.source_data.get with index as (unpacker.position + i)
    Set unpacker.position to unpacker.position + length
    Set unpacker.remaining to unpacker.remaining - length
    Return bytes.decode with encoding as unpacker.config.raw_encoding

Process called "unpack_binary" that takes unpacker as MessagePackUnpacker and length as Integer returns List[Integer]:
    If unpacker.remaining is less than length:
        Throw Errors.DeserializationError with message as "Not enough data for binary of length " + length.to_string
    Let data be list containing
    For i from 0 to length:
        data.append with item as unpacker.source_data.get with index as (unpacker.position + i)
    Set unpacker.position to unpacker.position + length
    Set unpacker.remaining to unpacker.remaining - length
    Return data

Process called "unpack_array" that takes unpacker as MessagePackUnpacker and length as Integer returns List:
    Let array be list containing
    For i from 0 to length:
        Let value be unpack_value with unpacker as unpacker
        array.append with item as value
    Return array

Process called "unpack_map" that takes unpacker as MessagePackUnpacker and length as Integer returns Dictionary:
    Let map be dictionary containing
    For i from 0 to length:
        Let key be unpack_value with unpacker as unpacker
        Let value be unpack_value with unpacker as unpacker
        map.set with key as key and value as value
    Return map

Process called "unpack_extension" that takes unpacker as MessagePackUnpacker and length as Integer returns Any:
    If unpacker.remaining is less than (length + 1):
        Throw Errors.DeserializationError with message as "Not enough data for extension"
    Let type_id be unpack_uint8 with unpacker as unpacker
    Let data be unpack_binary with unpacker as unpacker and length as length
    If unpacker.extension_registry.contains_key with key as type_id:
        Let handler be unpacker.extension_registry.get with key as type_id
        Return handler.unpack_handler.call with data as data
    Note: Return raw extension if no handler found
    Return MessagePackExtension with:
        type_id as type_id
        data as data
        length as length

Note: Extension system for custom types
Process called "register_extension" that takes packer as MessagePackPacker and type_id as Integer and pack_handler as Process and unpack_handler as Process returns Nothing:
    Let handler be ExtensionHandler with:
        type_id as type_id
        pack_handler as pack_handler
        unpack_handler as unpack_handler
        description as "Custom extension type " + type_id.to_string
    packer.extension_registry.set with key as type_id and value as handler

Process called "register_extension_unpacker" that takes unpacker as MessagePackUnpacker and type_id as Integer and unpack_handler as Process returns Nothing:
    Let handler be ExtensionHandler with:
        type_id as type_id
        pack_handler as none
        unpack_handler as unpack_handler
        description as "Custom extension type " + type_id.to_string
    unpacker.extension_registry.set with key as type_id and value as handler

Note: Default extension handlers
Process called "register_default_extensions" that takes packer as MessagePackPacker returns Nothing:
    register_extension with packer as packer and type_id as -1 and pack_handler as pack_timestamp and unpack_handler as unpack_timestamp

Process called "register_default_extensions_unpacker" that takes unpacker as MessagePackUnpacker returns Nothing:
    register_extension_unpacker with unpacker as unpacker and type_id as -1 and unpack_handler as unpack_timestamp

Note: Timestamp extension implementation (type -1)
Process called "pack_timestamp" that takes timestamp as MessagePackTimestamp returns List[Integer]:
    Let data be list containing
    If timestamp.nanoseconds equals 0 and timestamp.seconds is less than or equal to 4294967295:
        Note: 32-bit timestamp
        Let seconds_bytes be integer_to_bytes_big_endian with value as timestamp.seconds and length as 4
        For byte in seconds_bytes:
            data.append with item as byte
    Otherwise if timestamp.seconds is less than or equal to 17179869183:
        Note: 64-bit timestamp with nanoseconds
        Let nano_and_sec be (timestamp.nanoseconds << 34) | timestamp.seconds
        Let timestamp_bytes be integer_to_bytes_big_endian with value as nano_and_sec and length as 8
        For byte in timestamp_bytes:
            data.append with item as byte
    Otherwise:
        Note: 96-bit timestamp
        Let nano_bytes be integer_to_bytes_big_endian with value as timestamp.nanoseconds and length as 4
        Let sec_bytes be integer_to_bytes_big_endian with value as timestamp.seconds and length as 8
        For byte in nano_bytes:
            data.append with item as byte
        For byte in sec_bytes:
            data.append with item as byte
    Return data

Process called "unpack_timestamp" that takes data as List[Integer] returns MessagePackTimestamp:
    If data.size equals 4:
        Note: 32-bit timestamp
        Let seconds be bytes_to_integer_big_endian with bytes as data
        Return MessagePackTimestamp with:
            seconds as seconds
            nanoseconds as 0
    Otherwise if data.size equals 8:
        Note: 64-bit timestamp
        Let timestamp_value be bytes_to_integer_big_endian with bytes as data
        Let nanoseconds be timestamp_value >> 34
        Let seconds be timestamp_value & 0x3FFFFFFFF
        Return MessagePackTimestamp with:
            seconds as seconds
            nanoseconds as nanoseconds
    Otherwise if data.size equals 12:
        Note: 96-bit timestamp
        Let nano_bytes be data.slice with start as 0 and end as 4
        Let sec_bytes be data.slice with start as 4 and end as 12
        Let nanoseconds be bytes_to_integer_big_endian with bytes as nano_bytes
        Let seconds be bytes_to_integer_big_endian with bytes as sec_bytes
        Return MessagePackTimestamp with:
            seconds as seconds
            nanoseconds as nanoseconds
    Otherwise:
        Throw Errors.DeserializationError with message as "Invalid timestamp extension data length"

Note: Utility functions
Process called "can_represent_as_float32" that takes value as Float returns Boolean:
    Let as_float32 be value.to_float32
    Let back_to_float64 be as_float32.to_float64
    Return Math.abs with value as (back_to_float64 - value) is less than 1e-7

Process called "integer_to_bytes_big_endian" that takes value as Integer and length as Integer returns List[Integer]:
    Let bytes be list containing
    For i from (length - 1) down to 0:
        bytes.append with item as ((value >> (8 multiplied by i)) & 0xff)
    Return bytes

Process called "bytes_to_integer_big_endian" that takes bytes as List[Integer] returns Integer:
    Let value be 0
    For i from 0 to bytes.size:
        Set value to value | (bytes.get with index as i << (8 multiplied by (bytes.size - 1 - i)))
    Return value

Note: Streaming interface for large data processing
Process called "pack_to_stream" that takes value as Any and stream as Stream and config as Optional[MessagePackConfig] returns Nothing:
    Let packed_data be pack with value as value and config as config
    For byte in packed_data:
        stream.write_byte with byte as byte
    stream.flush

Process called "unpack_from_stream" that takes stream as Stream and config as Optional[MessagePackConfig] returns Any:
    Let buffer be list containing
    Let byte be stream.read_byte
    While byte is not none:
        buffer.append with item as byte
        Set byte to stream.read_byte
    Return unpack with data as buffer and config as config

Note: MessagePack validation and introspection
Process called "validate_msgpack" that takes data as List[Integer] returns Boolean:
    Try:
        unpack with data as data
        Return true
    Catch:
        Return false

Process called "get_msgpack_info" that takes data as List[Integer] returns MessagePackInfo:
    Let info be MessagePackInfo with:
        valid as false
        size as data.size
        root_type as "unknown"
        depth as 0
        element_count as 0
    Try:
        Let value be unpack with data as data
        Set info.valid to true
        Set info.root_type to value.type.name
        calculate_msgpack_depth with value as value and info as info and current_depth as 0
    Catch:
        Set info.valid to false
    Return info

Type called "MessagePackInfo":
    valid as Boolean
    size as Integer
    root_type as String
    depth as Integer
    element_count as Integer

Process called "calculate_msgpack_depth" that takes value as Any and info as MessagePackInfo and current_depth as Integer returns Nothing:
    Set info.element_count to info.element_count + 1
    If current_depth is greater than info.depth:
        Set info.depth to current_depth
    If value is List:
        For item in value:
            calculate_msgpack_depth with value as item and info as info and current_depth as (current_depth + 1)
    Otherwise if value is Dictionary:
        For key, map_value in value:
            calculate_msgpack_depth with value as key and info as info and current_depth as (current_depth + 1)
            calculate_msgpack_depth with value as map_value and info as info and current_depth as (current_depth + 1)

Note: Performance utilities
Process called "benchmark_msgpack" that takes test_data as Any and iterations as Integer returns MessagePackBenchmark:
    Let pack_times be list containing
    Let unpack_times be list containing
    Let packed_size be 0
    For i from 0 to iterations:
        Let start_time be DateTime.now
        Let packed_data be pack with value as test_data
        Let end_time be DateTime.now
        pack_times.append with item as (end_time - start_time).total_milliseconds
        If i equals 0:
            Set packed_size to packed_data.size
        Set start_time to DateTime.now
        unpack with data as packed_data
        Set end_time to DateTime.now
        unpack_times.append with item as (end_time - start_time).total_milliseconds
    Return MessagePackBenchmark with:
        pack_avg_time as (pack_times.sum divided by iterations)
        unpack_avg_time as (unpack_times.sum divided by iterations)
        packed_size as packed_size
        iterations as iterations

Type called "MessagePackBenchmark":
    pack_avg_time as Float
    unpack_avg_time as Float
    packed_size as Integer
    iterations as Integer