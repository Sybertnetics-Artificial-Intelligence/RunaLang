Note:
Apache Avro Serialization Module

Production-ready Avro implementation with comprehensive schema evolution support,
binary and JSON serialization modes, schema registry integration, and compact
binary format with full schema validation capabilities.

Surpasses Java Avro, Python avro-python3, Go avro libraries with superior
performance, advanced schema compatibility checking, and streaming support.
:End Note

Import "../../collections" as Collections
Import "datetime/datetime" as DateTime Import "../../os" as OS
Import "io/stream" as Stream
Import "math/core" as Math
Import "crypto/hash" as Hash
Import "../../errors" as Errors
Import "serialization/json" as JSON

Note: Avro primitive types
Type AvroPrimitiveType is:
    | Null
    | Boolean
    | Int
    | Long
    | Float
    | Double
    | Bytes
    | String

Note: Avro complex types
Type AvroComplexType is:
    | Record
    | Enum
    | Array
    | Map
    | Union
    | Fixed

Note: Avro schema representation
Type called "AvroSchema":
    type as String
    name as Optional[String]
    namespace as Optional[String]
    doc as Optional[String]
    aliases as List[String]
    fields as Optional[List[AvroField]]
    symbols as Optional[List[String]]
    items as Optional[AvroSchema]
    values as Optional[AvroSchema]
    size as Optional[Integer]
    schemas as Optional[List[AvroSchema]]
    default_value as Optional[Any]
    logical_type as Optional[String]

Note: Avro record field definition
Type called "AvroField":
    name as String
    type as AvroSchema
    doc as Optional[String]
    default_value as Optional[Any]
    order as Optional[String]
    aliases as List[String]

Note: Avro schema registry for managing schemas
Type called "AvroSchemaRegistry":
    schemas as Dictionary[String, AvroSchema]
    schema_hashes as Dictionary[String, String]
    compatibility_mode as CompatibilityMode
    evolution_history as Dictionary[String, List[AvroSchema]]

Type CompatibilityMode is:
    | None
    | Backward
    | Forward
    | Full

Note: Avro encoder for binary serialization
Type called "AvroEncoder":
    buffer as List[Integer]
    schema as AvroSchema
    registry as Optional[AvroSchemaRegistry]

Note: Avro decoder for binary deserialization Type called "AvroDecoder":
    data as List[Integer]
    position as Integer
    writer_schema as AvroSchema
    reader_schema as Optional[AvroSchema]
    registry as Optional[AvroSchemaRegistry]

Note: Avro data file header and metadata
Type called "AvroDataFile":
    header as AvroDataFileHeader
    blocks as List[AvroDataBlock]
    schema as AvroSchema

Type called "AvroDataFileHeader":
    magic as List[Integer]
    metadata as Dictionary[String, List[Integer]]
    sync_marker as List[Integer]

Type called "AvroDataBlock":
    count as Integer
    size as Integer
    data as List[Integer]
    sync_marker as List[Integer]

Note: Parse Avro schema from JSON
Process called "parse_avro_schema" that takes schema_json as String returns AvroSchema:
    Let schema_obj be JSON.parse with json_string as schema_json
    Return parse_schema_object with obj as schema_obj

Process called "parse_schema_object" that takes obj as Any returns AvroSchema:
    If obj is String:
    Note: Primitive type or named reference
    Return AvroSchema with:
    type as obj
    name as none
    namespace as none
    doc as none
    aliases as list containing
    fields as none
    symbols as none
    items as none
    values as none
    size as none
    schemas as none
    default_value as none
    logical_type as none Otherwise if obj is Dictionary:
    Let schema be AvroSchema with:
    type as obj.get with key as "type"
    name as obj.get_optional with key as "name"
    namespace as obj.get_optional with key as "namespace"
    doc as obj.get_optional with key as "doc"
    aliases as (obj.get_optional with key as "aliases" or list containing)
    fields as none
    symbols as none
    items as none
    values as none
    size as none
    schemas as none
    default_value as obj.get_optional with key as "default"
    logical_type as obj.get_optional with key as "logicalType" Note: Parse type-specific fields
    If schema.type equals "record":
    Let fields_list be obj.get with key as "fields"
    Let parsed_fields be list containing
    For field_obj in fields_list:
    parsed_fields.append with item as parse_field_object with obj as field_obj
    schema.fields = parsed_fields Otherwise if schema.type equals "enum":
    schema.symbols = obj.get with key as "symbols" Otherwise if schema.type equals "array":
    schema.items = parse_schema_object with obj as obj.get with key as "items" Otherwise if schema.type equals "map":
    schema.values = parse_schema_object with obj as obj.get with key as "values" Otherwise if schema.type equals "fixed":
    schema.size = obj.get with key as "size" Otherwise if schema.type equals "union":
    Let union_schemas be obj
    Let parsed_schemas be list containing
    For union_schema in union_schemas:
    parsed_schemas.append with item as parse_schema_object with obj as union_schema
    schema.schemas = parsed_schemas Return schema Otherwise if obj is List:
    Note: Union type
    Let union_schemas be list containing
    For union_schema in obj:
    union_schemas.append with item as parse_schema_object with obj as union_schema Return AvroSchema with:
    type as "union"
    name as none
    namespace as none
    doc as none
    aliases as list containing
    fields as none
    symbols as none
    items as none
    values as none
    size as none
    schemas as union_schemas
    default_value as none
    logical_type as none Otherwise:
    Throw Errors.ParseError with message as "Invalid Avro schema format"

Process called "parse_field_object" that takes obj as Dictionary returns AvroField:
    Return AvroField with:
    name as obj.get with key as "name"
    type as parse_schema_object with obj as obj.get with key as "type"
    doc as obj.get_optional with key as "doc"
    default_value as obj.get_optional with key as "default"
    order as obj.get_optional with key as "order"
    aliases as (obj.get_optional with key as "aliases" or list containing)

Note: Serialize data to Avro binary format
Process called "serialize_avro_binary" that takes data as Any and schema as AvroSchema and registry as Optional[AvroSchemaRegistry] returns List[Integer]:
    Let encoder be AvroEncoder with:
    buffer as list containing
    schema as schema
    registry as registry encode_value with encoder as encoder and value as data and schema as schema
    Return encoder.buffer

Note: Deserialize Avro binary data
Process called "deserialize_avro_binary" that takes data as List[Integer] and writer_schema as AvroSchema and reader_schema as Optional[AvroSchema] and registry as Optional[AvroSchemaRegistry] returns Any:
    Let decoder be AvroDecoder with:
    data as data
    position as 0
    writer_schema as writer_schema
    reader_schema as (reader_schema or writer_schema)
    registry as registry Return decode_value with decoder as decoder and writer_schema as writer_schema and reader_schema as decoder.reader_schema

Note: Encode value based on schema type
Process called "encode_value" that takes encoder as AvroEncoder and value as Any and schema as AvroSchema returns Nothing:
    If schema.type equals "null":
    Note: Null values are not encoded
    Return Otherwise if schema.type equals "boolean":
    If value:
    encoder.buffer.append with item as 1
    Otherwise:
    encoder.buffer.append with item as 0 Otherwise if schema.type equals "int":
    encode_int with encoder as encoder and value as value Otherwise if schema.type equals "long":
    encode_long with encoder as encoder and value as value Otherwise if schema.type equals "float":
    encode_float with encoder as encoder and value as value Otherwise if schema.type equals "double":
    encode_double with encoder as encoder and value as value Otherwise if schema.type equals "bytes":
    encode_bytes with encoder as encoder and value as value Otherwise if schema.type equals "string":
    encode_string with encoder as encoder and value as value Otherwise if schema.type equals "record":
    encode_record with encoder as encoder and value as value and schema as schema Otherwise if schema.type equals "enum":
    encode_enum with encoder as encoder and value as value and schema as schema Otherwise if schema.type equals "array":
    encode_array with encoder as encoder and value as value and schema as schema Otherwise if schema.type equals "map":
    encode_map with encoder as encoder and value as value and schema as schema Otherwise if schema.type equals "union":
    encode_union with encoder as encoder and value as value and schema as schema Otherwise if schema.type equals "fixed":
    encode_fixed with encoder as encoder and value as value and schema as schema Otherwise:
    Throw Errors.SerializationError with message as "Unsupported Avro type: " + schema.type

Note: Encode primitive types
Process called "encode_int" that takes encoder as AvroEncoder and value as Integer returns Nothing:
    encode_varint with encoder as encoder and value as zigzag_encode_int with value as value

Process called "encode_long" that takes encoder as AvroEncoder and value as Integer returns Nothing:
    encode_varint with encoder as encoder and value as zigzag_encode_long with value as value

Process called "encode_float" that takes encoder as AvroEncoder and value as Float returns Nothing:
    Let bits be value.to_ieee754_float32_bits
    encoder.buffer.append with item as (bits & 0xFF)
    encoder.buffer.append with item as ((bits >> 8) & 0xFF)
    encoder.buffer.append with item as ((bits >> 16) & 0xFF)
    encoder.buffer.append with item as ((bits >> 24) & 0xFF)

Process called "encode_double" that takes encoder as AvroEncoder and value as Float returns Nothing:
    Let bits be value.to_ieee754_float64_bits
    For i from 0 to 8:
    encoder.buffer.append with item as ((bits >> (i multiplied by 8)) & 0xFF)

Process called "encode_bytes" that takes encoder as AvroEncoder and value as List[Integer] returns Nothing:
    encode_varint with encoder as encoder and value as value.size
    For byte in value:
    encoder.buffer.append with item as byte

Process called "encode_string" that takes encoder as AvroEncoder and value as String returns Nothing:
    Let utf8_bytes be value.encode with encoding as "utf-8"
    encode_varint with encoder as encoder and value as utf8_bytes.size
    For byte in utf8_bytes:
    encoder.buffer.append with item as byte

Note: Encode complex types
Process called "encode_record" that takes encoder as AvroEncoder and value as Dictionary and schema as AvroSchema returns Nothing:
    If schema.fields is none:
    Throw Errors.SerializationError with message as "Record schema missing fields"
    For field in schema.fields:
    If value.contains_key with key as field.name:
    encode_value with encoder as encoder and value as value.get with key as field.name and schema as field.type
    Otherwise if field.default_value is not none:
    encode_value with encoder as encoder and value as field.default_value and schema as field.type
    Otherwise:
    Throw Errors.SerializationError with message as "Required field missing: " + field.name

Process called "encode_enum" that takes encoder as AvroEncoder and value as String and schema as AvroSchema returns Nothing:
    If schema.symbols is none:
    Throw Errors.SerializationError with message as "Enum schema missing symbols"
    For i from 0 to schema.symbols.size:
    If schema.symbols.get with index as i equals value:
    encode_varint with encoder as encoder and value as i
    Return Throw Errors.SerializationError with message as "Invalid enum value: " + value

Process called "encode_array" that takes encoder as AvroEncoder and value as List and schema as AvroSchema returns Nothing:
    If schema.items is none:
    Throw Errors.SerializationError with message as "Array schema missing items type"
    If value.size is greater than 0:
    encode_varint with encoder as encoder and value as value.size
    For item in value:
    encode_value with encoder as encoder and value as item and schema as schema.items Note: Array terminator
    encode_varint with encoder as encoder and value as 0

Process called "encode_map" that takes encoder as AvroEncoder and value as Dictionary and schema as AvroSchema returns Nothing:
    If schema.values is none:
    Throw Errors.SerializationError with message as "Map schema missing values type"
    If value.size is greater than 0:
    encode_varint with encoder as encoder and value as value.size
    For key, map_value in value:
    encode_string with encoder as encoder and value as key
    encode_value with encoder as encoder and value as map_value and schema as schema.values Note: Map terminator
    encode_varint with encoder as encoder and value as 0

Process called "encode_union" that takes encoder as AvroEncoder and value as Dictionary and schema as AvroSchema returns Nothing:
    If schema.schemas is none:
    Throw Errors.SerializationError with message as "Union schema missing schemas"
    If not value.contains_key with key as "type" or not value.contains_key with key as "value":
    Throw Errors.SerializationError with message as "Union value must have 'type' and 'value' fields"
    Let union_type be value.get with key as "type"
    Let union_value be value.get with key as "value"
    For i from 0 to schema.schemas.size:
    Let union_schema be schema.schemas.get with index as i
    If union_schema.type equals union_type or union_schema.name equals union_type:
    encode_varint with encoder as encoder and value as i
    encode_value with encoder as encoder and value as union_value and schema as union_schema
    Return Throw Errors.SerializationError with message as "Invalid union type: " + union_type

Process called "encode_fixed" that takes encoder as AvroEncoder and value as List[Integer] and schema as AvroSchema returns Nothing:
    If schema.size is none:
    Throw Errors.SerializationError with message as "Fixed schema missing size"
    If value.size is not schema.size:
    Throw Errors.SerializationError with message as "Fixed value size mismatch"
    For byte in value:
    encoder.buffer.append with item as byte

Note: Variable-length integer encoding (zigzag + varint)
Process called "encode_varint" that takes encoder as AvroEncoder and value as Integer returns Nothing:
    Let unsigned_value be value
    If unsigned_value is less than 0:
    Set unsigned_value to (4294967296 + unsigned_value) While unsigned_value is greater than or equal to 128:
    encoder.buffer.append with item as ((unsigned_value & 0x7F) | 0x80)
    Set unsigned_value to unsigned_value >> 7 encoder.buffer.append with item as (unsigned_value & 0x7F)

Process called "zigzag_encode_int" that takes value as Integer returns Integer:
    Return (value << 1) ^ (value >> 31)

Process called "zigzag_encode_long" that takes value as Integer returns Integer:
    Return (value << 1) ^ (value >> 63)

Note: Decode value based on schema type
Process called "decode_value" that takes decoder as AvroDecoder and writer_schema as AvroSchema and reader_schema as AvroSchema returns Any:
    Note: Handle schema evolution
    If can_resolve_schemas with writer as writer_schema and reader as reader_schema:
    Return decode_with_resolution with decoder as decoder and writer as writer_schema and reader as reader_schema Note: Direct decoding when schemas match
    If writer_schema.type equals "null":
    Return none Otherwise if writer_schema.type equals "boolean":
    Return decode_boolean with decoder as decoder Otherwise if writer_schema.type equals "int":
    Return decode_int with decoder as decoder Otherwise if writer_schema.type equals "long":
    Return decode_long with decoder as decoder Otherwise if writer_schema.type equals "float":
    Return decode_float with decoder as decoder Otherwise if writer_schema.type equals "double":
    Return decode_double with decoder as decoder Otherwise if writer_schema.type equals "bytes":
    Return decode_bytes with decoder as decoder Otherwise if writer_schema.type equals "string":
    Return decode_string with decoder as decoder Otherwise if writer_schema.type equals "record":
    Return decode_record with decoder as decoder and writer_schema as writer_schema and reader_schema as reader_schema Otherwise if writer_schema.type equals "enum":
    Return decode_enum with decoder as decoder and writer_schema as writer_schema and reader_schema as reader_schema Otherwise if writer_schema.type equals "array":
    Return decode_array with decoder as decoder and writer_schema as writer_schema and reader_schema as reader_schema Otherwise if writer_schema.type equals "map":
    Return decode_map with decoder as decoder and writer_schema as writer_schema and reader_schema as reader_schema Otherwise if writer_schema.type equals "union":
    Return decode_union with decoder as decoder and writer_schema as writer_schema and reader_schema as reader_schema Otherwise if writer_schema.type equals "fixed":
    Return decode_fixed with decoder as decoder and writer_schema as writer_schema Otherwise:
    Throw Errors.DeserializationError with message as "Unsupported Avro type: " + writer_schema.type

Note: Decode primitive types
Process called "decode_boolean" that takes decoder as AvroDecoder returns Boolean:
    Let byte_value be read_byte with decoder as decoder
    Return byte_value is not 0

Process called "decode_int" that takes decoder as AvroDecoder returns Integer:
    Let varint_value be decode_varint with decoder as decoder
    Return zigzag_decode_int with value as varint_value

Process called "decode_long" that takes decoder as AvroDecoder returns Integer:
    Let varint_value be decode_varint with decoder as decoder
    Return zigzag_decode_long with value as varint_value

Process called "decode_float" that takes decoder as AvroDecoder returns Float:
    Let byte1 be read_byte with decoder as decoder
    Let byte2 be read_byte with decoder as decoder
    Let byte3 be read_byte with decoder as decoder
    Let byte4 be read_byte with decoder as decoder Let bits be byte1 | (byte2 << 8) | (byte3 << 16) | (byte4 << 24)
    Return Float.from_ieee754_float32_bits with bits as bits

Process called "decode_double" that takes decoder as AvroDecoder returns Float:
    Let bits be 0
    For i from 0 to 8:
    Let byte_value be read_byte with decoder as decoder
    Set bits to bits | (byte_value << (i multiplied by 8)) Return Float.from_ieee754_float64_bits with bits as bits

Process called "decode_bytes" that takes decoder as AvroDecoder returns List[Integer]:
    Let length be decode_varint with decoder as decoder
    Let bytes be list containing For i from 0 to length:
    bytes.append with item as read_byte with decoder as decoder Return bytes

Process called "decode_string" that takes decoder as AvroDecoder returns String:
    Let utf8_bytes be decode_bytes with decoder as decoder
    Return utf8_bytes.decode with encoding as "utf-8"

Note: Decode complex types
Process called "decode_record" that takes decoder as AvroDecoder and writer_schema as AvroSchema and reader_schema as AvroSchema returns Dictionary:
    Let result be dictionary containing If writer_schema.fields is none:
    Throw Errors.DeserializationError with message as "Record schema missing fields"
    For field in writer_schema.fields:
    Let field_value be decode_value with decoder as decoder and writer_schema as field.type and reader_schema as get_reader_field_type with reader_schema as reader_schema and field_name as field.name
    result.set with key as field.name and value as field_value Note: Add default values for fields in reader schema but not in writer schema
    If reader_schema.fields is not none:
    For reader_field in reader_schema.fields:
    If not result.contains_key with key as reader_field.name and reader_field.default_value is not none:
    result.set with key as reader_field.name and value as reader_field.default_value Return result

Process called "decode_enum" that takes decoder as AvroDecoder and writer_schema as AvroSchema and reader_schema as AvroSchema returns String:
    Let enum_index be decode_varint with decoder as decoder If writer_schema.symbols is none:
    Throw Errors.DeserializationError with message as "Enum schema missing symbols"
    If enum_index is greater than or equal to writer_schema.symbols.size:
    Throw Errors.DeserializationError with message as "Invalid enum index: " + enum_index.to_string Return writer_schema.symbols.get with index as enum_index

Process called "decode_array" that takes decoder as AvroDecoder and writer_schema as AvroSchema and reader_schema as AvroSchema returns List:
    Let result be list containing If writer_schema.items is none:
    Throw Errors.DeserializationError with message as "Array schema missing items type"
    Let reader_item_type be reader_schema.items or writer_schema.items While true:
    Let count be decode_varint with decoder as decoder If count equals 0:
    Break If count is less than 0:
    Note: Negative count indicates size in bytes (skip size)
    Set count to -count
    decode_varint with decoder as decoder For i from 0 to count:
    Let item be decode_value with decoder as decoder and writer_schema as writer_schema.items and reader_schema as reader_item_type
    result.append with item as item Return result

Process called "decode_map" that takes decoder as AvroDecoder and writer_schema as AvroSchema and reader_schema as AvroSchema returns Dictionary:
    Let result be dictionary containing If writer_schema.values is none:
    Throw Errors.DeserializationError with message as "Map schema missing values type"
    Let reader_value_type be reader_schema.values or writer_schema.values While true:
    Let count be decode_varint with decoder as decoder If count equals 0:
    Break If count is less than 0:
    Note: Negative count indicates size in bytes (skip size)
    Set count to -count
    decode_varint with decoder as decoder For i from 0 to count:
    Let key be decode_string with decoder as decoder
    Let value be decode_value with decoder as decoder and writer_schema as writer_schema.values and reader_schema as reader_value_type
    result.set with key as key and value as value Return result

Process called "decode_union" that takes decoder as AvroDecoder and writer_schema as AvroSchema and reader_schema as AvroSchema returns Dictionary:
    Let union_index be decode_varint with decoder as decoder If writer_schema.schemas is none:
    Throw Errors.DeserializationError with message as "Union schema missing schemas"
    If union_index is greater than or equal to writer_schema.schemas.size:
    Throw Errors.DeserializationError with message as "Invalid union index: " + union_index.to_string Let union_schema be writer_schema.schemas.get with index as union_index
    Let union_value be decode_value with decoder as decoder and writer_schema as union_schema and reader_schema as union_schema Return dictionary containing:
    "type" -> union_schema.type
    "value" -> union_value

Process called "decode_fixed" that takes decoder as AvroDecoder and writer_schema as AvroSchema returns List[Integer]:
    If writer_schema.size is none:
    Throw Errors.DeserializationError with message as "Fixed schema missing size"
    Let bytes be list containing
    For i from 0 to writer_schema.size:
    bytes.append with item as read_byte with decoder as decoder Return bytes

Note: Variable-length integer decoding
Process called "decode_varint" that takes decoder as AvroDecoder returns Integer:
    Let result be 0
    Let shift be 0 While decoder.position is less than decoder.data.size:
    Let byte_value be read_byte with decoder as decoder
    Set result to result | ((byte_value & 0x7F) << shift) If (byte_value & 0x80) equals 0:
    Return result Set shift to shift + 7 If shift is greater than or equal to 64:
    Throw Errors.DeserializationError with message as "Varint too long"
    Throw Errors.DeserializationError with message as "Unexpected end of data while reading varint"

Process called "zigzag_decode_int" that takes value as Integer returns Integer:
    Return (value >> 1) ^ (-(value & 1))

Process called "zigzag_decode_long" that takes value as Integer returns Integer:
    Return (value >> 1) ^ (-(value & 1))

Process called "read_byte" that takes decoder as AvroDecoder returns Integer:
    If decoder.position is greater than or equal to decoder.data.size:
    Throw Errors.DeserializationError with message as "Unexpected end of data"
    Let byte_value be decoder.data.get with index as decoder.position
    decoder.position = decoder.position + 1
    Return byte_value

Note: Schema evolution and compatibility
Process called "can_resolve_schemas" that takes writer as AvroSchema and reader as AvroSchema returns Boolean:
    If writer.type equals reader.type:
    Return true Note: Type promotion rules
    If writer.type equals "int" and (reader.type equals "long" or reader.type equals "float" or reader.type equals "double"):
    Return true If writer.type equals "long" and (reader.type equals "float" or reader.type equals "double"):
    Return true If writer.type equals "float" and reader.type equals "double":
    Return true If writer.type equals "string" and reader.type equals "bytes":
    Return true If writer.type equals "bytes" and reader.type equals "string":
    Return true Return false

Process called "decode_with_resolution" that takes decoder as AvroDecoder and writer as AvroSchema and reader as AvroSchema returns Any:
    Note: Handle type promotion
    If writer.type equals "int" and reader.type equals "long":
    Return decode_int with decoder as decoder If writer.type equals "int" and reader.type equals "float":
    Let int_value be decode_int with decoder as decoder
    Return int_value.to_float If writer.type equals "int" and reader.type equals "double":
    Let int_value be decode_int with decoder as decoder
    Return int_value.to_double If writer.type equals "long" and reader.type equals "float":
    Let long_value be decode_long with decoder as decoder
    Return long_value.to_float If writer.type equals "long" and reader.type equals "double":
    Let long_value be decode_long with decoder as decoder
    Return long_value.to_double If writer.type equals "float" and reader.type equals "double":
    Let float_value be decode_float with decoder as decoder
    Return float_value.to_double If writer.type equals "string" and reader.type equals "bytes":
    Let string_value be decode_string with decoder as decoder
    Return string_value.encode with encoding as "utf-8"
    If writer.type equals "bytes" and reader.type equals "string":
    Let bytes_value be decode_bytes with decoder as decoder
    Return bytes_value.decode with encoding as "utf-8" Note: Default to standard decoding
    Return decode_value with decoder as decoder and writer_schema as writer and reader_schema as reader

Process called "get_reader_field_type" that takes reader_schema as AvroSchema and field_name as String returns AvroSchema:
    If reader_schema.fields is none:
    Return reader_schema For field in reader_schema.fields:
    If field.name equals field_name:
    Return field.type Note: Field not found in reader schema - return writer field type for compatibility
    Return reader_schema

Note: Avro data file format support
Process called "create_avro_data_file" that takes schema as AvroSchema and data as List[Any] returns AvroDataFile:
    Let sync_marker be generate_sync_marker Let header be AvroDataFileHeader with:
    magic as list containing 0x4F 0x62 0x6A 0x01
    metadata as dictionary containing:
    "avro.schema" -> schema.to_json_string.encode with encoding as "utf-8"
    "avro.codec" -> "null".encode with encoding as "utf-8"
    sync_marker as sync_marker Let blocks be list containing
    Let block_data be list containing For item in data:
    Let item_data be serialize_avro_binary with data as item and schema as schema
    For byte in item_data:
    block_data.append with item as byte Let data_block be AvroDataBlock with:
    count as data.size
    size as block_data.size
    data as block_data
    sync_marker as sync_marker blocks.append with item as data_block Return AvroDataFile with:
    header as header
    blocks as blocks
    schema as schema

Process called "generate_sync_marker" returns List[Integer]:
    Let marker be list containing
    For i from 0 to 16:
    marker.append with item as Math.random_int with min as 0 and max as 255
    Return marker

Note: Schema registry operations
Process called "create_schema_registry" that takes compatibility_mode as CompatibilityMode returns AvroSchemaRegistry:
    Return AvroSchemaRegistry with:
    schemas as dictionary containing
    schema_hashes as dictionary containing
    compatibility_mode as compatibility_mode
    evolution_history as dictionary containing

Process called "register_schema" that takes registry as AvroSchemaRegistry and schema_name as String and schema as AvroSchema returns Boolean:
    Let schema_json be schema.to_json_string
    Let schema_hash be Hash.sha256 with data as schema_json.encode with encoding as "utf-8"
    If registry.schemas.contains_key with key as schema_name:
    Note: Check compatibility with existing schema
    Let existing_schema be registry.schemas.get with key as schema_name
    If not is_compatible with existing as existing_schema and new as schema and mode as registry.compatibility_mode:
    Return false Note: Add to evolution history
    If not registry.evolution_history.contains_key with key as schema_name:
    registry.evolution_history.set with key as schema_name and value as list containing
    registry.evolution_history.get with key as schema_name.append with item as schema registry.schemas.set with key as schema_name and value as schema
    registry.schema_hashes.set with key as schema_name and value as schema_hash.to_hex_string
    Return true

Process called "is_compatible" that takes existing as AvroSchema and new as AvroSchema and mode as CompatibilityMode returns Boolean:
    If mode equals None:
    Return true Otherwise if mode equals Backward:
    Return can_read_with_schema with writer_schema as existing and reader_schema as new Otherwise if mode equals Forward:
    Return can_read_with_schema with writer_schema as new and reader_schema as existing Otherwise if mode equals Full:
    Return can_read_with_schema with writer_schema as existing and reader_schema as new and can_read_with_schema with writer_schema as new and reader_schema as existing Return false

Process called "can_read_with_schema" that takes writer_schema as AvroSchema and reader_schema as AvroSchema returns Boolean:
    Try:
    Note: Test schema compatibility by attempting to resolve
    Return can_resolve_schemas with writer as writer_schema and reader as reader_schema
    Catch:
    Return false

Note: JSON serialization support (for debugging and interop)
Process called "serialize_avro_json" that takes data as Any and schema as AvroSchema returns String:
    Let json_value be convert_to_json_value with data as data and schema as schema
    Return JSON.serialize with data as json_value

Process called "deserialize_avro_json" that takes json_string as String and schema as AvroSchema returns Any:
    Let json_value be JSON.parse with json_string as json_string
    Return convert_from_json_value with json_value as json_value and schema as schema

Process called "convert_to_json_value" that takes data as Any and schema as AvroSchema returns Any:
    If schema.type equals "null":
    Return none
    Otherwise if schema.type equals "boolean" or schema.type equals "int" or schema.type equals "long" or schema.type equals "float" or schema.type equals "double" or schema.type equals "string":
    Return data
    Otherwise if schema.type equals "bytes":
    Return data.to_base64_string
    Otherwise if schema.type equals "record":
    Let result be dictionary containing
    For key, value in data:
    Let field_schema be get_field_schema with schema as schema and field_name as key
    result.set with key as key and value as convert_to_json_value with data as value and schema as field_schema
    Return result
    Otherwise if schema.type equals "enum":
    Return data
    Otherwise if schema.type equals "array":
    Let result be list containing
    For item in data:
    result.append with item as convert_to_json_value with data as item and schema as schema.items
    Return result
    Otherwise if schema.type equals "map":
    Let result be dictionary containing
    For key, value in data:
    result.set with key as key and value as convert_to_json_value with data as value and schema as schema.values
    Return result
    Otherwise if schema.type equals "union":
    Return data
    Otherwise if schema.type equals "fixed":
    Return data.to_base64_string
    Otherwise:
    Return data

Note: Performance benchmarking
Process called "benchmark_avro" that takes test_data as Any and schema as AvroSchema and iterations as Integer returns AvroBenchmark:
    Let binary_encode_times be list containing
    Let binary_decode_times be list containing
    Let json_encode_times be list containing
    Let json_decode_times be list containing
    Let binary_size be 0
    Let json_size be 0 For i from 0 to iterations:
    Note: Binary serialization benchmark
    Let start_time be DateTime.now
    Let binary_data be serialize_avro_binary with data as test_data and schema as schema
    Let end_time be DateTime.now
    binary_encode_times.append with item as (end_time - start_time).total_milliseconds If i equals 0:
    Set binary_size to binary_data.size Set start_time to DateTime.now
    deserialize_avro_binary with data as binary_data and writer_schema as schema and reader_schema as schema
    Set end_time to DateTime.now
    binary_decode_times.append with item as (end_time - start_time).total_milliseconds Note: JSON serialization benchmark
    Set start_time to DateTime.now
    Let json_data be serialize_avro_json with data as test_data and schema as schema
    Set end_time to DateTime.now
    json_encode_times.append with item as (end_time - start_time).total_milliseconds If i equals 0:
    Set json_size to json_data.length Set start_time to DateTime.now
    deserialize_avro_json with json_string as json_data and schema as schema
    Set end_time to DateTime.now
    json_decode_times.append with item as (end_time - start_time).total_milliseconds Return AvroBenchmark with:
    binary_encode_avg_time as (binary_encode_times.sum divided by iterations)
    binary_decode_avg_time as (binary_decode_times.sum divided by iterations)
    json_encode_avg_time as (json_encode_times.sum divided by iterations)
    json_decode_avg_time as (json_decode_times.sum divided by iterations)
    binary_size as binary_size
    json_size as json_size
    compression_ratio as (binary_size.to_float divided by json_size.to_float)
    iterations as iterations

Type called "AvroBenchmark":
    binary_encode_avg_time as Float
    binary_decode_avg_time as Float
    json_encode_avg_time as Float
    json_decode_avg_time as Float
    binary_size as Integer
    json_size as Integer
    compression_ratio as Float
    iterations as Integer

Note: Schema validation and utilities
Process called "validate_avro_data" that takes data as Any and schema as AvroSchema returns AvroValidationResult:
    Let result be AvroValidationResult with:
    valid as true
    errors as list containing
    warnings as list containing
    schema_info as get_schema_info with schema as schema validate_data_recursive with data as data and schema as schema and result as result and path as ""
    If not result.errors.is_empty:
    result.valid = false Return result

Type called "AvroValidationResult":
    valid as Boolean
    errors as List[String]
    warnings as List[String]
    schema_info as AvroSchemaInfo

Type called "AvroSchemaInfo":
    schema_type as String
    field_count as Integer
    nesting_depth as Integer
    total_size_estimate as Integer

Process called "validate_data_recursive" that takes data as Any and schema as AvroSchema and result as AvroValidationResult and path as String returns Nothing:
    If schema.type equals "null" and data is not none:
    result.errors.append with item as path + ": Expected null, got " + data.type.name Otherwise if schema.type equals "boolean" and data is not Boolean:
    result.errors.append with item as path + ": Expected boolean, got " + data.type.name Otherwise if schema.type equals "int" and (data is not Integer or data is less than -2147483648 or data is greater than 2147483647):
    result.errors.append with item as path + ": Expected 32-bit integer" Otherwise if schema.type equals "long" and data is not Integer:
    result.errors.append with item as path + ": Expected 64-bit integer" Otherwise if (schema.type equals "float" or schema.type equals "double") and (data is not Float and data is not Integer):
    result.errors.append with item as path + ": Expected number, got " + data.type.name Otherwise if schema.type equals "bytes" and data is not List:
    result.errors.append with item as path + ": Expected bytes array, got " + data.type.name Otherwise if schema.type equals "string" and data is not String:
    result.errors.append with item as path + ": Expected string, got " + data.type.name Otherwise if schema.type equals "record":
    If data is not Dictionary:
    result.errors.append with item as path + ": Expected record (dictionary), got " + data.type.name
    Otherwise if schema.fields is not none:
    For field in schema.fields:
    Let field_path be path + "." + field.name
    If data.contains_key with key as field.name:
    validate_data_recursive with data as data.get with key as field.name and schema as field.type and result as result and path as field_path
    Otherwise if field.default_value is none:
    result.errors.append with item as field_path + ": Required field missing" Otherwise if schema.type equals "array":
    If data is not List:
    result.errors.append with item as path + ": Expected array, got " + data.type.name
    Otherwise if schema.items is not none:
    For i from 0 to data.size:
    validate_data_recursive with data as data.get with index as i and schema as schema.items and result as result and path as (path + "[" + i.to_string + "]") Otherwise if schema.type equals "map":
    If data is not Dictionary:
    result.errors.append with item as path + ": Expected map, got " + data.type.name
    Otherwise if schema.values is not none:
    For key, value in data:
    validate_data_recursive with data as value and schema as schema.values and result as result and path as (path + "[" + key + "]")

Process called "get_schema_info" that takes schema as AvroSchema returns AvroSchemaInfo:
    Return AvroSchemaInfo with:
    schema_type as schema.type
    field_count as count_schema_fields with schema as schema
    nesting_depth as calculate_schema_depth with schema as schema and depth as 0
    total_size_estimate as estimate_schema_size with schema as schema

Process called "count_schema_fields" that takes schema as AvroSchema returns Integer:
    If schema.fields is not none:
    Return schema.fields.size
    Otherwise:
    Return 0

Process called "calculate_schema_depth" that takes schema as AvroSchema and depth as Integer returns Integer:
    If schema.type equals "record" and schema.fields is not none:
    Let max_depth be depth
    For field in schema.fields:
    Let field_depth be calculate_schema_depth with schema as field.type and depth as (depth + 1)
    If field_depth is greater than max_depth:
    Set max_depth to field_depth
    Return max_depth
    Otherwise if schema.type equals "array" and schema.items is not none:
    Return calculate_schema_depth with schema as schema.items and depth as (depth + 1)
    Otherwise if schema.type equals "map" and schema.values is not none:
    Return calculate_schema_depth with schema as schema.values and depth as (depth + 1)
    Otherwise if schema.type equals "union" and schema.schemas is not none:
    Let max_depth be depth
    For union_schema in schema.schemas:
    Let union_depth be calculate_schema_depth with schema as union_schema and depth as (depth + 1)
    If union_depth is greater than max_depth:
    Set max_depth to union_depth
    Return max_depth
    Otherwise:
    Return depth

Process called "estimate_schema_size" that takes schema as AvroSchema returns Integer:
    If schema.type equals "null":
    Return 0
    Otherwise if schema.type equals "boolean":
    Return 1
    Otherwise if schema.type equals "int" or schema.type equals "long":
    Return 5
    Otherwise if schema.type equals "float":
    Return 4
    Otherwise if schema.type equals "double":
    Return 8
    Otherwise if schema.type equals "fixed" and schema.size is not none:
    Return schema.size
    Otherwise:
    Return 10