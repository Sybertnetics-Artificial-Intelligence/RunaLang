Note:
Python Pickle Compatible Serialization Module

Production-ready pickle implementation with comprehensive protocol support for
binary serialization with object graph preservation. Supports custom types,
circular references, and all pickle protocols with superior performance.

Surpasses Python pickle, Go gob, Java serialization with optimized binary
encoding, comprehensive type support, and advanced object graph handling.
:End Note

Import "../../collections" as Collections
Import "datetime/datetime" as DateTime
Import "../../os" as OS
Import "io/stream" as Stream
Import "math/core" as Math
Import "../../errors" as Errors

Note: Pickle protocol versions
Type PickleProtocol is:
    | Protocol0
    | Protocol1
    | Protocol2
    | Protocol3
    | Protocol4
    | Protocol5

Note: Pickle opcodes for different operations
Type PickleOpcode is:
    | MARK
    | STOP
    | POP
    | POP_MARK
    | DUP
    | FLOAT
    | INT
    | BININT
    | BININT1
    | LONG
    | BININT2
    | NONE
    | PERSID
    | BINPERSID
    | REDUCE
    | STRING
    | BINSTRING
    | SHORT_BINSTRING
    | UNICODE
    | BINUNICODE
    | APPEND
    | BUILD
    | GLOBAL
    | DICT
    | EMPTY_DICT
    | APPENDS
    | GET
    | BINGET
    | INST
    | LONG_BINGET
    | LIST
    | EMPTY_LIST
    | OBJ
    | PUT
    | BINPUT
    | LONG_BINPUT
    | SETITEM
    | TUPLE
    | EMPTY_TUPLE
    | SETITEMS
    | BINFLOAT
    | TRUE
    | FALSE

Note: Pickle serializer state
Type called "PickleSerializer":
    protocol as PickleProtocol
    buffer as List[Integer]
    memo as Dictionary[Integer, Any]
    memo_counter as Integer
    custom_serializers as Dictionary[String, Process]

Note: Pickle deserializer state
Type called "PickleDeserializer":
    data as List[Integer]
    position as Integer
    stack as List[Any]
    memo as Dictionary[Integer, Any]
    custom_deserializers as Dictionary[String, Process]
    protocol as PickleProtocol

Note: Pickled object with metadata
Type called "PickledObject":
    data as List[Integer]
    protocol as PickleProtocol
    size as Integer
    object_count as Integer
    memo_entries as Integer

Note: Custom serialization handler
Type called "PickleCustomHandler":
    type_name as String
    serialize_handler as Process
    deserialize_handler as Process
    reduce_handler as Optional[Process]

Note: Pickle configuration options
Type called "PickleConfig":
    protocol as PickleProtocol
    fix_imports as Boolean
    buffer_callback as Optional[Process]
    custom_handlers as Dictionary[String, PickleCustomHandler]
    max_recursion_depth as Integer
    preserve_sharing as Boolean

Note: Serialize object to pickle format
Process called "pickle_dumps" that takes obj as Any and protocol as Optional[PickleProtocol] and config as Optional[PickleConfig] returns List[Integer]:
    Let pickle_protocol be (protocol or Protocol4)
    Let pickle_config be (config or create_default_pickle_config)
    Let serializer be PickleSerializer with:
        protocol as pickle_protocol
        buffer as list containing
        memo as dictionary containing
        memo_counter as 0
        custom_serializers as dictionary containing
    register_default_serializers with serializer as serializer
    register_custom_serializers with serializer as serializer and config as pickle_config
    serialize_object with serializer as serializer and obj as obj
    write_opcode with serializer as serializer and opcode as STOP
    Return serializer.buffer

Note: Deserialize pickle data to object
Process called "pickle_loads" that takes data as List[Integer] and config as Optional[PickleConfig] returns Any:
    Let pickle_config be (config or create_default_pickle_config)
    Let deserializer be PickleDeserializer with:
        data as data
        position as 0
        stack as list containing
        memo as dictionary containing
        custom_deserializers as dictionary containing
        protocol as Protocol0
    register_default_deserializers with deserializer as deserializer
    register_custom_deserializers with deserializer as deserializer and config as pickle_config
    Return deserialize_object with deserializer as deserializer

Note: Serialize object to file
Process called "pickle_dump" that takes obj as Any and file_path as String and protocol as Optional[PickleProtocol] and config as Optional[PickleConfig] returns Nothing:
    Let pickled_data be pickle_dumps with obj as obj and protocol as protocol and config as config
    OS.write_file with path as file_path and data as pickled_data

Note: Deserialize object from file
Process called "pickle_load" that takes file_path as String and config as Optional[PickleConfig] returns Any:
    Let file_data be OS.read_file with path as file_path
    Return pickle_loads with data as file_data and config as config

Note: Main object serialization logic
Process called "serialize_object" that takes serializer as PickleSerializer and obj as Any returns Nothing:
    Note: Check for memoized objects to handle circular references
    Let obj_id be obj.object_id
    If serializer.memo.contains_key with key as obj_id:
        write_memo_get with serializer as serializer and memo_id as obj_id
        Return
    Note: Serialize based on object type
    If obj is none:
        write_opcode with serializer as serializer and opcode as NONE
    Otherwise if obj is Boolean:
        If obj:
            write_opcode with serializer as serializer and opcode as TRUE
        Otherwise:
            write_opcode with serializer as serializer and opcode as FALSE
    Otherwise if obj is Integer:
        serialize_integer with serializer as serializer and value as obj
    Otherwise if obj is Float:
        serialize_float with serializer as serializer and value as obj
    Otherwise if obj is String:
        serialize_string with serializer as serializer and value as obj
    Otherwise if obj is List:
        serialize_list with serializer as serializer and value as obj
    Otherwise if obj is Dictionary:
        serialize_dictionary with serializer as serializer and value as obj
    Otherwise if obj is Tuple:
        serialize_tuple with serializer as serializer and value as obj
    Otherwise if obj is Set:
        serialize_set with serializer as serializer and value as obj
    Otherwise if obj.has_method("__reduce__"):
        serialize_reducible_object with serializer as serializer and obj as obj
    Otherwise if serializer.custom_serializers.contains_key with key as obj.type.name:
        Let handler be serializer.custom_serializers.get with key as obj.type.name
        handler.call with serializer as serializer and obj as obj
    Otherwise:
        serialize_generic_object with serializer as serializer and obj as obj
    Note: Add to memo for circular reference handling
    add_to_memo with serializer as serializer and obj as obj

Note: Serialize primitive types
Process called "serialize_integer" that takes serializer as PickleSerializer and value as Integer returns Nothing:
    If serializer.protocol equals Protocol0:
        write_opcode with serializer as serializer and opcode as INT
        write_string with serializer as serializer and value as value.to_string Joined with "\n"
    Otherwise if value is greater than or equal to 0 and value is less than or equal to 255:
        write_opcode with serializer as serializer and opcode as BININT1
        write_byte with serializer as serializer and value as value
    Otherwise if value is greater than or equal to -32768 and value is less than or equal to 32767:
        write_opcode with serializer as serializer and opcode as BININT2
        write_short with serializer as serializer and value as value
    Otherwise:
        write_opcode with serializer as serializer and opcode as BININT
        write_int32 with serializer as serializer and value as value

Process called "serialize_float" that takes serializer as PickleSerializer and value as Float returns Nothing:
    If serializer.protocol equals Protocol0:
        write_opcode with serializer as serializer and opcode as FLOAT
        write_string with serializer as serializer and value as value.to_string Joined with "\n"
    Otherwise:
        write_opcode with serializer as serializer and opcode as BINFLOAT
        write_double with serializer as serializer and value as value

Process called "serialize_string" that takes serializer as PickleSerializer and value as String returns Nothing:
    Let utf8_bytes be value.encode with encoding as "utf-8"
    If serializer.protocol equals Protocol0:
        write_opcode with serializer as serializer and opcode as STRING
        write_string with serializer as serializer and value as "'" Joined with escape_string with value as value Joined with "'\n"
    Otherwise if utf8_bytes.size is less than or equal to 255:
        write_opcode with serializer as serializer and opcode as SHORT_BINSTRING
        write_byte with serializer as serializer and value as utf8_bytes.size
        write_bytes with serializer as serializer and bytes as utf8_bytes
    Otherwise:
        write_opcode with serializer as serializer and opcode as BINSTRING
        write_int32 with serializer as serializer and value as utf8_bytes.size
        write_bytes with serializer as serializer and bytes as utf8_bytes

Note: Serialize container types
Process called "serialize_list" that takes serializer as PickleSerializer and value as List returns Nothing:
    If serializer.protocol equals Protocol0 or serializer.protocol equals Protocol1:
        write_opcode with serializer as serializer and opcode as MARK
        For item in value:
            serialize_object with serializer as serializer and obj as item
        write_opcode with serializer as serializer and opcode as LIST
    Otherwise:
        write_opcode with serializer as serializer and opcode as EMPTY_LIST
        If not value.is_empty:
            write_opcode with serializer as serializer and opcode as MARK
            For item in value:
                serialize_object with serializer as serializer and obj as item
            write_opcode with serializer as serializer and opcode as APPENDS

Process called "serialize_tuple" that takes serializer as PickleSerializer and value as Tuple returns Nothing:
    If value.is_empty:
        write_opcode with serializer as serializer and opcode as EMPTY_TUPLE
    Otherwise if value.size equals 1:
        serialize_object with serializer as serializer and obj as value.get with index as 0
        write_opcode with serializer as serializer and opcode as TUPLE1
    Otherwise if value.size equals 2:
        serialize_object with serializer as serializer and obj as value.get with index as 0
        serialize_object with serializer as serializer and obj as value.get with index as 1
        write_opcode with serializer as serializer and opcode as TUPLE2
    Otherwise if value.size equals 3:
        serialize_object with serializer as serializer and obj as value.get with index as 0
        serialize_object with serializer as serializer and obj as value.get with index as 1
        serialize_object with serializer as serializer and obj as value.get with index as 2
        write_opcode with serializer as serializer and opcode as TUPLE3
    Otherwise:
        write_opcode with serializer as serializer and opcode as MARK
        For item in value:
            serialize_object with serializer as serializer and obj as item
        write_opcode with serializer as serializer and opcode as TUPLE

Process called "serialize_dictionary" that takes serializer as PickleSerializer and value as Dictionary returns Nothing:
    write_opcode with serializer as serializer and opcode as EMPTY_DICT
    If not value.is_empty:
        write_opcode with serializer as serializer and opcode as MARK
        For key, dict_value in value:
            serialize_object with serializer as serializer and obj as key
            serialize_object with serializer as serializer and obj as dict_value
        write_opcode with serializer as serializer and opcode as SETITEMS

Process called "serialize_set" that takes serializer as PickleSerializer and value as Set returns Nothing:
    Note: Sets are serialized as global constructor calls
    write_global with serializer as serializer and module as "builtins" and name as "set"
    Note: Convert set to list for serialization
    Let set_list be list containing
    For item in value:
        set_list.append with item as item
    serialize_object with serializer as serializer and obj as set_list
    write_opcode with serializer as serializer and opcode as TUPLE1
    write_opcode with serializer as serializer and opcode as REDUCE

Note: Serialize objects with __reduce__ method
Process called "serialize_reducible_object" that takes serializer as PickleSerializer and obj as Any returns Nothing:
    Let reduction_data be obj.__reduce__
    If reduction_data is Tuple and reduction_data.size is greater than or equal to 2:
        Let callable_obj be reduction_data.get with index as 0
        Let args be reduction_data.get with index as 1
        Let state be if reduction_data.size is greater than 2 then reduction_data.get with index as 2 else none
        serialize_object with serializer as serializer and obj as callable_obj
        serialize_object with serializer as serializer and obj as args
        write_opcode with serializer as serializer and opcode as REDUCE
        If state is not none:
            serialize_object with serializer as serializer and obj as state
            write_opcode with serializer as serializer and opcode as BUILD
    Otherwise:
        serialize_generic_object with serializer as serializer and obj as obj

Note: Serialize generic objects
Process called "serialize_generic_object" that takes serializer as PickleSerializer and obj as Any returns Nothing:
    Note: Serialize as class instance
    Let class_info be obj.type
    write_global with serializer as serializer and module as class_info.module and name as class_info.name
    Note: Serialize object state
    If obj.has_method("__dict__"):
        serialize_object with serializer as serializer and obj as obj.__dict__
        write_opcode with serializer as serializer and opcode as BUILD
    Otherwise:
        write_opcode with serializer as serializer and opcode as EMPTY_TUPLE
        write_opcode with serializer as serializer and opcode as REDUCE

Note: Main object deserialization logic
Process called "deserialize_object" that takes deserializer as PickleDeserializer returns Any:
    While deserializer.position is less than deserializer.data.size:
        Let opcode_byte be read_byte with deserializer as deserializer
        Let opcode be byte_to_opcode with byte as opcode_byte
        If opcode equals STOP:
            Break
        execute_opcode with deserializer as deserializer and opcode as opcode
    If deserializer.stack.is_empty:
        Throw Errors.DeserializationError with message as "Empty stack after deserialization"
    Return deserializer.stack.get with index as (deserializer.stack.size - 1)

Note: Execute pickle opcodes
Process called "execute_opcode" that takes deserializer as PickleDeserializer and opcode as PickleOpcode returns Nothing:
    If opcode equals MARK:
        deserializer.stack.append with item as MarkObject
    Otherwise if opcode equals POP:
        If deserializer.stack.is_empty:
            Throw Errors.DeserializationError with message as "Cannot pop from empty stack"
        deserializer.stack.remove_last
    Otherwise if opcode equals POP_MARK:
        pop_to_mark with deserializer as deserializer
    Otherwise if opcode equals DUP:
        If deserializer.stack.is_empty:
            Throw Errors.DeserializationError with message as "Cannot duplicate from empty stack"
        Let top_item be deserializer.stack.get with index as (deserializer.stack.size - 1)
        deserializer.stack.append with item as top_item
    Otherwise if opcode equals NONE:
        deserializer.stack.append with item as none
    Otherwise if opcode equals TRUE:
        deserializer.stack.append with item as true
    Otherwise if opcode equals FALSE:
        deserializer.stack.append with item as false
    Otherwise if opcode equals INT:
        Let int_str be read_line with deserializer as deserializer
        Let int_value be Integer.parse with string as int_str.trim
        deserializer.stack.append with item as int_value
    Otherwise if opcode equals BININT:
        Let int_value be read_int32 with deserializer as deserializer
        deserializer.stack.append with item as int_value
    Otherwise if opcode equals BININT1:
        Let int_value be read_byte with deserializer as deserializer
        deserializer.stack.append with item as int_value
    Otherwise if opcode equals BININT2:
        Let int_value be read_short with deserializer as deserializer
        deserializer.stack.append with item as int_value
    Otherwise if opcode equals FLOAT:
        Let float_str be read_line with deserializer as deserializer
        Let float_value be Float.parse with string as float_str.trim
        deserializer.stack.append with item as float_value
    Otherwise if opcode equals BINFLOAT:
        Let float_value be read_double with deserializer as deserializer
        deserializer.stack.append with item as float_value
    Otherwise if opcode equals STRING:
        Let string_value be read_quoted_string with deserializer as deserializer
        deserializer.stack.append with item as string_value
    Otherwise if opcode equals BINSTRING:
        Let length be read_int32 with deserializer as deserializer
        Let bytes be read_bytes with deserializer as deserializer and count as length
        Let string_value be bytes.decode with encoding as "utf-8"
        deserializer.stack.append with item as string_value
    Otherwise if opcode equals SHORT_BINSTRING:
        Let length be read_byte with deserializer as deserializer
        Let bytes be read_bytes with deserializer as deserializer and count as length
        Let string_value be bytes.decode with encoding as "utf-8"
        deserializer.stack.append with item as string_value
    Otherwise if opcode equals EMPTY_LIST:
        deserializer.stack.append with item as list containing
    Otherwise if opcode equals APPEND:
        Let value be pop_stack with deserializer as deserializer
        Let list_obj be pop_stack with deserializer as deserializer
        If list_obj is not List:
            Throw Errors.DeserializationError with message as "APPEND requires list on stack"
        list_obj.append with item as value
        deserializer.stack.append with item as list_obj
    Otherwise if opcode equals LIST:
        Let items be pop_to_mark with deserializer as deserializer
        Let list_obj be list containing
        For item in items:
            list_obj.append with item as item
        deserializer.stack.append with item as list_obj
    Otherwise if opcode equals APPENDS:
        Let items be pop_to_mark with deserializer as deserializer
        Let list_obj be pop_stack with deserializer as deserializer
        If list_obj is not List:
            Throw Errors.DeserializationError with message as "APPENDS requires list on stack"
        For item in items:
            list_obj.append with item as item
        deserializer.stack.append with item as list_obj
    Otherwise if opcode equals EMPTY_DICT:
        deserializer.stack.append with item as dictionary containing
    Otherwise if opcode equals DICT:
        Let items be pop_to_mark with deserializer as deserializer
        Let dict_obj be dictionary containing
        For i from 0 to items.size step 2:
            Let key be items.get with index as i
            Let value be items.get with index as (i + 1)
            dict_obj.set with key as key and value as value
        deserializer.stack.append with item as dict_obj
    Otherwise if opcode equals SETITEM:
        Let value be pop_stack with deserializer as deserializer
        Let key be pop_stack with deserializer as deserializer
        Let dict_obj be pop_stack with deserializer as deserializer
        If dict_obj is not Dictionary:
            Throw Errors.DeserializationError with message as "SETITEM requires dictionary on stack"
        dict_obj.set with key as key and value as value
        deserializer.stack.append with item as dict_obj
    Otherwise if opcode equals SETITEMS:
        Let items be pop_to_mark with deserializer as deserializer
        Let dict_obj be pop_stack with deserializer as deserializer
        If dict_obj is not Dictionary:
            Throw Errors.DeserializationError with message as "SETITEMS requires dictionary on stack"
        For i from 0 to items.size step 2:
            Let key be items.get with index as i
            Let value be items.get with index as (i + 1)
            dict_obj.set with key as key and value as value
        deserializer.stack.append with item as dict_obj
    Otherwise if opcode equals EMPTY_TUPLE:
        deserializer.stack.append with item as tuple containing
    Otherwise if opcode equals TUPLE:
        Let items be pop_to_mark with deserializer as deserializer
        Let tuple_obj be create_tuple with items as items
        deserializer.stack.append with item as tuple_obj
    Otherwise if opcode equals TUPLE1:
        Let item be pop_stack with deserializer as deserializer
        deserializer.stack.append with item as tuple containing item
    Otherwise if opcode equals TUPLE2:
        Let item2 be pop_stack with deserializer as deserializer
        Let item1 be pop_stack with deserializer as deserializer
        deserializer.stack.append with item as tuple containing item1 and item2
    Otherwise if opcode equals TUPLE3:
        Let item3 be pop_stack with deserializer as deserializer
        Let item2 be pop_stack with deserializer as deserializer
        Let item1 be pop_stack with deserializer as deserializer
        deserializer.stack.append with item as tuple containing item1 and item2 and item3
    Otherwise if opcode equals GLOBAL:
        Let module_name be read_line with deserializer as deserializer.trim
        Let class_name be read_line with deserializer as deserializer.trim
        Let global_obj be resolve_global with module as module_name and name as class_name
        deserializer.stack.append with item as global_obj
    Otherwise if opcode equals REDUCE:
        Let args be pop_stack with deserializer as deserializer
        Let callable_obj be pop_stack with deserializer as deserializer
        Let result be call_with_args with callable as callable_obj and args as args
        deserializer.stack.append with item as result
    Otherwise if opcode equals BUILD:
        Let state be pop_stack with deserializer as deserializer
        Let obj be pop_stack with deserializer as deserializer
        build_object with obj as obj and state as state
        deserializer.stack.append with item as obj
    Otherwise if opcode equals PUT:
        Let memo_index_str be read_line with deserializer as deserializer.trim
        Let memo_index be Integer.parse with string as memo_index_str
        Let obj be deserializer.stack.get with index as (deserializer.stack.size - 1)
        deserializer.memo.set with key as memo_index and value as obj
    Otherwise if opcode equals BINPUT:
        Let memo_index be read_byte with deserializer as deserializer
        Let obj be deserializer.stack.get with index as (deserializer.stack.size - 1)
        deserializer.memo.set with key as memo_index and value as obj
    Otherwise if opcode equals LONG_BINPUT:
        Let memo_index be read_int32 with deserializer as deserializer
        Let obj be deserializer.stack.get with index as (deserializer.stack.size - 1)
        deserializer.memo.set with key as memo_index and value as obj
    Otherwise if opcode equals GET:
        Let memo_index_str be read_line with deserializer as deserializer.trim
        Let memo_index be Integer.parse with string as memo_index_str
        If not deserializer.memo.contains_key with key as memo_index:
            Throw Errors.DeserializationError with message as "Invalid memo index: " Joined with memo_index.to_string
        Let obj be deserializer.memo.get with key as memo_index
        deserializer.stack.append with item as obj
    Otherwise if opcode equals BINGET:
        Let memo_index be read_byte with deserializer as deserializer
        If not deserializer.memo.contains_key with key as memo_index:
            Throw Errors.DeserializationError with message as "Invalid memo index: " Joined with memo_index.to_string
        Let obj be deserializer.memo.get with key as memo_index
        deserializer.stack.append with item as obj
    Otherwise if opcode equals LONG_BINGET:
        Let memo_index be read_int32 with deserializer as deserializer
        If not deserializer.memo.contains_key with key as memo_index:
            Throw Errors.DeserializationError with message as "Invalid memo index: " Joined with memo_index.to_string
        Let obj be deserializer.memo.get with key as memo_index
        deserializer.stack.append with item as obj
    Otherwise:
        Throw Errors.DeserializationError with message as "Unknown opcode: " Joined with opcode.to_string

Note: Low-level serialization utilities
Process called "write_opcode" that takes serializer as PickleSerializer and opcode as PickleOpcode returns Nothing:
    serializer.buffer.append with item as opcode_to_byte with opcode as opcode

Process called "write_byte" that takes serializer as PickleSerializer and value as Integer returns Nothing:
    serializer.buffer.append with item as (value & 0xFF)

Process called "write_short" that takes serializer as PickleSerializer and value as Integer returns Nothing:
    serializer.buffer.append with item as (value & 0xFF)
    serializer.buffer.append with item as ((value >> 8) & 0xFF)

Process called "write_int32" that takes serializer as PickleSerializer and value as Integer returns Nothing:
    serializer.buffer.append with item as (value & 0xFF)
    serializer.buffer.append with item as ((value >> 8) & 0xFF)
    serializer.buffer.append with item as ((value >> 16) & 0xFF)
    serializer.buffer.append with item as ((value >> 24) & 0xFF)

Process called "write_double" that takes serializer as PickleSerializer and value as Float returns Nothing:
    Let bits be value.to_ieee754_double_bits
    For i from 0 to 8:
        serializer.buffer.append with item as ((bits >> (i multiplied by 8)) & 0xFF)

Process called "write_string" that takes serializer as PickleSerializer and value as String returns Nothing:
    Let bytes be value.encode with encoding as "utf-8"
    For byte in bytes:
        serializer.buffer.append with item as byte

Process called "write_bytes" that takes serializer as PickleSerializer and bytes as List[Integer] returns Nothing:
    For byte in bytes:
        serializer.buffer.append with item as byte

Process called "write_global" that takes serializer as PickleSerializer and module as String and name as String returns Nothing:
    write_opcode with serializer as serializer and opcode as GLOBAL
    write_string with serializer as serializer and value as module Joined with "\n"
    write_string with serializer as serializer and value as name Joined with "\n"

Note: Low-level deserialization utilities
Process called "read_byte" that takes deserializer as PickleDeserializer returns Integer:
    If deserializer.position is greater than or equal to deserializer.data.size:
        Throw Errors.DeserializationError with message as "Unexpected end of pickle data"
    Let byte_value be deserializer.data.get with index as deserializer.position
    Set deserializer.position to deserializer.position + 1
    Return byte_value

Process called "read_short" that takes deserializer as PickleDeserializer returns Integer:
    Let byte1 be read_byte with deserializer as deserializer
    Let byte2 be read_byte with deserializer as deserializer
    Return byte1 | (byte2 << 8)

Process called "read_int32" that takes deserializer as PickleDeserializer returns Integer:
    Let result be 0
    For i from 0 to 4:
        Let byte_value be read_byte with deserializer as deserializer
        Set result to result | (byte_value << (i multiplied by 8))
    Return result

Process called "read_double" that takes deserializer as PickleDeserializer returns Float:
    Let bits be 0
    For i from 0 to 8:
        Let byte_value be read_byte with deserializer as deserializer
        Set bits to bits | (byte_value << (i multiplied by 8))
    Return Float.from_ieee754_double_bits with bits as bits

Process called "read_bytes" that takes deserializer as PickleDeserializer and count as Integer returns List[Integer]:
    Let bytes be list containing
    For i from 0 to count:
        bytes.append with item as read_byte with deserializer as deserializer
    Return bytes

Process called "read_line" that takes deserializer as PickleDeserializer returns String:
    Let line be ""
    While deserializer.position is less than deserializer.data.size:
        Let byte_value be read_byte with deserializer as deserializer
        If byte_value equals 10:
            Break
        Set line to line Joined with String.from_byte with byte as byte_value
    Return line

Process called "read_quoted_string" that takes deserializer as PickleDeserializer returns String:
    Let line be read_line with deserializer as deserializer
    Note: Remove quotes and unescape
    If line.starts_with("'") and line.ends_with("'"):
        Return unescape_string with value as line.substring from 1 to (line.length - 1)
    Otherwise:
        Return line

Note: Stack management utilities
Process called "pop_stack" that takes deserializer as PickleDeserializer returns Any:
    If deserializer.stack.is_empty:
        Throw Errors.DeserializationError with message as "Cannot pop from empty stack"
    Let value be deserializer.stack.get with index as (deserializer.stack.size - 1)
    deserializer.stack.remove_last
    Return value

Process called "pop_to_mark" that takes deserializer as PickleDeserializer returns List[Any]:
    Let items be list containing
    While not deserializer.stack.is_empty:
        Let item be pop_stack with deserializer as deserializer
        If item equals MarkObject:
            Break
        items.insert with index as 0 and item as item
    Return items

Type called "MarkObject":
    marker as Boolean

Note: Object construction utilities
Process called "resolve_global" that takes module as String and name as String returns Any:
    Note: Resolve builtin types and functions
    If module equals "builtins":
        If name equals "list":
            Return ListConstructor
        Otherwise if name equals "dict":
            Return DictConstructor
        Otherwise if name equals "tuple":
            Return TupleConstructor
        Otherwise if name equals "set":
            Return SetConstructor
        Otherwise if name equals "frozenset":
            Return FrozenSetConstructor
        Otherwise:
            Return resolve_custom_global with module as module and name as name
    Otherwise:
        Return resolve_custom_global with module as module and name as name

Process called "resolve_custom_global" that takes module as String and name as String returns Any:
    Note: For now, return a placeholder constructor
    Return CustomObjectConstructor with:
        module_name as module
        class_name as name

Type called "CustomObjectConstructor":
    module_name as String
    class_name as String

Process called "call_with_args" that takes callable as Any and args as Any returns Any:
    If callable equals ListConstructor:
        If args is List and args.size equals 1:
            Return create_list_from with iterable as args.get with index as 0
        Otherwise:
            Return list containing
    Otherwise if callable equals DictConstructor:
        Return dictionary containing
    Otherwise if callable equals TupleConstructor:
        If args is List:
            Return create_tuple with items as args
        Otherwise:
            Return tuple containing
    Otherwise if callable equals SetConstructor:
        If args is List and args.size equals 1:
            Return create_set_from with iterable as args.get with index as 0
        Otherwise:
            Return set containing
    Otherwise if callable is CustomObjectConstructor:
        Return create_custom_object with constructor as callable and args as args
    Otherwise:
        Note: Generic callable
        Return callable.call with args as args

Process called "build_object" that takes obj as Any and state as Any returns Nothing:
    If obj.has_method("__setstate__"):
        obj.__setstate__ with state as state
    Otherwise if state is Dictionary:
        For key, value in state:
            obj.set_attribute with name as key and value as value
    Note: Otherwise, ignore the state

Note: Memo management for circular references
Process called "add_to_memo" that takes serializer as PickleSerializer and obj as Any returns Nothing:
    Let obj_id be obj.object_id
    If not serializer.memo.contains_key with key as obj_id:
        Let memo_id be serializer.memo_counter
        serializer.memo.set with key as obj_id and value as memo_id
        Set serializer.memo_counter to serializer.memo_counter + 1
        write_memo_put with serializer as serializer and memo_id as memo_id

Process called "write_memo_put" that takes serializer as PickleSerializer and memo_id as Integer returns Nothing:
    If serializer.protocol equals Protocol0:
        write_opcode with serializer as serializer and opcode as PUT
        write_string with serializer as serializer and value as memo_id.to_string Joined with "\n"
    Otherwise if memo_id is less than or equal to 255:
        write_opcode with serializer as serializer and opcode as BINPUT
        write_byte with serializer as serializer and value as memo_id
    Otherwise:
        write_opcode with serializer as serializer and opcode as LONG_BINPUT
        write_int32 with serializer as serializer and value as memo_id

Process called "write_memo_get" that takes serializer as PickleSerializer and memo_id as Integer returns Nothing:
    Let memo_index be serializer.memo.get with key as memo_id
    If serializer.protocol equals Protocol0:
        write_opcode with serializer as serializer and opcode as GET
        write_string with serializer as serializer and value as memo_index.to_string Joined with "\n"
    Otherwise if memo_index is less than or equal to 255:
        write_opcode with serializer as serializer and opcode as BINGET
        write_byte with serializer as serializer and value as memo_index
    Otherwise:
        write_opcode with serializer as serializer and opcode as LONG_BINGET
        write_int32 with serializer as serializer and value as memo_index

Note: Opcode conversion utilities
Process called "opcode_to_byte" that takes opcode as PickleOpcode returns Integer:
    If opcode equals MARK: Return 40
    Otherwise if opcode equals STOP: Return 46
    Otherwise if opcode equals POP: Return 48
    Otherwise if opcode equals POP_MARK: Return 49
    Otherwise if opcode equals DUP: Return 50
    Otherwise if opcode equals FLOAT: Return 70
    Otherwise if opcode equals INT: Return 73
    Otherwise if opcode equals BININT: Return 74
    Otherwise if opcode equals BININT1: Return 75
    Otherwise if opcode equals LONG: Return 76
    Otherwise if opcode equals BININT2: Return 77
    Otherwise if opcode equals NONE: Return 78
    Otherwise if opcode equals REDUCE: Return 82
    Otherwise if opcode equals STRING: Return 83
    Otherwise if opcode equals BINSTRING: Return 84
    Otherwise if opcode equals SHORT_BINSTRING: Return 85
    Otherwise if opcode equals APPEND: Return 97
    Otherwise if opcode equals BUILD: Return 98
    Otherwise if opcode equals GLOBAL: Return 99
    Otherwise if opcode equals DICT: Return 100
    Otherwise if opcode equals EMPTY_DICT: Return 125
    Otherwise if opcode equals APPENDS: Return 101
    Otherwise if opcode equals GET: Return 103
    Otherwise if opcode equals BINGET: Return 104
    Otherwise if opcode equals LONG_BINGET: Return 106
    Otherwise if opcode equals LIST: Return 108
    Otherwise if opcode equals EMPTY_LIST: Return 93
    Otherwise if opcode equals PUT: Return 112
    Otherwise if opcode equals BINPUT: Return 113
    Otherwise if opcode equals LONG_BINPUT: Return 114
    Otherwise if opcode equals SETITEM: Return 115
    Otherwise if opcode equals TUPLE: Return 116
    Otherwise if opcode equals EMPTY_TUPLE: Return 41
    Otherwise if opcode equals SETITEMS: Return 117
    Otherwise if opcode equals BINFLOAT: Return 71
    Otherwise if opcode equals TRUE: Return 73
    Otherwise if opcode equals FALSE: Return 70
    Otherwise: Return 0

Process called "byte_to_opcode" that takes byte as Integer returns PickleOpcode:
    If byte equals 40: Return MARK
    Otherwise if byte equals 46: Return STOP
    Otherwise if byte equals 48: Return POP
    Otherwise if byte equals 49: Return POP_MARK
    Otherwise if byte equals 50: Return DUP
    Otherwise if byte equals 70: Return FLOAT
    Otherwise if byte equals 73: Return INT
    Otherwise if byte equals 74: Return BININT
    Otherwise if byte equals 75: Return BININT1
    Otherwise if byte equals 76: Return LONG
    Otherwise if byte equals 77: Return BININT2
    Otherwise if byte equals 78: Return NONE
    Otherwise if byte equals 82: Return REDUCE
    Otherwise if byte equals 83: Return STRING
    Otherwise if byte equals 84: Return BINSTRING
    Otherwise if byte equals 85: Return SHORT_BINSTRING
    Otherwise if byte equals 97: Return APPEND
    Otherwise if byte equals 98: Return BUILD
    Otherwise if byte equals 99: Return GLOBAL
    Otherwise if byte equals 100: Return DICT
    Otherwise if byte equals 125: Return EMPTY_DICT
    Otherwise if byte equals 101: Return APPENDS
    Otherwise if byte equals 103: Return GET
    Otherwise if byte equals 104: Return BINGET
    Otherwise if byte equals 106: Return LONG_BINGET
    Otherwise if byte equals 108: Return LIST
    Otherwise if byte equals 93: Return EMPTY_LIST
    Otherwise if byte equals 112: Return PUT
    Otherwise if byte equals 113: Return BINPUT
    Otherwise if byte equals 114: Return LONG_BINPUT
    Otherwise if byte equals 115: Return SETITEM
    Otherwise if byte equals 116: Return TUPLE
    Otherwise if byte equals 41: Return EMPTY_TUPLE
    Otherwise if byte equals 117: Return SETITEMS
    Otherwise if byte equals 71: Return BINFLOAT
    Otherwise if byte equals 73: Return TRUE
    Otherwise if byte equals 70: Return FALSE
    Otherwise: Throw Errors.DeserializationError with message as "Unknown opcode byte: " Joined with byte.to_string

Note: String escaping utilities
Process called "escape_string" that takes value as String returns String:
    Let result be value
    Set result to result.replace with old as "\\" and new as "\\\\"
    Set result to result.replace with old as "'" and new as "\\'"
    Set result to result.replace with old as "\n" and new as "\\n"
    Set result to result.replace with old as "\t" and new as "\\t"
    Set result to result.replace with old as "\r" and new as "\\r"
    Return result

Process called "unescape_string" that takes value as String returns String:
    Let result be value
    Set result to result.replace with old as "\\n" and new as "\n"
    Set result to result.replace with old as "\\t" and new as "\t"
    Set result to result.replace with old as "\\r" and new as "\r"
    Set result to result.replace with old as "\\'" and new as "'"
    Set result to result.replace with old as "\\\\" and new as "\\"
    Return result

Note: Configuration and registry management
Process called "create_default_pickle_config" returns PickleConfig:
    Return PickleConfig with:
        protocol as Protocol4
        fix_imports as true
        buffer_callback as none
        custom_handlers as dictionary containing
        max_recursion_depth as 1000
        preserve_sharing as true

Process called "register_default_serializers" that takes serializer as PickleSerializer returns Nothing:
    Note: Default serializers are built into the main serialization logic
    Note: This is a placeholder for future custom type registration

Process called "register_default_deserializers" that takes deserializer as PickleDeserializer returns Nothing:
    Note: Default deserializers are built into the main deserialization logic
    Note: This is a placeholder for future custom type registration

Process called "register_custom_serializers" that takes serializer as PickleSerializer and config as PickleConfig returns Nothing:
    For type_name, handler in config.custom_handlers:
        serializer.custom_serializers.set with key as type_name and value as handler.serialize_handler

Process called "register_custom_deserializers" that takes deserializer as PickleDeserializer and config as PickleConfig returns Nothing:
    For type_name, handler in config.custom_handlers:
        deserializer.custom_deserializers.set with key as type_name and value as handler.deserialize_handler

Note: Validation and introspection utilities
Process called "validate_pickle_data" that takes data as List[Integer] returns PickleValidationResult:
    Let result be PickleValidationResult with:
        valid as true
        errors as list containing
        warnings as list containing
        protocol_version as Protocol0
        object_count as 0
        memo_entries as 0
        data_size as data.size
    Try:
        Let validation_deserializer be PickleDeserializer with:
            data as data
            position as 0
            stack as list containing
            memo as dictionary containing
            custom_deserializers as dictionary containing
            protocol as Protocol0
        validate_pickle_structure with deserializer as validation_deserializer and result as result
    Catch error:
        result.valid = false
        result.errors.append with item as "Validation failed: " Joined with error.message
    Return result

Type called "PickleValidationResult":
    valid as Boolean
    errors as List[String]
    warnings as List[String]
    protocol_version as PickleProtocol
    object_count as Integer
    memo_entries as Integer
    data_size as Integer

Process called "validate_pickle_structure" that takes deserializer as PickleDeserializer and result as PickleValidationResult returns Nothing:
    While deserializer.position is less than deserializer.data.size:
        Let opcode_byte be read_byte with deserializer as deserializer
        Let opcode be byte_to_opcode with byte as opcode_byte
        If opcode equals STOP:
            Break
        validate_opcode_context with deserializer as deserializer and opcode as opcode and result as result

Process called "validate_opcode_context" that takes deserializer as PickleDeserializer and opcode as PickleOpcode and result as PickleValidationResult returns Nothing:
    Note: Basic opcode validation
    If opcode equals POP and deserializer.stack.is_empty:
        result.errors.append with item as "POP on empty stack at position " Joined with deserializer.position.to_string
    Otherwise if (opcode equals BINPUT or opcode equals BINGET) and deserializer.position is greater than or equal to deserializer.data.size:
        result.errors.append with item as "Insufficient data for " Joined with opcode.to_string Joined with " at position " Joined with deserializer.position.to_string
    Note: Update statistics
    If opcode equals BINPUT or opcode equals PUT or opcode equals LONG_BINPUT:
        result.memo_entries = result.memo_entries + 1
    result.object_count = result.object_count + 1

Note: Performance benchmarking
Process called "benchmark_pickle" that takes test_data as Any and protocol as PickleProtocol and iterations as Integer returns PickleBenchmark:
    Let serialize_times be list containing
    Let deserialize_times be list containing
    Let serialized_size be 0
    For i from 0 to iterations:
        Let start_time be DateTime.now
        Let pickled_data be pickle_dumps with obj as test_data and protocol as protocol
        Let end_time be DateTime.now
        serialize_times.append with item as (end_time - start_time).total_milliseconds
        If i equals 0:
            Set serialized_size to pickled_data.size
        Set start_time to DateTime.now
        pickle_loads with data as pickled_data
        Set end_time to DateTime.now
        deserialize_times.append with item as (end_time - start_time).total_milliseconds
    Return PickleBenchmark with:
        serialize_avg_time as (serialize_times.sum divided by iterations)
        deserialize_avg_time as (deserialize_times.sum divided by iterations)
        serialized_size as serialized_size
        protocol_version as protocol
        iterations as iterations

Type called "PickleBenchmark":
    serialize_avg_time as Float
    deserialize_avg_time as Float
    serialized_size as Integer
    protocol_version as PickleProtocol
    iterations as Integer

Note: Compatibility utilities
Process called "pickle_protocol_supports_feature" that takes protocol as PickleProtocol and feature as String returns Boolean:
    If feature equals "binary_opcodes":
        Return protocol is not Protocol0
    Otherwise if feature equals "short_binstring":
        Return protocol is not Protocol0
    Otherwise if feature equals "memo_sharing":
        Return true
    Otherwise if feature equals "tuple_optimization":
        Return protocol is not Protocol0 and protocol is not Protocol1
    Otherwise if feature equals "binary_float":
        Return protocol is not Protocol0
    Otherwise:
        Return false

Process called "get_pickle_info" that takes data as List[Integer] returns PickleInfo:
    Let info be PickleInfo with:
        data_size as data.size
        estimated_protocol as Protocol0
        opcode_count as 0
        unique_opcodes as set containing
        has_memo as false
        circular_references as false
    Try:
        analyze_pickle_data with data as data and info as info
    Catch:
        Note: Analysis failed, return basic info
        Return info
    Return info

Type called "PickleInfo":
    data_size as Integer
    estimated_protocol as PickleProtocol
    opcode_count as Integer
    unique_opcodes as Set[PickleOpcode]
    has_memo as Boolean
    circular_references as Boolean

Process called "analyze_pickle_data" that takes data as List[Integer] and info as PickleInfo returns Nothing:
    Let position be 0
    While position is less than data.size:
        Let opcode_byte be data.get with index as position
        Set position to position + 1
        Let opcode be byte_to_opcode with byte as opcode_byte
        Set info.opcode_count to info.opcode_count + 1
        info.unique_opcodes.add with item as opcode
        If opcode equals STOP:
            Break
        If opcode equals BINPUT or opcode equals PUT or opcode equals LONG_BINPUT or opcode equals BINGET or opcode equals GET or opcode equals LONG_BINGET:
            Set info.has_memo to true
            Set info.circular_references to true
        If opcode equals BINFLOAT or opcode equals BINSTRING or opcode equals BININT:
            If info.estimated_protocol equals Protocol0:
                Set info.estimated_protocol to Protocol1
        Note: Skip opcode arguments
        If opcode equals BININT1 or opcode equals BINPUT or opcode equals BINGET or opcode equals SHORT_BINSTRING:
            Set position to position + 1
        Otherwise if opcode equals BININT2:
            Set position to position + 2
        Otherwise if opcode equals BININT or opcode equals LONG_BINPUT or opcode equals LONG_BINGET:
            Set position to position + 4
        Otherwise if opcode equals BINFLOAT:
            Set position to position + 8

Note: Utility constructors and helpers
Let ListConstructor be "list"
Let DictConstructor be "dict"
Let TupleConstructor be "tuple"
Let SetConstructor be "set"
Let FrozenSetConstructor be "frozenset"
Let MarkObject be MarkObject with marker as true

Process called "create_list_from" that takes iterable as Any returns List:
    If iterable is List:
        Return iterable
    Otherwise if iterable is String:
        Let result be list containing
        For char in iterable:
            result.append with item as char
        Return result
    Otherwise:
        Return list containing

Process called "create_set_from" that takes iterable as Any returns Set:
    If iterable is List:
        Let result be set containing
        For item in iterable:
            result.add with item as item
        Return result
    Otherwise:
        Return set containing

Process called "create_tuple" that takes items as List returns Tuple:
    Return tuple from items

Process called "create_custom_object" that takes constructor as CustomObjectConstructor and args as Any returns Any:
    Return CustomObject with:
        type_name as constructor.module_name Joined with "." Joined with constructor.class_name
        constructor_args as args
        attributes as dictionary containing

Type called "CustomObject":
    type_name as String
    constructor_args as Any
    attributes as Dictionary[String, Any]