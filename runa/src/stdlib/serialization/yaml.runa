Note: Core parsing operations
Process called "parse_yaml" that takes input as String returns YAMLDocument:
    Let parser be create_yaml_parser()
    Let input_stream be Stream.create_string_stream with content as input
    Set parser.input_stream to input_stream Return parse_yaml_document with parser as parser

Process called "parse_all_yaml" that takes input as String returns List[YAMLDocument]:
    Let parser be create_yaml_parser()
    Set parser.parsing_options.load_all_documents to true
    Let input_stream be Stream.create_string_stream with content as input
    Set parser.input_stream to input_stream Let documents be list containing
    While true:
    Let document be parse_yaml_document with parser as parser
    If document is None:
    Break
    Add document to documents Return documents

Process called "create_yaml_parser" returns YAMLParser:
    Return YAMLParser with:
    parser_id as generate_parser_id()
    input_stream as Stream.create_empty_stream()
    current_position as create_initial_parser_position()
    parsing_options as create_default_parsing_options()
    scanner as create_yaml_scanner()
    composer as create_yaml_composer()
    resolver as create_yaml_resolver()
    loader as create_yaml_loader()

Process called "parse_yaml_document" that takes parser as YAMLParser returns Optional[YAMLDocument]:
    Let scanner be parser.scanner
    Let composer be parser.composer
    Let resolver be parser.resolver
    Let loader be parser.loader Let tokens be scan_tokens with scanner as scanner and input_stream as parser.input_stream
    If Collections.List.is_empty with lst as tokens:
    Return None Let events be compose_events with composer as composer and tokens as tokens
    Let nodes be resolve_nodes with resolver as resolver and events as events
    Let document_data be load_document_data with loader as loader and nodes as nodes Return create_yaml_document with data as document_data

Process called "scan_tokens" that takes scanner as YAMLScanner and input_stream as Stream.ReadableStream returns List[YAMLToken]:
    Let tokens be list containing
    initialize_scanner with scanner as scanner and input_stream as input_stream While true:
    Let token be scan_next_token with scanner as scanner
    If token is None:
    Break
    Add token to tokens
    If token.token_type is StreamEnd:
    Break Return tokens

Process called "initialize_scanner" that takes scanner as YAMLScanner and input_stream as Stream.ReadableStream:
    Set scanner.flow_level to 0
    Set scanner.tokens_taken to 0
    Set scanner.allow_simple_key to true
    Set scanner.possible_simple_key to false
    Add StreamStart token to scanner.token_queue

Process called "scan_next_token" that takes scanner as YAMLScanner returns Optional[YAMLToken]:
    If not Collections.List.is_empty with lst as scanner.token_queue:
    Return Collections.List.pop_first with lst as scanner.token_queue Let next_token be scan_token_from_input with scanner as scanner
    If next_token is not None:
    Add next_token to scanner.token_queue Return next_token

Process called "scan_token_from_input" that takes scanner as YAMLScanner returns Optional[YAMLToken]:
    skip_whitespace_and_comments with scanner as scanner Let char be peek_next_character_from_scanner with scanner as scanner
    If char is equal to "":
    Return create_token with type as StreamEnd and value as "" and location as get_current_scanner_location with scanner as scanner Let location be get_current_scanner_location with scanner as scanner Match char:
    When "%":
    Return scan_directive with scanner as scanner
    When "-":
    If check_document_start with scanner as scanner:
    Return create_token with type as DocumentStart and value as "---" and location as location
    Else if scanner.flow_level is equal to 0:
    Return scan_block_entry with scanner as scanner
    Otherwise:
    Return scan_plain_scalar with scanner as scanner
    When ".":
    If check_document_end with scanner as scanner:
    Return create_token with type as DocumentEnd and value as "..." and location as location
    Otherwise:
    Return scan_plain_scalar with scanner as scanner
    When "[":
    Return scan_flow_sequence_start with scanner as scanner
    When "{":
    Return scan_flow_mapping_start with scanner as scanner
    When "]":
    Return scan_flow_sequence_end with scanner as scanner
    When "}":
    Return scan_flow_mapping_end with scanner as scanner
    When ",":
    Return scan_flow_entry with scanner as scanner
    When "?":
    If scanner.flow_level is equal to 0:
    Return scan_key with scanner as scanner
    Otherwise:
    Return scan_plain_scalar with scanner as scanner
    When ":":
    If scanner.flow_level is equal to 0:
    Return scan_value with scanner as scanner
    Otherwise:
    Return scan_plain_scalar with scanner as scanner
    When "*":
    Return scan_alias with scanner as scanner
    When "&":
    Return scan_anchor with scanner as scanner
    When "!":
    Return scan_tag with scanner as scanner
    When "|":
    Return scan_literal_scalar with scanner as scanner
    When ">":
    Return scan_folded_scalar with scanner as scanner
    When "'":
    Return scan_single_quoted_scalar with scanner as scanner
    When "\"":
    Return scan_double_quoted_scalar with scanner as scanner
    Otherwise:
    If is_plain_safe with char as char:
    Return scan_plain_scalar with scanner as scanner
    Otherwise:
    Return None

Process called "compose_events" that takes composer as YAMLComposer and tokens as List[YAMLToken] returns List[YAMLEvent]:
    Let events be list containing For each token in tokens:
    Let event be compose_event_from_token with composer as composer and token as token
    If event is not None:
    Add event to events Return events

Process called "compose_event_from_token" that takes composer as YAMLComposer and token as YAMLToken returns Optional[YAMLEvent]:
    Match token.token_type:
    When StreamStart:
    Return YAMLEvent with event_type as StreamStartEvent and location as token.location
    When StreamEnd:
    Return YAMLEvent with event_type as StreamEndEvent and location as token.location
    When DocumentStart:
    Set composer.compose_document_start to true
    Return YAMLEvent with event_type as DocumentStartEvent and location as token.location
    When DocumentEnd:
    Return YAMLEvent with event_type as DocumentEndEvent and location as token.location
    When Scalar:
    Return YAMLEvent with event_type as ScalarEvent and value as token.value and location as token.location
    When Alias:
    Return YAMLEvent with event_type as AliasEvent and anchor as token.value and location as token.location
    When BlockSequenceStart:
    Return YAMLEvent with event_type as SequenceStartEvent and location as token.location
    When FlowSequenceStart:
    Return YAMLEvent with event_type as SequenceStartEvent and location as token.location
    When BlockMappingStart:
    Return YAMLEvent with event_type as MappingStartEvent and location as token.location
    When FlowMappingStart:
    Return YAMLEvent with event_type as MappingStartEvent and location as token.location
    When BlockEnd:
    Return determine_block_end_event with token as token
    When FlowSequenceEnd:
    Return YAMLEvent with event_type as SequenceEndEvent and location as token.location
    When FlowMappingEnd:
    Return YAMLEvent with event_type as MappingEndEvent and location as token.location
    Otherwise:
    Return None

Process called "resolve_nodes" that takes resolver as YAMLResolver and events as List[YAMLEvent] returns List[YAMLValue]:
    Let nodes be list containing For each event in events:
    Let resolved_node be resolve_node_from_event with resolver as resolver and event as event
    If resolved_node is not None:
    Add resolved_node to nodes Return nodes

Process called "resolve_node_from_event" that takes resolver as YAMLResolver and event as YAMLEvent returns Optional[YAMLValue]:
    Match event.event_type:
    When ScalarEvent:
    Let resolved_tag be resolve_scalar_tag with resolver as resolver and value as event.value and implicit as event.implicit
    Return create_yaml_value with type as determine_yaml_type_from_tag with tag as resolved_tag and data as construct_scalar_value with value as event.value and tag as resolved_tag
    When SequenceStartEvent:
    Return create_yaml_value with type as YAMLSequence and data as list containing
    When MappingStartEvent:
    Return create_yaml_value with type as YAMLMapping and data as dictionary containing
    When AliasEvent:
    Return create_yaml_value with type as YAMLAlias and data as event.anchor
    Otherwise:
    Return None

Process called "load_document_data" that takes loader as YAMLLoader and nodes as List[YAMLValue] returns YAMLValue:
    If Collections.List.is_empty with lst as nodes:
    Return create_yaml_value with type as YAMLNull and data as null Let root_node be nodes at index 0
    Return construct_document with loader as loader and node as root_node

Process called "construct_document" that takes loader as YAMLLoader and node as YAMLValue returns YAMLValue:
    If node.tag is not None:
    Let constructor be find_constructor with loader as loader and tag as node.tag
    If constructor is not None:
    Return constructor.construction_function with node as node Return construct_default_value with loader as loader and node as node

Note: YAML generation operations
Process called "dump_yaml" that takes data as Any returns String:
    Let generator be create_yaml_generator()
    Let output_stream be Stream.create_string_stream()
    Set generator.output_stream to output_stream generate_yaml_document with generator as generator and data as data
    Return Stream.get_content with stream as output_stream

Process called "dump_all_yaml" that takes documents as List[Any] returns String:
    Let generator be create_yaml_generator()
    Let output_stream be Stream.create_string_stream()
    Set generator.output_stream to output_stream
    Set generator.generation_options.explicit_start to true For each document in documents:
    generate_yaml_document with generator as generator and data as document Return Stream.get_content with stream as output_stream

Process called "create_yaml_generator" returns YAMLGenerator:
    Return YAMLGenerator with:
    generator_id as generate_generator_id()
    output_stream as Stream.create_empty_stream()
    generation_options as create_default_generation_options()
    emitter as create_yaml_emitter()
    serializer as create_yaml_serializer()
    representer as create_yaml_representer()

Process called "generate_yaml_document" that takes generator as YAMLGenerator and data as Any:
    Let representer be generator.representer
    Let serializer be generator.serializer
    Let emitter be generator.emitter Let yaml_value be represent_data with representer as representer and data as data
    Let events be serialize_value with serializer as serializer and value as yaml_value
    emit_events with emitter as emitter and events as events

Process called "represent_data" that takes representer as YAMLRepresenter and data as Any returns YAMLValue:
    Let data_type be get_data_type_name with data as data If Collections.Dict.contains_key with dict as representer.representers and key as data_type:
    Let representer_func be representer.representers[data_type]
    Return representer_func.representation_function with data as data Return represent_with_default_representer with representer as representer and data as data

Process called "serialize_value" that takes serializer as YAMLSerializer and value as YAMLValue returns List[YAMLEvent]:
    Let events be list containing If not serializer.closed:
    Add create_event with type as StreamStartEvent to events
    Add create_event with type as DocumentStartEvent to events serialize_value_recursive with serializer as serializer and value as value and events as events Add create_event with type as DocumentEndEvent to events
    Add create_event with type as StreamEndEvent to events Return events

Process called "serialize_value_recursive" that takes serializer as YAMLSerializer and value as YAMLValue and events as List[YAMLEvent]:
    If value.anchor is not None:
    If Collections.Dict.contains_key with dict as serializer.serialized_nodes and key as value.anchor:
    Add create_alias_event with anchor as value.anchor to events
    Return
    Set serializer.serialized_nodes[value.anchor] to true Match value.value_type:
    When YAMLNull:
    Add create_scalar_event with value as "null" and tag as "tag:yaml.org,2002:null" to events
    When YAMLBool:
    Let bool_str be if value.data then "true" else "false"
    Add create_scalar_event with value as bool_str and tag as "tag:yaml.org,2002:bool" to events
    When YAMLInt:
    Add create_scalar_event with value as from_integer with value as value.data and tag as "tag:yaml.org,2002:int" to events
    When YAMLFloat:
    Add create_scalar_event with value as from_float with value as value.data and tag as "tag:yaml.org,2002:float" to events
    When YAMLString:
    Add create_scalar_event with value as value.data and tag as "tag:yaml.org,2002:str" to events
    When YAMLSequence:
    Add create_sequence_start_event with anchor as value.anchor and tag as value.tag to events
    For each item in value.data:
    serialize_value_recursive with serializer as serializer and value as item and events as events
    Add create_sequence_end_event() to events
    When YAMLMapping:
    Add create_mapping_start_event with anchor as value.anchor and tag as value.tag to events
    For each key in Collections.Dict.keys with dict as value.data:
    Let key_value be create_yaml_value with type as YAMLString and data as key
    serialize_value_recursive with serializer as serializer and value as key_value and events as events
    serialize_value_recursive with serializer as serializer and value as value.data[key] and events as events
    Add create_mapping_end_event() to events

Process called "emit_events" that takes emitter as YAMLEmitter and events as List[YAMLEvent]:
    For each event in events:
    emit_event with emitter as emitter and event as event

Process called "emit_event" that takes emitter as YAMLEmitter and event as YAMLEvent:
    Match event.event_type:
    When StreamStartEvent:
    emit_stream_start with emitter as emitter
    When StreamEndEvent:
    emit_stream_end with emitter as emitter
    When DocumentStartEvent:
    emit_document_start with emitter as emitter and event as event
    When DocumentEndEvent:
    emit_document_end with emitter as emitter and event as event
    When AliasEvent:
    emit_alias with emitter as emitter and event as event
    When ScalarEvent:
    emit_scalar with emitter as emitter and event as event
    When SequenceStartEvent:
    emit_sequence_start with emitter as emitter and event as event
    When SequenceEndEvent:
    emit_sequence_end with emitter as emitter
    When MappingStartEvent:
    emit_mapping_start with emitter as emitter and event as event
    When MappingEndEvent:
    emit_mapping_end with emitter as emitter

Note: Anchor and alias resolution
Process called "resolve_aliases" that takes document as YAMLDocument returns YAMLDocument:
    Let alias_resolver be create_alias_resolver()
    Let resolved_root be resolve_aliases_in_value with resolver as alias_resolver and value as document.root_value Return YAMLDocument with:
    document_id as document.document_id
    root_value as resolved_root
    version_directive as document.version_directive
    tag_directives as document.tag_directives
    document_markers as document.document_markers
    implicit_start as document.implicit_start
    implicit_end as document.implicit_end

Type called "AliasResolver":
    resolver_id as String
    anchors as Dictionary[String, YAMLValue]
    resolving as List[String]
    resolved as Dictionary[String, YAMLValue]

Process called "create_alias_resolver" returns AliasResolver:
    Return AliasResolver with:
    resolver_id as generate_resolver_id()
    anchors as dictionary containing
    resolving as list containing
    resolved as dictionary containing

Process called "resolve_aliases_in_value" that takes resolver as AliasResolver and value as YAMLValue returns YAMLValue:
    If value.anchor is not None:
    Set resolver.anchors[value.anchor] to value Match value.value_type:
    When YAMLAlias:
    Let alias_name be value.data as String
    If Collections.List.contains with lst as resolver.resolving and item as alias_name:
    Return create_yaml_error_value with message as "Circular reference detected" Add alias_name to resolver.resolving If Collections.Dict.contains_key with dict as resolver.anchors and key as alias_name:
    Let resolved_value be resolve_aliases_in_value with resolver as resolver and value as resolver.anchors[alias_name]
    Set resolver.resolved[alias_name] to resolved_value
    Remove alias_name from resolver.resolving
    Return resolved_value
    Otherwise:
    Remove alias_name from resolver.resolving
    Return create_yaml_error_value with message as String.concat with parts as list containing "Unknown alias: ", alias_name
    When YAMLSequence:
    Let resolved_sequence be list containing
    For each item in value.data:
    Let resolved_item be resolve_aliases_in_value with resolver as resolver and value as item
    Add resolved_item to resolved_sequence
    Return create_yaml_value with type as YAMLSequence and data as resolved_sequence
    When YAMLMapping:
    Let resolved_mapping be dictionary containing
    For each key in Collections.Dict.keys with dict as value.data:
    Let resolved_key be resolve_aliases_in_value with resolver as resolver and value as create_yaml_value with type as YAMLString and data as key
    Let resolved_value be resolve_aliases_in_value with resolver as resolver and value as value.data[key]
    Set resolved_mapping[key] to resolved_value
    Return create_yaml_value with type as YAMLMapping and data as resolved_mapping
    Otherwise:
    Return value

Note: Schema validation operations
Process called "validate_yaml_with_schema" that takes document as YAMLDocument and schema as YAMLSchema returns ValidationResult:
    Let validator be create_schema_validator with schema as schema
    Return validate_yaml_value with validator as validator and value as document.root_value

Type called "YAMLSchemaValidator":
    validator_id as String
    schema as YAMLSchema
    validation_errors as List[ValidationError]
    validation_warnings as List[ValidationError]

Process called "create_schema_validator" that takes schema as YAMLSchema returns YAMLSchemaValidator:
    Return YAMLSchemaValidator with:
    validator_id as generate_validator_id()
    schema as schema
    validation_errors as list containing
    validation_warnings as list containing

Process called "validate_yaml_value" that takes validator as YAMLSchemaValidator and value as YAMLValue returns ValidationResult:
    validate_value_recursive with validator as validator and value as value Return ValidationResult with:
    is_valid as Collections.List.is_empty with lst as validator.validation_errors
    errors as validator.validation_errors
    warnings as validator.validation_warnings

Process called "validate_value_recursive" that takes validator as YAMLSchemaValidator and value as YAMLValue:
    Match value.value_type:
    When YAMLMapping:
    validate_mapping_value with validator as validator and mapping as value.data
    When YAMLSequence:
    validate_sequence_value with validator as validator and sequence as value.data
    When YAMLString:
    validate_string_value with validator as validator and string_value as value.data
    Otherwise:
    validate_scalar_value with validator as validator and scalar_value as value

Process called "validate_mapping_value" that takes validator as YAMLSchemaValidator and mapping as Dictionary[String, YAMLValue]:
    For each key in Collections.Dict.keys with dict as mapping:
    validate_value_recursive with validator as validator and value as mapping[key]

Process called "validate_sequence_value" that takes validator as YAMLSchemaValidator and sequence as List[YAMLValue]:
    For each item in sequence:
    validate_value_recursive with validator as validator and value as item

Process called "validate_string_value" that takes validator as YAMLSchemaValidator and string_value as String:
    Note: String-specific validation would go here

Process called "validate_scalar_value" that takes validator as YAMLSchemaValidator and scalar_value as YAMLValue:
    Note: Scalar-specific validation would go here

Note: High-level convenience operations
Process called "load_yaml" that takes yaml_string as String returns Any:
    Let document be parse_yaml with input as yaml_string
    Return convert_yaml_value_to_runa_value with yaml_value as document.root_value

Process called "load_all_yaml" that takes yaml_string as String returns List[Any]:
    Let documents be parse_all_yaml with input as yaml_string
    Let runa_values be list containing For each document in documents:
    Let runa_value be convert_yaml_value_to_runa_value with yaml_value as document.root_value
    Add runa_value to runa_values Return runa_values

Process called "safe_load_yaml" that takes yaml_string as String returns Any:
    Let parser be create_yaml_parser()
    Set parser.parsing_options.validate_schema to true
    Let input_stream be Stream.create_string_stream with content as yaml_string
    Set parser.input_stream to input_stream Let document be parse_yaml_document with parser as parser
    Return convert_yaml_value_to_runa_value with yaml_value as document.root_value

Note: Utility and helper functions
Process called "create_yaml_value" that takes type as YAMLType and data as Any returns YAMLValue:
    Return YAMLValue with:
    value_type as type
    data as data
    tag as None
    anchor as None
    source_location as None
    style_hint as PlainStyle

Process called "create_yaml_error_value" that takes message as String returns YAMLValue:
    Return create_yaml_value with type as YAMLString and data as String.concat with parts as list containing "ERROR: ", message

Process called "create_yaml_document" that takes data as YAMLValue returns YAMLDocument:
    Return YAMLDocument with:
    document_id as generate_document_id()
    root_value as data
    version_directive as None
    tag_directives as list containing
    document_markers as DocumentMarkers with has_start_marker as false and has_end_marker as false
    implicit_start as true
    implicit_end as true

Process called "convert_yaml_value_to_runa_value" that takes yaml_value as YAMLValue returns Any:
    Match yaml_value.value_type:
    When YAMLNull:
    Return null
    When YAMLBool:
    Return yaml_value.data
    When YAMLInt:
    Return yaml_value.data
    When YAMLFloat:
    Return yaml_value.data
    When YAMLString:
    Return yaml_value.data
    When YAMLSequence:
    Let runa_list be list containing
    For each item in yaml_value.data:
    Let runa_item be convert_yaml_value_to_runa_value with yaml_value as item
    Add runa_item to runa_list
    Return runa_list
    When YAMLMapping:
    Let runa_dict be dictionary containing
    For each key in Collections.Dict.keys with dict as yaml_value.data:
    Let runa_value be convert_yaml_value_to_runa_value with yaml_value as yaml_value.data[key]
    Set runa_dict[key] to runa_value
    Return runa_dict
    Otherwise:
    Return yaml_value.data

Process called "convert_runa_value_to_yaml_value" that takes runa_value as Any returns YAMLValue:
    If runa_value is null:
    Return create_yaml_value with type as YAMLNull and data as null
    Else if runa_value is Boolean:
    Return create_yaml_value with type as YAMLBool and data as runa_value
    Else if runa_value is Integer:
    Return create_yaml_value with type as YAMLInt and data as runa_value
    Else if runa_value is Float:
    Return create_yaml_value with type as YAMLFloat and data as runa_value
    Else if runa_value is String:
    Return create_yaml_value with type as YAMLString and data as runa_value
    Else if runa_value is List:
    Let yaml_sequence be list containing
    For each item in runa_value:
    Let yaml_item be convert_runa_value_to_yaml_value with runa_value as item
    Add yaml_item to yaml_sequence
    Return create_yaml_value with type as YAMLSequence and data as yaml_sequence
    Else if runa_value is Dictionary:
    Let yaml_mapping be dictionary containing
    For each key in Collections.Dict.keys with dict as runa_value:
    Let key_string be String.from_any with value as key
    Let yaml_value be convert_runa_value_to_yaml_value with runa_value as runa_value[key]
    Set yaml_mapping[key_string] to yaml_value
    Return create_yaml_value with type as YAMLMapping and data as yaml_mapping
    Otherwise:
    Return create_yaml_value with type as YAMLString and data as String.from_any with value as runa_value

Process called "generate_parser_id" returns String:
