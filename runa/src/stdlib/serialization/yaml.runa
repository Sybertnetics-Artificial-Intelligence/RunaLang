    default_style as PlainStyle
    default_flow_style as false
    canonical as false
    indent as 2
    width as 80
    allow_unicode as true
    line_break as UnixLineBreak
    encoding as "utf-8"
    explicit_start as false
    explicit_end as false
    version as None
    tags as None
    sort_keys as false

