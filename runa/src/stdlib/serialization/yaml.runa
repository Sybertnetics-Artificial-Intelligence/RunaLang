    indent_stack as list containing -1
    simple_key_stack as list containing
    flow_level as 0
    tokens_taken as 0
    allow_simple_key as true
    possible_simple_key as false

Process called "generate_scanner_id" returns String:
    Let timestamp be DateTime.now_milliseconds()
    Return String.concat with parts as list containing "YAML-SCANNER-", timestamp

Process called "create_token" that takes type as TokenType and value as Any and location as SourceLocation returns YAMLToken:
    Return YAMLToken with:
    token_type as type
    value as value
    location as location
    plain_implicit as true
    quoted_implicit as false

