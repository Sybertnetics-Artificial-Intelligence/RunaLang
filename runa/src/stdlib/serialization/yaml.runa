Note: Emitter operations (simplified implementations)
Process called "emit_stream_start" that takes emitter as YAMLEmitter:
    Stream.write_string with stream as emitter.output_stream and content as ""

Process called "emit_stream_end" that takes emitter as YAMLEmitter:
    Stream.write_string with stream as emitter.output_stream and content as ""

Process called "emit_document_start" that takes emitter as YAMLEmitter and event as YAMLEvent:
    If emitter.canonical or not event.implicit:
    Stream.write_string with stream as emitter.output_stream and content as "---\n"

Process called "emit_document_end" that takes emitter as YAMLEmitter and event as YAMLEvent:
    If not event.implicit:
    Stream.write_string with stream as emitter.output_stream and content as "...\n"

Process called "emit_alias" that takes emitter as YAMLEmitter and event as YAMLEvent:
    Stream.write_string with stream as emitter.output_stream and content as String.concat with parts as list containing "*", event.anchor

Process called "emit_scalar" that takes emitter as YAMLEmitter and event as YAMLEvent:
    If event.value is not None:
    Stream.write_string with stream as emitter.output_stream and content as event.value

Process called "emit_sequence_start" that takes emitter as YAMLEmitter and event as YAMLEvent:
    Stream.write_string with stream as emitter.output_stream and content as "["

Process called "emit_sequence_end" that takes emitter as YAMLEmitter:
    Stream.write_string with stream as emitter.output_stream and content as "]"

Process called "emit_mapping_start" that takes emitter as YAMLEmitter and event as YAMLEvent:
    Stream.write_string with stream as emitter.output_stream and content as "{"

Process called "emit_mapping_end" that takes emitter as YAMLEmitter:
    Stream.write_string with stream as emitter.output_stream and content as "}"