Note:
Runa Standard Library: Logging Filters Module

Advanced filtering capabilities for log records including advanced filtering,
pattern matching, rate limiting, deduplication, and context-aware filtering.
Surpasses traditional logging frameworks with advanced filtering decisions.
:End Note

Import "string" as String
Import "collections" as Collections
Import "concurrent" as Concurrent
Import "datetime" as DateTime
Import "crypto" as Crypto
Import "logging/core" as LogCore

Note: Base Filter Interface
Type Filter is
    | LevelFilter
    | LoggerFilter
    | RegexFilter
    | RateLimitFilter
    | DeduplicationFilter
    | SamplingFilter
    | ContextFilter
    | TimeFilter
    | AnomalyFilter
    | CompositeFilter
    | PerformanceFilter
    | SecurityFilter

Note: Filter Statistics for Monitoring
Type called "FilterStatistics":
    total_evaluated as Integer
    total_passed as Integer
    total_blocked as Integer
    pass_rate as Float
    last_evaluation_time as Float
    average_evaluation_time_us as Float

Note: Level Filter - Basic threshold filtering
Type called "LevelFilter":
    min_level as LogCore.LogLevel
    max_level as Optional[LogCore.LogLevel]
    statistics as FilterStatistics

Process called "create_level_filter" that takes min_level as LogCore.LogLevel returns LevelFilter:
    Return LevelFilter with:
    min_level as min_level,
    max_level as Optional.None,
    statistics as create_empty_statistics()

Process called "create_level_range_filter" that takes min_level as LogCore.LogLevel and max_level as LogCore.LogLevel returns LevelFilter:
    Return LevelFilter with:
    min_level as min_level,
    max_level as Optional.Some(max_level),
    statistics as create_empty_statistics()

Implement should_log for LevelFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp() Let level_value be LogCore.get_level_value(record.level)
    Let min_value be LogCore.get_level_value(self.min_level) Let should_pass be level_value is greater than or equal to min_value If self.max_level is not Optional.None:
    Let max_value be LogCore.get_level_value(Optional.unwrap(self.max_level))
    Set should_pass to should_pass and (level_value is less than or equal to max_value) update_statistics(self.statistics, should_pass, start_time)
    Return should_pass

Note: Logger Name Filter - Filter by logger hierarchy
Type called "LoggerFilter":
    patterns as List[String]
    mode as FilterMode // INCLUDE or EXCLUDE
    use_hierarchy as Boolean
    statistics as FilterStatistics

Type FilterMode is
    | INCLUDE
    | EXCLUDE

Process called "create_logger_filter" that takes patterns as List[String] and mode as FilterMode returns LoggerFilter:
    Return LoggerFilter with:
    patterns as patterns,
    mode as mode,
    use_hierarchy as true,
    statistics as create_empty_statistics()

Implement should_log for LoggerFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp() Let matches be false For Each pattern in self.patterns:
    If self.use_hierarchy:
Note: Check if logger name starts with pattern (hierarchy match)
    If String.starts_with(record.logger_name, pattern):
    Set matches to true
    Break
    Otherwise:
Note: Exact match or glob pattern
    If matches_pattern(record.logger_name, pattern):
    Set matches to true
    Break Let should_pass be Match self.mode:
    When INCLUDE: matches
    When EXCLUDE: not matches update_statistics(self.statistics, should_pass, start_time)
    Return should_pass

Note: Regex Filter - Pattern matching on messages
Type called "RegexFilter":
    pattern as String
    compiled_pattern as CompiledRegex
    field as String // Which field to match against
    mode as FilterMode
    statistics as FilterStatistics

Process called "create_regex_filter" that takes pattern as String and field as String and mode as FilterMode returns RegexFilter:
    Return RegexFilter with:
    pattern as pattern,
    compiled_pattern as compile_regex(pattern),
    field as field,
    mode as mode,
    statistics as create_empty_statistics()

Implement should_log for RegexFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp() Let field_value be extract_field_for_filter(record, self.field)
    Let matches be regex_matches(self.compiled_pattern, field_value) Let should_pass be Match self.mode:
    When INCLUDE: matches
    When EXCLUDE: not matches update_statistics(self.statistics, should_pass, start_time)
    Return should_pass

Note: Rate Limit Filter - Prevent log flooding
Type called "RateLimitFilter":
    max_logs_per_second as Float
    max_logs_per_minute as Float
    max_logs_per_hour as Float
    burst_size as Integer
    token_bucket as TokenBucket
    sliding_window as SlidingWindow
    statistics as FilterStatistics
    suppressed_count as AtomicInteger
    last_suppression_message_time as AtomicFloat

Type called "TokenBucket":
    capacity as Float
    tokens as AtomicFloat
    refill_rate as Float
    last_refill_time as AtomicFloat
    mutex as Concurrent.Mutex

Process called "create_rate_limit_filter" that takes max_per_second as Float and burst_size as Integer returns RateLimitFilter:
    Return RateLimitFilter with:
    max_logs_per_second as max_per_second,
    max_logs_per_minute as max_per_second multiplied by 60,
    max_logs_per_hour as max_per_second multiplied by 3600,
    burst_size as burst_size,
    token_bucket as create_token_bucket(max_per_second, burst_size),
    sliding_window as create_sliding_window(3600), // 1 hour window
    statistics as create_empty_statistics(),
    suppressed_count as Concurrent.create_atomic_integer(0),
    last_suppression_message_time as Concurrent.create_atomic_float(0.0)

Implement should_log for RateLimitFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp()
    Note: Refill token bucket
    refill_tokens(self.token_bucket)
    Note: Try to consume a token
    Let has_token be try_consume_token(self.token_bucket, 1.0) If has_token:
Note: Update sliding window
    add_to_sliding_window(self.sliding_window, start_time)
    Note: Reset suppressed count on successful log
    Concurrent.atomic_set(self.suppressed_count, 0) update_statistics(self.statistics, true, start_time)
    Return true
    Otherwise:
Note: Increment suppressed count
    Concurrent.atomic_increment(self.suppressed_count)
    Note: Periodically log suppression message
    Let last_message_time be Concurrent.atomic_get(self.last_suppression_message_time)
    If (start_time - last_message_time) is greater than 60.0: // Once per minute
    Concurrent.atomic_set(self.last_suppression_message_time, start_time)
Note: Could inject a summary log here about suppressed messages update_statistics(self.statistics, false, start_time)
    Return false

Note: Deduplication Filter - Remove duplicate messages
Type called "DeduplicationFilter":
    cache_size as Integer
    time_window_seconds as Float
    hash_fields as List[String]
    seen_hashes as LRUCache[String, Float]
    mutex as Concurrent.Mutex
    statistics as FilterStatistics
    duplicate_count as Dictionary[String, Integer]

Process called "create_deduplication_filter" that takes cache_size as Integer and time_window as Float returns DeduplicationFilter:
    Return DeduplicationFilter with:
    cache_size as cache_size,
    time_window_seconds as time_window,
    hash_fields as ["level", "logger", "message"],
    seen_hashes as Collections.create_lru_cache(cache_size),
    mutex as Concurrent.create_mutex(),
    statistics as create_empty_statistics(),
    duplicate_count as Dictionary.new()

Implement should_log for DeduplicationFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp()
    Note: Generate hash of relevant fields
    Let hash_input be generate_dedup_hash(record, self.hash_fields)
    Let hash be Crypto.sha256_hex(hash_input) Concurrent.with_lock(self.mutex, Process():
Note: Check if we've seen this hash recently
    If Collections.lru_cache_contains(self.seen_hashes, hash):
    Let last_seen be Collections.lru_cache_get(self.seen_hashes, hash) If (start_time - last_seen) is less than self.time_window_seconds:
Note: Duplicate within time window
    increment_duplicate_count(self.duplicate_count, hash)
    update_statistics(self.statistics, false, start_time)
    Return false
    Note: New or expired hash
    Collections.lru_cache_put(self.seen_hashes, hash, start_time)
    update_statistics(self.statistics, true, start_time)
    Return true
    )

Note: Sampling Filter - Statistical sampling of logs
Type called "SamplingFilter":
    sample_rate as Float // 0.0 to 1.0
    strategy as SamplingStrategy
    reservoir as ReservoirSampler
    counter as AtomicInteger
    statistics as FilterStatistics

Type SamplingStrategy is
    | RANDOM
    | SYSTEMATIC
    | RESERVOIR
    | ADAPTIVE

Process called "create_sampling_filter" that takes sample_rate as Float and strategy as SamplingStrategy returns SamplingFilter:
    Return SamplingFilter with:
    sample_rate as sample_rate,
    strategy as strategy,
    reservoir as create_reservoir_sampler(1000),
    counter as Concurrent.create_atomic_integer(0),
    statistics as create_empty_statistics()

Implement should_log for SamplingFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp() Let should_pass be Match self.strategy:
    When RANDOM:
    random_float() is less than self.sample_rate
    When SYSTEMATIC:
    systematic_sample(self.counter, self.sample_rate)
    When RESERVOIR:
    reservoir_sample(self.reservoir, record)
    When ADAPTIVE:
    adaptive_sample(record, self.sample_rate) update_statistics(self.statistics, should_pass, start_time)
    Return should_pass

Note: Context Filter - Filter based on context (trace ID, user, etc.)
Type called "ContextFilter":
    required_fields as Dictionary[String, Any]
    optional_fields as Dictionary[String, Any]
    match_mode as ContextMatchMode
    statistics as FilterStatistics

Type ContextMatchMode is
    | ALL_REQUIRED // All required fields must match
    | ANY_REQUIRED // At least one required field must match
    | ALL_OPTIONAL // All optional fields that exist must match
    | ANY_OPTIONAL // At least one optional field must match

Process called "create_context_filter" that takes required_fields as Dictionary[String, Any] returns ContextFilter:
    Return ContextFilter with:
    required_fields as required_fields,
    optional_fields as Dictionary.new(),
    match_mode as ALL_REQUIRED,
    statistics as create_empty_statistics()

Implement should_log for ContextFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp() Let required_matches be check_required_fields(record, self.required_fields, self.match_mode)
    Let optional_matches be check_optional_fields(record, self.optional_fields, self.match_mode) Let should_pass be required_matches and optional_matches update_statistics(self.statistics, should_pass, start_time)
    Return should_pass

Note: Time-based Filter - Filter by time of day/week
Type called "TimeFilter":
    allowed_hours as Set[Integer] // 0-23
    allowed_days as Set[Integer] // 0-6 (Monday=0)
    allowed_months as Set[Integer] // 1-12
    timezone as String
    statistics as FilterStatistics

Process called "create_time_filter" that returns TimeFilter:
    Return TimeFilter with:
    allowed_hours as Set.from_range(0, 23), // All hours by default
    allowed_days as Set.from_range(0, 6), // All days by default
    allowed_months as Set.from_range(1, 12), // All months by default
    timezone as "UTC",
    statistics as create_empty_statistics()

Process called "create_business_hours_filter" that returns TimeFilter:
    Return TimeFilter with:
    allowed_hours as Set.from_list([9, 10, 11, 12, 13, 14, 15, 16, 17]), // 9 AM - 5 PM
    allowed_days as Set.from_list([0, 1, 2, 3, 4]), // Monday - Friday
    allowed_months as Set.from_range(1, 12),
    timezone as "local",
    statistics as create_empty_statistics()

Implement should_log for TimeFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp() Let dt be DateTime.from_timestamp(record.timestamp, self.timezone)
    Let hour be DateTime.get_hour(dt)
    Let day_of_week be DateTime.get_day_of_week(dt)
    Let month be DateTime.get_month(dt) Let should_pass be Set.contains(self.allowed_hours, hour) and
    Set.contains(self.allowed_days, day_of_week) and
    Set.contains(self.allowed_months, month) update_statistics(self.statistics, should_pass, start_time)
    Return should_pass

Note: ML-Powered Anomaly Filter - Filter unusual logs
Type called "AnomalyFilter":
    model as AnomalyDetectionModel
    threshold as Float
    training_mode as Boolean
    feature_extractor as FeatureExtractor
    statistics as FilterStatistics
    anomaly_history as RingBuffer[AnomalyRecord]

Type called "AnomalyRecord":
    timestamp as Float
    score as Float
    record_hash as String
    features as Dictionary[String, Float]

Process called "create_anomaly_filter" that takes threshold as Float returns AnomalyFilter:
    Return AnomalyFilter with:
    model as load_anomaly_detection_model(),
    threshold as threshold,
    training_mode as false,
    feature_extractor as create_log_feature_extractor(),
    statistics as create_empty_statistics(),
    anomaly_history as Collections.create_ring_buffer(1000)

Implement should_log for AnomalyFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp()
    Note: Extract features
    Let features be self.feature_extractor.extract(record)
    Note: Get anomaly score
    Let anomaly_score be self.model.predict(features)
    Note: Record anomaly
    If anomaly_score is greater than self.threshold:
    Let anomaly_record be AnomalyRecord with:
    timestamp as record.timestamp,
    score as anomaly_score,
    record_hash as generate_record_hash(record),
    features as features
    Collections.ring_buffer_add(self.anomaly_history, anomaly_record)
    Note: In training mode, always pass but learn
    If self.training_mode:
    self.model.update(features)
    update_statistics(self.statistics, true, start_time)
    Return true
    Note: Filter based on anomaly score
    Let should_pass be anomaly_score is less than or equal to self.threshold update_statistics(self.statistics, should_pass, start_time)
    Return should_pass

Note: Composite Filter - Combine multiple filters
Type CompositeFilter is Structure implementing Filter with:
    filters as List[Filter]
    operator as LogicalOperator
    short_circuit as Boolean
    statistics as FilterStatistics

Type LogicalOperator is
    AND
    OR
    XOR
    NOT

Process called "create_and_filter" that takes filters as List[Filter] returns CompositeFilter:
    Return CompositeFilter with:
    filters as filters,
    operator as AND,
    short_circuit as true,
    statistics as create_empty_statistics()

Process called "create_or_filter" that takes filters as List[Filter] returns CompositeFilter:
    Return CompositeFilter with:
    filters as filters,
    operator as OR,
    short_circuit as true,
    statistics as create_empty_statistics()

Implement should_log for CompositeFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp() Let should_pass be Match self.operator:
    When AND:
    evaluate_and_filters(self.filters, record, self.short_circuit)
    When OR:
    evaluate_or_filters(self.filters, record, self.short_circuit)
    When XOR:
    evaluate_xor_filters(self.filters, record)
    When NOT:
    If Collections.length(self.filters) is greater than 0:
    not Collections.first(self.filters).should_log(record)
    Otherwise:
    true update_statistics(self.statistics, should_pass, start_time)
    Return should_pass

Note: Performance Filter - Filter based on performance metrics
Type PerformanceFilter is Structure implementing Filter with:
    max_duration_ms as Optional[Float]
    min_duration_ms as Optional[Float]
    max_cpu_usage as Optional[Float]
    max_memory_bytes as Optional[Integer]
    statistics as FilterStatistics

Process called "create_performance_filter" that returns PerformanceFilter:
    Return PerformanceFilter with:
    max_duration_ms as Optional.None,
    min_duration_ms as Optional.None,
    max_cpu_usage as Optional.None,
    max_memory_bytes as Optional.None,
    statistics as create_empty_statistics()

Implement should_log for PerformanceFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp() Let should_pass be true
    Note: Check performance metrics if present
    If record.performance_metrics is not Optional.None:
    Let metrics be Optional.unwrap(record.performance_metrics) If self.max_duration_ms is not Optional.None:
    Set should_pass to should_pass and 
    (metrics.duration_ms is less than or equal to Optional.unwrap(self.max_duration_ms)) If self.min_duration_ms is not Optional.None:
    Set should_pass to should_pass and 
    (metrics.duration_ms is greater than or equal to Optional.unwrap(self.min_duration_ms))
    Note: Check CPU usage
    If self.max_cpu_usage is not Optional.None and record.cpu_usage is not Optional.None:
    Set should_pass to should_pass and 
    (Optional.unwrap(record.cpu_usage) is less than or equal to Optional.unwrap(self.max_cpu_usage))
    Note: Check memory usage
    If self.max_memory_bytes is not Optional.None and record.memory_usage is not Optional.None:
    Let memory be Optional.unwrap(record.memory_usage)
    Set should_pass to should_pass and 
    (memory.heap_used_bytes is less than or equal to Optional.unwrap(self.max_memory_bytes)) update_statistics(self.statistics, should_pass, start_time)
    Return should_pass

Note: Security Filter - Filter sensitive information
Type SecurityFilter is Structure implementing Filter with:
    redact_patterns as List[CompiledRegex]
    allowed_users as Set[String]
    allowed_ips as List[IPRange]
    block_patterns as List[CompiledRegex]
    redaction_mode as RedactionMode
    statistics as FilterStatistics

Type RedactionMode is
    BLOCK // Don't log at all
    REDACT // Replace with [REDACTED]
    HASH // Replace with hash
    PARTIAL // Show partial (first/last few chars)

Process called "create_security_filter" that returns SecurityFilter:
    Return SecurityFilter with:
    redact_patterns as compile_common_sensitive_patterns(),
    allowed_users as Set.new(),
    allowed_ips as List.new(),
    block_patterns as List.new(),
    redaction_mode as REDACT,
    statistics as create_empty_statistics()

Implement should_log for SecurityFilter that takes record as LogCore.LogRecord returns Boolean:
    Let start_time be get_high_precision_timestamp()
    Note: Check if user is allowed
    If Collections.length(self.allowed_users) is greater than 0:
    If record.user_id is Optional.None or 
    not Set.contains(self.allowed_users, Optional.unwrap(record.user_id)):
    update_statistics(self.statistics, false, start_time)
    Return false
    Note: Check if IP is allowed
    If Collections.length(self.allowed_ips) is greater than 0:
    If record.ip_address is Optional.None or 
    not is_ip_in_ranges(Optional.unwrap(record.ip_address), self.allowed_ips):
    update_statistics(self.statistics, false, start_time)
    Return false
    Note: Check for blocked patterns
    For Each pattern in self.block_patterns:
    If regex_matches(pattern, record.message):
    update_statistics(self.statistics, false, start_time)
    Return false
    Note: Redact sensitive information
    For Each pattern in self.redact_patterns:
    If regex_matches(pattern, record.message):
    Match self.redaction_mode:
    When BLOCK:
    update_statistics(self.statistics, false, start_time)
    Return false
    When REDACT:
    Set record.message to regex_replace(pattern, record.message, "[REDACTED]")
    When HASH:
    Set record.message to redact_with_hash(pattern, record.message)
    When PARTIAL:
    Set record.message to redact_partial(pattern, record.message) update_statistics(self.statistics, true, start_time)
    Return true

Note: Helper Functions
Process called "create_empty_statistics" that returns FilterStatistics:
    Return FilterStatistics with:
    total_evaluated as 0,
    total_passed as 0,
    total_blocked as 0,
    pass_rate as 0.0,
    last_evaluation_time as 0.0,
    average_evaluation_time_us as 0.0

Process called "update_statistics" that takes stats as FilterStatistics and passed as Boolean and start_time as Float returns Nothing:
    Let end_time be get_high_precision_timestamp()
    Let duration_us be (end_time - start_time) multiplied by 1000000 Set stats.total_evaluated to stats.total_evaluated + 1 If passed:
    Set stats.total_passed to stats.total_passed + 1
    Otherwise:
    Set stats.total_blocked to stats.total_blocked + 1 Set stats.pass_rate to Float.from_integer(stats.total_passed) divided by 
    Float.from_integer(stats.total_evaluated) Set stats.last_evaluation_time to end_time
    Note: Update rolling average of evaluation time
    Let weight be 0.1 // Exponential moving average weight
    Set stats.average_evaluation_time_us to 
    (stats.average_evaluation_time_us multiplied by (1 - weight)) + (duration_us multiplied by weight)

Process called "extract_field_for_filter" that takes record as LogCore.LogRecord and field as String returns String:
    Match field:
    When "message": Return record.message
    When "logger": Return record.logger_name
    When "module": Return record.module
    When "function": Return record.function
    When "level": Return LogCore.level_to_string(record.level)
    Otherwise: Return ""

Process called "generate_dedup_hash" that takes record as LogCore.LogRecord and fields as List[String] returns String:
    Let parts be List.new() For Each field in fields:
    Let value be extract_field_for_filter(record, field)
    Add value to parts Return String.join(parts, "|")

Process called "generate_record_hash" that takes record as LogCore.LogRecord returns String:
    Let data be record.logger_name + "|" + 
    LogCore.level_to_string(record.level) + "|" +
    record.message
    Return Crypto.sha256_hex(data)

Process called "compile_common_sensitive_patterns" that returns List[CompiledRegex]:
    Return List[
    compile_regex("\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b"), // Email
    compile_regex("\\b(?:4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13}|3(?:0[0-5]|[68][0-9])[0-9]{11}|6(?:011|5[0-9]{2})[0-9]{12}|(?:2131|1800|35\\d{3})\\d{11})\\b"), // Credit cards
    compile_regex("\\b[0-9]{3}-[0-9]{2}-[0-9]{4}\\b"), // SSN
    compile_regex("Bearer [A-Za-z0-9\\-._~+/]+=*"), // Bearer tokens
    compile_regex("\\b[A-Za-z0-9]{40}\\b"), // API keys (generic)
    compile_regex("password[\"']?\\s*[:=]\\s*[\"']?[^\"'\\s]+"), // Passwords in configs
    ]

Process called "create_token_bucket" that takes rate as Float and capacity as Float returns TokenBucket:
    Return TokenBucket with:
    capacity as capacity,
    tokens as Concurrent.create_atomic_float(capacity),
    refill_rate as rate,
    last_refill_time as Concurrent.create_atomic_float(get_high_precision_timestamp()),
    mutex as Concurrent.create_mutex()

Process called "refill_tokens" that takes bucket as TokenBucket returns Nothing:
    Let current_time be get_high_precision_timestamp()
    Let last_refill be Concurrent.atomic_get(bucket.last_refill_time)
    Let time_passed be current_time - last_refill If time_passed is greater than 0:
    Let tokens_to_add be time_passed multiplied by bucket.refill_rate
    Let current_tokens be Concurrent.atomic_get(bucket.tokens)
    Let new_tokens be Math.min(current_tokens + tokens_to_add, bucket.capacity) Concurrent.atomic_set(bucket.tokens, new_tokens)
    Concurrent.atomic_set(bucket.last_refill_time, current_time)

Process called "try_consume_token" that takes bucket as TokenBucket and amount as Float returns Boolean:
    Return Concurrent.with_lock(bucket.mutex, Process():
    Let current_tokens be Concurrent.atomic_get(bucket.tokens) If current_tokens is greater than or equal to amount:
    Concurrent.atomic_set(bucket.tokens, current_tokens - amount)
    Return true
    Otherwise:
    Return false
    )