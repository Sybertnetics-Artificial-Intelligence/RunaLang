Note:
Runa Standard Library: Logging Handlers Module

Production-grade log handlers that surpass industry standards with advanced features
like automatic failover, advanced batching, cloud integration, and advanced routing.
:End Note

Import "../../io" as IO
Import "../../net" as Net
Import "../../concurrent" as Concurrent
Import "../../crypto" as Crypto
Import "../../json" as JSON
Import "logging/core" as LogCore
Import "logging/formatters" as Formatters

Note: Base Handler Interface
Type Handler is:
    handle that takes record as LogCore.LogRecord returns Boolean
    set_formatter that takes formatter as Formatter returns Nothing
    set_level that takes level as LogCore.LogLevel returns Nothing
    flush that returns Nothing
    close that returns Nothing
    supports_batch_write that returns Boolean
    write_batch that takes records as List[LogCore.LogRecord] returns Boolean

Note: Console Handler with Color Support and Progress Bars
Type called "ConsoleHandler":
    formatter as Formatter
    level as LogCore.LogLevel
    stream as String // "stdout" or "stderr"
    color_enabled as Boolean
    progress_bars as Dictionary[String, ProgressBar]
    mutex as Concurrent.Mutex
    buffer_size as Integer
    buffer as MutableString
    last_flush_time as Float

Process called "create_console_handler" that takes level as LogCore.LogLevel and colored as Boolean returns ConsoleHandler:
    Return ConsoleHandler with:
    formatter as Formatters.create_colored_formatter(),
    level as level,
    stream as "stderr",
    color_enabled as colored and is_terminal_tty(),
    progress_bars as new Dictionary,
    mutex as Concurrent.create_mutex(),
    buffer_size as 4096,
    buffer as MutableString.with_capacity(4096),
    last_flush_time as get_current_timestamp()

Implement handle for ConsoleHandler that takes record as LogCore.LogRecord returns Boolean:
    If not LogCore.is_level_enabled_for_handler(self, record.level):
    Return false
    Note: Format the record
    Let formatted be self.formatter.format(record)
    Note: Add to buffer with thread safety
    Concurrent.with_lock(self.mutex, Process():
    MutableString.append(self.buffer, formatted)
    MutableString.append(self.buffer, "\n")
    Note: Auto-flush if buffer is full or time elapsed
    If MutableString.length(self.buffer) is greater than self.buffer_size or
    (get_current_timestamp() minus self.last_flush_time) is greater than 1.0:
    self.flush()
    ) Return true

Implement flush for ConsoleHandler that returns Nothing:
    If MutableString.length(self.buffer) is equal to 0:
    Return Let content be MutableString.to_string(self.buffer) If self.stream is equal to "stdout":
    IO.write_stdout(content)
    Otherwise:
    IO.write_stderr(content) MutableString.clear(self.buffer)
    Set self.last_flush_time to get_current_timestamp()

Note: File Handler with Rotation and Compression
Type FileHandler is Structure implementing Handler with:
    formatter as Formatter
    level as LogCore.LogLevel
    file_path as String
    current_file as IO.File
    max_bytes as Integer
    backup_count as Integer
    compression as Optional[String] // "gzip", "zstd", "lz4"
    current_size as AtomicInteger
    mutex as Concurrent.Mutex
    encode_utf8 as Boolean
    write_buffer as IO.BufferedWriter
    rotation_strategy as RotationStrategy

Type RotationStrategy is
    SIZE_BASED
    TIME_BASED
    SIZE_AND_TIME
    DAILY
    HOURLY

Process called "create_file_handler" that takes path as String and level as LogCore.LogLevel and max_bytes as Integer returns FileHandler:
    Let file be IO.open_file(path, IO.APPEND | IO.CREATE | IO.WRITE)
    Let current_size be IO.get_file_size(path) Return FileHandler with:
    formatter as Formatters.create_json_formatter(),
    level as level,
    file_path as path,
    current_file as file,
    max_bytes as max_bytes,
    backup_count as 10,
    compression as Optional.Some("zstd"),
    current_size as Concurrent.create_atomic_integer(current_size),
    mutex as Concurrent.create_mutex(),
    encode_utf8 as true,
    write_buffer as IO.create_buffered_writer(file, 8192),
    rotation_strategy as SIZE_AND_TIME

Implement handle for FileHandler that takes record as LogCore.LogRecord returns Boolean:
    If not LogCore.is_level_enabled_for_handler(self, record.level):
    Return false
    Note: Format the record
    Let formatted be self.formatter.format(record)
    Let bytes be If self.encode_utf8 then String.to_utf8_bytes(formatted) 
    else String.to_bytes(formatted)
    Note: Write with thread safety
    Concurrent.with_lock(self.mutex, Process():
Note: Check rotation
    If should_rotate(self):
    rotate_log_file(self)
    Note: Write to buffer
    IO.write_bytes(self.write_buffer, bytes)
    IO.write_byte(self.write_buffer, 10) // Newline
    Note: Update size
    Concurrent.atomic_add(self.current_size, Collections.length(bytes) + 1)
    Note: Auto-flush on important logs
    If record.level is greater than or equal to ERROR:
    IO.flush(self.write_buffer)
    ) Return true

Process called "should_rotate" that takes handler as FileHandler returns Boolean:
    Match handler.rotation_strategy:
    When SIZE_BASED:
    Return Concurrent.atomic_get(handler.current_size) is greater than or equal to handler.max_bytes
    When TIME_BASED:
    Return should_rotate_by_time(handler)
    When SIZE_AND_TIME:
    Return Concurrent.atomic_get(handler.current_size) is greater than or equal to handler.max_bytes or
    should_rotate_by_time(handler)
    When DAILY:
    Return is_new_day_since_last_rotation(handler)
    When HOURLY:
    Return is_new_hour_since_last_rotation(handler)

Process called "rotate_log_file" that takes handler as FileHandler returns Nothing:
Note: Close current file
    IO.close(handler.write_buffer)
    IO.close(handler.current_file)
    Note: Generate rotation name
    Let timestamp be format_timestamp_for_filename(get_current_timestamp())
    Let base_name be handler.file_path
    Let rotated_name be base_name + "." + timestamp
    Note: Rename current file
    IO.rename_file(handler.file_path, rotated_name)
    Note: Compress if configured
    If handler.compression is not Optional.None:
    Let compression_type be Optional.unwrap(handler.compression)
    compress_rotated_file(rotated_name, compression_type)
    Note: Clean up old backups
    cleanup_old_backups(handler)
    Note: Open new file
    Set handler.current_file to IO.open_file(handler.file_path, IO.APPEND | IO.CREATE | IO.WRITE)
    Set handler.write_buffer to IO.create_buffered_writer(handler.current_file, 8192)
    Concurrent.atomic_set(handler.current_size, 0)

Note: Network Handler for Remote Logging
Type NetworkHandler is Structure implementing Handler with:
    formatter as Formatter
    level as LogCore.LogLevel
    endpoint as String
    protocol as NetworkProtocol
    connection as Net.Connection
    reconnect_attempts as Integer
    max_reconnect_attempts as Integer
    batch_size as Integer
    batch_buffer as List[LogCore.LogRecord]
    compression_enabled as Boolean
    encryption_enabled as Boolean
    auth_token as Optional[String]
    connection_pool as Net.ConnectionPool
    circuit_breaker as CircuitBreaker

Type NetworkProtocol is
    TCP
    UDP
    HTTP
    HTTPS
    GRPC
    WEBSOCKET
    MQTT
    AMQP

Process called "create_network_handler" that takes endpoint as String and protocol as NetworkProtocol and level as LogCore.LogLevel returns NetworkHandler:
    Let connection_pool be Net.create_connection_pool(endpoint, 10) Return NetworkHandler with:
    formatter as Formatters.create_json_formatter(),
    level as level,
    endpoint as endpoint,
    protocol as protocol,
    connection as Net.create_connection(endpoint, protocol),
    reconnect_attempts as 0,
    max_reconnect_attempts as 10,
    batch_size as 100,
    batch_buffer as new List,
    compression_enabled as true,
    encryption_enabled as true,
    auth_token as Optional.None,
    connection_pool as connection_pool,
    circuit_breaker as create_circuit_breaker()

Implement handle for NetworkHandler that takes record as LogCore.LogRecord returns Boolean:
    If not LogCore.is_level_enabled_for_handler(self, record.level):
    Return false
    Note: Check circuit breaker
    If not self.circuit_breaker.is_closed():
    Return false
    Note: Add to batch
    Add record to self.batch_buffer
    Note: Send if batch is full
    If Collections.length(self.batch_buffer) is greater than or equal to self.batch_size:
    Return send_batch(self) Return true

Process called "send_batch" that takes handler as NetworkHandler returns Boolean:
    If Collections.length(handler.batch_buffer) is equal to 0:
    Return true Try:
Note: Serialize batch
    Let serialized be serialize_log_batch(handler.batch_buffer, handler.formatter)
    Note: Compress if enabled
    If handler.compression_enabled:
    Set serialized to Compress.compress_zstd(serialized, 3)
    Note: Encrypt if enabled
    If handler.encryption_enabled:
    Set serialized to encrypt_data(serialized)
    Note: Send over network
    Let connection be Net.get_connection_from_pool(handler.connection_pool)
    Let success be Net.send_data(connection, serialized) If success:
    handler.circuit_breaker.record_success()
    Collections.clear(handler.batch_buffer)
    Return true
    Otherwise:
    handler.circuit_breaker.record_failure()
    Return false Catch error:
    handler.circuit_breaker.record_failure()
    Note: Try to reconnect
    If handler.reconnect_attempts is less than handler.max_reconnect_attempts:
    Set handler.reconnect_attempts to handler.reconnect_attempts + 1
    reconnect_handler(handler) Return false

Note: Database Handler for Structured Storage
Type DatabaseHandler is Structure implementing Handler with:
    formatter as Formatter
    level as LogCore.LogLevel
    connection_string as String
    table_name as String
    database as DB.Connection
    prepared_statement as DB.PreparedStatement
    batch_size as Integer
    batch_buffer as List[LogCore.LogRecord]
    transaction_size as Integer
    index_columns as List[String]
    partition_strategy as PartitionStrategy
    retention_days as Integer

Type PartitionStrategy is
    NONE
    DAILY
    MONTHLY
    BY_LEVEL
    BY_LOGGER

Process called "create_database_handler" that takes connection_string as String and table_name as String and level as LogCore.LogLevel returns DatabaseHandler:
    Let database be DB.connect(connection_string)
    Note: Create table if not exists
    create_log_table_if_not_exists(database, table_name)
    Note: Prepare insert statement
    Let prepared_statement be DB.prepare(database, 
    "INSERT INTO " + table_name + 
    " (timestamp, level, logger, message, module, function, line, metadata, trace_id, span_id) " +
    "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)") Return DatabaseHandler with:
    formatter as Formatters.create_structured_formatter(),
    level as level,
    connection_string as connection_string,
    table_name as table_name,
    database as database,
    prepared_statement as prepared_statement,
    batch_size as 100,
    batch_buffer as new List,
    transaction_size as 1000,
    index_columns as ["timestamp", "level", "logger", "trace_id"],
    partition_strategy as DAILY,
    retention_days as 90

Implement handle for DatabaseHandler that takes record as LogCore.LogRecord returns Boolean:
    If not LogCore.is_level_enabled_for_handler(self, record.level):
    Return false
    Note: Add to batch
    Add record to self.batch_buffer
    Note: Insert if batch is full
    If Collections.length(self.batch_buffer) is greater than or equal to self.batch_size:
    Return insert_batch(self) Return true

Process called "insert_batch" that takes handler as DatabaseHandler returns Boolean:
    If Collections.length(handler.batch_buffer) is equal to 0:
    Return true Try:
Note: Begin transaction
    DB.begin_transaction(handler.database) For Each record in handler.batch_buffer:
Note: Bind parameters
    DB.bind_timestamp(handler.prepared_statement, 1, record.timestamp)
    DB.bind_string(handler.prepared_statement, 2, LogCore.level_to_string(record.level))
    DB.bind_string(handler.prepared_statement, 3, record.logger_name)
    DB.bind_string(handler.prepared_statement, 4, record.message)
    DB.bind_string(handler.prepared_statement, 5, record.module)
    DB.bind_string(handler.prepared_statement, 6, record.function)
    DB.bind_integer(handler.prepared_statement, 7, record.line)
    DB.bind_json(handler.prepared_statement, 8, record.metadata)
    DB.bind_string(handler.prepared_statement, 9, 
    If record.trace_id is Optional.None then null else Optional.unwrap(record.trace_id))
    DB.bind_string(handler.prepared_statement, 10,
    If record.span_id is Optional.None then null else Optional.unwrap(record.span_id))
    Note: Execute insert
    DB.execute(handler.prepared_statement)
    Note: Commit transaction
    DB.commit(handler.database)
    Note: Clear buffer
    Collections.clear(handler.batch_buffer)
    Note: Clean up old partitions
    If handler.retention_days is greater than 0:
    cleanup_old_partitions(handler) Return true Catch error:
    DB.rollback(handler.database)
    Return false

Note: Cloud Handler for AWS/Azure/GCP Integration
Type CloudHandler is Structure implementing Handler with:
    formatter as Formatter
    level as LogCore.LogLevel
    provider as CloudProvider
    service_config as CloudServiceConfig
    client as Cloud.Client
    batch_size as Integer
    batch_buffer as List[LogCore.LogRecord]
    cost_optimizer as CostOptimizer
    multi_region as Boolean
    failover_regions as List[String]

Type CloudProvider is
    AWS_CLOUDWATCH
    AZURE_MONITOR
    GCP_STACKDRIVER
    DATADOG
    SPLUNK
    ELASTIC_CLOUD
    NEW_RELIC
    SUMOLOGIC

Process called "create_cloud_handler" that takes provider as CloudProvider and config as CloudServiceConfig and level as LogCore.LogLevel returns CloudHandler:
    Let client be Cloud.create_client(provider, config) Return CloudHandler with:
    formatter as Formatters.create_cloud_formatter(provider),
    level as level,
    provider as provider,
    service_config as config,
    client as client,
    batch_size as 500,
    batch_buffer as new List,
    cost_optimizer as create_cost_optimizer(provider),
    multi_region as true,
    failover_regions as determine_failover_regions(provider, config.primary_region)

Implement handle for CloudHandler that takes record as LogCore.LogRecord returns Boolean:
    If not LogCore.is_level_enabled_for_handler(self, record.level):
    Return false
    Note: Apply cost optimization
    If not self.cost_optimizer.should_log(record):
    Return false
    Note: Add to batch
    Add record to self.batch_buffer
    Note: Send if batch is full or high priority
    If Collections.length(self.batch_buffer) is greater than or equal to self.batch_size or
    record.level is greater than or equal to ERROR:
    Return send_to_cloud(self) Return true

Process called "send_to_cloud" that takes handler as CloudHandler returns Boolean:
    If Collections.length(handler.batch_buffer) is equal to 0:
    Return true
    Note: Convert to cloud-specific format
    Let cloud_logs be convert_to_cloud_format(handler.batch_buffer, handler.provider) Try:
Note: Try primary region first
    Let success be Cloud.put_log_events(handler.client, cloud_logs) If success:
    Collections.clear(handler.batch_buffer)
    handler.cost_optimizer.record_usage(Collections.length(cloud_logs))
    Return true
    Note: Failover to secondary regions
    For Each region in handler.failover_regions:
    Let regional_client be Cloud.create_regional_client(handler.provider, region)
    Set success to Cloud.put_log_events(regional_client, cloud_logs) If success:
    Collections.clear(handler.batch_buffer)
    Return true Return false Catch error:
Note: Store failed logs for retry
    store_failed_logs(handler.batch_buffer)
    Return false

Note: Syslog Handler for System Integration
Type SyslogHandler is Structure implementing Handler with:
    formatter as Formatter
    level as LogCore.LogLevel
    facility as SyslogFacility
    host as String
    port as Integer
    protocol as String // "udp" or "tcp"
    socket as Net.Socket
    app_name as String
    hostname as String
    rfc_format as RFCFormat

Type SyslogFacility is
    KERN with value as 0
    USER with value as 1
    MAIL with value as 2
    DAEMON with value as 3
    AUTH with value as 4
    SYSLOG with value as 5
    LPR with value as 6
    NEWS with value as 7
    UUCP with value as 8
    CRON with value as 9
    AUTHPRIV with value as 10
    FTP with value as 11
    LOCAL0 with value as 16
    LOCAL1 with value as 17
    LOCAL2 with value as 18
    LOCAL3 with value as 19
    LOCAL4 with value as 20
    LOCAL5 with value as 21
    LOCAL6 with value as 22
    LOCAL7 with value as 23

Type RFCFormat is
    RFC3164 // Traditional BSD syslog
    RFC5424 // Modern syslog with structured data

Process called "create_syslog_handler" that takes host as String and port as Integer and facility as SyslogFacility and level as LogCore.LogLevel returns SyslogHandler:
    Let socket be Net.create_udp_socket()
    Net.connect(socket, host, port) Return SyslogHandler with:
    formatter as Formatters.create_syslog_formatter(),
    level as level,
    facility as facility,
    host as host,
    port as port,
    protocol as "udp",
    socket as socket,
    app_name as get_application_name(),
    hostname as get_hostname(),
    rfc_format as RFC5424

Implement handle for SyslogHandler that takes record as LogCore.LogRecord returns Boolean:
    If not LogCore.is_level_enabled_for_handler(self, record.level):
    Return false
    Note: Calculate priority
    Let severity be log_level_to_syslog_severity(record.level)
    Let priority be (self.facility multiplied by 8) + severity
    Note: Format message based on RFC
    Let syslog_message be Match self.rfc_format:
    When RFC3164:
    format_rfc3164_message(priority, record, self)
    When RFC5424:
    format_rfc5424_message(priority, record, self)
    Note: Send to syslog server
    Try:
    Net.send_bytes(self.socket, String.to_bytes(syslog_message))
    Return true
    Catch error:
Note: Try to reconnect
    reconnect_syslog(self)
    Return false

Note: Email Handler for Alerts
Type EmailHandler is Structure implementing Handler with:
    formatter as Formatter
    level as LogCore.LogLevel
    smtp_config as SMTPConfig
    recipients as List[String]
    subject_template as String
    rate_limiter as RateLimiter
    aggregation_window_seconds as Integer
    aggregated_logs as List[LogCore.LogRecord]
    last_send_time as Float

Process called "create_email_handler" that takes smtp_config as SMTPConfig and recipients as List[String] and level as LogCore.LogLevel returns EmailHandler:
    Return EmailHandler with:
    formatter as Formatters.create_html_formatter(),
    level as level,
    smtp_config as smtp_config,
    recipients as recipients,
    subject_template as "[{level}] {logger}: {message}",
    rate_limiter as create_rate_limiter(10, 3600), // 10 emails per hour
    aggregation_window_seconds as 300, // 5 minutes
    aggregated_logs as new List,
    last_send_time as get_current_timestamp()

Implement handle for EmailHandler that takes record as LogCore.LogRecord returns Boolean:
    If not LogCore.is_level_enabled_for_handler(self, record.level):
    Return false
    Note: Check rate limit
    If not self.rate_limiter.allow():
    Return false
    Note: Add to aggregation buffer
    Add record to self.aggregated_logs
    Note: Send if critical or aggregation window expired
    If record.level is greater than or equal to CRITICAL or
    (get_current_timestamp() minus self.last_send_time) is greater than self.aggregation_window_seconds:
    Return send_email_alert(self) Return true

Process called "send_email_alert" that takes handler as EmailHandler returns Boolean:
    If Collections.length(handler.aggregated_logs) is equal to 0:
    Return true
    Note: Format email body
    Let body be format_email_body(handler.aggregated_logs, handler.formatter)
    Note: Generate subject
    Let most_severe be get_most_severe_log(handler.aggregated_logs)
    Let subject be format_email_subject(most_severe, handler.subject_template)
    Note: Send email
    Try:
    send_smtp_email(handler.smtp_config, handler.recipients, subject, body)
    Note: Clear buffer and update time
    Collections.clear(handler.aggregated_logs)
    Set handler.last_send_time to get_current_timestamp() Return true
    Catch error:
    Return false

Note: Memory Buffer Handler for High Performance
Type MemoryHandler is Structure implementing Handler with:
    formatter as Formatter
    level as LogCore.LogLevel
    buffer as RingBuffer[LogCore.LogRecord]
    capacity as Integer
    target_handler as Handler
    flush_level as LogCore.LogLevel
    flush_on_close as Boolean

Process called "create_memory_handler" that takes capacity as Integer and target as Handler and flush_level as LogCore.LogLevel returns MemoryHandler:
    Return MemoryHandler with:
    formatter as target.formatter,
    level as target.level,
    buffer as Collections.create_ring_buffer(capacity),
    capacity as capacity,
    target_handler as target,
    flush_level as flush_level,
    flush_on_close as true

Implement handle for MemoryHandler that takes record as LogCore.LogRecord returns Boolean:
    If not LogCore.is_level_enabled_for_handler(self, record.level):
    Return false
    Note: Add to ring buffer (overwrites old logs if full)
    Collections.ring_buffer_add(self.buffer, record)
    Note: Flush if we hit a high-priority log
    If record.level is greater than or equal to self.flush_level:
    Return flush_to_target(self) Return true

Process called "flush_to_target" that takes handler as MemoryHandler returns Boolean:
    Let records be Collections.ring_buffer_drain(handler.buffer) For Each record in records:
    handler.target_handler.handle(record) Return true

Note: Null Handler for Testing/Disabled Logging
Type NullHandler is Structure implementing Handler with:
    level as LogCore.LogLevel

Process called "create_null_handler" that returns NullHandler:
    Return NullHandler with:
    level as EMERGENCY // Accept everything but do nothing

Implement handle for NullHandler that takes record as LogCore.LogRecord returns Boolean:
    Return true // Always succeed but do nothing

Note: Multi-Handler for Fanout
Type MultiHandler is Structure implementing Handler with:
    handlers as List[Handler]
    level as LogCore.LogLevel
    parallel as Boolean
    continue_on_error as Boolean

Process called "create_multi_handler" that takes handlers as List[Handler] and parallel as Boolean returns MultiHandler:
    Return MultiHandler with:
    handlers as handlers,
    level as TRACE, // Accept all, let child handlers filter
    parallel as parallel,
    continue_on_error as true

Implement handle for MultiHandler that takes record as LogCore.LogRecord returns Boolean:
    If self.parallel:
Note: Process handlers in parallel
    Let results be Concurrent.parallel_map(self.handlers, Process(handler):
    Try:
    Return handler.handle(record)
    Catch error:
    If not self.continue_on_error:
    Throw error
    Return false
    )
    Note: Return true if any handler succeeded
    Return Collections.any(results, Process(result): Return result)
    Otherwise:
Note: Process handlers sequentially
    Let any_success be false For Each handler in self.handlers:
    Try:
    If handler.handle(record):
    Set any_success to true
    Catch error:
    If not self.continue_on_error:
    Throw error Return any_success

Note: Circuit Breaker for Network Handlers
Type called "CircuitBreaker":
    failure_threshold as Integer
    success_threshold as Integer
    timeout_seconds as Float
    failure_count as AtomicInteger
    success_count as AtomicInteger
    state as AtomicEnum[CircuitState]
    last_failure_time as AtomicFloat
    half_open_time as AtomicFloat

Type CircuitState is
    CLOSED
    OPEN
    HALF_OPEN

Process called "create_circuit_breaker" that returns CircuitBreaker:
    Return CircuitBreaker with:
    failure_threshold as 5,
    success_threshold as 2,
    timeout_seconds as 60.0,
    failure_count as Concurrent.create_atomic_integer(0),
    success_count as Concurrent.create_atomic_integer(0),
    state as Concurrent.create_atomic_enum(CLOSED),
    last_failure_time as Concurrent.create_atomic_float(0.0),
    half_open_time as Concurrent.create_atomic_float(0.0)

Note: Cost Optimizer for Cloud Logging
Type called "CostOptimizer":
    provider as CloudProvider
    cost_per_gb as Float
    monthly_budget as Float
    current_usage_bytes as AtomicInteger
    current_month_cost as AtomicFloat
    sampling_rates as Dictionary[LogCore.LogLevel, Float]

Process called "create_cost_optimizer" that takes provider as CloudProvider returns CostOptimizer:
    Let cost_per_gb be get_provider_cost_per_gb(provider) Return CostOptimizer with:
    provider as provider,
    cost_per_gb as cost_per_gb,
    monthly_budget as 1000.0, // $1000 default budget
    current_usage_bytes as Concurrent.create_atomic_integer(0),
    current_month_cost as Concurrent.create_atomic_float(0.0),
    sampling_rates as Dictionary[
    TRACE -> 0.01, // Sample 1% of trace logs
    DEBUG -> 0.1, // Sample 10% of debug logs
    VERBOSE -> 0.5, // Sample 50% of verbose logs
    INFO -> 1.0, // Keep all info logs
    NOTICE -> 1.0, // Keep all notice logs
    WARNING -> 1.0, // Keep all warnings
    ERROR -> 1.0, // Keep all errors
    CRITICAL -> 1.0, // Keep all critical
    FATAL -> 1.0, // Keep all fatal
    EMERGENCY -> 1.0 // Keep all emergency
    ]