Note:
Runa Standard Library: Logging Formatters Module

Advanced log formatting with support for multiple output formats, structured data,
colorization, templates, and ML-friendly formats. Surpasses industry standards
with automatic context enrichment and advanced formatting decisions.
:End Note

Import "string" as String
Import "json" as JSON
Import "datetime" as DateTime
Import "collections" as Collections
Import "logging/core" as LogCore

Note: Base Formatter Interface
Type Formatter is
    | TextFormatter
    | JSONFormatter
    | ColoredFormatter
    | XMLFormatter
    | CSVFormatter
    | LogstashFormatter
    | CEFFormatter
    | GELFFormatter

Note: Text Formatter with Template Support
Type called "TextFormatter":
    template as String
    date_format as String
    include_milliseconds as Boolean
    include_timezone as Boolean
    field_separator as String
    null_placeholder as String
    max_message_length as Integer
    truncate_indicator as String
    custom_fields as Dictionary[String, Function[LogCore.LogRecord, String]]

Process called "create_text_formatter" that returns TextFormatter:
    Return TextFormatter with:
    template as "{timestamp} [{level:5}] {logger:20} | {message}",
    date_format as "YYYY-MM-DD HH:mm:ss",
    include_milliseconds as true,
    include_timezone as true,
    field_separator as " | ",
    null_placeholder as "-",
    max_message_length as 10000,
    truncate_indicator as "...[truncated]",
    custom_fields as new Dictionary

Process called "create_detailed_text_formatter" that returns TextFormatter:
    Return TextFormatter with:
    template as "{timestamp} [{level:5}] {logger} ({module}:{function}:{line}) minus {message} {metadata}",
    date_format as "YYYY-MM-DD HH:mm:ss.SSS",
    include_milliseconds as true,
    include_timezone as true,
    field_separator as " | ",
    null_placeholder as "N/A",
    max_message_length as -1, // No truncation
    truncate_indicator as "",
    custom_fields as new Dictionary

Implement format for TextFormatter that takes record as LogCore.LogRecord returns String:
    Let result be self.template
    Note: Replace template variables
    Set result to replace_template_variable(result, "timestamp", 
    format_timestamp(record.timestamp, self.date_format, self.include_milliseconds, self.include_timezone)) Set result to replace_template_variable(result, "level", 
    format_level_padded(record.level, 5)) Set result to replace_template_variable(result, "logger",
    format_logger_name(record.logger_name, 20)) Set result to replace_template_variable(result, "message",
    format_message(record.message, self.max_message_length, self.truncate_indicator)) Set result to replace_template_variable(result, "module", record.module)
    Set result to replace_template_variable(result, "function", record.function)
    Set result to replace_template_variable(result, "line", Integer.to_string(record.line))
    Note: Add metadata if present
    If Collections.length(record.metadata) is greater than 0:
    Set result to replace_template_variable(result, "metadata",
    format_metadata_inline(record.metadata))
    Note: Add trace context if present
    If record.trace_id is not Optional.None:
    Set result to replace_template_variable(result, "trace_id",
    Optional.unwrap(record.trace_id)) If record.span_id is not Optional.None:
    Set result to replace_template_variable(result, "span_id",
    Optional.unwrap(record.span_id))
    Note: Apply custom fields
    For Each field_name in Collections.keys(self.custom_fields):
    Let field_func be Collections.get(self.custom_fields, field_name)
    Let field_value be field_func(record)
    Set result to replace_template_variable(result, field_name, field_value) Return result

Note: JSON Formatter for Structured Logging
Type called "JSONFormatter":
    pretty_print as Boolean
    indent_size as Integer
    include_null_fields as Boolean
    field_names as Dictionary[String, String] // Custom field name mapping
    exclude_fields as Set[String]
    max_depth as Integer
    circular_reference_handling as CircularReferenceStrategy
    nan_inf_handling as NaNInfStrategy
    binary_encoding as BinaryEncodingStrategy

Type CircularReferenceStrategy is
    | ERROR
    | SKIP
    | REFERENCE

Type NaNInfStrategy is
    | ERROR
    | NULL
    | STRING

Type BinaryEncodingStrategy is
    | BASE64
    | HEX
    | SKIP

Process called "create_json_formatter" that returns JSONFormatter:
    Return JSONFormatter with:
    pretty_print as false,
    indent_size as 0,
    include_null_fields as false,
    field_names as create_default_field_mapping(),
    exclude_fields as Set.new(),
    max_depth as 10,
    circular_reference_handling as SKIP,
    nan_inf_handling as NULL,
    binary_encoding as BASE64

Process called "create_pretty_json_formatter" that returns JSONFormatter:
    Return JSONFormatter with:
    pretty_print as true,
    indent_size as 2,
    include_null_fields as true,
    field_names as create_default_field_mapping(),
    exclude_fields as Set.new(),
    max_depth as 20,
    circular_reference_handling as REFERENCE,
    nan_inf_handling as STRING,
    binary_encoding as BASE64

Implement format for JSONFormatter that takes record as LogCore.LogRecord returns String:
    Let json_object be Dictionary.new()
    Note: Core fields
    Set json_object["timestamp"] to record.timestamp
    Set json_object["timestamp_iso"] to DateTime.format_iso8601(record.timestamp)
    Set json_object["level"] to LogCore.level_to_string(record.level)
    Set json_object["level_value"] to LogCore.get_level_value(record.level)
    Set json_object["logger"] to record.logger_name
    Set json_object["message"] to record.message
    Note: Source location
    Let source be Dictionary[
    "module" -> record.module,
    "file" -> record.file,
    "function" -> record.function,
    "line" -> record.line,
    "column" -> record.column
    ]
    Set json_object["source"] to source
    Note: Context
    Set json_object["thread_id"] to record.thread_id
    Set json_object["process_id"] to record.process_id
    Set json_object["hostname"] to record.hostname
    Set json_object["environment"] to record.environment
    Set json_object["version"] to record.version
    Note: Tracing
    If record.trace_id is not Optional.None:
    Set json_object["trace_id"] to Optional.unwrap(record.trace_id)
    If record.span_id is not Optional.None:
    Set json_object["span_id"] to Optional.unwrap(record.span_id)
    If record.parent_span_id is not Optional.None:
    Set json_object["parent_span_id"] to Optional.unwrap(record.parent_span_id)
    Note: Metadata and labels
    If Collections.length(record.metadata) is greater than 0:
    Set json_object["metadata"] to record.metadata
    If Collections.length(record.labels) is greater than 0:
    Set json_object["labels"] to record.labels
    If Collections.length(record.tags) is greater than 0:
    Set json_object["tags"] to Set.to_list(record.tags)
    Note: Performance metrics
    If record.performance_metrics is not Optional.None:
    Set json_object["performance"] to serialize_performance_metrics(
    Optional.unwrap(record.performance_metrics))
    Note: Exception info
    If record.exception_info is not Optional.None:
    Set json_object["exception"] to serialize_exception_info(
    Optional.unwrap(record.exception_info))
    Note: metadata fields
    If record.anomaly_score is not Optional.None:
    Set json_object["anomaly_score"] to Optional.unwrap(record.anomaly_score)
    If record.ml_model_id is not Optional.None:
    Set json_object["ml_model_id"] to Optional.unwrap(record.ml_model_id)
    Note: Remove excluded fields
    For Each field in self.exclude_fields:
    Dictionary.remove(json_object, field)
    Note: Apply field name mapping
    Let remapped be apply_field_name_mapping(json_object, self.field_names)
    Note: Convert to JSON string
    If self.pretty_print:
    Return JSON.stringify_pretty(remapped, self.indent_size)
    Otherwise:
    Return JSON.stringify(remapped)

Note: Colored Console Formatter
Type called "ColoredFormatter":
    base_formatter as Formatter
    color_scheme as ColorScheme
    enable_colors as Boolean
    enable_bold as Boolean
    enable_underline as Boolean
    highlight_errors as Boolean
    highlight_patterns as List[HighlightPattern]

Type called "ColorScheme":
    trace_color as String
    debug_color as String
    info_color as String
    warning_color as String
    error_color as String
    critical_color as String
    timestamp_color as String
    logger_color as String
    message_color as String
    metadata_color as String
    reset_color as String

Type called "HighlightPattern":
    pattern as String // Regex pattern
    color as String
    bold as Boolean
    underline as Boolean

Process called "create_colored_formatter" that returns ColoredFormatter:
    Return ColoredFormatter with:
    base_formatter as create_text_formatter(),
    color_scheme as create_default_color_scheme(),
    enable_colors as is_terminal_tty(),
    enable_bold as true,
    enable_underline as false,
    highlight_errors as true,
    highlight_patterns as create_default_highlight_patterns()

Process called "create_default_color_scheme" that returns ColorScheme:
    Return ColorScheme with:
    trace_color as "\033[90m", // Dark gray
    debug_color as "\033[36m", // Cyan
    info_color as "\033[32m", // Green
    warning_color as "\033[33m", // Yellow
    error_color as "\033[31m", // Red
    critical_color as "\033[35m", // Magenta
    timestamp_color as "\033[94m", // Light blue
    logger_color as "\033[96m", // Light cyan
    message_color as "\033[0m", // Default
    metadata_color as "\033[90m", // Dark gray
    reset_color as "\033[0m" // Reset

Implement format for ColoredFormatter that takes record as LogCore.LogRecord returns String:
    If not self.enable_colors:
    Return self.base_formatter.format(record)
    Note: Get base formatted string
    Let formatted be self.base_formatter.format(record)
    Note: Apply level coloring
    Let level_color be get_level_color(record.level, self.color_scheme)
    Set formatted to String.replace(formatted, 
    "[" + LogCore.level_to_string(record.level) + "]",
    level_color + "[" + LogCore.level_to_string(record.level) + "]" + self.color_scheme.reset_color)
    Note: Apply timestamp coloring
    Set formatted to apply_timestamp_color(formatted, self.color_scheme.timestamp_color)
    Note: Apply logger name coloring
    Set formatted to apply_logger_color(formatted, record.logger_name, self.color_scheme.logger_color)
    Note: Highlight error patterns
    If self.highlight_errors and record.level is greater than or equal to ERROR:
    Set formatted to highlight_error_patterns(formatted, self.color_scheme.error_color)
    Note: Apply custom highlight patterns
    For Each pattern in self.highlight_patterns:
    Set formatted to apply_highlight_pattern(formatted, pattern) Return formatted

Note: XML Formatter for Enterprise Systems
Type called "XMLFormatter":
    root_element as String
    namespace as String
    schema_location as String
    include_cdata as Boolean
    escape_special_chars as Boolean
    indent as Boolean
    indent_size as Integer

Process called "create_xml_formatter" that returns XMLFormatter:
    Return XMLFormatter with:
    root_element as "logRecord",
    namespace as "http://runa.dev/logging/1.0",
    schema_location as "",
    include_cdata as true,
    escape_special_chars as true,
    indent as false,
    indent_size as 2

Implement format for XMLFormatter that takes record as LogCore.LogRecord returns String:
    Let xml be StringBuilder.new()
    Note: Start root element
    StringBuilder.append(xml, "<" + self.root_element)
    If String.length(self.namespace) is greater than 0:
    StringBuilder.append(xml, " xmlns=\"" + self.namespace + "\"")
    StringBuilder.append(xml, ">") If self.indent:
    StringBuilder.append(xml, "\n")
    Note: Add fields
    append_xml_element(xml, "timestamp", DateTime.format_iso8601(record.timestamp), self.indent, 1)
    append_xml_element(xml, "level", LogCore.level_to_string(record.level), self.indent, 1)
    append_xml_element(xml, "logger", record.logger_name, self.indent, 1)
    Note: Message with CDATA if needed
    If self.include_cdata and contains_special_xml_chars(record.message):
    append_xml_cdata(xml, "message", record.message, self.indent, 1)
    Otherwise:
    append_xml_element(xml, "message", escape_xml(record.message), self.indent, 1)
    Note: Source location
    StringBuilder.append(xml, create_indent(1) + "<source>")
    If self.indent:
    StringBuilder.append(xml, "\n")
    append_xml_element(xml, "module", record.module, self.indent, 2)
    append_xml_element(xml, "function", record.function, self.indent, 2)
    append_xml_element(xml, "line", Integer.to_string(record.line), self.indent, 2)
    StringBuilder.append(xml, create_indent(1) + "</source>")
    Note: Close root element
    If self.indent:
    StringBuilder.append(xml, "\n")
    StringBuilder.append(xml, "</" + self.root_element + ">") Return StringBuilder.to_string(xml)

Note: CSV Formatter for Data Analysis
Type called "CSVFormatter":
    delimiter as String
    quote_char as String
    escape_char as String
    include_header as Boolean
    columns as List[String]
    null_value as String
    line_terminator as String

Process called "create_csv_formatter" that returns CSVFormatter:
    Return CSVFormatter with:
    delimiter as ",",
    quote_char as "\"",
    escape_char as "\\",
    include_header as true,
    columns as ["timestamp", "level", "logger", "message", "module", "function", "line"],
    null_value as "",
    line_terminator as "\n"

Implement format for CSVFormatter that takes record as LogCore.LogRecord returns String:
    Let values be List.new() For Each column in self.columns:
    Let value be extract_field_value(record, column)
    Note: Quote if contains delimiter or quotes
    If contains_csv_special_chars(value, self.delimiter, self.quote_char):
    Set value to quote_csv_value(value, self.quote_char, self.escape_char) Add value to values Return String.join(values, self.delimiter) + self.line_terminator

Note: Logstash Formatter for ELK Stack
Type called "LogstashFormatter":
    version as String
    type as String
    tags as List[String]
    extra_fields as Dictionary[String, Any]

Process called "create_logstash_formatter" that returns LogstashFormatter:
    Return LogstashFormatter with:
    version as "1",
    type as "runa",
    tags as List.new(),
    extra_fields as Dictionary.new()

Implement format for LogstashFormatter that takes record as LogCore.LogRecord returns String:
    Let logstash_event be Dictionary[
    "@timestamp" -> DateTime.format_iso8601(record.timestamp),
    "@version" -> self.version,
    "type" -> self.type,
    "host" -> record.hostname,
    "level" -> LogCore.level_to_string(record.level),
    "logger_name" -> record.logger_name,
    "message" -> record.message,
    "thread_name" -> "thread-" + Integer.to_string(record.thread_id),
    "level_value" -> LogCore.get_level_value(record.level),
    "stack_trace" -> If record.stack_trace is Optional.None then null 
    else format_stack_trace_string(Optional.unwrap(record.stack_trace))
    ]
    Note: Add tags
    If Collections.length(self.tags) is greater than 0:
    Set logstash_event["tags"] to self.tags
    Note: Add extra fields
    For Each key in Collections.keys(self.extra_fields):
    Set logstash_event[key] to Collections.get(self.extra_fields, key)
    Note: Add metadata
    If Collections.length(record.metadata) is greater than 0:
    For Each key in Collections.keys(record.metadata):
    Set logstash_event["metadata_" + key] to Collections.get(record.metadata, key) Return JSON.stringify(logstash_event)

Note: CEF (Common Event Format) Formatter for Security
Type called "CEFFormatter":
    device_vendor as String
    device_product as String
    device_version as String
    signature_id as String
    name_template as String
    severity_mapping as Dictionary[LogCore.LogLevel, Integer]

Process called "create_cef_formatter" that returns CEFFormatter:
    Return CEFFormatter with:
    device_vendor as "Runa",
    device_product as "RunaLogger",
    device_version as "1.0",
    signature_id as "100",
    name_template as "{level}: {message}",
    severity_mapping as Dictionary[
    TRACE -> 0,
    DEBUG -> 1,
    INFO -> 3,
    WARNING -> 5,
    ERROR -> 7,
    CRITICAL -> 9,
    FATAL -> 10,
    EMERGENCY -> 10
    ]

Implement format for CEFFormatter that takes record as LogCore.LogRecord returns String:
    Let cef_header be "CEF:0|" + 
    self.device_vendor + "|" +
    self.device_product + "|" +
    self.device_version + "|" +
    self.signature_id + "|" +
    format_cef_name(record, self.name_template) + "|" +
    Integer.to_string(Collections.get(self.severity_mapping, record.level)) + "|"
    Note: Add extension fields
    Let extensions be List[
    "msg=" + escape_cef_value(record.message),
    "src=" + record.hostname,
    "act=" + record.function,
    "cs1Label=Logger",
    "cs1=" + record.logger_name
    ] If record.user_id is not Optional.None:
    Add "suser=" + escape_cef_value(Optional.unwrap(record.user_id)) to extensions If record.ip_address is not Optional.None:
    Add "src=" + Optional.unwrap(record.ip_address) to extensions Return cef_header + String.join(extensions, " ")

Note: GELF (Graylog Extended Log Format) Formatter
Type called "GELFFormatter":
    version as String
    host as String
    facility as String
    include_stack_trace as Boolean
    include_source_location as Boolean
    max_short_message_length as Integer

Process called "create_gelf_formatter" that returns GELFFormatter:
    Return GELFFormatter with:
    version as "1.1",
    host as get_hostname(),
    facility as "runa",
    include_stack_trace as true,
    include_source_location as true,
    max_short_message_length as 120

Implement format for GELFFormatter that takes record as LogCore.LogRecord returns String:
    Let gelf_message be Dictionary[
    "version" -> self.version,
    "host" -> self.host,
    "timestamp" -> record.timestamp,
    "level" -> map_to_syslog_level(record.level),
    "facility" -> self.facility,
    "short_message" -> truncate_message(record.message, self.max_short_message_length),
    "full_message" -> record.message
    ]
    Note: Add source location
    If self.include_source_location:
    Set gelf_message["_file"] to record.file
    Set gelf_message["_line"] to record.line
    Set gelf_message["_function"] to record.function
    Note: Add custom fields (prefixed with underscore)
    For Each key in Collections.keys(record.metadata):
    Set gelf_message["_" + key] to Collections.get(record.metadata, key)
    Note: Add stack trace if present
    If self.include_stack_trace and record.stack_trace is not Optional.None:
    Set gelf_message["_stack_trace"] to format_stack_trace_string(
    Optional.unwrap(record.stack_trace)) Return JSON.stringify(gelf_message)

Note: Helper Functions
Process called "replace_template_variable" that takes template as String and variable as String and value as String returns String:
Note: Handle both {var} and {var:width} formats
    Let pattern be "\\{" + variable + "(:[0-9]+)?\\}"
    Return String.replace_regex(template, pattern, value)

Process called "format_level_padded" that takes level as LogCore.LogLevel and width as Integer returns String:
    Let level_str be LogCore.level_to_string(level)
    Return String.pad_right(level_str, width)

Process called "format_logger_name" that takes name as String and max_width as Integer returns String:
    If max_width is less than or equal to 0:
    Return name If String.length(name) is less than or equal to max_width:
    Return String.pad_right(name, max_width)
    Note: Truncate with ellipsis
    Return String.substring(name, 0, max_width - 3) + "..."

Process called "format_message" that takes message as String and max_length as Integer and truncate_indicator as String returns String:
    If max_length is less than or equal to 0 or String.length(message) is less than or equal to max_length:
    Return message Let truncate_at be max_length - String.length(truncate_indicator)
    Return String.substring(message, 0, truncate_at) + truncate_indicator

Process called "format_metadata_inline" that takes metadata as Dictionary[String, Any] returns String:
    Let pairs be List.new() For Each key in Collections.keys(metadata):
    Let value be Collections.get(metadata, key)
    Add key + "=" + format_metadata_value(value) to pairs Return "{" + String.join(pairs, ", ") + "}"

Process called "format_metadata_value" that takes value as Any returns String:
    If value is String:
    Return "\"" + escape_string(value) + "\""
    Otherwise if value is Integer or value is Float:
    Return value.to_string()
    Otherwise if value is Boolean:
    Return If value then "true" else "false"
    Otherwise if value is List:
    Return "[" + format_list_values(value) + "]"
    Otherwise if value is Dictionary:
    Return format_metadata_inline(value)
    Otherwise:
    Return "null"

Process called "serialize_performance_metrics" that takes metrics as LogCore.PerformanceMetrics returns Dictionary[String, Any]:
    Return Dictionary[
    "duration_ms" -> metrics.duration_ms,
    "cpu_time_ms" -> metrics.cpu_time_ms,
    "wall_time_ms" -> metrics.wall_time_ms,
    "wait_time_ms" -> metrics.wait_time_ms,
    "io_time_ms" -> metrics.io_time_ms,
    "cache_hits" -> metrics.cache_hits,
    "cache_misses" -> metrics.cache_misses,
    "operations_count" -> metrics.operations_count
    ]

Process called "serialize_exception_info" that takes info as LogCore.ExceptionInfo returns Dictionary[String, Any]:
    Let result be Dictionary[
    "type" -> info.exception_type,
    "message" -> info.exception_message,
    "details" -> info.exception_details
    ] If Collections.length(info.inner_exceptions) is greater than 0:
    Let inner_list be List.new()
    For Each inner in info.inner_exceptions:
    Add serialize_exception_info(inner) to inner_list
    Set result["inner_exceptions"] to inner_list Return result

Process called "is_terminal_tty" that returns Boolean:
Note: Check if output is going to a terminal
    Return IO.is_tty(IO.stdout()) or IO.is_tty(IO.stderr())

Process called "escape_xml" that takes text as String returns String:
    Let result be text
    Set result to String.replace(result, "&", "&amp;")
    Set result to String.replace(result, "<", "&lt;")
    Set result to String.replace(result, ">", "&gt;")
    Set result to String.replace(result, "\"", "&quot;")
    Set result to String.replace(result, "'", "&apos;")
    Return result

Process called "escape_cef_value" that takes value as String returns String:
    Let result be value
    Set result to String.replace(result, "\\", "\\\\")
    Set result to String.replace(result, "=", "\\=")
    Set result to String.replace(result, "\n", "\\n")
    Set result to String.replace(result, "\r", "\\r")
    Return result