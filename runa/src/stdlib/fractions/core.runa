Note: Fractions Core Module
Note: Foundational types, utilities and mathematical foundations for rational arithmetic
Note: This module contains core types, GCD/LCM algorithms, and basic fraction utilities
:End Note

Import "decimal/decimal" as decimal_module
Import "decimal/context" as decimal_context
Import "math/core" as math_module
Import "errors/errors" as error_handling

Note: Core Types

Type FractionResult is:
    | FractionSuccess with value as Fraction
    | FractionError with message as String and code as String

Type Fraction is Dictionary with:
    numerator as Integer
    denominator as Integer
    metadata as Dictionary[String, String]

Type FractionFormat is:
    | DECIMAL
    | RATIONAL  
    | MIXED
    | SCIENTIFIC

Note: Core Mathematical Utilities

Process greatest_common_divisor with a as Integer and b as Integer:
    Note: Euclidean algorithm for GCD computation
    Let abs_a be absolute_value with value as a
    Let abs_b be absolute_value with value as b
    
    If abs_a is equal to 0:
        Return abs_b
    If abs_b is equal to 0:
        Return abs_a
    
    While abs_b is not equal to 0:
        Let remainder be abs_a modulo abs_b
        Set abs_a to abs_b
        Set abs_b to remainder
    
    Return abs_a

Process least_common_multiple with a as Integer and b as Integer:
    Note: LCM using identity: lcm(a,b) = |a*b| / gcd(a,b)
    Let abs_a be absolute_value with value as a
    Let abs_b be absolute_value with value as b
    
    If abs_a is equal to 0 or abs_b is equal to 0:
        Return 0
    
    Let gcd_value be greatest_common_divisor with a as abs_a and b as abs_b
    Let product be abs_a multiplied by abs_b
    Return product divided by gcd_value

Process absolute_value with value as Integer:
    If value is less than 0:
        Return negative value
    Otherwise:
        Return value

Process integer_square_root with value as Integer:
    Note: Newton's method for exact integer square root
    If value is less than 0:
        Return null
    
    If value is equal to 0 or value is equal to 1:
        Return value
    
    Let x be value divided by 2
    Let prev_x be x plus 1
    
    While x is less than prev_x:
        Set prev_x to x
        Set x to (x plus (value divided by x)) divided by 2
    
    If prev_x multiplied by prev_x is equal to value:
        Return prev_x
    Otherwise:
        Return null

Process integer_cube_root with value as Integer:
    Note: Newton's method for exact integer cube root
    If value is equal to 0 or value is equal to 1:
        Return value
    
    Let abs_value be absolute_value with value as value
    Let x be abs_value divided by 3
    Let prev_x be x plus 1
    
    While x is less than prev_x:
        Set prev_x to x
        Set x to (2 multiplied by x plus (abs_value divided by (x multiplied by x))) divided by 3
    
    If prev_x multiplied by prev_x multiplied by prev_x is equal to abs_value:
        If value is less than 0:
            Return negative prev_x
        Otherwise:
            Return prev_x
    Otherwise:
        Return null

Note: String and Parsing Utilities

Process parse_fraction_string with input as String:
    Let trimmed be trim_whitespace with string as input
    Let parts be split_string with string as trimmed and delimiter as "/"
    
    If list_utils.get_length with list as parts is equal to 2:
        Let numerator_str be list_utils.get_item with list as parts and index as 0
        Let denominator_str be list_utils.get_item with list as parts and index as 1
        
        Let numerator be parse_integer with string as numerator_str  
        Let denominator be parse_integer with string as denominator_str
        
        If numerator is not equal to null and denominator is not equal to null:
            Return FractionSuccess with value as (numerator, denominator)
        Otherwise:
            Return FractionError with message as "Invalid number format" and code as "INVALID_FORMAT"
    Otherwise:
        Return FractionError with message as "Invalid fraction format" and code as "INVALID_FORMAT"

Process parse_integer with string as String:
    Let trimmed be trim_whitespace with string as string
    If string_utils.get_length with string as trimmed is equal to 0:
        Return null
    
    Let result be 0
    Let sign be 1
    Let start_index be 0
    
    If string_utils.character_at with string as trimmed and index as 0 is equal to "-":
        Set sign to negative 1
        Set start_index to 1
    Otherwise If string_utils.character_at with string as trimmed and index as 0 is equal to "+":
        Set start_index to 1
    
    For i from start_index to string_utils.get_length with string as trimmed minus 1:
        Let char be string_utils.character_at with string as trimmed and index as i
        If string_utils.is_digit with char as char:
            Let digit_value be string_utils.char_to_digit with char as char
            Set result to result multiplied by 10 plus digit_value
        Otherwise:
            Return null
    
    Return result multiplied by sign

Process trim_whitespace with string as String:
    Let start_index be 0
    Let end_index be string_utils.get_length with string as string
    
    While start_index is less than end_index:
        Let char be string_utils.character_at with string as string and index as start_index
        If not string_utils.is_whitespace with char as char:
            Break
        Set start_index to start_index plus 1
    
    While end_index is greater than start_index:
        Let char be string_utils.character_at with string as string and index as end_index minus 1
        If not string_utils.is_whitespace with char as char:
            Break
        Set end_index to end_index minus 1
    
    If start_index is greater than or equal to end_index:
        Return ""
    
    Return string_utils.substring_range with string as string and start as start_index and end as end_index

Process split_string with string as String and delimiter as String:
    If string_utils.get_length with string as delimiter is equal to 0:
        Return list_utils.create_list_with_items with items as [string]
    
    Let result be list_utils.create_empty_list
    Let current_part be ""
    Let i be 0
    Let string_length be string_utils.get_length with string as string
    Let delimiter_length be string_utils.get_length with string as delimiter
    
    While i is less than string_length:
        Let matches_delimiter be true
        
        For j from 0 to delimiter_length minus 1:
            If i plus j is greater than or equal to string_length:
                Set matches_delimiter to false
                Break
            If string_utils.character_at with string as string and index as i plus j is not equal to string_utils.character_at with string as delimiter and index as j:
                Set matches_delimiter to false
                Break
        
        If matches_delimiter:
            Call list_utils.append with list as result and item as current_part
            Set current_part to ""
            Set i to i plus delimiter_length
        Otherwise:
            Set current_part to string_utils.concatenate with strings as [current_part, string_utils.character_at with string as string and index as i]
            Set i to i plus 1
    
    Call list_utils.append with list as result and item as current_part
    Return result

Note: Decimal Conversion Utilities

Process decimal_to_rational with decimal_value as Float and max_precision as Integer:
    Note: Convert decimal to rational using continued fractions
    Let tolerance be 1.0 divided by (10 to the power of max_precision)
    Let continued_fraction be compute_continued_fraction with value as decimal_value and max_terms as max_precision
    
    Let numerator be 0
    Let denominator be 1
    Let prev_numerator be 1
    Let prev_denominator be 0
    
    For Each term in continued_fraction:
        Let new_numerator be term multiplied by numerator plus prev_numerator
        Let new_denominator be term multiplied by denominator plus prev_denominator
        
        Set prev_numerator to numerator
        Set prev_denominator to denominator
        Set numerator to new_numerator
        Set denominator to new_denominator
        
        Let approximation be numerator divided by denominator
        If math_module.absolute with value as approximation minus decimal_value is less than tolerance:
            Break
    
    Return (numerator, denominator)

Process compute_continued_fraction with value as Float and max_terms as Integer:
    Let result be list_utils.create_empty_list
    Let x be value
    Let terms_count be 0
    
    While terms_count is less than max_terms and x is not equal to 0.0:
        Let integer_part be math_module.floor with value as x
        Call list_utils.append with list as result and item as integer_part
        Set terms_count to terms_count plus 1
        
        Let fractional_part be x minus integer_part
        If fractional_part is less than 0.000001:
            Break
        
        Set x to 1.0 divided by fractional_part
    
    Return result

Note: Formatting Utilities

Process format_decimal with value as Float:
    If value is equal to 0.0:
        Return "0.0"
    If math_module.is_infinite with value as value or math_module.is_nan with value as value:
        Return "invalid"
    
    Let abs_value be math_module.absolute with value as value
    Let sign_prefix be ""
    If value is less than 0.0:
        Set sign_prefix to "-"
    
    Let decimal_places be determine_decimal_places with value as abs_value
    Let formatted be math_module.format_float with value as abs_value and precision as decimal_places
    
    Return string_utils.concatenate with strings as [sign_prefix, formatted]

Process format_scientific with value as Float:
    If value is equal to 0.0:
        Return "0.0e+00"
    If math_module.is_infinite with value as value or math_module.is_nan with value as value:
        Return "invalid"
    
    Let abs_value be math_module.absolute with value as value
    Let sign_prefix be ""
    If value is less than 0.0:
        Set sign_prefix to "-"
    
    Let exponent be 0
    Let mantissa be abs_value
    
    While mantissa is greater than or equal to 10.0:
        Set mantissa to mantissa divided by 10.0
        Set exponent to exponent plus 1
    While mantissa is less than 1.0 and mantissa is greater than 0.0:
        Set mantissa to mantissa multiplied by 10.0
        Set exponent to exponent minus 1
    
    Let mantissa_str be math_module.format_float with value as mantissa and precision as 6
    Let exponent_sign be "+"
    If exponent is less than 0:
        Set exponent_sign to "-"
        Set exponent to negative exponent
    
    Let exponent_str be string_utils.pad_integer with value as exponent and width as 2
    
    Return string_utils.concatenate with strings as [sign_prefix, mantissa_str, "e", exponent_sign, exponent_str]

Process determine_decimal_places with value as Float:
    Let abs_value be math_module.absolute with value as value
    
    If abs_value is greater than or equal to 1.0:
        Return 6
    Otherwise If abs_value is greater than or equal to 0.1:
        Return 8
    Otherwise If abs_value is greater than or equal to 0.01:
        Return 10
    Otherwise:
        Return 12

Note: System Integration Utilities

Process get_current_timestamp:
    Return datetime_module.get_timestamp

Process create_metadata_dict:
    Return dict_utils.create_empty_dict