Note: Fractions Operations Module  
Note: Complete arithmetic operations for rational numbers with mathematical correctness
Note: Provides all basic and advanced operations: +, -, *, /, ^, comparisons, and advanced math
:End Note

Import "fractions/core" as core
Import "decimal/decimal" as decimal_module  
Import "math/core" as math_module
Import "collections/list" as list_utils
Import "collections/dict" as dict_utils
Import "string/format" as string_utils

Note: Arithmetic Operations

Process add with a as core.Fraction and b as core.Fraction:
    Note: Add two fractions: a/b + c/d = (a*d + c*b) / (b*d)
    Let numerator be a.numerator multiplied by b.denominator plus b.numerator multiplied by a.denominator
    Let denominator be a.denominator multiplied by b.denominator
    
    Return create_fraction with numerator as numerator and denominator as denominator

Process subtract with a as core.Fraction and b as core.Fraction:
    Note: Subtract two fractions: a/b - c/d = (a*d - c*b) / (b*d)
    Let numerator be a.numerator multiplied by b.denominator minus b.numerator multiplied by a.denominator
    Let denominator be a.denominator multiplied by b.denominator
    
    Return create_fraction with numerator as numerator and denominator as denominator

Process multiply with a as core.Fraction and b as core.Fraction:
    Note: Multiply two fractions: (a/b) * (c/d) = (a*c) / (b*d)
    Let numerator be a.numerator multiplied by b.numerator
    Let denominator be a.denominator multiplied by b.denominator
    
    Return create_fraction with numerator as numerator and denominator as denominator

Process divide with a as core.Fraction and b as core.Fraction:
    Note: Divide two fractions: (a/b) / (c/d) = (a/b) * (d/c)
    If b.numerator is equal to 0:
        Return core.FractionError with message as "Division by zero" and code as "DIVISION_BY_ZERO"
    
    Let numerator be a.numerator multiplied by b.denominator
    Let denominator be a.denominator multiplied by b.numerator
    
    Return create_fraction with numerator as numerator and denominator as denominator

Process power with base as core.Fraction and exponent as Integer:
    Note: Raise fraction to integer power: (a/b)^n = a^n / b^n
    If exponent is equal to 0:
        Return create_fraction with numerator as 1 and denominator as 1
    Otherwise If exponent is equal to 1:
        Return core.FractionSuccess with value as base
    Otherwise If exponent is greater than 0:
        Let numerator be math_module.integer_power with base as base.numerator and exponent as exponent
        Let denominator be math_module.integer_power with base as base.denominator and exponent as exponent
        Return create_fraction with numerator as numerator and denominator as denominator
    Otherwise:
        Note: Negative exponent: (a/b)^(-n) = (b/a)^n
        Let positive_exponent be negative exponent
        If base.numerator is equal to 0:
            Return core.FractionError with message as "Division by zero in negative power" and code as "DIVISION_BY_ZERO"
        Let numerator be math_module.integer_power with base as base.denominator and exponent as positive_exponent
        Let denominator be math_module.integer_power with base as base.numerator and exponent as positive_exponent
        Return create_fraction with numerator as numerator and denominator as denominator

Process negate with fraction as core.Fraction:
    Note: Negate a fraction: -(a/b) = (-a)/b
    Return core.Fraction with:
        numerator as negative fraction.numerator and
        denominator as fraction.denominator and
        metadata as fraction.metadata

Process reciprocal with fraction as core.Fraction:
    Note: Calculate reciprocal: 1/(a/b) = b/a
    If fraction.numerator is equal to 0:
        Return core.FractionError with message as "Cannot compute reciprocal of zero" and code as "ZERO_RECIPROCAL"
    
    Return create_fraction with numerator as fraction.denominator and denominator as fraction.numerator

Process modulo with a as core.Fraction and b as core.Fraction:
    Note: Modulo operation: a mod b = a - floor(a/b) * b
    Let division_result be divide with a as a and b as b
    Match division_result:
        When core.FractionSuccess with value as quotient:
            Let floor_quotient be math_module.floor with value as to_decimal with fraction as quotient
            Let floor_fraction be create_fraction with numerator as floor_quotient and denominator as 1
            Match floor_fraction:
                When core.FractionSuccess with value as floor_frac:
                    Let product be multiply with a as floor_frac and b as b
                    Match product:
                        When core.FractionSuccess with value as product_frac:
                            Return subtract with a as a and b as product_frac
                        Otherwise:
                            Return product
                Otherwise:
                    Return floor_fraction
        Otherwise:
            Return division_result

Note: Comparison Operations  

Process is_equal with a as core.Fraction and b as core.Fraction:
    Note: Check equality by cross multiplication: a/b = c/d iff a*d = b*c
    Let simplified_a be simplify_fraction with fraction as a
    Let simplified_b be simplify_fraction with fraction as b
    
    Match simplified_a:
        When core.FractionSuccess with value as a_simplified:
            Match simplified_b:
                When core.FractionSuccess with value as b_simplified:
                    Return a_simplified.numerator is equal to b_simplified.numerator and a_simplified.denominator is equal to b_simplified.denominator
                Otherwise:
                    Return false
        Otherwise:
            Return false

Process is_less_than with a as core.Fraction and b as core.Fraction:
    Note: Compare fractions: a/b < c/d iff (a*d - b*c) * (b*d) < 0
    Let cross_product be a.numerator multiplied by b.denominator minus b.numerator multiplied by a.denominator
    Let denominator_product be a.denominator multiplied by b.denominator
    Return cross_product multiplied by denominator_product is less than 0

Process is_greater_than with a as core.Fraction and b as core.Fraction:
    Return is_less_than with a as b and b as a

Process is_less_than_or_equal with a as core.Fraction and b as core.Fraction:
    Return is_less_than with a as a and b as b or is_equal with a as a and b as b

Process is_greater_than_or_equal with a as core.Fraction and b as core.Fraction:
    Return is_greater_than with a as a and b as b or is_equal with a as a and b as b

Process compare with a as core.Fraction and b as core.Fraction:
    Note: Three-way comparison: -1 if a < b, 0 if a = b, 1 if a > b
    If is_equal with a as a and b as b:
        Return 0
    Otherwise If is_less_than with a as a and b as b:
        Return -1
    Otherwise:
        Return 1

Note: Advanced Mathematical Functions

Process square_root with fraction as core.Fraction:
    Note: Calculate exact square root if possible: sqrt(a/b) = sqrt(a)/sqrt(b)
    If is_negative with fraction as fraction:
        Return core.FractionError with message as "Cannot compute square root of negative number" and code as "NEGATIVE_SQUARE_ROOT"
    
    If is_zero with fraction as fraction:
        Return create_fraction with numerator as 0 and denominator as 1
    
    Let numerator_sqrt be core.integer_square_root with value as fraction.numerator
    Let denominator_sqrt be core.integer_square_root with value as fraction.denominator
    
    If numerator_sqrt is not equal to null and denominator_sqrt is not equal to null:
        Return create_fraction with numerator as numerator_sqrt and denominator as denominator_sqrt
    Otherwise:
        Return core.FractionError with message as "Cannot compute exact square root" and code as "IRRATIONAL_RESULT"

Process cube_root with fraction as core.Fraction:
    Note: Calculate exact cube root if possible: cbrt(a/b) = cbrt(a)/cbrt(b)  
    If is_zero with fraction as fraction:
        Return create_fraction with numerator as 0 and denominator as 1
    
    Let numerator_cbrt be core.integer_cube_root with value as fraction.numerator
    Let denominator_cbrt be core.integer_cube_root with value as fraction.denominator
    
    If numerator_cbrt is not equal to null and denominator_cbrt is not equal to null:
        Return create_fraction with numerator as numerator_cbrt and denominator as denominator_cbrt
    Otherwise:
        Return core.FractionError with message as "Cannot compute exact cube root" and code as "IRRATIONAL_RESULT"

Process factorial with fraction as core.Fraction:
    Note: Factorial only defined for non-negative integers
    If not is_integer with fraction as fraction:
        Return core.FractionError with message as "Factorial is only defined for integers" and code as "NON_INTEGER_FACTORIAL"
    
    If is_negative with fraction as fraction:
        Return core.FractionError with message as "Factorial is not defined for negative numbers" and code as "NEGATIVE_FACTORIAL"
    
    Let n be fraction.numerator
    If n is equal to 0 or n is equal to 1:
        Return create_fraction with numerator as 1 and denominator as 1
    
    Let result be 1
    For i from 2 to n:
        Set result to result multiplied by i
    
    Return create_fraction with numerator as result and denominator as 1

Process fraction_gcd with a as core.Fraction and b as core.Fraction:
    Note: GCD of fractions: gcd(a/b, c/d) = gcd(a,c) / lcm(b,d)
    Let gcd_numerator be core.greatest_common_divisor with a as a.numerator and b as b.numerator
    Let lcm_denominator be core.least_common_multiple with a as a.denominator and b as b.denominator
    
    Return create_fraction with numerator as gcd_numerator and denominator as lcm_denominator

Process fraction_lcm with a as core.Fraction and b as core.Fraction:
    Note: LCM of fractions: lcm(a/b, c/d) = lcm(a,c) / gcd(b,d)
    Let lcm_numerator be core.least_common_multiple with a as a.numerator and b as b.numerator
    Let gcd_denominator be core.greatest_common_divisor with a as a.denominator and b as b.denominator
    
    Return create_fraction with numerator as lcm_numerator and denominator as gcd_denominator

Note: Utility Operations

Process absolute_value with fraction as core.Fraction:
    Note: Absolute value: |a/b| = |a|/|b|
    Return core.Fraction with:
        numerator as core.absolute_value with value as fraction.numerator and
        denominator as core.absolute_value with value as fraction.denominator and
        metadata as fraction.metadata

Process floor with fraction as core.Fraction:
    Note: Floor function: floor(a/b) = floor division of a by b
    If fraction.numerator is greater than or equal to 0:
        Return fraction.numerator divided by fraction.denominator
    Otherwise:
        Let quotient be fraction.numerator divided by fraction.denominator
        Let remainder be fraction.numerator modulo fraction.denominator
        If remainder is not equal to 0:
            Return quotient minus 1
        Otherwise:
            Return quotient

Process ceiling with fraction as core.Fraction:
    Note: Ceiling function: ceil(a/b) 
    If fraction.numerator is less than or equal to 0:
        Return fraction.numerator divided by fraction.denominator
    Otherwise:
        Let quotient be fraction.numerator divided by fraction.denominator
        Let remainder be fraction.numerator modulo fraction.denominator
        If remainder is not equal to 0:
            Return quotient plus 1
        Otherwise:
            Return quotient

Process round with fraction as core.Fraction:
    Note: Round to nearest integer using round-half-to-even
    Let decimal_value be to_decimal with fraction as fraction
    Return math_module.round with value as decimal_value

Process truncate with fraction as core.Fraction:
    Note: Truncate towards zero
    If fraction.numerator is greater than or equal to 0:
        Return floor with fraction as fraction
    Otherwise:
        Return ceiling with fraction as fraction

Note: Property Checks

Process is_proper with fraction as core.Fraction:
    Note: Proper fraction: |numerator| < |denominator|
    Return core.absolute_value with value as fraction.numerator is less than core.absolute_value with value as fraction.denominator

Process is_improper with fraction as core.Fraction:
    Return not is_proper with fraction as fraction

Process is_unit with fraction as core.Fraction:
    Note: Unit fraction: |numerator| = 1
    Return core.absolute_value with value as fraction.numerator is equal to 1

Process is_zero with fraction as core.Fraction:
    Return fraction.numerator is equal to 0

Process is_positive with fraction as core.Fraction:
    Return fraction.numerator multiplied by fraction.denominator is greater than 0

Process is_negative with fraction as core.Fraction:  
    Return fraction.numerator multiplied by fraction.denominator is less than 0

Process is_integer with fraction as core.Fraction:
    Return fraction.denominator is equal to 1 or fraction.numerator modulo fraction.denominator is equal to 0

Note: Helper Functions

Process create_fraction with numerator as Integer and denominator as Integer:
    If denominator is equal to 0:
        Return core.FractionError with message as "Denominator cannot be zero" and code as "ZERO_DENOMINATOR"
    
    Let normalized be normalize_sign with numerator as numerator and denominator as denominator
    Let simplified be simplify_fraction_values with numerator as normalized.numerator and denominator as normalized.denominator
    
    Return core.FractionSuccess with value as core.Fraction with:
        numerator as simplified.numerator and
        denominator as simplified.denominator and
        metadata as core.create_metadata_dict

Process simplify_fraction with fraction as core.Fraction:
    If fraction.numerator is equal to 0:
        Return core.FractionSuccess with value as core.Fraction with:
            numerator as 0 and
            denominator as 1 and
            metadata as fraction.metadata
    
    Let gcd_value be core.greatest_common_divisor with a as core.absolute_value with value as fraction.numerator and b as core.absolute_value with value as fraction.denominator
    
    If gcd_value is equal to 1:
        Return core.FractionSuccess with value as fraction
    
    Let simplified_numerator be fraction.numerator divided by gcd_value
    Let simplified_denominator be fraction.denominator divided by gcd_value
    
    Let metadata be dict_utils.copy_dict with dict as fraction.metadata
    Call dict_utils.set_value with dict as metadata and key as "simplified" and value as "true"
    Call dict_utils.set_value with dict as metadata and key as "gcd_used" and value as string_utils.integer_to_string with value as gcd_value
    
    Return core.FractionSuccess with value as core.Fraction with:
        numerator as simplified_numerator and
        denominator as simplified_denominator and
        metadata as metadata

Process simplify_fraction_values with numerator as Integer and denominator as Integer:
    Let gcd_value be core.greatest_common_divisor with a as core.absolute_value with value as numerator and b as core.absolute_value with value as denominator
    
    Return (numerator divided by gcd_value, denominator divided by gcd_value)

Process normalize_sign with numerator as Integer and denominator as Integer:
    Note: Ensure denominator is positive (move sign to numerator)
    If denominator is less than 0:
        Return (negative numerator, negative denominator)
    Otherwise:
        Return (numerator, denominator)

Process to_decimal with fraction as core.Fraction:
    Note: Convert fraction to decimal approximation
    Return fraction.numerator divided by fraction.denominator

Process to_mixed_number with fraction as core.Fraction:
    Note: Convert improper fraction to mixed number
    Let whole_part be floor with fraction as fraction  
    Let remainder_numerator be core.absolute_value with value as fraction.numerator modulo core.absolute_value with value as fraction.denominator
    
    If fraction.numerator is less than 0 and remainder_numerator is not equal to 0:
        Set whole_part to whole_part minus 1
        Set remainder_numerator to core.absolute_value with value as fraction.denominator minus remainder_numerator
    
    Let remainder_fraction be create_fraction with numerator as remainder_numerator and denominator as fraction.denominator
    
    Match remainder_fraction:
        When core.FractionSuccess with value as remainder:
            Return (whole_part, remainder)
        Otherwise:
            Let zero_fraction be create_fraction with numerator as 0 and denominator as 1
            Match zero_fraction:
                When core.FractionSuccess with value as zero:
                    Return (whole_part, zero)
                Otherwise:
                    Return (whole_part, core.Fraction with numerator as 0 and denominator as 1 and metadata as core.create_metadata_dict)