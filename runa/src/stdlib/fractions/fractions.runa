Note: Fractions Module
Note: High-level API for rational number arithmetic with comprehensive features
Note: Provides creation, conversion, formatting, and AI-friendly interfaces
:End Note

Import "fractions/core" as core
Import "fractions/operations" as ops
Import "decimal/decimal" as decimal_module
Import "collections/list" as list_utils
Import "collections/dict" as dict_utils
Import "string/format" as string_utils
Import "datetime/datetime" as datetime_module

Note: Public Creation Functions

Process create_fraction with numerator as Integer and denominator as Integer:
    Return ops.create_fraction with numerator as numerator and denominator as denominator

Process from_decimal with decimal_value as Float:
    Return from_decimal_with_precision with decimal_value as decimal_value and max_precision as 1000

Process from_decimal_with_precision with decimal_value as Float and max_precision as Integer:
    If math_module.is_infinite with value as decimal_value or math_module.is_nan with value as decimal_value:
        Return core.FractionError with message as "Cannot convert non-finite value to fraction" and code as "NON_FINITE_VALUE"
    
    Let rational_pair be core.decimal_to_rational with decimal_value as decimal_value and max_precision as max_precision
    Let numerator be rational_pair[0]
    Let denominator be rational_pair[1]
    
    Return ops.create_fraction with numerator as numerator and denominator as denominator

Process from_string with string_value as String:
    Let parsed be core.parse_fraction_string with input as string_value
    Match parsed:
        When core.FractionSuccess with value as pair:
            Let numerator be pair[0]
            Let denominator be pair[1]
            Return ops.create_fraction with numerator as numerator and denominator as denominator
        Otherwise:
            Return parsed

Process zero:
    Let result be ops.create_fraction with numerator as 0 and denominator as 1
    Match result:
        When core.FractionSuccess with value as fraction:
            Let metadata be dict_utils.copy_dict with dict as fraction.metadata
            Call dict_utils.set_value with dict as metadata and key as "special" and value as "zero"
            Return core.Fraction with:
                numerator as 0 and
                denominator as 1 and
                metadata as metadata
        Otherwise:
            Return core.Fraction with:
                numerator as 0 and
                denominator as 1 and
                metadata as core.create_metadata_dict

Process one:
    Let result be ops.create_fraction with numerator as 1 and denominator as 1
    Match result:
        When core.FractionSuccess with value as fraction:
            Let metadata be dict_utils.copy_dict with dict as fraction.metadata
            Call dict_utils.set_value with dict as metadata and key as "special" and value as "one"
            Return core.Fraction with:
                numerator as 1 and
                denominator as 1 and
                metadata as metadata
        Otherwise:
            Return core.Fraction with:
                numerator as 1 and
                denominator as 1 and
                metadata as core.create_metadata_dict

Process negative_one:
    Let result be ops.create_fraction with numerator as negative 1 and denominator as 1  
    Match result:
        When core.FractionSuccess with value as fraction:
            Let metadata be dict_utils.copy_dict with dict as fraction.metadata
            Call dict_utils.set_value with dict as metadata and key as "special" and value as "negative_one"
            Return core.Fraction with:
                numerator as negative 1 and
                denominator as 1 and
                metadata as metadata
        Otherwise:
            Return core.Fraction with:
                numerator as negative 1 and
                denominator as 1 and
                metadata as core.create_metadata_dict

Note: Arithmetic Operations (Public Interface)

Process add with a as core.Fraction and b as core.Fraction:
    Return ops.add with a as a and b as b

Process subtract with a as core.Fraction and b as core.Fraction:
    Return ops.subtract with a as a and b as b

Process multiply with a as core.Fraction and b as core.Fraction:
    Return ops.multiply with a as a and b as b

Process divide with a as core.Fraction and b as core.Fraction:
    Return ops.divide with a as a and b as b

Process power with base as core.Fraction and exponent as Integer:
    Return ops.power with base as base and exponent as exponent

Process negate with fraction as core.Fraction:
    Return ops.negate with fraction as fraction

Process reciprocal with fraction as core.Fraction:
    Return ops.reciprocal with fraction as fraction

Process modulo with a as core.Fraction and b as core.Fraction:
    Return ops.modulo with a as a and b as b

