    execution_time_ns as 5000000
    cpu_cycles as 10000000
    instruction_count as 5000000
    cache_miss_count as 100000
    branch_misprediction_count as 50000
    page_fault_count as 10
    context_switch_count as 5
    system_call_count as 20
    lock_wait_time_ns as 100000
    io_wait_time_ns as 200000
    gc_time_ns as 50000
    metadata as dictionary containing

