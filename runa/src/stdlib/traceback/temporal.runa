Type called "PerformanceSnapshot":
            snapshot_id as String
            timestamp_ns as Integer
            cpu_utilization_percent as Float
            memory_usage_bytes as Integer
            active_threads as Integer
            pending_io_operations as Integer
            cache_hit_rates as Dictionary[String, Float]
            system_load_average as Float
            temporal_anomalies as List[TemporalAnomaly]
            metadata as Dictionary[String, Any]

Type called "TemporalAnomaly":
            anomaly_id as String
            detection_time_ns as Integer
            anomaly_type as AnomalyType
            severity as AnomalySeverity
            affected_functions as List[String]
            timing_deviation_ns as Integer
            expected_duration_ns as Integer
            actual_duration_ns as Integer
            root_cause_analysis as String
            suggested_actions as List[String]
