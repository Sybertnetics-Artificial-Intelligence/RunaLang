Type called "SynchronizationEvent":
            event_id as String
            timestamp_ns as Integer
            sync_type as SynchronizationType
            sync_object_id as String
            operation as SyncOperation
            thread_id as Integer
            wait_time_ns as Integer
            blocking_thread_id as Integer
            metadata as Dictionary[String, Any]

Type SynchronizationType is:
            | Mutex
            | Semaphore
            | Condition
            | ReadWriteLock
            | Barrier

Type SyncOperation is:
            | Acquire
            | Release
            | TryAcquire
            | Wait
            | Signal

Type called "TemporalBreakpoint":
            breakpoint_id as String
            temporal_condition as TemporalCondition
            trigger_time_ns as Integer
            duration_condition as DurationCondition
            frequency_condition as FrequencyCondition
            is_active as Boolean
            hit_count as Integer
            last_triggered_time_ns as Integer
            actions as List[TemporalAction]
            metadata as Dictionary[String, Any]

Type called "TemporalCondition":
            condition_type as TemporalConditionType
            time_threshold_ns as Integer
            duration_threshold_ns as Integer
            frequency_threshold as Float
            comparison_operator as ComparisonOperator
            reference_timestamp_ns as Integer
            metadata as Dictionary[String, Any]

Type TemporalConditionType is:
            | AbsoluteTime
            | RelativeTime
            | ExecutionDuration
            | CallFrequency
            | PerformanceThreshold

Type ComparisonOperator is:
            | Greater
            | Less
            | Equal
            | GreaterEqual
            | LessEqual
            | NotEqual

Type called "DurationCondition":
            min_duration_ns as Integer
            max_duration_ns as Integer
            function_name as String
            cumulative_duration as Boolean
            sliding_window_ms as Integer
            metadata as Dictionary[String, Any]

Type called "FrequencyCondition":
            calls_per_second as Float
            time_window_ms as Integer
            function_pattern as String
            thread_filter as List[Integer]
            metadata as Dictionary[String, Any]

Type called "TimingCorrelation":
            correlation_id as String
            primary_event as ExecutionEvent
            correlated_events as List[ExecutionEvent]
            correlation_strength as Float
            temporal_offset_ns as Integer
            causality_confidence as Float
            correlation_type as CorrelationType
            statistical_significance as Float
            metadata as Dictionary[String, Any]

Type CorrelationType is:
            | Causal
            | Temporal
            | Statistical
            | Functional

Type called "CausalityChain":
            chain_id as String
            root_cause_event as ExecutionEvent
            dependent_events as List[ExecutionEvent]
            chain_length as Integer
            total_propagation_time_ns as Integer
            confidence_score as Float
            impact_analysis as CausalityImpact
            metadata as Dictionary[String, Any]

Type called "CausalityImpact":
            affected_functions as List[String]
            performance_degradation_percent as Float
            resource_utilization_impact as Float
            error_propagation_risk as Float
            optimization_opportunities as List[String]
