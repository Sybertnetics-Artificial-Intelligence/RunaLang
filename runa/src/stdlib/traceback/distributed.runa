Process called "generate_random_hex" that takes length as Integer returns String:
    Note: Generate cryptographically secure random hex string
            Let hex_chars be "0123456789abcdef"
            Let result be ""
    Let random_seed be get_cryptographic_random_seed For i from 0 to (length - 1):
            Let random_index be (random_seed i * 16807) modulo 16
            Let hex_char be get_character_at_index with string as hex_chars and index as random_index
            Set result to result Joined with hex_char
            Set random_seed to (random_seed * 16807 2147483647) modulo 4294967296 Return result

Process called "string_to_integer" that takes string as String returns Integer:
    Note: Convert string to integer with comprehensive parsing
    If length of string = 0:
            Return 0 Let result be 0
            Let is_negative be false
    Let start_index be 0 Note: Handle negative numbers
    If get_character_at_index with string as string and index as 0 = "-":
            Set is_negative to true
    Set start_index to 1 Note: Parse each digit
    For i from start_index to (length of string - 1):
            Let char be get_character_at_index with string as string and index as i
    If char > or equal to "0" and char < or equal to "9":
            Let digit_value be get_ascii_value with character as char - 48
            Set result to result * 10 digit_value
    Otherwise:
    Note: Invalid character, return current result
            Break from loop Return if is_negative then 0 - result else result

Process called "calculate_absolute_difference" that takes value1 as Integer and value2 as Integer returns Integer:
            Let diff be value1 - value2
            Return if diff < 0 then (0 - diff) else diff

Process called "reverse_list" that takes list as List[ErrorPropagation] returns List[ErrorPropagation]:
    Note: Reverse list order with proper implementation
            Let reversed_list be list containing
    Let list_length be length of list For i from (list_length - 1) down to 0:
            Add to reversed_list list[i] Return reversed_list

Process called "check_span_for_timeout_indicators" that takes span as TraceContext returns Boolean:
    Note: Check if span indicates timeout
            Return "timeout" in span.tags or "deadline" in span.tags

Process called "count_unique_services" that takes spans as List[TraceContext] returns Integer:
    Let unique_services be list containing For each span in spans:
    If span.service_name not in unique_services:
            Add to unique_services span.service_name Return length of unique_services

Process called "extract_span_latencies" that takes spans as List[TraceContext] returns List[Integer]:
    Let latencies be list containing For each span in spans:
    If span.duration_nanoseconds > 0:
            Add to latencies span.duration_nanoseconds Return latencies

Process called "sort_latencies" that takes latencies as List[Integer] returns List[Integer]:
    Note: Sort latencies using bubble sort algorithm
    Let sorted_latencies be list containing Note: Copy input list
    For each latency in latencies:
            Add to sorted_latencies latency Let n be length of sorted_latencies
    If n < or equal to 1:
    Return sorted_latencies Note: Bubble sort implementation
    For i from 0 to (n - 2):
    For j from 0 to (n - 2 - i):
    If sorted_latencies[j] > sorted_latencies[j 1]:
            Let temp be sorted_latencies[j]
            Set sorted_latencies[j] to sorted_latencies[j 1]
            Set sorted_latencies[j 1] to temp Return sorted_latencies

Process called "calculate_percentile" that takes values as List[Integer] and percentile as Integer returns Integer:
    Note: Calculate percentile value
            Let count be length of values
    If count = 0:
            Return 0 Let index be (percentile times count) / 100
    If index > or equal to count:
            Return values[count - 1]
            Return values[index]

Process called "calculate_trace_duration_seconds" that takes spans as List[TraceContext] returns Float:
    Note: Calculate trace duration in seconds
    If length of spans = 0:
            Return 0.0 Let min_start be spans[0].start_timestamp
    Let max_end be spans[0].end_timestamp For each span in spans:
    If span.start_timestamp < min_start:
            Set min_start to span.start_timestamp
    If span.end_timestamp > max_end:
            Set max_end to span.end_timestamp Let duration_ns be max_end - min_start
            Return duration_ns / 1000000000.0

Process called "count_service_dependencies" that takes call_chain as List[ServiceCall] returns Integer:
    Let unique_dependencies be list containing For each call in call_chain:
            Let dependency_pair be call.caller_service Joined with "->" Joined with call.callee_service
    If dependency_pair not in unique_dependencies:
            Add to unique_dependencies dependency_pair Return length of unique_dependencies

Process called "identify_user_facing_services" that takes services as List[String] returns List[String]:
    Let user_facing_services be list containing For each service in services:
    If service contains "frontend" or service contains "api" or service contains "gateway":
            Add to user_facing_services service Return user_facing_services

Process called "calculate_error_rate_for_services" that takes trace as DistributedTrace and services as List[String] returns Float:
            Let total_spans be 0
    Let error_spans be 0 For each span in trace.all_spans:
    If span.service_name in services:
            Set total_spans to total_spans 1
    If span.status = Error:
    Set error_spans to error_spans 1 If total_spans = 0:
            Return 0.0
            Return error_spans / total_spans

Process called "remove_duplicates" that takes list as List[String] returns List[String]:
    Let unique_items be list containing For each item in list:
    If item not in unique_items:
            Add to unique_items item Return unique_items

Process called "create_production_spans_for_trace" that takes trace_id as String returns List[TraceContext]:
    Note: Create spans for current trace context
    Let spans be collect_active_trace_spans with trace_id as trace_id If length of spans = 0:
    Note: If no active spans, create current span
    Let current_span be TraceContext with:
            trace_id as trace_id
            span_id as generate_span_id
            parent_span_id as get_parent_span_id_or_none
            service_name as get_current_service_name
            operation_name as get_current_operation_name
            start_timestamp as get_span_start_timestamp
            end_timestamp as get_system_time_nanoseconds
            duration_nanoseconds as calculate_span_duration
            status as get_span_status
            tags as extract_span_tags
            logs as extract_span_logs
            baggage as extract_span_baggage
            metadata as extract_span_metadata Add to spans current_span Return spans