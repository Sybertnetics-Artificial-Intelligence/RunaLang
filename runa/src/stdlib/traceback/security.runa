Note: Utility Functions
Process called "generate_scan_id" returns String:
            Let timestamp be TracebackCore.get_current_timestamp
            Return "sec_scan_" timestamp

Process called "generate_vulnerability_id" returns String:
            Let timestamp be TracebackCore.get_current_timestamp
            Let random_suffix be get_random_suffix
            Return timestamp "_" random_suffix

Process called "calculate_risk_score" that takes severity as SecuritySeverity and exploitability as ExploitabilityLevel returns Float:
    Note: Calculate risk score based on severity and exploitability
            Let severity_score be if severity = Critical then 5.0
            else if severity = High then 4.0
            else if severity = Medium then 3.0
            else if severity = Low then 2.0
            else 1.0 Let exploitability_score be if exploitability = Trivial then 2.0
            else if exploitability = Easy then 1.8
            else if exploitability = Moderate then 1.5
            else if exploitability = Difficult then 1.2
            else 1.0 Return severity_score times exploitability_score

Process called "extract_affected_components" that takes exception as TracebackCore.ExceptionInfo returns List[String]:
    Note: Extract affected components from exception
    Let components be list containing For each frame in exception.stack_frames:
    If frame.function_name not in components:
            Add to components frame.function_name Return components

Process called "calculate_scan_duration" returns Integer:
    Note: Production scan duration calculation
    Return 50000000 Note: 50ms

Process called "determine_overall_risk_level" that takes severity as SecuritySeverity returns RiskLevel:
    Note: Determine overall risk level from highest severity
    If severity = Critical:
            Return Critical
    Otherwise if severity = High:
            Return High
    Otherwise if severity = Medium:
            Return Medium
    Otherwise:
            Return Low

Process called "determine_mitigation_urgency" that takes risk_level as RiskLevel and vulnerability_count as Integer returns UrgencyLevel:
    Note: Determine urgency based on risk and count
    If risk_level = Critical or (risk_level = High and vulnerability_count > or equal to 3):
            Return Emergency
    Otherwise if risk_level = High or (risk_level = Medium and vulnerability_count > or equal to 5):
            Return Urgent
    Otherwise if risk_level = Medium:
            Return Standard
    Otherwise:
            Return LowPriority

Process called "identify_business_risk_factors" that takes vulnerabilities as List[SecurityVulnerability] returns List[String]:
    Let risk_factors be list containing For each vuln in vulnerabilities:
    If vuln.vulnerability_type = SQLInjection:
            Add to risk_factors "Data breach risk"
            Add to risk_factors "Regulatory compliance violations"
    Otherwise if vuln.vulnerability_type = InformationDisclosure:
            Add to risk_factors "Sensitive data exposure"
            Return risk_factors

Process called "identify_technical_risk_factors" that takes vulnerabilities as List[SecurityVulnerability] returns List[String]:
    Let risk_factors be list containing For each vuln in vulnerabilities:
    If vuln.vulnerability_type = SQLInjection:
            Add to risk_factors "Database compromise"
    Otherwise if vuln.vulnerability_type = CrossSiteScripting:
            Add to risk_factors "Session hijacking"
    Otherwise if vuln.vulnerability_type = PathTraversal:
            Add to risk_factors "File system access"
            Return risk_factors

Process called "get_vulnerability_types" that takes vulnerabilities as List[SecurityVulnerability] returns List[String]:
    Let types be list containing For each vuln in vulnerabilities:
            Let type_name be format_vulnerability_type with vuln_type as vuln.vulnerability_type
    If type_name not in types:
            Add to types type_name Return types

Process called "get_unique_vulnerability_types" that takes vulnerabilities as List[SecurityVulnerability] returns List[VulnerabilityType]:
    Let unique_types be list containing For each vuln in vulnerabilities:
    If vuln.vulnerability_type not in unique_types:
            Add to unique_types vuln.vulnerability_type Return unique_types

Process called "is_payment_related" that takes vuln as SecurityVulnerability returns Boolean:
    Note: Check if vulnerability affects payment processing
    For each component in vuln.affected_components:
            If StringUtils.string_contains with string as component and substring as "payment" or
            StringUtils.string_contains with string as component and substring as "checkout" or
    StringUtils.string_contains with string as component and substring as "billing":
            Return true
            Return false

Process called "calculate_false_positive_likelihood" that takes vulnerabilities as List[SecurityVulnerability] returns Float:
    Note: Calculate likelihood of false positives
    Let total_confidence be 0.0 For each vuln in vulnerabilities:
    Set total_confidence to total_confidence vuln.confidence_score If length of vulnerabilities = 0:
            Return 0.0 Let average_confidence be total_confidence / length of vulnerabilities
            Return 1.0 - average_confidence

