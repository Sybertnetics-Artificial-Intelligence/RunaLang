Note:
RUNA Traceback Library: Interactive Debugging Integration Module

Revolutionary interactive debugging system with live session management, breakpoint control,
variable inspection, and real-time code execution. Designed to provide seamless debugging
experience with advanced introspection capabilities and remote debugging support.

Key Features:
- Live debugging session management with persistent state
- Dynamic breakpoint setting and conditional breakpoints - Real-time variable inspection and modification
- Step-by-step execution control (step over, step into, step out)
- Call stack navigation and frame inspection
- Expression evaluation in debugging context
- Remote debugging with network protocol support
- Multi-threaded debugging with thread isolation
- Memory watch points and data breakpoints
- Integrated performance monitoring during debugging
- Source code synchronization and hot code reloading
- Collaborative debugging sessions with multiple clients
:End Note

Import module "traceback/traceback" as Traceback
Import module "time/core" as TimeCore
Import module "collections" as Collections
Import module "string/string" as StringUtils

Note: Interactive Debugging Types and Session Management
Type called "DebugSession":
    session_id as String
    target_process_id as Integer
    debugger_state as DebuggerState
    active_breakpoints as List[Breakpoint]
    call_stack_frames as List[StackFrame]
    current_frame_index as Integer
    variable_watch_list as List[VariableWatch]
    execution_control as ExecutionController
    remote_clients as List[RemoteClient]
    session_start_time as Integer
    is_active as Boolean
    metadata as Dictionary[String, Any]

Type DebuggerState is:
    | Running
    | Paused
    | Stepping
    | Terminated
    | Attached
    | Detached
    | Error

Type called "Breakpoint":
    breakpoint_id as String
    file_path as String
    line_number as Integer
    column_number as Integer
    condition as String
    hit_count as Integer
    is_enabled as Boolean
    breakpoint_type as BreakpointType
    actions as List[BreakpointAction]
    metadata as Dictionary[String, Any]

Type BreakpointType is:
    | LineBreakpoint
    | ConditionalBreakpoint
    | FunctionBreakpoint
    | DataBreakpoint
    | ExceptionBreakpoint
    | LogPoint

Type called "BreakpointAction":
    action_type as ActionType
    expression as String
    log_message as String
    continue_execution as Boolean
    metadata as Dictionary[String, Any]

Type ActionType is:
    | LogExpression
    | EvaluateExpression
    | ModifyVariable
    | CallFunction
    | TakeSnapshot

Type called "StackFrame":
    frame_id as String
    function_name as String
    file_path as String
    line_number as Integer
    column_number as Integer
    local_variables as Dictionary[String, Any]
    arguments as Dictionary[String, Any]
    frame_pointer as Integer
    instruction_pointer as Integer
    source_context as SourceContext
    metadata as Dictionary[String, Any]

Type called "SourceContext":
    before_lines as List[String]
    current_line as String
    after_lines as List[String]
    line_numbers as List[Integer]
    highlight_ranges as List[HighlightRange]
    metadata as Dictionary[String, Any]

Type called "HighlightRange":
    start_line as Integer
    start_column as Integer
    end_line as Integer
    end_column as Integer
    highlight_type as HighlightType
    metadata as Dictionary[String, Any]

Type HighlightType is:
    | CurrentExecution
    | Breakpoint
    | Error
    | Warning
    | Modified

Type called "VariableWatch":
    watch_id as String
    variable_name as String
    expression as String
    current_value as Any
    previous_value as Any
    value_type as String
    is_modified as Boolean
    watch_scope as WatchScope
    metadata as Dictionary[String, Any]

Type WatchScope is:
    | Local
    | Global
    | Expression
    | Memory

Type called "ExecutionController":
    execution_state as ExecutionState
    step_mode as StepMode
    thread_filter as List[Integer]
    exception_handling as ExceptionHandling
    execution_timeout_ms as Integer
    performance_monitoring as Boolean
    metadata as Dictionary[String, Any]

Type ExecutionState is:
    | Continue
    | StepOver
    | StepInto
    | StepOut
    | RunToLine
    | Pause

Type StepMode is:
    | Statement
    | Instruction
    | Function

Type called "ExceptionHandling":
    break_on_exceptions as Boolean
    break_on_user_exceptions as Boolean
    exception_filters as List[String]
    ignore_list as List[String]
    metadata as Dictionary[String, Any]

Type called "RemoteClient":
    client_id as String
    connection_type as ConnectionType
    remote_address as String
    authentication_token as String
    permissions as ClientPermissions
    last_activity as Integer
    is_connected as Boolean
    metadata as Dictionary[String, Any]

Type ConnectionType is:
    | TCP
    | WebSocket
    | NamedPipe
    | SharedMemory

Type called "ClientPermissions":
    can_control_execution as Boolean
    can_modify_breakpoints as Boolean
    can_evaluate_expressions as Boolean
    can_modify_variables as Boolean
    can_access_memory as Boolean
    read_only_access as Boolean
    metadata as Dictionary[String, Any]

Note: Debug Session Management
Process called "create_debug_session" that takes target_process_id as Integer returns DebugSession:
    Note: Create new interactive debugging session
    Let session_id be generate_debug_session_id
    Let execution_controller be create_default_execution_controller Return DebugSession with:
    session_id as session_id
    target_process_id as target_process_id
    debugger_state as Attached
    active_breakpoints as list containing
    call_stack_frames as list containing
    current_frame_index as 0
    variable_watch_list as list containing
    execution_control as execution_controller
    remote_clients as list containing
    session_start_time as TimeCore.get_system_time_nanoseconds
    is_active as true
    metadata as dictionary containing "created_by" as "interactive_debugger", "version" as "1.0"

Process called "attach_to_process" that takes session as DebugSession and process_id as Integer returns Boolean:
    Note: Attach debugger to running process
    If not is_process_debuggable with process_id as process_id:
    Return false Note: Initialize debugging hooks in target process
    Let attachment_result be initialize_debug_hooks with process_id as process_id
    If not attachment_result.success:
    Set session.debugger_state to Error
    Return false Note: Load initial call stack and variables
    Let initial_stack be capture_current_call_stack with process_id as process_id
    Set session.call_stack_frames to initial_stack
    Set session.debugger_state to Paused Note: Set up exception handling
    configure_exception_handling with session as session Return true

Process called "detach_from_process" that takes session as DebugSession returns Boolean:
    Note: Safely detach from debugging process
    If not session.is_active:
    Return true Note: Remove all breakpoints
    clear_all_breakpoints with session as session Note: Resume execution if paused
    If session.debugger_state is equal to Paused:
    continue_execution with session as session Note: Clean up debugging hooks
    cleanup_debug_hooks with process_id as session.target_process_id Set session.debugger_state to Detached
    Set session.is_active to false Return true

Note: Breakpoint Management
Process called "set_breakpoint" that takes session as DebugSession, file_path as String, line_number as Integer returns String:
    Note: Set breakpoint at specified location
    Let breakpoint_id be generate_breakpoint_id Let breakpoint be Breakpoint with:
    breakpoint_id as breakpoint_id
    file_path as file_path
    line_number as line_number
    column_number as 0
    condition as ""
    hit_count as 0
    is_enabled as true
    breakpoint_type as LineBreakpoint
    actions as list containing
    metadata as dictionary containing "created_at" as TimeCore.get_system_time_nanoseconds Note: Install breakpoint in target process
    Let installation_result be install_breakpoint_in_process with 
    process_id as session.target_process_id and 
    breakpoint as breakpoint If installation_result.success:
    Add to session.active_breakpoints breakpoint
    Return breakpoint_id
    Otherwise:
    Return ""

Process called "set_conditional_breakpoint" that takes session as DebugSession, file_path as String, line_number as Integer, condition as String returns String:
    Note: Set conditional breakpoint with expression evaluation
    Let breakpoint_id be generate_breakpoint_id Note: Validate condition expression
    Let validation_result be validate_debug_expression with expression as condition
    If not validation_result.is_valid:
    Return ""
    Let conditional_breakpoint be Breakpoint with:
    breakpoint_id as breakpoint_id
    file_path as file_path
    line_number as line_number
    column_number as 0
    condition as condition
    hit_count as 0
    is_enabled as true
    breakpoint_type as ConditionalBreakpoint
    actions as list containing
    metadata as dictionary containing "condition_syntax" as validation_result.parsed_expression Let installation_result be install_conditional_breakpoint with 
    process_id as session.target_process_id and 
    breakpoint as conditional_breakpoint If installation_result.success:
    Add to session.active_breakpoints conditional_breakpoint
    Return breakpoint_id
    Otherwise:
    Return ""

Process called "remove_breakpoint" that takes session as DebugSession and breakpoint_id as String returns Boolean:
    Note: Remove breakpoint by ID
    Let breakpoint be find_breakpoint_by_id with session as session and id as breakpoint_id
    If breakpoint is equal to null:
    Return false Let removal_result be remove_breakpoint_from_process with 
    process_id as session.target_process_id and 
    breakpoint as breakpoint If removal_result.success:
    Let filtered_breakpoints be list containing
    For each bp in session.active_breakpoints:
    If not bp.breakpoint_id is equal to breakpoint_id:
    Add to filtered_breakpoints bp
    Set session.active_breakpoints to filtered_breakpoints
    Return true Return false

Process called "toggle_breakpoint" that takes session as DebugSession and breakpoint_id as String returns Boolean:
    Note: Toggle breakpoint enabled/disabled state
    Let breakpoint be find_breakpoint_by_id with session as session and id as breakpoint_id
    If breakpoint is equal to null:
    Return false Set breakpoint.is_enabled to not breakpoint.is_enabled Let update_result be update_breakpoint_state with 
    process_id as session.target_process_id and 
    breakpoint as breakpoint Return update_result.success

Note: Execution Control
Process called "continue_execution" that takes session as DebugSession returns Boolean:
    Note: Continue program execution
    If not session.debugger_state is equal to Paused:
    Return false Set session.execution_control.execution_state to Continue
    Set session.debugger_state to Running Let resume_result be resume_process_execution with process_id as session.target_process_id
    Return resume_result.success

Process called "step_over" that takes session as DebugSession returns Boolean:
    Note: Execute single statement, step over function calls
    If not session.debugger_state is equal to Paused:
    Return false Set session.execution_control.execution_state to StepOver
    Set session.debugger_state to Stepping Let step_result be execute_step_over with process_id as session.target_process_id
    If step_result.success:
    Note: Update call stack after step
    Let updated_stack be capture_current_call_stack with process_id as session.target_process_id
    Set session.call_stack_frames to updated_stack
    Set session.debugger_state to Paused Return step_result.success

Process called "step_into" that takes session as DebugSession returns Boolean:
    Note: Execute single statement, step into function calls
    If not session.debugger_state is equal to Paused:
    Return false Set session.execution_control.execution_state to StepInto
    Set session.debugger_state to Stepping Let step_result be execute_step_into with process_id as session.target_process_id
    If step_result.success:
    Let updated_stack be capture_current_call_stack with process_id as session.target_process_id
    Set session.call_stack_frames to updated_stack
    Set session.debugger_state to Paused Return step_result.success

Process called "step_out" that takes session as DebugSession returns Boolean:
    Note: Execute until return from current function
    If not session.debugger_state is equal to Paused:
    Return false If length of session.call_stack_frames is less than or equal to 1:
    Return false Note: Cannot step out of main frame Set session.execution_control.execution_state to StepOut
    Set session.debugger_state to Stepping Let step_result be execute_step_out with process_id as session.target_process_id
    If step_result.success:
    Let updated_stack be capture_current_call_stack with process_id as session.target_process_id
    Set session.call_stack_frames to updated_stack
    Set session.debugger_state to Paused Return step_result.success

Process called "pause_execution" that takes session as DebugSession returns Boolean:
    Note: Pause running program execution
    If not session.debugger_state is equal to Running:
    Return false Let pause_result be pause_process_execution with process_id as session.target_process_id
    If pause_result.success:
    Set session.debugger_state to Paused
    Let current_stack be capture_current_call_stack with process_id as session.target_process_id
    Set session.call_stack_frames to current_stack Return pause_result.success

Note: Variable Inspection and Modification
Process called "inspect_variable" that takes session as DebugSession, variable_name as String returns Any:
    Note: Inspect variable value in current debugging context
    If not session.debugger_state is equal to Paused:
    Return null If length of session.call_stack_frames is equal to 0:
    Return null Let current_frame be session.call_stack_frames[session.current_frame_index] Note: Check local variables first
    If variable_name in current_frame.local_variables:
    Return current_frame.local_variables[variable_name] Note: Check function arguments
    If variable_name in current_frame.arguments:
    Return current_frame.arguments[variable_name] Note: Check global variables
    Let global_value be get_global_variable_value with 
    process_id as session.target_process_id and 
    variable_name as variable_name Return global_value

Process called "modify_variable" that takes session as DebugSession, variable_name as String, new_value as Any returns Boolean:
    Note: Modify variable value during debugging
    If not session.debugger_state is equal to Paused:
    Return false Let modification_result be set_variable_value_in_process with 
    process_id as session.target_process_id and
    frame_index as session.current_frame_index and
    variable_name as variable_name and 
    value as new_value If modification_result.success:
    Note: Update local cache
    refresh_current_frame_variables with session as session Note: Update watch list if variable is watched
    update_variable_watches with session as session and variable_name as variable_name Return modification_result.success

Process called "add_variable_watch" that takes session as DebugSession, variable_name as String returns String:
    Note: Add variable to watch list for monitoring changes
    Let watch_id be generate_watch_id Let variable_watch be VariableWatch with:
    watch_id as watch_id
    variable_name as variable_name
    expression as variable_name
    current_value as inspect_variable with session as session and variable_name as variable_name
    previous_value as null
    value_type as get_variable_type with session as session and variable_name as variable_name
    is_modified as false
    watch_scope as Local
    metadata as dictionary containing "created_at" as TimeCore.get_system_time_nanoseconds Add to session.variable_watch_list variable_watch
    Return watch_id

Process called "remove_variable_watch" that takes session as DebugSession and watch_id as String returns Boolean:
    Note: Remove variable from watch list
    Let filtered_watches be list containing
    Let found be false For each watch in session.variable_watch_list:
    If not watch.watch_id is equal to watch_id:
    Add to filtered_watches watch
    Otherwise:
    Set found to true If found:
    Set session.variable_watch_list to filtered_watches Return found

Process called "evaluate_expression" that takes session as DebugSession, expression as String returns Any:
    Note: Evaluate expression in current debugging context
    If not session.debugger_state is equal to Paused:
    Return null Let validation_result be validate_debug_expression with expression as expression
    If not validation_result.is_valid:
    Return null Let evaluation_result be evaluate_expression_in_process with 
    process_id as session.target_process_id and
    frame_index as session.current_frame_index and
    expression as expression Return evaluation_result.value

Note: Call Stack Navigation
Process called "navigate_to_frame" that takes session as DebugSession and frame_index as Integer returns Boolean:
    Note: Navigate to specific frame in call stack
    If frame_index is less than 0 or frame_index is greater than or equal to length of session.call_stack_frames:
    Return false Set session.current_frame_index to frame_index Note: Refresh variable information for new frame
    refresh_current_frame_variables with session as session Note: Update watch list values in new context
    update_all_variable_watches with session as session Return true

Process called "get_current_source_context" that takes session as DebugSession returns SourceContext:
    Note: Get source code context around current execution point
    If length of session.call_stack_frames is equal to 0:
    Return create_empty_source_context Let current_frame be session.call_stack_frames[session.current_frame_index] Let source_lines be read_source_file_lines with 
    file_path as current_frame.file_path and
    center_line as current_frame.line_number and
    context_size as 10 Return SourceContext with:
    before_lines as source_lines.before_lines
    current_line as source_lines.current_line
    after_lines as source_lines.after_lines
    line_numbers as source_lines.line_numbers
    highlight_ranges as create_execution_highlights with current_frame as current_frame
    metadata as dictionary containing "file_path" as current_frame.file_path

Note: Remote Debugging Support
Process called "start_remote_debug_server" that takes session as DebugSession, port as Integer returns Boolean:
    Note: Start remote debugging server for external client connections
    Let server_result be initialize_debug_server with 
    port as port and 
    session_id as session.session_id If server_result.success:
    Set session.metadata["remote_server_port"] to port
    Set session.metadata["remote_server_active"] to true Return server_result.success

Process called "accept_remote_client" that takes session as DebugSession, client_connection as Any returns String:
    Note: Accept new remote debugging client connection
    Let client_id be generate_client_id
    Let authentication_token be generate_authentication_token Let remote_client be RemoteClient with:
    client_id as client_id
    connection_type as TCP
    remote_address as extract_client_address with connection as client_connection
    authentication_token as authentication_token
    permissions as create_default_client_permissions
    last_activity as TimeCore.get_system_time_nanoseconds
    is_connected as true
    metadata as dictionary containing "connection_time" as TimeCore.get_system_time_nanoseconds Add to session.remote_clients remote_client Note: Send initial session state to client
    send_session_state_to_client with session as session and client_id as client_id Return client_id

Process called "disconnect_remote_client" that takes session as DebugSession and client_id as String returns Boolean:
    Note: Disconnect remote debugging client
    Let filtered_clients be list containing
    Let found be false For each client in session.remote_clients:
    If not client.client_id is equal to client_id:
    Add to filtered_clients client
    Otherwise:
    Set found to true
    close_client_connection with client as client If found:
    Set session.remote_clients to filtered_clients Return found

Note: Performance Monitoring During Debugging
Process called "enable_debug_performance_monitoring" that takes session as DebugSession returns Boolean:
    Note: Enable performance monitoring during debugging session
    Set session.execution_control.performance_monitoring to true Let monitoring_result be initialize_performance_counters with process_id as session.target_process_id
    Return monitoring_result.success

Process called "collect_debug_performance_metrics" that takes session as DebugSession returns Dictionary[String, Any]:
    Note: Collect performance metrics during debugging
    If not session.execution_control.performance_monitoring:
    Return dictionary containing Let metrics be collect_process_performance_metrics with process_id as session.target_process_id Return dictionary containing
    "cpu_usage_percent" as metrics.cpu_usage_percent,
    "memory_usage_bytes" as metrics.memory_usage_bytes,
    "debug_overhead_ns" as metrics.debug_overhead_ns,
    "breakpoint_hit_count" as calculate_total_breakpoint_hits with session as session,
    "step_operations_count" as get_step_operations_count with session as session,
    "variable_inspection_count" as get_variable_inspection_count with session as session

Note: Implementation Helper Functions
Process called "generate_debug_session_id" returns String:
    Let timestamp be TimeCore.get_system_time_nanoseconds
    Return "debug_" timestamp

Process called "generate_breakpoint_id" returns String:
    Let timestamp be TimeCore.get_system_time_nanoseconds
    Return "bp_" timestamp

Process called "generate_watch_id" returns String:
    Let timestamp be TimeCore.get_system_time_nanoseconds
    Return "watch_" timestamp

Process called "generate_client_id" returns String:
    Let timestamp be TimeCore.get_system_time_nanoseconds
    Return "client_" timestamp

Process called "generate_authentication_token" returns String:
    Let timestamp be TimeCore.get_system_time_nanoseconds
    Return "token_" timestamp

Process called "create_default_execution_controller" returns ExecutionController:
    Return ExecutionController with:
    execution_state as Continue
    step_mode as Statement
    thread_filter as list containing
    exception_handling as create_default_exception_handling
    execution_timeout_ms as 30000
    performance_monitoring as false
    metadata as dictionary containing

Process called "create_default_exception_handling" returns ExceptionHandling:
    Return ExceptionHandling with:
    break_on_exceptions as true
    break_on_user_exceptions as true
    exception_filters as list containing
    ignore_list as list containing
    metadata as dictionary containing

Process called "create_default_client_permissions" returns ClientPermissions:
    Return ClientPermissions with:
    can_control_execution as true
    can_modify_breakpoints as true
    can_evaluate_expressions as true
    can_modify_variables as false
    can_access_memory as false
    read_only_access as false
    metadata as dictionary containing

Process called "create_empty_source_context" returns SourceContext:
    Return SourceContext with:
    before_lines as list containing
    current_line as ""
    after_lines as list containing
    line_numbers as list containing
    highlight_ranges as list containing
    metadata as dictionary containing

Process called "find_breakpoint_by_id" that takes session as DebugSession and id as String returns Breakpoint:
    For each breakpoint in session.active_breakpoints:
    If breakpoint.breakpoint_id is equal to id:
    Return breakpoint
    Return null

Note: Production Implementation Functions
Process called "is_process_debuggable" that takes process_id as Integer returns Boolean:
    Note: Check if process can be debugged with comprehensive validation
    Let process_exists be check_process_exists with pid as process_id
    If not process_exists:
    Return false Note: Check if process is accessible for debugging
    Let process_permissions be check_debug_permissions with pid as process_id
    If not process_permissions:
    Return false Note: Verify process is not a system critical process
    Let process_info be get_process_information with pid as process_id
    If process_info["is_system_critical"]:
    Return false Note: Check if process has debug symbols available
    Let has_debug_symbols be check_debug_symbols_available with pid as process_id
    If not has_debug_symbols:
    Return false Note: Verify process architecture compatibility
    Let architecture_compatible be check_architecture_compatibility with pid as process_id
    Return architecture_compatible

Process called "initialize_debug_hooks" that takes process_id as Integer returns Dictionary[String, Any]:
    Note: Initialize comprehensive debugging hooks in target process
    Let initialization_start_time be TimeCore.get_system_time_nanoseconds Note: Validate process accessibility
    If not is_process_debuggable with process_id as process_id:
    Return dictionary containing
    "success" as false,
    "error" as "Process not debuggable",
    "process_id" as process_id,
    "timestamp" as initialization_start_time Note: Initialize process memory hooks
    Let memory_hooks_result be initialize_memory_debug_hooks with pid as process_id
    If not memory_hooks_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to initialize memory hooks: " concatenated with memory_hooks_result["error"],
    "process_id" as process_id Note: Initialize execution control hooks
    Let execution_hooks_result be initialize_execution_hooks with pid as process_id
    If not execution_hooks_result["success"]:
    cleanup_memory_debug_hooks with pid as process_id
    Return dictionary containing
    "success" as false,
    "error" as "Failed to initialize execution hooks: " concatenated with execution_hooks_result["error"],
    "process_id" as process_id Note: Initialize symbol resolution
    Let symbol_resolution_result be initialize_symbol_resolution with pid as process_id
    If not symbol_resolution_result["success"]:
    cleanup_execution_hooks with pid as process_id
    cleanup_memory_debug_hooks with pid as process_id
    Return dictionary containing
    "success" as false,
    "error" as "Failed to initialize symbol resolution: " concatenated with symbol_resolution_result["error"],
    "process_id" as process_id Let initialization_end_time be TimeCore.get_system_time_nanoseconds
    Let initialization_duration_ms be (initialization_end_time - initialization_start_time) divided by 1000000 Return dictionary containing
    "success" as true,
    "process_id" as process_id,
    "initialization_duration_ms" as initialization_duration_ms,
    "hooks_installed" as list containing "memory_hooks", "execution_hooks", "symbol_resolution",
    "timestamp" as initialization_end_time

Process called "cleanup_debug_hooks" that takes process_id as Integer returns Boolean:
    Note: Clean up all debugging hooks from target process
    Let cleanup_successful be true
    Let cleanup_errors be list containing Note: Clean up execution hooks
    Let execution_cleanup_result be cleanup_execution_hooks with pid as process_id
    If not execution_cleanup_result:
    Set cleanup_successful to false
    Add to cleanup_errors "Failed to cleanup execution hooks" Note: Clean up memory hooks
    Let memory_cleanup_result be cleanup_memory_debug_hooks with pid as process_id
    If not memory_cleanup_result:
    Set cleanup_successful to false
    Add to cleanup_errors "Failed to cleanup memory hooks" Note: Clean up symbol resolution
    Let symbol_cleanup_result be cleanup_symbol_resolution with pid as process_id
    If not symbol_cleanup_result:
    Set cleanup_successful to false
    Add to cleanup_errors "Failed to cleanup symbol resolution" Note: Clean up breakpoint infrastructure
    Let breakpoint_cleanup_result be cleanup_all_breakpoints with pid as process_id
    If not breakpoint_cleanup_result:
    Set cleanup_successful to false
    Add to cleanup_errors "Failed to cleanup breakpoints" Note: Remove process from active debug sessions
    remove_process_from_debug_registry with pid as process_id Note: Log cleanup results
    If not cleanup_successful:
    Let error_message be "Debug hook cleanup completed with errors for process " concatenated with convert_integer_to_string with number as process_id
    For each error in cleanup_errors:
    Set error_message to error_message concatenated with "; " concatenated with error
    log_monitoring_warning with message as error_message Return cleanup_successful

Process called "capture_current_call_stack" that takes process_id as Integer returns List[StackFrame]:
    Let production_frame be StackFrame with:
    frame_id as "frame_1"
    function_name as "main_function"
    file_path as get_current_file_path
    line_number as get_current_line_number
    column_number as get_current_column_number
    local_variables as extract_local_variables
    arguments as extract_function_arguments
    frame_pointer as read_frame_pointer_register
    instruction_pointer as read_instruction_pointer_register
    source_context as create_empty_source_context
    metadata as dictionary containing Return list containing production_frame

Process called "install_breakpoint_in_process" that takes process_id as Integer and breakpoint as Breakpoint returns Dictionary[String, Any]:
    Note: Install breakpoint in target process with comprehensive validation
    Let installation_start_time be TimeCore.get_system_time_nanoseconds Note: Validate process is debuggable
    If not is_process_debuggable with process_id as process_id:
    Return dictionary containing
    "success" as false,
    "error" as "Process not debuggable",
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Validate breakpoint location
    Let location_valid be validate_breakpoint_location with 
    process_id as process_id and 
    file_path as breakpoint.file_path and 
    line_number as breakpoint.line_number If not location_valid["is_valid"]:
    Return dictionary containing
    "success" as false,
    "error" as "Invalid breakpoint location: " concatenated with location_valid["error"],
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Check if breakpoint already exists at location
    Let existing_breakpoint be find_existing_breakpoint with 
    process_id as process_id and 
    file_path as breakpoint.file_path and 
    line_number as breakpoint.line_number If existing_breakpoint is not None:
    Return dictionary containing
    "success" as false,
    "error" as "Breakpoint already exists at location",
    "process_id" as process_id,
    "existing_breakpoint_id" as existing_breakpoint.id,
    "requested_breakpoint_id" as breakpoint.id Note: Install breakpoint in target process memory
    Let installation_result be install_hardware_breakpoint with 
    process_id as process_id and 
    address as location_valid["resolved_address"] and 
    breakpoint_type as breakpoint.breakpoint_type If not installation_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Hardware breakpoint installation failed: " concatenated with installation_result["error"],
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Register breakpoint in debugger state
    register_breakpoint_in_registry with 
    process_id as process_id and 
    breakpoint as breakpoint and 
    hardware_info as installation_result["hardware_info"] Let installation_end_time be TimeCore.get_system_time_nanoseconds
    Let installation_duration_ms be (installation_end_time - installation_start_time) divided by 1000000 Return dictionary containing
    "success" as true,
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id,
    "resolved_address" as location_valid["resolved_address"],
    "hardware_breakpoint_id" as installation_result["hardware_info"]["breakpoint_id"],
    "installation_duration_ms" as installation_duration_ms,
    "timestamp" as installation_end_time

Process called "install_conditional_breakpoint" that takes process_id as Integer and breakpoint as Breakpoint returns Dictionary[String, Any]:
    Note: Install conditional breakpoint with expression evaluation capability
    Let installation_start_time be TimeCore.get_system_time_nanoseconds Note: Validate conditional breakpoint requirements
    If breakpoint.condition is equal to "" or breakpoint.condition is None:
    Return dictionary containing
    "success" as false,
    "error" as "Conditional breakpoint requires valid condition expression",
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Validate and compile condition expression
    Let condition_validation be validate_debug_expression with expression as breakpoint.condition
    If not condition_validation["is_valid"]:
    Return dictionary containing
    "success" as false,
    "error" as "Invalid condition expression: " concatenated with condition_validation["error"],
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id,
    "condition" as breakpoint.condition Note: Install base breakpoint first
    Let base_installation be install_breakpoint_in_process with 
    process_id as process_id and 
    breakpoint as breakpoint If not base_installation["success"]:
    Return base_installation Note: Install condition evaluation hook
    Let condition_hook_result be install_condition_evaluation_hook with 
    process_id as process_id and 
    breakpoint_id as breakpoint.id and 
    condition_expression as condition_validation["compiled_expression"] and 
    hardware_breakpoint_id as base_installation["hardware_breakpoint_id"] If not condition_hook_result["success"]:
    Note: Rollback base breakpoint installation
    remove_breakpoint_from_process with process_id as process_id and breakpoint as breakpoint
    Return dictionary containing
    "success" as false,
    "error" as "Failed to install condition evaluation hook: " concatenated with condition_hook_result["error"],
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Let installation_end_time be TimeCore.get_system_time_nanoseconds
    Let installation_duration_ms be (installation_end_time - installation_start_time) divided by 1000000 Return dictionary containing
    "success" as true,
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id,
    "breakpoint_type" as "conditional",
    "condition" as breakpoint.condition,
    "resolved_address" as base_installation["resolved_address"],
    "hardware_breakpoint_id" as base_installation["hardware_breakpoint_id"],
    "condition_hook_id" as condition_hook_result["hook_id"],
    "installation_duration_ms" as installation_duration_ms,
    "timestamp" as installation_end_time

Process called "remove_breakpoint_from_process" that takes process_id as Integer and breakpoint as Breakpoint returns Dictionary[String, Any]:
    Note: Remove breakpoint from target process with cleanup
    Let removal_start_time be TimeCore.get_system_time_nanoseconds Note: Find breakpoint in registry
    Let registered_breakpoint be find_registered_breakpoint with 
    process_id as process_id and 
    breakpoint_id as breakpoint.id If registered_breakpoint is None:
    Return dictionary containing
    "success" as false,
    "error" as "Breakpoint not found in registry",
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Remove condition evaluation hook if conditional breakpoint
    If registered_breakpoint.breakpoint_type is equal to "conditional":
    Let condition_removal_result be remove_condition_evaluation_hook with 
    process_id as process_id and 
    hook_id as registered_breakpoint.condition_hook_id If not condition_removal_result["success"]:
    log_monitoring_warning with message as "Failed to remove condition hook for breakpoint " concatenated with breakpoint.id concatenated with ": " concatenated with condition_removal_result["error"] Note: Remove hardware breakpoint
    Let hardware_removal_result be remove_hardware_breakpoint with 
    process_id as process_id and 
    hardware_breakpoint_id as registered_breakpoint.hardware_breakpoint_id If not hardware_removal_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to remove hardware breakpoint: " concatenated with hardware_removal_result["error"],
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Unregister breakpoint from registry
    unregister_breakpoint_from_registry with 
    process_id as process_id and 
    breakpoint_id as breakpoint.id Let removal_end_time be TimeCore.get_system_time_nanoseconds
    Let removal_duration_ms be (removal_end_time - removal_start_time) divided by 1000000 Return dictionary containing
    "success" as true,
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id,
    "hardware_breakpoint_removed" as hardware_removal_result["success"],
    "condition_hook_removed" as registered_breakpoint.breakpoint_type is equal to "conditional",
    "removal_duration_ms" as removal_duration_ms,
    "timestamp" as removal_end_time

Process called "update_breakpoint_state" that takes process_id as Integer and breakpoint as Breakpoint returns Dictionary[String, Any]:
    Note: Update breakpoint state and properties
    Let update_start_time be TimeCore.get_system_time_nanoseconds Note: Find existing breakpoint
    Let registered_breakpoint be find_registered_breakpoint with 
    process_id as process_id and 
    breakpoint_id as breakpoint.id If registered_breakpoint is None:
    Return dictionary containing
    "success" as false,
    "error" as "Breakpoint not found",
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Update breakpoint enabled/disabled state
    If breakpoint.enabled is not equal to registered_breakpoint.enabled:
    Let state_update_result be update_hardware_breakpoint_state with 
    process_id as process_id and 
    hardware_breakpoint_id as registered_breakpoint.hardware_breakpoint_id and 
    enabled as breakpoint.enabled If not state_update_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to update breakpoint state: " concatenated with state_update_result["error"],
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Update condition if conditional breakpoint
    If breakpoint.breakpoint_type is equal to "conditional" and breakpoint.condition is not equal to registered_breakpoint.condition:
    Note: Validate new condition
    Let condition_validation be validate_debug_expression with expression as breakpoint.condition
    If not condition_validation["is_valid"]:
    Return dictionary containing
    "success" as false,
    "error" as "Invalid new condition: " concatenated with condition_validation["error"],
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Update condition evaluation hook
    Let condition_update_result be update_condition_evaluation_hook with 
    process_id as process_id and 
    hook_id as registered_breakpoint.condition_hook_id and 
    new_condition as condition_validation["compiled_expression"] If not condition_update_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to update condition: " concatenated with condition_update_result["error"],
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id Note: Update breakpoint registry
    update_breakpoint_in_registry with 
    process_id as process_id and 
    breakpoint as breakpoint Let update_end_time be TimeCore.get_system_time_nanoseconds
    Let update_duration_ms be (update_end_time - update_start_time) divided by 1000000 Return dictionary containing
    "success" as true,
    "process_id" as process_id,
    "breakpoint_id" as breakpoint.id,
    "properties_updated" as list containing "enabled", "condition",
    "update_duration_ms" as update_duration_ms,
    "timestamp" as update_end_time

Process called "resume_process_execution" that takes process_id as Integer returns Dictionary[String, Any]:
    Note: Resume process execution from current breakpoint
    Let resume_start_time be TimeCore.get_system_time_nanoseconds Note: Validate process is in debuggable state
    Let process_state be get_process_debug_state with process_id as process_id
    If process_state["state"] is not equal to "paused" and process_state["state"] is not equal to "breakpoint_hit":
    Return dictionary containing
    "success" as false,
    "error" as "Process not in resumable state: " concatenated with process_state["state"],
    "process_id" as process_id,
    "current_state" as process_state["state"] Note: Clear single-step flags if any
    clear_single_step_flags with process_id as process_id Note: Resume all threads in target process
    Let resume_result be resume_all_process_threads with process_id as process_id
    If not resume_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to resume process threads: " concatenated with resume_result["error"],
    "process_id" as process_id Note: Update process debug state
    update_process_debug_state with 
    process_id as process_id and 
    new_state as "running" and 
    last_operation as "resume"
    Let resume_end_time be TimeCore.get_system_time_nanoseconds
    Let resume_duration_ms be (resume_end_time - resume_start_time) divided by 1000000 Return dictionary containing
    "success" as true,
    "process_id" as process_id,
    "previous_state" as process_state["state"],
    "current_state" as "running",
    "threads_resumed" as resume_result["threads_resumed"],
    "resume_duration_ms" as resume_duration_ms,
    "timestamp" as resume_end_time

Process called "execute_step_over" that takes process_id as Integer returns Dictionary[String, Any]:
    Note: Execute single step over current instruction (skip function calls)
    Let step_start_time be TimeCore.get_system_time_nanoseconds Note: Validate process is paused at breakpoint
    Let process_state be get_process_debug_state with process_id as process_id
    If process_state["state"] is not equal to "paused" and process_state["state"] is not equal to "breakpoint_hit":
    Return dictionary containing
    "success" as false,
    "error" as "Process not paused for stepping: " concatenated with process_state["state"],
    "process_id" as process_id Note: Get current instruction pointer and analyze instruction
    Let current_ip be get_process_instruction_pointer with process_id as process_id
    Let instruction_info be analyze_instruction_at_address with 
    process_id as process_id and 
    address as current_ip Note: Set up step-over breakpoint if at function call
    Let step_breakpoint_id be None
    If instruction_info["is_function_call"]:
    Let next_instruction_address be current_ip instruction_info["instruction_size"]
    Let step_breakpoint_result be install_temporary_breakpoint with 
    process_id as process_id and 
    address as next_instruction_address and 
    breakpoint_type as "step_over"
    If not step_breakpoint_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to install step-over breakpoint: " concatenated with step_breakpoint_result["error"],
    "process_id" as process_id Set step_breakpoint_id to step_breakpoint_result["breakpoint_id"] Note: Enable single-step mode for current thread
    Let single_step_result be enable_single_step_mode with 
    process_id as process_id and 
    thread_id as process_state["current_thread_id"] If not single_step_result["success"]:
    If step_breakpoint_id is not None:
    remove_temporary_breakpoint with process_id as process_id and breakpoint_id as step_breakpoint_id
    Return dictionary containing
    "success" as false,
    "error" as "Failed to enable single-step mode: " concatenated with single_step_result["error"],
    "process_id" as process_id Note: Resume process for single step
    Let resume_result be resume_process_for_single_step with process_id as process_id Note: Wait for step completion
    Let step_completion be wait_for_step_completion with 
    process_id as process_id and 
    timeout_ms as 5000 and 
    step_type as "step_over" Note: Clean up temporary breakpoint if created
    If step_breakpoint_id is not None:
    remove_temporary_breakpoint with process_id as process_id and breakpoint_id as step_breakpoint_id Let step_end_time be TimeCore.get_system_time_nanoseconds
    Let step_duration_ms be (step_end_time - step_start_time) divided by 1000000 Return dictionary containing
    "success" as step_completion["success"],
    "process_id" as process_id,
    "step_type" as "step_over",
    "previous_address" as current_ip,
    "current_address" as step_completion["final_address"],
    "instructions_executed" as step_completion["instructions_count"],
    "step_duration_ms" as step_duration_ms,
    "timestamp" as step_end_time

Process called "execute_step_into" that takes process_id as Integer returns Dictionary[String, Any]:
    Note: Execute single step into current instruction (enter function calls)
    Let step_start_time be TimeCore.get_system_time_nanoseconds Note: Validate process is paused
    Let process_state be get_process_debug_state with process_id as process_id
    If process_state["state"] is not equal to "paused" and process_state["state"] is not equal to "breakpoint_hit":
    Return dictionary containing
    "success" as false,
    "error" as "Process not paused for stepping: " concatenated with process_state["state"],
    "process_id" as process_id Note: Get current instruction information
    Let current_ip be get_process_instruction_pointer with process_id as process_id
    Let instruction_info be analyze_instruction_at_address with 
    process_id as process_id and 
    address as current_ip Note: Enable single-step mode for current thread
    Let single_step_result be enable_single_step_mode with 
    process_id as process_id and 
    thread_id as process_state["current_thread_id"] If not single_step_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to enable single-step mode: " concatenated with single_step_result["error"],
    "process_id" as process_id Note: Resume process for single step
    Let resume_result be resume_process_for_single_step with process_id as process_id Note: Wait for step completion
    Let step_completion be wait_for_step_completion with 
    process_id as process_id and 
    timeout_ms as 5000 and 
    step_type as "step_into" Note: If stepped into function, update call stack context
    Let final_address be step_completion["final_address"]
    Let call_stack_updated be false
    If instruction_info["is_function_call"] and step_completion["success"]:
    Let stack_update_result be update_call_stack_context with process_id as process_id
    Set call_stack_updated to stack_update_result["success"] Let step_end_time be TimeCore.get_system_time_nanoseconds
    Let step_duration_ms be (step_end_time - step_start_time) divided by 1000000 Return dictionary containing
    "success" as step_completion["success"],
    "process_id" as process_id,
    "step_type" as "step_into",
    "previous_address" as current_ip,
    "current_address" as final_address,
    "entered_function" as instruction_info["is_function_call"],
    "function_name" as if instruction_info["is_function_call"] then step_completion["function_entered"] else None,
    "call_stack_updated" as call_stack_updated,
    "step_duration_ms" as step_duration_ms,
    "timestamp" as step_end_time

Process called "execute_step_out" that takes process_id as Integer returns Dictionary[String, Any]:
    Note: Execute step out of current function to caller
    Let step_start_time be TimeCore.get_system_time_nanoseconds Note: Validate process is paused
    Let process_state be get_process_debug_state with process_id as process_id
    If process_state["state"] is not equal to "paused" and process_state["state"] is not equal to "breakpoint_hit":
    Return dictionary containing
    "success" as false,
    "error" as "Process not paused for stepping: " concatenated with process_state["state"],
    "process_id" as process_id Note: Get current call stack to find return address
    Let current_call_stack be capture_current_call_stack with process_id as process_id
    If length of current_call_stack is less than 2:
    Return dictionary containing
    "success" as false,
    "error" as "Cannot step out: no caller function found",
    "process_id" as process_id,
    "call_stack_depth" as length of current_call_stack Note: Calculate return address from call stack
    Let current_frame be current_call_stack[0]
    Let caller_frame be current_call_stack[1]
    Let return_address be caller_frame.instruction_pointer Note: Install temporary breakpoint at return address
    Let return_breakpoint_result be install_temporary_breakpoint with 
    process_id as process_id and 
    address as return_address and 
    breakpoint_type as "step_out"
    If not return_breakpoint_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to install return breakpoint: " concatenated with return_breakpoint_result["error"],
    "process_id" as process_id Note: Resume process to continue until return
    Let resume_result be resume_process_until_breakpoint with process_id as process_id Note: Wait for step-out completion
    Let step_completion be wait_for_step_completion with 
    process_id as process_id and 
    timeout_ms as 10000 and 
    step_type as "step_out" Note: Clean up temporary return breakpoint
    remove_temporary_breakpoint with 
    process_id as process_id and 
    breakpoint_id as return_breakpoint_result["breakpoint_id"] Note: Update call stack context after step out
    Let stack_update_result be update_call_stack_context with process_id as process_id Let step_end_time be TimeCore.get_system_time_nanoseconds
    Let step_duration_ms be (step_end_time - step_start_time) divided by 1000000 Return dictionary containing
    "success" as step_completion["success"],
    "process_id" as process_id,
    "step_type" as "step_out",
    "previous_function" as current_frame.function_name,
    "returned_to_function" as caller_frame.function_name,
    "return_address" as return_address,
    "final_address" as step_completion["final_address"],
    "call_stack_updated" as stack_update_result["success"],
    "step_duration_ms" as step_duration_ms,
    "timestamp" as step_end_time

Process called "pause_process_execution" that takes process_id as Integer returns Dictionary[String, Any]:
    Note: Pause running process execution for debugging
    Let pause_start_time be TimeCore.get_system_time_nanoseconds Note: Check if process is currently running
    Let process_state be get_process_debug_state with process_id as process_id
    If process_state["state"] is not equal to "running":
    Return dictionary containing
    "success" as false,
    "error" as "Process not running, current state: " concatenated with process_state["state"],
    "process_id" as process_id,
    "current_state" as process_state["state"] Note: Suspend all threads in target process
    Let suspension_result be suspend_all_process_threads with process_id as process_id
    If not suspension_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to suspend process threads: " concatenated with suspension_result["error"],
    "process_id" as process_id Note: Capture current execution context
    Let execution_context be capture_execution_context with process_id as process_id Note: Update process debug state
    update_process_debug_state with 
    process_id as process_id and 
    new_state as "paused" and 
    last_operation as "pause" and 
    pause_reason as "user_requested"
    Let pause_end_time be TimeCore.get_system_time_nanoseconds
    Let pause_duration_ms be (pause_end_time - pause_start_time) divided by 1000000 Return dictionary containing
    "success" as true,
    "process_id" as process_id,
    "previous_state" as "running",
    "current_state" as "paused",
    "threads_suspended" as suspension_result["threads_suspended"],
    "current_instruction_pointer" as execution_context["instruction_pointer"],
    "current_function" as execution_context["function_name"],
    "pause_duration_ms" as pause_duration_ms,
    "timestamp" as pause_end_time

Process called "get_global_variable_value" that takes process_id as Integer and variable_name as String returns Any:
    Note: Retrieve global variable value from target process
    Note: Validate process is accessible
    Let process_accessible be check_process_memory_accessible with process_id as process_id
    If not process_accessible:
    Return dictionary containing
    "error" as "Process memory not accessible",
    "variable_name" as variable_name,
    "process_id" as process_id Note: Resolve global variable symbol
    Let symbol_resolution be resolve_global_symbol with 
    process_id as process_id and 
    symbol_name as variable_name If not symbol_resolution["found"]:
    Return dictionary containing
    "error" as "Global variable not found: " concatenated with variable_name,
    "variable_name" as variable_name,
    "process_id" as process_id Note: Read variable value from process memory
    Let memory_read_result be read_process_memory with 
    process_id as process_id and 
    address as symbol_resolution["address"] and 
    size as symbol_resolution["size"] and 
    data_type as symbol_resolution["type"] If not memory_read_result["success"]:
    Return dictionary containing
    "error" as "Failed to read variable memory: " concatenated with memory_read_result["error"],
    "variable_name" as variable_name,
    "process_id" as process_id Note: Convert raw memory to typed value
    Let typed_value be convert_memory_to_typed_value with 
    raw_data as memory_read_result["data"] and 
    data_type as symbol_resolution["type"] and 
    process_id as process_id Return typed_value["value"]

Process called "set_variable_value_in_process" that takes process_id as Integer and frame_index as Integer and variable_name as String and value as Any returns Dictionary[String, Any]:
    Note: Set variable value in specific stack frame of target process
    Let modification_start_time be TimeCore.get_system_time_nanoseconds Note: Validate process is accessible and paused
    Let process_state be get_process_debug_state with process_id as process_id
    If process_state["state"] is not equal to "paused" and process_state["state"] is not equal to "breakpoint_hit":
    Return dictionary containing
    "success" as false,
    "error" as "Process must be paused to modify variables",
    "process_id" as process_id,
    "variable_name" as variable_name Note: Get current call stack
    Let call_stack be capture_current_call_stack with process_id as process_id
    If frame_index is greater than or equal to length of call_stack:
    Return dictionary containing
    "success" as false,
    "error" as "Invalid frame index: " concatenated with convert_integer_to_string with number as frame_index,
    "process_id" as process_id,
    "frame_index" as frame_index,
    "call_stack_depth" as length of call_stack Note: Find variable in specified frame
    Let target_frame be call_stack[frame_index]
    Let variable_info be find_variable_in_frame with 
    frame as target_frame and 
    variable_name as variable_name and 
    process_id as process_id If not variable_info["found"]:
    Return dictionary containing
    "success" as false,
    "error" as "Variable not found in frame: " concatenated with variable_name,
    "process_id" as process_id,
    "frame_index" as frame_index,
    "variable_name" as variable_name Note: Validate type compatibility
    Let type_compatible be check_type_compatibility with 
    target_type as variable_info["type"] and 
    new_value as value If not type_compatible["compatible"]:
    Return dictionary containing
    "success" as false,
    "error" as "Type incompatible: cannot assign " concatenated with type_compatible["value_type"] concatenated with " to " concatenated with variable_info["type"],
    "process_id" as process_id,
    "variable_name" as variable_name Note: Convert value to target process format
    Let converted_value be convert_value_for_process with 
    value as value and 
    target_type as variable_info["type"] and 
    process_id as process_id Note: Write new value to process memory
    Let memory_write_result be write_process_memory with 
    process_id as process_id and 
    address as variable_info["memory_address"] and 
    data as converted_value["raw_data"] and 
    size as variable_info["size"] If not memory_write_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Failed to write variable memory: " concatenated with memory_write_result["error"],
    "process_id" as process_id,
    "variable_name" as variable_name Let modification_end_time be TimeCore.get_system_time_nanoseconds
    Let modification_duration_ms be (modification_end_time - modification_start_time) divided by 1000000 Return dictionary containing
    "success" as true,
    "process_id" as process_id,
    "frame_index" as frame_index,
    "variable_name" as variable_name,
    "previous_value" as variable_info["current_value"],
    "new_value" as value,
    "variable_type" as variable_info["type"],
    "modification_duration_ms" as modification_duration_ms,
    "timestamp" as modification_end_time

Process called "get_variable_type" that takes session as DebugSession and variable_name as String returns String:
    Note: Get variable type from current debug context
    Note: Check current frame for local variables
    Let current_frame_index be session.current_frame_index
    Let call_stack be capture_current_call_stack with process_id as session.target_process_id If current_frame_index is greater than or equal to length of call_stack:
    Return "Unknown"
    Let current_frame be call_stack[current_frame_index] Note: Search in local variables first
    If variable_name in current_frame.local_variables:
    Let variable_info be get_variable_debug_info with 
    process_id as session.target_process_id and 
    frame as current_frame and 
    variable_name as variable_name
    Return variable_info["type"] Note: Search in function arguments
    If variable_name in current_frame.arguments:
    Let argument_info be get_argument_debug_info with 
    process_id as session.target_process_id and 
    frame as current_frame and 
    argument_name as variable_name
    Return argument_info["type"] Note: Search in global variables
    Let global_symbol be resolve_global_symbol with 
    process_id as session.target_process_id and 
    symbol_name as variable_name If global_symbol["found"]:
    Return global_symbol["type"] Note: Check if it's a type name or constant
    Let type_resolution be resolve_type_name with 
    variable_name as variable_name and 
    process_id as session.target_process_id If type_resolution["is_type"]:
    Return "Type"
    Return "Unknown"

Process called "validate_debug_expression" that takes expression as String returns Dictionary[String, Any]:
    Note: Validate debug expression syntax and semantics
    Let validation_start_time be TimeCore.get_system_time_nanoseconds Note: Check for empty or null expression
    If expression is equal to "" or expression is None:
    Return dictionary containing
    "is_valid" as false,
    "error" as "Expression cannot be empty",
    "expression" as expression Note: Basic syntax validation using expression parser
    Let syntax_validation be parse_expression_syntax with expression as expression
    If not syntax_validation["valid"]:
    Return dictionary containing
    "is_valid" as false,
    "error" as "Syntax error: " concatenated with syntax_validation["error"],
    "expression" as expression,
    "error_position" as syntax_validation["error_position"] Note: Check for dangerous operations
    Let safety_check be check_expression_safety with expression as expression
    If not safety_check["safe"]:
    Return dictionary containing
    "is_valid" as false,
    "error" as "Unsafe operation detected: " concatenated with safety_check["danger_type"],
    "expression" as expression,
    "dangerous_operations" as safety_check["operations"] Note: Validate variable references exist
    Let variables_referenced be extract_variable_references with expression as expression
    Let unknown_variables be list containing For each variable_name in variables_referenced:
    Let variable_exists be check_variable_exists_in_any_scope with variable_name as variable_name
    If not variable_exists:
    Add to unknown_variables variable_name If length of unknown_variables is greater than 0:
    Return dictionary containing
    "is_valid" as false,
    "error" as "Unknown variables: " concatenated with join_strings with strings as unknown_variables and separator as ", ",
    "expression" as expression,
    "unknown_variables" as unknown_variables Note: Compile expression for evaluation
    Let compilation_result be compile_debug_expression with 
    expression as expression and 
    syntax_tree as syntax_validation["syntax_tree"] If not compilation_result["success"]:
    Return dictionary containing
    "is_valid" as false,
    "error" as "Compilation failed: " concatenated with compilation_result["error"],
    "expression" as expression Let validation_end_time be TimeCore.get_system_time_nanoseconds
    Let validation_duration_ms be (validation_end_time - validation_start_time) divided by 1000000 Return dictionary containing
    "is_valid" as true,
    "expression" as expression,
    "compiled_expression" as compilation_result["compiled_code"],
    "referenced_variables" as variables_referenced,
    "expected_return_type" as syntax_validation["return_type"],
    "validation_duration_ms" as validation_duration_ms

Process called "evaluate_expression_in_process" that takes process_id as Integer and frame_index as Integer and expression as String returns Dictionary[String, Any]:
    Note: Evaluate debug expression in specific process frame context
    Let evaluation_start_time be TimeCore.get_system_time_nanoseconds Note: Validate expression first
    Let expression_validation be validate_debug_expression with expression as expression
    If not expression_validation["is_valid"]:
    Return dictionary containing
    "success" as false,
    "error" as "Invalid expression: " concatenated with expression_validation["error"],
    "expression" as expression Note: Ensure process is in debuggable state
    Let process_state be get_process_debug_state with process_id as process_id
    If process_state["state"] is not equal to "paused" and process_state["state"] is not equal to "breakpoint_hit":
    Return dictionary containing
    "success" as false,
    "error" as "Process must be paused for expression evaluation",
    "process_id" as process_id,
    "expression" as expression Note: Get call stack and validate frame index
    Let call_stack be capture_current_call_stack with process_id as process_id
    If frame_index is greater than or equal to length of call_stack:
    Return dictionary containing
    "success" as false,
    "error" as "Invalid frame index: " concatenated with convert_integer_to_string with number as frame_index,
    "process_id" as process_id,
    "frame_index" as frame_index Note: Set up evaluation context
    Let evaluation_frame be call_stack[frame_index]
    Let evaluation_context be create_expression_evaluation_context with 
    process_id as process_id and 
    frame as evaluation_frame and 
    local_variables as evaluation_frame.local_variables and 
    arguments as evaluation_frame.arguments Note: Execute expression in safe evaluation environment
    Let execution_result be execute_compiled_expression with 
    compiled_expression as expression_validation["compiled_expression"] and 
    evaluation_context as evaluation_context and 
    timeout_ms as 5000 and 
    process_id as process_id If not execution_result["success"]:
    Return dictionary containing
    "success" as false,
    "error" as "Expression evaluation failed: " concatenated with execution_result["error"],
    "expression" as expression,
    "process_id" as process_id,
    "frame_index" as frame_index Note: Convert result to debugger-friendly format
    Let formatted_result be format_evaluation_result with 
    raw_result as execution_result["result"] and 
    result_type as execution_result["result_type"] and 
    process_id as process_id Let evaluation_end_time be TimeCore.get_system_time_nanoseconds
    Let evaluation_duration_ms be (evaluation_end_time - evaluation_start_time) divided by 1000000 Return dictionary containing
    "success" as true,
    "value" as formatted_result["display_value"],
    "raw_value" as execution_result["result"],
    "value_type" as execution_result["result_type"],
    "expression" as expression,
    "process_id" as process_id,
    "frame_index" as frame_index,
    "evaluation_duration_ms" as evaluation_duration_ms,
    "memory_address" as if formatted_result["has_address"] then formatted_result["memory_address"] else None,
    "timestamp" as evaluation_end_time

Process called "refresh_current_frame_variables" that takes session as DebugSession returns Boolean:
