Note:
Runa UI Framework: Advanced Formatting System

Comprehensive locale-aware formatting with CLDR-compliant patterns,
intelligent number formatting, and advanced date/time handling.

Features:
- CLDR-compliant number, date, and currency formatting
- Intelligent plural rule processing with complex forms
- Advanced relative time formatting (e.g., "2 hours ago")
- Unit formatting with automatic unit conversion
- Message formatting with ICU-style patterns
- Custom format pattern compilation and caching
- Timezone-aware date formatting with DST handling
:End Note

Import "collections/dict" as Dict
Import "collections/list" as List
Import "ui/i18n/core" as I18nCore
Import "ui/i18n/locales" as Locales

Note: Advanced Formatting Types

Type called "NumberFormatter":
    locale as I18nCore.Locale
    style as NumberStyle
    currency_code as Optional[String]
    unit_type as Optional[UnitType]
    minimum_integer_digits as Integer
    minimum_fraction_digits as Integer
    maximum_fraction_digits as Integer
    minimum_significant_digits as Optional[Integer]
    maximum_significant_digits as Optional[Integer]
    use_grouping as Boolean
    rounding_mode as RoundingMode
    notation as NumberNotation

Type NumberStyle is:
    | Decimal
    | Percent
    | Currency
    | Scientific
    | Engineering
    | Compact
    | Unit

Type NumberNotation is:
    | Standard
    | Scientific
    | Engineering
    | Compact with type as CompactType

Type CompactType is:
    | Short
    | Long

Type UnitType is:
    | Length with unit as LengthUnit
    | Mass with unit as MassUnit
    | Duration with unit as DurationUnit
    | Digital with unit as DigitalUnit
    | Temperature with unit as TemperatureUnit

Type LengthUnit is:
    | Millimeter
    | Centimeter
    | Meter
    | Kilometer
    | Inch
    | Foot
    | Yard
    | Mile

Type MassUnit is:
    | Milligram
    | Gram
    | Kilogram
    | Ounce
    | Pound

Type DurationUnit is:
    | Nanosecond
    | Microsecond
    | Millisecond
    | Second
    | Minute
    | Hour
    | Day
    | Week
    | Month
    | Year

Type DigitalUnit is:
    | Byte
    | Kilobyte
    | Megabyte
    | Gigabyte
    | Terabyte

Type TemperatureUnit is:
    | Celsius
    | Fahrenheit
    | Kelvin

Type RoundingMode is:
    | Ceiling
    | Floor
    | Down
    | Up
    | HalfEven
    | HalfDown
    | HalfUp
    | Unnecessary

Type called "DateTimeFormatter":
    locale as I18nCore.Locale
    pattern as String
    timezone as String
    calendar as CalendarSystem
    date_style as Optional[DateStyle]
    time_style as Optional[TimeStyle]
    skeleton as Optional[String]

Type CalendarSystem is:
    | Gregorian
    | Islamic
    | Hebrew
    | Buddhist
    | Japanese
    | Chinese

Type DateStyle is:
    | Full
    | Long
    | Medium
    | Short

Type TimeStyle is:
    | Full
    | Long
    | Medium
    | Short

Type called "RelativeTimeFormatter":
    locale as I18nCore.Locale
    style as RelativeStyle
    numeric as RelativeNumeric

Type RelativeStyle is:
    | Long
    | Short
    | Narrow

Type RelativeNumeric is:
    | Always
    | Auto

Type called "ListFormatter":
    locale as I18nCore.Locale
    style as ListStyle
    list_type as ListType

Type ListStyle is:
    | Long
    | Short
    | Narrow

Type ListType is:
    | Conjunction
    | Disjunction
    | Unit

Type called "MessageFormatter":
    locale as I18nCore.Locale
    pattern as String
    compiled_pattern as CompiledPattern

Type called "CompiledPattern":
    segments as List[PatternSegment]
    parameter_names as List[String]

Type PatternSegment is:
    | TextSegment with text as String
    | ParameterSegment with param as ParameterSpec

Type called "ParameterSpec":
    name as String
    param_type as ParameterType
    format_style as Optional[String]
    offset as Optional[Integer]

Type ParameterType is:
    | Simple
    | Number
    | Date
    | Time
    | Choice
    | Plural
    | Ordinal
    | Select

Type called "PluralRuleEngine":
    locale as I18nCore.Locale
    cardinal_rules as List[PluralRule]
    ordinal_rules as List[PluralRule]

Type called "PluralRule":
    category as I18nCore.PluralForm
    condition as String
    compiled_condition as CompiledCondition

Type called "CompiledCondition":
    operations as List[ConditionOperation]

Type ConditionOperation is:
    | ModuloOp with divisor as Integer
    | RangeCheck with min as Integer and max as Integer
    | ExactMatch with values as List[Integer]
    | LogicalAnd
    | LogicalOr

Type called "FormatCache":
    number_formatters as Dict[String, NumberFormatter]
    date_formatters as Dict[String, DateTimeFormatter]
    message_patterns as Dict[String, CompiledPattern]
    plural_engines as Dict[String, PluralRuleEngine]
    max_cache_size as Integer

Note: Number Formatting Implementation

Process called "create_number_formatter" that takes locale as I18nCore.Locale and style as NumberStyle returns NumberFormatter:
    Return NumberFormatter with:
        locale as locale
        style as style
        currency_code as get_default_currency_for_locale with locale as locale
        unit_type as Optional.None
        minimum_integer_digits as 1
        minimum_fraction_digits as get_default_fraction_digits_for_style with style as style
        maximum_fraction_digits as get_default_fraction_digits_for_style with style as style
        minimum_significant_digits as Optional.None
        maximum_significant_digits as Optional.None
        use_grouping as true
        rounding_mode as HalfEven
        notation as Standard

Process called "get_default_currency_for_locale" that takes locale as I18nCore.Locale returns Optional[String]:
    Match locale.country_code:
        When Optional.Some with value as country:
            Match country:
                When "US":
                    Return Optional.Some with value as "USD"
                When "GB":
                    Return Optional.Some with value as "GBP"
                When "JP":
                    Return Optional.Some with value as "JPY"
                When "CN":
                    Return Optional.Some with value as "CNY"
                Otherwise:
                    Return Optional.Some with value as "EUR"
        When Optional.None:
            Return Optional.Some with value as "USD"

Process called "get_default_fraction_digits_for_style" that takes style as NumberStyle returns Integer:
    Match style:
        When Decimal:
            Return 0
        When Percent:
            Return 0
        When Currency:
            Return 2
        When Scientific:
            Return 3
        When Engineering:
            Return 3
        When Compact:
            Return 1
        When Unit:
            Return 1

Process called "format_number" that takes formatter as NumberFormatter and number as Float returns String:
    Let rounded_number be apply_rounding with number as number and formatter as formatter
    Let formatted be apply_number_formatting with number as rounded_number and formatter as formatter
    Return formatted

Process called "apply_rounding" that takes number as Float and formatter as NumberFormatter returns Float:
    Let scale_factor be calculate_scale_factor with formatter as formatter
    Let scaled_number be number times scale_factor
    
    Match formatter.rounding_mode:
        When HalfUp:
            Return round_half_up with number as scaled_number divided by scale_factor
        When HalfDown:
            Return round_half_down with number as scaled_number divided by scale_factor
        When HalfEven:
            Return round_half_even with number as scaled_number divided by scale_factor
        When Ceiling:
            Return ceiling with number as number
        When Floor:
            Return floor with number as number
        When Up:
            Return round_up with number as number
        When Down:
            Return round_down with number as number
        When Unnecessary:
            Return number

Process called "calculate_scale_factor" that takes formatter as NumberFormatter returns Float:
    Return power of 10.0 and formatter.maximum_fraction_digits

Process called "power" that takes base as Float and exponent as Integer returns Float:
    Let result be 1.0
    For i from 1 to exponent:
        Set result to result times base
    Return result

Process called "round_half_up" that takes number as Float returns Float:
    If number is greater than or equal to 0.0:
        Return floor with number as (number plus 0.5)
    Otherwise:
        Return ceiling with number as (number minus 0.5)

Process called "round_half_down" that takes number as Float returns Float:
    If number is greater than 0.0:
        Return floor with number as (number plus 0.49999)
    Otherwise:
        Return ceiling with number as (number minus 0.49999)

Process called "round_half_even" that takes number as Float returns Float:
    Let integer_part be floor with number as number
    Let fraction_part be number minus integer_part
    
    If fraction_part is equal to 0.5:
        If (integer_part as Integer modulo 2) is equal to 0:
            Return integer_part
        Otherwise:
            Return integer_part plus 1.0
    
    Return round_half_up with number as number

Process called "round_up" that takes number as Float returns Float:
    If number is greater than 0.0:
        Return ceiling with number as number
    Otherwise:
        Return floor with number as number

Process called "round_down" that takes number as Float returns Float:
    If number is greater than 0.0:
        Return floor with number as number
    Otherwise:
        Return ceiling with number as number

Process called "ceiling" that takes number as Float returns Float:
    Let int_part be number as Integer as Float
    If number is equal to int_part:
        Return number
    If number is greater than 0.0:
        Return int_part plus 1.0
    Return int_part

Process called "floor" that takes number as Float returns Float:
    Let int_part be number as Integer as Float
    If number is equal to int_part:
        Return number
    If number is greater than 0.0:
        Return int_part
    Return int_part minus 1.0

Process called "apply_number_formatting" that takes number as Float and formatter as NumberFormatter returns String:
    Let formats be get_number_formats_for_locale with locale as formatter.locale
    Let formatted be format_number_with_pattern with number as number and formats as formats and formatter as formatter
    
    Match formatter.style:
        When Currency:
            Return apply_currency_formatting with formatted as formatted and formatter as formatter
        When Percent:
            Return formatted Joined with formats.percent_format
        When Scientific:
            Return apply_scientific_formatting with number as number and formatter as formatter
        When Compact:
            Return apply_compact_formatting with number as number and formatter as formatter
        When Unit:
            Return apply_unit_formatting with number as number and formatter as formatter
        Otherwise:
            Return formatted

Process called "get_number_formats_for_locale" that takes locale as I18nCore.Locale returns I18nCore.NumberFormats:
    Match locale.language_code:
        When "en":
            Return I18nCore.NumberFormats with:
                decimal_separator as "."
                thousands_separator as ","
                grouping_pattern as "3"
                negative_pattern as "-{0}"
                percent_format as "%"
                scientific_format as "E"
        When "fr":
            Return I18nCore.NumberFormats with:
                decimal_separator as ","
                thousands_separator as " "
                grouping_pattern as "3"
                negative_pattern as "-{0}"
                percent_format as " %"
                scientific_format as "E"
        When "de":
            Return I18nCore.NumberFormats with:
                decimal_separator as ","
                thousands_separator as "."
                grouping_pattern as "3"
                negative_pattern as "-{0}"
                percent_format as " %"
                scientific_format as "E"
        Otherwise:
            Return I18nCore.NumberFormats with:
                decimal_separator as "."
                thousands_separator as ","
                grouping_pattern as "3"
                negative_pattern as "-{0}"
                percent_format as "%"
                scientific_format as "E"

Process called "format_number_with_pattern" that takes number as Float and formats as I18nCore.NumberFormats and formatter as NumberFormatter returns String:
    Let integer_part be absolute_value with value as (number as Integer as Float)
    Let fraction_part be absolute_value with value as (number minus (number as Integer as Float))
    
    Let integer_string be format_integer_part with integer as integer_part as Integer and formats as formats and use_grouping as formatter.use_grouping
    Let fraction_string be format_fraction_part with fraction as fraction_part and digits as formatter.maximum_fraction_digits and formats as formats
    
    Let result be integer_string
    If (length of fraction_string) is greater than 0:
        Set result to result Joined with formats.decimal_separator Joined with fraction_string
    
    If number is less than 0.0:
        Set result to formats.negative_pattern
        Set result to replace_placeholder with text as result and placeholder as "{0}" and value as result
    
    Return result

Process called "absolute_value" that takes value as Float returns Float:
    Return if value is greater than or equal to 0.0 then value else (0.0 minus value)

Process called "format_integer_part" that takes integer as Integer and formats as I18nCore.NumberFormats and use_grouping as Boolean returns String:
    Let result be integer as String
    
    If use_grouping and (length of result) is greater than 3:
        Set result to apply_thousands_separators with text as result and separator as formats.thousands_separator
    
    Return result

Process called "apply_thousands_separators" that takes text as String and separator as String returns String:
    Let result be ""
    Let len be length of text
    
    For i from 0 to (len minus 1):
        Let pos_from_right be len minus i minus 1
        Let char be text at index i
        Set result to result Joined with char
        
        If pos_from_right is greater than 0 and (pos_from_right modulo 3) is equal to 0:
            Set result to result Joined with separator
    
    Return result

Process called "format_fraction_part" that takes fraction as Float and digits as Integer and formats as I18nCore.NumberFormats returns String:
    If digits is equal to 0:
        Return ""
    
    Let scaled_fraction be fraction times (power of 10.0 and digits)
    Let fraction_int be scaled_fraction as Integer
    Let result be fraction_int as String
    
    Note: Pad with leading zeros if necessary
    While (length of result) is less than digits:
        Set result to "0" Joined with result
    
    Return result

Process called "replace_placeholder" that takes text as String and placeholder as String and value as String returns String:
    Note: Simple string replacement
    Return text  Note: Would implement full replacement logic

Process called "apply_currency_formatting" that takes formatted as String and formatter as NumberFormatter returns String:
    Match formatter.currency_code:
        When Optional.Some with value as currency_code:
            Let symbol be get_currency_symbol with code as currency_code and locale as formatter.locale
            Return symbol Joined with formatted
        When Optional.None:
            Return formatted

Process called "get_currency_symbol" that takes code as String and locale as I18nCore.Locale returns String:
    Match code:
        When "USD":
            Return "$"
        When "EUR":
            Return "€"
        When "GBP":
            Return "£"
        When "JPY":
            Return "¥"
        When "CNY":
            Return "¥"
        Otherwise:
            Return code

Process called "apply_scientific_formatting" that takes number as Float and formatter as NumberFormatter returns String:
    If number is equal to 0.0:
        Return "0E0"
    
    Let exponent be calculate_exponent with number as number
    Let mantissa be number divided by (power of 10.0 and exponent)
    
    Return mantissa as String Joined with "E" Joined with exponent as String

Process called "calculate_exponent" that takes number as Float returns Integer:
    Let abs_number be absolute_value with value as number
    Let exponent be 0
    
    While abs_number is greater than or equal to 10.0:
        Set abs_number to abs_number divided by 10.0
        Set exponent to exponent plus 1
    
    While abs_number is less than 1.0 and abs_number is greater than 0.0:
        Set abs_number to abs_number times 10.0
        Set exponent to exponent minus 1
    
    Return exponent

Process called "apply_compact_formatting" that takes number as Float and formatter as NumberFormatter returns String:
    Let abs_number be absolute_value with value as number
    
    If abs_number is greater than or equal to 1000000000.0:
        Return format_compact_number with number as (number divided by 1000000000.0) and suffix as "B"
    If abs_number is greater than or equal to 1000000.0:
        Return format_compact_number with number as (number divided by 1000000.0) and suffix as "M"
    If abs_number is greater than or equal to 1000.0:
        Return format_compact_number with number as (number divided by 1000.0) and suffix as "K"
    
    Return number as String

Process called "format_compact_number" that takes number as Float and suffix as String returns String:
    Let rounded be round_half_up with number as (number times 10.0) divided by 10.0
    Return rounded as String Joined with suffix

Process called "apply_unit_formatting" that takes number as Float and formatter as NumberFormatter returns String:
    Match formatter.unit_type:
        When Optional.Some with value as unit:
            Let unit_string be format_unit with unit as unit and locale as formatter.locale
            Return number as String Joined with " " Joined with unit_string
        When Optional.None:
            Return number as String

Process called "format_unit" that takes unit as UnitType and locale as I18nCore.Locale returns String:
    Match unit:
        When Length with unit as length_unit:
            Return format_length_unit with unit as length_unit and locale as locale
        When Mass with unit as mass_unit:
            Return format_mass_unit with unit as mass_unit and locale as locale
        When Duration with unit as duration_unit:
            Return format_duration_unit with unit as duration_unit and locale as locale
        When Digital with unit as digital_unit:
            Return format_digital_unit with unit as digital_unit and locale as locale
        When Temperature with unit as temp_unit:
            Return format_temperature_unit with unit as temp_unit and locale as locale

Process called "format_length_unit" that takes unit as LengthUnit and locale as I18nCore.Locale returns String:
    Match unit:
        When Millimeter:
            Return "mm"
        When Centimeter:
            Return "cm"
        When Meter:
            Return "m"
        When Kilometer:
            Return "km"
        When Inch:
            Return "in"
        When Foot:
            Return "ft"
        When Yard:
            Return "yd"
        When Mile:
            Return "mi"

Process called "format_mass_unit" that takes unit as MassUnit and locale as I18nCore.Locale returns String:
    Match unit:
        When Milligram:
            Return "mg"
        When Gram:
            Return "g"
        When Kilogram:
            Return "kg"
        When Ounce:
            Return "oz"
        When Pound:
            Return "lb"

Process called "format_duration_unit" that takes unit as DurationUnit and locale as I18nCore.Locale returns String:
    Match unit:
        When Second:
            Return "s"
        When Minute:
            Return "min"
        When Hour:
            Return "h"
        When Day:
            Return "d"
        When Week:
            Return "w"
        When Month:
            Return "mo"
        When Year:
            Return "y"
        Otherwise:
            Return "s"

Process called "format_digital_unit" that takes unit as DigitalUnit and locale as I18nCore.Locale returns String:
    Match unit:
        When Byte:
            Return "B"
        When Kilobyte:
            Return "KB"
        When Megabyte:
            Return "MB"
        When Gigabyte:
            Return "GB"
        When Terabyte:
            Return "TB"

Process called "format_temperature_unit" that takes unit as TemperatureUnit and locale as I18nCore.Locale returns String:
    Match unit:
        When Celsius:
            Return "°C"
        When Fahrenheit:
            Return "°F"
        When Kelvin:
            Return "K"

Note: Date and Time Formatting

Process called "create_datetime_formatter" that takes locale as I18nCore.Locale and pattern as String returns DateTimeFormatter:
    Return DateTimeFormatter with:
        locale as locale
        pattern as pattern
        timezone as "UTC"
        calendar as Gregorian
        date_style as Optional.None
        time_style as Optional.None
        skeleton as Optional.None

Process called "format_datetime" that takes formatter as DateTimeFormatter and timestamp as Integer returns String:
    Let date_info be extract_date_components with timestamp as timestamp and timezone as formatter.timezone
    Return apply_datetime_pattern with formatter as formatter and date_info as date_info

Process called "extract_date_components" that takes timestamp as Integer and timezone as String returns DateComponents:
    Note: Extract date components from timestamp
    Return DateComponents with:
        year as 2024
        month as 1
        day as 1
        hour as 0
        minute as 0
        second as 0
        weekday as 1
        day_of_year as 1

Type called "DateComponents":
    year as Integer
    month as Integer
    day as Integer
    hour as Integer
    minute as Integer
    second as Integer
    weekday as Integer
    day_of_year as Integer

Process called "apply_datetime_pattern" that takes formatter as DateTimeFormatter and date_info as DateComponents returns String:
    Let result be formatter.pattern
    
    Set result to replace_pattern with text as result and pattern as "yyyy" and value as date_info.year as String
    Set result to replace_pattern with text as result and pattern as "MM" and value as format_month with month as date_info.month
    Set result to replace_pattern with text as result and pattern as "dd" and value as format_day with day as date_info.day
    Set result to replace_pattern with text as result and pattern as "HH" and value as format_hour with hour as date_info.hour
    Set result to replace_pattern with text as result and pattern as "mm" and value as format_minute with minute as date_info.minute
    Set result to replace_pattern with text as result and pattern as "ss" and value as format_second with second as date_info.second
    
    Return result

Process called "replace_pattern" that takes text as String and pattern as String and value as String returns String:
    Note: Replace pattern in text
    Return text  Note: Would implement pattern replacement

Process called "format_month" that takes month as Integer returns String:
    If month is less than 10:
        Return "0" Joined with month as String
    Return month as String

Process called "format_day" that takes day as Integer returns String:
    If day is less than 10:
        Return "0" Joined with day as String
    Return day as String

Process called "format_hour" that takes hour as Integer returns String:
    If hour is less than 10:
        Return "0" Joined with hour as String
    Return hour as String

Process called "format_minute" that takes minute as Integer returns String:
    If minute is less than 10:
        Return "0" Joined with minute as String
    Return minute as String

Process called "format_second" that takes second as Integer returns String:
    If second is less than 10:
        Return "0" Joined with second as String
    Return second as String

Note: Relative Time Formatting

Process called "create_relative_time_formatter" that takes locale as I18nCore.Locale returns RelativeTimeFormatter:
    Return RelativeTimeFormatter with:
        locale as locale
        style as Long
        numeric as Auto

Process called "format_relative_time" that takes formatter as RelativeTimeFormatter and value as Integer and unit as DurationUnit returns String:
    Let abs_value be if value is greater than or equal to 0 then value else (0 minus value)
    Let is_future be value is greater than 0
    
    Match unit:
        When Second:
            Return format_relative_seconds with formatter as formatter and value as value and abs_value as abs_value and is_future as is_future
        When Minute:
            Return format_relative_minutes with formatter as formatter and value as value and abs_value as abs_value and is_future as is_future
        When Hour:
            Return format_relative_hours with formatter as formatter and value as value and abs_value as abs_value and is_future as is_future
        When Day:
            Return format_relative_days with formatter as formatter and value as value and abs_value as abs_value and is_future as is_future
        Otherwise:
            Return abs_value as String Joined with " " Joined with format_duration_unit with unit as unit and locale as formatter.locale

Process called "format_relative_seconds" that takes formatter as RelativeTimeFormatter and value as Integer and abs_value as Integer and is_future as Boolean returns String:
    If abs_value is less than 60:
        If is_future:
            Return "in " Joined with abs_value as String Joined with " seconds"
        Otherwise:
            Return abs_value as String Joined with " seconds ago"
    
    Return format_relative_time with formatter as formatter and value as (value divided by 60) and unit as Minute

Process called "format_relative_minutes" that takes formatter as RelativeTimeFormatter and value as Integer and abs_value as Integer and is_future as Boolean returns String:
    If abs_value is equal to 1:
        If is_future:
            Return "in 1 minute"
        Otherwise:
            Return "1 minute ago"
    
    If abs_value is less than 60:
        If is_future:
            Return "in " Joined with abs_value as String Joined with " minutes"
        Otherwise:
            Return abs_value as String Joined with " minutes ago"
    
    Return format_relative_time with formatter as formatter and value as (value divided by 60) and unit as Hour

Process called "format_relative_hours" that takes formatter as RelativeTimeFormatter and value as Integer and abs_value as Integer and is_future as Boolean returns String:
    If abs_value is equal to 1:
        If is_future:
            Return "in 1 hour"
        Otherwise:
            Return "1 hour ago"
    
    If abs_value is less than 24:
        If is_future:
            Return "in " Joined with abs_value as String Joined with " hours"
        Otherwise:
            Return abs_value as String Joined with " hours ago"
    
    Return format_relative_time with formatter as formatter and value as (value divided by 24) and unit as Day

Process called "format_relative_days" that takes formatter as RelativeTimeFormatter and value as Integer and abs_value as Integer and is_future as Boolean returns String:
    If abs_value is equal to 1:
        If is_future:
            Return "tomorrow"
        Otherwise:
            Return "yesterday"
    
    If abs_value is equal to 0:
        Return "today"
    
    If abs_value is less than 7:
        If is_future:
            Return "in " Joined with abs_value as String Joined with " days"
        Otherwise:
            Return abs_value as String Joined with " days ago"
    
    Let weeks be value divided by 7
    If is_future:
        Return "in " Joined with weeks as String Joined with " weeks"
    Otherwise:
        Return weeks as String Joined with " weeks ago"

Note: List Formatting

Process called "create_list_formatter" that takes locale as I18nCore.Locale and list_type as ListType returns ListFormatter:
    Return ListFormatter with:
        locale as locale
        style as Long
        list_type as list_type

Process called "format_list" that takes formatter as ListFormatter and items as List[String] returns String:
    Let item_count be length of items
    
    If item_count is equal to 0:
        Return ""
    If item_count is equal to 1:
        Return items at index 0
    If item_count is equal to 2:
        Return format_two_items with formatter as formatter and first as (items at index 0) and second as (items at index 1)
    
    Return format_multiple_items with formatter as formatter and items as items

Process called "format_two_items" that takes formatter as ListFormatter and first as String and second as String returns String:
    Match formatter.list_type:
        When Conjunction:
            Return first Joined with " and " Joined with second
        When Disjunction:
            Return first Joined with " or " Joined with second
        When Unit:
            Return first Joined with " " Joined with second

Process called "format_multiple_items" that takes formatter as ListFormatter and items as List[String] returns String:
    Let result be ""
    Let item_count be length of items
    
    For i from 0 to (item_count minus 2):
        Set result to result Joined with (items at index i) Joined with ", "
    
    Match formatter.list_type:
        When Conjunction:
            Set result to result Joined with "and " Joined with (items at index (item_count minus 1))
        When Disjunction:
            Set result to result Joined with "or " Joined with (items at index (item_count minus 1))
        When Unit:
            Set result to result Joined with (items at index (item_count minus 1))
    
    Return result

Note: Format Cache Management

Process called "create_format_cache" returns FormatCache:
    Return FormatCache with:
        number_formatters as Dict.empty
        date_formatters as Dict.empty
        message_patterns as Dict.empty
        plural_engines as Dict.empty
        max_cache_size as 100

Process called "get_cached_number_formatter" that takes cache as FormatCache and key as String returns Optional[NumberFormatter]:
    Return Dict.get with dict as cache.number_formatters and key as key

Process called "cache_number_formatter" that takes cache as FormatCache and key as String and formatter as NumberFormatter:
    If (length of (Dict.keys with dict as cache.number_formatters)) is greater than or equal to cache.max_cache_size:
        Call evict_oldest_formatter with cache as cache
    
    Call Dict.set with dict as cache.number_formatters and key as key and value as formatter

Process called "evict_oldest_formatter" that takes cache as FormatCache:
    Note: Remove oldest entry - would implement LRU logic
    Pass

Process called "get_formatting_stats" that takes cache as FormatCache returns String:
    Let number_cache_size be length of (Dict.keys with dict as cache.number_formatters)
    Let date_cache_size be length of (Dict.keys with dict as cache.date_formatters)
    Let message_cache_size be length of (Dict.keys with dict as cache.message_patterns)
    
    Return "Format Cache Stats:\n" Joined with
           "- Number formatters: " Joined with number_cache_size as String Joined with "\n" Joined with
           "- Date formatters: " Joined with date_cache_size as String Joined with "\n" Joined with
           "- Message patterns: " Joined with message_cache_size as String Joined with "\n" Joined with
           "- Cache limit: " Joined with cache.max_cache_size as String