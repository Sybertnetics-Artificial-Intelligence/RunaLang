Process called "create_japanese_jp_locale" returns ExtendedLocale:
    Let base_locale be I18nCore.Locale with:
        language_code as "ja"
        country_code as Optional.Some with value as "JP"
        script as Optional.Some with value as "Jpan"
        variant as Optional.None
        display_name as "Japanese (Japan)"
        native_name as "日本語（日本）"
        is_rtl as false
    
    Let collation be CollationRules with:
        primary_strength as true
        secondary_strength as false
        tertiary_strength as false
        case_sensitive as false
        numeric_sorting as true
        custom_rules as Optional.Some with value as "&[before 1]ぁ<<あ<<<ア"
    
    Let exemplars be ExemplarCharSets with:
        main_characters as "あ-ん ア-ン 一-龠 ぁ-ゟ"
        auxiliary_characters as "a-z"
        numbers as "0-9 〇 一 二 三 四 五 六 七 八 九 十"
        punctuation as "! \" # % & ' ( ) * + , - . / : ; < = > ? @ [ \\ ] ^ _ ` { | } 。 、 ・ ： ； ？ ！ ー"
        index_characters as "あ か さ た な は ま や ら わ"
    
    Return ExtendedLocale with:
        base as base_locale
        parent_locale as Optional.None
        fallback_chain as create_list_with_items with items as ["ja", "en"]
        cldr_version as "44.0"
        territories as create_list_with_items with items as ["JP"]
        currencies as create_list_with_items with items as ["JPY"]
        collation as collation
        exemplar_characters as exemplars
        measurement_system as Metric
        paper_size as A4
        first_day_of_week as Sunday

