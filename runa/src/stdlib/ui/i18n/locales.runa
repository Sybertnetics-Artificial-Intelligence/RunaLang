Process called "create_territory_mappings" returns Dict[String, List[String]]:
    Let mappings be Dict.empty
    
    Call Dict.set with dict as mappings and key as "US" and value as create_list_with_items with items as ["en", "es"]
    Call Dict.set with dict as mappings and key as "GB" and value as create_list_with_items with items as ["en"]
    Call Dict.set with dict as mappings and key as "CA" and value as create_list_with_items with items as ["en", "fr"]
    Call Dict.set with dict as mappings and key as "FR" and value as create_list_with_items with items as ["fr"]
    Call Dict.set with dict as mappings and key as "DE" and value as create_list_with_items with items as ["de"]
    Call Dict.set with dict as mappings and key as "ES" and value as create_list_with_items with items as ["es"]
    Call Dict.set with dict as mappings and key as "JP" and value as create_list_with_items with items as ["ja"]
    Call Dict.set with dict as mappings and key as "CN" and value as create_list_with_items with items as ["zh"]
    Call Dict.set with dict as mappings and key as "SA" and value as create_list_with_items with items as ["ar"]
    
    Return mappings

Process called "create_language_scripts" returns Dict[String, String]:
    Let scripts be Dict.empty
    
    Call Dict.set with dict as scripts and key as "en" and value as "Latn"
    Call Dict.set with dict as scripts and key as "fr" and value as "Latn"
    Call Dict.set with dict as scripts and key as "de" and value as "Latn"
    Call Dict.set with dict as scripts and key as "es" and value as "Latn"
    Call Dict.set with dict as scripts and key as "ja" and value as "Jpan"
    Call Dict.set with dict as scripts and key as "zh" and value as "Hans"
    Call Dict.set with dict as scripts and key as "ar" and value as "Arab"
    Call Dict.set with dict as scripts and key as "ru" and value as "Cyrl"
    Call Dict.set with dict as scripts and key as "hi" and value as "Deva"
    Call Dict.set with dict as scripts and key as "th" and value as "Thai"
    
    Return scripts

Process called "create_locale_aliases" returns Dict[String, String]:
    Let aliases be Dict.empty
    
    Call Dict.set with dict as aliases and key as "english" and value as "en"
    Call Dict.set with dict as aliases and key as "spanish" and value as "es"
    Call Dict.set with dict as aliases and key as "french" and value as "fr"
    Call Dict.set with dict as aliases and key as "german" and value as "de"
    Call Dict.set with dict as aliases and key as "japanese" and value as "ja"
    Call Dict.set with dict as aliases and key as "chinese" and value as "zh"
    Call Dict.set with dict as aliases and key as "arabic" and value as "ar"
    Call Dict.set with dict as aliases and key as "simplified" and value as "zh_CN"
    Call Dict.set with dict as aliases and key as "traditional" and value as "zh_TW"
    
    Return aliases

Process called "create_default_regions" returns Dict[String, String]:
    Let regions be Dict.empty
    
    Call Dict.set with dict as regions and key as "en" and value as "US"
    Call Dict.set with dict as regions and key as "fr" and value as "FR"
    Call Dict.set with dict as regions and key as "de" and value as "DE"
    Call Dict.set with dict as regions and key as "es" and value as "ES"
    Call Dict.set with dict as regions and key as "ja" and value as "JP"
    Call Dict.set with dict as regions and key as "zh" and value as "CN"
    Call Dict.set with dict as regions and key as "ar" and value as "SA"
    Call Dict.set with dict as regions and key as "ru" and value as "RU"
    Call Dict.set with dict as regions and key as "pt" and value as "BR"
    Call Dict.set with dict as regions and key as "it" and value as "IT"
    
    Return regions

Process called "create_rtl_languages" returns List[String]:
    Let rtl_langs be List.empty
    Call List.append with list as rtl_langs and item as "ar"
    Call List.append with list as rtl_langs and item as "he"
    Call List.append with list as rtl_langs and item as "fa"
    Call List.append with list as rtl_langs and item as "ur"
    Call List.append with list as rtl_langs and item as "yi"
    Call List.append with list as rtl_langs and item as "iw"
    Call List.append with list as rtl_langs and item as "ji"
    Return rtl_langs

Process called "create_plural_rule_mappings" returns Dict[String, String]:
    Let mappings be Dict.empty
    
    Call Dict.set with dict as mappings and key as "en" and value as "one_other"
    Call Dict.set with dict as mappings and key as "fr" and value as "one_other"
    Call Dict.set with dict as mappings and key as "de" and value as "one_other"
    Call Dict.set with dict as mappings and key as "es" and value as "one_other"
    Call Dict.set with dict as mappings and key as "ja" and value as "other_only"
    Call Dict.set with dict as mappings and key as "zh" and value as "other_only"
    Call Dict.set with dict as mappings and key as "ar" and value as "zero_one_two_few_many_other"
    Call Dict.set with dict as mappings and key as "ru" and value as "one_few_many_other"
    Call Dict.set with dict as mappings and key as "pl" and value as "one_few_many_other"
    
    Return mappings

Note: Locale Negotiation

Process called "create_locale_negotiator" that takes supported_locales as List[String] returns LocaleNegotiator:
    Return LocaleNegotiator with:
        supported_locales as supported_locales
        default_locale as "en_US"
        quality_weights as create_default_quality_weights

Process called "create_default_quality_weights" returns Dict[String, Float]:
    Let weights be Dict.empty
    Call Dict.set with dict as weights and key as "exact_match" and value as 1.0
    Call Dict.set with dict as weights and key as "language_match" and value as 0.8
    Call Dict.set with dict as weights and key as "fallback_match" and value as 0.6
    Call Dict.set with dict as weights and key as "default_match" and value as 0.4
    Return weights

Process called "negotiate_locale" that takes negotiator as LocaleNegotiator and accept_languages as List[String] returns String:
    Let best_match be ""
    Let highest_quality be 0.0
    
    For requested_locale in accept_languages:
        Let quality be calculate_locale_quality with negotiator as negotiator and requested as requested_locale
        If quality is greater than highest_quality:
            Set highest_quality to quality
            Set best_match to find_best_supported_match with negotiator as negotiator and requested as requested_locale
    
    If best_match is equal to "":
        Return negotiator.default_locale
    
    Return best_match

Process called "calculate_locale_quality" that takes negotiator as LocaleNegotiator and requested as String returns Float:
    For supported in negotiator.supported_locales:
        If requested is equal to supported:
            Return negotiator.quality_weights.exact_match
        
        Let requested_lang be extract_language_code with locale_code as requested
        Let supported_lang be extract_language_code with locale_code as supported
        If requested_lang is equal to supported_lang:
            Return negotiator.quality_weights.language_match
    
    Return negotiator.quality_weights.default_match

Process called "extract_language_code" that takes locale_code as String returns String:
    Let parts be split_string with text as locale_code and delimiter as "_"
    If (length of parts) is greater than 0:
        Return parts at index 0
    Return locale_code

Process called "split_string" that takes text as String and delimiter as String returns List[String]:
    Let parts be List.empty
    Let current_part be ""
    
    For i from 0 to ((length of text) minus 1):
        Let char be text at index i
        If char is equal to delimiter:
            If (length of current_part) is greater than 0:
                Call List.append with list as parts and item as current_part
                Set current_part to ""
        Otherwise:
            Set current_part to current_part Joined with char
    
    If (length of current_part) is greater than 0:
        Call List.append with list as parts and item as current_part
    
    Return parts

Process called "find_best_supported_match" that takes negotiator as LocaleNegotiator and requested as String returns String:
    For supported in negotiator.supported_locales:
        If requested is equal to supported:
            Return supported
    
    Let requested_lang be extract_language_code with locale_code as requested
    For supported in negotiator.supported_locales:
        Let supported_lang be extract_language_code with locale_code as supported
        If requested_lang is equal to supported_lang:
            Return supported
    
    Return negotiator.default_locale

Note: Locale Loading and Management

Process called "load_locale_from_cldr" that takes registry as LocaleRegistry and locale_code as String returns Optional[ExtendedLocale]:
    Note: Load locale data from CLDR
    Return Optional.None

Process called "register_custom_locale" that takes registry as LocaleRegistry and locale as ExtendedLocale:
    Let key be I18nCore.locale_to_key with locale as locale.base
    Call Dict.set with dict as registry.locales and key as key and value as locale
    Call validate_locale with locale as locale

Process called "validate_locale" that takes locale as ExtendedLocale returns Boolean:
    If (length of locale.base.language_code) is less than 2:
        Return false
    
    Match locale.base.country_code:
        When Optional.Some with value as country:
            If (length of country) is not equal to 2:
                Return false
        When Optional.None:
            Pass
    
    Return true

Process called "get_locale_fallback_chain" that takes registry as LocaleRegistry and locale_code as String returns List[String]:
    Let locale_option be Dict.get with dict as registry.locales and key as locale_code
    Match locale_option:
        When Optional.Some with value as locale:
            Return locale.fallback_chain
        When Optional.None:
            Let lang_code be extract_language_code with locale_code as locale_code
            Return create_list_with_items with items as [lang_code, "en"]

Process called "is_rtl_language" that takes registry as LocaleRegistry and language_code as String returns Boolean:
    For rtl_lang in registry.rtl_languages:
        If rtl_lang is equal to language_code:
            Return true
    Return false

Process called "get_supported_territories" that takes registry as LocaleRegistry and language_code as String returns List[String]:
    Let territories_option be Dict.get with dict as registry.territory_mappings and key as language_code
    Return Optional.unwrap_or with optional as territories_option and default as List.empty

Process called "find_locales_by_territory" that takes registry as LocaleRegistry and territory as String returns List[String]:
    Let result be List.empty
    
    For locale_code in Dict.keys with dict as registry.locales:
        Let locale_option be Dict.get with dict as registry.locales and key as locale_code
        Match locale_option:
            When Optional.Some with value as locale:
                For supported_territory in locale.territories:
                    If supported_territory is equal to territory:
                        Call List.append with list as result and item as locale_code
            When Optional.None:
                Pass
    
    Return result

Note: Locale Bundle Management

Process called "create_locale_bundle" that takes locale as ExtendedLocale returns LocaleBundle:
    Return LocaleBundle with:
        locale as locale
        display_names as create_display_names with locale as locale
        script_names as create_script_names with locale as locale
        territory_names as create_territory_names with locale as locale
        currency_names as create_currency_names with locale as locale
        language_names as create_language_names with locale as locale

Process called "create_display_names" that takes locale as ExtendedLocale returns Dict[String, String]:
    Let names be Dict.empty
    Call Dict.set with dict as names and key as "locale" and value as locale.base.display_name
    Call Dict.set with dict as names and key as "native" and value as locale.base.native_name
    Return names

Process called "create_script_names" that takes locale as ExtendedLocale returns Dict[String, String]:
    Let names be Dict.empty
    
    Match locale.base.script:
        When Optional.Some with value as script:
            Match script:
                When "Latn":
                    Call Dict.set with dict as names and key as "Latn" and value as "Latin"
                When "Arab":
                    Call Dict.set with dict as names and key as "Arab" and value as "Arabic"
                When "Jpan":
                    Call Dict.set with dict as names and key as "Jpan" and value as "Japanese"
                When "Hans":
                    Call Dict.set with dict as names and key as "Hans" and value as "Simplified Han"
                When "Hant":
                    Call Dict.set with dict as names and key as "Hant" and value as "Traditional Han"
                Otherwise:
                    Call Dict.set with dict as names and key as script and value as script
        When Optional.None:
            Pass
    
    Return names

Process called "create_territory_names" that takes locale as ExtendedLocale returns Dict[String, String]:
    Let names be Dict.empty
    
    For territory in locale.territories:
        Match territory:
            When "US":
                Call Dict.set with dict as names and key as "US" and value as "United States"
            When "GB":
                Call Dict.set with dict as names and key as "GB" and value as "United Kingdom"
            When "CA":
                Call Dict.set with dict as names and key as "CA" and value as "Canada"
            When "FR":
                Call Dict.set with dict as names and key as "FR" and value as "France"
            When "DE":
                Call Dict.set with dict as names and key as "DE" and value as "Germany"
            When "ES":
                Call Dict.set with dict as names and key as "ES" and value as "Spain"
            When "JP":
                Call Dict.set with dict as names and key as "JP" and value as "Japan"
            When "CN":
                Call Dict.set with dict as names and key as "CN" and value as "China"
            When "SA":
                Call Dict.set with dict as names and key as "SA" and value as "Saudi Arabia"
            Otherwise:
                Call Dict.set with dict as names and key as territory and value as territory
    
    Return names

Process called "create_currency_names" that takes locale as ExtendedLocale returns Dict[String, String]:
    Let names be Dict.empty
    
    For currency in locale.currencies:
        Match currency:
            When "USD":
                Call Dict.set with dict as names and key as "USD" and value as "US Dollar"
            When "EUR":
                Call Dict.set with dict as names and key as "EUR" and value as "Euro"
            When "GBP":
                Call Dict.set with dict as names and key as "GBP" and value as "British Pound"
            When "JPY":
                Call Dict.set with dict as names and key as "JPY" and value as "Japanese Yen"
            When "CNY":
                Call Dict.set with dict as names and key as "CNY" and value as "Chinese Yuan"
            When "SAR":
                Call Dict.set with dict as names and key as "SAR" and value as "Saudi Riyal"
            Otherwise:
                Call Dict.set with dict as names and key as currency and value as currency
    
    Return names

Process called "create_language_names" that takes locale as ExtendedLocale returns Dict[String, String]:
    Let names be Dict.empty
    
    Call Dict.set with dict as names and key as "en" and value as "English"
    Call Dict.set with dict as names and key as "fr" and value as "French"
    Call Dict.set with dict as names and key as "de" and value as "German"
    Call Dict.set with dict as names and key as "es" and value as "Spanish"
    Call Dict.set with dict as names and key as "ja" and value as "Japanese"
    Call Dict.set with dict as names and key as "zh" and value as "Chinese"
    Call Dict.set with dict as names and key as "ar" and value as "Arabic"
    Call Dict.set with dict as names and key as "ru" and value as "Russian"
    Call Dict.set with dict as names and key as "pt" and value as "Portuguese"
    Call Dict.set with dict as names and key as "it" and value as "Italian"
    
    Return names

Note: Utility Functions

Process called "get_locale_registry_stats" that takes registry as LocaleRegistry returns String:
    Let locale_count be length of (Dict.keys with dict as registry.locales)
    Let territory_count be length of (Dict.keys with dict as registry.territory_mappings)
    Let alias_count be length of (Dict.keys with dict as registry.locale_aliases)
    Let rtl_count be length of registry.rtl_languages
    
    Return "Locale Registry Stats:\n" Joined with
           "- Registered locales: " Joined with locale_count as String Joined with "\n" Joined with
           "- Territory mappings: " Joined with territory_count as String Joined with "\n" Joined with
           "- Locale aliases: " Joined with alias_count as String Joined with "\n" Joined with
           "- RTL languages: " Joined with rtl_count as String