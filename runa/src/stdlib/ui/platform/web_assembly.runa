    module_ref as WASMModule
    imported_functions as Dict[String, Function]
    exported_functions as Dict[String, Function]
    memory as WASMMemory
    tables as List[WASMTable]
    globals as List[WASMGlobal]

Type called "WASMMemory":
    memory_id as String
    buffer as MemoryBuffer
    page_size as Integer
    current_pages as Integer
    max_pages as Optional[Integer]

Type called "MemoryBuffer":
