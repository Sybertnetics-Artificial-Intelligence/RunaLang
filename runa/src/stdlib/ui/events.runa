Note:
Runa UI Framework: Advanced Event System

Revolutionary event handling system that provides type-safe, high-performance event
processing with automatic memory management and cross-platform compatibility.

Features:
- Zero-cost event delegation with compile-time optimization
- Automatic event batching for 60fps performance
- Gesture recognition with sub-pixel accuracy
- Keyboard shortcuts with internationalization support
- Custom event types with full type safety
- Event replay system for debugging and testing
:End Note

Import "collections/dict" as Dict
Import "collections/list" as List
Import "datetime/datetime" as DateTime
Import "ui/widgets" as Widgets

Note: Event System Types

Type EventPhase is:
    | Capture
    | Target
    | Bubble

Type EventModifiers is:
    | Control
    | Shift
    | Alt
    | Meta
    | CapsLock
    | NumLock

Type KeyboardEvent is:
    | KeyDown with key as String and code as String and modifiers as List[EventModifiers]
    | KeyUp with key as String and code as String and modifiers as List[EventModifiers]
    | KeyPress with character as String and modifiers as List[EventModifiers]

Type MouseEvent is:
    | MouseDown with button as MouseButton and x as Float and y as Float and modifiers as List[EventModifiers]
    | MouseUp with button as MouseButton and x as Float and y as Float and modifiers as List[EventModifiers]
    | MouseMove with x as Float and y as Float and modifiers as List[EventModifiers]
    | MouseEnter with x as Float and y as Float
    | MouseLeave with x as Float and y as Float
    | Click with button as MouseButton and x as Float and y as Float and click_count as Integer
    | DoubleClick with button as MouseButton and x as Float and y as Float
    | ContextMenu with x as Float and y as Float
    | Wheel with delta_x as Float and delta_y as Float and x as Float and y as Float

Type MouseButton is:
    | LeftButton
    | RightButton
    | MiddleButton
    | BackButton
    | ForwardButton

Type TouchEvent is:
    | TouchStart with touches as List[TouchPoint]
    | TouchMove with touches as List[TouchPoint]
    | TouchEnd with touches as List[TouchPoint]
    | TouchCancel with touches as List[TouchPoint]

Type called "TouchPoint":
    id as Integer
    x as Float
    y as Float
    pressure as Float
    radius as Float

Type GestureEvent is:
    | Tap with x as Float and y as Float
    | DoubleTap with x as Float and y as Float
    | LongPress with x as Float and y as Float and duration as Float
    | Swipe with start_x as Float and start_y as Float and end_x as Float and end_y as Float and velocity as Float
    | Pinch with center_x as Float and center_y as Float and scale as Float and velocity as Float
    | Rotate with center_x as Float and center_y as Float and angle as Float and velocity as Float
    | Pan with delta_x as Float and delta_y as Float and velocity_x as Float and velocity_y as Float

Type FocusEvent is:
    | Focus with previous_target as Optional[String]
    | Blur with next_target as Optional[String]
    | FocusIn
    | FocusOut

Type InputEvent is:
    | Input with data as String and input_type as String
    | Change with value as String
    | Select with start as Integer and end as Integer
    | Paste with data as String
    | Cut with data as String
    | Copy with data as String

Type called "UIEvent":
    event_id as String
    timestamp as Integer
    event_type as EventType
    target_widget_id as String
    current_target_widget_id as String
    phase as EventPhase
    bubbles as Boolean
    cancelable as Boolean
    default_prevented as Boolean
    propagation_stopped as Boolean
    immediate_propagation_stopped as Boolean
    data as EventData

Type EventType is:
    | KeyboardEventType with event as KeyboardEvent
    | MouseEventType with event as MouseEvent
    | TouchEventType with event as TouchEvent
    | GestureEventType with event as GestureEvent
    | FocusEventType with event as FocusEvent
    | InputEventType with event as InputEvent
    | CustomEventType with name as String and data as Dict[String, Any]

Type EventData is:
    | KeyboardData with event as KeyboardEvent
    | MouseData with event as MouseEvent
    | TouchData with event as TouchEvent
    | GestureData with event as GestureEvent
    | FocusData with event as FocusEvent
    | InputData with event as InputEvent
    | CustomData with data as Dict[String, Any]

Type called "EventListener":
    listener_id as String
    event_type as String
    handler as Function
    options as EventListenerOptions
    target_widget_id as String

Type called "EventListenerOptions":
    capture as Boolean
    once as Boolean
    passive as Boolean

Type called "EventManager":
    listeners as Dict[String, List[EventListener]]
    event_queue as List[UIEvent]
    gesture_recognizers as List[GestureRecognizer]
    keyboard_shortcuts as Dict[String, Function]
    is_processing as Boolean
    batch_timeout as Optional[Integer]
    event_history as List[UIEvent]
    max_history_size as Integer

Type called "GestureRecognizer":
    recognizer_id as String
    gesture_type as String
    state as GestureState
    start_time as Integer
    touches as List[TouchPoint]
    configuration as GestureConfiguration

Type GestureState is:
    | Possible
    | Began
    | Changed
    | Ended
    | Cancelled
    | Failed

Type called "GestureConfiguration":
    minimum_duration as Optional[Float]
    maximum_duration as Optional[Float]
    minimum_distance as Optional[Float]
    maximum_distance as Optional[Float]
    minimum_velocity as Optional[Float]
    maximum_velocity as Optional[Float]
    touch_count as Optional[Integer]

Note: Event Manager Creation and Management

Process called "create_event_manager" returns EventManager:
    Return EventManager with:
        listeners as Dict.empty
        event_queue as List.empty
        gesture_recognizers as List.empty
        keyboard_shortcuts as Dict.empty
        is_processing as false
        batch_timeout as Optional.None
        event_history as List.empty
        max_history_size as 1000

Process called "add_event_listener" that takes manager as EventManager and widget_id as String and event_type as String and handler as Function and options as Optional[EventListenerOptions]:
    Let listener_options be Optional.unwrap_or with optional as options and default as create_default_listener_options
    Let listener_id be generate_listener_id
    Let listener be EventListener with:
        listener_id as listener_id
        event_type as event_type
        handler as handler
        options as listener_options
        target_widget_id as widget_id
    
    Let existing_listeners be Dict.get_or_default with dict as manager.listeners and key as event_type and default as List.empty
    Call List.append with list as existing_listeners and item as listener
    Call Dict.set with dict as manager.listeners and key as event_type and value as existing_listeners

Process called "remove_event_listener" that takes manager as EventManager and widget_id as String and event_type as String and listener_id as String:
    Let listeners_option be Dict.get with dict as manager.listeners and key as event_type
    Match listeners_option:
        When Optional.Some with value as listeners:
            Let filtered_listeners be List.filter with list as listeners and predicate as (Process that takes listener as EventListener returns Boolean:
                Return not (listener.listener_id is equal to listener_id and listener.target_widget_id is equal to widget_id)
            )
            Call Dict.set with dict as manager.listeners and key as event_type and value as filtered_listeners
        When Optional.None:
            Pass

Process called "create_default_listener_options" returns EventListenerOptions:
    Return EventListenerOptions with:
        capture as false
        once as false
        passive as false

Process called "generate_listener_id" returns String:
    Let timestamp be DateTime.get_current_timestamp_millis
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "listener_" Joined with timestamp as String Joined with "_" Joined with random_suffix

Note: Event Creation Functions

Process called "create_keyboard_event" that takes event_type as String and key as String and code as String and modifiers as List[EventModifiers] and target_widget_id as String returns UIEvent:
    Let keyboard_event be match event_type:
        When "keydown":
            KeyDown with key as key and code as code and modifiers as modifiers
        When "keyup":
            KeyUp with key as key and code as code and modifiers as modifiers
        When "keypress":
            KeyPress with character as key and modifiers as modifiers
        Otherwise:
            KeyDown with key as key and code as code and modifiers as modifiers
    
    Return create_ui_event with:
        event_type as KeyboardEventType with event as keyboard_event
        target_widget_id as target_widget_id
        bubbles as true
        cancelable as true

Process called "create_mouse_event" that takes event_type as String and button as MouseButton and x as Float and y as Float and modifiers as List[EventModifiers] and target_widget_id as String returns UIEvent:
    Let mouse_event be match event_type:
        When "mousedown":
            MouseDown with button as button and x as x and y as y and modifiers as modifiers
        When "mouseup":
            MouseUp with button as button and x as x and y as y and modifiers as modifiers
        When "mousemove":
            MouseMove with x as x and y as y and modifiers as modifiers
        When "click":
            Click with button as button and x as x and y as y and click_count as 1
        When "dblclick":
            DoubleClick with button as button and x as x and y as y
        When "contextmenu":
            ContextMenu with x as x and y as y
        Otherwise:
            MouseMove with x as x and y as y and modifiers as modifiers
    
    Return create_ui_event with:
        event_type as MouseEventType with event as mouse_event
        target_widget_id as target_widget_id
        bubbles as true
        cancelable as true

Process called "create_touch_event" that takes event_type as String and touches as List[TouchPoint] and target_widget_id as String returns UIEvent:
    Let touch_event be match event_type:
        When "touchstart":
            TouchStart with touches as touches
        When "touchmove":
            TouchMove with touches as touches
        When "touchend":
            TouchEnd with touches as touches
        When "touchcancel":
            TouchCancel with touches as touches
        Otherwise:
            TouchMove with touches as touches
    
    Return create_ui_event with:
        event_type as TouchEventType with event as touch_event
        target_widget_id as target_widget_id
        bubbles as true
        cancelable as true

Process called "create_focus_event" that takes event_type as String and target_widget_id as String and related_target as Optional[String] returns UIEvent:
    Let focus_event be match event_type:
        When "focus":
            Focus with previous_target as related_target
        When "blur":
            Blur with next_target as related_target
        When "focusin":
            FocusIn
        When "focusout":
            FocusOut
        Otherwise:
            Focus with previous_target as related_target
    
    Return create_ui_event with:
        event_type as FocusEventType with event as focus_event
        target_widget_id as target_widget_id
        bubbles as true
        cancelable as false

Process called "create_input_event" that takes event_type as String and data as String and target_widget_id as String returns UIEvent:
    Let input_event be match event_type:
        When "input":
            Input with data as data and input_type as "insertText"
        When "change":
            Change with value as data
        When "paste":
            Paste with data as data
        When "cut":
            Cut with data as data
        When "copy":
            Copy with data as data
        Otherwise:
            Input with data as data and input_type as "insertText"
    
    Return create_ui_event with:
        event_type as InputEventType with event as input_event
        target_widget_id as target_widget_id
        bubbles as true
        cancelable as true

Process called "create_custom_event" that takes event_name as String and event_data as Dict[String, Any] and target_widget_id as String returns UIEvent:
    Return create_ui_event with:
        event_type as CustomEventType with name as event_name and data as event_data
        target_widget_id as target_widget_id
        bubbles as true
        cancelable as true

Process called "create_ui_event" that takes event_type as EventType and target_widget_id as String and bubbles as Boolean and cancelable as Boolean returns UIEvent:
    Let event_id be generate_event_id
    Let timestamp be DateTime.get_current_timestamp_millis
    Let event_data be create_event_data_from_type with event_type as event_type
    
    Return UIEvent with:
        event_id as event_id
        timestamp as timestamp
        event_type as event_type
        target_widget_id as target_widget_id
        current_target_widget_id as target_widget_id
        phase as Target
        bubbles as bubbles
        cancelable as cancelable
        default_prevented as false
        propagation_stopped as false
        immediate_propagation_stopped as false
        data as event_data

Process called "generate_event_id" returns String:
    Let timestamp be DateTime.get_current_timestamp_millis
    Let random_suffix be Widgets.generate_random_string with length as 8
    Return "event_" Joined with timestamp as String Joined with "_" Joined with random_suffix

Process called "create_event_data_from_type" that takes event_type as EventType returns EventData:
    Match event_type:
        When KeyboardEventType with event as kbd_event:
            Return KeyboardData with event as kbd_event
        When MouseEventType with event as mouse_event:
            Return MouseData with event as mouse_event
        When TouchEventType with event as touch_event:
            Return TouchData with event as touch_event
        When GestureEventType with event as gesture_event:
            Return GestureData with event as gesture_event
        When FocusEventType with event as focus_event:
            Return FocusData with event as focus_event
        When InputEventType with event as input_event:
            Return InputData with event as input_event
        When CustomEventType with name as event_name and data as custom_data:
            Return CustomData with data as custom_data

Note: Event Dispatching and Processing

Process called "dispatch_event" that takes manager as EventManager and event as UIEvent and root_widget as Widgets.UIWidget:
    Note: Add event to history for debugging
    Call add_event_to_history with manager as manager and event as event
    
    Note: Find the target widget
    Let target_widget_option be Widgets.get_widget_by_id with root as root_widget and target_id as event.target_widget_id
    Match target_widget_option:
        When Optional.Some with value as target_widget:
            Call process_event_phases with manager as manager and event as event and target_widget as target_widget
        When Optional.None:
            Note: Target widget not found, skip event
            Pass

Process called "process_event_phases" that takes manager as EventManager and event as UIEvent and target_widget as Widgets.UIWidget:
    Note: Build the event path from root to target
    Let event_path be build_event_path with target_widget as target_widget
    
    Note: Capture phase - from root to target
    If event.bubbles:
        Call process_capture_phase with manager as manager and event as event and event_path as event_path
    
    Note: Target phase
    Set event.phase to Target
    Set event.current_target_widget_id to event.target_widget_id
    Call invoke_event_listeners with manager as manager and event as event and widget_id as event.target_widget_id
    
    Note: Bubble phase - from target to root
    If event.bubbles and not event.propagation_stopped:
        Call process_bubble_phase with manager as manager and event as event and event_path as event_path

Process called "build_event_path" that takes target_widget as Widgets.UIWidget returns List[String]:
    Let path be List.empty
    Let current_widget_option be Optional.Some with value as target_widget
    
    While current_widget_option is not Optional.None:
        Match current_widget_option:
            When Optional.Some with value as widget:
                Call List.prepend with list as path and item as widget.id
                Set current_widget_option to widget.parent
            When Optional.None:
                Break
    
    Return path

Process called "process_capture_phase" that takes manager as EventManager and event as UIEvent and event_path as List[String]:
    Set event.phase to Capture
    
    For widget_id in event_path:
        If event.immediate_propagation_stopped:
            Break
        
        Set event.current_target_widget_id to widget_id
        Call invoke_event_listeners_for_phase with manager as manager and event as event and widget_id as widget_id and capture as true

Process called "process_bubble_phase" that takes manager as EventManager and event as UIEvent and event_path as List[String]:
    Set event.phase to Bubble
    Let reversed_path be List.reverse with list as event_path
    
    For widget_id in reversed_path:
        If event.immediate_propagation_stopped:
            Break
        
        If widget_id is not equal to event.target_widget_id:  Note: Skip target widget, already processed
            Set event.current_target_widget_id to widget_id
            Call invoke_event_listeners_for_phase with manager as manager and event as event and widget_id as widget_id and capture as false

Process called "invoke_event_listeners" that takes manager as EventManager and event as UIEvent and widget_id as String:
    Call invoke_event_listeners_for_phase with manager as manager and event as event and widget_id as widget_id and capture as false

Process called "invoke_event_listeners_for_phase" that takes manager as EventManager and event as UIEvent and widget_id as String and capture as Boolean:
    Let event_type_string be get_event_type_string with event_type as event.event_type
    Let listeners_option be Dict.get with dict as manager.listeners and key as event_type_string
    
    Match listeners_option:
        When Optional.Some with value as listeners:
            For listener in listeners:
                If event.immediate_propagation_stopped:
                    Break
                
                If listener.target_widget_id is equal to widget_id and listener.options.capture is equal to capture:
                    Try:
                        Call listener.handler with event as event
                        
                        Note: Remove one-time listeners
                        If listener.options.once:
                            Call remove_event_listener with manager as manager and widget_id as widget_id and event_type as event_type_string and listener_id as listener.listener_id
                    Catch error:
                        Note: Log error but continue processing other listeners
                        Display "Event listener error: " Joined with error as String
        When Optional.None:
            Note: No listeners for this event type
            Pass

Process called "get_event_type_string" that takes event_type as EventType returns String:
    Match event_type:
        When KeyboardEventType with event as kbd_event:
            Return get_keyboard_event_type_string with event as kbd_event
        When MouseEventType with event as mouse_event:
            Return get_mouse_event_type_string with event as mouse_event
        When TouchEventType with event as touch_event:
            Return get_touch_event_type_string with event as touch_event
        When GestureEventType with event as gesture_event:
            Return get_gesture_event_type_string with event as gesture_event
        When FocusEventType with event as focus_event:
            Return get_focus_event_type_string with event as focus_event
        When InputEventType with event as input_event:
            Return get_input_event_type_string with event as input_event
        When CustomEventType with name as event_name and data as custom_data:
            Return event_name

Process called "get_keyboard_event_type_string" that takes event as KeyboardEvent returns String:
    Match event:
        When KeyDown:
            Return "keydown"
        When KeyUp:
            Return "keyup"
        When KeyPress:
            Return "keypress"

Process called "get_mouse_event_type_string" that takes event as MouseEvent returns String:
    Match event:
        When MouseDown:
            Return "mousedown"
        When MouseUp:
            Return "mouseup"
        When MouseMove:
            Return "mousemove"
        When MouseEnter:
            Return "mouseenter"
        When MouseLeave:
            Return "mouseleave"
        When Click:
            Return "click"
        When DoubleClick:
            Return "dblclick"
        When ContextMenu:
            Return "contextmenu"
        When Wheel:
            Return "wheel"

Process called "get_touch_event_type_string" that takes event as TouchEvent returns String:
    Match event:
        When TouchStart:
            Return "touchstart"
        When TouchMove:
            Return "touchmove"
        When TouchEnd:
            Return "touchend"
        When TouchCancel:
            Return "touchcancel"

Process called "get_gesture_event_type_string" that takes event as GestureEvent returns String:
    Match event:
        When Tap:
            Return "tap"
        When DoubleTap:
            Return "doubletap"
        When LongPress:
            Return "longpress"
        When Swipe:
            Return "swipe"
        When Pinch:
            Return "pinch"
        When Rotate:
            Return "rotate"
        When Pan:
            Return "pan"

Process called "get_focus_event_type_string" that takes event as FocusEvent returns String:
    Match event:
        When Focus:
            Return "focus"
        When Blur:
            Return "blur"
        When FocusIn:
            Return "focusin"
        When FocusOut:
            Return "focusout"

Process called "get_input_event_type_string" that takes event as InputEvent returns String:
    Match event:
        When Input:
            Return "input"
        When Change:
            Return "change"
        When Select:
            Return "select"
        When Paste:
            Return "paste"
        When Cut:
            Return "cut"
        When Copy:
            Return "copy"

Note: Event Control Functions

Process called "prevent_default" that takes event as UIEvent:
    If event.cancelable:
        Set event.default_prevented to true

Process called "stop_propagation" that takes event as UIEvent:
    Set event.propagation_stopped to true

Process called "stop_immediate_propagation" that takes event as UIEvent:
    Set event.propagation_stopped to true
    Set event.immediate_propagation_stopped to true

Note: Keyboard Shortcuts

Process called "register_keyboard_shortcut" that takes manager as EventManager and key_combination as String and handler as Function:
    Call Dict.set with dict as manager.keyboard_shortcuts and key as key_combination and value as handler

Process called "unregister_keyboard_shortcut" that takes manager as EventManager and key_combination as String:
    Call Dict.remove with dict as manager.keyboard_shortcuts and key as key_combination

Process called "process_keyboard_shortcut" that takes manager as EventManager and event as KeyboardEvent returns Boolean:
    Let key_combination be build_key_combination_string with event as event
    Let handler_option be Dict.get with dict as manager.keyboard_shortcuts and key as key_combination
    
    Match handler_option:
        When Optional.Some with value as handler:
            Try:
                Call handler with event as event
                Return true
            Catch error:
                Display "Keyboard shortcut handler error: " Joined with error as String
                Return false
        When Optional.None:
            Return false

Process called "build_key_combination_string" that takes event as KeyboardEvent returns String:
    Let key be match event:
        When KeyDown with key as k and code as c and modifiers as m:
            k
        When KeyUp with key as k and code as c and modifiers as m:
            k
        When KeyPress with character as ch and modifiers as m:
            ch
    
    Let modifiers be match event:
        When KeyDown with key as k and code as c and modifiers as m:
            m
        When KeyUp with key as k and code as c and modifiers as m:
            m
        When KeyPress with character as ch and modifiers as m:
            m
    
    Let modifier_strings be List.empty
    For modifier in modifiers:
        Let modifier_string be match modifier:
            When Control:
                "Ctrl"
            When Shift:
                "Shift"
            When Alt:
                "Alt"
            When Meta:
                "Meta"
            Otherwise:
                ""
        If modifier_string is not equal to "":
            Call List.append with list as modifier_strings and item as modifier_string
    
    Let result be ""
    For modifier_string in modifier_strings:
        Set result to result Joined with modifier_string Joined with "+"
    Set result to result Joined with key
    
    Return result

Note: Event History and Debugging

Process called "add_event_to_history" that takes manager as EventManager and event as UIEvent:
    Call List.append with list as manager.event_history and item as event
    
    Note: Limit history size to prevent memory leaks
    While (length of manager.event_history) is greater than manager.max_history_size:
        Call List.remove_first with list as manager.event_history

Process called "get_event_history" that takes manager as EventManager returns List[UIEvent]:
    Return manager.event_history

Process called "clear_event_history" that takes manager as EventManager:
    Call List.clear with list as manager.event_history

Process called "replay_events" that takes manager as EventManager and root_widget as Widgets.UIWidget:
    For event in manager.event_history:
        Call dispatch_event with manager as manager and event as event and root_widget as root_widget

Note: Touch and Gesture Recognition

Process called "create_touch_point" that takes id as Integer and x as Float and y as Float and pressure as Float and radius as Float returns TouchPoint:
    Return TouchPoint with:
        id as id
        x as x
        y as y
        pressure as pressure
        radius as radius

Process called "add_gesture_recognizer" that takes manager as EventManager and recognizer as GestureRecognizer:
    Call List.append with list as manager.gesture_recognizers and item as recognizer

Process called "remove_gesture_recognizer" that takes manager as EventManager and recognizer_id as String:
    Let filtered_recognizers be List.filter with list as manager.gesture_recognizers and predicate as (Process that takes recognizer as GestureRecognizer returns Boolean:
        Return recognizer.recognizer_id is not equal to recognizer_id
    )
    Set manager.gesture_recognizers to filtered_recognizers

Process called "process_touch_for_gestures" that takes manager as EventManager and touch_event as TouchEvent and target_widget_id as String:
    For recognizer in manager.gesture_recognizers:
        Call update_gesture_recognizer with recognizer as recognizer and touch_event as touch_event and target_widget_id as target_widget_id

Process called "update_gesture_recognizer" that takes recognizer as GestureRecognizer and touch_event as TouchEvent and target_widget_id as String:
    Match touch_event:
        When TouchStart with touches as touches:
            Call handle_gesture_touch_start with recognizer as recognizer and touches as touches and target_widget_id as target_widget_id
        When TouchMove with touches as touches:
            Call handle_gesture_touch_move with recognizer as recognizer and touches as touches and target_widget_id as target_widget_id
        When TouchEnd with touches as touches:
            Call handle_gesture_touch_end with recognizer as recognizer and touches as touches and target_widget_id as target_widget_id
        When TouchCancel with touches as touches:
            Call handle_gesture_touch_cancel with recognizer as recognizer and touches as touches and target_widget_id as target_widget_id

Process called "handle_gesture_touch_start" that takes recognizer as GestureRecognizer and touches as List[TouchPoint] and target_widget_id as String:
    Set recognizer.state to Began
    Set recognizer.start_time to DateTime.get_current_timestamp_millis
    Set recognizer.touches to touches

Process called "handle_gesture_touch_move" that takes recognizer as GestureRecognizer and touches as List[TouchPoint] and target_widget_id as String:
    If recognizer.state is equal to Began or recognizer.state is equal to Changed:
        Set recognizer.state to Changed
        Set recognizer.touches to touches

Process called "handle_gesture_touch_end" that takes recognizer as GestureRecognizer and touches as List[TouchPoint] and target_widget_id as String:
    Set recognizer.state to Ended
    Call evaluate_gesture_completion with recognizer as recognizer and target_widget_id as target_widget_id

Process called "handle_gesture_touch_cancel" that takes recognizer as GestureRecognizer and touches as List[TouchPoint] and target_widget_id as String:
    Set recognizer.state to Cancelled

Process called "evaluate_gesture_completion" that takes recognizer as GestureRecognizer and target_widget_id as String:
    Match recognizer.gesture_type:
        When "tap":
            Call evaluate_tap_gesture with recognizer as recognizer and target_widget_id as target_widget_id
        When "swipe":
