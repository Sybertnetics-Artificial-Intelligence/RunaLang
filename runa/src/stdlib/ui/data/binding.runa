Note:
Runa UI Framework: Advanced Data Binding System

Revolutionary two-way data binding framework with reactive updates, dependency tracking,
and automatic optimization for minimal re-renders.

Features:
- Two-way data binding with automatic synchronization
- Fine-grained reactivity with dependency tracking
- Computed properties with automatic memoization
- Observable collections with change detection
- Validation pipeline with async validators
- Change batching for performance optimization
- Time-travel debugging with state snapshots
:End Note

Import "collections/dict" as Dict
Import "collections/list" as List
Import "ui/widgets" as Widgets

Note: Data Binding Core Types

Type BindingMode is:
    | OneWay
    | TwoWay
    | OneTime
    | OneWayToSource

Type BindingDirection is:
    | SourceToTarget
    | TargetToSource
    | Bidirectional

Type called "DataBinding":
    binding_id as String
    source as BindingSource
    target as BindingTarget
    mode as BindingMode
    converter as Optional[ValueConverter]
    validator as Optional[Validator]
    update_trigger as UpdateTrigger
    is_active as Boolean
    last_value as Any

Type called "BindingSource":
    object as Any
    property_path as PropertyPath
    metadata as Dict[String, Any]

Type called "BindingTarget":
    widget_id as String
    property_name as String
    metadata as Dict[String, Any]

Type called "PropertyPath":
    segments as List[String]
    is_nested as Boolean

Type UpdateTrigger is:
    | PropertyChanged
    | LostFocus
    | Explicit
    | Continuous

Type called "ValueConverter":
    converter_id as String
    convert_function as Function
    convert_back_function as Optional[Function]

Type called "Validator":
    validator_id as String
    validate_function as Function
    error_message_template as String
    is_async as Boolean

Type called "Observable":
    observable_id as String
    value as Any
    subscribers as List[ObservableSubscriber]
    dependencies as List[String]
    is_computed as Boolean
    compute_function as Optional[Function]
    is_dirty as Boolean

Type called "ObservableSubscriber":
    subscriber_id as String
    callback as Function
    priority as Integer

Type called "ObservableCollection":
    collection_id as String
    items as List[Any]
    item_type as String
    subscribers as List[CollectionSubscriber]
    change_tracking as ChangeTracking

Type called "CollectionSubscriber":
    subscriber_id as String
    callback as Function
    change_types as List[CollectionChangeType]

Type CollectionChangeType is:
    | ItemAdded
    | ItemRemoved
    | ItemReplaced
    | CollectionReset
    | CollectionReordered

Type called "ChangeTracking":
    is_tracking as Boolean
    changes as List[CollectionChange]
    original_state as List[Any]

Type called "CollectionChange":
    change_type as CollectionChangeType
    index as Optional[Integer]
    item as Optional[Any]
    old_item as Optional[Any]

Type called "BindingContext":
    context_id as String
    data_source as Any
    bindings as Dict[String, DataBinding]
    observables as Dict[String, Observable]
    collections as Dict[String, ObservableCollection]
    validation_errors as Dict[String, ValidationError]

Type called "ValidationError":
    property_name as String
    error_message as String
    severity as ValidationSeverity

Type ValidationSeverity is:
    | Error
    | Warning
    | Info

Type called "BindingEngine":
    contexts as Dict[String, BindingContext]
    global_converters as Dict[String, ValueConverter]
    global_validators as Dict[String, Validator]
    update_queue as List[BindingUpdate]
    is_updating as Boolean
    change_detection_mode as ChangeDetectionMode

Type called "BindingUpdate":
    binding_id as String
    source_value as Any
    timestamp as Integer

Type ChangeDetectionMode is:
    | Automatic
    | Manual
    | OnPush

Note: Binding Engine Creation and Management

Process called "create_binding_engine" returns BindingEngine:
    Return BindingEngine with:
        contexts as Dict.empty
        global_converters as create_default_converters
        global_validators as create_default_validators
        update_queue as List.empty
        is_updating as false
        change_detection_mode as Automatic

Process called "create_default_converters" returns Dict[String, ValueConverter]:
    Let converters be Dict.empty
    
    Let string_converter be create_string_converter
    Call Dict.set with dict as converters and key as "string" and value as string_converter
    
    Let number_converter be create_number_converter
    Call Dict.set with dict as converters and key as "number" and value as number_converter
    
    Let boolean_converter be create_boolean_converter
    Call Dict.set with dict as converters and key as "boolean" and value as boolean_converter
    
    Return converters

Process called "create_string_converter" returns ValueConverter:
    Let convert be Process that takes value as Any returns String:
        Return value as String
    
    Let convert_back be Process that takes value as String returns Any:
        Return value
    
    Return ValueConverter with:
        converter_id as "string_converter"
        convert_function as convert
        convert_back_function as Optional.Some with value as convert_back

Process called "create_number_converter" returns ValueConverter:
    Let convert be Process that takes value as Any returns Float:
        Return value as Float
    
    Let convert_back be Process that takes value as Float returns Any:
        Return value
    
    Return ValueConverter with:
        converter_id as "number_converter"
        convert_function as convert
        convert_back_function as Optional.Some with value as convert_back

Process called "create_boolean_converter" returns ValueConverter:
    Let convert be Process that takes value as Any returns Boolean:
        Return value as Boolean
    
    Let convert_back be Process that takes value as Boolean returns Any:
        Return value
    
    Return ValueConverter with:
        converter_id as "boolean_converter"
        convert_function as convert
        convert_back_function as Optional.Some with value as convert_back

Process called "create_default_validators" returns Dict[String, Validator]:
    Let validators be Dict.empty
    
    Let required_validator be create_required_validator
    Call Dict.set with dict as validators and key as "required" and value as required_validator
    
    Let email_validator be create_email_validator
    Call Dict.set with dict as validators and key as "email" and value as email_validator
    
    Let range_validator be create_range_validator with min as 0.0 and max as 100.0
    Call Dict.set with dict as validators and key as "range" and value as range_validator
    
    Return validators

Process called "create_required_validator" returns Validator:
    Let validate be Process that takes value as Any returns Boolean:
        Match value:
            When String as s:
                Return (length of s) is greater than 0
            When List as l:
                Return (length of l) is greater than 0
            Otherwise:
                Return value is not equal to null
    
    Return Validator with:
        validator_id as "required"
        validate_function as validate
        error_message_template as "This field is required"
        is_async as false

Process called "create_email_validator" returns Validator:
    Let validate be Process that takes value as Any returns Boolean:
        Match value:
            When String as email:
                Return validate_email_format with email as email
            Otherwise:
                Return false
    
    Return Validator with:
        validator_id as "email"
        validate_function as validate
        error_message_template as "Please enter a valid email address"
        is_async as false

Process called "validate_email_format" that takes email as String returns Boolean:
    Note: Simplified email validation
    Let has_at be contains_character with text as email and char as "@"
    Let has_dot be contains_character with text as email and char as "."
    Return has_at and has_dot

Process called "contains_character" that takes text as String and char as String returns Boolean:
    For i from 0 to ((length of text) minus 1):
        If (text at index i) is equal to char:
            Return true
    Return false

Process called "create_range_validator" that takes min as Float and max as Float returns Validator:
    Let validate be Process that takes value as Any returns Boolean:
        Match value:
            When Float as f:
                Return f is greater than or equal to min and f is less than or equal to max
            When Integer as i:
                Return i is greater than or equal to (min as Integer) and i is less than or equal to (max as Integer)
            Otherwise:
                Return false
    
    Return Validator with:
        validator_id as "range"
        validate_function as validate
        error_message_template as "Value must be between " concatenated with min as String concatenated with " and " concatenated with max as String
        is_async as false

Note: Binding Context Management

Process called "create_binding_context" that takes data_source as Any returns BindingContext:
    Let context_id be generate_binding_context_id
    
    Return BindingContext with:
        context_id as context_id
        data_source as data_source
        bindings as Dict.empty
        observables as Dict.empty
        collections as Dict.empty
        validation_errors as Dict.empty

Process called "generate_binding_context_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "context_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "register_binding_context" that takes engine as BindingEngine and context as BindingContext:
    Call Dict.set with dict as engine.contexts and key as context.context_id and value as context

Process called "unregister_binding_context" that takes engine as BindingEngine and context_id as String:
    Let context_option be Dict.get with dict as engine.contexts and key as context_id
    Match context_option:
        When Optional.Some with value as context:
            Call cleanup_context_bindings with context as context
            Call Dict.remove with dict as engine.contexts and key as context_id
        When Optional.None:
            Pass

Process called "cleanup_context_bindings" that takes context as BindingContext:
    For binding_id in Dict.keys with dict as context.bindings:
        Let binding_option be Dict.get with dict as context.bindings and key as binding_id
        Match binding_option:
            When Optional.Some with value as binding:
                Set binding.is_active to false
            When Optional.None:
                Pass
    
    Call Dict.clear with dict as context.bindings
    Call Dict.clear with dict as context.observables
    Call Dict.clear with dict as context.collections

Note: Data Binding Creation

Process called "create_binding" that takes source as BindingSource and target as BindingTarget and mode as BindingMode returns DataBinding:
    Let binding_id be generate_binding_id
    
    Return DataBinding with:
        binding_id as binding_id
        source as source
        target as target
        mode as mode
        converter as Optional.None
        validator as Optional.None
        update_trigger as PropertyChanged
        is_active as false
        last_value as null

Process called "generate_binding_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "binding_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_binding_source" that takes object as Any and property_path as String returns BindingSource:
    Let path_segments be parse_property_path with path as property_path
    
    Return BindingSource with:
        object as object
        property_path as PropertyPath with:
            segments as path_segments
            is_nested as (length of path_segments) is greater than 1
        metadata as Dict.empty

Process called "parse_property_path" that takes path as String returns List[String]:
    Let segments be List.empty
    Let current_segment be ""
    
    For i from 0 to ((length of path) minus 1):
        Let char be path at index i
        If char is equal to ".":
            If (length of current_segment) is greater than 0:
                Call List.append with list as segments and item as current_segment
                Set current_segment to ""
        Otherwise:
            Set current_segment to current_segment concatenated with char
    
    If (length of current_segment) is greater than 0:
        Call List.append with list as segments and item as current_segment
    
    Return segments

Process called "create_binding_target" that takes widget_id as String and property_name as String returns BindingTarget:
    Return BindingTarget with:
        widget_id as widget_id
        property_name as property_name
        metadata as Dict.empty

Process called "activate_binding" that takes engine as BindingEngine and context as BindingContext and binding as DataBinding:
    Set binding.is_active to true
    Call Dict.set with dict as context.bindings and key as binding.binding_id and value as binding
    
    Note: Initial synchronization
    Call update_binding with engine as engine and binding as binding and direction as SourceToTarget

Process called "deactivate_binding" that takes context as BindingContext and binding_id as String:
    Let binding_option be Dict.get with dict as context.bindings and key as binding_id
    Match binding_option:
        When Optional.Some with value as binding:
            Set binding.is_active to false
            Call Dict.remove with dict as context.bindings and key as binding_id
        When Optional.None:
            Pass

Note: Binding Updates

Process called "update_binding" that takes engine as BindingEngine and binding as DataBinding and direction as BindingDirection:
    If not binding.is_active:
        Return
    
    Match direction:
        When SourceToTarget:
            Call update_source_to_target with engine as engine and binding as binding
        When TargetToSource:
            Call update_target_to_source with engine as engine and binding as binding
        When Bidirectional:
            Call update_source_to_target with engine as engine and binding as binding
            Call update_target_to_source with engine as engine and binding as binding

Process called "update_source_to_target" that takes engine as BindingEngine and binding as DataBinding:
    Let source_value be get_property_value with object as binding.source.object and path as binding.source.property_path
    
    Note: Apply converter if present
    Let converted_value be match binding.converter:
        When Optional.Some with value as converter:
            converter.convert_function with value as source_value
        When Optional.None:
            source_value
    
    Note: Validate if validator present
    Match binding.validator:
        When Optional.Some with value as validator:
            Let is_valid be validator.validate_function with value as converted_value
            If not is_valid:
                Call add_validation_error with binding as binding and message as validator.error_message_template
                Return
        When Optional.None:
            Pass
    
    Note: Update target widget property
    Call set_widget_property with widget_id as binding.target.widget_id and property_name as binding.target.property_name and value as converted_value
    Set binding.last_value to converted_value

Process called "update_target_to_source" that takes engine as BindingEngine and binding as DataBinding:
    If binding.mode is equal to OneWay or binding.mode is equal to OneTime:
        Return  Note: These modes don't support target to source updates
    
    Let target_value be get_widget_property with widget_id as binding.target.widget_id and property_name as binding.target.property_name
    
    Note: Apply reverse converter if present
    Let converted_value be match binding.converter:
        When Optional.Some with value as converter:
            Match converter.convert_back_function:
                When Optional.Some with value as convert_back:
                    convert_back with value as target_value
                When Optional.None:
                    target_value
        When Optional.None:
            target_value
    
    Note: Update source object property
    Call set_property_value with object as binding.source.object and path as binding.source.property_path and value as converted_value
    Set binding.last_value to converted_value

Process called "get_property_value" that takes object as Any and path as PropertyPath returns Any:
    Let current_object be object
    
    For segment in path.segments:
        Set current_object to get_object_property with object as current_object and property_name as segment
        If current_object is equal to null:
            Return null
    
    Return current_object

Process called "set_property_value" that takes object as Any and path as PropertyPath and value as Any:
    If (length of path.segments) is equal to 0:
        Return
    
    Let current_object be object
    Let segments be path.segments
    
    Note: Navigate to parent object for nested paths
    For i from 0 to ((length of segments) minus 2):
        Let segment be segments at index i
        Set current_object to get_object_property with object as current_object and property_name as segment
        If current_object is equal to null:
            Return
    
    Note: Set the final property
    Let final_segment be segments at index ((length of segments) minus 1)
    Call set_object_property with object as current_object and property_name as final_segment and value as value

Process called "get_object_property" that takes object as Any and property_name as String returns Any:
    Note: This would use reflection or dynamic property access
    Return null  Note: Placeholder

Process called "set_object_property" that takes object as Any and property_name as String and value as Any:
    Note: This would use reflection or dynamic property setting
    Pass  Note: Placeholder

Process called "get_widget_property" that takes widget_id as String and property_name as String returns Any:
    Note: This would integrate with the widget system
    Return null  Note: Placeholder

Process called "set_widget_property" that takes widget_id as String and property_name as String and value as Any:
    Note: This would integrate with the widget system
    Pass  Note: Placeholder

Note: Observable System

Process called "create_observable" that takes initial_value as Any returns Observable:
    Let observable_id be generate_observable_id
    
    Return Observable with:
        observable_id as observable_id
        value as initial_value
        subscribers as List.empty
        dependencies as List.empty
        is_computed as false
        compute_function as Optional.None
        is_dirty as false

Process called "generate_observable_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "observable_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_computed_observable" that takes compute_function as Function and dependencies as List[String] returns Observable:
    Let observable_id be generate_observable_id
    Let initial_value be compute_function
    
    Return Observable with:
        observable_id as observable_id
        value as initial_value
        subscribers as List.empty
        dependencies as dependencies
        is_computed as true
        compute_function as Optional.Some with value as compute_function
        is_dirty as false

Process called "subscribe_to_observable" that takes observable as Observable and callback as Function returns String:
    Let subscriber_id be generate_subscriber_id
    Let subscriber be ObservableSubscriber with:
        subscriber_id as subscriber_id
        callback as callback
        priority as 0
    
    Call List.append with list as observable.subscribers and item as subscriber
    Return subscriber_id

Process called "generate_subscriber_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 4
    Return "subscriber_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "unsubscribe_from_observable" that takes observable as Observable and subscriber_id as String:
    Let filtered_subscribers be List.filter with list as observable.subscribers and predicate as (Process that takes subscriber as ObservableSubscriber returns Boolean:
        Return subscriber.subscriber_id is not equal to subscriber_id
    )
    Set observable.subscribers to filtered_subscribers

Process called "set_observable_value" that takes observable as Observable and value as Any:
    Let old_value be observable.value
    Set observable.value to value
    
    If old_value is not equal to value:
        Call notify_observable_subscribers with observable as observable and old_value as old_value and new_value as value

Process called "notify_observable_subscribers" that takes observable as Observable and old_value as Any and new_value as Any:
    For subscriber in observable.subscribers:
        Call subscriber.callback with old_value as old_value and new_value as new_value

Process called "mark_computed_dirty" that takes observable as Observable:
    If observable.is_computed:
        Set observable.is_dirty to true

Process called "recompute_if_dirty" that takes observable as Observable:
    If observable.is_computed and observable.is_dirty:
        Match observable.compute_function:
            When Optional.Some with value as compute:
                Let new_value be compute
                Call set_observable_value with observable as observable and value as new_value
                Set observable.is_dirty to false
            When Optional.None:
                Pass

Note: Observable Collections

Process called "create_observable_collection" that takes item_type as String returns ObservableCollection:
    Let collection_id be generate_collection_id
    
    Return ObservableCollection with:
        collection_id as collection_id
        items as List.empty
        item_type as item_type
        subscribers as List.empty
        change_tracking as create_change_tracking

Process called "generate_collection_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "collection_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_change_tracking" returns ChangeTracking:
    Return ChangeTracking with:
        is_tracking as false
        changes as List.empty
        original_state as List.empty

Process called "add_item_to_collection" that takes collection as ObservableCollection and item as Any:
    Call List.append with list as collection.items and item as item
    
    If collection.change_tracking.is_tracking:
        Let change be CollectionChange with:
            change_type as ItemAdded
            index as Optional.Some with value as ((length of collection.items) minus 1)
            item as Optional.Some with value as item
            old_item as Optional.None
        Call List.append with list as collection.change_tracking.changes and item as change
    
    Call notify_collection_subscribers with collection as collection and change_type as ItemAdded

Process called "remove_item_from_collection" that takes collection as ObservableCollection and index as Integer:
    If index is greater than or equal to 0 and index is less than (length of collection.items):
        Let removed_item be collection.items at index index
        Call List.remove_at with list as collection.items and index as index
        
        If collection.change_tracking.is_tracking:
            Let change be CollectionChange with:
                change_type as ItemRemoved
                index as Optional.Some with value as index
                item as Optional.None
                old_item as Optional.Some with value as removed_item
            Call List.append with list as collection.change_tracking.changes and item as change
        
        Call notify_collection_subscribers with collection as collection and change_type as ItemRemoved

Process called "notify_collection_subscribers" that takes collection as ObservableCollection and change_type as CollectionChangeType:
    For subscriber in collection.subscribers:
        If List.contains with list as subscriber.change_types and item as change_type:
            Call subscriber.callback with change_type as change_type

Process called "begin_change_tracking" that takes collection as ObservableCollection:
    Set collection.change_tracking.is_tracking to true
    Set collection.change_tracking.original_state to List.clone with list as collection.items
    Call List.clear with list as collection.change_tracking.changes

Process called "commit_changes" that takes collection as ObservableCollection:
    Set collection.change_tracking.is_tracking to false
    Call List.clear with list as collection.change_tracking.changes
    Call List.clear with list as collection.change_tracking.original_state

Process called "rollback_changes" that takes collection as ObservableCollection:
    If collection.change_tracking.is_tracking:
        Set collection.items to List.clone with list as collection.change_tracking.original_state
        Set collection.change_tracking.is_tracking to false
        Call List.clear with list as collection.change_tracking.changes
        Call notify_collection_subscribers with collection as collection and change_type as CollectionReset

Note: Validation System

Process called "add_validation_error" that takes binding as DataBinding and message as String:
    Let error be ValidationError with:
        property_name as binding.target.property_name
        error_message as message
        severity as Error
    
    Note: This would add the error to the context's validation errors
    Pass

Process called "clear_validation_errors" that takes context as BindingContext:
    Call Dict.clear with dict as context.validation_errors

Process called "validate_all_bindings" that takes context as BindingContext returns Boolean:
    Let is_valid be true
    
    For binding_id in Dict.keys with dict as context.bindings:
        Let binding_option be Dict.get with dict as context.bindings and key as binding_id
        Match binding_option:
            When Optional.Some with value as binding:
                Match binding.validator:
                    When Optional.Some with value as validator:
                        Let value be get_property_value with object as binding.source.object and path as binding.source.property_path
                        Let validation_result be validator.validate_function with value as value
                        If not validation_result:
                            Set is_valid to false
                            Call add_validation_error with binding as binding and message as validator.error_message_template
                    When Optional.None:
                        Pass
            When Optional.None:
                Pass
    
    Return is_valid

Note: Change Detection and Updates

Process called "process_update_queue" that takes engine as BindingEngine:
    If engine.is_updating:
        Return  Note: Prevent recursive updates
    
    Set engine.is_updating to true
    
    While (length of engine.update_queue) is greater than 0:
        Let update_option be List.pop_first with list as engine.update_queue
        Match update_option:
            When Optional.Some with value as update:
                Call process_binding_update with engine as engine and update as update
            When Optional.None:
                Break
    
    Set engine.is_updating to false

Process called "process_binding_update" that takes engine as BindingEngine and update as BindingUpdate:
    Note: Find and update the binding
    For context_id in Dict.keys with dict as engine.contexts:
        Let context_option be Dict.get with dict as engine.contexts and key as context_id
        Match context_option:
            When Optional.Some with value as context:
                Let binding_option be Dict.get with dict as context.bindings and key as update.binding_id
                Match binding_option:
                    When Optional.Some with value as binding:
                        Call update_binding with engine as engine and binding as binding and direction as SourceToTarget
                    When Optional.None:
                        Pass
            When Optional.None:
                Pass

Process called "queue_binding_update" that takes engine as BindingEngine and binding_id as String and source_value as Any:
    Let update be BindingUpdate with:
        binding_id as binding_id
        source_value as source_value
        timestamp as Widgets.get_current_timestamp
    
    Call List.append with list as engine.update_queue and item as update
    
    If engine.change_detection_mode is equal to Automatic:
        Call process_update_queue with engine as engine

Process called "set_change_detection_mode" that takes engine as BindingEngine and mode as ChangeDetectionMode:
    Set engine.change_detection_mode to mode

Process called "trigger_manual_change_detection" that takes engine as BindingEngine:
    If engine.change_detection_mode is equal to Manual or engine.change_detection_mode is equal to OnPush:
        Call process_update_queue with engine as engine

Note: Utility Functions

Process called "create_simple_binding" that takes source_object as Any and source_property as String and widget_id as String and widget_property as String returns DataBinding:
    Let source be create_binding_source with object as source_object and property_path as source_property
    Let target be create_binding_target with widget_id as widget_id and property_name as widget_property
    Return create_binding with source as source and target as target and mode as TwoWay

Process called "get_binding_stats" that takes engine as BindingEngine returns String:
    Let context_count be length of (Dict.keys with dict as engine.contexts)
    Let total_bindings be 0
    Let active_bindings be 0
    
    For context_id in Dict.keys with dict as engine.contexts:
        Let context_option be Dict.get with dict as engine.contexts and key as context_id
        Match context_option:
            When Optional.Some with value as context:
                Set total_bindings to total_bindings plus (length of (Dict.keys with dict as context.bindings))
                For binding_id in Dict.keys with dict as context.bindings:
                    Let binding_option be Dict.get with dict as context.bindings and key as binding_id
                    Match binding_option:
                        When Optional.Some with value as binding:
                            If binding.is_active:
                                Set active_bindings to active_bindings plus 1
                        When Optional.None:
                            Pass
            When Optional.None:
                Pass
    
    Return "Binding Engine Stats:\n" concatenated with
           "- Contexts: " concatenated with context_count as String concatenated with "\n" concatenated with
           "- Total bindings: " concatenated with total_bindings as String concatenated with "\n" concatenated with
           "- Active bindings: " concatenated with active_bindings as String concatenated with "\n" concatenated with
           "- Update queue size: " concatenated with (length of engine.update_queue) as String