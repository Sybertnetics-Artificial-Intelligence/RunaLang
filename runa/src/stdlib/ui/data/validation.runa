Note:
Runa UI Framework: Advanced Validation System

Comprehensive validation framework with async validators, real-time feedback,
and accessibility-aware error reporting for production-grade forms.

Features:
- Real-time validation with debouncing
- Async validators with promise handling
- Complex validation rules with dependency tracking
- Multi-field cross-validation
- Accessibility-compliant error reporting
- Custom validation messages with i18n support
- Performance-optimized validation scheduling
:End Note

Import "collections/dict" as Dict
Import "collections/list" as List
Import "ui/widgets" as Widgets
Import "ui/data/binding" as Binding

Note: Validation Core Types

Type ValidationResult is:
    | Valid
    | Invalid with errors as List[ValidationError]
    | Pending

Type called "ValidationError":
    field_name as String
    error_code as String
    error_message as String
    severity as ErrorSeverity
    metadata as Dict[String, Any]

Type ErrorSeverity is:
    | Critical
    | Warning
    | Info

Type called "Validator":
    validator_id as String
    name as String
    validate_function as Function
    is_async as Boolean
    priority as Integer
    depends_on as List[String]
    debounce_delay as Float

Type called "ValidationRule":
    rule_id as String
    field_name as String
    validators as List[Validator]
    when_condition as Optional[Function]
    error_message_override as Optional[String]

Type called "FormValidator":
    form_id as String
    rules as Dict[String, ValidationRule]
    field_values as Dict[String, Any]
    validation_results as Dict[String, ValidationResult]
    cross_validators as List[CrossValidator]
    validation_state as ValidationState

Type ValidationState is:
    | Pristine
    | Validating
    | Valid
    | Invalid
    | Dirty

Type called "CrossValidator":
    validator_id as String
    dependent_fields as List[String]
    validation_function as Function
    error_target_field as String

Type called "AsyncValidator":
    base as Validator
    timeout as Float
    cache_results as Boolean
    cache as Dict[String, ValidationResult]

type called "ValidationTrigger":
    trigger_type as TriggerType
    delay as Float
    condition as Optional[Function]

Type TriggerType is:
    | OnChange
    | OnBlur
    | OnSubmit
    | OnFocus
    | Manual
    | Debounced

Type called "ValidationContext":
    form_data as Dict[String, Any]
    user_context as Dict[String, Any]
    locale as String
    timezone as String

Type called "ValidationEngine":
    active_forms as Dict[String, FormValidator]
    global_validators as Dict[String, Validator]
    validation_queue as List[ValidationTask]
    async_results as Dict[String, ValidationResult]
    performance_metrics as ValidationMetrics

Type called "ValidationTask":
    task_id as String
    form_id as String
    field_name as String
    value as Any
    validator as Validator
    context as ValidationContext
    timestamp as Integer

Type called "ValidationMetrics":
    total_validations as Integer
    async_validations as Integer
    validation_times as List[Float]
    error_counts as Dict[String, Integer]

Note: Validation Engine Creation

Process called "create_validation_engine" returns ValidationEngine:
    Return ValidationEngine with:
        active_forms as Dict.empty
        global_validators as create_default_validators
        validation_queue as List.empty
        async_results as Dict.empty
        performance_metrics as create_validation_metrics

Process called "create_default_validators" returns Dict[String, Validator]:
    Let validators be Dict.empty
    
    Let required_validator be create_required_validator
    Call Dict.set with dict as validators and key as "required" and value as required_validator
    
    Let email_validator be create_email_validator
    Call Dict.set with dict as validators and key as "email" and value as email_validator
    
    Let length_validator be create_length_validator
    Call Dict.set with dict as validators and key as "length" and value as length_validator
    
    Let pattern_validator be create_pattern_validator
    Call Dict.set with dict as validators and key as "pattern" and value as pattern_validator
    
    Let range_validator be create_range_validator
    Call Dict.set with dict as validators and key as "range" and value as range_validator
    
    Return validators

Process called "create_required_validator" returns Validator:
    Let validate_function be Process that takes value as Any and context as ValidationContext returns ValidationResult:
        Match value:
            When String as str:
                If (length of str) is greater than 0:
                    Return Valid
                Otherwise:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "required" and message as "This field is required"
            When List as list:
                If (length of list) is greater than 0:
                    Return Valid
                Otherwise:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "required" and message as "This field is required"
            Otherwise:
                If value is not equal to null:
                    Return Valid
                Otherwise:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "required" and message as "This field is required"
    
    Return Validator with:
        validator_id as "required"
        name as "Required"
        validate_function as validate_function
        is_async as false
        priority as 100
        depends_on as List.empty
        debounce_delay as 0.0

Process called "create_validation_error" that takes field as String and code as String and message as String returns ValidationError:
    Return ValidationError with:
        field_name as field
        error_code as code
        error_message as message
        severity as Critical
        metadata as Dict.empty

Process called "create_error_list" that takes error as ValidationError returns List[ValidationError]:
    Let errors be List.empty
    Call List.append with list as errors and item as error
    Return errors

Process called "create_email_validator" returns Validator:
    Let validate_function be Process that takes value as Any and context as ValidationContext returns ValidationResult:
        Match value:
            When String as email:
                If validate_email_format with email as email:
                    Return Valid
                Otherwise:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "email" and code as "invalid_email" and message as "Please enter a valid email address"
            Otherwise:
                Return Invalid with errors as create_error_list with error as create_validation_error with field as "email" and code as "invalid_type" and message as "Email must be a string"
    
    Return Validator with:
        validator_id as "email"
        name as "Email"
        validate_function as validate_function
        is_async as false
        priority as 50
        depends_on as List.empty
        debounce_delay as 300.0

Process called "validate_email_format" that takes email as String returns Boolean:
    Note: Comprehensive email validation
    If (length of email) is less than 3:
        Return false
    
    If not contains_character with text as email and char as "@":
        Return false
    
    Let at_position be find_character_position with text as email and char as "@"
    If at_position is equal to 0 or at_position is equal to ((length of email) minus 1):
        Return false
    
    Let local_part be substring with text as email and start as 0 and end as at_position
    Let domain_part be substring with text as email and start as (at_position plus 1) and end as (length of email)
    
    If not validate_email_local_part with local as local_part:
        Return false
    
    If not validate_email_domain_part with domain as domain_part:
        Return false
    
    Return true

Process called "contains_character" that takes text as String and char as String returns Boolean:
    For i from 0 to ((length of text) minus 1):
        If (text at index i) is equal to char:
            Return true
    Return false

Process called "find_character_position" that takes text as String and char as String returns Integer:
    For i from 0 to ((length of text) minus 1):
        If (text at index i) is equal to char:
            Return i
    Return -1

Process called "substring" that takes text as String and start as Integer and end as Integer returns String:
    Let result be ""
    For i from start to (end minus 1):
        If i is greater than or equal to 0 and i is less than (length of text):
            Set result to result concatenated with (text at index i)
    Return result

Process called "validate_email_local_part" that takes local as String returns Boolean:
    If (length of local) is equal to 0 or (length of local) is greater than 64:
        Return false
    
    Let first_char be local at index 0
    Let last_char be local at index ((length of local) minus 1)
    
    If first_char is equal to "." or last_char is equal to ".":
        Return false
    
    Return true

Process called "validate_email_domain_part" that takes domain as String returns Boolean:
    If (length of domain) is equal to 0 or (length of domain) is greater than 253:
        Return false
    
    If not contains_character with text as domain and char as ".":
        Return false
    
    Let parts be split_string with text as domain and delimiter as "."
    If (length of parts) is less than 2:
        Return false
    
    Let last_part be parts at index ((length of parts) minus 1)
    If (length of last_part) is less than 2:
        Return false
    
    Return true

Process called "split_string" that takes text as String and delimiter as String returns List[String]:
    Let parts be List.empty
    Let current_part be ""
    
    For i from 0 to ((length of text) minus 1):
        Let char be text at index i
        If char is equal to delimiter:
            If (length of current_part) is greater than 0:
                Call List.append with list as parts and item as current_part
                Set current_part to ""
        Otherwise:
            Set current_part to current_part concatenated with char
    
    If (length of current_part) is greater than 0:
        Call List.append with list as parts and item as current_part
    
    Return parts

Process called "create_length_validator" returns Validator:
    Let validate_function be Process that takes value as Any and context as ValidationContext returns ValidationResult:
        Match value:
            When String as str:
                Let length be length of str
                Let min_length be get_context_value with context as context and key as "min_length" and default as 0
                Let max_length be get_context_value with context as context and key as "max_length" and default as 1000
                
                If length is less than min_length:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "too_short" and message as "Must be at least " concatenated with min_length as String concatenated with " characters"
                
                If length is greater than max_length:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "too_long" and message as "Must be no more than " concatenated with max_length as String concatenated with " characters"
                
                Return Valid
            Otherwise:
                Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "invalid_type" and message as "Value must be text"
    
    Return Validator with:
        validator_id as "length"
        name as "Length"
        validate_function as validate_function
        is_async as false
        priority as 25
        depends_on as List.empty
        debounce_delay as 200.0

Process called "get_context_value" that takes context as ValidationContext and key as String and default as Integer returns Integer:
    Let value_option be Dict.get with dict as context.user_context and key as key
    Match value_option:
        When Optional.Some with value as value:
            Return value as Integer
        When Optional.None:
            Return default

Process called "create_pattern_validator" returns Validator:
    Let validate_function be Process that takes value as Any and context as ValidationContext returns ValidationResult:
        Match value:
            When String as str:
                Let pattern_option be Dict.get with dict as context.user_context and key as "pattern"
                Match pattern_option:
                    When Optional.Some with value as pattern:
                        If matches_pattern with text as str and pattern as pattern as String:
                            Return Valid
                        Otherwise:
                            Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "pattern_mismatch" and message as "Value does not match required format"
                    When Optional.None:
                        Return Valid
            Otherwise:
                Return Valid
    
    Return Validator with:
        validator_id as "pattern"
        name as "Pattern"
        validate_function as validate_function
        is_async as false
        priority as 30
        depends_on as List.empty
        debounce_delay as 100.0

Process called "matches_pattern" that takes text as String and pattern as String returns Boolean:
    Note: Simplified pattern matching - would use regex in production
    Return (length of text) is greater than 0

Process called "create_range_validator" returns Validator:
    Let validate_function be Process that takes value as Any and context as ValidationContext returns ValidationResult:
        Match value:
            When Float as num:
                Let min_value be get_context_float_value with context as context and key as "min" and default as -1000000.0
                Let max_value be get_context_float_value with context as context and key as "max" and default as 1000000.0
                
                If num is less than min_value:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "below_minimum" and message as "Value must be at least " concatenated with min_value as String
                
                If num is greater than max_value:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "above_maximum" and message as "Value must be no more than " concatenated with max_value as String
                
                Return Valid
            When Integer as int_num:
                Let num as Float be int_num as Float
                Let min_value be get_context_float_value with context as context and key as "min" and default as -1000000.0
                Let max_value be get_context_float_value with context as context and key as "max" and default as 1000000.0
                
                If num is less than min_value:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "below_minimum" and message as "Value must be at least " concatenated with min_value as String
                
                If num is greater than max_value:
                    Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "above_maximum" and message as "Value must be no more than " concatenated with max_value as String
                
                Return Valid
            Otherwise:
                Return Invalid with errors as create_error_list with error as create_validation_error with field as "field" and code as "invalid_type" and message as "Value must be a number"
    
    Return Validator with:
        validator_id as "range"
        name as "Range"
        validate_function as validate_function
        is_async as false
        priority as 20
        depends_on as List.empty
        debounce_delay as 0.0

Process called "get_context_float_value" that takes context as ValidationContext and key as String and default as Float returns Float:
    Let value_option be Dict.get with dict as context.user_context and key as key
    Match value_option:
        When Optional.Some with value as value:
            Return value as Float
        When Optional.None:
            Return default

Process called "create_validation_metrics" returns ValidationMetrics:
    Return ValidationMetrics with:
        total_validations as 0
        async_validations as 0
        validation_times as List.empty
        error_counts as Dict.empty

Note: Form Validation

Process called "create_form_validator" that takes form_id as String returns FormValidator:
    Return FormValidator with:
        form_id as form_id
        rules as Dict.empty
        field_values as Dict.empty
        validation_results as Dict.empty
        cross_validators as List.empty
        validation_state as Pristine

Process called "add_validation_rule" that takes form as FormValidator and rule as ValidationRule:
    Call Dict.set with dict as form.rules and key as rule.field_name and value as rule

Process called "create_validation_rule" that takes field_name as String and validators as List[Validator] returns ValidationRule:
    Let rule_id be generate_rule_id
    
    Return ValidationRule with:
        rule_id as rule_id
        field_name as field_name
        validators as validators
        when_condition as Optional.None
        error_message_override as Optional.None

Process called "generate_rule_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "rule_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "validate_field" that takes engine as ValidationEngine and form as FormValidator and field_name as String and value as Any returns ValidationResult:
    Let rule_option be Dict.get with dict as form.rules and key as field_name
    Match rule_option:
        When Optional.Some with value as rule:
            Set form.validation_state to Validating
            Call Dict.set with dict as form.field_values and key as field_name and value as value
            
            Note: Check if rule should be applied
            Match rule.when_condition:
                When Optional.Some with value as condition:
                    If not condition with form_data as form.field_values:
                        Return Valid
                When Optional.None:
                    Pass
            
            Let context be create_validation_context with form as form
            Let combined_result be run_validators with validators as rule.validators and value as value and context as context
            
            Call Dict.set with dict as form.validation_results and key as field_name and value as combined_result
            Call update_form_validation_state with form as form
            
            Return combined_result
        When Optional.None:
            Return Valid

Process called "create_validation_context" that takes form as FormValidator returns ValidationContext:
    Return ValidationContext with:
        form_data as form.field_values
        user_context as Dict.empty
        locale as "en"
        timezone as "UTC"

Process called "run_validators" that takes validators as List[Validator] and value as Any and context as ValidationContext returns ValidationResult:
    Let all_errors be List.empty
    Let has_pending be false
    
    For validator in validators:
        Let result be validator.validate_function with value as value and context as context
        Match result:
            When Invalid with errors as errors:
                For error in errors:
                    Call List.append with list as all_errors and item as error
            When Pending:
                Set has_pending to true
            When Valid:
                Pass
    
    If has_pending:
        Return Pending
    
    If (length of all_errors) is greater than 0:
        Return Invalid with errors as all_errors
    
    Return Valid

Process called "update_form_validation_state" that takes form as FormValidator:
    Let has_invalid be false
    Let has_pending be false
    Let has_results be false
    
    For field_name in Dict.keys with dict as form.validation_results:
        Let result_option be Dict.get with dict as form.validation_results and key as field_name
        Match result_option:
            When Optional.Some with value as result:
                Set has_results to true
                Match result:
                    When Invalid:
                        Set has_invalid to true
                    When Pending:
                        Set has_pending to true
                    When Valid:
                        Pass
            When Optional.None:
                Pass
    
    If has_pending:
        Set form.validation_state to Validating
    If has_invalid:
        Set form.validation_state to Invalid
    If has_results and not has_invalid and not has_pending:
        Set form.validation_state to Valid
    Otherwise:
        Set form.validation_state to Dirty

Process called "validate_entire_form" that takes engine as ValidationEngine and form as FormValidator returns Boolean:
    Let is_valid be true
    
    For field_name in Dict.keys with dict as form.rules:
        Let value_option be Dict.get with dict as form.field_values and key as field_name
        Match value_option:
            When Optional.Some with value as value:
                Let result be validate_field with engine as engine and form as form and field_name as field_name and value as value
                Match result:
                    When Invalid:
                        Set is_valid to false
                    When Pending:
                        Set is_valid to false
                    When Valid:
                        Pass
            When Optional.None:
                Note: Field has no value, validate with null
                Let result be validate_field with engine as engine and form as form and field_name as field_name and value as null
                Match result:
                    When Invalid:
                        Set is_valid to false
                    When Pending:
                        Set is_valid to false
                    When Valid:
                        Pass
    
    Note: Run cross-validators
    For cross_validator in form.cross_validators:
        Let cross_result be cross_validator.validation_function with form_data as form.field_values
        Match cross_result:
            When Invalid with errors as errors:
                Set is_valid to false
                Call Dict.set with dict as form.validation_results and key as cross_validator.error_target_field and value as cross_result
            When Valid:
                Pass
            When Pending:
                Set is_valid to false
    
    Return is_valid

Note: Cross-Validation

Process called "create_cross_validator" that takes dependent_fields as List[String] and validation_function as Function and error_target_field as String returns CrossValidator:
    Let validator_id be generate_cross_validator_id
    
    Return CrossValidator with:
        validator_id as validator_id
        dependent_fields as dependent_fields
        validation_function as validation_function
        error_target_field as error_target_field

Process called "generate_cross_validator_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "cross_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "add_cross_validator" that takes form as FormValidator and cross_validator as CrossValidator:
    Call List.append with list as form.cross_validators and item as cross_validator

Process called "create_password_confirmation_validator" that takes password_field as String and confirm_field as String returns CrossValidator:
    Let validation_function be Process that takes form_data as Dict[String, Any] returns ValidationResult:
        Let password_option be Dict.get with dict as form_data and key as password_field
        Let confirm_option be Dict.get with dict as form_data and key as confirm_field
        
        Match password_option:
            When Optional.Some with value as password:
                Match confirm_option:
                    When Optional.Some with value as confirm:
                        If password is equal to confirm:
                            Return Valid
                        Otherwise:
                            Return Invalid with errors as create_error_list with error as create_validation_error with field as confirm_field and code as "password_mismatch" and message as "Passwords do not match"
                    When Optional.None:
                        Return Invalid with errors as create_error_list with error as create_validation_error with field as confirm_field and code as "required" and message as "Please confirm your password"
            When Optional.None:
                Return Valid
    
    Let dependent_fields be List.empty
    Call List.append with list as dependent_fields and item as password_field
    Call List.append with list as dependent_fields and item as confirm_field
    
    Return create_cross_validator with dependent_fields as dependent_fields and validation_function as validation_function and error_target_field as confirm_field

Note: Async Validation

Process called "create_async_validator" that takes base_validator as Validator and timeout as Float returns AsyncValidator:
    Return AsyncValidator with:
        base as base_validator
        timeout as timeout
        cache_results as true
        cache as Dict.empty

Process called "run_async_validation" that takes engine as ValidationEngine and async_validator as AsyncValidator and value as Any and context as ValidationContext returns String:
    Let task_id be generate_task_id
    
    Let task be ValidationTask with:
        task_id as task_id
        form_id as "async_form"
        field_name as "async_field"
        value as value
        validator as async_validator.base
        context as context
        timestamp as Widgets.get_current_timestamp
    
    Call List.append with list as engine.validation_queue and item as task
    Call schedule_async_validation with engine as engine and task as task
    
    Return task_id

Process called "generate_task_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 8
    Return "task_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "schedule_async_validation" that takes engine as ValidationEngine and task as ValidationTask:
    Note: Schedule async validation to run
    Call process_async_validation_task with engine as engine and task as task

Process called "process_async_validation_task" that takes engine as ValidationEngine and task as ValidationTask:
    Let result be task.validator.validate_function with value as task.value and context as task.context
    Call Dict.set with dict as engine.async_results and key as task.task_id and value as result

Process called "get_async_validation_result" that takes engine as ValidationEngine and task_id as String returns Optional[ValidationResult]:
    Return Dict.get with dict as engine.async_results and key as task_id

Note: Validation Triggers and Debouncing

Process called "create_validation_trigger" that takes trigger_type as TriggerType and delay as Float returns ValidationTrigger:
    Return ValidationTrigger with:
        trigger_type as trigger_type
        delay as delay
        condition as Optional.None

Process called "should_trigger_validation" that takes trigger as ValidationTrigger and event_type as String returns Boolean:
    Match trigger.trigger_type:
        When OnChange:
            Return event_type is equal to "change"
        When OnBlur:
            Return event_type is equal to "blur"
        When OnFocus:
            Return event_type is equal to "focus"
        When OnSubmit:
            Return event_type is equal to "submit"
        When Debounced:
            Return event_type is equal to "change" or event_type is equal to "input"
        When Manual:
            Return false

Process called "debounce_validation" that takes engine as ValidationEngine and form_id as String and field_name as String and value as Any and delay as Float:
    Note: Implement debounced validation
    Call schedule_delayed_validation with engine as engine and form_id as form_id and field_name as field_name and value as value and delay as delay

Process called "schedule_delayed_validation" that takes engine as ValidationEngine and form_id as String and field_name as String and value as Any and delay as Float:
    Note: Schedule validation after delay
    Pass

Note: Error Reporting and Accessibility

Process called "get_field_errors" that takes form as FormValidator and field_name as String returns List[ValidationError]:
    Let result_option be Dict.get with dict as form.validation_results and key as field_name
    Match result_option:
        When Optional.Some with value as result:
            Match result:
                When Invalid with errors as errors:
                    Return errors
                Otherwise:
                    Return List.empty
        When Optional.None:
            Return List.empty

Process called "get_all_form_errors" that takes form as FormValidator returns List[ValidationError]:
    Let all_errors be List.empty
    
    For field_name in Dict.keys with dict as form.validation_results:
        Let field_errors be get_field_errors with form as form and field_name as field_name
        For error in field_errors:
            Call List.append with list as all_errors and item as error
    
    Return all_errors

Process called "format_error_message" that takes error as ValidationError and locale as String returns String:
    Note: Format error message with i18n support
    Return error.error_message

Process called "create_accessible_error_message" that takes errors as List[ValidationError] and field_name as String returns String:
    If (length of errors) is equal to 0:
        Return ""
    
    If (length of errors) is equal to 1:
        Let error be errors at index 0
        Return "Error in " concatenated with field_name concatenated with ": " concatenated with error.error_message
    
    Let message be "Errors in " concatenated with field_name concatenated with ": "
    For i from 0 to ((length of errors) minus 1):
        Let error be errors at index i
        Set message to message concatenated with error.error_message
        If i is less than ((length of errors) minus 1):
            Set message to message concatenated with ", "
    
    Return message

Process called "announce_validation_error" that takes widget as Widgets.UIWidget and error_message as String:
    Note: Announce error to screen readers
    Call Widgets.set_widget_accessibility_description with widget as widget and description as error_message

Note: Performance and Optimization

Process called "optimize_validation_performance" that takes engine as ValidationEngine:
    Call cleanup_completed_tasks with engine as engine
    Call optimize_validation_queue with engine as engine

Process called "cleanup_completed_tasks" that takes engine as ValidationEngine:
    Let completed_tasks be List.empty
    
    For task in engine.validation_queue:
        Let result_option be Dict.get with dict as engine.async_results and key as task.task_id
        Match result_option:
            When Optional.Some:
                Call List.append with list as completed_tasks and item as task.task_id
            When Optional.None:
                Pass
    
    For task_id in completed_tasks:
        Call Dict.remove with dict as engine.async_results and key as task_id

Process called "optimize_validation_queue" that takes engine as ValidationEngine:
    Note: Remove duplicate validation tasks
    Pass

Process called "get_validation_stats" that takes engine as ValidationEngine returns String:
    Let active_forms be length of (Dict.keys with dict as engine.active_forms)
    Let queue_size be length of engine.validation_queue
    Let pending_async be length of (Dict.keys with dict as engine.async_results)
    
    Return "Validation Engine Stats:\n" concatenated with
           "- Active forms: " concatenated with active_forms as String concatenated with "\n" concatenated with
           "- Validation queue: " concatenated with queue_size as String concatenated with "\n" concatenated with
           "- Pending async: " concatenated with pending_async as String concatenated with "\n" concatenated with
           "- Total validations: " concatenated with engine.performance_metrics.total_validations as String

Process called "register_form" that takes engine as ValidationEngine and form as FormValidator:
    Call Dict.set with dict as engine.active_forms and key as form.form_id and value as form

Process called "unregister_form" that takes engine as ValidationEngine and form_id as String:
    Call Dict.remove with dict as engine.active_forms and key as form_id