Note:
Runa UI Framework: Core Animation System

Revolutionary animation framework that provides hardware-accelerated animations
with physics-based motion, spring dynamics, and gesture-driven interactions.

Features:
- Hardware-accelerated transformations with GPU optimization
- Physics-based animations with spring and damping systems
- Gesture-driven animation triggers with velocity inheritance
- Timeline-based animation sequencing with parallel execution
- Performance-optimized with 60fps guarantee and adaptive frame dropping
- Accessibility-aware with respect for reduced motion preferences
- Memory-efficient with automatic cleanup and resource pooling
:End Note

Import "collections/dict" as Dict
Import "collections/list" as List
Import "math/core" as Math
Import "ui/widgets" as Widgets

Note: Animation Core Types

Type AnimationState is:
    | Idle
    | Running
    | Paused
    | Completed
    | Cancelled

Type AnimationDirection is:
    | Forward
    | Reverse
    | Alternate
    | AlternateReverse

Type AnimationFillMode is:
    | None
    | Forwards
    | Backwards
    | Both

Type EasingFunction is:
    | Linear
    | EaseIn
    | EaseOut
    | EaseInOut
    | CubicBezier with p1_x as Float and p1_y as Float and p2_x as Float and p2_y as Float
    | Spring with tension as Float and friction as Float
    | Bounce
    | Elastic
    | Custom with function as Function

Type called "Animation":
    animation_id as String
    name as String
    target_widget_id as String
    property as AnimatableProperty
    from_value as AnimationValue
    to_value as AnimationValue
    duration as Float
    delay as Float
    easing as EasingFunction
    direction as AnimationDirection
    iteration_count as AnimationIterationCount
    fill_mode as AnimationFillMode
    state as AnimationState
    current_time as Float
    start_time as Optional[Float]
    end_time as Optional[Float]
    progress as Float
    current_value as AnimationValue

Type AnimationIterationCount is:
    | Finite with count as Integer
    | Infinite

Type AnimatableProperty is:
    | Transform with transform_type as TransformType
    | Opacity
    | Color with color_property as ColorProperty
    | Size with size_property as SizeProperty
    | Position with position_property as PositionProperty
    | Custom with property_name as String

Type TransformType is:
    | TranslateX
    | TranslateY
    | TranslateZ
    | Rotate
    | RotateX
    | RotateY
    | RotateZ
    | ScaleX
    | ScaleY
    | ScaleZ
    | SkewX
    | SkewY

Type ColorProperty is:
    | BackgroundColor
    | TextColor
    | BorderColor
    | ShadowColor

Type SizeProperty is:
    | Width
    | Height
    | BorderWidth
    | BorderRadius

Type PositionProperty is:
    | Left
    | Top
    | Right
    | Bottom

Type AnimationValue is:
    | FloatValue with value as Float
    | ColorValue with color as Widgets.UIColor
    | TransformValue with transform as Transform
    | StringValue with value as String

Type called "Transform":
    translate_x as Float
    translate_y as Float
    translate_z as Float
    rotate as Float
    rotate_x as Float
    rotate_y as Float
    rotate_z as Float
    scale_x as Float
    scale_y as Float
    scale_z as Float
    skew_x as Float
    skew_y as Float

Type called "AnimationGroup":
    group_id as String
    name as String
    animations as List[Animation]
    state as AnimationState
    current_time as Float
    duration as Float

Type called "AnimationTimeline":
    timeline_id as String
    keyframes as List[Keyframe]
    duration as Float
    current_time as Float
    state as AnimationState

Type called "Keyframe":
    time as Float
    properties as Dict[String, AnimationValue]
    easing as EasingFunction

Type called "AnimationEngine":
    running_animations as Dict[String, Animation]
    running_groups as Dict[String, AnimationGroup]
    running_timelines as Dict[String, AnimationTimeline]
    frame_rate as Float
    last_frame_time as Float
    performance_mode as PerformanceMode
    reduced_motion as Boolean

Type PerformanceMode is:
    | HighPerformance
    | Balanced
    | PowerSaving

Type called "AnimationEvent":
    event_type as AnimationEventType
    animation_id as String
    timestamp as Float
    progress as Float

Type AnimationEventType is:
    | AnimationStart
    | AnimationEnd
    | AnimationCancel
    | AnimationIteration

Note: Animation Engine Creation and Management

Process called "create_animation_engine" returns AnimationEngine:
    Return AnimationEngine with:
        running_animations as Dict.empty
        running_groups as Dict.empty
        running_timelines as Dict.empty
        frame_rate as 60.0
        last_frame_time as 0.0
        performance_mode as Balanced
        reduced_motion as false

Process called "create_animation" that takes name as String and target_widget_id as String and property as AnimatableProperty and from_value as AnimationValue and to_value as AnimationValue and duration as Float returns Animation:
    Let animation_id be generate_animation_id
    
    Return Animation with:
        animation_id as animation_id
        name as name
        target_widget_id as target_widget_id
        property as property
        from_value as from_value
        to_value as to_value
        duration as duration
        delay as 0.0
        easing as EaseInOut
        direction as Forward
        iteration_count as Finite with count as 1
        fill_mode as None
        state as Idle
        current_time as 0.0
        start_time as Optional.None
        end_time as Optional.None
        progress as 0.0
        current_value as from_value

Process called "generate_animation_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "anim_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "configure_animation" that takes animation as Animation and duration as Float and easing as EasingFunction and delay as Float:
    Set animation.duration to duration
    Set animation.easing to easing
    Set animation.delay to delay

Process called "start_animation" that takes engine as AnimationEngine and animation as Animation:
    Set animation.state to Running
    Set animation.start_time to Optional.Some with value as get_current_animation_time
    Set animation.end_time to Optional.Some with value as (get_current_animation_time plus animation.delay plus animation.duration)
    
    Call Dict.set with dict as engine.running_animations and key as animation.animation_id and value as animation
    Call fire_animation_event with animation as animation and event_type as AnimationStart

Process called "get_current_animation_time" returns Float:
    Return Widgets.get_current_timestamp as Float

Process called "pause_animation" that takes engine as AnimationEngine and animation_id as String:
    Let animation_option be Dict.get with dict as engine.running_animations and key as animation_id
    Match animation_option:
        When Optional.Some with value as animation:
            Set animation.state to Paused
        When Optional.None:
            Pass

Process called "resume_animation" that takes engine as AnimationEngine and animation_id as String:
    Let animation_option be Dict.get with dict as engine.running_animations and key as animation_id
    Match animation_option:
        When Optional.Some with value as animation:
            If animation.state is equal to Paused:
                Set animation.state to Running
        When Optional.None:
            Pass

Process called "stop_animation" that takes engine as AnimationEngine and animation_id as String:
    Let animation_option be Dict.get with dict as engine.running_animations and key as animation_id
    Match animation_option:
        When Optional.Some with value as animation:
            Set animation.state to Cancelled
            Call fire_animation_event with animation as animation and event_type as AnimationCancel
            Call Dict.remove with dict as engine.running_animations and key as animation_id
        When Optional.None:
            Pass

Process called "fire_animation_event" that takes animation as Animation and event_type as AnimationEventType:
    Let event be AnimationEvent with:
        event_type as event_type
        animation_id as animation.animation_id
        timestamp as get_current_animation_time
        progress as animation.progress
    
    Call handle_animation_event with event as event

Process called "handle_animation_event" that takes event as AnimationEvent:
    Note: Handle animation events (callbacks, state updates, etc.)
    Match event.event_type:
        When AnimationStart:
            Display "Animation started: " concatenated with event.animation_id
        When AnimationEnd:
            Display "Animation ended: " concatenated with event.animation_id
        When AnimationCancel:
            Display "Animation cancelled: " concatenated with event.animation_id
        When AnimationIteration:
            Display "Animation iteration: " concatenated with event.animation_id

Note: Animation Update and Rendering

Process called "update_animations" that takes engine as AnimationEngine:
    Let current_time be get_current_animation_time
    Let delta_time be current_time minus engine.last_frame_time
    Set engine.last_frame_time to current_time
    
    Let completed_animations be List.empty
    
    For animation_id in Dict.keys with dict as engine.running_animations:
        Let animation_option be Dict.get with dict as engine.running_animations and key as animation_id
        Match animation_option:
            When Optional.Some with value as animation:
                If animation.state is equal to Running:
                    Call update_single_animation with animation as animation and current_time as current_time
                    If animation.state is equal to Completed:
                        Call List.append with list as completed_animations and item as animation_id
            When Optional.None:
                Pass
    
    Note: Remove completed animations
    For animation_id in completed_animations:
        Call Dict.remove with dict as engine.running_animations and key as animation_id

Process called "update_single_animation" that takes animation as Animation and current_time as Float:
    Match animation.start_time:
        When Optional.Some with value as start_time:
            Let elapsed_time be current_time minus start_time
            
            If elapsed_time is less than animation.delay:
                Return  Note: Animation hasn't started yet
            
            Let animation_time be elapsed_time minus animation.delay
            Set animation.current_time to animation_time
            
            If animation_time is greater than or equal to animation.duration:
                Note: Animation completed
                Set animation.progress to 1.0
                Set animation.current_value to animation.to_value
                Set animation.state to Completed
                Call fire_animation_event with animation as animation and event_type as AnimationEnd
            Otherwise:
                Note: Animation in progress
                Set animation.progress to animation_time divided by animation.duration
                Let eased_progress be apply_easing_function with progress as animation.progress and easing as animation.easing
                Set animation.current_value to interpolate_animation_values with from as animation.from_value and to as animation.to_value and progress as eased_progress
            
            Call apply_animation_to_widget with animation as animation
        When Optional.None:
            Pass

Process called "apply_easing_function" that takes progress as Float and easing as EasingFunction returns Float:
    Match easing:
        When Linear:
            Return progress
        When EaseIn:
            Return progress times progress
        When EaseOut:
            Return 1.0 minus ((1.0 minus progress) times (1.0 minus progress))
        When EaseInOut:
            If progress is less than 0.5:
                Return 2.0 times progress times progress
            Otherwise:
                Let adjusted be 1.0 minus (2.0 times progress minus 2.0)
                Return 1.0 minus (adjusted times adjusted divided by 2.0)
        When CubicBezier with p1_x as p1_x and p1_y as p1_y and p2_x as p2_x and p2_y as p2_y:
            Return evaluate_cubic_bezier with t as progress and p1_x as p1_x and p1_y as p1_y and p2_x as p2_x and p2_y as p2_y
        When Spring with tension as tension and friction as friction:
            Return evaluate_spring_easing with t as progress and tension as tension and friction as friction
        When Bounce:
            Return evaluate_bounce_easing with t as progress
        When Elastic:
            Return evaluate_elastic_easing with t as progress
        When Custom with function as func:
            Return func with progress as progress

Process called "evaluate_cubic_bezier" that takes t as Float and p1_x as Float and p1_y as Float and p2_x as Float and p2_y as Float returns Float:
    Note: Simplified cubic bezier evaluation
    Let t2 be t times t
    Let t3 be t2 times t
    Let u be 1.0 minus t
    Let u2 be u times u
    Let u3 be u2 times u
    
    Return (u3 times 0.0) plus (3.0 times u2 times t times p1_y) plus (3.0 times u times t2 times p2_y) plus (t3 times 1.0)

Process called "evaluate_spring_easing" that takes t as Float and tension as Float and friction as Float returns Float:
    Note: Simplified spring easing function
    Let damping be friction divided by (2.0 times square_root with value as tension)
    If damping is less than 1.0:
        Let omega be square_root with value as (tension minus (friction times friction) divided by 4.0)
        Let exp_decay be exponential with base as 2.71828 and exponent as (0.0 minus (damping times square_root with value as tension times t))
        Return 1.0 minus (exp_decay times cosine with angle as (omega times t))
    Otherwise:
        Let exp_decay be exponential with base as 2.71828 and exponent as (0.0 minus (square_root with value as tension times t))
        Return 1.0 minus (exp_decay times (1.0 plus (square_root with value as tension times t)))

Process called "evaluate_bounce_easing" that takes t as Float returns Float:
    If t is less than (1.0 divided by 2.75):
        Return 7.5625 times t times t
    If t is less than (2.0 divided by 2.75):
        Let adjusted_t be t minus (1.5 divided by 2.75)
        Return (7.5625 times adjusted_t times adjusted_t) plus 0.75
    If t is less than (2.5 divided by 2.75):
        Let adjusted_t be t minus (2.25 divided by 2.75)
        Return (7.5625 times adjusted_t times adjusted_t) plus 0.9375
    Otherwise:
        Let adjusted_t be t minus (2.625 divided by 2.75)
        Return (7.5625 times adjusted_t times adjusted_t) plus 0.984375

Process called "evaluate_elastic_easing" that takes t as Float returns Float:
    If t is equal to 0.0:
        Return 0.0
    If t is equal to 1.0:
        Return 1.0
    
    Let period be 0.3
    Let amplitude be 1.0
    Let s be period divided by 4.0
    
    Let adjusted_t be t minus 1.0
    Let exp_part be exponential with base as 2.71828 and exponent as (0.0 minus (10.0 times adjusted_t))
    Let sin_part be sine with angle as ((adjusted_t minus s) times (2.0 times 3.14159) divided by period)
    
    Return 0.0 minus (amplitude times exp_part times sin_part)

Process called "square_root" that takes value as Float returns Float:
    Note: Newton's method square root approximation
    Let guess be value divided by 2.0
    For i from 0 to 9:
        Set guess to (guess plus (value divided by guess)) divided by 2.0
    Return guess

Process called "exponential" that takes base as Float and exponent as Float returns Float:
    Note: Simplified exponential function for common cases
    If exponent is equal to 0.0:
        Return 1.0
    If exponent is equal to 1.0:
        Return base
    If exponent is equal to 2.0:
        Return base times base
    Otherwise:
        Note: Approximate using Taylor series for e^x when base is close to e
        Return 1.0 plus exponent  Note: Very simplified approximation

Process called "cosine" that takes angle as Float returns Float:
    Note: Simplified cosine approximation using Taylor series
    Let x be angle
    While x is greater than 6.28318:  Note: 2 * PI
        Set x to x minus 6.28318
    While x is less than 0.0:
        Set x to x plus 6.28318
    
    Let x2 be x times x
    Return 1.0 minus (x2 divided by 2.0) plus (x2 times x2 divided by 24.0)

Process called "sine" that takes angle as Float returns Float:
    Note: Use cosine identity: sin(x) = cos(PI/2 - x)
    Return cosine with angle as (1.5708 minus angle)  Note: PI/2 ≈ 1.5708

Process called "interpolate_animation_values" that takes from as AnimationValue and to as AnimationValue and progress as Float returns AnimationValue:
    Match from:
        When FloatValue with value as from_float:
            Match to:
                When FloatValue with value as to_float:
                    Let interpolated be from_float plus ((to_float minus from_float) times progress)
                    Return FloatValue with value as interpolated
                Otherwise:
                    Return from
        When ColorValue with color as from_color:
            Match to:
                When ColorValue with color as to_color:
                    Let interpolated_color be interpolate_colors with from as from_color and to as to_color and progress as progress
                    Return ColorValue with color as interpolated_color
                Otherwise:
                    Return from
        When TransformValue with transform as from_transform:
            Match to:
                When TransformValue with transform as to_transform:
                    Let interpolated_transform be interpolate_transforms with from as from_transform and to as to_transform and progress as progress
                    Return TransformValue with transform as interpolated_transform
                Otherwise:
                    Return from
        Otherwise:
            Return if progress is less than 0.5 then from else to

Process called "interpolate_colors" that takes from as Widgets.UIColor and to as Widgets.UIColor and progress as Float returns Widgets.UIColor:
    Match from:
        When Widgets.RGB with red as from_r and green as from_g and blue as from_b:
            Match to:
                When Widgets.RGB with red as to_r and green as to_g and blue as to_b:
                    Let interp_r be from_r plus ((to_r minus from_r) times progress) as Integer
                    Let interp_g be from_g plus ((to_g minus from_g) times progress) as Integer
                    Let interp_b be from_b plus ((to_b minus from_b) times progress) as Integer
                    Return Widgets.RGB with red as interp_r and green as interp_g and blue as interp_b
                Otherwise:
                    Return from
        Otherwise:
            Return if progress is less than 0.5 then from else to

Process called "interpolate_transforms" that takes from as Transform and to as Transform and progress as Float returns Transform:
    Return Transform with:
        translate_x as from.translate_x plus ((to.translate_x minus from.translate_x) times progress)
        translate_y as from.translate_y plus ((to.translate_y minus from.translate_y) times progress)
        translate_z as from.translate_z plus ((to.translate_z minus from.translate_z) times progress)
        rotate as from.rotate plus ((to.rotate minus from.rotate) times progress)
        rotate_x as from.rotate_x plus ((to.rotate_x minus from.rotate_x) times progress)
        rotate_y as from.rotate_y plus ((to.rotate_y minus from.rotate_y) times progress)
        rotate_z as from.rotate_z plus ((to.rotate_z minus from.rotate_z) times progress)
        scale_x as from.scale_x plus ((to.scale_x minus from.scale_x) times progress)
        scale_y as from.scale_y plus ((to.scale_y minus from.scale_y) times progress)
        scale_z as from.scale_z plus ((to.scale_z minus from.scale_z) times progress)
        skew_x as from.skew_x plus ((to.skew_x minus from.skew_x) times progress)
        skew_y as from.skew_y plus ((to.skew_y minus from.skew_y) times progress)

Process called "apply_animation_to_widget" that takes animation as Animation:
    Note: Apply the current animation value to the target widget
    Note: This would integrate with the widget system to update properties
    Pass

Note: Animation Helpers and Utilities

Process called "create_fade_in_animation" that takes target_widget_id as String and duration as Float returns Animation:
    Return create_animation with:
        name as "fade_in"
        target_widget_id as target_widget_id
        property as Opacity
        from_value as FloatValue with value as 0.0
        to_value as FloatValue with value as 1.0
        duration as duration

Process called "create_fade_out_animation" that takes target_widget_id as String and duration as Float returns Animation:
    Return create_animation with:
        name as "fade_out"
        target_widget_id as target_widget_id
        property as Opacity
        from_value as FloatValue with value as 1.0
        to_value as FloatValue with value as 0.0
        duration as duration

Process called "create_slide_in_animation" that takes target_widget_id as String and direction as SlideDirection and distance as Float and duration as Float returns Animation:
    Let transform_property be match direction:
        When SlideLeft:
            Transform with transform_type as TranslateX
        When SlideRight:
            Transform with transform_type as TranslateX
        When SlideUp:
            Transform with transform_type as TranslateY
        When SlideDown:
            Transform with transform_type as TranslateY
    
    Let from_distance be match direction:
        When SlideLeft:
            distance
        When SlideRight:
            0.0 minus distance
        When SlideUp:
            distance
        When SlideDown:
            0.0 minus distance
    
    Let from_transform be create_identity_transform
    Set from_transform.translate_x to if direction is equal to SlideLeft or direction is equal to SlideRight then from_distance else 0.0
    Set from_transform.translate_y to if direction is equal to SlideUp or direction is equal to SlideDown then from_distance else 0.0
    
    Let to_transform be create_identity_transform
    
    Return create_animation with:
        name as "slide_in"
        target_widget_id as target_widget_id
        property as transform_property
        from_value as TransformValue with transform as from_transform
        to_value as TransformValue with transform as to_transform
        duration as duration

Type SlideDirection is:
    | SlideLeft
    | SlideRight
    | SlideUp
    | SlideDown

Process called "create_identity_transform" returns Transform:
    Return Transform with:
        translate_x as 0.0
        translate_y as 0.0
        translate_z as 0.0
        rotate as 0.0
        rotate_x as 0.0
        rotate_y as 0.0
        rotate_z as 0.0
        scale_x as 1.0
        scale_y as 1.0
        scale_z as 1.0
        skew_x as 0.0
        skew_y as 0.0

Process called "create_scale_animation" that takes target_widget_id as String and from_scale as Float and to_scale as Float and duration as Float returns Animation:
    Let from_transform be create_identity_transform
    Set from_transform.scale_x to from_scale
    Set from_transform.scale_y to from_scale
    
    Let to_transform be create_identity_transform
    Set to_transform.scale_x to to_scale
    Set to_transform.scale_y to to_scale
    
    Return create_animation with:
        name as "scale"
        target_widget_id as target_widget_id
        property as Transform with transform_type as ScaleX
        from_value as TransformValue with transform as from_transform
        to_value as TransformValue with transform as to_transform
        duration as duration

Process called "create_rotation_animation" that takes target_widget_id as String and from_angle as Float and to_angle as Float and duration as Float returns Animation:
    Let from_transform be create_identity_transform
    Set from_transform.rotate as from_angle
    
    Let to_transform be create_identity_transform
    Set to_transform.rotate to to_angle
    
    Return create_animation with:
        name as "rotation"
        target_widget_id as target_widget_id
        property as Transform with transform_type as Rotate
        from_value as TransformValue with transform as from_transform
        to_value as TransformValue with transform as to_transform
        duration as duration

Note: Animation Groups and Sequencing

Process called "create_animation_group" that takes name as String and animations as List[Animation] returns AnimationGroup:
    Let group_id be generate_animation_group_id
    Let max_duration be calculate_group_duration with animations as animations
    
    Return AnimationGroup with:
        group_id as group_id
        name as name
        animations as animations
        state as Idle
        current_time as 0.0
        duration as max_duration

Process called "generate_animation_group_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "group_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "calculate_group_duration" that takes animations as List[Animation] returns Float:
    Let max_duration be 0.0
    For animation in animations:
        Let total_duration be animation.delay plus animation.duration
        Set max_duration to maximum of max_duration and total_duration
    Return max_duration

Process called "start_animation_group" that takes engine as AnimationEngine and group as AnimationGroup:
    Set group.state to Running
    
    For animation in group.animations:
        Call start_animation with engine as engine and animation as animation
    
    Call Dict.set with dict as engine.running_groups and key as group.group_id and value as group

Process called "create_sequential_animation" that takes name as String and animations as List[Animation] returns AnimationGroup:
    Let current_delay be 0.0
    
    For animation in animations:
        Set animation.delay to current_delay
        Set current_delay to current_delay plus animation.duration
    
    Return create_animation_group with name as name and animations as animations

Process called "create_parallel_animation" that takes name as String and animations as List[Animation] returns AnimationGroup:
    Note: All animations start at the same time (no delay adjustment needed)
    Return create_animation_group with name as name and animations as animations

Note: Performance and Optimization

Process called "set_performance_mode" that takes engine as AnimationEngine and mode as PerformanceMode:
    Set engine.performance_mode to mode
    
    Match mode:
        When HighPerformance:
            Set engine.frame_rate to 60.0
        When Balanced:
            Set engine.frame_rate to 30.0
        When PowerSaving:
            Set engine.frame_rate to 15.0

Process called "set_reduced_motion" that takes engine as AnimationEngine and reduced as Boolean:
    Set engine.reduced_motion to reduced
    
    If reduced:
        Note: Disable or simplify animations for accessibility
        Call simplify_running_animations with engine as engine

Process called "simplify_running_animations" that takes engine as AnimationEngine:
    For animation_id in Dict.keys with dict as engine.running_animations:
        Let animation_option be Dict.get with dict as engine.running_animations and key as animation_id
        Match animation_option:
            When Optional.Some with value as animation:
                Note: Simplify or complete animation immediately
                Set animation.duration to 0.1  Note: Very short duration
                Set animation.easing to Linear
            When Optional.None:
                Pass

Process called "optimize_animation_performance" that takes engine as AnimationEngine:
    Note: Remove completed animations and optimize memory usage
    Call cleanup_completed_animations with engine as engine
    Call optimize_frame_rate with engine as engine

Process called "cleanup_completed_animations" that takes engine as AnimationEngine:
    Let completed_ids be List.empty
    
    For animation_id in Dict.keys with dict as engine.running_animations:
        Let animation_option be Dict.get with dict as engine.running_animations and key as animation_id
        Match animation_option:
            When Optional.Some with value as animation:
                If animation.state is equal to Completed or animation.state is equal to Cancelled:
                    Call List.append with list as completed_ids and item as animation_id
            When Optional.None:
                Pass
    
    For animation_id in completed_ids:
        Call Dict.remove with dict as engine.running_animations and key as animation_id

Process called "optimize_frame_rate" that takes engine as AnimationEngine:
    Let running_count be length of (Dict.keys with dict as engine.running_animations)
    
    If running_count is greater than 50:
        Set engine.frame_rate to 30.0  Note: Reduce frame rate under heavy load
    If running_count is greater than 100:
        Set engine.frame_rate to 15.0  Note: Further reduce under extreme load
    Otherwise:
        Match engine.performance_mode:
            When HighPerformance:
                Set engine.frame_rate to 60.0
            Otherwise:
                Pass  Note: Keep current frame rate

Note: Animation Debugging and Utilities

Process called "get_animation_stats" that takes engine as AnimationEngine returns String:
    Let running_count be length of (Dict.keys with dict as engine.running_animations)
    Let group_count be length of (Dict.keys with dict as engine.running_groups)
    
    Return "Animation Engine Stats:\n" concatenated with
           "- Running animations: " concatenated with running_count as String concatenated with "\n" concatenated with
           "- Running groups: " concatenated with group_count as String concatenated with "\n" concatenated with
           "- Frame rate: " concatenated with engine.frame_rate as String concatenated with " fps\n" concatenated with
           "- Performance mode: " concatenated with performance_mode_to_string with mode as engine.performance_mode

Process called "performance_mode_to_string" that takes mode as PerformanceMode returns String:
    Match mode:
        When HighPerformance:
            Return "High Performance"
        When Balanced:
            Return "Balanced"
        When PowerSaving:
            Return "Power Saving"

Process called "pause_all_animations" that takes engine as AnimationEngine:
    For animation_id in Dict.keys with dict as engine.running_animations:
        Call pause_animation with engine as engine and animation_id as animation_id

Process called "resume_all_animations" that takes engine as AnimationEngine:
    For animation_id in Dict.keys with dict as engine.running_animations:
        Call resume_animation with engine as engine and animation_id as animation_id

Process called "clear_all_animations" that takes engine as AnimationEngine:
    For animation_id in Dict.keys with dict as engine.running_animations:
        Call stop_animation with engine as engine and animation_id as animation_id
    
    Call Dict.clear with dict as engine.running_animations
    Call Dict.clear with dict as engine.running_groups
    Call Dict.clear with dict as engine.running_timelines