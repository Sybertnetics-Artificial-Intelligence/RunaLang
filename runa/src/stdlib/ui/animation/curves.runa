Note:
Runa UI Framework: Animation Curves and Easing Functions

Advanced easing library that provides mathematically precise curves with custom
bezier functions, spring physics, and specialized motion patterns.

Features:
- Mathematically precise bezier curve evaluation with subdivision algorithms
- Physics-based spring curves with configurable tension and damping
- Specialized curves for UI patterns: bounce, elastic, anticipate, overshoot
- Custom curve creation with control point manipulation
- Performance-optimized lookup tables for complex curves
- Curve composition and chaining for advanced effects
:End Note

Import "collections/dict" as Dict
Import "collections/list" as List
Import "math/core" as Math

Note: Curve Definition Types

Type called "BezierCurve":
    p0_x as Float
    p0_y as Float
    p1_x as Float
    p1_y as Float
    p2_x as Float
    p2_y as Float
    p3_x as Float
    p3_y as Float
    lookup_table as Optional[List[Float]]
    table_resolution as Integer

Type called "SpringCurve":
    mass as Float
    stiffness as Float
    damping as Float
    velocity as Float
    precision as Float
    lookup_table as Optional[List[Float]]

Type called "BounceCurve":
    amplitude as Float
    period as Float
    bounce_count as Integer
    decay_factor as Float

Type called "ElasticCurve":
    amplitude as Float
    period as Float
    overshoot as Float

Type called "CustomCurve":
    curve_id as String
    name as String
    evaluation_function as Function
    control_points as List[ControlPoint]
    curve_type as CurveType

Type called "ControlPoint":
    x as Float
    y as Float
    handle_in_x as Float
    handle_in_y as Float
    handle_out_x as Float
    handle_out_y as Float

Type CurveType is:
    | Interpolated
    | Stepped
    | Linear
    | Bezier
    | BSpline
    | CatmullRom

Type called "CurveLibrary":
    predefined_curves as Dict[String, CustomCurve]
    user_curves as Dict[String, CustomCurve]
    curve_cache as Dict[String, List[Float]]

Type called "CurveComposition":
    composition_id as String
    curves as List[CurveSegment]
    blend_mode as BlendMode

Type called "CurveSegment":
    curve as CustomCurve
    start_time as Float
    end_time as Float
    weight as Float

Type BlendMode is:
    | Add
    | Multiply
    | Overlay
    | Screen
    | SoftLight

Note: Predefined Curve Constants

Process called "create_curve_library" returns CurveLibrary:
    Let library be CurveLibrary with:
        predefined_curves as Dict.empty
        user_curves as Dict.empty
        curve_cache as Dict.empty
    
    Call populate_predefined_curves with library as library
    Return library

Process called "populate_predefined_curves" that takes library as CurveLibrary:
    Note: Add standard easing curves
    Call add_predefined_curve with library as library and name as "linear" and curve as create_linear_curve
    Call add_predefined_curve with library as library and name as "ease" and curve as create_ease_curve
    Call add_predefined_curve with library as library and name as "ease_in" and curve as create_ease_in_curve
    Call add_predefined_curve with library as library and name as "ease_out" and curve as create_ease_out_curve
    Call add_predefined_curve with library as library and name as "ease_in_out" and curve as create_ease_in_out_curve
    
    Note: Add specialized curves
    Call add_predefined_curve with library as library and name as "bounce_in" and curve as create_bounce_in_curve
    Call add_predefined_curve with library as library and name as "bounce_out" and curve as create_bounce_out_curve
    Call add_predefined_curve with library as library and name as "bounce_in_out" and curve as create_bounce_in_out_curve
    
    Call add_predefined_curve with library as library and name as "elastic_in" and curve as create_elastic_in_curve
    Call add_predefined_curve with library as library and name as "elastic_out" and curve as create_elastic_out_curve
    Call add_predefined_curve with library as library and name as "elastic_in_out" and curve as create_elastic_in_out_curve
    
    Call add_predefined_curve with library as library and name as "back_in" and curve as create_back_in_curve
    Call add_predefined_curve with library as library and name as "back_out" and curve as create_back_out_curve
    Call add_predefined_curve with library as library and name as "back_in_out" and curve as create_back_in_out_curve

Process called "add_predefined_curve" that takes library as CurveLibrary and name as String and curve as CustomCurve:
    Call Dict.set with dict as library.predefined_curves and key as name and value as curve

Note: Standard Easing Curves

Process called "create_linear_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        Return t
    
    Return CustomCurve with:
        curve_id as "linear"
        name as "Linear"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Linear

Process called "create_ease_curve" returns CustomCurve:
    Return create_cubic_bezier_curve with p1_x as 0.25 and p1_y as 0.1 and p2_x as 0.25 and p2_y as 1.0 and name as "Ease"

Process called "create_ease_in_curve" returns CustomCurve:
    Return create_cubic_bezier_curve with p1_x as 0.42 and p1_y as 0.0 and p2_x as 1.0 and p2_y as 1.0 and name as "Ease In"

Process called "create_ease_out_curve" returns CustomCurve:
    Return create_cubic_bezier_curve with p1_x as 0.0 and p1_y as 0.0 and p2_x as 0.58 and p2_y as 1.0 and name as "Ease Out"

Process called "create_ease_in_out_curve" returns CustomCurve:
    Return create_cubic_bezier_curve with p1_x as 0.42 and p1_y as 0.0 and p2_x as 0.58 and p2_y as 1.0 and name as "Ease In Out"

Note: Cubic Bezier Curve Implementation

Process called "create_cubic_bezier_curve" that takes p1_x as Float and p1_y as Float and p2_x as Float and p2_y as Float and name as String returns CustomCurve:
    Let bezier be BezierCurve with:
        p0_x as 0.0
        p0_y as 0.0
        p1_x as p1_x
        p1_y as p1_y
        p2_x as p2_x
        p2_y as p2_y
        p3_x as 1.0
        p3_y as 1.0
        lookup_table as Optional.None
        table_resolution as 100
    
    Let evaluation_function be Process that takes t as Float returns Float:
        Return evaluate_cubic_bezier_curve with bezier as bezier and t as t
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as name
        evaluation_function as evaluation_function
        control_points as bezier_to_control_points with bezier as bezier
        curve_type as Bezier

Process called "generate_curve_id" returns String:
    Let timestamp be get_current_timestamp
    Let random_suffix be generate_random_string with length as 6
    Return "curve_" Joined with timestamp as String Joined with "_" Joined with random_suffix

Process called "get_current_timestamp" returns Integer:
    Return 1600000000  Note: Placeholder timestamp

Process called "generate_random_string" that takes length as Integer returns String:
    Let characters be "abcdefghijklmnopqrstuvwxyz0123456789"
    Let result be ""
    For i from 0 to (length minus 1):
        Let random_index be i modulo (length of characters)
        Let char be characters at index random_index
        Set result to result Joined with char
    Return result

Process called "bezier_to_control_points" that takes bezier as BezierCurve returns List[ControlPoint]:
    Let points be List.empty
    
    Let p0 be ControlPoint with:
        x as bezier.p0_x
        y as bezier.p0_y
        handle_in_x as bezier.p0_x
        handle_in_y as bezier.p0_y
        handle_out_x as bezier.p1_x
        handle_out_y as bezier.p1_y
    Call List.append with list as points and item as p0
    
    Let p3 be ControlPoint with:
        x as bezier.p3_x
        y as bezier.p3_y
        handle_in_x as bezier.p2_x
        handle_in_y as bezier.p2_y
        handle_out_x as bezier.p3_x
        handle_out_y as bezier.p3_y
    Call List.append with list as points and item as p3
    
    Return points

Process called "evaluate_cubic_bezier_curve" that takes bezier as BezierCurve and t as Float returns Float:
    Note: Use lookup table if available, otherwise compute directly
    Match bezier.lookup_table:
        When Optional.Some with value as table:
            Return lookup_curve_value with table as table and t as t
        When Optional.None:
            Return compute_cubic_bezier_y with bezier as bezier and t as t

Process called "compute_cubic_bezier_y" that takes bezier as BezierCurve and t as Float returns Float:
    Note: Find the t parameter that gives us the desired x value, then compute y
    Let target_x be t
    Let bezier_t be solve_cubic_bezier_x with bezier as bezier and target_x as target_x
    
    Note: Compute y value using the found t parameter
    Let u be 1.0 minus bezier_t
    Let u2 be u times u
    Let u3 be u2 times u
    Let t2 be bezier_t times bezier_t
    Let t3 be t2 times bezier_t
    
    Return (u3 times bezier.p0_y) plus (3.0 times u2 times bezier_t times bezier.p1_y) plus (3.0 times u times t2 times bezier.p2_y) plus (t3 times bezier.p3_y)

Process called "solve_cubic_bezier_x" that takes bezier as BezierCurve and target_x as Float returns Float:
    Note: Use Newton-Raphson method to solve for t given x
    Let t be target_x  Note: Initial guess
    
    For iteration from 0 to 9:  Note: Max 10 iterations
        Let x be compute_cubic_bezier_x_at_t with bezier as bezier and t as t
        Let dx be compute_cubic_bezier_dx_dt with bezier as bezier and t as t
        
        If absolute_value of (x minus target_x) is less than 0.0001:
            Return t
        
        If absolute_value of dx is less than 0.0001:
            Break  Note: Avoid division by zero
        
        Set t to t minus ((x minus target_x) divided by dx)
        Set t to clamp with value as t and min as 0.0 and max as 1.0
    
    Return t

Process called "compute_cubic_bezier_x_at_t" that takes bezier as BezierCurve and t as Float returns Float:
    Let u be 1.0 minus t
    Let u2 be u times u
    Let u3 be u2 times u
    Let t2 be t times t
    Let t3 be t2 times t
    
    Return (u3 times bezier.p0_x) plus (3.0 times u2 times t times bezier.p1_x) plus (3.0 times u times t2 times bezier.p2_x) plus (t3 times bezier.p3_x)

Process called "compute_cubic_bezier_dx_dt" that takes bezier as BezierCurve and t as Float returns Float:
    Let u be 1.0 minus t
    Let u2 be u times u
    Let t2 be t times t
    
    Return (3.0 times u2 times (bezier.p1_x minus bezier.p0_x)) plus (6.0 times u times t times (bezier.p2_x minus bezier.p1_x)) plus (3.0 times t2 times (bezier.p3_x minus bezier.p2_x))

Process called "absolute_value" that takes value as Float returns Float:
    Return if value is greater than or equal to 0.0 then value else (0.0 minus value)

Process called "clamp" that takes value as Float and min as Float and max as Float returns Float:
    If value is less than min:
        Return min
    If value is greater than max:
        Return max
    Return value

Note: Bounce Curves

Process called "create_bounce_in_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        Return 1.0 minus evaluate_bounce_out with t as (1.0 minus t)
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Bounce In"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Process called "create_bounce_out_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        Return evaluate_bounce_out with t as t
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Bounce Out"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Process called "create_bounce_in_out_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        If t is less than 0.5:
            Return (1.0 minus evaluate_bounce_out with t as (1.0 minus (2.0 times t))) times 0.5
        Otherwise:
            Return (evaluate_bounce_out with t as ((2.0 times t) minus 1.0) times 0.5) plus 0.5
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Bounce In Out"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Process called "evaluate_bounce_out" that takes t as Float returns Float:
    Let n1 be 7.5625
    Let d1 be 2.75
    
    If t is less than (1.0 divided by d1):
        Return n1 times t times t
    If t is less than (2.0 divided by d1):
        Let adjusted_t be t minus (1.5 divided by d1)
        Return (n1 times adjusted_t times adjusted_t) plus 0.75
    If t is less than (2.5 divided by d1):
        Let adjusted_t be t minus (2.25 divided by d1)
        Return (n1 times adjusted_t times adjusted_t) plus 0.9375
    Otherwise:
        Let adjusted_t be t minus (2.625 divided by d1)
        Return (n1 times adjusted_t times adjusted_t) plus 0.984375

Note: Elastic Curves

Process called "create_elastic_in_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        Return 0.0 minus evaluate_elastic_out with t as (1.0 minus t)
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Elastic In"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Process called "create_elastic_out_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        Return evaluate_elastic_out with t as t
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Elastic Out"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Process called "create_elastic_in_out_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        If t is less than 0.5:
            Return (0.0 minus evaluate_elastic_out with t as (1.0 minus (2.0 times t))) times 0.5
        Otherwise:
            Return (evaluate_elastic_out with t as ((2.0 times t) minus 1.0) times 0.5) plus 0.5
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Elastic In Out"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Process called "evaluate_elastic_out" that takes t as Float returns Float:
    If t is equal to 0.0:
        Return 0.0
    If t is equal to 1.0:
        Return 1.0
    
    Let c4 be (2.0 times 3.14159) divided by 3.0
    Let power_result be power_of_2 with exponent as (0.0 minus (10.0 times t))
    Let sine_result be sine with angle as ((t times 10.0 minus 0.75) times c4)
    
    Return power_result times sine_result plus 1.0

Process called "power_of_2" that takes exponent as Float returns Float:
    Note: Simplified 2^x approximation
    If exponent is equal to 0.0:
        Return 1.0
    If exponent is equal to 1.0:
        Return 2.0
    If exponent is equal to 2.0:
        Return 4.0
    If exponent is less than 0.0:
        Return 1.0 divided by power_of_2 with exponent as (0.0 minus exponent)
    Otherwise:
        Note: Linear approximation for simplicity
        Return 1.0 plus exponent

Process called "sine" that takes angle as Float returns Float:
    Note: Taylor series approximation for sine
    Let x be angle
    Let x3 be x times x times x
    Let x5 be x3 times x times x
    Return x minus (x3 divided by 6.0) plus (x5 divided by 120.0)

Note: Back (Overshoot) Curves

Process called "create_back_in_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        Let c1 be 1.70158
        Let c3 be c1 plus 1.0
        Return c3 times t times t times t minus c1 times t times t
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Back In"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Process called "create_back_out_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        Let c1 be 1.70158
        Let c3 be c1 plus 1.0
        Let adjusted_t be t minus 1.0
        Return 1.0 plus c3 times adjusted_t times adjusted_t times adjusted_t plus c1 times adjusted_t times adjusted_t
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Back Out"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Process called "create_back_in_out_curve" returns CustomCurve:
    Let evaluation_function be Process that takes t as Float returns Float:
        Let c1 be 1.70158
        Let c2 be c1 times 1.525
        
        If t is less than 0.5:
            Let doubled_t be 2.0 times t
            Return (doubled_t times doubled_t times ((c2 plus 1.0) times doubled_t minus c2)) divided by 2.0
        Otherwise:
            Let adjusted_t be (2.0 times t) minus 2.0
            Return ((adjusted_t times adjusted_t times ((c2 plus 1.0) times adjusted_t plus c2)) plus 2.0) divided by 2.0
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Back In Out"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Note: Spring Physics Curves

Process called "create_spring_curve" that takes mass as Float and stiffness as Float and damping as Float returns CustomCurve:
    Let spring be SpringCurve with:
        mass as mass
        stiffness as stiffness
        damping as damping
        velocity as 0.0
        precision as 0.001
        lookup_table as Optional.None
    
    Let evaluation_function be Process that takes t as Float returns Float:
        Return evaluate_spring_curve with spring as spring and t as t
    
    Return CustomCurve with:
        curve_id as generate_curve_id
        name as "Spring"
        evaluation_function as evaluation_function
        control_points as List.empty
        curve_type as Interpolated

Process called "evaluate_spring_curve" that takes spring as SpringCurve and t as Float returns Float:
    Note: Simplified spring physics evaluation
    Let omega be square_root with value as (spring.stiffness divided by spring.mass)
    Let zeta be spring.damping divided by (2.0 times square_root with value as (spring.stiffness times spring.mass))
    
    If zeta is less than 1.0:
        Note: Underdamped oscillation
        Let omega_d be omega times square_root with value as (1.0 minus (zeta times zeta))
        Let exp_decay be exponential with base as 2.71828 and exponent as (0.0 minus (zeta times omega times t))
        Return 1.0 minus (exp_decay times (cosine with angle as (omega_d times t)))
    If zeta is equal to 1.0:
        Note: Critically damped
        Let exp_decay be exponential with base as 2.71828 and exponent as (0.0 minus (omega times t))
        Return 1.0 minus (exp_decay times (1.0 plus (omega times t)))
    Otherwise:
        Note: Overdamped
        Let r1 be (0.0 minus zeta plus square_root with value as ((zeta times zeta) minus 1.0)) times omega
        Let r2 be (0.0 minus zeta minus square_root with value as ((zeta times zeta) minus 1.0)) times omega
        Let exp1 be exponential with base as 2.71828 and exponent as (r1 times t)
        Let exp2 be exponential with base as 2.71828 and exponent as (r2 times t)
        Return 1.0 minus ((r2 times exp1 minus r1 times exp2) divided by (r2 minus r1))

Process called "square_root" that takes value as Float returns Float:
    Note: Newton's method square root
    If value is less than or equal to 0.0:
        Return 0.0
    
    Let guess be value divided by 2.0
    For i from 0 to 9:
        Set guess to (guess plus (value divided by guess)) divided by 2.0
    Return guess

Process called "exponential" that takes base as Float and exponent as Float returns Float:
    Note: Simplified exponential for common cases
    If exponent is equal to 0.0:
        Return 1.0
    If base is equal to 2.71828 and exponent is greater than 0.0 and exponent is less than 1.0:
        Return 1.0 plus exponent plus ((exponent times exponent) divided by 2.0)
    If base is equal to 2.71828 and exponent is less than 0.0:
        Let positive_exp be 0.0 minus exponent
        Return 1.0 divided by (1.0 plus positive_exp plus ((positive_exp times positive_exp) divided by 2.0))
    Otherwise:
        Return 1.0

Process called "cosine" that takes angle as Float returns Float:
    Note: Taylor series cosine approximation
    Let x be angle
    Let x2 be x times x
    Let x4 be x2 times x2
    Return 1.0 minus (x2 divided by 2.0) plus (x4 divided by 24.0)

Note: Lookup Table Optimization

Process called "generate_lookup_table" that takes curve as CustomCurve and resolution as Integer returns List[Float]:
    Let table be List.empty
    
    For i from 0 to resolution:
        Let t be (i as Float) divided by (resolution as Float)
        Let value be curve.evaluation_function with t as t
        Call List.append with list as table and item as value
    
    Return table

Process called "lookup_curve_value" that takes table as List[Float] and t as Float returns Float:
    Let clamped_t be clamp with value as t and min as 0.0 and max as 1.0
    Let table_size be length of table
    Let index_float be clamped_t times ((table_size minus 1) as Float)
    Let index be index_float as Integer
    Let fraction be index_float minus (index as Float)
    
    If index is greater than or equal to (table_size minus 1):
        Return table at index (table_size minus 1)
    
    Let value1 be table at index index
    Let value2 be table at index (index plus 1)
    
    Return value1 plus ((value2 minus value1) times fraction)

Process called "precompute_curve_table" that takes curve as CustomCurve and resolution as Integer:
    Let table be generate_lookup_table with curve as curve and resolution as resolution
    Note: This would update the curve's lookup table if it was mutable
    Pass

Note: Curve Library Management

Process called "get_curve_by_name" that takes library as CurveLibrary and name as String returns Optional[CustomCurve]:
    Let predefined_curve be Dict.get with dict as library.predefined_curves and key as name
    Match predefined_curve:
        When Optional.Some with value as curve:
            Return Optional.Some with value as curve
        When Optional.None:
            Return Dict.get with dict as library.user_curves and key as name

Process called "add_user_curve" that takes library as CurveLibrary and curve as CustomCurve:
    Call Dict.set with dict as library.user_curves and key as curve.name and value as curve

Process called "remove_user_curve" that takes library as CurveLibrary and name as String:
    Call Dict.remove with dict as library.user_curves and key as name

Process called "list_available_curves" that takes library as CurveLibrary returns List[String]:
    Let curve_names be List.empty
    
    For name in Dict.keys with dict as library.predefined_curves:
        Call List.append with list as curve_names and item as name
    
    For name in Dict.keys with dict as library.user_curves:
        Call List.append with list as curve_names and item as name
    
    Return curve_names

Note: Curve Composition and Blending

Process called "create_curve_composition" that takes curves as List[CurveSegment] and blend_mode as BlendMode returns CurveComposition:
    Let composition_id be generate_curve_id
    
    Return CurveComposition with:
        composition_id as composition_id
        curves as curves
        blend_mode as blend_mode

Process called "evaluate_curve_composition" that takes composition as CurveComposition and t as Float returns Float:
    Let result be 0.0
    Let total_weight be 0.0
    
    For segment in composition.curves:
        If t is greater than or equal to segment.start_time and t is less than or equal to segment.end_time:
            Let segment_t be (t minus segment.start_time) divided by (segment.end_time minus segment.start_time)
            Let segment_value be segment.curve.evaluation_function with t as segment_t
            
            Match composition.blend_mode:
                When Add:
                    Set result to result plus (segment_value times segment.weight)
                When Multiply:
                    Set result to result times segment_value
                When Overlay:
                    Set result to blend_overlay with base as result and overlay as segment_value
                When Screen:
                    Set result to blend_screen with base as result and overlay as segment_value
                When SoftLight:
                    Set result to blend_soft_light with base as result and overlay as segment_value
            
            Set total_weight to total_weight plus segment.weight
    
    If composition.blend_mode is equal to Add and total_weight is greater than 0.0:
        Set result to result divided by total_weight
    
    Return clamp with value as result and min as 0.0 and max as 1.0

Process called "blend_overlay" that takes base as Float and overlay as Float returns Float:
    If base is less than 0.5:
        Return 2.0 times base times overlay
    Otherwise:
        Return 1.0 minus (2.0 times (1.0 minus base) times (1.0 minus overlay))

Process called "blend_screen" that takes base as Float and overlay as Float returns Float:
    Return 1.0 minus ((1.0 minus base) times (1.0 minus overlay))

Process called "blend_soft_light" that takes base as Float and overlay as Float returns Float:
    If overlay is less than 0.5:
        Return base minus ((1.0 minus (2.0 times overlay)) times base times (1.0 minus base))
    Otherwise:
        Return base plus (((2.0 times overlay) minus 1.0) times (square_root with value as base minus base))

Note: Curve Analysis and Utilities

Process called "analyze_curve_properties" that takes curve as CustomCurve and sample_count as Integer returns CurveAnalysis:
    Let samples be generate_curve_samples with curve as curve and sample_count as sample_count
    
    Return CurveAnalysis with:
        min_value as find_minimum_value with samples as samples
        max_value as find_maximum_value with samples as samples
        average_value as calculate_average_value with samples as samples
        peak_count as count_peaks with samples as samples
        monotonic as is_monotonic with samples as samples

Type called "CurveAnalysis":
    min_value as Float
    max_value as Float
    average_value as Float
    peak_count as Integer
    monotonic as Boolean

Process called "generate_curve_samples" that takes curve as CustomCurve and sample_count as Integer returns List[Float]:
    Let samples be List.empty
    
    For i from 0 to sample_count:
        Let t be (i as Float) divided by (sample_count as Float)
        Let value be curve.evaluation_function with t as t
        Call List.append with list as samples and item as value
    
    Return samples

Process called "find_minimum_value" that takes samples as List[Float] returns Float:
    Let min_value be 1.0
    For sample in samples:
        Set min_value to minimum of min_value and sample
    Return min_value

Process called "find_maximum_value" that takes samples as List[Float] returns Float:
    Let max_value be 0.0
    For sample in samples:
        Set max_value to maximum of max_value and sample
    Return max_value

Process called "calculate_average_value" that takes samples as List[Float] returns Float:
    Let sum be 0.0
    For sample in samples:
        Set sum to sum plus sample
    Return sum divided by ((length of samples) as Float)

Process called "count_peaks" that takes samples as List[Float] returns Integer:
    Let peak_count be 0
    Let sample_count be length of samples
    
    For i from 1 to (sample_count minus 2):
        Let prev_value be samples at index (i minus 1)
        Let current_value be samples at index i
        Let next_value be samples at index (i plus 1)
        
        If current_value is greater than prev_value and current_value is greater than next_value:
            Set peak_count to peak_count plus 1
    
    Return peak_count

Process called "is_monotonic" that takes samples as List[Float] returns Boolean:
    Let is_increasing be true
    Let is_decreasing be true
    
    For i from 1 to ((length of samples) minus 1):
        Let prev_value be samples at index (i minus 1)
        Let current_value be samples at index i
        
        If current_value is less than prev_value:
            Set is_increasing to false
        If current_value is greater than prev_value:
            Set is_decreasing to false
    
    Return is_increasing or is_decreasing

Process called "minimum" that takes a as Float and b as Float returns Float:
    Return if a is less than b then a else b

Process called "maximum" that takes a as Float and b as Float returns Float:
    Return if a is greater than b then a else b