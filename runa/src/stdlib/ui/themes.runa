            color as create_color with red as 0 and green as 0 and blue as 0
            inset as false
        sm as ShadowToken with:
            offset_x as 0.0
            offset_y as 1.0
            blur_radius as 3.0
            spread_radius as 0.0
            color as create_color with red as 0 and green as 0 and blue as 0
            inset as false
        base as ShadowToken with:
            offset_x as 0.0
            offset_y as 1.0
            blur_radius as 3.0
            spread_radius as 0.0
            color as create_color with red as 0 and green as 0 and blue as 0
            inset as false
        md as ShadowToken with:
            offset_x as 0.0
            offset_y as 4.0
            blur_radius as 6.0
            spread_radius as -1.0
            color as create_color with red as 0 and green as 0 and blue as 0
            inset as false
        lg as ShadowToken with:
            offset_x as 0.0
            offset_y as 10.0
            blur_radius as 15.0
            spread_radius as -3.0
            color as create_color with red as 0 and green as 0 and blue as 0
            inset as false
        xl as ShadowToken with:
            offset_x as 0.0
            offset_y as 20.0
            blur_radius as 25.0
            spread_radius as -5.0
            color as create_color with red as 0 and green as 0 and blue as 0
            inset as false
        xl2 as ShadowToken with:
            offset_x as 0.0
            offset_y as 25.0
            blur_radius as 50.0
            spread_radius as -12.0
            color as create_color with red as 0 and green as 0 and blue as 0
            inset as false
        inner as ShadowToken with:
            offset_x as 0.0
            offset_y as 2.0
            blur_radius as 4.0
            spread_radius as 0.0
            color as create_color with red as 0 and green as 0 and blue as 0
            inset as true

Process called "create_dark_shadow_scale" returns ShadowScale:
    Let light_shadows be create_default_shadow_scale
    Note: Dark mode shadows are typically more intense
    Return ShadowScale with:
        xs as enhance_shadow_for_dark_mode with shadow as light_shadows.xs
        sm as enhance_shadow_for_dark_mode with shadow as light_shadows.sm
        base as enhance_shadow_for_dark_mode with shadow as light_shadows.base
        md as enhance_shadow_for_dark_mode with shadow as light_shadows.md
        lg as enhance_shadow_for_dark_mode with shadow as light_shadows.lg
        xl as enhance_shadow_for_dark_mode with shadow as light_shadows.xl
        xl2 as enhance_shadow_for_dark_mode with shadow as light_shadows.xl2
        inner as enhance_shadow_for_dark_mode with shadow as light_shadows.inner

Process called "enhance_shadow_for_dark_mode" that takes shadow as ShadowToken returns ShadowToken:
    Return ShadowToken with:
        offset_x as shadow.offset_x
        offset_y as shadow.offset_y
        blur_radius as shadow.blur_radius times 1.2
        spread_radius as shadow.spread_radius
        color as shadow.color
        inset as shadow.inset

Process called "create_default_animation_tokens" returns AnimationTokens:
    Return AnimationTokens with:
        durations as AnimationDurations with:
            instant as 0.0
            fast as 150.0
            normal as 300.0
            slow as 500.0
            slower as 800.0
        easings as AnimationEasings with:
            linear as "linear"
            ease as "ease"
            ease_in as "ease-in"
            ease_out as "ease-out"
            ease_in_out as "ease-in-out"
            bounce as "cubic-bezier(0.68, -0.55, 0.265, 1.55)"
            elastic as "cubic-bezier(0.175, 0.885, 0.32, 1.275)"
        delays as AnimationDelays with:
            none as 0.0
            short as 100.0
            medium as 200.0
            long as 500.0

Process called "create_default_accessibility_tokens" returns AccessibilityTokens:
    Return AccessibilityTokens with:
        focus_ring_width as 2.0
        focus_ring_color as create_color with red as 37 and green as 99 and blue as 235
        focus_ring_offset as 2.0
        high_contrast_mode as false
        reduced_motion as false
        minimum_touch_target as 44.0
        minimum_contrast_ratio as 4.5

Process called "create_high_contrast_theme" returns Theme:
    Let base_theme be create_default_light_theme
    Return Theme with:
        name as "High Contrast"
        version as "1.0.0"
        colors as create_high_contrast_color_palette
        typography as base_theme.typography
        spacing as base_theme.spacing
        borders as base_theme.borders
        shadows as create_minimal_shadow_scale
        animations as base_theme.animations
        accessibility as AccessibilityTokens with:
            focus_ring_width as 3.0
            focus_ring_color as create_color with red as 255 and green as 255 and blue as 0
            focus_ring_offset as 3.0
            high_contrast_mode as true
            reduced_motion as false
            minimum_touch_target as 48.0
            minimum_contrast_ratio as 7.0
        custom_tokens as Dict.empty
        metadata as ThemeMetadata with:
            author as "Runa UI Framework"
            description as "High contrast theme for accessibility"
            created_at as get_current_timestamp
            updated_at as get_current_timestamp
            tags as list containing "high-contrast", "accessibility", "a11y"
            license as "MIT"
            supports_dark_mode as false
            wcag_compliant as true

Process called "create_high_contrast_color_palette" returns ColorPalette:
    Note: High contrast palette with maximum contrast ratios
    Let base_palette be create_light_color_palette
    Return ColorPalette with:
        primary as base_palette.primary
        secondary as base_palette.secondary
        tertiary as base_palette.tertiary
        success as base_palette.success
        warning as base_palette.warning
        error as base_palette.error
        info as base_palette.info
        neutral as base_palette.neutral
        surface as SurfaceColors with:
            background as create_color with red as 255 and green as 255 and blue as 255
            foreground as create_color with red as 0 and green as 0 and blue as 0
            card as create_color with red as 255 and green as 255 and blue as 255
            popover as create_color with red as 255 and green as 255 and blue as 255
            modal as create_color with red as 255 and green as 255 and blue as 255
            sidebar as create_color with red as 240 and green as 240 and blue as 240
            navbar as create_color with red as 255 and green as 255 and blue as 255
            footer as create_color with red as 240 and green as 240 and blue as 240
        text as TextColors with:
            primary as create_color with red as 0 and green as 0 and blue as 0
            secondary as create_color with red as 0 and green as 0 and blue as 0
            muted as create_color with red as 64 and green as 64 and blue as 64
            disabled as create_color with red as 128 and green as 128 and blue as 128
            placeholder as create_color with red as 128 and green as 128 and blue as 128
            link as create_color with red as 0 and green as 0 and blue as 255
            link_hover as create_color with red as 0 and green as 0 and blue as 128
            link_visited as create_color with red as 128 and green as 0 and blue as 128
        border as BorderColors with:
            default as create_color with red as 0 and green as 0 and blue as 0
            muted as create_color with red as 128 and green as 128 and blue as 128
            focus as create_color with red as 255 and green as 255 and blue as 0
            error as create_color with red as 255 and green as 0 and blue as 0
            success as create_color with red as 0 and green as 128 and blue as 0
            warning as create_color with red as 255 and green as 165 and blue as 0
        semantic as base_palette.semantic

Process called "create_minimal_shadow_scale" returns ShadowScale:
    Let no_shadow be ShadowToken with:
        offset_x as 0.0
        offset_y as 0.0
        blur_radius as 0.0
        spread_radius as 0.0
        color as create_color with red as 0 and green as 0 and blue as 0
        inset as false
    
    Return ShadowScale with:
        xs as no_shadow
        sm as no_shadow
        base as no_shadow
        md as no_shadow
        lg as no_shadow
        xl as no_shadow
        xl2 as no_shadow
        inner as no_shadow

Note: Theme Application and Management

Process called "apply_theme_to_widget" that takes theme as Theme and widget as Widgets.UIWidget:
    Note: Apply theme colors and styles to widget based on widget type
    Match widget.widget_type:
        When "button":
            Call apply_button_theme with theme as theme and widget as widget
        When "input":
            Call apply_input_theme with theme as theme and widget as widget
        When "text":
            Call apply_text_theme with theme as theme and widget as widget
        Otherwise:
            Call apply_default_theme with theme as theme and widget as widget

Process called "apply_button_theme" that takes theme as Theme and widget as Widgets.UIWidget:
    Call Widgets.set_widget_style_property with widget as widget and property as "background_color" and value as theme.colors.primary.500
    Call Widgets.set_widget_style_property with widget as widget and property as "text_color" and value as theme.colors.surface.background
    Call Widgets.set_widget_style_property with widget as widget and property as "border_radius" and value as theme.borders.default
    Call Widgets.set_widget_style_property with widget as widget and property as "font_family" and value as theme.typography.font_families.body

Process called "apply_input_theme" that takes theme as Theme and widget as Widgets.UIWidget:
    Call Widgets.set_widget_style_property with widget as widget and property as "background_color" and value as theme.colors.surface.background
    Call Widgets.set_widget_style_property with widget as widget and property as "text_color" and value as theme.colors.text.primary
    Call Widgets.set_widget_style_property with widget as widget and property as "border_color" and value as theme.colors.border.default
    Call Widgets.set_widget_style_property with widget as widget and property as "border_width" and value as theme.borders.default

Process called "apply_text_theme" that takes theme as Theme and widget as Widgets.UIWidget:
    Call Widgets.set_widget_style_property with widget as widget and property as "text_color" and value as theme.colors.text.primary
    Call Widgets.set_widget_style_property with widget as widget and property as "font_family" and value as theme.typography.font_families.body
    Call Widgets.set_widget_style_property with widget as widget and property as "font_size" and value as theme.typography.font_sizes.base

Process called "apply_default_theme" that takes theme as Theme and widget as Widgets.UIWidget:
    Call Widgets.set_widget_style_property with widget as widget and property as "background_color" and value as theme.colors.surface.background
    Call Widgets.set_widget_style_property with widget as widget and property as "text_color" and value as theme.colors.text.primary

Process called "switch_theme" that takes manager as ThemeManager and theme_name as String returns Boolean:
    For theme in manager.available_themes:
        If theme.name is equal to theme_name:
            Set manager.current_theme to theme
            Return true
    Return false

Process called "get_theme_by_name" that takes manager as ThemeManager and theme_name as String returns Optional[Theme]:
    For theme in manager.available_themes:
        If theme.name is equal to theme_name:
            Return Optional.Some with value as theme
    Return Optional.None

Process called "add_custom_theme" that takes manager as ThemeManager and theme as Theme:
    Call List.append with list as manager.available_themes and item as theme

Process called "remove_theme" that takes manager as ThemeManager and theme_name as String returns Boolean:
    Let filtered_themes be List.filter with list as manager.available_themes and predicate as (Process that takes theme as Theme returns Boolean:
        Return theme.name is not equal to theme_name
    )
    
    Let original_count be length of manager.available_themes
    Set manager.available_themes to filtered_themes
    Let new_count be length of manager.available_themes
    
    Return new_count is less than original_count

Note: Color Utility Functions

Process called "get_contrast_ratio" that takes color1 as Color and color2 as Color returns Float:
    Let luminance1 be get_relative_luminance with color as color1
    Let luminance2 be get_relative_luminance with color as color2
    
    Let lighter be Math.maximum of luminance1 and luminance2
    Let darker be Math.minimum of luminance1 and luminance2
    
    Return (lighter plus 0.05) divided by (darker plus 0.05)

Process called "get_relative_luminance" that takes color as Color returns Float:
    Let r be color.red as Float divided by 255.0
    Let g be color.green as Float divided by 255.0
    Let b be color.blue as Float divided by 255.0
    
    Let r_linear be if r is less than or equal to 0.03928 then r divided by 12.92 else Math.power of ((r plus 0.055) divided by 1.055) and 2.4
    Let g_linear be if g is less than or equal to 0.03928 then g divided by 12.92 else Math.power of ((g plus 0.055) divided by 1.055) and 2.4
    Let b_linear be if b is less than or equal to 0.03928 then b divided by 12.92 else Math.power of ((b plus 0.055) divided by 1.055) and 2.4
    
    Return 0.2126 times r_linear plus 0.7152 times g_linear plus 0.0722 times b_linear

Process called "meets_contrast_requirement" that takes foreground as Color and background as Color and requirement as Float returns Boolean:
    Let contrast_ratio be get_contrast_ratio with color1 as foreground and color2 as background
    Return contrast_ratio is greater than or equal to requirement

Process called "generate_accessible_color_pair" that takes base_color as Color and target_contrast as Float returns List[Color]:
    Note: Generate a color pair that meets the specified contrast ratio
    Let results be List.empty
    Call List.append with list as results and item as base_color
    
    Note: Generate a contrasting color
    Let contrasting_color be if get_relative_luminance with color as base_color is greater than 0.5 
        then create_color with red as 0 and green as 0 and blue as 0
        else create_color with red as 255 and green as 255 and blue as 255
    
    Call List.append with list as results and item as contrasting_color
    Return results