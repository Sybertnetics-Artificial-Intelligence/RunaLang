Note:
Runa UI Framework: Advanced State Management Core System

Comprehensive state management with reactive patterns, time-travel debugging,
and enterprise-grade scalability for complex application architectures.

Features:
- Immutable state trees with structural sharing
- Action-based state mutations with middleware support
- Time-travel debugging with state snapshots
- Reactive subscriptions with fine-grained updates
- Middleware ecosystem for logging, persistence, and analytics
- State composition and module isolation
- Performance optimization with memoization
- DevTools integration for development workflows
:End Note

Import "collections/dict" as Dict
Import "collections/list" as List
Import "ui/widgets" as Widgets
Import "ui/events" as Events

Note: Core State Management Types

Type called "StateStore":
    store_id as String
    current_state as State
    state_history as List[StateSnapshot]
    reducers as Dict[String, Reducer]
    middleware as List[Middleware]
    subscribers as Dict[String, Subscription]
    dispatch_queue as List[QueuedAction]
    store_config as StoreConfig

Type called "State":
    data as Dict[String, Any]
    metadata as StateMetadata
    version as Integer
    timestamp as Integer

Type called "StateMetadata":
    last_action as Optional[Action]
    modification_count as Integer
    performance_metrics as PerformanceMetrics

Type called "PerformanceMetrics":
    update_time_ms as Float
    serialization_time_ms as Float
    subscriber_notification_time_ms as Float
    memory_usage_bytes as Integer

Type called "StateSnapshot":
    snapshot_id as String
    state as State
    action as Action
    timestamp as Integer
    parent_snapshot as Optional[String]

Type called "Action":
    action_type as String
    payload as Dict[String, Any]
    metadata as ActionMetadata

Type called "ActionMetadata":
    source as String
    timestamp as Integer
    batch_id as Optional[String]
    transaction_id as Optional[String]

Type called "Reducer":
    reducer_id as String
    action_types as List[String]
    reduce_function as Function
    state_selector as Optional[Function]
    is_async as Boolean

Type called "Middleware":
    middleware_id as String
    middleware_type as MiddlewareType
    handler as Function
    priority as Integer
    is_enabled as Boolean

Type MiddlewareType is:
    | PreDispatch
    | PostDispatch
    | StateChange
    | ActionLogger
    | ErrorHandler
    | Performance
    | Custom with identifier as String

Type called "Subscription":
    subscription_id as String
    selector as Function
    callback as Function
    subscription_config as SubscriptionConfig
    last_notified_state as Optional[Any]

Type called "SubscriptionConfig":
    debounce_ms as Optional[Integer]
    throttle_ms as Optional[Integer]
    deep_comparison as Boolean
    immediate_notification as Boolean

Type called "QueuedAction":
    action as Action
    queued_at as Integer
    priority as ActionPriority

Type ActionPriority is:
    | Low
    | Normal
    | High
    | Critical

Type called "StoreConfig":
    enable_time_travel as Boolean
    max_history_size as Integer
    enable_devtools as Boolean
    enable_performance_monitoring as Boolean
    state_serializer as Optional[StateSerializer]
    action_sanitizer as Optional[ActionSanitizer]

Type called "StateSerializer":
    serialize_function as Function
    deserialize_function as Function
    compression_enabled as Boolean

Type called "ActionSanitizer":
    sanitize_function as Function
    sensitive_fields as List[String]

Type called "StateManager":
    manager_id as String
    stores as Dict[String, StateStore]
    global_middleware as List[Middleware]
    store_factories as Dict[String, StoreFactory]
    dev_tools as Optional[DevTools]

Type called "StoreFactory":
    factory_id as String
    create_function as Function
    initial_state_provider as Function
    default_reducers as List[Reducer]

Type called "DevTools":
    devtools_id as String
    is_connected as Boolean
    action_history as List[DevToolsAction]
    state_inspector as StateInspector
    time_travel_controller as TimeTravelController

Type called "DevToolsAction":
    action as Action
    state_before as State
    state_after as State
    execution_time_ms as Float

Type called "StateInspector":
    inspector_id as String
    inspection_views as List[InspectionView]
    diff_calculator as DiffCalculator

Type called "InspectionView":
    view_id as String
    path as String
    value as Any
    value_type as String

Type called "DiffCalculator":
    calculator_id as String
    diff_strategy as DiffStrategy

Type DiffStrategy is:
    | ShallowDiff
    | DeepDiff
    | StructuralDiff
    | CustomDiff with algorithm as Function

Type called "TimeTravelController":
    controller_id as String
    current_position as Integer
    snapshots as List[StateSnapshot]
    playback_speed as Float
    is_recording as Boolean

Note: State Store Implementation

Process called "create_state_store" that takes initial_state as Dict[String, Any] and store_config as StoreConfig returns StateStore:
    Let store_id be generate_store_id
    
    Let state be State with:
        data as initial_state
        metadata as StateMetadata with:
            last_action as Optional.None
            modification_count as 0
            performance_metrics as PerformanceMetrics with:
                update_time_ms as 0.0
                serialization_time_ms as 0.0
                subscriber_notification_time_ms as 0.0
                memory_usage_bytes as 0
        version as 1
        timestamp as Widgets.get_current_timestamp
    
    Return StateStore with:
        store_id as store_id
        current_state as state
        state_history as create_initial_history with state as state
        reducers as Dict.empty
        middleware as List.empty
        subscribers as Dict.empty
        dispatch_queue as List.empty
        store_config as store_config

Process called "generate_store_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 8
    Return "store_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_initial_history" that takes state as State returns List[StateSnapshot]:
    Let history be List.empty
    
    If true:  Note: Always create initial snapshot
        Let initial_snapshot be StateSnapshot with:
            snapshot_id as generate_snapshot_id
            state as state
            action as Action with:
                action_type as "@@INIT"
                payload as Dict.empty
                metadata as ActionMetadata with:
                    source as "system"
                    timestamp as state.timestamp
                    batch_id as Optional.None
                    transaction_id as Optional.None
            timestamp as state.timestamp
            parent_snapshot as Optional.None
        
        Call List.append with list as history and item as initial_snapshot
    
    Return history

Process called "generate_snapshot_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "snap_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_default_store_config" returns StoreConfig:
    Return StoreConfig with:
        enable_time_travel as true
        max_history_size as 50
        enable_devtools as true
        enable_performance_monitoring as true
        state_serializer as Optional.None
        action_sanitizer as Optional.None

Process called "add_reducer" that takes store as StateStore and reducer as Reducer:
    Call Dict.set with dict as store.reducers and key as reducer.reducer_id and value as reducer

Process called "create_reducer" that takes reducer_id as String and action_types as List[String] and reduce_function as Function returns Reducer:
    Return Reducer with:
        reducer_id as reducer_id
        action_types as action_types
        reduce_function as reduce_function
        state_selector as Optional.None
        is_async as false

Process called "add_middleware" that takes store as StateStore and middleware as Middleware:
    Call List.append with list as store.middleware and item as middleware
    Call sort_middleware_by_priority with middleware_list as store.middleware

Process called "sort_middleware_by_priority" that takes middleware_list as List[Middleware]:
    Note: Sort middleware by priority (higher priority first)
    Pass  Note: Would implement sorting algorithm

Process called "create_middleware" that takes middleware_id as String and middleware_type as MiddlewareType and handler as Function returns Middleware:
    Return Middleware with:
        middleware_id as middleware_id
        middleware_type as middleware_type
        handler as handler
        priority as get_default_priority_for_type with middleware_type as middleware_type
        is_enabled as true

Process called "get_default_priority_for_type" that takes middleware_type as MiddlewareType returns Integer:
    Match middleware_type:
        When PreDispatch:
            Return 100
        When PostDispatch:
            Return 90
        When StateChange:
            Return 80
        When ActionLogger:
            Return 70
        When ErrorHandler:
            Return 60
        When Performance:
            Return 50
        When Custom:
            Return 40

Note: Action Dispatching

Process called "dispatch_action" that takes store as StateStore and action as Action returns State:
    Let start_time be Widgets.get_current_timestamp
    
    Call execute_pre_dispatch_middleware with store as store and action as action
    
    Let new_state be apply_reducers with store as store and action as action
    
    Call update_store_state with store as store and new_state as new_state and action as action
    
    Call execute_post_dispatch_middleware with store as store and action as action and old_state as store.current_state and new_state as new_state
    
    Call notify_subscribers with store as store and old_state as store.current_state and new_state as new_state
    
    If store.store_config.enable_performance_monitoring:
        Let end_time be Widgets.get_current_timestamp
        Call record_performance_metric with store as store and metric_type as "dispatch_time" and value as (end_time minus start_time) as Float
    
    Return new_state

Process called "execute_pre_dispatch_middleware" that takes store as StateStore and action as Action:
    For middleware in store.middleware:
        If middleware.is_enabled:
            Match middleware.middleware_type:
                When PreDispatch:
                    Call middleware.handler with store as store and action as action
                When ActionLogger:
                    Call middleware.handler with store as store and action as action
                Otherwise:
                    Pass

Process called "apply_reducers" that takes store as StateStore and action as Action returns State:
    Let new_state_data be copy_state_data with data as store.current_state.data
    Let state_changed be false
    
    For reducer_id in Dict.keys with dict as store.reducers:
        Let reducer_option be Dict.get with dict as store.reducers and key as reducer_id
        Match reducer_option:
            When Optional.Some with value as reducer:
                If can_handle_action with reducer as reducer and action as action:
                    Let reducer_result be apply_reducer with reducer as reducer and state as new_state_data and action as action
                    Set new_state_data to reducer_result
                    Set state_changed to true
            When Optional.None:
                Pass
    
    If state_changed:
        Return State with:
            data as new_state_data
            metadata as StateMetadata with:
                last_action as Optional.Some with value as action
                modification_count as store.current_state.metadata.modification_count plus 1
                performance_metrics as store.current_state.metadata.performance_metrics
            version as store.current_state.version plus 1
            timestamp as Widgets.get_current_timestamp
    Otherwise:
        Return store.current_state

Process called "copy_state_data" that takes data as Dict[String, Any] returns Dict[String, Any]:
    Let copied_data be Dict.empty
    
    For key in Dict.keys with dict as data:
        Let value_option be Dict.get with dict as data and key as key
        Match value_option:
            When Optional.Some with value as value:
                Call Dict.set with dict as copied_data and key as key and value as deep_copy_value with value as value
            When Optional.None:
                Pass
    
    Return copied_data

Process called "deep_copy_value" that takes value as Any returns Any:
    Note: Deep copy value - would implement proper deep copying
    Return value

Process called "can_handle_action" that takes reducer as Reducer and action as Action returns Boolean:
    For action_type in reducer.action_types:
        If action_type is equal to action.action_type:
            Return true
    Return false

Process called "apply_reducer" that takes reducer as Reducer and state as Dict[String, Any] and action as Action returns Dict[String, Any]:
    Return reducer.reduce_function with state as state and action as action

Process called "update_store_state" that takes store as StateStore and new_state as State and action as Action:
    Let old_state be store.current_state
    Set store.current_state to new_state
    
    If store.store_config.enable_time_travel:
        Call add_to_history with store as store and old_state as old_state and new_state as new_state and action as action

Process called "add_to_history" that takes store as StateStore and old_state as State and new_state as State and action as Action:
    Let snapshot be StateSnapshot with:
        snapshot_id as generate_snapshot_id
        state as new_state
        action as action
        timestamp as new_state.timestamp
        parent_snapshot as get_current_snapshot_id with store as store
    
    Call List.append with list as store.state_history and item as snapshot
    
    Note: Trim history if it exceeds max size
    While (length of store.state_history) is greater than store.store_config.max_history_size:
        Call List.remove_first with list as store.state_history

Process called "get_current_snapshot_id" that takes store as StateStore returns Optional[String]:
    Let history_length be length of store.state_history
    If history_length is greater than 0:
        Let last_snapshot be store.state_history at index (history_length minus 1)
        Return Optional.Some with value as last_snapshot.snapshot_id
    Return Optional.None

Process called "execute_post_dispatch_middleware" that takes store as StateStore and action as Action and old_state as State and new_state as State:
    For middleware in store.middleware:
        If middleware.is_enabled:
            Match middleware.middleware_type:
                When PostDispatch:
                    Call middleware.handler with store as store and action as action and old_state as old_state and new_state as new_state
                When StateChange:
                    If not states_are_equal with state1 as old_state and state2 as new_state:
                        Call middleware.handler with store as store and old_state as old_state and new_state as new_state
                Otherwise:
                    Pass

Process called "states_are_equal" that takes state1 as State and state2 as State returns Boolean:
    Return state1.version is equal to state2.version

Process called "record_performance_metric" that takes store as StateStore and metric_type as String and value as Float:
    Match metric_type:
        When "dispatch_time":
            Set store.current_state.metadata.performance_metrics.update_time_ms to value
        Otherwise:
            Pass

Note: Subscription Management

Process called "subscribe" that takes store as StateStore and selector as Function and callback as Function and config as SubscriptionConfig returns String:
    Let subscription_id be generate_subscription_id
    
    Let subscription be Subscription with:
        subscription_id as subscription_id
        selector as selector
        callback as callback
        subscription_config as config
        last_notified_state as Optional.None
    
    Call Dict.set with dict as store.subscribers and key as subscription_id and value as subscription
    
    If config.immediate_notification:
        Let selected_state be selector with state as store.current_state
        Call callback with value as selected_state
        Set subscription.last_notified_state to Optional.Some with value as selected_state
    
    Return subscription_id

Process called "generate_subscription_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 8
    Return "sub_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "unsubscribe" that takes store as StateStore and subscription_id as String:
    Call Dict.remove with dict as store.subscribers and key as subscription_id

Process called "notify_subscribers" that takes store as StateStore and old_state as State and new_state as State:
    Let start_time be Widgets.get_current_timestamp
    
    For subscription_id in Dict.keys with dict as store.subscribers:
        Let subscription_option be Dict.get with dict as store.subscribers and key as subscription_id
        Match subscription_option:
            When Optional.Some with value as subscription:
                Call notify_subscription with subscription as subscription and old_state as old_state and new_state as new_state
            When Optional.None:
                Pass
    
    Let end_time be Widgets.get_current_timestamp
    Set store.current_state.metadata.performance_metrics.subscriber_notification_time_ms to (end_time minus start_time) as Float

Process called "notify_subscription" that takes subscription as Subscription and old_state as State and new_state as State:
    Let old_selected_state be subscription.selector with state as old_state
    Let new_selected_state be subscription.selector with state as new_state
    
    Let should_notify be should_notify_subscription with subscription as subscription and old_value as old_selected_state and new_value as new_selected_state
    
    If should_notify:
        Call subscription.callback with value as new_selected_state
        Set subscription.last_notified_state to Optional.Some with value as new_selected_state

Process called "should_notify_subscription" that takes subscription as Subscription and old_value as Any and new_value as Any returns Boolean:
    If subscription.subscription_config.deep_comparison:
        Return not deep_equals with value1 as old_value and value2 as new_value
    Otherwise:
        Return not shallow_equals with value1 as old_value and value2 as new_value

Process called "deep_equals" that takes value1 as Any and value2 as Any returns Boolean:
    Note: Deep equality comparison - would implement proper deep comparison
    Return false

Process called "shallow_equals" that takes value1 as Any and value2 as Any returns Boolean:
    Note: Shallow equality comparison
    Return false

Process called "create_subscription_config" returns SubscriptionConfig:
    Return SubscriptionConfig with:
        debounce_ms as Optional.None
        throttle_ms as Optional.None
        deep_comparison as false
        immediate_notification as false

Note: State Selectors

Process called "select_state_path" that takes path as String returns Function:
    Return Process that takes state as State returns Any:
        Return get_nested_value with data as state.data and path as path

Process called "get_nested_value" that takes data as Dict[String, Any] and path as String returns Any:
    Let path_segments be split_path with path as path
    Let current_value be data as Any
    
    For segment in path_segments:
        Match current_value:
            When Dict:
                Let dict_value be current_value as Dict[String, Any]
                Let value_option be Dict.get with dict as dict_value and key as segment
                Match value_option:
                    When Optional.Some with value as value:
                        Set current_value to value
                    When Optional.None:
                        Return None
            Otherwise:
                Return None
    
    Return current_value

Process called "split_path" that takes path as String returns List[String]:
    Let segments be List.empty
    Let current_segment be ""
    
    For i from 0 to ((length of path) minus 1):
        Let char be path at index i
        If char is equal to ".":
            If (length of current_segment) is greater than 0:
                Call List.append with list as segments and item as current_segment
                Set current_segment to ""
        Otherwise:
            Set current_segment to current_segment concatenated with char
    
    If (length of current_segment) is greater than 0:
        Call List.append with list as segments and item as current_segment
    
    Return segments

Process called "create_memoized_selector" that takes selector as Function returns Function:
    Let cache be Dict.empty
    Let last_args as Optional[Any] be Optional.None
    Let last_result as Optional[Any] be Optional.None
    
    Return Process that takes state as State returns Any:
        Let cache_key be generate_cache_key with state as state
        Let cached_result_option be Dict.get with dict as cache and key as cache_key
        
        Match cached_result_option:
            When Optional.Some with value as cached_result:
                Return cached_result
            When Optional.None:
                Let result be selector with state as state
                Call Dict.set with dict as cache and key as cache_key and value as result
                Return result

Process called "generate_cache_key" that takes state as State returns String:
    Return "state_v" concatenated with state.version as String

Note: Time Travel and DevTools

Process called "travel_to_snapshot" that takes store as StateStore and snapshot_id as String returns Boolean:
    For snapshot in store.state_history:
        If snapshot.snapshot_id is equal to snapshot_id:
            Set store.current_state to snapshot.state
            Call notify_subscribers with store as store and old_state as store.current_state and new_state as snapshot.state
            Return true
    Return false

Process called "get_action_history" that takes store as StateStore returns List[Action]:
    Let actions be List.empty
    
    For snapshot in store.state_history:
        Call List.append with list as actions and item as snapshot.action
    
    Return actions

Process called "replay_actions" that takes store as StateStore and actions as List[Action]:
    Note: Reset to initial state
    If (length of store.state_history) is greater than 0:
        Let initial_snapshot be store.state_history at index 0
        Set store.current_state to initial_snapshot.state
    
    Note: Replay actions
    For action in actions:
        Call dispatch_action with store as store and action as action

Process called "create_dev_tools" returns DevTools:
    Let devtools_id be generate_devtools_id
    
    Return DevTools with:
        devtools_id as devtools_id
        is_connected as false
        action_history as List.empty
        state_inspector as create_state_inspector
        time_travel_controller as create_time_travel_controller

Process called "generate_devtools_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "devtools_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_state_inspector" returns StateInspector:
    Let inspector_id be generate_inspector_id
    
    Return StateInspector with:
        inspector_id as inspector_id
        inspection_views as List.empty
        diff_calculator as create_diff_calculator

Process called "generate_inspector_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "inspector_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_diff_calculator" returns DiffCalculator:
    Let calculator_id be generate_diff_calculator_id
    
    Return DiffCalculator with:
        calculator_id as calculator_id
        diff_strategy as DeepDiff

Process called "generate_diff_calculator_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "diff_calc_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_time_travel_controller" returns TimeTravelController:
    Let controller_id be generate_time_travel_controller_id
    
    Return TimeTravelController with:
        controller_id as controller_id
        current_position as 0
        snapshots as List.empty
        playback_speed as 1.0
        is_recording as true

Process called "generate_time_travel_controller_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "tt_ctrl_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Note: State Manager

Process called "create_state_manager" returns StateManager:
    Let manager_id be generate_state_manager_id
    
    Return StateManager with:
        manager_id as manager_id
        stores as Dict.empty
        global_middleware as create_default_global_middleware
        store_factories as create_default_store_factories
        dev_tools as Optional.Some with value as create_dev_tools

Process called "generate_state_manager_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 8
    Return "state_mgr_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_default_global_middleware" returns List[Middleware]:
    Let middleware be List.empty
    
    Let logger_middleware be create_action_logger_middleware
    Call List.append with list as middleware and item as logger_middleware
    
    Let performance_middleware be create_performance_middleware
    Call List.append with list as middleware and item as performance_middleware
    
    Return middleware

Process called "create_action_logger_middleware" returns Middleware:
    Let middleware_id be generate_middleware_id
    
    Let handler be Process that takes store as StateStore and action as Action:
        Display "Action dispatched: " concatenated with action.action_type
    
    Return create_middleware with middleware_id as middleware_id and middleware_type as ActionLogger and handler as handler

Process called "generate_middleware_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "middleware_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_performance_middleware" returns Middleware:
    Let middleware_id be generate_middleware_id
    
    Let handler be Process that takes store as StateStore and action as Action and old_state as State and new_state as State:
        Note: Record performance metrics
        Pass
    
    Return create_middleware with middleware_id as middleware_id and middleware_type as Performance and handler as handler

Process called "create_default_store_factories" returns Dict[String, StoreFactory]:
    Let factories be Dict.empty
    
    Let default_factory be create_default_store_factory
    Call Dict.set with dict as factories and key as "default" and value as default_factory
    
    Return factories

Process called "create_default_store_factory" returns StoreFactory:
    Let factory_id be generate_store_factory_id
    
    Let create_function be Process that takes initial_state as Dict[String, Any] and config as StoreConfig returns StateStore:
        Return create_state_store with initial_state as initial_state and store_config as config
    
    Let initial_state_provider be Process that returns Dict[String, Any]:
        Return Dict.empty
    
    Return StoreFactory with:
        factory_id as factory_id
        create_function as create_function
        initial_state_provider as initial_state_provider
        default_reducers as List.empty

Process called "generate_store_factory_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "factory_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "register_store" that takes manager as StateManager and store_name as String and store as StateStore:
    Call Dict.set with dict as manager.stores and key as store_name and value as store

Process called "get_store" that takes manager as StateManager and store_name as String returns Optional[StateStore]:
    Return Dict.get with dict as manager.stores and key as store_name

Process called "create_store" that takes manager as StateManager and store_name as String and factory_name as String and initial_state as Dict[String, Any] returns StateStore:
    Let factory_option be Dict.get with dict as manager.store_factories and key as factory_name
    Match factory_option:
        When Optional.Some with value as factory:
            Let config be create_default_store_config
            Let store be factory.create_function with initial_state as initial_state and config as config
            
            Note: Add global middleware to store
            For middleware in manager.global_middleware:
                Call add_middleware with store as store and middleware as middleware
            
            Call register_store with manager as manager and store_name as store_name and store as store
            Return store
        When Optional.None:
            Note: Fall back to default factory
            Let config be create_default_store_config
            Let store be create_state_store with initial_state as initial_state and store_config as config
            Call register_store with manager as manager and store_name as store_name and store as store
            Return store

Note: Action Creators and Utilities

Process called "create_action" that takes action_type as String and payload as Dict[String, Any] returns Action:
    Return Action with:
        action_type as action_type
        payload as payload
        metadata as ActionMetadata with:
            source as "user"
            timestamp as Widgets.get_current_timestamp
            batch_id as Optional.None
            transaction_id as Optional.None

Process called "create_batch_actions" that takes actions as List[Action] returns List[Action]:
    Let batch_id be generate_batch_id
    Let batched_actions be List.empty
    
    For action in actions:
        Let batched_action be Action with:
            action_type as action.action_type
            payload as action.payload
            metadata as ActionMetadata with:
                source as action.metadata.source
                timestamp as action.metadata.timestamp
                batch_id as Optional.Some with value as batch_id
                transaction_id as action.metadata.transaction_id
        
        Call List.append with list as batched_actions and item as batched_action
    
    Return batched_actions

Process called "generate_batch_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "batch_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "dispatch_batch" that takes store as StateStore and actions as List[Action]:
    Let batched_actions be create_batch_actions with actions as actions
    
    For action in batched_actions:
        Call dispatch_action with store as store and action as action

Note: State Composition and Modules

Process called "combine_reducers" that takes reducers as Dict[String, Reducer] returns Reducer:
    Let combined_reducer_id be generate_combined_reducer_id
    
    Let reduce_function be Process that takes state as Dict[String, Any] and action as Action returns Dict[String, Any]:
        Let new_state be copy_state_data with data as state
        
        For key in Dict.keys with dict as reducers:
            Let reducer_option be Dict.get with dict as reducers and key as key
            Match reducer_option:
                When Optional.Some with value as reducer:
                    If can_handle_action with reducer as reducer and action as action:
                        Let current_slice_option be Dict.get with dict as new_state and key as key
                        Match current_slice_option:
                            When Optional.Some with value as current_slice:
                                Let current_slice_dict be current_slice as Dict[String, Any]
                                Let new_slice be apply_reducer with reducer as reducer and state as current_slice_dict and action as action
                                Call Dict.set with dict as new_state and key as key and value as new_slice
                            When Optional.None:
                                Let empty_slice be Dict.empty
                                Let new_slice be apply_reducer with reducer as reducer and state as empty_slice and action as action
                                Call Dict.set with dict as new_state and key as key and value as new_slice
                When Optional.None:
                    Pass
        
        Return new_state
    
    Let all_action_types be List.empty
    For reducer_key in Dict.keys with dict as reducers:
        Let reducer_option be Dict.get with dict as reducers and key as reducer_key
        Match reducer_option:
            When Optional.Some with value as reducer:
                For action_type in reducer.action_types:
                    Call List.append with list as all_action_types and item as action_type
            When Optional.None:
                Pass
    
    Return Reducer with:
        reducer_id as combined_reducer_id
        action_types as all_action_types
        reduce_function as reduce_function
        state_selector as Optional.None
        is_async as false

Process called "generate_combined_reducer_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "combined_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Note: Utility Functions

Process called "get_state_stats" that takes store as StateStore returns String:
    Let history_size be length of store.state_history
    Let subscriber_count be length of (Dict.keys with dict as store.subscribers)
    Let reducer_count be length of (Dict.keys with dict as store.reducers)
    Let middleware_count be length of store.middleware
    
    Return "State Store Stats:\n" concatenated with
           "- Store ID: " concatenated with store.store_id concatenated with "\n" concatenated with
           "- Current version: " concatenated with store.current_state.version as String concatenated with "\n" concatenated with
           "- History size: " concatenated with history_size as String concatenated with "\n" concatenated with
           "- Subscribers: " concatenated with subscriber_count as String concatenated with "\n" concatenated with
           "- Reducers: " concatenated with reducer_count as String concatenated with "\n" concatenated with
           "- Middleware: " concatenated with middleware_count as String concatenated with "\n" concatenated with
           "- Modifications: " concatenated with store.current_state.metadata.modification_count as String

Process called "export_state" that takes store as StateStore returns String:
    Note: Serialize state for export
    Return "STATE_EXPORT_" concatenated with store.store_id

Process called "import_state" that takes store as StateStore and state_data as String:
    Note: Import state from serialized data
    Pass

Process called "reset_store" that takes store as StateStore:
    If (length of store.state_history) is greater than 0:
        Let initial_snapshot be store.state_history at index 0
        Set store.current_state to initial_snapshot.state
        Call List.clear with list as store.state_history
        Call List.append with list as store.state_history and item as initial_snapshot
        
        Call notify_subscribers with store as store and old_state as store.current_state and new_state as initial_snapshot.state

Process called "clear_history" that takes store as StateStore:
    Call List.clear with list as store.state_history
    
    Let current_snapshot be StateSnapshot with:
        snapshot_id as generate_snapshot_id
        state as store.current_state
        action as Action with:
            action_type as "@@CLEAR_HISTORY"
            payload as Dict.empty
            metadata as ActionMetadata with:
                source as "system"
                timestamp as Widgets.get_current_timestamp
                batch_id as Optional.None
                transaction_id as Optional.None
        timestamp as Widgets.get_current_timestamp
        parent_snapshot as Optional.None
    
    Call List.append with list as store.state_history and item as current_snapshot

Process called "get_state_manager_stats" that takes manager as StateManager returns String:
    Let store_count be length of (Dict.keys with dict as manager.stores)
    Let global_middleware_count be length of manager.global_middleware
    Let factory_count be length of (Dict.keys with dict as manager.store_factories)
    
    Let devtools_connected be match manager.dev_tools:
        When Optional.Some with value as devtools:
            if devtools.is_connected then "Yes" else "No"
        When Optional.None:
            "Not available"
    
    Return "State Manager Stats:\n" concatenated with
           "- Manager ID: " concatenated with manager.manager_id concatenated with "\n" concatenated with
           "- Registered stores: " concatenated with store_count as String concatenated with "\n" concatenated with
           "- Global middleware: " concatenated with global_middleware_count as String concatenated with "\n" concatenated with
           "- Store factories: " concatenated with factory_count as String concatenated with "\n" concatenated with
           "- DevTools connected: " concatenated with devtools_connected