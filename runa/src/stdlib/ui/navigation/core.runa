Note:
Runa UI Framework: Advanced Navigation Core System

Comprehensive navigation framework with hierarchical routing, intelligent 
navigation guards, and seamless integration with state management.

Features:
- Hierarchical navigation with nested route support
- Intelligent navigation guards with async validation
- History management with back/forward navigation
- Route-based code splitting and lazy loading
- Navigation middleware with custom interceptors
- Deep linking support with parameter validation
- Breadcrumb generation and navigation analytics
- Cross-platform navigation (web, mobile, desktop)
:End Note

Import "collections/dict" as Dict
Import "collections/list" as List
Import "ui/widgets" as Widgets
Import "ui/events" as Events

Note: Core Navigation Types

Type NavigationState is:
    | Idle
    | Navigating
    | Loading
    | Error with message as String
    | Blocked with reason as String

Type called "NavigationContext":
    current_route as Route
    previous_route as Optional[Route]
    navigation_stack as List[Route]
    route_parameters as Dict[String, String]
    query_parameters as Dict[String, String]
    state as NavigationState
    can_go_back as Boolean
    can_go_forward as Boolean

Type called "Route":
    path as String
    name as String
    component_id as String
    parent as Optional[Route]
    children as List[Route]
    parameters as List[RouteParameter]
    guards as List[NavigationGuard]
    metadata as RouteMetadata
    is_exact as Boolean
    redirect_to as Optional[String]

Type called "RouteParameter":
    name as String
    param_type as ParameterType
    is_optional as Boolean
    default_value as Optional[String]
    validator as Optional[Function]

Type ParameterType is:
    | String
    | Integer
    | Float
    | Boolean
    | UUID
    | Custom with validator as Function

Type called "NavigationGuard":
    guard_id as String
    guard_type as GuardType
    condition as Function
    priority as Integer
    is_async as Boolean

Type GuardType is:
    | CanActivate
    | CanDeactivate
    | CanLoad
    | CanActivateChild

Type called "RouteMetadata":
    title as String
    description as String
    icon as Optional[String]
    requires_auth as Boolean
    roles as List[String]
    tags as List[String]
    cache_duration as Optional[Integer]

Type called "NavigationManager":
    routes as Dict[String, Route]
    route_tree as RouteTree
    current_context as NavigationContext
    history as NavigationHistory
    guards as List[NavigationGuard]
    middleware as List[NavigationMiddleware]
    resolvers as Dict[String, RouteResolver]

Type called "RouteTree":
    root_routes as List[Route]
    route_map as Dict[String, Route]
    parameter_routes as List[Route]
    wildcard_routes as List[Route]

Type called "NavigationHistory":
    entries as List[HistoryEntry]
    current_index as Integer
    max_size as Integer

Type called "HistoryEntry":
    route as Route
    timestamp as Integer
    scroll_position as Optional[ScrollPosition]
    state_snapshot as Optional[Dict[String, Any]]

Type called "ScrollPosition":
    x as Float
    y as Float

Type called "NavigationMiddleware":
    middleware_id as String
    before_navigation as Optional[Function]
    after_navigation as Optional[Function]
    on_error as Optional[Function]

Type called "RouteResolver":
    resolver_id as String
    parameter_name as String
    resolve_function as Function

Type called "NavigationResult":
    success as Boolean
    route as Optional[Route]
    error as Optional[String]
    redirected_to as Optional[String]

Type called "RouteMatch":
    route as Route
    parameters as Dict[String, String]
    match_score as Float
    is_exact as Boolean

Note: Navigation Manager Creation

Process called "create_navigation_manager" returns NavigationManager:
    Return NavigationManager with:
        routes as Dict.empty
        route_tree as create_route_tree
        current_context as create_initial_context
        history as create_navigation_history
        guards as List.empty
        middleware as List.empty
        resolvers as Dict.empty

Process called "create_route_tree" returns RouteTree:
    Return RouteTree with:
        root_routes as List.empty
        route_map as Dict.empty
        parameter_routes as List.empty
        wildcard_routes as List.empty

Process called "create_initial_context" returns NavigationContext:
    Let initial_route be create_default_route
    
    Return NavigationContext with:
        current_route as initial_route
        previous_route as Optional.None
        navigation_stack as List.empty
        route_parameters as Dict.empty
        query_parameters as Dict.empty
        state as Idle
        can_go_back as false
        can_go_forward as false

Process called "create_default_route" returns Route:
    Return Route with:
        path as "/"
        name as "home"
        component_id as "home_component"
        parent as Optional.None
        children as List.empty
        parameters as List.empty
        guards as List.empty
        metadata as create_default_route_metadata
        is_exact as true
        redirect_to as Optional.None

Process called "create_default_route_metadata" returns RouteMetadata:
    Return RouteMetadata with:
        title as "Home"
        description as "Home page"
        icon as Optional.None
        requires_auth as false
        roles as List.empty
        tags as List.empty
        cache_duration as Optional.None

Process called "create_navigation_history" returns NavigationHistory:
    Return NavigationHistory with:
        entries as List.empty
        current_index as -1
        max_size as 50

Note: Route Registration and Management

Process called "register_route" that takes manager as NavigationManager and route as Route:
    Call Dict.set with dict as manager.routes and key as route.path and value as route
    Call add_to_route_tree with tree as manager.route_tree and route as route
    Call validate_route with route as route

Process called "add_to_route_tree" that takes tree as RouteTree and route as Route:
    Call Dict.set with dict as tree.route_map and key as route.path and value as route
    
    If has_parameters with route as route:
        Call List.append with list as tree.parameter_routes and item as route
    
    If is_wildcard_route with route as route:
        Call List.append with list as tree.wildcard_routes and item as route
    
    Match route.parent:
        When Optional.None:
            Call List.append with list as tree.root_routes and item as route
        When Optional.Some:
            Pass

Process called "has_parameters" that takes route as Route returns Boolean:
    Return (length of route.parameters) is greater than 0

Process called "is_wildcard_route" that takes route as Route returns Boolean:
    Return contains_substring with text as route.path and substring as "*"

Process called "contains_substring" that takes text as String and substring as String returns Boolean:
    Note: Simple substring check
    Return false  Note: Would implement proper substring check

Process called "validate_route" that takes route as Route returns Boolean:
    If (length of route.path) is equal to 0:
        Return false
    
    If not starts_with with text as route.path and prefix as "/":
        Return false
    
    For param in route.parameters:
        If not validate_parameter with param as param:
            Return false
    
    Return true

Process called "starts_with" that takes text as String and prefix as String returns Boolean:
    If (length of prefix) is greater than (length of text):
        Return false
    
    For i from 0 to ((length of prefix) minus 1):
        If (text at index i) is not equal to (prefix at index i):
            Return false
    
    Return true

Process called "validate_parameter" that takes param as RouteParameter returns Boolean:
    Return (length of param.name) is greater than 0

Process called "create_route" that takes path as String and component_id as String returns Route:
    Let route_name be extract_route_name with path as path
    
    Return Route with:
        path as path
        name as route_name
        component_id as component_id
        parent as Optional.None
        children as List.empty
        parameters as extract_parameters from path
        guards as List.empty
        metadata as create_route_metadata with name as route_name
        is_exact as true
        redirect_to as Optional.None

Process called "extract_route_name" that takes path as String returns String:
    Let segments be split_path with path as path
    If (length of segments) is greater than 0:
        Return segments at index ((length of segments) minus 1)
    Return "route"

Process called "split_path" that takes path as String returns List[String]:
    Let segments be List.empty
    Let current_segment be ""
    
    For i from 1 to ((length of path) minus 1):  Note: Skip leading slash
        Let char be path at index i
        If char is equal to "/":
            If (length of current_segment) is greater than 0:
                Call List.append with list as segments and item as current_segment
                Set current_segment to ""
        Otherwise:
            Set current_segment to current_segment concatenated with char
    
    If (length of current_segment) is greater than 0:
        Call List.append with list as segments and item as current_segment
    
    Return segments

Process called "extract_parameters" that takes path as String returns List[RouteParameter]:
    Let parameters be List.empty
    Let segments be split_path with path as path
    
    For segment in segments:
        If starts_with with text as segment and prefix as ":":
            Let param_name be substring with text as segment and start as 1 and end as (length of segment)
            Let parameter be RouteParameter with:
                name as param_name
                param_type as String
                is_optional as false
                default_value as Optional.None
                validator as Optional.None
            Call List.append with list as parameters and item as parameter
    
    Return parameters

Process called "substring" that takes text as String and start as Integer and end as Integer returns String:
    Let result be ""
    For i from start to (end minus 1):
        If i is greater than or equal to 0 and i is less than (length of text):
            Set result to result concatenated with (text at index i)
    Return result

Process called "create_route_metadata" that takes name as String returns RouteMetadata:
    Return RouteMetadata with:
        title as capitalize with text as name
        description as capitalize with text as name concatenated with " page"
        icon as Optional.None
        requires_auth as false
        roles as List.empty
        tags as List.empty
        cache_duration as Optional.None

Process called "capitalize" that takes text as String returns String:
    If (length of text) is equal to 0:
        Return text
    
    Let first_char be text at index 0
    Let rest be substring with text as text and start as 1 and end as (length of text)
    Return to_uppercase with char as first_char concatenated with rest

Process called "to_uppercase" that takes char as String returns String:
    Note: Simple uppercase conversion
    Return char  Note: Would implement proper case conversion

Note: Navigation Operations

Process called "navigate_to" that takes manager as NavigationManager and path as String returns NavigationResult:
    Set manager.current_context.state to Navigating
    
    Let match_result be match_route with manager as manager and path as path
    Match match_result:
        When Optional.Some with value as route_match:
            Let guard_result be check_navigation_guards with manager as manager and route as route_match.route
            Match guard_result:
                When Optional.Some with value as error:
                    Set manager.current_context.state to Blocked with reason as error
                    Return NavigationResult with:
                        success as false
                        route as Optional.None
                        error as Optional.Some with value as error
                        redirected_to as Optional.None
                When Optional.None:
                    Call perform_navigation with manager as manager and route_match as route_match
                    Return NavigationResult with:
                        success as true
                        route as Optional.Some with value as route_match.route
                        error as Optional.None
                        redirected_to as Optional.None
        When Optional.None:
            Set manager.current_context.state to Error with message as "Route not found"
            Return NavigationResult with:
                success as false
                route as Optional.None
                error as Optional.Some with value as "Route not found: " concatenated with path
                redirected_to as Optional.None

Process called "match_route" that takes manager as NavigationManager and path as String returns Optional[RouteMatch]:
    Note: Try exact match first
    Let exact_match_option be Dict.get with dict as manager.route_tree.route_map and key as path
    Match exact_match_option:
        When Optional.Some with value as route:
            Return Optional.Some with value as RouteMatch with:
                route as route
                parameters as Dict.empty
                match_score as 1.0
                is_exact as true
        When Optional.None:
            Return match_parameterized_route with manager as manager and path as path

Process called "match_parameterized_route" that takes manager as NavigationManager and path as String returns Optional[RouteMatch]:
    For route in manager.route_tree.parameter_routes:
        Let match_result be try_match_route_pattern with route as route and path as path
        Match match_result:
            When Optional.Some with value as route_match:
                Return Optional.Some with value as route_match
            When Optional.None:
                Pass
    
    Return Optional.None

Process called "try_match_route_pattern" that takes route as Route and path as String returns Optional[RouteMatch]:
    Let route_segments be split_path with path as route.path
    Let path_segments be split_path with path as path
    
    If (length of route_segments) is not equal to (length of path_segments):
        Return Optional.None
    
    Let parameters be Dict.empty
    Let score be 0.0
    
    For i from 0 to ((length of route_segments) minus 1):
        Let route_segment be route_segments at index i
        Let path_segment be path_segments at index i
        
        If starts_with with text as route_segment and prefix as ":":
            Let param_name be substring with text as route_segment and start as 1 and end as (length of route_segment)
            Call Dict.set with dict as parameters and key as param_name and value as path_segment
            Set score to score plus 0.5
        Otherwise:
            If route_segment is equal to path_segment:
                Set score to score plus 1.0
            Otherwise:
                Return Optional.None
    
    Return Optional.Some with value as RouteMatch with:
        route as route
        parameters as parameters
        match_score as score divided by ((length of route_segments) as Float)
        is_exact as false

Process called "check_navigation_guards" that takes manager as NavigationManager and route as Route returns Optional[String]:
    For guard in route.guards:
        Let guard_result be execute_guard with guard as guard and route as route
        Match guard_result:
            When Optional.Some with value as error:
                Return Optional.Some with value as error
            When Optional.None:
                Pass
    
    For global_guard in manager.guards:
        Let guard_result be execute_guard with guard as global_guard and route as route
        Match guard_result:
            When Optional.Some with value as error:
                Return Optional.Some with value as error
            When Optional.None:
                Pass
    
    Return Optional.None

Process called "execute_guard" that takes guard as NavigationGuard and route as Route returns Optional[String]:
    Note: Execute guard condition
    Return Optional.None  Note: Would call guard.condition

Process called "perform_navigation" that takes manager as NavigationManager and route_match as RouteMatch:
    Let previous_route be manager.current_context.current_route
    
    Set manager.current_context.previous_route to Optional.Some with value as previous_route
    Set manager.current_context.current_route to route_match.route
    Set manager.current_context.route_parameters to route_match.parameters
    Set manager.current_context.state to Loading
    
    Call add_to_history with history as manager.history and route as route_match.route
    Call update_navigation_state with manager as manager
    Call execute_middleware with manager as manager and phase as "before"
    
    Set manager.current_context.state to Idle

Process called "add_to_history" that takes history as NavigationHistory and route as Route:
    Let entry be HistoryEntry with:
        route as route
        timestamp as Widgets.get_current_timestamp
        scroll_position as Optional.None
        state_snapshot as Optional.None
    
    Call List.append with list as history.entries and item as entry
    Set history.current_index to history.current_index plus 1
    
    Note: Trim history if it exceeds max size
    While (length of history.entries) is greater than history.max_size:
        Call List.remove_first with list as history.entries

Process called "update_navigation_state" that takes manager as NavigationManager:
    Set manager.current_context.can_go_back to manager.history.current_index is greater than 0
    Set manager.current_context.can_go_forward to manager.history.current_index is less than ((length of manager.history.entries) minus 1)

Process called "execute_middleware" that takes manager as NavigationManager and phase as String:
    For middleware in manager.middleware:
        Match phase:
            When "before":
                Match middleware.before_navigation:
                    When Optional.Some with value as callback:
                        Call callback
                    When Optional.None:
                        Pass
            When "after":
                Match middleware.after_navigation:
                    When Optional.Some with value as callback:
                        Call callback
                    When Optional.None:
                        Pass
            Otherwise:
                Pass

Note: History Navigation

Process called "go_back" that takes manager as NavigationManager returns Boolean:
    If not manager.current_context.can_go_back:
        Return false
    
    Set manager.history.current_index to manager.history.current_index minus 1
    Let entry be manager.history.entries at index manager.history.current_index
    
    Call navigate_to_route_from_history with manager as manager and route as entry.route
    Return true

Process called "go_forward" that takes manager as NavigationManager returns Boolean:
    If not manager.current_context.can_go_forward:
        Return false
    
    Set manager.history.current_index to manager.history.current_index plus 1
    Let entry be manager.history.entries at index manager.history.current_index
    
    Call navigate_to_route_from_history with manager as manager and route as entry.route
    Return true

Process called "navigate_to_route_from_history" that takes manager as NavigationManager and route as Route:
    Set manager.current_context.current_route to route
    Set manager.current_context.state to Loading
    Call update_navigation_state with manager as manager
    Set manager.current_context.state to Idle

Process called "clear_history" that takes manager as NavigationManager:
    Call List.clear with list as manager.history.entries
    Set manager.history.current_index to -1
    Call update_navigation_state with manager as manager

Note: Navigation Guards

Process called "add_navigation_guard" that takes manager as NavigationManager and guard as NavigationGuard:
    Call List.append with list as manager.guards and item as guard

Process called "create_auth_guard" returns NavigationGuard:
    Let guard_id be generate_guard_id
    
    Let condition be Process that takes route as Route returns Optional[String]:
        If route.metadata.requires_auth:
            Let is_authenticated be check_authentication
            If not is_authenticated:
                Return Optional.Some with value as "Authentication required"
        Return Optional.None
    
    Return NavigationGuard with:
        guard_id as guard_id
        guard_type as CanActivate
        condition as condition
        priority as 100
        is_async as false

Process called "generate_guard_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "guard_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "check_authentication" returns Boolean:
    Note: Would check actual authentication state
    Return true

Process called "create_role_guard" that takes required_roles as List[String] returns NavigationGuard:
    Let guard_id be generate_guard_id
    
    Let condition be Process that takes route as Route returns Optional[String]:
        If (length of route.metadata.roles) is greater than 0:
            Let user_roles be get_user_roles
            For required_role in route.metadata.roles:
                If not has_role with roles as user_roles and role as required_role:
                    Return Optional.Some with value as "Insufficient permissions"
        Return Optional.None
    
    Return NavigationGuard with:
        guard_id as guard_id
        guard_type as CanActivate
        condition as condition
        priority as 90
        is_async as false

Process called "get_user_roles" returns List[String]:
    Note: Would get actual user roles
    Return List.empty

Process called "has_role" that takes roles as List[String] and role as String returns Boolean:
    For user_role in roles:
        If user_role is equal to role:
            Return true
    Return false

Note: Navigation Middleware

Process called "add_navigation_middleware" that takes manager as NavigationManager and middleware as NavigationMiddleware:
    Call List.append with list as manager.middleware and item as middleware

Process called "create_logging_middleware" returns NavigationMiddleware:
    Let middleware_id be generate_middleware_id
    
    Let before_nav be Process:
        Display "Navigation starting"
    
    Let after_nav be Process:
        Display "Navigation completed"
    
    Return NavigationMiddleware with:
        middleware_id as middleware_id
        before_navigation as Optional.Some with value as before_nav
        after_navigation as Optional.Some with value as after_nav
        on_error as Optional.None

Process called "generate_middleware_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "middleware_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Note: Route Resolvers

Process called "add_route_resolver" that takes manager as NavigationManager and resolver as RouteResolver:
    Call Dict.set with dict as manager.resolvers and key as resolver.parameter_name and value as resolver

Process called "resolve_route_parameters" that takes manager as NavigationManager and route as Route and parameters as Dict[String, String]:
    For param_name in Dict.keys with dict as parameters:
        Let resolver_option be Dict.get with dict as manager.resolvers and key as param_name
        Match resolver_option:
            When Optional.Some with value as resolver:
                Let resolved_value be resolver.resolve_function with parameter_value as (Dict.get with dict as parameters and key as param_name)
                Call Dict.set with dict as parameters and key as param_name and value as resolved_value as String
            When Optional.None:
                Pass

Note: Utility Functions

Process called "get_current_route" that takes manager as NavigationManager returns Route:
    Return manager.current_context.current_route

Process called "get_current_path" that takes manager as NavigationManager returns String:
    Return manager.current_context.current_route.path

Process called "get_route_parameter" that takes manager as NavigationManager and param_name as String returns Optional[String]:
    Return Dict.get with dict as manager.current_context.route_parameters and key as param_name

Process called "get_query_parameter" that takes manager as NavigationManager and param_name as String returns Optional[String]:
    Return Dict.get with dict as manager.current_context.query_parameters and key as param_name

Process called "is_route_active" that takes manager as NavigationManager and path as String returns Boolean:
    Return manager.current_context.current_route.path is equal to path

Process called "get_navigation_breadcrumbs" that takes manager as NavigationManager returns List[Route]:
    Let breadcrumbs be List.empty
    Let current be Optional.Some with value as manager.current_context.current_route
    
    While current is not equal to Optional.None:
        Match current:
            When Optional.Some with value as route:
                Call List.prepend with list as breadcrumbs and item as route
                Set current to route.parent
            When Optional.None:
                Pass
    
    Return breadcrumbs

Process called "get_navigation_stats" that takes manager as NavigationManager returns String:
    Let route_count be length of (Dict.keys with dict as manager.routes)
    Let guard_count be length of manager.guards
    Let middleware_count be length of manager.middleware
    Let history_size be length of manager.history.entries
    
    Return "Navigation Manager Stats:\n" concatenated with
           "- Registered routes: " concatenated with route_count as String concatenated with "\n" concatenated with
           "- Active guards: " concatenated with guard_count as String concatenated with "\n" concatenated with
           "- Middleware: " concatenated with middleware_count as String concatenated with "\n" concatenated with
           "- History entries: " concatenated with history_size as String concatenated with "\n" concatenated with
           "- Current route: " concatenated with manager.current_context.current_route.path