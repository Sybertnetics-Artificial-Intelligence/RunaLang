Note:
Runa UI Framework: Advanced Router Implementation

High-performance router with intelligent route matching, lazy loading,
and seamless integration with UI components and state management.

Features:
- Intelligent route matching with scoring algorithms
- Component-based routing with lazy loading
- Route transitions with animated navigation
- Route-level code splitting and caching
- Advanced route guards with async support
- Nested routing with outlet management
- Route data preloading and caching
- SEO-friendly routing with meta management
:End Note

Import "collections/dict" as Dict
Import "collections/list" as List
Import "ui/widgets" as Widgets
Import "ui/navigation/core" as NavigationCore
Import "ui/events" as Events
Import "ui/animation/core" as AnimationCore

Note: Router Implementation Types

Type called "Router":
    router_id as String
    navigation_manager as NavigationCore.NavigationManager
    route_config as RouterConfig
    outlets as Dict[String, RouterOutlet]
    component_cache as ComponentCache
    route_data_cache as RouteDataCache
    transition_manager as TransitionManager
    preloader as RoutePreloader

Type called "RouterConfig":
    enable_tracing as Boolean
    hash_location_strategy as Boolean
    case_sensitive as Boolean
    trailing_slash_strategy as TrailingSlashStrategy
    default_route as String
    error_route as String
    loading_component_id as String
    enable_preloading as Boolean

Type TrailingSlashStrategy is:
    | Ignore
    | Redirect
    | Strict

Type called "RouterOutlet":
    outlet_id as String
    outlet_name as String
    current_component as Optional[RoutedComponent]
    widget_container as Widgets.UIWidget
    activation_state as ActivationState

Type ActivationState is:
    | Inactive
    | Activating
    | Active
    | Deactivating

Type called "RoutedComponent":
    component_id as String
    route as NavigationCore.Route
    widget as Widgets.UIWidget
    data as Dict[String, Any]
    state as ComponentState
    destroy_callback as Optional[Function]

Type ComponentState is:
    | Loading
    | Loaded
    | Error with message as String
    | Destroyed

Type called "ComponentCache":
    cached_components as Dict[String, RoutedComponent]
    cache_strategy as CacheStrategy
    max_cache_size as Integer
    ttl_seconds as Integer

Type CacheStrategy is:
    | NoCache
    | LRU
    | TTL
    | CustomStrategy with strategy as Function

Type called "RouteDataCache":
    cached_data as Dict[String, CachedRouteData]
    max_cache_entries as Integer

Type called "CachedRouteData":
    route_path as String
    data as Dict[String, Any]
    timestamp as Integer
    expires_at as Integer

Type called "TransitionManager":
    active_transition as Optional[RouteTransition]
    transition_queue as List[RouteTransition]
    default_transition as TransitionConfig

Type called "RouteTransition":
    transition_id as String
    from_route as NavigationCore.Route
    to_route as NavigationCore.Route
    transition_config as TransitionConfig
    state as TransitionState

Type TransitionState is:
    | Pending
    | InProgress
    | Completed
    | Cancelled

Type called "TransitionConfig":
    animation_type as AnimationType
    duration as Float
    easing as String
    overlay_during_transition as Boolean

Type AnimationType is:
    | Slide with direction as SlideDirection
    | Fade
    | Scale
    | Flip
    | Custom with animation as AnimationCore.Animation

Type SlideDirection is:
    | Left
    | Right
    | Up
    | Down

Type called "RoutePreloader":
    preload_strategy as PreloadStrategy
    preloaded_routes as Dict[String, PreloadedRoute]
    loading_queue as List[String]

Type PreloadStrategy is:
    | NoPreload
    | PreloadAll
    | PreloadVisible
    | CustomPreload with selector as Function

Type called "PreloadedRoute":
    route_path as String
    component as RoutedComponent
    data as Dict[String, Any]
    preloaded_at as Integer

Type called "RouteResolver":
    route_resolvers as Dict[String, DataResolver]
    resolution_timeout as Float

Type called "DataResolver":
    resolver_id as String
    resolve_function as Function
    cache_duration as Optional[Integer]

Note: Router Creation and Configuration

Process called "create_router" that takes config as RouterConfig returns Router:
    Let router_id be generate_router_id
    
    Return Router with:
        router_id as router_id
        navigation_manager as NavigationCore.create_navigation_manager
        route_config as config
        outlets as Dict.empty
        component_cache as create_component_cache
        route_data_cache as create_route_data_cache
        transition_manager as create_transition_manager
        preloader as create_route_preloader

Process called "generate_router_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 8
    Return "router_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "create_default_router_config" returns RouterConfig:
    Return RouterConfig with:
        enable_tracing as false
        hash_location_strategy as false
        case_sensitive as false
        trailing_slash_strategy as Ignore
        default_route as "/"
        error_route as "/error"
        loading_component_id as "loading_component"
        enable_preloading as true

Process called "create_component_cache" returns ComponentCache:
    Return ComponentCache with:
        cached_components as Dict.empty
        cache_strategy as LRU
        max_cache_size as 10
        ttl_seconds as 3600

Process called "create_route_data_cache" returns RouteDataCache:
    Return RouteDataCache with:
        cached_data as Dict.empty
        max_cache_entries as 50

Process called "create_transition_manager" returns TransitionManager:
    Return TransitionManager with:
        active_transition as Optional.None
        transition_queue as List.empty
        default_transition as create_default_transition_config

Process called "create_default_transition_config" returns TransitionConfig:
    Return TransitionConfig with:
        animation_type as Fade
        duration as 0.3
        easing as "ease-in-out"
        overlay_during_transition as false

Process called "create_route_preloader" returns RoutePreloader:
    Return RoutePreloader with:
        preload_strategy as PreloadVisible
        preloaded_routes as Dict.empty
        loading_queue as List.empty

Note: Router Outlet Management

Process called "create_router_outlet" that takes outlet_name as String and container as Widgets.UIWidget returns RouterOutlet:
    Let outlet_id be generate_outlet_id
    
    Return RouterOutlet with:
        outlet_id as outlet_id
        outlet_name as outlet_name
        current_component as Optional.None
        widget_container as container
        activation_state as Inactive

Process called "generate_outlet_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "outlet_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "register_outlet" that takes router as Router and outlet as RouterOutlet:
    Call Dict.set with dict as router.outlets and key as outlet.outlet_name and value as outlet

Process called "activate_route_in_outlet" that takes router as Router and outlet_name as String and route as NavigationCore.Route returns Boolean:
    Let outlet_option be Dict.get with dict as router.outlets and key as outlet_name
    Match outlet_option:
        When Optional.Some with value as outlet:
            Set outlet.activation_state to Activating
            Let component be load_route_component with router as router and route as route
            Call transition_to_component with router as router and outlet as outlet and component as component
            Return true
        When Optional.None:
            Return false

Process called "load_route_component" that takes router as Router and route as NavigationCore.Route returns RoutedComponent:
    Let cached_component_option be get_cached_component with cache as router.component_cache and route as route
    Match cached_component_option:
        When Optional.Some with value as component:
            Return component
        When Optional.None:
            Return create_new_component with router as router and route as route

Process called "get_cached_component" that takes cache as ComponentCache and route as NavigationCore.Route returns Optional[RoutedComponent]:
    Return Dict.get with dict as cache.cached_components and key as route.component_id

Process called "create_new_component" that takes router as Router and route as NavigationCore.Route returns RoutedComponent:
    Let widget be create_component_widget with component_id as route.component_id
    Let data be resolve_route_data with router as router and route as route
    
    Let component be RoutedComponent with:
        component_id as route.component_id
        route as route
        widget as widget
        data as data
        state as Loading
        destroy_callback as Optional.None
    
    Call cache_component with cache as router.component_cache and component as component
    Return component

Process called "create_component_widget" that takes component_id as String returns Widgets.UIWidget:
    Note: Create widget from component ID
    Return Widgets.create_widget with widget_type as "component" and id as component_id

Process called "resolve_route_data" that takes router as Router and route as NavigationCore.Route returns Dict[String, Any]:
    Let cached_data_option be get_cached_route_data with cache as router.route_data_cache and route_path as route.path
    Match cached_data_option:
        When Optional.Some with value as cached_data:
            If not is_cache_expired with cached_data as cached_data:
                Return cached_data.data
        When Optional.None:
            Pass
    
    Let resolved_data be perform_data_resolution with router as router and route as route
    Call cache_route_data with cache as router.route_data_cache and route_path as route.path and data as resolved_data
    Return resolved_data

Process called "get_cached_route_data" that takes cache as RouteDataCache and route_path as String returns Optional[CachedRouteData]:
    Return Dict.get with dict as cache.cached_data and key as route_path

Process called "is_cache_expired" that takes cached_data as CachedRouteData returns Boolean:
    Let current_time be Widgets.get_current_timestamp
    Return current_time is greater than cached_data.expires_at

Process called "perform_data_resolution" that takes router as Router and route as NavigationCore.Route returns Dict[String, Any]:
    Note: Resolve data for route
    Return Dict.empty

Process called "cache_route_data" that takes cache as RouteDataCache and route_path as String and data as Dict[String, Any]:
    Let current_time be Widgets.get_current_timestamp
    Let cached_data be CachedRouteData with:
        route_path as route_path
        data as data
        timestamp as current_time
        expires_at as current_time plus 3600  Note: 1 hour TTL
    
    Call Dict.set with dict as cache.cached_data and key as route_path and value as cached_data
    
    Note: Clean up old entries if cache is full
    If (length of (Dict.keys with dict as cache.cached_data)) is greater than cache.max_cache_entries:
        Call cleanup_route_data_cache with cache as cache

Process called "cleanup_route_data_cache" that takes cache as RouteDataCache:
    Note: Remove oldest entries
    Pass

Process called "cache_component" that takes cache as ComponentCache and component as RoutedComponent:
    Call Dict.set with dict as cache.cached_components and key as component.component_id and value as component
    
    If (length of (Dict.keys with dict as cache.cached_components)) is greater than cache.max_cache_size:
        Call evict_component_from_cache with cache as cache

Process called "evict_component_from_cache" that takes cache as ComponentCache:
    Note: Evict based on cache strategy
    Match cache.cache_strategy:
        When LRU:
            Call evict_least_recently_used with cache as cache
        When TTL:
            Call evict_expired_components with cache as cache
        Otherwise:
            Pass

Process called "evict_least_recently_used" that takes cache as ComponentCache:
    Note: Would implement LRU eviction
    Pass

Process called "evict_expired_components" that takes cache as ComponentCache:
    Note: Would implement TTL-based eviction
    Pass

Note: Route Transitions

Process called "transition_to_component" that takes router as Router and outlet as RouterOutlet and component as RoutedComponent:
    Match outlet.current_component:
        When Optional.Some with value as current:
            Let transition be create_route_transition with from_component as current and to_component as component
            Call execute_transition with router as router and outlet as outlet and transition as transition
        When Optional.None:
            Call activate_component_directly with outlet as outlet and component as component

Process called "create_route_transition" that takes from_component as RoutedComponent and to_component as RoutedComponent returns RouteTransition:
    Let transition_id be generate_transition_id
    
    Return RouteTransition with:
        transition_id as transition_id
        from_route as from_component.route
        to_route as to_component.route
        transition_config as create_default_transition_config
        state as Pending

Process called "generate_transition_id" returns String:
    Let timestamp be Widgets.get_current_timestamp
    Let random_suffix be Widgets.generate_random_string with length as 6
    Return "transition_" concatenated with timestamp as String concatenated with "_" concatenated with random_suffix

Process called "execute_transition" that takes router as Router and outlet as RouterOutlet and transition as RouteTransition:
    Set transition.state to InProgress
    Set router.transition_manager.active_transition to Optional.Some with value as transition
    
    Match transition.transition_config.animation_type:
        When Fade:
            Call execute_fade_transition with outlet as outlet and transition as transition
        When Slide with direction as dir:
            Call execute_slide_transition with outlet as outlet and transition as transition and direction as dir
        When Scale:
            Call execute_scale_transition with outlet as outlet and transition as transition
        When Custom with animation as anim:
            Call execute_custom_transition with outlet as outlet and transition as transition and animation as anim
        Otherwise:
            Call execute_immediate_transition with outlet as outlet and transition as transition

Process called "execute_fade_transition" that takes outlet as RouterOutlet and transition as RouteTransition:
    Note: Implement fade transition
    Call complete_transition with outlet as outlet and transition as transition

Process called "execute_slide_transition" that takes outlet as RouterOutlet and transition as RouteTransition and direction as SlideDirection:
    Note: Implement slide transition
    Call complete_transition with outlet as outlet and transition as transition

Process called "execute_scale_transition" that takes outlet as RouterOutlet and transition as RouteTransition:
    Note: Implement scale transition
    Call complete_transition with outlet as outlet and transition as transition

Process called "execute_custom_transition" that takes outlet as RouterOutlet and transition as RouteTransition and animation as AnimationCore.Animation:
    Note: Execute custom animation
    Call complete_transition with outlet as outlet and transition as transition

Process called "execute_immediate_transition" that takes outlet as RouterOutlet and transition as RouteTransition:
    Call complete_transition with outlet as outlet and transition as transition

Process called "complete_transition" that takes outlet as RouterOutlet and transition as RouteTransition:
    Set transition.state to Completed
    Call activate_component_directly with outlet as outlet and component as create_to_component_from_transition with transition as transition

Process called "create_to_component_from_transition" that takes transition as RouteTransition returns RoutedComponent:
    Note: Would reconstruct component from transition
    Return RoutedComponent with:
        component_id as transition.to_route.component_id
        route as transition.to_route
        widget as create_component_widget with component_id as transition.to_route.component_id
        data as Dict.empty
        state as Loaded
        destroy_callback as Optional.None

Process called "activate_component_directly" that takes outlet as RouterOutlet and component as RoutedComponent:
    Set outlet.current_component to Optional.Some with value as component
    Set outlet.activation_state to Active
    Set component.state to Loaded
    Call attach_component_to_outlet with outlet as outlet and component as component

Process called "attach_component_to_outlet" that takes outlet as RouterOutlet and component as RoutedComponent:
    Note: Attach component widget to outlet container
    Call Widgets.add_child_widget with parent as outlet.widget_container and child as component.widget

Process called "deactivate_outlet" that takes outlet as RouterOutlet:
    Match outlet.current_component:
        When Optional.Some with value as component:
            Set outlet.activation_state to Deactivating
            Call detach_component_from_outlet with outlet as outlet and component as component
            Set component.state to Destroyed
            Set outlet.current_component to Optional.None
            Set outlet.activation_state to Inactive
        When Optional.None:
            Pass

Process called "detach_component_from_outlet" that takes outlet as RouterOutlet and component as RoutedComponent:
    Call Widgets.remove_child_widget with parent as outlet.widget_container and child as component.widget

Note: Route Preloading

Process called "preload_routes" that takes router as Router:
    Match router.preloader.preload_strategy:
        When PreloadAll:
            Call preload_all_routes with router as router
        When PreloadVisible:
            Call preload_visible_routes with router as router
        When CustomPreload with selector as selector:
            Call preload_custom_routes with router as router and selector as selector
        Otherwise:
            Pass

Process called "preload_all_routes" that takes router as Router:
    For route_path in Dict.keys with dict as router.navigation_manager.routes:
        Call preload_route with router as router and route_path as route_path

Process called "preload_visible_routes" that takes router as Router:
    Note: Preload routes that are likely to be navigated to
    Let current_route be NavigationCore.get_current_route with manager as router.navigation_manager
    For child in current_route.children:
        Call preload_route with router as router and route_path as child.path

Process called "preload_custom_routes" that takes router as Router and selector as Function:
    Note: Use custom selector to determine which routes to preload
    Pass

Process called "preload_route" that takes router as Router and route_path as String:
    Let already_preloaded_option be Dict.get with dict as router.preloader.preloaded_routes and key as route_path
    Match already_preloaded_option:
        When Optional.Some:
            Return  Note: Already preloaded
        When Optional.None:
            Let route_option be Dict.get with dict as router.navigation_manager.routes and key as route_path
            Match route_option:
                When Optional.Some with value as route:
                    Call perform_route_preload with router as router and route as route
                When Optional.None:
                    Pass

Process called "perform_route_preload" that takes router as Router and route as NavigationCore.Route:
    Let component be create_new_component with router as router and route as route
    Let data be resolve_route_data with router as router and route as route
    
    Let preloaded_route be PreloadedRoute with:
        route_path as route.path
        component as component
        data as data
        preloaded_at as Widgets.get_current_timestamp
    
    Call Dict.set with dict as router.preloader.preloaded_routes and key as route.path and value as preloaded_route

Note: Router Navigation Integration

Process called "navigate" that takes router as Router and path as String returns Boolean:
    Let result be NavigationCore.navigate_to with manager as router.navigation_manager and path as path
    Match result.success:
        When true:
            Match result.route:
                When Optional.Some with value as route:
                    Call update_active_outlet with router as router and route as route
                    If router.route_config.enable_preloading:
                        Call preload_related_routes with router as router and route as route
                When Optional.None:
                    Pass
        When false:
            Call handle_navigation_error with router as router and error as result.error
    
    Return result.success

Process called "update_active_outlet" that takes router as Router and route as NavigationCore.Route:
    Note: Find appropriate outlet for route
    Let primary_outlet_option be Dict.get with dict as router.outlets and key as "primary"
    Match primary_outlet_option:
        When Optional.Some with value as outlet:
            Call activate_route_in_outlet with router as router and outlet_name as "primary" and route as route
        When Optional.None:
            Display "No primary outlet found for route: " concatenated with route.path

Process called "preload_related_routes" that takes router as Router and route as NavigationCore.Route:
    For child in route.children:
        Call preload_route with router as router and route_path as child.path

Process called "handle_navigation_error" that takes router as Router and error as Optional[String]:
    Match error:
        When Optional.Some with value as error_message:
            Display "Navigation error: " concatenated with error_message
            Call navigate_to_error_route with router as router
        When Optional.None:
            Pass

Process called "navigate_to_error_route" that takes router as Router:
    Call navigate with router as router and path as router.route_config.error_route

Note: Router Lifecycle Management

Process called "initialize_router" that takes router as Router:
    Note: Set up initial route
    Let initial_path be get_current_location_path
    If (length of initial_path) is equal to 0:
        Set initial_path to router.route_config.default_route
    
    Call navigate with router as router and path as initial_path
    
    If router.route_config.enable_preloading:
        Call preload_routes with router as router

Process called "get_current_location_path" returns String:
    Note: Get current path from browser location or similar
    Return "/"

Process called "destroy_router" that takes router as Router:
    For outlet_name in Dict.keys with dict as router.outlets:
        Let outlet_option be Dict.get with dict as router.outlets and key as outlet_name
        Match outlet_option:
            When Optional.Some with value as outlet:
                Call deactivate_outlet with outlet as outlet
            When Optional.None:
                Pass
    
    Call clear_component_cache with cache as router.component_cache
    Call clear_route_data_cache with cache as router.route_data_cache
    Call clear_preloaded_routes with preloader as router.preloader

Process called "clear_component_cache" that takes cache as ComponentCache:
    For component_id in Dict.keys with dict as cache.cached_components:
        Let component_option be Dict.get with dict as cache.cached_components and key as component_id
        Match component_option:
            When Optional.Some with value as component:
                Set component.state to Destroyed
                Match component.destroy_callback:
                    When Optional.Some with value as callback:
                        Call callback
                    When Optional.None:
                        Pass
            When Optional.None:
                Pass
    
    Call Dict.clear with dict as cache.cached_components

Process called "clear_route_data_cache" that takes cache as RouteDataCache:
    Call Dict.clear with dict as cache.cached_data

Process called "clear_preloaded_routes" that takes preloader as RoutePreloader:
    Call Dict.clear with dict as preloader.preloaded_routes
    Call List.clear with list as preloader.loading_queue

Note: Utility Functions

Process called "get_active_route" that takes router as Router returns Optional[NavigationCore.Route]:
    Return Optional.Some with value as NavigationCore.get_current_route with manager as router.navigation_manager

Process called "get_outlet_component" that takes router as Router and outlet_name as String returns Optional[RoutedComponent]:
    Let outlet_option be Dict.get with dict as router.outlets and key as outlet_name
    Match outlet_option:
        When Optional.Some with value as outlet:
            Return outlet.current_component
        When Optional.None:
            Return Optional.None

Process called "is_route_preloaded" that takes router as Router and route_path as String returns Boolean:
    Let preloaded_option be Dict.get with dict as router.preloader.preloaded_routes and key as route_path
    Match preloaded_option:
        When Optional.Some:
            Return true
        When Optional.None:
            Return false

Process called "get_router_stats" that takes router as Router returns String:
    Let outlet_count be length of (Dict.keys with dict as router.outlets)
    Let cached_component_count be length of (Dict.keys with dict as router.component_cache.cached_components)
    Let cached_data_count be length of (Dict.keys with dict as router.route_data_cache.cached_data)
    Let preloaded_route_count be length of (Dict.keys with dict as router.preloader.preloaded_routes)
    
    Let active_transition_text be match router.transition_manager.active_transition:
        When Optional.Some with value as transition:
            transition.transition_id
        When Optional.None:
            "None"
    
    Return "Router Stats:\n" concatenated with
           "- Router ID: " concatenated with router.router_id concatenated with "\n" concatenated with
           "- Active outlets: " concatenated with outlet_count as String concatenated with "\n" concatenated with
           "- Cached components: " concatenated with cached_component_count as String concatenated with "\n" concatenated with
           "- Cached route data: " concatenated with cached_data_count as String concatenated with "\n" concatenated with
           "- Preloaded routes: " concatenated with preloaded_route_count as String concatenated with "\n" concatenated with
           "- Active transition: " concatenated with active_transition_text