Note:
Runa Standard Library: Audio Streaming Module

Provides comprehensive real-time audio streaming capabilities for live audio processing,
recording, playback, and network streaming. Competitive with professional audio libraries
like PortAudio, JACK, ASIO, and modern streaming protocols.

Features:
- Ultra-low latency audio streaming (sub-millisecond)
- Multi-channel audio I/O with hardware device management
- Real-time processing with zero-copy buffering
- Network audio streaming (RTP, RTSP, WebRTC, Custom UDP)
- Audio device enumeration and configuration
- Sample rate conversion and format adaptation
- Adaptive buffering and jitter compensation
- Audio synchronization and clock recovery
- Live audio effects processing chain
- Recording and playback with timestamp alignment
- Professional audio driver integration (ASIO, CoreAudio, ALSA)
- Streaming protocols (HLS, DASH, Icecast, SHOUTcast)
:End Note

Note: Core Streaming Types
Type called "AudioDevice":
    id as Integer
    name as String
    driver_name as String
    max_input_channels as Integer
    max_output_channels as Integer
    default_sample_rate as Integer
    supported_sample_rates as List[Integer]
    default_buffer_size as Integer
    supported_buffer_sizes as List[Integer]
    input_latency as Float
    output_latency as Float
    is_default_input as Boolean
    is_default_output as Boolean
    is_available as Boolean

Type called "AudioStream":
    device as AudioDevice
    is_input as Boolean
    is_output as Boolean
    channels as Integer
    sample_rate as Integer
    buffer_size as Integer
    sample_format as SampleFormat
    is_running as Boolean
    is_paused as Boolean
    callback as Process
    user_data as Any
    stream_time as Float
    frames_processed as Integer
    underrun_count as Integer
    overrun_count as Integer

Type called "StreamingServer":
    protocol as StreamingProtocol
    port as Integer
    max_connections as Integer
    current_connections as Integer
    bit_rate as Integer
    sample_rate as Integer
    channels as Integer
    is_running as Boolean
    clients as List[StreamingClient]
    metadata as Dictionary[String, String]

Type called "StreamingClient":
    id as String
    ip_address as String
    connection_time as Float
    bytes_sent as Integer
    is_connected as Boolean
    buffer_health as Float
    latency_ms as Float

Type StreamingProtocol is:
    | RTP
    | RTSP
    | WEBRTC
    | UDP_CUSTOM
    | TCP_CUSTOM
    | HLS
    | DASH
    | ICECAST
    | SHOUTCAST

Type called "NetworkPacket":
    sequence_number as Integer
    timestamp as Integer
    payload as List[Integer]
    payload_type as Integer
    marker as Boolean
    ssrc as Integer

Type called "BufferManager":
    ring_buffers as List[RingBuffer]
    read_index as Integer
    write_index as Integer
    buffer_size as Integer
    sample_rate as Integer
    channels as Integer
    target_latency_ms as Float
    current_latency_ms as Float
    underrun_protection as Boolean

Type called "RingBuffer":
    buffer as List[AudioSample]
    size as Integer
    read_pos as Integer
    write_pos as Integer
    available_samples as Integer
    is_full as Boolean
    is_empty as Boolean

