Process called "get_default_input_device" returns AudioDevice:
    Let devices be enumerate_audio_devices
    For each device in devices:
        If device["is_default_input"]:
            Return device
    
    Note: Return first available input device if no default found
    For each device in devices:
        If device["max_input_channels"] is greater than 0:
            Return device
    
    Note: Return invalid device if none found
    Return AudioDevice with:
        id as negative 1
        name as "No Device"
        driver_name as ""
        max_input_channels as 0
        max_output_channels as 0
        default_sample_rate as 44100
        supported_sample_rates as list containing
        default_buffer_size as 512
        supported_buffer_sizes as list containing
        input_latency as 0.0
        output_latency as 0.0
        is_default_input as false
        is_default_output as false
        is_available as false

Process called "get_default_output_device" returns AudioDevice:
    Let devices be enumerate_audio_devices
    For each device in devices:
        If device["is_default_output"]:
            Return device
    
    Note: Return first available output device if no default found
    For each device in devices:
        If device["max_output_channels"] is greater than 0:
            Return device
    
    Note: Return invalid device
    Return AudioDevice with:
        id as negative 1
        name as "No Device"
        driver_name as ""
        max_input_channels as 0
        max_output_channels as 0
        default_sample_rate as 44100
        supported_sample_rates as list containing
        default_buffer_size as 512
        supported_buffer_sizes as list containing
        input_latency as 0.0
        output_latency as 0.0
        is_default_input as false
        is_default_output as false
        is_available as false

Process called "validate_stream_parameters" that takes device as AudioDevice and sample_rate as Integer and channels as Integer and buffer_size as Integer returns Boolean:
    Note: Check if sample rate is supported
    Let sample_rate_supported be false
    For each rate in device["supported_sample_rates"]:
        If rate is equal to sample_rate:
            Set sample_rate_supported to true
            break
    
    If not sample_rate_supported:
        Return false
    
    Note: Check if buffer size is supported
    Let buffer_size_supported be false
    For each size in device["supported_buffer_sizes"]:
        If size is equal to buffer_size:
            Set buffer_size_supported to true
            break
    
    If not buffer_size_supported:
        Return false
    
    Note: Check channel count
    If channels is greater than device["max_input_channels"] and channels is greater than device["max_output_channels"]:
        Return false
    
    Return true

Note: Audio Stream Management
Process called "open_input_stream" that takes device as AudioDevice and channels as Integer and sample_rate as Integer and buffer_size as Integer and callback as Process returns AudioStream:
    If not validate_stream_parameters with device as device and sample_rate as sample_rate and channels as channels and buffer_size as buffer_size:
        Return create_invalid_stream
    
    Let stream be AudioStream with:
        device as device
        is_input as true
        is_output as false
        channels as channels
        sample_rate as sample_rate
        buffer_size as buffer_size
        sample_format as FLOAT_32
        is_running as false
        is_paused as false
        callback as callback
        user_data as None
        stream_time as 0.0
        frames_processed as 0
        underrun_count as 0
        overrun_count as 0
    
    Note: Initialize hardware stream
    Let success be initialize_hardware_stream with stream as stream
    If not success:
        Return create_invalid_stream
    
    Return stream

Process called "open_output_stream" that takes device as AudioDevice and channels as Integer and sample_rate as Integer and buffer_size as Integer and callback as Process returns AudioStream:
    If not validate_stream_parameters with device as device and sample_rate as sample_rate and channels as channels and buffer_size as buffer_size:
        Return create_invalid_stream
    
    Let stream be AudioStream with:
        device as device
        is_input as false
        is_output as true
        channels as channels
        sample_rate as sample_rate
        buffer_size as buffer_size
        sample_format as FLOAT_32
        is_running as false
        is_paused as false
        callback as callback
        user_data as None
        stream_time as 0.0
        frames_processed as 0
        underrun_count as 0
        overrun_count as 0
    
    Note: Initialize hardware stream
    Let success be initialize_hardware_stream with stream as stream
    If not success:
        Return create_invalid_stream
    
    Return stream

Process called "open_duplex_stream" that takes input_device as AudioDevice and output_device as AudioDevice and channels as Integer and sample_rate as Integer and buffer_size as Integer and callback as Process returns AudioStream:
    Note: Validate both devices
    If not validate_stream_parameters with device as input_device and sample_rate as sample_rate and channels as channels and buffer_size as buffer_size:
        Return create_invalid_stream
    
    If not validate_stream_parameters with device as output_device and sample_rate as sample_rate and channels as channels and buffer_size as buffer_size:
        Return create_invalid_stream
    
    Let stream be AudioStream with:
        device as input_device
        is_input as true
        is_output as true
        channels as channels
        sample_rate as sample_rate
        buffer_size as buffer_size
        sample_format as FLOAT_32
        is_running as false
        is_paused as false
        callback as callback
        user_data as None
        stream_time as 0.0
        frames_processed as 0
        underrun_count as 0
        overrun_count as 0
    
    Note: Initialize duplex stream
    Let success be initialize_duplex_hardware_stream with stream as stream and output_device as output_device
    If not success:
        Return create_invalid_stream
    
    Return stream

Process called "start_stream" that takes stream as AudioStream returns Boolean:
    If stream["device"]["id"] is less than 0:
        Return false
    
    Set stream["is_running"] to true
    Set stream["is_paused"] to false
    Set stream["stream_time"] to get_current_time_seconds
    
    Note: Start hardware stream
    Return start_hardware_stream with stream as stream

Process called "stop_stream" that takes stream as AudioStream returns Boolean:
    Set stream["is_running"] to false
    Set stream["is_paused"] to false
    
    Note: Stop hardware stream
    Return stop_hardware_stream with stream as stream

Process called "pause_stream" that takes stream as AudioStream returns Boolean:
    Set stream["is_paused"] to true
    
    Note: Pause hardware stream
    Return pause_hardware_stream with stream as stream

Process called "resume_stream" that takes stream as AudioStream returns Boolean:
    Set stream["is_paused"] to false
    
    Note: Resume hardware stream
    Return resume_hardware_stream with stream as stream

Process called "close_stream" that takes stream as AudioStream returns Boolean:
    If stream["is_running"]:
        stop_stream with stream as stream
    
    Note: Close hardware stream
    Return close_hardware_stream with stream as stream

Process called "create_invalid_stream" returns AudioStream:
    Return AudioStream with:
        device as AudioDevice with:
            id as negative 1
            name as "Invalid"
            driver_name as ""
            max_input_channels as 0
            max_output_channels as 0
            default_sample_rate as 44100
            supported_sample_rates as list containing
            default_buffer_size as 512
            supported_buffer_sizes as list containing
            input_latency as 0.0
            output_latency as 0.0
            is_default_input as false
            is_default_output as false
            is_available as false
        is_input as false
        is_output as false
        channels as 0
        sample_rate as 0
        buffer_size as 0
        sample_format as FLOAT_32
        is_running as false
        is_paused as false
        callback as None
        user_data as None
        stream_time as 0.0
        frames_processed as 0
        underrun_count as 0
        overrun_count as 0

Note: Ring Buffer Implementation for Low-Latency Streaming
Process called "create_ring_buffer" that takes size as Integer returns RingBuffer:
    Let buffer be list containing
    For i from 0 to size minus 1:
        Add 0.0 to buffer
    
    Return RingBuffer with:
        buffer as buffer
        size as size
        read_pos as 0
        write_pos as 0
        available_samples as 0
        is_full as false
        is_empty as true

Process called "write_to_ring_buffer" that takes ring_buffer as RingBuffer and samples as List[AudioSample] returns Integer:
    Let samples_written be 0
    Let available_space be ring_buffer["size"] minus ring_buffer["available_samples"]
    Let samples_to_write be minimum of available_space and length of samples
    
    For i from 0 to samples_to_write minus 1:
        Set ring_buffer["buffer"] at index ring_buffer["write_pos"] to samples at index i
        Set ring_buffer["write_pos"] to (ring_buffer["write_pos"] plus 1) modulo ring_buffer["size"]
        Set samples_written to samples_written plus 1
    
    Set ring_buffer["available_samples"] to ring_buffer["available_samples"] plus samples_written
    Set ring_buffer["is_empty"] to ring_buffer["available_samples"] is equal to 0
    Set ring_buffer["is_full"] to ring_buffer["available_samples"] is equal to ring_buffer["size"]
    
    Return samples_written

Process called "read_from_ring_buffer" that takes ring_buffer as RingBuffer and num_samples as Integer returns List[AudioSample]:
    Let samples_read be list containing
    Let samples_to_read be minimum of ring_buffer["available_samples"] and num_samples
    
    For i from 0 to samples_to_read minus 1:
        Add ring_buffer["buffer"] at index ring_buffer["read_pos"] to samples_read
        Set ring_buffer["read_pos"] to (ring_buffer["read_pos"] plus 1) modulo ring_buffer["size"]
    
    Set ring_buffer["available_samples"] to ring_buffer["available_samples"] minus samples_to_read
    Set ring_buffer["is_empty"] to ring_buffer["available_samples"] is equal to 0
    Set ring_buffer["is_full"] to ring_buffer["available_samples"] is equal to ring_buffer["size"]
    
    Return samples_read

Process called "get_ring_buffer_available_read" that takes ring_buffer as RingBuffer returns Integer:
    Return ring_buffer["available_samples"]

Process called "get_ring_buffer_available_write" that takes ring_buffer as RingBuffer returns Integer:
    Return ring_buffer["size"] minus ring_buffer["available_samples"]

Note: Buffer Management for Adaptive Streaming
Process called "create_buffer_manager" that takes channels as Integer and sample_rate as Integer and target_latency_ms as Float returns BufferManager:
    Let buffer_size be integer from (sample_rate times target_latency_ms divided by 1000.0) times 4
    Let ring_buffers be list containing
    
    For ch from 0 to channels minus 1:
        Add create_ring_buffer with size as buffer_size to ring_buffers
    
    Return BufferManager with:
        ring_buffers as ring_buffers
        read_index as 0
        write_index as 0
        buffer_size as buffer_size
        sample_rate as sample_rate
        channels as channels
        target_latency_ms as target_latency_ms
        current_latency_ms as target_latency_ms
        underrun_protection as true

Process called "write_to_buffer_manager" that takes buffer_manager as BufferManager and audio_buffer as AudioBuffer returns Integer:
    Let channels be buffer_manager["channels"]
    Let frames_written be 0
    
    If audio_buffer["channels"] is not equal to channels:
        Return 0
    
    Note: Write samples channel by channel
    For ch from 0 to channels minus 1:
        Let channel_samples be get_channel_samples with buffer as audio_buffer and channel as ch
        Let ring_buffer be buffer_manager["ring_buffers"] at index ch
        Let samples_written be write_to_ring_buffer with ring_buffer as ring_buffer and samples as channel_samples
        
        If ch is equal to 0:
            Set frames_written to samples_written
    
    Note: Update latency estimate
    Let total_samples_buffered be 0
    For each ring_buffer in buffer_manager["ring_buffers"]:
        Set total_samples_buffered to total_samples_buffered plus get_ring_buffer_available_read with ring_buffer as ring_buffer
    
    Let avg_samples_buffered be total_samples_buffered divided by channels
    Set buffer_manager["current_latency_ms"] to (avg_samples_buffered divided by buffer_manager["sample_rate"]) times 1000.0
    
    Return frames_written

Process called "read_from_buffer_manager" that takes buffer_manager as BufferManager and num_frames as Integer returns AudioBuffer:
    Let channels be buffer_manager["channels"]
    Let output_buffer be create_audio_buffer with channels as channels and sample_rate as buffer_manager["sample_rate"] and length as num_frames
    
    Note: Read samples channel by channel
    For ch from 0 to channels minus 1:
        Let ring_buffer be buffer_manager["ring_buffers"] at index ch
        Let channel_samples be read_from_ring_buffer with ring_buffer as ring_buffer and num_samples as num_frames
        
        Note: Pad with zeros if not enough samples (underrun protection)
        While length of channel_samples is less than num_frames:
            Add 0.0 to channel_samples
        
        Set output_buffer to set_channel_samples with buffer as output_buffer and channel as ch and samples as channel_samples
    
    Return output_buffer

Process called "get_buffer_health" that takes buffer_manager as BufferManager returns Float:
    Note: Return buffer health as percentage (0.0 = empty, 1.0 = full)
    Let total_available be 0
    Let total_capacity be 0
    
    For each ring_buffer in buffer_manager["ring_buffers"]:
        Set total_available to total_available plus get_ring_buffer_available_read with ring_buffer as ring_buffer
        Set total_capacity to total_capacity plus ring_buffer["size"]
    
    If total_capacity is equal to 0:
        Return 0.0
    
    Return total_available divided by total_capacity

Note: Network Streaming Implementation
Process called "create_streaming_server" that takes protocol as StreamingProtocol and port as Integer and sample_rate as Integer and channels as Integer and bit_rate as Integer returns StreamingServer:
    Return StreamingServer with:
        protocol as protocol
        port as port
        max_connections as 100
        current_connections as 0
        bit_rate as bit_rate
        sample_rate as sample_rate
        channels as channels
        is_running as false
        clients as list containing
        metadata as dictionary containing

Process called "start_streaming_server" that takes server as StreamingServer returns Boolean:
    Set server["is_running"] to true
    
    Match server["protocol"]:
        When RTP:
            Return start_rtp_server with server as server
        When UDP_CUSTOM:
            Return start_udp_server with server as server
        When HLS:
            Return start_hls_server with server as server
        When ICECAST:
            Return start_icecast_server with server as server
        Otherwise:
            Return start_generic_server with server as server

Process called "stop_streaming_server" that takes server as StreamingServer returns Boolean:
    Set server["is_running"] to false
    
    Note: Disconnect all clients gracefully
    For each client in server["clients"]:
        disconnect_client with server as server and client as client
    
    Set server["clients"] to list containing
    Set server["current_connections"] to 0
    
    Return true

Process called "stream_audio_to_clients" that takes server as StreamingServer and audio_buffer as AudioBuffer returns Integer:
    If not server["is_running"]:
        Return 0
    
    Let clients_streamed be 0
    
    For each client in server["clients"]:
        If client["is_connected"]:
            Let success be send_audio_to_client with server as server and client as client and buffer as audio_buffer
            If success:
                Set clients_streamed to clients_streamed plus 1
    
    Return clients_streamed

Process called "send_audio_to_client" that takes server as StreamingServer and client as StreamingClient and buffer as AudioBuffer returns Boolean:
    Match server["protocol"]:
        When RTP:
            Return send_rtp_packet with client as client and buffer as buffer
        When UDP_CUSTOM:
            Return send_udp_packet with client as client and buffer as buffer
        When HLS:
            Return add_to_hls_segment with client as client and buffer as buffer
        Otherwise:
            Return send_generic_packet with client as client and buffer as buffer

Note: RTP Streaming Implementation
Process called "start_rtp_server" that takes server as StreamingServer returns Boolean:
    Note: Initialize RTP server socket and start listening
    Return bind_udp_socket with port as server["port"]

Process called "send_rtp_packet" that takes client as StreamingClient and buffer as AudioBuffer returns Boolean:
    Note: Create RTP header
    Let packet be create_rtp_packet with buffer as buffer and sequence as get_next_sequence_number with client as client
    
    Note: Send packet to client
    Let success be send_udp_packet with ip as client["ip_address"] and data as packet
    
    If success:
        Set client["bytes_sent"] to client["bytes_sent"] plus length of packet["payload"]
    
    Return success

Process called "create_rtp_packet" that takes buffer as AudioBuffer and sequence as Integer returns NetworkPacket:
    Note: Convert audio buffer to payload bytes
    Let payload be list containing
    For each sample in buffer["samples"]:
        Let sample_bytes be float_to_bytes with value as sample
        For each byte in sample_bytes:
            Add byte to payload
    
    Return NetworkPacket with:
        sequence_number as sequence
        timestamp as integer from get_current_time_ms
        payload as payload
        payload_type as 97  Note: Dynamic payload type for audio
        marker as false
        ssrc as 12345      Note: Synchronization source identifier

Process called "get_next_sequence_number" that takes client as StreamingClient returns Integer:
    Note: This would be stored per client and incremented
    Return 1

Note: HLS (HTTP Live Streaming) Implementation
Process called "start_hls_server" that takes server as StreamingServer returns Boolean:
    Note: Initialize HLS server with HTTP endpoint
    Return start_http_server with port as server["port"]

Process called "add_to_hls_segment" that takes client as StreamingClient and buffer as AudioBuffer returns Boolean:
    Note: Add audio data to current HLS segment
    Note: This would accumulate audio data and create TS segments periodically
    Return true

Note: Audio Processing Callbacks
Process called "create_passthrough_callback" returns Process:
    Return Process called "passthrough_callback" that takes input_buffer as AudioBuffer and output_buffer as AudioBuffer and frames as Integer returns Integer:
        Note: Simple passthrough - copy input to output
        If input_buffer is not None and output_buffer is not None:
            For i from 0 to frames minus 1:
                For ch from 0 to minimum of input_buffer["channels"] and output_buffer["channels"] minus 1:
                    Let sample_index be i times input_buffer["channels"] plus ch
                    Let output_index be i times output_buffer["channels"] plus ch
                    Set output_buffer["samples"] at index output_index to input_buffer["samples"] at index sample_index
        
        Return frames

Process called "create_recording_callback" that takes file_path as String returns Process:
    Let recording_buffer be list containing
    
    Return Process called "recording_callback" that takes input_buffer as AudioBuffer and output_buffer as AudioBuffer and frames as Integer returns Integer:
        Note: Record input to buffer and optionally pass through to output
        If input_buffer is not None:
            For each sample in input_buffer["samples"]:
                Add sample to recording_buffer
        
        Note: Periodically write to file (simplified)
        If length of recording_buffer is greater than 44100:
            write_audio_samples_to_file with path as file_path and samples as recording_buffer
            Set recording_buffer to list containing
        
        Note: Pass through to output if needed
        If input_buffer is not None and output_buffer is not None:
            For i from 0 to frames minus 1:
                For ch from 0 to minimum of input_buffer["channels"] and output_buffer["channels"] minus 1:
                    Let sample_index be i times input_buffer["channels"] plus ch
                    Let output_index be i times output_buffer["channels"] plus ch
                    Set output_buffer["samples"] at index output_index to input_buffer["samples"] at index sample_index
        
        Return frames

Process called "create_effects_callback" that takes effects_chain as EffectChain returns Process:
    Return Process called "effects_callback" that takes input_buffer as AudioBuffer and output_buffer as AudioBuffer and frames as Integer returns Integer:
        Note: Apply effects chain to audio
        If input_buffer is not None and output_buffer is not None:
            Let processed_result be process_effect_chain with chain as effects_chain and buffer as input_buffer
            
            Match processed_result:
                When ProcessingSuccess with buffer as processed_buffer:
                    For i from 0 to frames minus 1:
                        For ch from 0 to minimum of processed_buffer["channels"] and output_buffer["channels"] minus 1:
                            Let sample_index be i times processed_buffer["channels"] plus ch
                            Let output_index be i times output_buffer["channels"] plus ch
                            Set output_buffer["samples"] at index output_index to processed_buffer["samples"] at index sample_index
                
                When ProcessingError:
                    Note: Fall back to passthrough on error
                    For i from 0 to frames minus 1:
                        For ch from 0 to minimum of input_buffer["channels"] and output_buffer["channels"] minus 1:
                            Let sample_index be i times input_buffer["channels"] plus ch
                            Let output_index be i times output_buffer["channels"] plus ch
                            Set output_buffer["samples"] at index output_index to input_buffer["samples"] at index sample_index
        
        Return frames

Note: Stream Statistics and Monitoring
Process called "get_stream_statistics" that takes stream as AudioStream returns Dictionary[String, Float]:
    Let stats be dictionary containing
    
    Set stats["stream_time"] to stream["stream_time"]
    Set stats["frames_processed"] to stream["frames_processed"]
    Set stats["underrun_count"] to stream["underrun_count"]
    Set stats["overrun_count"] to stream["overrun_count"]
    
    Let current_time be get_current_time_seconds
    Let elapsed_time be current_time minus stream["stream_time"]
    
    If elapsed_time is greater than 0.0:
        Set stats["average_fps"] to stream["frames_processed"] divided by elapsed_time
        Set stats["cpu_load"] to calculate_cpu_load with stream as stream
    Otherwise:
        Set stats["average_fps"] to 0.0
        Set stats["cpu_load"] to 0.0
    
    Set stats["input_latency"] to stream["device"]["input_latency"]
    Set stats["output_latency"] to stream["device"]["output_latency"]
    
    Return stats

Process called "calculate_cpu_load" that takes stream as AudioStream returns Float:
    Note: Calculate CPU load as percentage of real-time
    Let expected_callback_time be stream["buffer_size"] divided by stream["sample_rate"]
    Let actual_callback_time be measure_callback_time with stream as stream
    
    If expected_callback_time is greater than 0.0:
        Return (actual_callback_time divided by expected_callback_time) times 100.0
    Otherwise:
        Return 0.0

Process called "measure_callback_time" that takes stream as AudioStream returns Float:
    Note: This would measure actual callback execution time
    Return 0.001  Note: Mock 1ms callback time

Note: Advanced Streaming Features
Process called "create_adaptive_stream" that takes base_stream as AudioStream and target_latency_ms as Float returns AudioStream:
    Note: Create adaptive stream that adjusts buffer sizes based on network conditions
    Let adaptive_stream be base_stream
    Set adaptive_stream["user_data"] to create_buffer_manager with channels as base_stream["channels"] and sample_rate as base_stream["sample_rate"] and target_latency_ms as target_latency_ms
    
    Return adaptive_stream

Process called "update_adaptive_parameters" that takes stream as AudioStream and network_jitter_ms as Float and packet_loss_rate as Float returns AudioStream:
    If stream["user_data"] is not None:
        Let buffer_manager be stream["user_data"]
        
        Note: Adjust target latency based on network conditions
        Let base_latency be buffer_manager["target_latency_ms"]
        Let jitter_compensation be network_jitter_ms times 2.0
        Let loss_compensation be packet_loss_rate times 100.0
        
        Let new_target_latency be base_latency plus jitter_compensation plus loss_compensation
        Set buffer_manager["target_latency_ms"] to minimum of new_target_latency and 500.0  Note: Cap at 500ms
    
    Return stream

Process called "enable_echo_cancellation" that takes stream as AudioStream and echo_tail_ms as Float returns AudioStream:
    Note: Enable acoustic echo cancellation
    Note: This would integrate with the effects chain
    Return stream

Process called "enable_noise_suppression" that takes stream as AudioStream and aggressiveness as Float returns AudioStream:
    Note: Enable noise suppression
    Note: This would integrate with the effects chain
    Return stream

Note: Multi-cast and Broadcast Streaming
Process called "create_multicast_sender" that takes multicast_address as String and port as Integer and sample_rate as Integer and channels as Integer returns StreamingServer:
    Let server be create_streaming_server with protocol as UDP_CUSTOM and port as port and sample_rate as sample_rate and channels as channels and bit_rate as 128000
    
    Note: Configure for multicast
    Set server["metadata"]["multicast_address"] to multicast_address
    Set server["metadata"]["stream_type"] to "multicast"
    
    Return server

Process called "join_multicast_stream" that takes multicast_address as String and port as Integer returns StreamingClient:
    Return StreamingClient with:
        id as "multicast_receiver"
        ip_address as multicast_address
        connection_time as get_current_time_seconds
        bytes_sent as 0
        is_connected as true
        buffer_health as 1.0
        latency_ms as 50.0

Note: Utility Functions
Process called "get_current_time_seconds" returns Float:
    Note: Get current time in seconds - would be implemented by runtime
    Return 0.0

Process called "get_current_time_ms" returns Float:
    Note: Get current time in milliseconds with high precision
    Try:
        Return system_call_get_current_timestamp_milliseconds as Float
    
    Catch error:
        Note: Fallback to system clock if high-precision call fails
        Let seconds be system_call_get_current_timestamp_seconds
        Return seconds times 1000.0

Process called "minimum" that takes a as Integer and b as Integer returns Integer:
    If a is less than b:
        Return a
    Otherwise:
        Return b

Process called "minimum" that takes a as Float and b as Float returns Float:
    If a is less than b:
        Return a
    Otherwise:
        Return b

Process called "integer" that takes value as Float returns Integer:
    Note: Convert float to integer with proper truncation
    Try:
        Return system_call_float_to_integer with value as value and mode as "truncate"
    
    Catch error:
        Note: Manual truncation if system call fails
        If value is greater than or equal to 0.0:
            Return integer_part_of_positive with value as value
        Otherwise:
            Return negative integer_part_of_positive with value as negative value

Process called "float_to_bytes" that takes value as Float returns List[Integer]:
    Note: Convert float to byte array (IEEE 754 32-bit format)
    Try:
        Return system_call_float_to_ieee754_bytes with value as value and precision as 32
    
    Catch error:
        Note: Manual IEEE 754 conversion if system call fails
        Let sign_bit be 0
        Let working_value be value
        
        If working_value is less than 0.0:
            Set sign_bit to 1
            Set working_value to negative working_value
        
        Note: Handle special cases
        If working_value is equal to 0.0:
            Return list containing 0, 0, 0, 0
        
        Note: Extract exponent and mantissa (simplified)
        Let exponent be 127  Note: Bias for normal numbers
        Let mantissa_bits be integer from (working_value times 8388608.0) modulo 8388608  Note: 23-bit mantissa
        
        Note: Pack into 4 bytes (sign + exponent + mantissa)
        Let byte0 be (sign_bit times 128) plus (exponent divided by 2)
        Let byte1 be (exponent modulo 2 times 128) plus (mantissa_bits divided by 65536)
        Let byte2 be (mantissa_bits modulo 65536) divided by 256
        Let byte3 be mantissa_bits modulo 256
        
        Return list containing byte0, byte1, byte2, byte3

Process called "integer_part_of_positive" that takes value as Float returns Integer:
    Note: Extract integer part of positive float value
    Let result be 0
    Let temp_value be value
    
    While temp_value is greater than or equal to 1.0:
        Set result to result plus 1
        Set temp_value to temp_value minus 1.0
    
    Return result

