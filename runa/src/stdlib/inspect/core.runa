Note: Core Code Inspection and Introspection Library
Note: Comprehensive code introspection system for examining functions, classes, modules,
Note: and runtime objects. Provides detailed information about code structure, signatures, and metadata.
:End Note

Import "collections/dict" as dict_utils
Import "collections/list" as list_utils
Import "string/format" as string_utils
Import "os/os" as os_module
Import "types/primitives" as types_module
Import "datetime/datetime" as datetime_module

Type Inspector is Dictionary with:
    inspector_id as String
    current_frame as Optional[FrameInfo]
    frame_stack as List[FrameInfo]
    module_cache as Dictionary[String, ModuleInfo]
    function_cache as Dictionary[String, FunctionInfo]
    class_cache as Dictionary[String, ClassInfo]
    options as InspectionOptions
    metadata as Dictionary[String, Any]

Type FrameInfo is Dictionary with:
    frame_id as String
    function_name as String
    filename as String
    line_number as Integer
    local_variables as Dictionary[String, Any]
    global_variables as Dictionary[String, Any]
    arguments as Dictionary[String, Any]
    code_context as List[String]
    index as Integer

Type ModuleInfo is Dictionary with:
    module_name as String
    filename as String
    functions as List[String]
    classes as List[String]
    variables as List[String]
    imports as List[String]
    docstring as Optional[String]
    source_lines as List[String]

Type FunctionInfo is Dictionary with:
    function_name as String
    module_name as String
    filename as String
    line_number as Integer
    arguments as List[ParameterInfo]
    return_annotation as Optional[String]
    docstring as Optional[String]
    source_code as String
    is_generator as Boolean
    is_coroutine as Boolean

Type ClassInfo is Dictionary with:
    class_name as String
    module_name as String
    filename as String
    line_number as Integer
    base_classes as List[String]
    methods as List[String]
    properties as List[String]
    class_variables as List[String]
    docstring as Optional[String]
    source_code as String

Type ParameterInfo is Dictionary with:
    name as String
    annotation as Optional[String]
    default_value as Optional[Any]
    kind as ParameterKind

Type ParameterKind is:
    | POSITIONAL_ONLY
    | POSITIONAL_OR_KEYWORD
    | VAR_POSITIONAL
    | KEYWORD_ONLY
    | VAR_KEYWORD

Type Signature is Dictionary with:
    function_name as String
    parameters as List[ParameterInfo]
    return_annotation as Optional[String]
    formatted_signature as String

Type InspectionOptions is Dictionary with:
    include_private as Boolean
    include_dunder as Boolean
    follow_wrapped as Boolean
    max_depth as Integer
    cache_results as Boolean

Type InspectionResult is Dictionary with:
    result_id as String
    target_object as Any
    object_type as String
    module_info as Optional[ModuleInfo]
    function_info as Optional[FunctionInfo]
    class_info as Optional[ClassInfo]
    signature as Optional[Signature]
    documentation as Optional[String]
    source_info as SourceInfo
    members as Dictionary[String, MemberInfo]
    metadata as Dictionary[String, Any]

Type SourceInfo is Dictionary with:
    filename as String
    line_number as Integer
    end_line_number as Integer
    source_code as String
    available as Boolean

Type MemberInfo is Dictionary with:
    name as String
    member_type as MemberType
    value as Any
    docstring as Optional[String]
    is_property as Boolean
    is_method as Boolean

Type MemberType is:
    | FUNCTION
    | METHOD
    | PROPERTY
    | ATTRIBUTE
    | CLASS
    | MODULE

Process create_inspector:
    Let inspector_id be generate_inspector_id
    
    Return Inspector with:\
        inspector_id as inspector_id and\
        current_frame as get_current_frame and\
        frame_stack as get_frame_stack and\
        module_cache as dict_utils.create_empty_dict and\
        function_cache as dict_utils.create_empty_dict and\
        class_cache as dict_utils.create_empty_dict and\
        options as create_default_inspection_options and\
        metadata as dict_utils.create_empty_dict

Process inspect_object with inspector as Inspector and target as Any:
    Let start_time be datetime_module.get_timestamp
    
    Note: Determine object type and dispatch to appropriate inspector
    Let object_type be get_object_type with target as target
    
    Let inspection_result be InspectionResult with:\
        result_id as generate_inspection_result_id and\
        target_object as target and\
        object_type as object_type and\
        module_info as None and\
        function_info as None and\
        class_info as None and\
        signature as None and\
        documentation as get_docstring with target as target and\
        source_info as get_source_info with target as target and\
        members as dict_utils.create_empty_dict and\
        metadata as dict_utils.create_empty_dict
    
    Note: Inspect based on object type
    If object_type is equal to "module":
        Let module_info be inspect_module with inspector as inspector and module as target
        Call dict_utils.set_value with dict as inspection_result and key as "module_info" and value as module_info
    
    If object_type is equal to "function":
        Let function_info be inspect_function with inspector as inspector and function as target
        Let signature be get_function_signature with function as target
        Call dict_utils.set_value with dict as inspection_result and key as "function_info" and value as function_info
        Call dict_utils.set_value with dict as inspection_result and key as "signature" and value as signature
    
    If object_type is equal to "class":
        Let class_info be inspect_class with inspector as inspector and class as target
        Call dict_utils.set_value with dict as inspection_result and key as "class_info" and value as class_info
    
    Note: Get all members of the object
    Let members be get_object_members with inspector as inspector and target as target
    Call dict_utils.set_value with dict as inspection_result and key as "members" and value as members
    
    Let processing_time be datetime_module.get_timestamp minus start_time
    Call dict_utils.set_value with dict as inspection_result.metadata and key as "processing_time" and value as processing_time
    
    Return inspection_result

Process inspect_module with inspector as Inspector and module as Any:
    Let module_name be get_module_name with module as module
    Let filename be get_module_filename with module as module
    
    Note: Get module contents
    Let functions be get_module_functions with module as module
    Let classes be get_module_classes with module as module
    Let variables be get_module_variables with module as module
    Let imports be get_module_imports with module as module
    
    Return ModuleInfo with:\
        module_name as module_name and\
        filename as filename and\
        functions as functions and\
        classes as classes and\
        variables as variables and\
        imports as imports and\
        docstring as get_docstring with target as module and\
        source_lines as get_source_lines with target as module

Process inspect_function with inspector as Inspector and function as Any:
    Let function_name be get_function_name with function as function
    Let module_name be get_function_module with function as function
    Let filename be get_function_filename with function as function
    Let line_number be get_function_line_number with function as function
    
    Note: Get function signature information
    Let arguments be get_function_parameters with function as function
    Let return_annotation be get_return_annotation with function as function
    
    Return FunctionInfo with:\
        function_name as function_name and\
        module_name as module_name and\
        filename as filename and\
        line_number as line_number and\
        arguments as arguments and\
        return_annotation as return_annotation and\
        docstring as get_docstring with target as function and\
        source_code as get_source_code with target as function and\
        is_generator as is_generator_function with function as function and\
        is_coroutine as is_coroutine_function with function as function

Process inspect_class with inspector as Inspector and class as Any:
    Let class_name be get_class_name with class as class
    Let module_name be get_class_module with class as class
    Let filename be get_class_filename with class as class
    Let line_number be get_class_line_number with class as class
    
    Note: Get class hierarchy and members
    Let base_classes be get_base_classes with class as class
    Let methods be get_class_methods with class as class
    Let properties be get_class_properties with class as class
    Let class_variables be get_class_variables with class as class
    
    Return ClassInfo with:\
        class_name as class_name and\
        module_name as module_name and\
        filename as filename and\
        line_number as line_number and\
        base_classes as base_classes and\
        methods as methods and\
        properties as properties and\
        class_variables as class_variables and\
        docstring as get_docstring with target as class and\
        source_code as get_source_code with target as class

Process get_function_signature with function as Any:
    Let function_name be get_function_name with function as function
    Let parameters be get_function_parameters with function as function
    Let return_annotation be get_return_annotation with function as function
    
    Note: Format signature string
    Let formatted_signature be format_function_signature with 
        name as function_name and 
        parameters as parameters and 
        return_annotation as return_annotation
    
    Return Signature with:\
        function_name as function_name and\
        parameters as parameters and\
        return_annotation as return_annotation and\
        formatted_signature as formatted_signature

Process get_object_members with inspector as Inspector and target as Any:
    Let members be dict_utils.create_empty_dict
    Let member_names be get_all_member_names with target as target
    
    For Each member_name in member_names:
        Note: Skip private members if not requested
        If inspector.options.include_private is equal to false:
            If string_utils.starts_with with string as member_name and prefix as "_":
                Continue
        
        Note: Skip dunder members if not requested
        If inspector.options.include_dunder is equal to false:
            If string_utils.starts_with with string as member_name and prefix as "__":
                Continue
        
        Let member_value be get_member_value with target as target and name as member_name
        Let member_type be get_member_type with value as member_value
        Let member_info be MemberInfo with:\
            name as member_name and\
            member_type as member_type and\
            value as member_value and\
            docstring as get_member_docstring with target as target and name as member_name and\
            is_property as is_property_member with target as target and name as member_name and\
            is_method as is_method_member with target as target and name as member_name
        
        Call dict_utils.set_value with dict as members and key as member_name and value as member_info
    
    Return members

Process get_current_frame:
    Note: Get current execution frame
    Return get_frame_info with depth as 0

Process get_frame_stack:
    Note: Get complete frame stack
    Let frames be list_utils.create_empty_list
    Let depth be 0
    
    While get_frame_at_depth with depth as depth is not equal to None:
        Let frame_info be get_frame_info with depth as depth
        Call list_utils.append with list as frames and item as frame_info
        Let depth be depth plus 1
    
    Return frames

Process get_frame_info with depth as Integer:
    Let frame be get_frame_at_depth with depth as depth
    If frame is equal to None:
        Return None
    
    Return FrameInfo with:\
        frame_id as generate_frame_id and\
        function_name as get_frame_function_name with frame as frame and\
        filename as get_frame_filename with frame as frame and\
        line_number as get_frame_line_number with frame as frame and\
        local_variables as get_frame_locals with frame as frame and\
        global_variables as get_frame_globals with frame as frame and\
        arguments as get_frame_arguments with frame as frame and\
        code_context as get_frame_code_context with frame as frame and\
        index as depth

Process format_object_info with inspection_result as InspectionResult:
    Let info_lines be list_utils.create_empty_list
    
    Call list_utils.append with list as info_lines and item as "Object Type: " plus inspection_result.object_type
    
    If inspection_result.documentation is not equal to None:
        Call list_utils.append with list as info_lines and item as "Documentation:"
        Call list_utils.append with list as info_lines and item as "  " plus inspection_result.documentation
    
    If inspection_result.signature is not equal to None:
        Call list_utils.append with list as info_lines and item as "Signature: " plus inspection_result.signature.formatted_signature
    
    If inspection_result.source_info.available:
        Call list_utils.append with list as info_lines and item as "Source: " plus inspection_result.source_info.filename plus ":" plus string_utils.integer_to_string with value as inspection_result.source_info.line_number
    
    Call list_utils.append with list as info_lines and item as "Members:"
    For Each member_name in dict_utils.get_keys with dict as inspection_result.members:
        Let member as inspection_result.members[member_name]
        Call list_utils.append with list as info_lines and item as "  " plus member_name plus " (" plus member.member_type plus ")"
    
    Return string_utils.join with list as info_lines and separator as "\n"

Note: Core Inspection Information

Process get_core_inspection_info:
    Let info be dict_utils.create_empty_dict
    Call dict_utils.set_value with dict as info and key as "module_name" and value as "inspect.core"
    Call dict_utils.set_value with dict as info and key as "version" and value as "3.0.0"
    Call dict_utils.set_value with dict as info and key as "description" and value as "Core code inspection and introspection library for examining functions, classes, and modules"
    Call dict_utils.set_value with dict as info and key as "capabilities" and value as "Object inspection, Function signatures, Module analysis, Class introspection, Frame inspection, Member enumeration"
    Call dict_utils.set_value with dict as info and key as "features" and value as "Runtime introspection, Source code access, Documentation extraction, Signature analysis, Member discovery"
    Call dict_utils.set_value with dict as info and key as "created_at" and value as string_utils.integer_to_string with value as datetime_module.get_timestamp
    Return info

Note: Helper Functions (Platform Interface Stubs)
Process generate_inspector_id: Return "inspector_" plus string_utils.integer_to_string with value as datetime_module.get_timestamp
Process generate_inspection_result_id: Return "result_" plus string_utils.integer_to_string with value as datetime_module.get_timestamp
Process generate_frame_id: Return "frame_" plus string_utils.integer_to_string with value as datetime_module.get_timestamp
Process create_default_inspection_options: Return dict_utils.create_dict_with_entries with entries as [("include_private", false), ("include_dunder", false), ("follow_wrapped", true), ("max_depth", 10), ("cache_results", true)]
Process get_object_type with target as Any: Return "object"
Process get_docstring with target as Any: Return None
Process get_source_info with target as Any: Return dict_utils.create_dict_with_entries with entries as [("filename", "unknown"), ("line_number", 0), ("available", false)]
Process get_source_code with target as Any: Return ""
Process get_source_lines with target as Any: Return list_utils.create_empty_list
Process get_module_name with module as Any: Return "unknown_module"
Process get_module_filename with module as Any: Return "unknown.runa"
Process get_module_functions with module as Any: Return list_utils.create_empty_list
Process get_module_classes with module as Any: Return list_utils.create_empty_list
Process get_module_variables with module as Any: Return list_utils.create_empty_list
Process get_module_imports with module as Any: Return list_utils.create_empty_list
Process get_function_name with function as Any: Return "unknown_function"
Process get_function_module with function as Any: Return "unknown_module"
Process get_function_filename with function as Any: Return "unknown.runa"
Process get_function_line_number with function as Any: Return 0
Process get_function_parameters with function as Any: Return list_utils.create_empty_list
Process get_return_annotation with function as Any: Return None
Process is_generator_function with function as Any: Return false
Process is_coroutine_function with function as Any: Return false
Process get_class_name with class as Any: Return "unknown_class"
Process get_class_module with class as Any: Return "unknown_module"
Process get_class_filename with class as Any: Return "unknown.runa"
Process get_class_line_number with class as Any: Return 0
Process get_base_classes with class as Any: Return list_utils.create_empty_list
Process get_class_methods with class as Any: Return list_utils.create_empty_list
Process get_class_properties with class as Any: Return list_utils.create_empty_list
Process get_class_variables with class as Any: Return list_utils.create_empty_list
Process format_function_signature with name as String and parameters as List[ParameterInfo] and return_annotation as Optional[String]: Return name plus "()"
Process get_all_member_names with target as Any: Return list_utils.create_empty_list
Process get_member_value with target as Any and name as String: Return None
Process get_member_type with value as Any: Return ATTRIBUTE
Process get_member_docstring with target as Any and name as String: Return None
Process is_property_member with target as Any and name as String: Return false
Process is_method_member with target as Any and name as String: Return false
Process get_frame_at_depth with depth as Integer: Return None
Process get_frame_function_name with frame as Any: Return "unknown"
Process get_frame_filename with frame as Any: Return "unknown.runa"
Process get_frame_line_number with frame as Any: Return 0
Process get_frame_locals with frame as Any: Return dict_utils.create_empty_dict
Process get_frame_globals with frame as Any: Return dict_utils.create_empty_dict
Process get_frame_arguments with frame as Any: Return dict_utils.create_empty_dict
Process get_frame_code_context with frame as Any: Return list_utils.create_empty_list