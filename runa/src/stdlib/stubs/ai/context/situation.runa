Type SituationContext is Dictionary with:
    context_id as String
    spatial_context as SpatialContext
    temporal_context as TemporalContext
    environmental_context as EnvironmentalContext
    social_context as SocialContext
    operational_context as OperationalContext
    strategic_context as StrategicContext
    context_relationships as List[ContextRelationship]

Type ThreatAssessment is Dictionary with:
    assessment_id as String
    threat_identification as ThreatIdentification
    threat_analysis as ThreatAnalysis
    threat_impact as ThreatImpact
    threat_probability as Float
    threat_severity as String
    threat_urgency as String
    mitigation_options as List[MitigationOption]

Type OpportunityAssessment is Dictionary with:
    assessment_id as String
    opportunity_identification as OpportunityIdentification
    opportunity_analysis as OpportunityAnalysis
    opportunity_potential as OpportunityPotential
    opportunity_feasibility as Float
    opportunity_value as String
    opportunity_timing as String
    exploitation_options as List[ExploitationOption]

Type DecisionSupport is Dictionary with:
    support_id as String
    decision_context as DecisionContext
    decision_options as List[DecisionOption]
    recommendation_engine as RecommendationEngine
    decision_criteria as List[DecisionCriterion]
    decision_analysis as DecisionAnalysis
    decision_tracking as DecisionTracking
    support_quality as SupportQuality

