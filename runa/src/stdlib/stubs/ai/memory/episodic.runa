Process called "get_latest_event_time" that takes events as List[EpisodicEvent] returns Float
Process called "generate_memory_summary" that takes events as List[EpisodicEvent] returns String
Process called "extract_memory_themes" that takes events as List[EpisodicEvent] returns List[String]
Process called "construct_emotional_arc" that takes events as List[EpisodicEvent] returns List[Dictionary]
Process called "calculate_memory_importance" that takes memory as EpisodicMemory returns Float
Process called "discover_memory_insights" that takes memory as EpisodicMemory returns List[String]
Process called "find_related_memories" that takes memory as EpisodicMemory returns List[String]
Process called "insert_memory_chronologically" that takes ordered_list as List[String] and memory as EpisodicMemory returns List[String]
Process called "get_timeline_memories" that takes timeline as MemoryTimeline returns List[EpisodicMemory]
Process called "create_new_cluster" that takes memory as EpisodicMemory returns Dictionary
Process called "group_memories_by_theme" that takes memories as List[EpisodicMemory] returns Dictionary
Process called "construct_narrative_arc" that takes memories as List[EpisodicMemory] returns List[Dictionary]
Process called "calculate_thread_strength" that takes memories as List[EpisodicMemory] returns Float
