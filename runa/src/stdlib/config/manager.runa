Note: Central Configuration Management System for Runa Standard Library
Note: This module provides a comprehensive configuration system that supports:
Note: - Runtime configuration changes
Note: - Environment-specific overrides
Note: - Configuration validation
Note: - Default value management
Note: - Thread-safe access
Note: - Configuration persistence
Note: - Configuration event notification

Import "collections" as Collections
Import "os" as OS

Note: Core Configuration Types

Type called "ConfigurationManager":
    configurations as Dictionary[String, ConfigurationSection]
    environment_overrides as Dictionary[String, Dictionary[String, Any]]
    validation_rules as Dictionary[String, ValidationRule]
    change_listeners as List[ConfigurationListener]
    config_lock as MutexGuard
    auto_persist as Boolean
    config_file_path as String
    metadata as Dictionary[String, Any]

Type called "ConfigurationSection":
    section_name as String
    values as Dictionary[String, ConfigValue]
    defaults as Dictionary[String, Any]
    description as String
    is_runtime_modifiable as Boolean
    requires_restart as Boolean
    metadata as Dictionary[String, Any]

Type called "ConfigValue":
    key as String
    value as Any
    default_value as Any
    value_type as ConfigValueType
    description as String
    is_runtime_modifiable as Boolean
    validation_rule as Optional[ValidationRule]
    environment_override as Optional[String]
    last_modified as Float
    metadata as Dictionary[String, Any]

Type ConfigValueType is:
    | StringType
    | IntegerType with min as Optional[Integer] and max as Optional[Integer]
    | FloatType with min as Optional[Float] and max as Optional[Float]
    | BooleanType
    | ListType with element_type as ConfigValueType
    | DictionaryType with key_type as ConfigValueType and value_type as ConfigValueType
    | EnumType with allowed_values as List[Any]

Type called "ValidationRule":
    rule_name as String
    validator as Process that takes value as Any returns ValidationResult
    error_message as String
    metadata as Dictionary[String, Any]

Type ValidationResult is:
    | Valid
    | Invalid with reason as String

Type called "ConfigurationListener":
    listener_id as String
    on_change as Process that takes section as String and key as String and old_value as Any and new_value as Any returns Unit
    sections_of_interest as List[String]
    metadata as Dictionary[String, Any]

Type ConfigurationError is:
    | SectionNotFound with section as String
    | KeyNotFound with section as String and key as String
    | ValidationFailed with section as String and key as String and reason as String
    | TypeMismatch with section as String and key as String and expected_type as String and actual_type as String
    | ReadOnlyValue with section as String and key as String
    | EnvironmentOverrideConflict with section as String and key as String and env_var as String

Note: Global Configuration Manager Instance
Let GLOBAL_CONFIG_MANAGER be create_configuration_manager

Process called "create_configuration_manager" returns ConfigurationManager:
    Let config_path be OS.get_env_var_or_default with key as "RUNA_CONFIG_PATH" and default as "runa.config"
    
    Return ConfigurationManager with:
        configurations as empty dictionary
        environment_overrides as load_environment_overrides
        validation_rules as empty dictionary
        change_listeners as empty list
        config_lock as create_mutex_guard
        auto_persist as true
        config_file_path as config_path
        metadata as dictionary containing
            "created_at" as get_current_time
            "version" as "1.0.0"

Process called "load_environment_overrides" returns Dictionary[String, Dictionary[String, Any]]:
    Let overrides be empty dictionary
    Let env_vars be OS.get_all_env_vars
    
    For each env_var in env_vars:
        If env_var.key starts_with "RUNA_CONFIG_":
            Let parts be env_var.key split by "_"
            If parts.length >= 3:
                Let section be parts get 2
                Let key be join remaining parts starting from 3 with "_"
                Let value be parse_environment_value with env_var.value
                
                If overrides does_not_contain section:
                    Set overrides at section to empty dictionary
                
                Set overrides at section at key to value
    
    Return overrides

Process called "parse_environment_value" that takes raw_value as String returns Any:
    Note: Try to parse as different types
    If raw_value equals "true":
        Return true
    Else if raw_value equals "false":
        Return false
    Else if raw_value matches integer pattern:
        Return parse_integer with raw_value
    Else if raw_value matches float pattern:
        Return parse_float with raw_value
    Else if raw_value starts_with "[" and ends_with "]":
        Return parse_list_from_string with raw_value
    Else:
        Return raw_value

Process called "register_section" that takes manager as ConfigurationManager and section_name as String and section as ConfigurationSection returns Result[Unit, ConfigurationError]:
    Lock manager.config_lock:
        Set manager.configurations at section_name to section
        
        Note: Apply environment overrides if they exist
        If manager.environment_overrides contains section_name:
            Let overrides be manager.environment_overrides get section_name
            For each override in overrides:
                Let result be set_config_value with manager and section_name and override.key and override.value and from_environment as true
                If result is Invalid with reason:
                    Return Invalid with EnvironmentOverrideConflict with section as section_name and key as override.key and env_var as ("RUNA_CONFIG_" + section_name + "_" + override.key)
        
        Return Valid with unit

Process called "get_config_value" that takes manager as ConfigurationManager and section as String and key as String returns Result[Any, ConfigurationError]:
    Lock manager.config_lock:
        If manager.configurations does_not_contain section:
            Return Invalid with SectionNotFound with section as section
        
        Let config_section be manager.configurations get section
        If config_section.values does_not_contain key:
            Return Invalid with KeyNotFound with section as section and key as key
        
        Let config_value be config_section.values get key
        Return Valid with config_value.value

Process called "set_config_value" that takes manager as ConfigurationManager and section as String and key as String and new_value as Any and from_environment as Boolean defaults to false returns Result[Unit, ConfigurationError]:
    Lock manager.config_lock:
        If manager.configurations does_not_contain section:
            Return Invalid with SectionNotFound with section as section
        
        Let config_section be manager.configurations get section
        If config_section.values does_not_contain key:
            Return Invalid with KeyNotFound with section as section and key as key
        
        Let config_value be config_section.values get key
        
        Note: Check if value is runtime modifiable
        If not from_environment and not config_value.is_runtime_modifiable:
            Return Invalid with ReadOnlyValue with section as section and key as key
        
        Note: Validate the new value
        If config_value.validation_rule is Some with rule:
            Let validation_result be rule.validator with new_value
            If validation_result is Invalid with reason:
                Return Invalid with ValidationFailed with section as section and key as key and reason as reason
        
        Note: Type check the new value
        Let type_check_result be validate_type with new_value and config_value.value_type
        If type_check_result is Invalid with reason:
            Return Invalid with TypeMismatch with section as section and key as key and expected_type as format_type with config_value.value_type and actual_type as get_type_name with new_value
        
        Let old_value be config_value.value
        
        Note: Update the value
        Set config_value.value to new_value
        Set config_value.last_modified to get_current_time
        
        Note: Notify listeners
        For each listener in manager.change_listeners:
            If listener.sections_of_interest is_empty or listener.sections_of_interest contains section:
                Call listener.on_change with section and key and old_value and new_value
        
        Note: Auto-persist if enabled
        If manager.auto_persist:
            Let persist_result be persist_configuration with manager
            Note: Continue even if persistence fails, but log the error
        
        Return Valid with unit

Process called "validate_type" that takes value as Any and expected_type as ConfigValueType returns ValidationResult:
    Match expected_type:
        Case StringType:
            If value is String:
                Return Valid
            Else:
                Return Invalid with reason as "Expected String type"
        
        Case IntegerType with min and max:
            If value is Integer:
                If min is Some with min_val and value < min_val:
                    Return Invalid with reason as ("Value " + to_string with value + " is below minimum " + to_string with min_val)
                If max is Some with max_val and value > max_val:
                    Return Invalid with reason as ("Value " + to_string with value + " is above maximum " + to_string with max_val)
                Return Valid
            Else:
                Return Invalid with reason as "Expected Integer type"
        
        Case FloatType with min and max:
            If value is Float:
                If min is Some with min_val and value < min_val:
                    Return Invalid with reason as ("Value " + to_string with value + " is below minimum " + to_string with min_val)
                If max is Some with max_val and value > max_val:
                    Return Invalid with reason as ("Value " + to_string with value + " is above maximum " + to_string with max_val)
                Return Valid
            Else:
                Return Invalid with reason as "Expected Float type"
        
        Case BooleanType:
            If value is Boolean:
                Return Valid
            Else:
                Return Invalid with reason as "Expected Boolean type"
        
        Case ListType with element_type:
            If value is List:
                For each element in value:
                    Let element_validation be validate_type with element and element_type
                    If element_validation is Invalid with reason:
                        Return Invalid with reason as ("List element validation failed: " + reason)
                Return Valid
            Else:
                Return Invalid with reason as "Expected List type"
        
        Case EnumType with allowed_values:
            If allowed_values contains value:
                Return Valid
            Else:
                Return Invalid with reason as ("Value must be one of: " + join allowed_values with ", ")

Process called "register_validation_rule" that takes manager as ConfigurationManager and section as String and key as String and rule as ValidationRule returns Unit:
    Let rule_key be section + "." + key
    Set manager.validation_rules at rule_key to rule

Process called "add_configuration_listener" that takes manager as ConfigurationManager and listener as ConfigurationListener returns Unit:
    Add listener to manager.change_listeners

Process called "remove_configuration_listener" that takes manager as ConfigurationManager and listener_id as String returns Unit:
    Filter manager.change_listeners to keep only listeners where listener.listener_id != listener_id

Process called "persist_configuration" that takes manager as ConfigurationManager returns Result[Unit, String]:
    Note: Serialize configuration to file
    Let config_data be serialize_configuration with manager
    Let write_result be write_file with manager.config_file_path and config_data
    
    If write_result is Success:
        Return Valid with unit
    Else:
        Return Invalid with "Failed to persist configuration"

Process called "load_configuration_from_file" that takes manager as ConfigurationManager returns Result[Unit, String]:
    Note: Load configuration from file if it exists
    If file_exists with manager.config_file_path:
        Let read_result be read_file with manager.config_file_path
        If read_result is Success with content:
            Let parse_result be parse_configuration with content
            If parse_result is Success with config_data:
                Let apply_result be apply_configuration_data with manager and config_data
                Return apply_result
            Else:
                Return Invalid with "Failed to parse configuration file"
        Else:
            Return Invalid with "Failed to read configuration file"
    Else:
        Return Valid with unit

Process called "serialize_configuration" that takes manager as ConfigurationManager returns String:
    Note: Simple JSON-like serialization for now
    Let result be "{\n"
    
    For each section in manager.configurations:
        Set result to result + "  \"" + section.key + "\": {\n"
        
        For each value in section.value.values:
            Set result to result + "    \"" + value.key + "\": " + serialize_value with value.value.value + ",\n"
        
        Set result to result + "  },\n"
    
    Set result to result + "}"
    Return result

Process called "serialize_value" that takes value as Any returns String:
    If value is String:
        Return "\"" + value + "\""
    Else if value is Boolean or value is Integer or value is Float:
        Return to_string with value
    Else if value is List:
        Let items be map value with serialize_value
        Return "[" + join items with ", " + "]"
    Else:
        Return "\"" + to_string with value + "\""

Note: Helper processes for common operations

Process called "get_current_time" returns Float:
    Note: This would integrate with the system time
    Return 0.0

Process called "create_mutex_guard" returns MutexGuard:
    Note: This would create an actual mutex in a real implementation
    Return empty_mutex_guard

Process called "file_exists" that takes path as String returns Boolean:
    Note: This would check if file exists
    Return false

Process called "read_file" that takes path as String returns Result[String, String]:
    Note: This would read file content
    Return Invalid with "Not implemented"

Process called "write_file" that takes path as String and content as String returns Result[Unit, String]:
    Note: This would write file content
    Return Invalid with "Not implemented"

Process called "parse_integer" that takes value as String returns Integer:
    Note: This would parse string to integer
    Return 0

Process called "parse_float" that takes value as String returns Float:
    Note: This would parse string to float
    Return 0.0

Process called "parse_list_from_string" that takes value as String returns List[Any]:
    Note: This would parse a list from string representation
    Return empty list

Process called "get_type_name" that takes value as Any returns String:
    Note: This would return the runtime type name
    Return "Any"

Process called "format_type" that takes config_type as ConfigValueType returns String:
    Match config_type:
        Case StringType:
            Return "String"
        Case IntegerType with min and max:
            Return "Integer"
        Case FloatType with min and max:
            Return "Float"
        Case BooleanType:
            Return "Boolean"
        Case ListType with element_type:
            Return "List[" + format_type with element_type + "]"
        Case DictionaryType with key_type and value_type:
            Return "Dictionary[" + format_type with key_type + ", " + format_type with value_type + "]"
        Case EnumType with allowed_values:
            Return "Enum"

Type called "MutexGuard":
    Note: Placeholder for actual mutex implementation
    dummy as Boolean defaults to true

Let empty_mutex_guard be MutexGuard with dummy as true

Note: Export the global configuration manager for use by other modules
Export GLOBAL_CONFIG_MANAGER as config_manager