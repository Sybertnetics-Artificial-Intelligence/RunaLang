Note: Caching Configuration Module
Note: This module provides configuration management specifically for caching systems
Note: It uses the central configuration system to manage all cache-related settings

Import "../config/manager" as ConfigManager

Note: Cache Configuration Section Definition

Type called "CacheConfiguration":
    Note: Performance Configuration
    pattern_confidence_threshold as Float
    prediction_confidence_threshold as Float
    prefetch_confidence_threshold as Float
    
    Note: Memory Configuration
    max_memory_bytes as Integer
    memory_pressure_threshold as Float
    emergency_eviction_threshold as Float
    
    Note: Access Frequency Configuration
    min_access_frequency as Float
    priority_score_threshold as Float
    hit_ratio_excellence_threshold as Float
    
    Note: Compression Configuration
    enable_compression as Boolean
    compression_threshold_bytes as Integer
    
    Note: Adaptive Configuration
    enable_adaptive_sizing as Boolean
    enable_predictive_caching as Boolean
    
    Note: Thread Safety Configuration
    enable_thread_safety as Boolean
    lock_timeout_ms as Integer
    max_concurrent_readers as Integer
    
    Note: Analytics Configuration
    track_access_patterns as Boolean
    track_performance_metrics as Boolean
    metrics_aggregation_interval_ms as Integer
    
    Note: Cache Level Configuration
    default_cache_levels as Integer
    l1_cache_size as Integer
    l2_cache_size as Integer
    l3_cache_size as Integer
    
    Note: Eviction Policy Configuration
    default_eviction_policy as String
    ttl_default_seconds as Integer
    lru_aging_factor as Float

Note: Default Cache Configuration Values

Process called "create_default_cache_config" returns CacheConfiguration:
    Return CacheConfiguration with:
        Note: Performance thresholds
        pattern_confidence_threshold as 0.8
        prediction_confidence_threshold as 0.75
        prefetch_confidence_threshold as 0.85
        
        Note: Memory management
        max_memory_bytes as 268435456
        memory_pressure_threshold as 0.8
        emergency_eviction_threshold as 0.95
        
        Note: Access patterns
        min_access_frequency as 0.1
        priority_score_threshold as 0.5
        hit_ratio_excellence_threshold as 0.9
        
        Note: Compression settings
        enable_compression as true
        compression_threshold_bytes as 1024
        
        Note: Adaptive behavior
        enable_adaptive_sizing as true
        enable_predictive_caching as true
        
        Note: Thread safety
        enable_thread_safety as true
        lock_timeout_ms as 5000
        max_concurrent_readers as 100
        
        Note: Analytics
        track_access_patterns as true
        track_performance_metrics as true
        metrics_aggregation_interval_ms as 60000
        
        Note: Cache levels
        default_cache_levels as 3
        l1_cache_size as 1048576
        l2_cache_size as 16777216
        l3_cache_size as 268435456
        
        Note: Eviction policies
        default_eviction_policy as "LRU"
        ttl_default_seconds as 3600
        lru_aging_factor as 1.5

Note: Configuration Section Setup

Process called "register_cache_configuration" returns ConfigManager.ConfigurationSection:
    Let default_config be create_default_cache_config
    
    Let config_values be empty dictionary
    
    Note: Register performance configuration values
    Set config_values at "pattern_confidence_threshold" to ConfigManager.ConfigValue with:
        key as "pattern_confidence_threshold"
        value as default_config.pattern_confidence_threshold
        default_value as default_config.pattern_confidence_threshold
        value_type as ConfigManager.FloatType with min as Some with 0.0 and max as Some with 1.0
        description as "Confidence threshold for pattern recognition in caching"
        is_runtime_modifiable as true
        validation_rule as Some with create_confidence_threshold_validator
        environment_override as Some with "RUNA_CONFIG_CACHE_PATTERN_CONFIDENCE_THRESHOLD"
        last_modified as ConfigManager.get_current_time
        metadata as empty dictionary
    
    Set config_values at "lock_timeout_ms" to ConfigManager.ConfigValue with:
        key as "lock_timeout_ms"
        value as default_config.lock_timeout_ms
        default_value as default_config.lock_timeout_ms
        value_type as ConfigManager.IntegerType with min as Some with 100 and max as Some with 30000
        description as "Timeout in milliseconds for cache lock operations"
        is_runtime_modifiable as true
        validation_rule as Some with create_timeout_validator
        environment_override as Some with "RUNA_CONFIG_CACHE_LOCK_TIMEOUT_MS"
        last_modified as ConfigManager.get_current_time
        metadata as empty dictionary
    
    Set config_values at "max_memory_bytes" to ConfigManager.ConfigValue with:
        key as "max_memory_bytes"
        value as default_config.max_memory_bytes
        default_value as default_config.max_memory_bytes
        value_type as ConfigManager.IntegerType with min as Some with 1048576 and max as Some with 17179869184
        description as "Maximum memory in bytes for cache storage"
        is_runtime_modifiable as false
        validation_rule as Some with create_memory_size_validator
        environment_override as Some with "RUNA_CONFIG_CACHE_MAX_MEMORY_BYTES"
        last_modified as ConfigManager.get_current_time
        metadata as dictionary containing "requires_restart" as true
    
    Set config_values at "memory_pressure_threshold" to ConfigManager.ConfigValue with:
        key as "memory_pressure_threshold"
        value as default_config.memory_pressure_threshold
        default_value as default_config.memory_pressure_threshold
        value_type as ConfigManager.FloatType with min as Some with 0.5 and max as Some with 0.99
        description as "Memory pressure threshold for triggering cache eviction"
        is_runtime_modifiable as true
        validation_rule as Some with create_pressure_threshold_validator
        environment_override as Some with "RUNA_CONFIG_CACHE_MEMORY_PRESSURE_THRESHOLD"
        last_modified as ConfigManager.get_current_time
        metadata as empty dictionary
    
    Set config_values at "prediction_confidence_threshold" to ConfigManager.ConfigValue with:
        key as "prediction_confidence_threshold"
        value as default_config.prediction_confidence_threshold
        default_value as default_config.prediction_confidence_threshold
        value_type as ConfigManager.FloatType with min as Some with 0.0 and max as Some with 1.0
        description as "Confidence threshold for predictive caching algorithms"
        is_runtime_modifiable as true
        validation_rule as Some with create_confidence_threshold_validator
        environment_override as Some with "RUNA_CONFIG_CACHE_PREDICTION_CONFIDENCE_THRESHOLD"
        last_modified as ConfigManager.get_current_time
        metadata as empty dictionary
    
    Set config_values at "prefetch_confidence_threshold" to ConfigManager.ConfigValue with:
        key as "prefetch_confidence_threshold"
        value as default_config.prefetch_confidence_threshold
        default_value as default_config.prefetch_confidence_threshold
        value_type as ConfigManager.FloatType with min as Some with 0.0 and max as Some with 1.0
        description as "Confidence threshold for prefetch operations"
        is_runtime_modifiable as true
        validation_rule as Some with create_confidence_threshold_validator
        environment_override as Some with "RUNA_CONFIG_CACHE_PREFETCH_CONFIDENCE_THRESHOLD"
        last_modified as ConfigManager.get_current_time
        metadata as empty dictionary
    
    Set config_values at "min_access_frequency" to ConfigManager.ConfigValue with:
        key as "min_access_frequency"
        value as default_config.min_access_frequency
        default_value as default_config.min_access_frequency
        value_type as ConfigManager.FloatType with min as Some with 0.001 and max as Some with 10.0
        description as "Minimum access frequency for cache entry retention"
        is_runtime_modifiable as true
        validation_rule as None
        environment_override as Some with "RUNA_CONFIG_CACHE_MIN_ACCESS_FREQUENCY"
        last_modified as ConfigManager.get_current_time
        metadata as empty dictionary
    
    Set config_values at "max_concurrent_readers" to ConfigManager.ConfigValue with:
        key as "max_concurrent_readers"
        value as default_config.max_concurrent_readers
        default_value as default_config.max_concurrent_readers
        value_type as ConfigManager.IntegerType with min as Some with 1 and max as Some with 1000
        description as "Maximum number of concurrent reader threads"
        is_runtime_modifiable as true
        validation_rule as Some with create_concurrency_validator
        environment_override as Some with "RUNA_CONFIG_CACHE_MAX_CONCURRENT_READERS"
        last_modified as ConfigManager.get_current_time
        metadata as empty dictionary
    
    Set config_values at "compression_threshold_bytes" to ConfigManager.ConfigValue with:
        key as "compression_threshold_bytes"
        value as default_config.compression_threshold_bytes
        default_value as default_config.compression_threshold_bytes
        value_type as ConfigManager.IntegerType with min as Some with 64 and max as Some with 1048576
        description as "Minimum size in bytes for cache entry compression"
        is_runtime_modifiable as true
        validation_rule as None
        environment_override as Some with "RUNA_CONFIG_CACHE_COMPRESSION_THRESHOLD_BYTES"
        last_modified as ConfigManager.get_current_time
        metadata as empty dictionary
    
    Return ConfigManager.ConfigurationSection with:
        section_name as "cache"
        values as config_values
        defaults as extract_defaults_from_cache_config with default_config
        description as "Cache System Configuration Settings"
        is_runtime_modifiable as true
        requires_restart as false
        metadata as dictionary containing
            "version" as "1.0.0"
            "last_updated" as ConfigManager.get_current_time

Note: Validation Rules

Process called "create_confidence_threshold_validator" returns ConfigManager.ValidationRule:
    Return ConfigManager.ValidationRule with:
        rule_name as "confidence_threshold_validator"
        validator as validate_confidence_threshold
        error_message as "Confidence threshold must be between 0.0 and 1.0"
        metadata as empty dictionary

Process called "validate_confidence_threshold" that takes value as Any returns ConfigManager.ValidationResult:
    If value is Float:
        If value < 0.0:
            Return ConfigManager.Invalid with reason as "Confidence threshold cannot be negative"
        If value > 1.0:
            Return ConfigManager.Invalid with reason as "Confidence threshold cannot exceed 1.0"
        Return ConfigManager.Valid
    Else:
        Return ConfigManager.Invalid with reason as "Confidence threshold must be a float value"

Process called "create_timeout_validator" returns ConfigManager.ValidationRule:
    Return ConfigManager.ValidationRule with:
        rule_name as "timeout_validator"
        validator as validate_timeout
        error_message as "Timeout must be reasonable for system performance"
        metadata as empty dictionary

Process called "validate_timeout" that takes value as Any returns ConfigManager.ValidationResult:
    If value is Integer:
        If value < 100:
            Return ConfigManager.Invalid with reason as "Timeout too small - minimum is 100ms"
        If value > 30000:
            Return ConfigManager.Invalid with reason as "Timeout too large - maximum is 30 seconds"
        Return ConfigManager.Valid
    Else:
        Return ConfigManager.Invalid with reason as "Timeout must be an integer value"

Process called "create_memory_size_validator" returns ConfigManager.ValidationRule:
    Return ConfigManager.ValidationRule with:
        rule_name as "memory_size_validator"
        validator as validate_cache_memory_size
        error_message as "Memory size must be reasonable and properly aligned"
        metadata as empty dictionary

Process called "validate_cache_memory_size" that takes value as Any returns ConfigManager.ValidationResult:
    If value is Integer:
        If value < 1048576:
            Return ConfigManager.Invalid with reason as "Memory size too small - minimum is 1MB"
        If value > 17179869184:
            Return ConfigManager.Invalid with reason as "Memory size too large - maximum is 16GB"
        
        Note: Check if value is a power of 2 for better memory allocation
        Let is_power_of_two be (value & (value - 1)) == 0
        If not is_power_of_two:
            Return ConfigManager.Invalid with reason as "Memory size should be a power of 2 for optimal allocation"
        
        Return ConfigManager.Valid
    Else:
        Return ConfigManager.Invalid with reason as "Memory size must be an integer value"

Process called "create_pressure_threshold_validator" returns ConfigManager.ValidationRule:
    Return ConfigManager.ValidationRule with:
        rule_name as "pressure_threshold_validator"
        validator as validate_pressure_threshold
        error_message as "Pressure threshold must be between 0.5 and 0.99"
        metadata as empty dictionary

Process called "validate_pressure_threshold" that takes value as Any returns ConfigManager.ValidationResult:
    If value is Float:
        If value < 0.5:
            Return ConfigManager.Invalid with reason as "Pressure threshold too low - minimum is 0.5"
        If value >= 1.0:
            Return ConfigManager.Invalid with reason as "Pressure threshold must be less than 1.0"
        Return ConfigManager.Valid
    Else:
        Return ConfigManager.Invalid with reason as "Pressure threshold must be a float value"

Process called "create_concurrency_validator" returns ConfigManager.ValidationRule:
    Return ConfigManager.ValidationRule with:
        rule_name as "concurrency_validator"
        validator as validate_concurrency
        error_message as "Concurrency level must be reasonable for system resources"
        metadata as empty dictionary

Process called "validate_concurrency" that takes value as Any returns ConfigManager.ValidationResult:
    If value is Integer:
        If value < 1:
            Return ConfigManager.Invalid with reason as "Concurrency level must be at least 1"
        If value > 1000:
            Return ConfigManager.Invalid with reason as "Concurrency level too high - maximum is 1000"
        Return ConfigManager.Valid
    Else:
        Return ConfigManager.Invalid with reason as "Concurrency level must be an integer value"

Process called "extract_defaults_from_cache_config" that takes config as CacheConfiguration returns Dictionary[String, Any]:
    Let defaults be empty dictionary
    
    Set defaults at "pattern_confidence_threshold" to config.pattern_confidence_threshold
    Set defaults at "prediction_confidence_threshold" to config.prediction_confidence_threshold
    Set defaults at "prefetch_confidence_threshold" to config.prefetch_confidence_threshold
    Set defaults at "max_memory_bytes" to config.max_memory_bytes
    Set defaults at "memory_pressure_threshold" to config.memory_pressure_threshold
    Set defaults at "emergency_eviction_threshold" to config.emergency_eviction_threshold
    Set defaults at "min_access_frequency" to config.min_access_frequency
    Set defaults at "priority_score_threshold" to config.priority_score_threshold
    Set defaults at "hit_ratio_excellence_threshold" to config.hit_ratio_excellence_threshold
    Set defaults at "enable_compression" to config.enable_compression
    Set defaults at "compression_threshold_bytes" to config.compression_threshold_bytes
    Set defaults at "enable_adaptive_sizing" to config.enable_adaptive_sizing
    Set defaults at "enable_predictive_caching" to config.enable_predictive_caching
    Set defaults at "enable_thread_safety" to config.enable_thread_safety
    Set defaults at "lock_timeout_ms" to config.lock_timeout_ms
    Set defaults at "max_concurrent_readers" to config.max_concurrent_readers
    Set defaults at "track_access_patterns" to config.track_access_patterns
    Set defaults at "track_performance_metrics" to config.track_performance_metrics
    Set defaults at "metrics_aggregation_interval_ms" to config.metrics_aggregation_interval_ms
    Set defaults at "default_cache_levels" to config.default_cache_levels
    Set defaults at "l1_cache_size" to config.l1_cache_size
    Set defaults at "l2_cache_size" to config.l2_cache_size
    Set defaults at "l3_cache_size" to config.l3_cache_size
    Set defaults at "default_eviction_policy" to config.default_eviction_policy
    Set defaults at "ttl_default_seconds" to config.ttl_default_seconds
    Set defaults at "lru_aging_factor" to config.lru_aging_factor
    
    Return defaults

Note: Global Cache Configuration Instance

Let CACHE_CONFIG_SECTION be register_cache_configuration

Process called "initialize_cache_config" returns Unit:
    Let register_result be ConfigManager.register_section with 
        manager as ConfigManager.GLOBAL_CONFIG_MANAGER 
        and section_name as "cache" 
        and section as CACHE_CONFIG_SECTION
    
    Match register_result:
        Case ConfigManager.Valid:
            Note: Cache configuration registered successfully
        Case ConfigManager.Invalid with error:
            Note: Handle configuration registration error
            Print "Failed to register cache configuration: " + format_config_error with error

Process called "format_config_error" that takes error as ConfigManager.ConfigurationError returns String:
    Match error:
        Case ConfigManager.SectionNotFound with section:
            Return "Section not found: " + section
        Case ConfigManager.KeyNotFound with section and key:
            Return "Key not found: " + section + "." + key
        Case ConfigManager.ValidationFailed with section and key and reason:
            Return "Validation failed for " + section + "." + key + ": " + reason
        Case ConfigManager.TypeMismatch with section and key and expected_type and actual_type:
            Return "Type mismatch for " + section + "." + key + ": expected " + expected_type + ", got " + actual_type
        Case ConfigManager.ReadOnlyValue with section and key:
            Return "Cannot modify read-only value: " + section + "." + key
        Case ConfigManager.EnvironmentOverrideConflict with section and key and env_var:
            Return "Environment override conflict for " + section + "." + key + " from " + env_var

Note: Convenience Functions for Cache Configuration Access

Process called "get_cache_config_value" that takes key as String returns Any:
    Let result be ConfigManager.get_config_value with 
        manager as ConfigManager.GLOBAL_CONFIG_MANAGER 
        and section as "cache" 
        and key as key
    
    Match result:
        Case ConfigManager.Valid with value:
            Return value
        Case ConfigManager.Invalid with error:
            Note: Return default value if configuration fails
            Let default_config be create_default_cache_config
            Return get_default_value_for_cache_key with default_config and key

Process called "set_cache_config_value" that takes key as String and value as Any returns Boolean:
    Let result be ConfigManager.set_config_value with 
        manager as ConfigManager.GLOBAL_CONFIG_MANAGER 
        and section as "cache" 
        and key as key 
        and new_value as value
    
    Match result:
        Case ConfigManager.Valid:
            Return true
        Case ConfigManager.Invalid with error:
            Note: Log the error
            Print "Failed to set cache config value " + key + ": " + format_config_error with error
            Return false

Process called "get_default_value_for_cache_key" that takes config as CacheConfiguration and key as String returns Any:
    Match key:
        Case "pattern_confidence_threshold":
            Return config.pattern_confidence_threshold
        Case "lock_timeout_ms":
            Return config.lock_timeout_ms
        Case "max_memory_bytes":
            Return config.max_memory_bytes
        Case "memory_pressure_threshold":
            Return config.memory_pressure_threshold
        Case "prediction_confidence_threshold":
            Return config.prediction_confidence_threshold
        Case "prefetch_confidence_threshold":
            Return config.prefetch_confidence_threshold
        Case "min_access_frequency":
            Return config.min_access_frequency
        Case "max_concurrent_readers":
            Return config.max_concurrent_readers
        Case "compression_threshold_bytes":
            Return config.compression_threshold_bytes
        Case _:
            Return 0

Note: Initialize cache configuration when module is loaded
Call initialize_cache_config

Note: Export configuration access functions
Export get_cache_config_value as get_config
Export set_cache_config_value as set_config
Export create_default_cache_config as get_defaults