    Return "0000000"

Process called "get_typeflag_for_file_type" that takes file_type as String returns String:
    Note: Get TAR typeflag for file type
    Match file_type:
        When "regular":
            Return "0"
        When "directory":
            Return "5"
        When "symlink":
            Return "2"
        When "hardlink":
            Return "1"
        Otherwise:
            Return "0"

Process called "get_magic_for_format" that takes format as String returns String:
    Note: Get magic number for TAR format
    Match format:
        When "ustar":
            Return "ustar "
        When "gnu":
            Return "ustar\0"
        When "pax":
            Return "ustar "
        Otherwise:
            Return "ustar "

Process called "get_version_for_format" that takes format as String returns String:
    Note: Get version string for TAR format
    Match format:
        When "ustar":
            Return "00"
        When "gnu":
            Return " \0"
        When "pax":
            Return "00"
        Otherwise:
            Return "00"

