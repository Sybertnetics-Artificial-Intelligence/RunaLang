Note:
Runa Standard Library: ZIP Archive Module

Provides production-ready ZIP archive format support for creating, extracting, and
manipulating ZIP files. Supports ZIP64 format for large archives, various compression
methods, encryption, and full compatibility with modern ZIP tools.

Features:
- Complete ZIP format support (ZIP32 and ZIP64 for large files)
- Multiple compression methods (Store, Deflate, BZIP2, LZMA)
- Password-based encryption with AES-256 and traditional ZIP encryption
- Stream-based archive creation and extraction for large files
- Memory-efficient operations with configurable buffer sizes
- Comprehensive error handling with detailed diagnostics
- Progress tracking for long-running archive operations
- Thread-safe operations for concurrent archive processing
- Integration with Runa's advanced type system for type safety
- Advanced file metadata preservation (timestamps, attributes)
- Unicode filename support with proper encoding handling
- Directory traversal with filtering and exclusion patterns
- Archive verification and integrity checking
- Cross-platform compatibility with proper path handling
- Comment support for archives and individual files
- Extra field support for extended metadata

Technical specifications:
- Format support: ZIP32 (standard), ZIP64 (large files >4GB)
- Compression: Store, Deflate, BZIP2, LZMA
- Encryption: Traditional ZIP, AES-128, AES-192, AES-256
- Maximum file size: 4GB (ZIP32), 16EB (ZIP64)
- Maximum files: 65,535 (ZIP32), unlimited (ZIP64)
- Thread safety: All operations are thread-safe and reentrant
- Memory usage: Configurable buffer sizes for memory efficiency
- Error recovery: Robust error handling with detailed diagnostics
:End Note

Import "compress/gzip" as gzip_module
Import "compress/bz2" as bz2_module
Import "compress/lzma" as lzma_module

Note: Core ZIP Types and Configuration
Type called "ZIPConfig":
    compression_method as String defaults to "deflate"
    compression_level as Integer defaults to 6
    enable_zip64 as Boolean defaults to true
    enable_encryption as Boolean defaults to false
    encryption_method as String defaults to "aes256"
    password as Optional[String] defaults to None
    preserve_timestamps as Boolean defaults to true
    preserve_attributes as Boolean defaults to true
    enable_unicode_filenames as Boolean defaults to true
    enable_progress_tracking as Boolean defaults to false
    buffer_size as Integer defaults to 65536
    enable_verification as Boolean defaults to true
    exclusion_patterns as List[String] defaults to list containing
    inclusion_patterns as List[String] defaults to list containing
    base_directory as Optional[String] defaults to None
    archive_comment as Optional[String] defaults to None
    default_file_comment as Optional[String] defaults to None
    enable_streaming as Boolean defaults to false
    memory_limit as Optional[Integer] defaults to None
    enable_data_descriptor as Boolean defaults to true
    store_symlinks as Boolean defaults to true
    follow_symlinks as Boolean defaults to false
    metadata as Dictionary[String, Any] defaults to dictionary containing

Type ZIPResult is:
    | ZIPSuccess with archive_path as String and operation as String and files_processed as Integer and total_size as Integer and compressed_size as Integer and processing_time as Float and compression_ratio as Float
    | ZIPError with error_message as String and error_code as String and archive_path as String and operation as String and suggestions as List[String] and context as Dictionary[String, Any]

Type called "ZIPEntry":
    filename as String
    file_comment as String
    file_size as Integer
    compressed_size as Integer
    crc32 as String
    compression_method as String
    encryption_method as String
    last_modified as Integer
    attributes as Integer
    extra_fields as Dictionary[String, Any]
    local_header_offset as Integer
    is_directory as Boolean
    is_encrypted as Boolean
    uses_data_descriptor as Boolean
    uses_utf8_encoding as Boolean
    metadata as Dictionary[String, Any]

Type called "ZIPLocalHeader":
    signature as Integer
    version_needed as Integer
    flags as Integer
    compression_method as Integer
    last_modified_time as Integer
    last_modified_date as Integer
    crc32 as Integer
    compressed_size as Integer
    uncompressed_size as Integer
    filename_length as Integer
    extra_field_length as Integer
    filename as String
    extra_field as List[Integer]
    metadata as Dictionary[String, Any]

Type called "ZIPCentralDirectoryHeader":
    signature as Integer
    version_made_by as Integer
    version_needed as Integer
    flags as Integer
    compression_method as Integer
    last_modified_time as Integer
    last_modified_date as Integer
    crc32 as Integer
    compressed_size as Integer
    uncompressed_size as Integer
    filename_length as Integer
    extra_field_length as Integer
    file_comment_length as Integer
    disk_number as Integer
    internal_attributes as Integer
    external_attributes as Integer
    local_header_offset as Integer
    filename as String
    extra_field as List[Integer]
    file_comment as String
    metadata as Dictionary[String, Any]

Type called "ZIPEndOfCentralDirectory":
    signature as Integer
    disk_number as Integer
    central_directory_disk as Integer
    entries_on_disk as Integer
    total_entries as Integer
    central_directory_size as Integer
    central_directory_offset as Integer
    comment_length as Integer
    comment as String
    metadata as Dictionary[String, Any]

Type called "ZIP64EndOfCentralDirectory":
    signature as Integer
    size_of_record as Integer
    version_made_by as Integer
    version_needed as Integer
    disk_number as Integer
    central_directory_disk as Integer
    entries_on_disk as Integer
    total_entries as Integer
    central_directory_size as Integer
    central_directory_offset as Integer
    metadata as Dictionary[String, Any]

Type ZIPCompressionMethod is:
    | Store | Deflate | BZIP2 | LZMA

Type ZIPEncryptionMethod is:
    | None | Traditional | AES128 | AES192 | AES256

Type called "ZIPArchiveContext":
    config as ZIPConfig
    entries as List[ZIPEntry]
    central_directory_entries as List[ZIPCentralDirectoryHeader]
    current_offset as Integer
    files_processed as Integer
    total_size as Integer
    compressed_size as Integer
    encryption_context as Optional[Dictionary[String, Any]]
    compression_contexts as Dictionary[String, Any]
    metadata as Dictionary[String, Any]
:End Note

Note: Core ZIP Archive Functions
Process called "create_zip_archive" that takes files as List[String] and archive_path as String and config as Optional[ZIPConfig] returns ZIPResult:
    Let start_time be get_current_time
    Let final_config be config if config is not None else create_default_zip_config
    
    Try:
        If length of files is equal to 0:
            Return ZIPError with:
                error_message as "Cannot create ZIP archive with no files"
                error_code as "ZIP_EMPTY_FILE_LIST"
                archive_path as archive_path
                operation as "create"
                suggestions as list containing "Provide at least one file to archive"
                context as dictionary containing "file_count" as 0
        
        Let validation_result be validate_zip_config with config as final_config
        If not validation_result.is_valid:
            Return ZIPError with:
                error_message as "Invalid ZIP configuration: " plus validation_result.error_message
                error_code as "ZIP_INVALID_CONFIG"
                archive_path as archive_path
                operation as "create"
                suggestions as validation_result.suggestions
                context as dictionary containing "config" as final_config
        
        Let missing_files be find_missing_files with files as files
        If length of missing_files is greater than 0:
            Let missing_list be join_list with list as missing_files and separator as ", "
            Return ZIPError with:
                error_message as "Files not found: " plus missing_list
                error_code as "ZIP_FILES_NOT_FOUND"
                archive_path as archive_path
                operation as "create"
                suggestions as list containing "Verify all file paths are correct", "Check file permissions"
                context as dictionary containing "missing_files" as missing_files
        
        If final_config.enable_encryption and final_config.password is None:
            Return ZIPError with:
                error_message as "Encryption enabled but no password provided"
                error_code as "ZIP_ENCRYPTION_NO_PASSWORD"
                archive_path as archive_path
                operation as "create"
                suggestions as list containing "Provide password for encryption", "Disable encryption"
                context as dictionary containing "encryption_method" as final_config.encryption_method
        
        Let archive_context be initialize_zip_archive_context with config as final_config and archive_path as archive_path
        Let file_list be expand_file_list with files as files and config as final_config
        
        Let creation_result be create_zip_archive_with_context with:
            file_list as file_list
            archive_path as archive_path
            context as archive_context
        
        Match creation_result.status:
            When "success":
                Let end_time be get_current_time
                Let processing_time be end_time minus start_time
                Let compression_ratio be calculate_compression_ratio with:
                    original_size as creation_result.total_size
                    compressed_size as creation_result.compressed_size
                
                Return ZIPSuccess with:
                    archive_path as archive_path
                    operation as "create"
                    files_processed as creation_result.files_processed
                    total_size as creation_result.total_size
                    compressed_size as creation_result.compressed_size
                    processing_time as processing_time
                    compression_ratio as compression_ratio
            
            When "error":
                Return ZIPError with:
                    error_message as creation_result.error_message
                    error_code as creation_result.error_code
                    archive_path as archive_path
                    operation as "create"
                    suggestions as creation_result.suggestions
                    context as creation_result.context
    
    Catch error:
        Return ZIPError with:
            error_message as "Unexpected ZIP creation error: " plus error.message
            error_code as "ZIP_CREATE_INTERNAL_ERROR"
            archive_path as archive_path
            operation as "create"
            suggestions as list containing "Check system resources", "Verify file permissions", "Report this as a bug"
            context as dictionary containing "error_details" as error.message

Process called "extract_zip_archive" that takes archive_path as String and output_directory as String and config as Optional[ZIPConfig] returns ZIPResult:
    Let start_time be get_current_time
    Let final_config be config if config is not None else create_default_zip_config
    
    Try:
        Let archive_exists be check_file_exists with path as archive_path
        If not archive_exists:
            Return ZIPError with:
                error_message as "ZIP archive does not exist: " plus archive_path
                error_code as "ZIP_ARCHIVE_NOT_FOUND"
                archive_path as archive_path
                operation as "extract"
                suggestions as list containing "Verify archive path is correct", "Check file permissions"
                context as dictionary containing
        
        Let validation_result be validate_zip_archive_format with path as archive_path
        If not validation_result.is_valid:
            Return ZIPError with:
                error_message as "Invalid ZIP archive format: " plus validation_result.error_message
                error_code as "ZIP_INVALID_FORMAT"
                archive_path as archive_path
                operation as "extract"
                suggestions as validation_result.suggestions
                context as dictionary containing "format_issues" as validation_result.issues
        
        Let dir_created be ensure_directory_exists with path as output_directory
        If not dir_created:
            Return ZIPError with:
                error_message as "Cannot create output directory: " plus output_directory
                error_code as "ZIP_OUTPUT_DIR_ERROR"
                archive_path as archive_path
                operation as "extract"
                suggestions as list containing "Check directory permissions", "Verify path is valid"
                context as dictionary containing "output_directory" as output_directory
        
        Let archive_context be initialize_zip_extraction_context with:
            archive_path as archive_path
            output_directory as output_directory
            config as final_config
        
        Let extraction_result be extract_zip_archive_with_context with:
            archive_path as archive_path
            output_directory as output_directory
            context as archive_context
        
        Match extraction_result.status:
            When "success":
                Let end_time be get_current_time
                Let processing_time be end_time minus start_time
                Let compression_ratio be calculate_compression_ratio with:
                    original_size as extraction_result.total_size
                    compressed_size as extraction_result.compressed_size
                
                Return ZIPSuccess with:
                    archive_path as archive_path
                    operation as "extract"
                    files_processed as extraction_result.files_processed
                    total_size as extraction_result.total_size
                    compressed_size as extraction_result.compressed_size
                    processing_time as processing_time
                    compression_ratio as compression_ratio
            
            When "error":
                Return ZIPError with:
                    error_message as extraction_result.error_message
                    error_code as extraction_result.error_code
                    archive_path as archive_path
                    operation as "extract"
                    suggestions as extraction_result.suggestions
                    context as extraction_result.context
    
    Catch error:
        Return ZIPError with:
            error_message as "Unexpected ZIP extraction error: " plus error.message
            error_code as "ZIP_EXTRACT_INTERNAL_ERROR"
            archive_path as archive_path
            operation as "extract"
            suggestions as list containing "Check system resources", "Verify archive integrity", "Report this as a bug"
            context as dictionary containing "error_details" as error.message

Process called "list_zip_contents" that takes archive_path as String and config as Optional[ZIPConfig] returns Dictionary[String, Any]:
    Let final_config be config if config is not None else create_default_zip_config
    
    Try:
        Let archive_exists be check_file_exists with path as archive_path
        If not archive_exists:
            Return dictionary containing:
                "success" as false
                "error_message" as "ZIP archive does not exist: " plus archive_path
                "error_code" as "ZIP_ARCHIVE_NOT_FOUND"
                "suggestions" as list containing "Verify archive path is correct", "Check file permissions"
        
        Let validation_result be validate_zip_archive_format with path as archive_path
        If not validation_result.is_valid:
            Return dictionary containing:
                "success" as false
                "error_message" as "Invalid ZIP archive format: " plus validation_result.error_message
                "error_code" as "ZIP_INVALID_FORMAT"
                "suggestions" as validation_result.suggestions
        
        Let listing_result be list_zip_entries with archive_path as archive_path and config as final_config
        
        If listing_result.success:
            Return dictionary containing:
                "success" as true
                "entries" as listing_result.entries
                "total_files" as listing_result.total_files
                "total_size" as listing_result.total_size
                "compressed_size" as listing_result.compressed_size
                "archive_comment" as listing_result.archive_comment
                "uses_zip64" as listing_result.uses_zip64
                "encryption_methods" as listing_result.encryption_methods
                "compression_methods" as listing_result.compression_methods
        Otherwise:
            Return dictionary containing:
                "success" as false
                "error_message" as listing_result.error_message
                "error_code" as listing_result.error_code
                "suggestions" as listing_result.suggestions
    
    Catch error:
        Return dictionary containing:
            "success" as false
            "error_message" as "Unexpected ZIP listing error: " plus error.message
            "error_code" as "ZIP_LIST_INTERNAL_ERROR"
            "suggestions" as list containing "Check archive integrity", "Report this as a bug"

Process called "add_to_zip_archive" that takes archive_path as String and files as List[String] and config as Optional[ZIPConfig] returns ZIPResult:
    Let start_time be get_current_time
    Let final_config be config if config is not None else create_default_zip_config
    
    Try:
        If length of files is equal to 0:
            Return ZIPError with:
                error_message as "Cannot add empty file list to ZIP archive"
                error_code as "ZIP_EMPTY_ADD_LIST"
                archive_path as archive_path
                operation as "add"
                suggestions as list containing "Provide at least one file to add"
                context as dictionary containing "file_count" as 0
        
        Let archive_exists be check_file_exists with path as archive_path
        If not archive_exists:
            Return ZIPError with:
                error_message as "ZIP archive does not exist: " plus archive_path
                error_code as "ZIP_ARCHIVE_NOT_FOUND"
                archive_path as archive_path
                operation as "add"
                suggestions as list containing "Create archive first using create_zip_archive", "Verify archive path is correct"
                context as dictionary containing
        
        Let missing_files be find_missing_files with files as files
        If length of missing_files is greater than 0:
            Let missing_list be join_list with list as missing_files and separator as ", "
            Return ZIPError with:
                error_message as "Files not found: " plus missing_list
                error_code as "ZIP_FILES_NOT_FOUND"
                archive_path as archive_path
                operation as "add"
                suggestions as list containing "Verify all file paths are correct", "Check file permissions"
                context as dictionary containing "missing_files" as missing_files
        
        Let addition_result be add_files_to_zip_archive with:
            archive_path as archive_path
            files as files
            config as final_config
        
        Match addition_result.status:
            When "success":
                Let end_time be get_current_time
                Let processing_time be end_time minus start_time
                Let compression_ratio be calculate_compression_ratio with:
                    original_size as addition_result.total_size
                    compressed_size as addition_result.compressed_size
                
                Return ZIPSuccess with:
                    archive_path as archive_path
                    operation as "add"
                    files_processed as addition_result.files_processed
                    total_size as addition_result.total_size
                    compressed_size as addition_result.compressed_size
                    processing_time as processing_time
                    compression_ratio as compression_ratio
            
            When "error":
                Return ZIPError with:
                    error_message as addition_result.error_message
                    error_code as addition_result.error_code
                    archive_path as archive_path
                    operation as "add"
                    suggestions as addition_result.suggestions
                    context as addition_result.context
    
    Catch error:
        Return ZIPError with:
            error_message as "Unexpected ZIP addition error: " plus error.message
            error_code as "ZIP_ADD_INTERNAL_ERROR"
            archive_path as archive_path
            operation as "add"
            suggestions as list containing "Check system resources", "Verify file permissions", "Report this as a bug"
            context as dictionary containing "error_details" as error.message

Process called "verify_zip_archive" that takes archive_path as String and config as Optional[ZIPConfig] returns Dictionary[String, Any]:
    Let final_config be config if config is not None else create_default_zip_config
    
    Try:
        Let archive_exists be check_file_exists with path as archive_path
        If not archive_exists:
            Return dictionary containing:
                "success" as false
                "error_message" as "ZIP archive does not exist: " plus archive_path
                "error_code" as "ZIP_ARCHIVE_NOT_FOUND"
                "suggestions" as list containing "Verify archive path is correct", "Check file permissions"
        
        Let verification_result be verify_zip_archive_integrity with:
            archive_path as archive_path
            config as final_config
        
        If verification_result.success:
            Return dictionary containing:
                "success" as true
                "is_valid" as verification_result.is_valid
                "total_files" as verification_result.total_files
                "total_size" as verification_result.total_size
                "crc_errors" as verification_result.crc_errors
                "structure_errors" as verification_result.structure_errors
                "encryption_errors" as verification_result.encryption_errors
                "warnings" as verification_result.warnings
                "uses_zip64" as verification_result.uses_zip64
        Otherwise:
            Return dictionary containing:
                "success" as false
                "error_message" as verification_result.error_message
                "error_code" as verification_result.error_code
                "suggestions" as verification_result.suggestions
    
    Catch error:
        Return dictionary containing:
            "success" as false
            "error_message" as "Unexpected ZIP verification error: " plus error.message
            "error_code" as "ZIP_VERIFY_INTERNAL_ERROR"
            "suggestions" as list containing "Check archive integrity", "Report this as a bug"

Process called "extract_single_file" that takes archive_path as String and filename as String and output_path as String and config as Optional[ZIPConfig] returns Dictionary[String, Any]:
    Let final_config be config if config is not None else create_default_zip_config
    
    Try:
        Let archive_exists be check_file_exists with path as archive_path
        If not archive_exists:
            Return dictionary containing:
                "success" as false
                "error_message" as "ZIP archive does not exist: " plus archive_path
                "error_code" as "ZIP_ARCHIVE_NOT_FOUND"
