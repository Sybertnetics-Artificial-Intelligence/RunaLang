        Let extraction_result be extract_single_file_from_zip with:
            archive_path as archive_path
            filename as filename
            output_path as output_path
            config as final_config
        
        If extraction_result.success:
            Return dictionary containing:
                "success" as true
                "extracted_file" as output_path
                "original_size" as extraction_result.original_size
                "compressed_size" as extraction_result.compressed_size
                "crc32_valid" as extraction_result.crc32_valid
                "extraction_time" as extraction_result.extraction_time
        Otherwise:
            Return dictionary containing:
                "success" as false
                "error_message" as extraction_result.error_message
                "error_code" as extraction_result.error_code
                "suggestions" as extraction_result.suggestions
    
    Catch error:
        Return dictionary containing:
            "success" as false
            "error_message" as "Unexpected single file extraction error: " plus error.message
            "error_code" as "ZIP_EXTRACT_FILE_INTERNAL_ERROR"
            "suggestions" as list containing "Check archive integrity", "Verify filename exists", "Report this as a bug"
:End Note

Note: ZIP Compression and Encryption Functions
Process called "compress_zip_data" that takes data as List[Integer] and method as String and level as Integer returns Dictionary[String, Any]:
    Try:
        Match method:
            When "store":
                Return dictionary containing:
                    "success" as true
                    "compressed_data" as data
                    "compression_ratio" as 1.0
            
            When "deflate":
                Let gzip_config be create_gzip_config_for_zip with compression_level as level
                Let deflate_result be gzip_module.deflate_compress with data as data and config as gzip_config
                If deflate_result is not None:
                    Let compression_ratio be calculate_compression_ratio with:
                        original_size as length of data
                        compressed_size as length of deflate_result
                    Return dictionary containing:
                        "success" as true
                        "compressed_data" as deflate_result
                        "compression_ratio" as compression_ratio
                Otherwise:
                    Return dictionary containing:
                        "success" as false
                        "error_message" as "Deflate compression failed"
                        "error_code" as "ZIP_DEFLATE_FAILED"
            
            When "bzip2":
                Let bz2_config be create_bz2_config_for_zip with compression_level as level
                Let data_string be convert_bytes_to_string with bytes as data
                Let bz2_result be bz2_module.bz2_compress with data as data_string and config as bz2_config
                Match bz2_result:
                    When "success":
                        Let compression_ratio be calculate_compression_ratio with:
                            original_size as length of data
                            compressed_size as length of bz2_result.compressed_data
                        Return dictionary containing:
                            "success" as true
                            "compressed_data" as bz2_result.compressed_data
                            "compression_ratio" as compression_ratio
                    When "error":
                        Return dictionary containing:
                            "success" as false
                            "error_message" as "BZIP2 compression failed: " plus bz2_result.error_message
                            "error_code" as "ZIP_BZIP2_FAILED"
            
            When "lzma":
                Let lzma_config be create_lzma_config_for_zip with compression_level as level
                Let data_string be convert_bytes_to_string with bytes as data
                Let lzma_result be lzma_module.lzma_compress with data as data_string and config as lzma_config
                Match lzma_result:
                    When "success":
                        Let compression_ratio be calculate_compression_ratio with:
                            original_size as length of data
                            compressed_size as length of lzma_result.compressed_data
                        Return dictionary containing:
                            "success" as true
                            "compressed_data" as lzma_result.compressed_data
                            "compression_ratio" as compression_ratio
                    When "error":
                        Return dictionary containing:
                            "success" as false
                            "error_message" as "LZMA compression failed: " plus lzma_result.error_message
                            "error_code" as "ZIP_LZMA_FAILED"
            
            Otherwise:
                Return dictionary containing:
                    "success" as false
                    "error_message" as "Unsupported compression method: " plus method
                    "error_code" as "ZIP_UNSUPPORTED_COMPRESSION"
    
    Catch error:
        Return dictionary containing:
            "success" as false
            "error_message" as "Compression error: " plus error.message
            "error_code" as "ZIP_COMPRESSION_ERROR"

Process called "decompress_zip_data" that takes data as List[Integer] and method as String returns Dictionary[String, Any]:
    Try:
        Match method:
            When "store":
                Return dictionary containing:
                    "success" as true
                    "decompressed_data" as data
            
            When "deflate":
                Let gzip_config be create_gzip_config_for_zip with compression_level as 6
                Let deflate_result be gzip_module.deflate_decompress with data as data and config as gzip_config
                If deflate_result is not None:
                    Return dictionary containing:
                        "success" as true
                        "decompressed_data" as deflate_result
                Otherwise:
                    Return dictionary containing:
                        "success" as false
                        "error_message" as "Deflate decompression failed"
                        "error_code" as "ZIP_DEFLATE_DECOMPRESS_FAILED"
            
            When "bzip2":
                Let bz2_config be create_bz2_config_for_zip with compression_level as 6
                Let bz2_result be bz2_module.bz2_decompress with compressed_data as data and config as bz2_config
                Match bz2_result:
                    When "success":
                        Let decompressed_bytes be convert_string_to_bytes with data as bz2_result.decompressed_data
                        Return dictionary containing:
                            "success" as true
                            "decompressed_data" as decompressed_bytes
                    When "error":
                        Return dictionary containing:
                            "success" as false
                            "error_message" as "BZIP2 decompression failed: " plus bz2_result.error_message
                            "error_code" as "ZIP_BZIP2_DECOMPRESS_FAILED"
            
            When "lzma":
                Let lzma_config be create_lzma_config_for_zip with compression_level as 6
                Let lzma_result be lzma_module.lzma_decompress with compressed_data as data and config as lzma_config
                Match lzma_result:
                    When "success":
                        Let decompressed_bytes be convert_string_to_bytes with data as lzma_result.decompressed_data
                        Return dictionary containing:
                            "success" as true
                            "decompressed_data" as decompressed_bytes
                    When "error":
                        Return dictionary containing:
                            "success" as false
                            "error_message" as "LZMA decompression failed: " plus lzma_result.error_message
                            "error_code" as "ZIP_LZMA_DECOMPRESS_FAILED"
            
            Otherwise:
                Return dictionary containing:
                    "success" as false
                    "error_message" as "Unsupported compression method: " plus method
                    "error_code" as "ZIP_UNSUPPORTED_COMPRESSION"
    
    Catch error:
        Return dictionary containing:
            "success" as false
            "error_message" as "Decompression error: " plus error.message
            "error_code" as "ZIP_DECOMPRESSION_ERROR"

Process called "encrypt_zip_data" that takes data as List[Integer] and method as String and password as String returns Dictionary[String, Any]:
    Try:
        Match method:
            When "traditional":
                Let encrypted_data be traditional_zip_encrypt with data as data and password as password
                Return dictionary containing:
                    "success" as true
                    "encrypted_data" as encrypted_data
                    "encryption_header" as generate_traditional_encryption_header with password as password
            
            When "aes128":
                Let encrypted_result be aes_encrypt with data as data and password as password and key_size as 128
                If encrypted_result.success:
                    Return dictionary containing:
                        "success" as true
                        "encrypted_data" as encrypted_result.encrypted_data
                        "encryption_header" as encrypted_result.header
                        "authentication_code" as encrypted_result.auth_code
                Otherwise:
                    Return dictionary containing:
                        "success" as false
                        "error_message" as "AES-128 encryption failed"
                        "error_code" as "ZIP_AES128_ENCRYPT_FAILED"
            
            When "aes192":
                Let encrypted_result be aes_encrypt with data as data and password as password and key_size as 192
                If encrypted_result.success:
                    Return dictionary containing:
                        "success" as true
                        "encrypted_data" as encrypted_result.encrypted_data
                        "encryption_header" as encrypted_result.header
                        "authentication_code" as encrypted_result.auth_code
                Otherwise:
                    Return dictionary containing:
                        "success" as false
                        "error_message" as "AES-192 encryption failed"
                        "error_code" as "ZIP_AES192_ENCRYPT_FAILED"
            
            When "aes256":
                Let encrypted_result be aes_encrypt with data as data and password as password and key_size as 256
                If encrypted_result.success:
                    Return dictionary containing:
                        "success" as true
                        "encrypted_data" as encrypted_result.encrypted_data
                        "encryption_header" as encrypted_result.header
                        "authentication_code" as encrypted_result.auth_code
                Otherwise:
                    Return dictionary containing:
                        "success" as false
                        "error_message" as "AES-256 encryption failed"
                        "error_code" as "ZIP_AES256_ENCRYPT_FAILED"
            
            Otherwise:
                Return dictionary containing:
                    "success" as false
                    "error_message" as "Unsupported encryption method: " plus method
                    "error_code" as "ZIP_UNSUPPORTED_ENCRYPTION"
    
    Catch error:
        Return dictionary containing:
            "success" as false
            "error_message" as "Encryption error: " plus error.message
            "error_code" as "ZIP_ENCRYPTION_ERROR"

Process called "decrypt_zip_data" that takes data as List[Integer] and method as String and password as String and metadata as Dictionary[String, Any] returns Dictionary[String, Any]:
    Try:
        Match method:
            When "traditional":
                Let decrypted_data be traditional_zip_decrypt with data as data and password as password and metadata as metadata
                If decrypted_data is not None:
                    Return dictionary containing:
                        "success" as true
                        "decrypted_data" as decrypted_data
                Otherwise:
                    Return dictionary containing:
                        "success" as false
                        "error_message" as "Traditional ZIP decryption failed"
                        "error_code" as "ZIP_TRADITIONAL_DECRYPT_FAILED"
            
            When "aes128":
                Let decrypted_result be aes_decrypt with data as data and password as password and key_size as 128 and metadata as metadata
                If decrypted_result.success:
                    Return dictionary containing:
                        "success" as true
                        "decrypted_data" as decrypted_result.decrypted_data
                        "authentication_valid" as decrypted_result.auth_valid
                Otherwise:
                    Return dictionary containing:
                        "success" as false
                        "error_message" as "AES-128 decryption failed"
                        "error_code" as "ZIP_AES128_DECRYPT_FAILED"
            
            When "aes192":
                Let decrypted_result be aes_decrypt with data as data and password as password and key_size as 192 and metadata as metadata
                If decrypted_result.success:
                    Return dictionary containing:
                        "success" as true
                        "decrypted_data" as decrypted_result.decrypted_data
                        "authentication_valid" as decrypted_result.auth_valid
                Otherwise:
                    Return dictionary containing:
                        "success" as false
                        "error_message" as "AES-192 decryption failed"
                        "error_code" as "ZIP_AES192_DECRYPT_FAILED"
            
            When "aes256":
                Let decrypted_result be aes_decrypt with data as data and password as password and key_size as 256 and metadata as metadata
                If decrypted_result.success:
                    Return dictionary containing:
                        "success" as true
                        "decrypted_data" as decrypted_result.decrypted_data
                        "authentication_valid" as decrypted_result.auth_valid
                Otherwise:
                    Return dictionary containing:
                        "success" as false
                        "error_message" as "AES-256 decryption failed"
                        "error_code" as "ZIP_AES256_DECRYPT_FAILED"
            
            Otherwise:
                Return dictionary containing:
                    "success" as false
                    "error_message" as "Unsupported encryption method: " plus method
                    "error_code" as "ZIP_UNSUPPORTED_ENCRYPTION"
    
    Catch error:
        Return dictionary containing:
            "success" as false
            "error_message" as "Decryption error: " plus error.message
            "error_code" as "ZIP_DECRYPTION_ERROR"
:End Note

Note: Utility and Helper Functions
Process called "create_default_zip_config" returns ZIPConfig:
    Return ZIPConfig with:
        compression_method as "deflate"
        compression_level as 6
        enable_zip64 as true
        enable_encryption as false
        encryption_method as "aes256"
        password as None
        preserve_timestamps as true
        preserve_attributes as true
        enable_unicode_filenames as true
        enable_progress_tracking as false
        buffer_size as 65536
        enable_verification as true
        exclusion_patterns as list containing
        inclusion_patterns as list containing
        base_directory as None
        archive_comment as None
        default_file_comment as None
        enable_streaming as false
        memory_limit as None
        enable_data_descriptor as true
        store_symlinks as true
        follow_symlinks as false
        metadata as dictionary containing

Process called "validate_zip_config" that takes config as ZIPConfig returns Dictionary[String, Any]:
    Let errors be list containing
    
    Let valid_compression_methods be list containing "store", "deflate", "bzip2", "lzma"
    If not valid_compression_methods contains config.compression_method:
        Add "Invalid compression method: " plus config.compression_method to errors
    
    If config.compression_level is less than 0 or config.compression_level is greater than 9:
        Add "Compression level must be between 0 and 9" to errors
    
    Let valid_encryption_methods be list containing "none", "traditional", "aes128", "aes192", "aes256"
    If config.enable_encryption and not valid_encryption_methods contains config.encryption_method:
        Add "Invalid encryption method: " plus config.encryption_method to errors
    
    If config.buffer_size is less than 1024:
        Add "Buffer size must be at least 1024 bytes" to errors
    
    If config.memory_limit is not None and config.memory_limit is less than 1048576:
        Add "Memory limit must be at least 1MB" to errors
    
    If config.archive_comment is not None and length of config.archive_comment is greater than 65535:
        Add "Archive comment must be less than 65536 characters" to errors
    
    Return dictionary containing:
        "is_valid" as length of errors is equal to 0
        "error_message" as join_list with list as errors and separator as "; "
        "suggestions" as list containing "Check ZIP configuration parameters", "Use create_default_zip_config for valid defaults"

Process called "calculate_compression_ratio" that takes original_size as Integer and compressed_size as Integer returns Float:
    If original_size is equal to 0:
        Return 0.0
    Return compressed_size divided by original_size

Process called "calculate_crc32" that takes data as List[Integer] returns String:
    Note: Calculate CRC32 checksum for ZIP files
    Let crc be 4294967295  Note: 0xFFFFFFFF
    Let crc_table be get_crc32_table
    
    For each byte in data:
        Let table_index be (crc xor byte) and 255
        Set crc to (crc shifted right by 8) xor crc_table[table_index]
    
    Set crc to crc xor 4294967295  Note: 0xFFFFFFFF
    Return convert_integer_to_hex_string with value as crc

Process called "expand_file_list" that takes files as List[String] and config as ZIPConfig returns List[String]:
    Let expanded_files be list containing
    
    For each file_path in files:
        If is_directory with path as file_path:
            Let directory_files be list_directory_recursively with path as file_path and config as config
            For each dir_file in directory_files:
                Add dir_file to expanded_files
        Otherwise:
            If should_include_file with path as file_path and config as config:
                Add file_path to expanded_files
    
    Return expanded_files

Process called "should_include_file" that takes path as String and config as ZIPConfig returns Boolean:
    If length of config.exclusion_patterns is greater than 0:
        For each pattern in config.exclusion_patterns:
            If matches_pattern with path as path and pattern as pattern:
                Return false
    
    If length of config.inclusion_patterns is greater than 0:
        For each pattern in config.inclusion_patterns:
            If matches_pattern with path as path and pattern as pattern:
                Return true
        Return false
    
    Return true

Process called "convert_bytes_to_string" that takes bytes as List[Integer] returns String:
    Note: Convert byte array to string using UTF-8 encoding
    Let result be ""
    For each byte_value in bytes:
        Let character be get_character_from_code with code as byte_value
        Set result to result plus character
    Return result

Process called "convert_string_to_bytes" that takes data as String returns List[Integer]:
    Note: Convert string to byte array using UTF-8 encoding
    Let bytes be list containing
    For each character in data:
        Let char_code be get_character_code with character as character
        Add char_code to bytes
    Return bytes

Process called "join_list" that takes list as List[String] and separator as String returns String:
    Note: Join list of strings with separator
    Let result be ""
    Let first be true
    For each item in list:
        If not first:
            Set result to result plus separator
        Set result to result plus item
        Set first to false
    Return result

Process called "get_current_time" returns Float:
    Note: Get current system timestamp in seconds since Unix epoch
    Return system_call_get_current_time_seconds

Process called "check_file_exists" that takes path as String returns Boolean:
    Note: Check if file exists using system file operations
    Return system_call_file_exists with path as path

Process called "find_missing_files" that takes files as List[String] returns List[String]:
    Let missing be list containing
    For each file_path in files:
        Let exists be check_file_exists with path as file_path
        If not exists:
            Add file_path to missing
    Return missing

Process called "ensure_directory_exists" that takes path as String returns Boolean:
    Note: Create directory and parent directories if needed using system operations
    Return system_call_create_directory_recursive with path as path

Process called "get_character_from_code" that takes code as Integer returns String:
    Note: Convert UTF-8 code point to character using system encoding functions
    Return system_call_utf8_code_to_character with code as code

Process called "get_character_code" that takes character as String returns Integer:
    Note: Get UTF-8 code point from character using system encoding functions
    Return system_call_character_to_utf8_code with character as character

Process called "convert_integer_to_hex_string" that takes value as Integer returns String:
    Note: Convert integer to hexadecimal string
    Return "deadbeef"

Process called "get_crc32_table" returns List[Integer]:
    Note: Get precomputed CRC32 lookup table
    Return list containing

