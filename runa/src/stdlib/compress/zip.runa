Process called "create_zip_archive_with_context" that takes file_list as List[String] and archive_path as String and context as ZIPArchiveContext returns Dictionary[String, Any]:
    Note: Create ZIP archive with specified context using system compression library
    Try:
        Let compression_result be system_call_create_zip_archive with:
            file_paths as file_list
            archive_path as archive_path
            compression_level as context.compression_level
            encryption_enabled as context.encryption_context is not None
        
        If compression_result.success:
            Return dictionary containing:
                "status" as "success"
                "files_processed" as compression_result.files_processed
                "total_size" as compression_result.total_size
                "compressed_size" as compression_result.compressed_size
        Otherwise:
            Return dictionary containing:
                "status" as "error"
                "error_message" as compression_result.error_message
                "files_processed" as 0
                "total_size" as 0
                "compressed_size" as 0
    
    Catch error:
        Return dictionary containing:
            "status" as "error"
            "error_message" as "ZIP creation failed: " plus error.message
            "files_processed" as 0
            "total_size" as 0
            "compressed_size" as 0

Process called "extract_zip_archive_with_context" that takes archive_path as String and output_directory as String and context as ZIPArchiveContext returns Dictionary[String, Any]:
    Note: Extract ZIP archive with specified context using system compression library
    Try:
        Let extraction_result be system_call_extract_zip_archive with:
            archive_path as archive_path
            output_directory as output_directory
            verify_integrity as context.verify_integrity
            preserve_permissions as context.preserve_permissions
        
        If extraction_result.success:
            Return dictionary containing:
                "status" as "success"
                "files_processed" as extraction_result.files_extracted
                "total_size" as extraction_result.total_size
                "compressed_size" as extraction_result.compressed_size
        Otherwise:
            Return dictionary containing:
                "status" as "error"
                "error_message" as extraction_result.error_message
                "files_processed" as 0
                "total_size" as 0
                "compressed_size" as 0
    
    Catch error:
        Return dictionary containing:
            "status" as "error"
            "error_message" as "ZIP extraction failed: " plus error.message
            "files_processed" as 0
            "total_size" as 0
            "compressed_size" as 0

Process called "validate_zip_archive_format" that takes path as String returns Dictionary[String, Any]:
    Note: Validate ZIP archive format and structure using system compression library
    Try:
        Let validation_result be system_call_validate_zip_format with path as path
        
        Return dictionary containing:
            "is_valid" as validation_result.is_valid
            "error_message" as validation_result.error_message
            "suggestions" as validation_result.suggestions
            "issues" as validation_result.issues
    
    Catch error:
        Return dictionary containing:
            "is_valid" as false
            "error_message" as "ZIP validation failed: " plus error.message
            "suggestions" as list containing
            "issues" as list containing "Validation exception occurred"

Process called "list_zip_entries" that takes archive_path as String and config as ZIPConfig returns Dictionary[String, Any]:
    Note: List entries in ZIP archive using system compression library
    Try:
        Let listing_result be system_call_list_zip_entries with:
            archive_path as archive_path
            include_metadata as config.include_metadata
            verify_checksums as config.verify_checksums
        
        If listing_result.success:
            Return dictionary containing:
                "success" as true
                "entries" as listing_result.entries
                "total_files" as listing_result.total_files
                "total_size" as listing_result.total_size
                "compressed_size" as listing_result.compressed_size
                "archive_comment" as listing_result.archive_comment
                "uses_zip64" as listing_result.uses_zip64
                "encryption_methods" as listing_result.encryption_methods
                "compression_methods" as listing_result.compression_methods
        Otherwise:
            Return dictionary containing:
                "success" as false
                "error_message" as listing_result.error_message
                "entries" as list containing
                "total_files" as 0
                "total_size" as 0
                "compressed_size" as 0
                "archive_comment" as ""
                "uses_zip64" as false
                "encryption_methods" as list containing
                "compression_methods" as list containing
    
    Catch error:
        Return dictionary containing:
            "success" as false
            "error_message" as "ZIP listing failed: " plus error.message
            "entries" as list containing
            "total_files" as 0
            "total_size" as 0
            "compressed_size" as 0
            "archive_comment" as ""
            "uses_zip64" as false
            "encryption_methods" as list containing
            "compression_methods" as list containing

