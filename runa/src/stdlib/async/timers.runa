Note:
Runa Standard Library: Async Timers Module

Provides comprehensive timer and scheduling functionality for async applications
including one-shot timers, repeating timers, cron-like scheduling, and high-precision timing.

Features:
- High-precision timing with nanosecond accuracy
- One-shot and repeating timers
- Cron-like scheduling with complex patterns
- Timer pools and efficient management
- Callback and coroutine-based timers
- Timer statistics and monitoring
:End Note

Import "async.async" as async
Import "async.core" as core

Note: Timer Types
Type TimerType is:
    | ONE_SHOT
    | REPEATING
    | CRON_BASED
    | INTERVAL_BASED

Type TimerState is:
    | CREATED
    | RUNNING
    | PAUSED
    | CANCELLED
    | COMPLETED

Type called "AsyncTimer":
    timer_id as String
    timer_type as TimerType
    state as TimerState
    interval_ms as Float
    remaining_ms as Float
    callback as Optional[Process]
    coroutine as Optional[Process]
    repeat_count as Optional[Integer]
    remaining_repeats as Optional[Integer]
    created_time as Float
    last_execution_time as Optional[Float]
    total_executions as Integer
    metadata as Dictionary[String, Any]

Type called "CronSchedule":
    minute as String    Note: 0-59 or *
    hour as String      Note: 0-23 or *
    day as String       Note: 1-31 or *
    month as String     Note: 1-12 or *
    weekday as String   Note: 0-6 or *
    timezone as Optional[String]

Type called "TimerPool":
    pool_id as String
    active_timers as Dictionary[String, AsyncTimer]
    timer_heap as List[Tuple[Float, String]]  Note: (next_execution_time, timer_id)
    stats as TimerPoolStats
    running as Boolean

Type called "TimerPoolStats":
    total_timers_created as Integer
    total_timers_executed as Integer
    total_timers_cancelled as Integer
    active_timer_count as Integer
    average_execution_time_ns as Float
    peak_timer_count as Integer

Note: Timer Creation
Process called "create_timer" that takes timer_type as TimerType and interval_ms as Float returns AsyncTimer:
    Return AsyncTimer with:
        timer_id as generate_unique_id
        timer_type as timer_type
        state as CREATED
        interval_ms as interval_ms
        remaining_ms as interval_ms
        callback as None
        coroutine as None
        repeat_count as None
        remaining_repeats as None
        created_time as get_high_precision_time
        last_execution_time as None
        total_executions as 0
        metadata as dictionary containing

Process called "create_one_shot_timer" that takes delay_ms as Float and callback as Process returns AsyncTimer:
    Let timer be create_timer with timer_type as ONE_SHOT and interval_ms as delay_ms
    Set timer["callback"] to callback
    Return timer

Process called "create_repeating_timer" that takes interval_ms as Float and callback as Process and repeat_count as Optional[Integer] returns AsyncTimer:
    Let timer be create_timer with timer_type as REPEATING and interval_ms as interval_ms
    Set timer["callback"] to callback
    Set timer["repeat_count"] to repeat_count
    Set timer["remaining_repeats"] to repeat_count
    Return timer

Process called "create_cron_timer" that takes schedule as CronSchedule and callback as Process returns AsyncTimer:
    Let timer be create_timer with timer_type as CRON_BASED and interval_ms as 0.0
    Set timer["callback"] to callback
    Set timer["metadata"]["cron_schedule"] to schedule
    Set timer["remaining_ms"] to calculate_next_cron_execution with schedule as schedule
    Return timer

Async Process called "create_async_timer" that takes delay_ms as Float and coroutine as Process returns AsyncTimer:
    Let timer be create_timer with timer_type as ONE_SHOT and interval_ms as delay_ms
    Set timer["coroutine"] to coroutine
    Return timer

Note: Timer Management
Process called "start_timer" that takes timer as AsyncTimer returns None:
    If timer["state"] is not CREATED and timer["state"] is not PAUSED:
        Throw "Timer cannot be started in current state: " plus timer["state"]
    
    Set timer["state"] to RUNNING
    
    Note: Add to event loop or timer pool
    schedule_timer_execution with timer as timer

Process called "pause_timer" that takes timer as AsyncTimer returns None:
    If timer["state"] is not RUNNING:
        Throw "Timer is not running"
    
    Set timer["state"] to PAUSED

Process called "resume_timer" that takes timer as AsyncTimer returns None:
    If timer["state"] is not PAUSED:
        Throw "Timer is not paused"
    
    Set timer["state"] to RUNNING
    schedule_timer_execution with timer as timer

Process called "cancel_timer" that takes timer as AsyncTimer returns None:
    Set timer["state"] to CANCELLED

Process called "reset_timer" that takes timer as AsyncTimer returns None:
    Set timer["remaining_ms"] to timer["interval_ms"]
    Set timer["state"] to CREATED
    Set timer["total_executions"] to 0
    Set timer["last_execution_time"] to None
    
    If timer["timer_type"] is REPEATING and timer["repeat_count"] is not None:
        Set timer["remaining_repeats"] to timer["repeat_count"]

Note: Timer Pool Management
Process called "create_timer_pool" returns TimerPool:
    Return TimerPool with:
        pool_id as generate_unique_id
        active_timers as dictionary containing
        timer_heap as list containing
        stats as create_timer_pool_stats
        running as false

Process called "create_timer_pool_stats" returns TimerPoolStats:
    Return TimerPoolStats with:
        total_timers_created as 0
        total_timers_executed as 0
        total_timers_cancelled as 0
        active_timer_count as 0
        average_execution_time_ns as 0.0
        peak_timer_count as 0

Process called "add_timer_to_pool" that takes pool as TimerPool and timer as AsyncTimer returns None:
    Set pool["active_timers"][timer["timer_id"]] to timer
    
    Let execution_time be get_high_precision_time plus timer["remaining_ms"]
    Let heap_entry be tuple with execution_time and timer["timer_id"]
    heap_push with heap as pool["timer_heap"] and item as heap_entry
    
    Set pool["stats"]["total_timers_created"] to pool["stats"]["total_timers_created"] plus 1
    Set pool["stats"]["active_timer_count"] to pool["stats"]["active_timer_count"] plus 1
    
    If pool["stats"]["active_timer_count"] is greater than pool["stats"]["peak_timer_count"]:
        Set pool["stats"]["peak_timer_count"] to pool["stats"]["active_timer_count"]

Process called "remove_timer_from_pool" that takes pool as TimerPool and timer_id as String returns None:
    If timer_id is in pool["active_timers"]:
        Remove pool["active_timers"][timer_id]
        Set pool["stats"]["active_timer_count"] to pool["stats"]["active_timer_count"] minus 1
        
        Note: Remove from heap (lazy removal - will be filtered out during processing)
        Note: This is more efficient than rebuilding the heap

Process called "run_timer_pool" that takes pool as TimerPool returns None:
    Set pool["running"] to true
    
    While pool["running"]:
        process_timer_pool_tick with pool as pool
        sleep_precise with duration_ms as 1.0  Note: 1ms precision

Process called "process_timer_pool_tick" that takes pool as TimerPool returns None:
    Let current_time be get_high_precision_time
    Let executed_timers be list containing
    
    Note: Process all timers ready for execution
    While length of pool["timer_heap"] is greater than 0:
        Let next_entry be heap_peek with heap as pool["timer_heap"]
        Let execution_time be next_entry[0]
        Let timer_id be next_entry[1]
        
        If execution_time is greater than current_time:
            Break loop  Note: No more timers ready
        
        heap_pop with heap as pool["timer_heap"]
        
        Note: Check if timer still exists (lazy removal)
        If timer_id is not in pool["active_timers"]:
            Continue loop
        
        Let timer be pool["active_timers"][timer_id]
        
        If timer["state"] is RUNNING:
            execute_timer with pool as pool and timer as timer
            Add timer to executed_timers
    
    Note: Reschedule repeating timers
    For each timer in executed_timers:
        If timer["timer_type"] is REPEATING and timer["state"] is not CANCELLED:
            If timer["remaining_repeats"] is None or timer["remaining_repeats"] is greater than 0:
                reschedule_repeating_timer with pool as pool and timer as timer
        Otherwise if timer["timer_type"] is CRON_BASED and timer["state"] is not CANCELLED:
            reschedule_cron_timer with pool as pool and timer as timer

Note: Timer Execution
Process called "execute_timer" that takes pool as TimerPool and timer as AsyncTimer returns None:
    Let execution_start be get_high_precision_time_ns
    
    Try:
        If timer["callback"] is not None:
            timer["callback"] with timer as timer
        
        If timer["coroutine"] is not None:
            Note: Schedule coroutine for async execution
            let task be async.create_task with coroutine as timer["coroutine"] and loop as get_current_loop
            start_task with task as task
        
        Set timer["total_executions"] to timer["total_executions"] plus 1
        Set timer["last_execution_time"] to get_high_precision_time
        
        Note: Update statistics
        Set pool["stats"]["total_timers_executed"] to pool["stats"]["total_timers_executed"] plus 1
        
        Let execution_end be get_high_precision_time_ns
        Let execution_time_ns be execution_end minus execution_start
        update_average_execution_time with stats as pool["stats"] and execution_time as execution_time_ns
        
    Catch error:
        handle_timer_error with pool as pool and timer as timer and error as error
    
    Note: Handle one-shot timer completion
    If timer["timer_type"] is ONE_SHOT:
        Set timer["state"] to COMPLETED
        remove_timer_from_pool with pool as pool and timer_id as timer["timer_id"]
    
    Note: Handle repeating timer count
    If timer["timer_type"] is REPEATING and timer["remaining_repeats"] is not None:
        Set timer["remaining_repeats"] to timer["remaining_repeats"] minus 1
        If timer["remaining_repeats"] is less than or equal to 0:
            Set timer["state"] to COMPLETED
            remove_timer_from_pool with pool as pool and timer_id as timer["timer_id"]

Process called "reschedule_repeating_timer" that takes pool as TimerPool and timer as AsyncTimer returns None:
    Let next_execution_time be get_high_precision_time plus timer["interval_ms"]
    Let heap_entry be tuple with next_execution_time and timer["timer_id"]
    heap_push with heap as pool["timer_heap"] and item as heap_entry

Process called "reschedule_cron_timer" that takes pool as TimerPool and timer as AsyncTimer returns None:
    Let schedule be timer["metadata"]["cron_schedule"]
    Let next_execution_delay be calculate_next_cron_execution with schedule as schedule
    Let next_execution_time be get_high_precision_time plus next_execution_delay
    Let heap_entry be tuple with next_execution_time and timer["timer_id"]
    heap_push with heap as pool["timer_heap"] and item as heap_entry

Note: Cron Scheduling
Process called "calculate_next_cron_execution" that takes schedule as CronSchedule returns Float:
    Let current_time be get_current_datetime
    Let next_time be find_next_cron_time with schedule as schedule and from_time as current_time
    Return datetime_to_milliseconds with datetime as next_time minus current_time

Process called "find_next_cron_time" that takes schedule as CronSchedule and from_time as DateTime returns DateTime:
    Note: Complete cron implementation supporting all standard cron expressions
    Note: Handles *, numbers, ranges (1-5), lists (1,3,5), and step values (*/2)
    
    Let start_time be from_time
    Let candidate_time be add_seconds with datetime as start_time and seconds as 60  Note: Start from next minute
    Let max_iterations be 4 times 366 times 24 times 60  Note: Prevent infinite loops (4 years max)
    Let iterations be 0
    
    While iterations is less than max_iterations:
        Set iterations to iterations plus 1
        
        Let current_minute be get_minute with datetime as candidate_time
        Let current_hour be get_hour with datetime as candidate_time
        Let current_day be get_day with datetime as candidate_time
        Let current_month be get_month with datetime as candidate_time
        Let current_year be get_year with datetime as candidate_time
        Let current_weekday be get_weekday with datetime as candidate_time
        
        Note: Check if current time matches all cron fields
        Let minute_matches be cron_field_matches with field as schedule["minute"] and value as current_minute and max as 59
        Let hour_matches be cron_field_matches with field as schedule["hour"] and value as current_hour and max as 23
        Let day_matches be cron_field_matches with field as schedule["day"] and value as current_day and max as 31
        Let month_matches be cron_field_matches with field as schedule["month"] and value as current_month and max as 12
        Let weekday_matches be cron_field_matches with field as schedule["weekday"] and value as current_weekday and max as 6
        
        Note: Handle day OR weekday logic (standard cron behavior)
        Let day_or_weekday_matches be day_matches or weekday_matches
        If schedule["day"] is equal to "*" and schedule["weekday"] is not equal to "*":
            Set day_or_weekday_matches to weekday_matches
        Otherwise if schedule["day"] is not equal to "*" and schedule["weekday"] is equal to "*":
            Set day_or_weekday_matches to day_matches
        
        If minute_matches and hour_matches and month_matches and day_or_weekday_matches:
            Return create_datetime with year as current_year and month as current_month and day as current_day and hour as current_hour and minute as current_minute and second as 0
        
        Note: Advance to next minute
        Set candidate_time to add_seconds with datetime as candidate_time and seconds as 60
    
    Note: Fallback if no match found within reasonable time
    Return add_seconds with datetime as from_time and seconds as 3600  Note: 1 hour later

Process called "cron_field_matches" that takes field as String and value as Integer and max as Integer returns Boolean:
    Note: Check if value matches cron field expression
    If field is equal to "*":
        Return true
    
    Note: Handle numeric value
    If field contains only digits:
        Let field_value be parse_integer with string as field
        Return value is equal to field_value
    
    Note: Handle comma-separated lists (e.g., "1,3,5")
    If field contains ",":
        Let values be split_string with string as field and delimiter as ","
        For each item in values:
            Let item_value be parse_integer with string as trim_string with string as item
            If value is equal to item_value:
                Return true
        Return false
    
    Note: Handle ranges (e.g., "1-5")
    If field contains "-":
        Let parts be split_string with string as field and delimiter as "-"
        If length of parts is equal to 2:
            Let start_val be parse_integer with string as trim_string with string as parts at index 0
            Let end_val be parse_integer with string as trim_string with string as parts at index 1
            Return value is greater than or equal to start_val and value is less than or equal to end_val
    
    Note: Handle step values (e.g., "*/2", "0-10/3")
    If field contains "/":
        Let parts be split_string with string as field and delimiter as "/"
        If length of parts is equal to 2:
            Let step be parse_integer with string as trim_string with string as parts at index 1
            Let base_field be trim_string with string as parts at index 0
            
            If base_field is equal to "*":
                Return value modulo step is equal to 0
            Otherwise if base_field contains "-":
                Let range_parts be split_string with string as base_field and delimiter as "-"
                If length of range_parts is equal to 2:
                    Let start_val be parse_integer with string as trim_string with string as range_parts at index 0
                    Let end_val be parse_integer with string as trim_string with string as range_parts at index 1
                    If value is greater than or equal to start_val and value is less than or equal to end_val:
                        Return (value minus start_val) modulo step is equal to 0
                Return false
            Otherwise:
                Let base_val be parse_integer with string as base_field
                Return value is greater than or equal to base_val and (value minus base_val) modulo step is equal to 0
    
    Note: Default fallback for unrecognized patterns
    Return false

Process called "parse_cron_field" that takes field as String and current as Integer and max as Integer returns Integer:
    If field is equal to "*":
        Return current plus 1  Note: Next occurrence
    Otherwise:
        Return parse_integer with string as field

Note: High-Precision Timing
Async Process called "sleep_precise" that takes duration_ms as Float returns None:
    Let start_time be get_high_precision_time_ns
    Let target_duration_ns be duration_ms times 1000000  Note: Convert to nanoseconds
    
    Note: Use busy wait for very short durations (< 1ms)
    If duration_ms is less than 1.0:
        While get_high_precision_time_ns minus start_time is less than target_duration_ns:
            yield_cpu_briefly
    Otherwise:
        Note: Use regular sleep for longer durations
        Await async.sleep with seconds as duration_ms divided by 1000.0

Process called "measure_execution_time" that takes operation as Process returns Dictionary[String, Float]:
    Let start_time be get_high_precision_time_ns
    Let result be operation
    Let end_time be get_high_precision_time_ns
    
    Return dictionary with:
        "execution_time_ns" as end_time minus start_time
        "execution_time_ms" as end_time minus start_time divided by 1000000.0
        "result" as result

Note: Timer Utilities
Process called "create_timeout" that takes timeout_ms as Float and operation as Process returns Process:
    Return Process called "timeout_wrapper" returns Any:
        Let timer be create_one_shot_timer with delay_ms as timeout_ms and callback as create_timeout_callback
        start_timer with timer as timer
        
        Try:
            Let result be operation
            cancel_timer with timer as timer
            Return result
        Catch error:
            cancel_timer with timer as timer
            Throw error

Process called "create_timeout_callback" returns Process:
    Return Process called "timeout_handler" that takes timer as AsyncTimer returns None:
        Throw "Operation timed out"

Process called "create_debounced_timer" that takes delay_ms as Float and callback as Process returns Process:
    Let last_timer be None
    
    Return Process called "debounced_operation" that takes args as List[Any] returns None:
        If last_timer is not None:
            cancel_timer with timer as last_timer
        
        Set last_timer to create_one_shot_timer with delay_ms as delay_ms and callback as callback
        start_timer with timer as last_timer

Process called "create_throttled_timer" that takes interval_ms as Float and callback as Process returns Process:
    Let last_execution be 0.0
    
    Return Process called "throttled_operation" that takes args as List[Any] returns None:
        Let current_time be get_high_precision_time
        
        If current_time minus last_execution is greater than interval_ms:
            Set last_execution to current_time
            callback with args as args

Note: Statistics and Monitoring
Process called "get_timer_pool_stats" that takes pool as TimerPool returns TimerPoolStats:
    Return pool["stats"]

Process called "update_average_execution_time" that takes stats as TimerPoolStats and execution_time as Float returns None:
    Let total_executions be stats["total_timers_executed"]
    If total_executions is greater than 0:
        Let current_average be stats["average_execution_time_ns"]
        Let new_average be current_average times total_executions minus 1 plus execution_time divided by total_executions
        Set stats["average_execution_time_ns"] to new_average

Process called "handle_timer_error" that takes pool as TimerPool and timer as AsyncTimer and error as String returns None:
    Display "Timer execution error in " plus timer["timer_id"] plus ": " plus error
    Set timer["state"] to CANCELLED
    remove_timer_from_pool with pool as pool and timer_id as timer["timer_id"]

Note: Utility Functions
Process called "schedule_timer_execution" that takes timer as AsyncTimer returns None:
    Note: Integration with event loop or timer pool
    Let pool be get_default_timer_pool
    add_timer_to_pool with pool as pool and timer as timer

Process called "get_default_timer_pool" returns TimerPool:
    Note: Singleton timer pool for application-wide timer management
    Try:
        Let global_pool be system_call_get_global_timer_pool
        If global_pool is not None:
            Return global_pool
        
        Note: Create new global pool if none exists
        Let new_pool be create_timer_pool with:
            pool_id as "global_default_pool"
            max_timers as 10000
            thread_pool_size as 4
            enable_statistics as true
            cleanup_interval_ms as 60000
        
        Let success be system_call_set_global_timer_pool with pool as new_pool
        Return new_pool
    Catch error:
        Note: Fallback to basic timer pool
        Return create_timer_pool with:
            pool_id as "fallback_pool"
            max_timers as 1000
            thread_pool_size as 2
            enable_statistics as false
            cleanup_interval_ms as 300000

Process called "heap_push" that takes heap as List[Tuple[Float, String]] and item as Tuple[Float, String] returns None:
    Note: Min-heap implementation for efficient timer scheduling
    Add item to end of heap
    heap_bubble_up with heap as heap and index as length of heap minus 1

Process called "heap_pop" that takes heap as List[Tuple[Float, String]] returns Optional[Tuple[Float, String]]:
    If length of heap is equal to 0:
        Return None
    
    Let result be heap at index 0
    Let last_item be heap at index length of heap minus 1
    Remove heap at index length of heap minus 1
    
    If length of heap is greater than 0:
        Set heap at index 0 to last_item
        heap_bubble_down with heap as heap and index as 0
    
    Return result

Process called "heap_peek" that takes heap as List[Tuple[Float, String]] returns Optional[Tuple[Float, String]]:
    If length of heap is greater than 0:
        Return heap at index 0
    Return None