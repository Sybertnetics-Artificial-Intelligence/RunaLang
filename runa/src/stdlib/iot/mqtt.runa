    Let random_component be generate_secure_random_string with length as 10
    Return "mqtt_analytics_" Joined with timestamp Joined with "_" Joined with random_component

Process called "generate_unique_security_manager_id" returns String:
    Let timestamp be get_current_timestamp
    Let random_component be generate_secure_random_string with length as 10
    Return "mqtt_security_" Joined with timestamp Joined with "_" Joined with random_component

Process called "get_current_timestamp" returns Float:
    Return get_system_time_microseconds divided by 1000000.0