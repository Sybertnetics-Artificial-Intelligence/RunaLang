    cached_responses as Dictionary[String, CachedResponse]
    security_config as CoAPSecurity
    performance_metrics as ServerMetrics
    proxy_config as ProxyConfig
    multicast_groups as List[MulticastGroup]
    dtls_sessions as Dictionary[String, DTLSSession]
