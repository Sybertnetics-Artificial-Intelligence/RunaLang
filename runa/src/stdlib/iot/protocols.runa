        ml_path_predictor as ml_path_predictor
        adaptive_algorithms as adaptive_algorithms
        performance_monitor as performance_monitor
        ai_optimization_enabled as routing_config["ai_optimization"] or true
        multi_objective_optimization as routing_config["multi_objective"] or true
        dynamic_adaptation as routing_config["dynamic_adaptation"] or true
        predictive_routing as routing_config["predictive_routing"] or true
        load_balancing_strategy as routing_config["load_balancing"] or "intelligent"
        fault_tolerance_mode as routing_config["fault_tolerance"] or "proactive"
        energy_awareness as routing_config["energy_aware"] or true
