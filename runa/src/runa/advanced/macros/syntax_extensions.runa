            token_patterns as list containing
            token_actions as dictionary containing
            metadata as dictionary containing
        error_handler as ExtensionErrorHandler with:
            handler_id as "default_error_handler"
            error_types as list containing
            recovery_strategies as dictionary containing
            metadata as dictionary containing
        metadata as dictionary containing

