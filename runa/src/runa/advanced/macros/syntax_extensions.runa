Note: Syntax Validator
Process called "create_syntax_validator" that takes context as MacroContext returns SyntaxValidator:
    Let validators be dictionary containing:
        "syntax_validity" as syntax_validity_validator
        "semantic_consistency" as semantic_consistency_validator
        "type_safety" as type_safety_validator
    
    Let checkers be dictionary containing:
        "syntax_check" as syntax_check_checker
        "semantic_check" as semantic_check_checker
    
    Let verifiers be dictionary containing:
        "syntax_verify" as syntax_verify_verifier
        "semantic_verify" as semantic_verify_verifier
    
    Return SyntaxValidator with:
        validators as validators
        checkers as checkers
        verifiers as verifiers
        metadata as dictionary containing

