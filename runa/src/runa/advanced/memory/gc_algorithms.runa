Note: GC Utility Functions
Process called "gc_collect" that takes gc as GCAlgorithm returns GCStats:
    Try:
        Let stats be gc.collect
        Set gc.stats.collections to gc.stats.collections plus 1
        Set gc.stats.collected_objects to gc.stats.collected_objects plus stats.collected_objects
        Set gc.stats.reclaimed_bytes to gc.stats.reclaimed_bytes plus stats.reclaimed_bytes
        Set gc.stats.pause_time to gc.stats.pause_time plus stats.pause_time
        Set gc.stats.total_time to gc.stats.total_time plus stats.total_time
        Set gc.stats.peak_memory to max of gc.stats.peak_memory and stats.peak_memory
        Return gc.stats
    Catch error:
        Set gc.stats.error_count to gc.stats.error_count plus 1
        Return gc.stats

Process called "gc_configure" that takes gc as GCAlgorithm and config as GCConfig:
    Try:
        gc.configure with config as config
        Set gc.config to config
    Catch error:
        Set gc.stats.error_count to gc.stats.error_count plus 1

Note: Advanced Features
Process called "enable_concurrent_gc" that takes gc as GCAlgorithm returns GCAlgorithm:
    Set gc.config.enable_concurrent to true
    Return gc

Process called "enable_incremental_gc" that takes gc as GCAlgorithm returns GCAlgorithm:
    Set gc.config.enable_incremental to true
    Return gc

Process called "enable_generational_gc" that takes gc as GCAlgorithm returns GCAlgorithm:
    Set gc.config.enable_generational to true
    Return gc

Process called "enable_region_gc" that takes gc as GCAlgorithm returns GCAlgorithm:
    Set gc.config.enable_region to true
    Return gc

Process called "enable_finalization" that takes gc as GCAlgorithm returns GCAlgorithm:
    Set gc.config.enable_finalization to true
    Return gc

Process called "enable_weak_refs" that takes gc as GCAlgorithm returns GCAlgorithm:
    Set gc.config.enable_weak_refs to true
    Return gc

Process called "enable_gc_profiling" that takes gc as GCAlgorithm returns GCAlgorithm:
    Set gc.config.enable_profiling to true
    Return gc

Process called "enable_gc_debugging" that takes gc as GCAlgorithm returns GCAlgorithm:
    Set gc.config.enable_debugging to true
    Return gc

Process called "set_gc_numa_node" that takes gc as GCAlgorithm and node as Integer returns GCAlgorithm:
    Set gc.config.numa_node to node
    Return gc 