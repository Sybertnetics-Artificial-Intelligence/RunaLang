Import module "core/plugin_shared"

Note:
Runa Advanced Standard Library: Plugin Architecture Module

Defines the architecture and design patterns for robust, extensible, and secure plugin systems.

Features:
- Modular plugin system design
- Extension points and hooks
- Dependency management and resolution
- Plugin isolation and sandboxing
- Versioning, compatibility, and upgrade
- Error handling, validation, and debugging
- AI/agent-friendly APIs
- Production-ready, robust, and extensible
:End Note

Note: Plugin Architecture Types and Interfaces
Type PluginSystem is Dictionary with:
    plugins as Dictionary[String, Plugin]
    extension_points as Dictionary[String, ExtensionPoint]
    dependencies as Dictionary[String, List[String]]
    isolation_manager as PluginIsolationManager
    version_manager as PluginVersionManager
    metadata as Dictionary[String, Any]

Type ExtensionPoint is Dictionary with:
    extension_id as String
    name as String
    description as String
    register as Function that takes extension as Any returns None
    unregister as Function that takes extension_id as String returns None
    metadata as Dictionary[String, Any]

Type PluginIsolationManager is Dictionary with:
    isolate_plugin as Function that takes plugin_id as String returns Boolean
    release_plugin as Function that takes plugin_id as String returns Boolean
    metadata as Dictionary[String, Any]

Type PluginVersionManager is Dictionary with:
    check_compatibility as Function that takes plugin as Plugin returns Boolean
    upgrade_plugin as Function that takes plugin_id as String and new_version as String returns Boolean
    metadata as Dictionary[String, Any]

Note: Internal State for Architecture Management
Let _extension_registry be Dictionary[String, ExtensionPoint] containing
Let _dependency_graph be Dictionary[String, List[String]] containing
Let _isolation_state be Dictionary[String, Boolean] containing
Let _version_state be Dictionary[String, String] containing
Let _extension_locks be Dictionary[String, Lock] containing

Note: Advanced Extension Point System
Type ExtensionPointSchema is Dictionary with:
    extension_point_id as String
    name as String
    description as String
    schema as JSONSchema
    required_attributes as List[String]
    optional_attributes as List[String]
    child_elements as List[ExtensionElementSchema]
    metadata as Dictionary[String, Any]

Type ExtensionElementSchema is Dictionary with:
    name as String
    type as String
    required as Boolean
    metadata as Dictionary[String, Any]

Process called "create_extension_point_with_schema" that takes id as String and schema as ExtensionPointSchema returns ExtensionPoint:
    Let extension_point be ExtensionPoint with:
        extension_id as id
        name as schema.name
        description as schema.description
        register as function(extension):
            validate_extension_against_schema(extension, schema)
            register_validated_extension(id, extension)
        unregister as function(extension_id):
            unregister_extension_safely(id, extension_id)
        metadata as schema.metadata
    Set _extension_registry[id] to extension_point
    Return extension_point

Note: Core Plugin Architecture Functions
Process called "create_plugin_system" returns PluginSystem:
    Return PluginSystem with:
        plugins as dictionary containing
        extension_points as _extension_registry
        dependencies as _dependency_graph
        isolation_manager as create_plugin_isolation_manager()
        version_manager as create_plugin_version_manager()
        metadata as dictionary containing

Process called "register_extension_point" that takes system as PluginSystem and extension_point as ExtensionPoint returns Boolean:
    If extension_point.extension_id in system.extension_points:
        Return false
    Set system.extension_points[extension_point.extension_id] to extension_point
    Return true

Process called "resolve_plugin_dependencies" that takes system as PluginSystem and plugin_id as String returns Boolean:
    If plugin_id not in system.plugins:
        Return false
    Let dependencies be system.dependencies.get(plugin_id, list containing)
    For each dep_id in dependencies:
        If dep_id not in system.plugins:
            Throw DependencyResolutionError with message "Missing dependency: " plus dep_id
    Return true

Process called "isolate_plugin" that takes system as PluginSystem and plugin_id as String returns Boolean:
    If plugin_id not in system.plugins:
        Return false
    Acquire _extension_locks[plugin_id]
    Set _isolation_state[plugin_id] to true
    Release _extension_locks[plugin_id]
    Return system.isolation_manager.isolate_plugin with plugin_id as plugin_id

Process called "release_plugin" that takes system as PluginSystem and plugin_id as String returns Boolean:
    If plugin_id not in system.plugins:
        Return false
    Acquire _extension_locks[plugin_id]
    Set _isolation_state[plugin_id] to false
    Release _extension_locks[plugin_id]
    Return system.isolation_manager.release_plugin with plugin_id as plugin_id

Process called "check_plugin_compatibility" that takes system as PluginSystem and plugin as Plugin returns Boolean:
    Return system.version_manager.check_compatibility with plugin as plugin

Process called "upgrade_plugin" that takes system as PluginSystem and plugin_id as String and new_version as String returns Boolean:
    If plugin_id not in system.plugins:
        Return false
    Acquire _extension_locks[plugin_id]
    Set _version_state[plugin_id] to new_version
    Release _extension_locks[plugin_id]
    Return system.version_manager.upgrade_plugin with plugin_id as plugin_id and new_version as new_version

Process called "create_plugin_isolation_manager" returns PluginIsolationManager:
    Return PluginIsolationManager with:
        isolate_plugin as function(plugin_id):
            Set _isolation_state[plugin_id] to true
            Return true
        release_plugin as function(plugin_id):
            Set _isolation_state[plugin_id] to false
            Return true
        metadata as dictionary containing

Process called "create_plugin_version_manager" returns PluginVersionManager:
    Return PluginVersionManager with:
        check_compatibility as function(plugin):
            Let current_version be _version_state.get(plugin.plugin_id, plugin.version)
            Return is_compatible_version(plugin.version, current_version)
        upgrade_plugin as function(plugin_id, new_version):
            Set _version_state[plugin_id] to new_version
            Return true
        metadata as dictionary containing 