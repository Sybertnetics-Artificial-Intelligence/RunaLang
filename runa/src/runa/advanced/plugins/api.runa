Process called "create_comprehensive_plugin_api" returns PluginAPI:
    Return PluginAPI with:
        ui as create_ui_extension_api()
        editor as create_editor_extension_api()
        workspace as create_workspace_extension_api()
        language as create_language_extension_api()
        debug as create_debug_extension_api()
