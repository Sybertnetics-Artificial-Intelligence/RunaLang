Note: Advanced Decision Tree System for AI Agents
Note: Implements decision trees, random forests, gradient boosting,
Note: ensemble methods, feature selection, and tree interpretation
Note: Competitive with scikit-learn, XGBoost, LightGBM, and CatBoost

Note: Core decision tree types
Type DecisionTree is Dictionary with:
    tree id as String
    tree type as String  Note: "classification", "regression", "survival", "multi_output"
    root node as TreeNode
    feature names as List[String]
    feature importance as Dictionary[String, Float]
    tree depth as Integer
    node count as Integer
    leaf count as Integer
    tree properties as Dictionary
    training metrics as Dictionary

Type TreeNode is Dictionary with:
    node id as String
    node type as String  Note: "internal", "leaf"
    split feature as String
    split threshold as Float
    split criterion as String  Note: "gini", "entropy", "mse", "mae"
    split gain as Float
    samples count as Integer
    class distribution as Dictionary[String, Integer]
    prediction as Float
    prediction confidence as Float
    left child as TreeNode
    right child as TreeNode
    depth as Integer

Type RandomForest is Dictionary with:
    forest id as String
    forest type as String  Note: "classification", "regression"
    decision trees as List[DecisionTree]
    tree count as Integer
    feature sampling rate as Float
    sample sampling rate as Float
    max features as Integer
    bootstrap sampling as Boolean
    out of bag score as Float
    feature importance as Dictionary[String, Float]

Type GradientBoostingModel is Dictionary with:
    model id as String
    model type as String  Note: "gradient_boosting", "xgboost", "lightgbm"
    base learners as List[DecisionTree]
    learning rate as Float
    max iterations as Integer
    loss function as String
    regularization as Dictionary
    early stopping as Dictionary
    validation scores as List[Float]
    feature importance as Dictionary[String, Float]

Type TreeEnsemble is Dictionary with:
    ensemble id as String
    ensemble type as String  Note: "bagging", "boosting", "stacking", "voting"
    component models as List[DecisionTree]
    voting strategy as String  Note: "majority", "weighted", "probability"
    model weights as List[Float]
    combination method as String
    ensemble performance as Dictionary
    diversity measures as Dictionary

Type FeatureSelection is Dictionary with:
    selection id as String
    selection method as String  Note: "univariate", "recursive", "tree_based", "permutation"
    selected features as List[String]
    feature scores as Dictionary[String, Float]
    selection threshold as Float
    importance ranking as List[String]
    cross validation scores as Dictionary

Note: Basic Decision Tree Construction
Process called "create_decision_tree" that takes config as Dictionary returns DecisionTree:
    Let tree be create_decision_tree_structure
    Set tree with field tree_id to generate_tree_id
    Set tree with field tree_type to config with key "type" or "classification"
    Set tree with field feature_names to config with key "features"
    Set tree with field tree_depth to 0
    Set tree with field node_count to 0
    Set tree with field leaf_count to 0
    Set tree with field tree_properties to config with key "properties" or empty dictionary
    Set tree with field training_metrics to empty dictionary
    Set tree with field feature_importance to empty dictionary
    
    Return tree

Process called "build_decision_tree" that takes training_data as Dataset and tree_config as Dictionary returns DecisionTree:
    Let tree be create_decision_tree with tree_config
    Let max_depth be tree_config with key "max_depth" or 10
    Let min_samples_split be tree_config with key "min_samples_split" or 2
    Let min_samples_leaf be tree_config with key "min_samples_leaf" or 1
    Let criterion be tree_config with key "criterion" or "gini"
    
    Note: Extract features and targets from training data
    Let features be training_data with field features
    Let targets be training_data with field targets
    Let feature_names be training_data with field feature_names
    
    Note: Build tree recursively starting from root
    Let root_node be build_tree_recursive with features and targets and feature_names and criterion and max_depth and min_samples_split and min_samples_leaf and 0
    Set tree with field root_node to root_node
    
    Note: Calculate tree statistics
    Let tree_stats be calculate_tree_statistics with root_node
    Set tree with field tree_depth to tree_stats with key "depth"
    Set tree with field node_count to tree_stats with key "node_count"
    Set tree with field leaf_count to tree_stats with key "leaf_count"
    
    Note: Calculate feature importance
    Let importance_scores be calculate_feature_importance with root_node and feature_names
    Set tree with field feature_importance to importance_scores
    
    Return tree

Process called "build_tree_recursive" that takes features as Matrix and targets as Vector and feature_names as List[String] and criterion as String and max_depth as Integer and min_samples_split as Integer and min_samples_leaf as Integer and current_depth as Integer returns TreeNode:
    Let node be create_tree_node_structure
    Set node with field node_id to generate_node_id
    Set node with field depth to current_depth
    Set node with field samples_count to length of targets
    
    Note: Calculate class distribution for classification
    Let class_distribution be calculate_class_distribution with targets
    Set node with field class_distribution to class_distribution
    
    Note: Check stopping criteria
    If current_depth is greater than or equal to max_depth:
        Return create_leaf_node with node and targets and class_distribution
    
    If length of targets is less than min_samples_split:
        Return create_leaf_node with node and targets and class_distribution
    
    If is_pure_node with targets:
        Return create_leaf_node with node and targets and class_distribution
    
    Note: Find best split
    Let best_split be find_best_split with features and targets and feature_names and criterion
    
    If best_split with key "gain" is less than or equal to 0.0:
        Return create_leaf_node with node and targets and class_distribution
    
    Note: Create internal node with split
    Set node with field node_type to "internal"
    Set node with field split_feature to best_split with key "feature"
    Set node with field split_threshold to best_split with key "threshold"
    Set node with field split_criterion to criterion
    Set node with field split_gain to best_split with key "gain"
    
    Note: Split data based on best split
    Let split_data be split_dataset with features and targets and best_split
    Let left_features be split_data with key "left_features"
    Let left_targets be split_data with key "left_targets"
    Let right_features be split_data with key "right_features"
    Let right_targets be split_data with key "right_targets"
    
    Note: Check minimum samples in leaf
    If length of left_targets is less than min_samples_leaf or length of right_targets is less than min_samples_leaf:
        Return create_leaf_node with node and targets and class_distribution
    
    Note: Recursively build child nodes
    Let left_child be build_tree_recursive with left_features and left_targets and feature_names and criterion and max_depth and min_samples_split and min_samples_leaf and (current_depth plus 1)
    Let right_child be build_tree_recursive with right_features and right_targets and feature_names and criterion and max_depth and min_samples_split and min_samples_leaf and (current_depth plus 1)
    
    Set node with field left_child to left_child
    Set node with field right_child to right_child
    
    Return node

Process called "find_best_split" that takes features as Matrix and targets as Vector and feature_names as List[String] and criterion as String returns Dictionary:
    Let best_gain be 0.0
    Let best_feature be empty string
    Let best_threshold be 0.0
    Let best_split_info be empty dictionary
    
    Note: Calculate current node impurity
    Let current_impurity be calculate_impurity with targets and criterion
    
    Note: Try each feature for splitting
    For feature_index from 0 to length of feature_names minus 1:
        Let feature_name be feature_names with index feature_index
        Let feature_values be extract_column with features and feature_index
        
        Note: Get unique values to try as thresholds
        Let unique_values be get_unique_sorted_values with feature_values
        
        Note: Try each unique value as potential threshold
        For value_index from 0 to length of unique_values minus 2:
            Let threshold be (unique_values with index value_index plus unique_values with index (value_index plus 1)) divided by 2.0
            
            Note: Split data based on threshold
            Let split_indices be split_by_threshold with feature_values and threshold
            Let left_indices be split_indices with key "left"
            Let right_indices be split_indices with key "right"
            
            If length of left_indices is equal to 0 or length of right_indices is equal to 0:
                Continue to next iteration
            
            Note: Calculate weighted impurity after split
            Let left_targets be extract_subset with targets and left_indices
            Let right_targets be extract_subset with targets and right_indices
            
            Let left_impurity be calculate_impurity with left_targets and criterion
            Let right_impurity be calculate_impurity with right_targets and criterion
            
            Let left_weight be length of left_targets as Float divided by length of targets as Float
            Let right_weight be length of right_targets as Float divided by length of targets as Float
            
            Let weighted_impurity be (left_weight multiplied by left_impurity) plus (right_weight multiplied by right_impurity)
            Let information_gain be current_impurity minus weighted_impurity
            
            Note: Update best split if this is better
            If information_gain is greater than best_gain:
                Set best_gain to information_gain
                Set best_feature to feature_name
                Set best_threshold to threshold
                Set best_split_info to dictionary with keys "left_indices", "right_indices", "left_impurity", "right_impurity":
                    "left_indices" maps to left_indices
                    "right_indices" maps to right_indices
                    "left_impurity" maps to left_impurity
                    "right_impurity" maps to right_impurity
    
    Return dictionary with keys "feature", "threshold", "gain", "split_info":
        "feature" maps to best_feature
        "threshold" maps to best_threshold
        "gain" maps to best_gain
        "split_info" maps to best_split_info

Process called "calculate_impurity" that takes targets as Vector and criterion as String returns Float:
    If criterion is equal to "gini":
        Return calculate_gini_impurity with targets
    
    If criterion is equal to "entropy":
        Return calculate_entropy_impurity with targets
    
    If criterion is equal to "mse":
        Return calculate_mse_impurity with targets
    
    If criterion is equal to "mae":
        Return calculate_mae_impurity with targets
    
    Return 0.0  Note: Default fallback

Process called "calculate_gini_impurity" that takes targets as Vector returns Float:
    Let class_counts be count_class_occurrences with targets
    Let total_samples be length of targets as Float
    Let gini_impurity be 1.0
    
    For each class_label in keys of class_counts:
        Let class_count be class_counts with key class_label
        Let class_probability be class_count as Float divided by total_samples
        Set gini_impurity to gini_impurity minus (class_probability multiplied by class_probability)
    
    Return gini_impurity

Process called "calculate_entropy_impurity" that takes targets as Vector returns Float:
    Let class_counts be count_class_occurrences with targets
    Let total_samples be length of targets as Float
    Let entropy be 0.0
    
    For each class_label in keys of class_counts:
        Let class_count be class_counts with key class_label
        Let class_probability be class_count as Float divided by total_samples
        If class_probability is greater than 0.0:
            Set entropy to entropy minus (class_probability multiplied by logarithm_base_2 of class_probability)
    
    Return entropy

Note: Random Forest Implementation
Process called "create_random_forest" that takes config as Dictionary returns RandomForest:
    Let forest be create_random_forest_structure
    Set forest with field forest_id to generate_forest_id
    Set forest with field forest_type to config with key "type" or "classification"
    Set forest with field tree_count to config with key "n_estimators" or 100
    Set forest with field feature_sampling_rate to config with key "max_features_ratio" or 0.8
    Set forest with field sample_sampling_rate to config with key "bootstrap_ratio" or 1.0
    Set forest with field bootstrap_sampling to config with key "bootstrap" or true
    Set forest with field decision_trees to empty list
    Set forest with field out_of_bag_score to 0.0
    Set forest with field feature_importance to empty dictionary
    
    Return forest

Process called "train_random_forest" that takes forest as RandomForest and training_data as Dataset and forest_config as Dictionary returns RandomForest:
    Let tree_count be forest with field tree_count
    Let feature_sampling_rate be forest with field feature_sampling_rate
    Let bootstrap_sampling be forest with field bootstrap_sampling
    Let sample_count be length of training_data with field targets
    
    Note: Train individual trees
    For tree_index from 1 to tree_count:
        Note: Create bootstrap sample
        Let bootstrap_data be empty dataset
        If bootstrap_sampling is equal to true:
            Set bootstrap_data to create_bootstrap_sample with training_data
        Otherwise:
            Set bootstrap_data to training_data
        
        Note: Select random subset of features
        Let selected_features be select_random_features with training_data with field feature_names and feature_sampling_rate
        Let feature_subset_data be extract_feature_subset with bootstrap_data and selected_features
        
        Note: Configure tree for random forest
        Let tree_config be dictionary with keys "type", "max_depth", "min_samples_split", "min_samples_leaf", "criterion", "features":
            "type" maps to forest with field forest_type
            "max_depth" maps to forest_config with key "max_depth" or 10
            "min_samples_split" maps to forest_config with key "min_samples_split" or 2
            "min_samples_leaf" maps to forest_config with key "min_samples_leaf" or 1
            "criterion" maps to forest_config with key "criterion" or "gini"
            "features" maps to selected_features
        
        Note: Train individual tree
        Let tree be build_decision_tree with feature_subset_data and tree_config
        Add tree to forest with field decision_trees
    
    Note: Calculate feature importance across forest
    Let aggregated_importance be aggregate_feature_importance with forest with field decision_trees
    Set forest with field feature_importance to aggregated_importance
    
    Note: Calculate out-of-bag score if bootstrap sampling is used
    If bootstrap_sampling is equal to true:
        Let oob_score be calculate_out_of_bag_score with forest and training_data
        Set forest with field out_of_bag_score to oob_score
    
    Return forest

Process called "create_bootstrap_sample" that takes dataset as Dataset returns Dataset:
    Let sample_size be length of dataset with field targets
    Let bootstrap_indices be empty list
    
    Note: Sample with replacement
    For sample_index from 1 to sample_size:
        Let random_index be generate_random_integer between 0 and (sample_size minus 1)
        Add random_index to bootstrap_indices
    
    Note: Create new dataset with bootstrap samples
    Let bootstrap_features be extract_rows with dataset with field features and bootstrap_indices
    Let bootstrap_targets be extract_subset with dataset with field targets and bootstrap_indices
    
    Let bootstrap_dataset be create_dataset_structure
    Set bootstrap_dataset with field features to bootstrap_features
    Set bootstrap_dataset with field targets to bootstrap_targets
    Set bootstrap_dataset with field feature_names to dataset with field feature_names
    
    Return bootstrap_dataset

Process called "predict_random_forest" that takes forest as RandomForest and test_features as Matrix returns Vector:
    Let forest_type be forest with field forest_type
    Let decision_trees be forest with field decision_trees
    Let sample_count be length of test_features
    Let predictions be create_vector with sample_count
    
    Note: Get predictions from each tree
    For sample_index from 0 to sample_count minus 1:
        Let sample_features be test_features with index sample_index
        Let tree_predictions be empty list
        
        For each tree in decision_trees:
            Let tree_prediction be predict_decision_tree with tree and sample_features
            Add tree_prediction to tree_predictions
        
        Note: Aggregate predictions based on forest type
        Let final_prediction be 0.0
        If forest_type is equal to "classification":
            Set final_prediction to majority_vote with tree_predictions
        Otherwise:
            Set final_prediction to calculate_mean with tree_predictions
        
        Set predictions with index sample_index to final_prediction
    
    Return predictions

Note: Gradient Boosting Implementation
Process called "create_gradient_boosting_model" that takes config as Dictionary returns GradientBoostingModel:
    Let model be create_gradient_boosting_structure
    Set model with field model_id to generate_gradient_boosting_id
    Set model with field model_type to config with key "type" or "gradient_boosting"
    Set model with field learning_rate to config with key "learning_rate" or 0.1
    Set model with field max_iterations to config with key "n_estimators" or 100
    Set model with field loss_function to config with key "loss" or "deviance"
    Set model with field base_learners to empty list
    Set model with field validation_scores to empty list
    Set model with field feature_importance to empty dictionary
    
    Note: Initialize regularization parameters
    Set model with field regularization to dictionary with keys "subsample", "max_features", "min_samples_split":
        "subsample" maps to config with key "subsample" or 1.0
        "max_features" maps to config with key "max_features" or 1.0
        "min_samples_split" maps to config with key "min_samples_split" or 2
    
    Note: Initialize early stopping
    Set model with field early_stopping to dictionary with keys "enabled", "patience", "tolerance":
        "enabled" maps to config with key "early_stopping" or false
        "patience" maps to config with key "patience" or 10
        "tolerance" maps to config with key "tolerance" or 0.001
    
    Return model

Process called "train_gradient_boosting" that takes model as GradientBoostingModel and training_data as Dataset and validation_data as Dataset returns GradientBoostingModel:
    Let learning_rate be model with field learning_rate
    Let max_iterations be model with field max_iterations
    Let loss_function be model with field loss_function
    Let regularization be model with field regularization
    Let early_stopping be model with field early_stopping
    
    Let features be training_data with field features
    Let targets be training_data with field targets
    
    Note: Initialize predictions with mean/mode
    Let initial_prediction be calculate_initial_prediction with targets and loss_function
    Let current_predictions be create_vector_filled with length of targets and initial_prediction
    
    Let best_validation_score be positive_infinity
    Let patience_counter be 0
    
    Note: Gradient boosting main loop
    For iteration from 1 to max_iterations:
        Note: Calculate negative gradients (pseudo-residuals)
        Let negative_gradients be calculate_negative_gradients with targets and current_predictions and loss_function
        
        Note: Create subsample for this iteration
        Let subsample_ratio be regularization with key "subsample"
        Let subsample_data be create_subsample with features and negative_gradients and subsample_ratio
        
        Note: Configure weak learner (regression tree for gradients)
        Let weak_learner_config be dictionary with keys "type", "max_depth", "min_samples_split", "criterion":
            "type" maps to "regression"
            "max_depth" maps to 3  Note: Shallow trees for boosting
            "min_samples_split" maps to regularization with key "min_samples_split"
            "criterion" maps to "mse"
        
        Note: Train weak learner on gradients
        Let weak_learner be build_decision_tree with subsample_data and weak_learner_config
        Add weak_learner to model with field base_learners
        
        Note: Update predictions
        For sample_index from 0 to length of targets minus 1:
            Let sample_features be features with index sample_index
            Let weak_prediction be predict_decision_tree with weak_learner and sample_features
            Let updated_prediction be current_predictions with index sample_index plus (learning_rate multiplied by weak_prediction)
            Set current_predictions with index sample_index to updated_prediction
        
        Note: Evaluate on validation set if provided
        If validation_data is not equal to null:
            Let validation_score be evaluate_gradient_boosting with model and validation_data
            Add validation_score to model with field validation_scores
            
            Note: Check early stopping
            If early_stopping with key "enabled" is equal to true:
                If validation_score is less than best_validation_score minus early_stopping with key "tolerance":
                    Set best_validation_score to validation_score
                    Set patience_counter to 0
                Otherwise:
                    Set patience_counter to patience_counter plus 1
                    If patience_counter is greater than or equal to early_stopping with key "patience":
                        Break from loop
    
    Note: Calculate final feature importance
    Let aggregated_importance be aggregate_feature_importance with model with field base_learners
    Set model with field feature_importance to aggregated_importance
    
    Return model

Process called "calculate_negative_gradients" that takes targets as Vector and predictions as Vector and loss_function as String returns Vector:
    Let sample_count be length of targets
    Let gradients be create_vector with sample_count
    
    For sample_index from 0 to sample_count minus 1:
        Let target be targets with index sample_index
        Let prediction be predictions with index sample_index
        Let gradient be 0.0
        
        If loss_function is equal to "deviance":
            Note: For logistic loss (classification)
            Let probability be sigmoid_function with prediction
            Set gradient to target minus probability
        
        If loss_function is equal to "least_squares":
            Note: For squared loss (regression)
            Set gradient to target minus prediction
        
        If loss_function is equal to "least_absolute_deviation":
            Note: For absolute loss (regression)
            If target is greater than prediction:
                Set gradient to 1.0
            Otherwise if target is less than prediction:
                Set gradient to negative 1.0
            Otherwise:
                Set gradient to 0.0
        
        Set gradients with index sample_index to gradient
    
    Return gradients

Note: Tree Ensemble Methods
Process called "create_tree_ensemble" that takes config as Dictionary returns TreeEnsemble:
    Let ensemble be create_tree_ensemble_structure
    Set ensemble with field ensemble_id to generate_ensemble_id
    Set ensemble with field ensemble_type to config with key "type" or "bagging"
    Set ensemble with field component_models to empty list
    Set ensemble with field voting_strategy to config with key "voting" or "majority"
    Set ensemble with field model_weights to config with key "weights" or empty list
    Set ensemble with field combination_method to config with key "combination" or "average"
    Set ensemble with field ensemble_performance to empty dictionary
    Set ensemble with field diversity_measures to empty dictionary
    
    Return ensemble

Process called "train_ensemble" that takes ensemble as TreeEnsemble and training_data as Dataset and ensemble_config as Dictionary returns TreeEnsemble:
    Let ensemble_type be ensemble with field ensemble_type
    Let model_count be ensemble_config with key "n_models" or 10
    
    If ensemble_type is equal to "bagging":
        Return train_bagging_ensemble with ensemble and training_data and ensemble_config
    
    If ensemble_type is equal to "boosting":
        Return train_boosting_ensemble with ensemble and training_data and ensemble_config
    
    If ensemble_type is equal to "stacking":
        Return train_stacking_ensemble with ensemble and training_data and ensemble_config
    
    If ensemble_type is equal to "voting":
        Return train_voting_ensemble with ensemble and training_data and ensemble_config
    
    Return ensemble

Process called "train_bagging_ensemble" that takes ensemble as TreeEnsemble and training_data as Dataset and config as Dictionary returns TreeEnsemble:
    Let model_count be config with key "n_models" or 10
    Let component_models be empty list
    
    Note: Train multiple models on bootstrap samples
    For model_index from 1 to model_count:
        Let bootstrap_sample be create_bootstrap_sample with training_data
        
        Let tree_config be dictionary with keys "type", "max_depth", "min_samples_split", "criterion":
            "type" maps to config with key "tree_type" or "classification"
            "max_depth" maps to config with key "max_depth" or 10
            "min_samples_split" maps to config with key "min_samples_split" or 2
            "criterion" maps to config with key "criterion" or "gini"
        
        Let tree be build_decision_tree with bootstrap_sample and tree_config
        Add tree to component_models
    
    Set ensemble with field component_models to component_models
    
    Note: Calculate diversity measures
    Let diversity_measures be calculate_ensemble_diversity with component_models and training_data
    Set ensemble with field diversity_measures to diversity_measures
    
    Return ensemble

Note: Feature Selection for Trees
Process called "create_feature_selection" that takes config as Dictionary returns FeatureSelection:
    Let selection be create_feature_selection_structure
    Set selection with field selection_id to generate_selection_id
    Set selection with field selection_method to config with key "method" or "tree_based"
    Set selection with field selection_threshold to config with key "threshold" or 0.01
    Set selection with field selected_features to empty list
    Set selection with field feature_scores to empty dictionary
    Set selection with field importance_ranking to empty list
    
    Return selection

Process called "select_features_tree_based" that takes training_data as Dataset and selection_config as Dictionary returns FeatureSelection:
    Let selection be create_feature_selection with selection_config
    
    Note: Train a tree model to get feature importance
    Let tree_config be dictionary with keys "type", "max_depth", "criterion":
        "type" maps to "classification"
        "max_depth" maps to selection_config with key "max_depth" or 10
        "criterion" maps to selection_config with key "criterion" or "gini"
    
    Let tree be build_decision_tree with training_data and tree_config
    Let feature_importance be tree with field feature_importance
    Set selection with field feature_scores to feature_importance
    
    Note: Rank features by importance
    Let sorted_features be sort_features_by_importance with feature_importance
    Set selection with field importance_ranking to sorted_features
    
    Note: Select features above threshold
    Let threshold be selection with field selection_threshold
    Let selected_features be empty list
    For each feature_name in sorted_features:
        Let importance_score be feature_importance with key feature_name
        If importance_score is greater than threshold:
            Add feature_name to selected_features
    
    Set selection with field selected_features to selected_features
    
    Return selection

Process called "select_features_recursive_elimination" that takes training_data as Dataset and selection_config as Dictionary returns FeatureSelection:
    Let selection be create_feature_selection with selection_config
    Let target_feature_count be selection_config with key "n_features" or 10
    Let current_features be copy of training_data with field feature_names
    Let elimination_history be empty list
    
    Note: Recursive feature elimination loop
    While length of current_features is greater than target_feature_count:
        Note: Train model with current features
        Let subset_data be extract_feature_subset with training_data and current_features
        
        Let tree_config be dictionary with keys "type", "criterion":
            "type" maps to "classification"
            "criterion" maps to "gini"
        
        Let tree be build_decision_tree with subset_data and tree_config
        Let feature_importance be tree with field feature_importance
        
        Note: Find least important feature
        Let least_important_feature be find_least_important_feature with feature_importance
        
        Note: Remove least important feature
        Set current_features to remove_feature_from_list with current_features and least_important_feature
        
        Let elimination_record be dictionary with keys "eliminated_feature", "remaining_features", "importance_scores":
            "eliminated_feature" maps to least_important_feature
            "remaining_features" maps to copy of current_features
            "importance_scores" maps to feature_importance
        Add elimination_record to elimination_history
    
    Set selection with field selected_features to current_features
    Set selection with field feature_scores to get_final_importance_scores with elimination_history
    
    Return selection

Note: Tree Interpretation and Explanation
Process called "interpret_decision_tree" that takes tree as DecisionTree and sample as Vector returns Dictionary:
    Let interpretation be empty dictionary
    Set interpretation with key "prediction" to predict_decision_tree with tree and sample
    
    Note: Get decision path through tree
    Let decision_path be trace_decision_path with tree with field root_node and sample
    Set interpretation with key "decision_path" to decision_path
    
    Note: Get feature contributions
    Let feature_contributions be calculate_feature_contributions with tree and sample
    Set interpretation with key "feature_contributions" to feature_contributions
    
    Note: Get rules in natural language
    Let decision_rules be generate_decision_rules with decision_path
    Set interpretation with key "decision_rules" to decision_rules
    
    Return interpretation

Process called "trace_decision_path" that takes node as TreeNode and sample as Vector returns List[Dictionary]:
    Let path be empty list
    Let current_node be node
    
    Note: Traverse tree following the sample's path
    While current_node is not equal to null:
        Let path_step be dictionary with keys "node_id", "node_type", "split_feature", "split_threshold", "split_direction", "prediction":
            "node_id" maps to current_node with field node_id
            "node_type" maps to current_node with field node_type
            "split_feature" maps to current_node with field split_feature
            "split_threshold" maps to current_node with field split_threshold
            "prediction" maps to current_node with field prediction
        
        Add path_step to path
        
        If current_node with field node_type is equal to "leaf":
            Break from loop
        
        Note: Determine which child to follow
        Let feature_index be find_feature_index with current_node with field split_feature
        Let feature_value be sample with index feature_index
        
        If feature_value is less than or equal to current_node with field split_threshold:
            Set path_step with key "split_direction" to "left"
            Set current_node to current_node with field left_child
        Otherwise:
            Set path_step with key "split_direction" to "right"
            Set current_node to current_node with field right_child
    
    Return path

Process called "generate_decision_rules" that takes decision_path as List[Dictionary] returns List[String]:
    Let rules be empty list
    
    For each step in decision_path:
        If step with key "node_type" is equal to "internal":
            Let feature be step with key "split_feature"
            Let threshold be step with key "split_threshold"
            Let direction be step with key "split_direction"
            
            Let rule_text be empty string
            If direction is equal to "left":
                Set rule_text to feature concatenated with " <= " concatenated with threshold as String
            Otherwise:
                Set rule_text to feature concatenated with " > " concatenated with threshold as String
            
            Add rule_text to rules
        Otherwise:
            Let prediction be step with key "prediction"
            Let final_rule be "Predict: " concatenated with prediction as String
            Add final_rule to rules
    
    Return rules

Note: Tree Visualization and Analysis
Process called "analyze_tree_structure" that takes tree as DecisionTree returns Dictionary:
    Let analysis be empty dictionary
    Let root_node be tree with field root_node
    
    Note: Calculate tree statistics
    Set analysis with key "tree_depth" to tree with field tree_depth
    Set analysis with key "node_count" to tree with field node_count
    Set analysis with key "leaf_count" to tree with field leaf_count
    
    Note: Analyze feature usage
    Let feature_usage be analyze_feature_usage with root_node
    Set analysis with key "feature_usage" to feature_usage
    
    Note: Calculate tree balance
    Let balance_measure be calculate_tree_balance with root_node
    Set analysis with key "balance_measure" to balance_measure
    
    Note: Analyze split quality
    Let split_quality be analyze_split_quality with root_node
    Set analysis with key "split_quality" to split_quality
    
    Return analysis

Process called "calculate_tree_balance" that takes node as TreeNode returns Float:
    If node with field node_type is equal to "leaf":
        Return 0.0
    
    Let left_depth be calculate_subtree_depth with node with field left_child
    Let right_depth be calculate_subtree_depth with node with field right_child
    
    Note: Balance measure: difference in depths normalized by maximum depth
    Let depth_difference be absolute_value of (left_depth minus right_depth)
    Let max_depth be maximum of left_depth and right_depth
    
    If max_depth is equal to 0:
        Return 1.0  Note: Perfect balance for single node
    
    Return 1.0 minus (depth_difference as Float divided by max_depth as Float)

Note: Main decision tree coordination
Process called "create_decision_tree_system" that takes configuration as Dictionary returns Dictionary:
    Let system be empty dictionary
    Set system with key "tree_types" to configuration with key "supported_types" or list containing "classification", "regression"
    Set system with key "ensemble_methods" to configuration with key "ensemble_methods" or list containing "random_forest", "gradient_boosting"
    Set system with key "feature_selection" to configuration with key "feature_selection" or false
    Set system with key "tree_interpretation" to configuration with key "interpretation" or false
    Set system with key "pruning_enabled" to configuration with key "pruning" or false
    
    Return system

Process called "execute_decision_tree_analysis" that takes system as Dictionary and query as Dictionary returns Dictionary:
    Let query_type be query with key "type"
    Let result be empty dictionary
    
    If query_type is equal to "train_decision_tree":
        Let training_data be query with key "training_data"
        Let tree_config be query with key "tree_config"
        
        Let decision_tree be build_decision_tree with training_data and tree_config
        Set result with key "trained_tree" to decision_tree
        
        Note: Add tree analysis
        Let tree_analysis be analyze_tree_structure with decision_tree
        Set result with key "tree_analysis" to tree_analysis
    
    If query_type is equal to "train_random_forest":
        Let training_data be query with key "training_data"
        Let forest_config be query with key "forest_config"
        
        Let forest be create_random_forest with forest_config
        Set forest to train_random_forest with forest and training_data and forest_config
        Set result with key "trained_forest" to forest
    
    If query_type is equal to "train_gradient_boosting":
        Let training_data be query with key "training_data"
        Let validation_data be query with key "validation_data"
        Let model_config be query with key "model_config"
        
        Let gb_model be create_gradient_boosting_model with model_config
        Set gb_model to train_gradient_boosting with gb_model and training_data and validation_data
        Set result with key "trained_model" to gb_model
    
    If query_type is equal to "feature_selection":
        Let training_data be query with key "training_data"
        Let selection_config be query with key "selection_config"
        Let method be selection_config with key "method" or "tree_based"
        
        Let feature_selection be empty dictionary
        If method is equal to "tree_based":
            Set feature_selection to select_features_tree_based with training_data and selection_config
        
        If method is equal to "recursive_elimination":
            Set feature_selection to select_features_recursive_elimination with training_data and selection_config
        
        Set result with key "feature_selection" to feature_selection
    
    If query_type is equal to "interpret_prediction":
        Let tree be query with key "tree"
        Let sample be query with key "sample"
        
        Let interpretation be interpret_decision_tree with tree and sample
        Set result with key "interpretation" to interpretation
    
    If query_type is equal to "ensemble_prediction":
        Let ensemble be query with key "ensemble"
        Let test_features be query with key "test_features"
        
        Let ensemble_type be ensemble with key "ensemble_type"
        Let predictions be empty vector
        
        If ensemble_type is equal to "random_forest":
            Set predictions to predict_random_forest with ensemble and test_features
        
        Set result with key "predictions" to predictions
        Set result with key "ensemble_analysis" to analyze_ensemble_performance with ensemble
    
    Note: Add metadata
    Set result with key "decision_tree_timestamp" to current_timestamp
    Set result with key "system_config" to extract_system_summary with system
    
    Return result