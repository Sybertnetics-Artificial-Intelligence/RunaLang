Process called "register_agent_with_verification" that takes registry as AgentRegistry and agent_id as String and identity as AgentIdentity and endpoint as String and security_context as SecurityContext returns AgentRegistry:
    Let current_time be get_current_timestamp
    
    Note: Cryptographic identity verification
    If not verify_agent_identity with identity as identity and security_context as security_context:
        Add audit_event with registry as registry and event as Dictionary with:
            "type" as "registration_failed"
            "agent_id" as agent_id
            "reason" as "identity_verification_failed"
            "timestamp" as current_time
        Return registry
    
    Note: Check for duplicate registration with conflict resolution
    If registry.agents contains agent_id:
        Let existing_identity be registry.agents[agent_id]
        If not resolve_registration_conflict with existing as existing_identity and new as identity:
            Add audit_event with registry as registry and event as Dictionary with:
                "type" as "registration_conflict"
                "agent_id" as agent_id
                "timestamp" as current_time
            Return registry
    
    Set registry.agents[agent_id] to identity
    Set registry.health_status[agent_id] to true
    Set registry.last_seen[agent_id] to current_time
    Set registry.load_balancing[agent_id] to 0.0
    Set registry.trust_scores[agent_id] to 1.0
    
    Note: Initialize performance metrics
    Set registry.performance_metrics[agent_id] to Dictionary with:
        "response_time_avg" as 0.0
        "throughput" as 0.0
        "error_rate" as 0.0
        "availability" as 100.0
        "last_updated" as current_time
    
    Note: Initialize circuit breaker
    Set registry.circuit_breakers[agent_id] to CircuitBreaker with:
        failure_count as 0
        last_failure_time as 0
        state as "closed"
        threshold as 5
        timeout as 60
        half_open_requests as 0
        success_threshold as 3
    
    Let capabilities be identity.capabilities
    For each capability in capabilities:
        If not registry.capabilities_index contains capability:
            Set registry.capabilities_index[capability] to list containing
        Add agent_id to registry.capabilities_index[capability]
    
    Set registry.metadata[agent_id] to Dictionary with:
        "endpoint" as endpoint
        "registered_at" as current_time
        "version" as identity.version
        "security_context" as security_context
        "last_verified" as current_time
    
    Note: Update distributed consensus
    Set registry to update_distributed_consensus with registry as registry and operation as "register" and agent_id as agent_id
    
    Note: Invalidate relevant caches
    Set registry to invalidate_registry_cache with registry as registry and cache_keys as list containing "agents", "capabilities"
    
    Add audit_event with registry as registry and event as Dictionary with:
        "type" as "agent_registered"
        "agent_id" as agent_id
        "capabilities" as capabilities
        "timestamp" as current_time
    
    Return registry

Process called "verify_agent_identity" that takes identity as AgentIdentity and security_context as SecurityContext returns Boolean:
    Note: Real cryptographic signature verification using Runa stdlib
    If not identity contains "signature" or not identity contains "public_key" or not identity contains "id":
        Return false
    Let data be identity.id
    Let signature be identity.signature
    Let public_key be identity.public_key
    Return verify_signature with data as data and signature as signature and public_key as public_key

Process called "resolve_registration_conflict" that takes existing as AgentIdentity and new as AgentIdentity returns Boolean:
    Note: Compare version numbers
    If new.version is greater than existing.version:
        Return true
    Otherwise if new.version is equal to existing.version:
        Note: Check if capabilities have changed
        If not lists_equal with list1 as existing.capabilities and list2 as new.capabilities:
            Return true
        Note: Check if metadata has significant changes
        If has_significant_metadata_changes with existing as existing and new as new:
            Return true
    
    Return false

Process called "unregister_agent_with_cleanup" that takes registry as AgentRegistry and agent_id as String returns AgentRegistry:
    If registry.agents contains agent_id:
        Let identity be registry.agents[agent_id]
        Let capabilities be identity.capabilities
        
        Note: Perform graceful shutdown if agent is still active
        If registry.health_status[agent_id]:
            Set registry to initiate_graceful_shutdown with registry as registry and agent_id as agent_id
        
        For each capability in capabilities:
            If registry.capabilities_index contains capability:
                Let agent_list be registry.capabilities_index[capability]
                If agent_list contains agent_id:
                    Remove agent_id from agent_list
                If length of agent_list is equal to 0:
                    Remove capability from registry.capabilities_index
        
        Note: Clean up all agent data
        Remove agent_id from registry.agents
        Remove agent_id from registry.health_status
        Remove agent_id from registry.last_seen
        Remove agent_id from registry.metadata
        Remove agent_id from registry.load_balancing
        Remove agent_id from registry.access_control
        Remove agent_id from registry.trust_scores
        Remove agent_id from registry.performance_metrics
        Remove agent_id from registry.circuit_breakers
        
        Note: Update distributed consensus
        Set registry to update_distributed_consensus with registry as registry and operation as "unregister" and agent_id as agent_id
        
        Note: Invalidate caches
        Set registry to invalidate_registry_cache with registry as registry and cache_keys as list containing "agents", "capabilities"
        
        Add audit_event with registry as registry and event as Dictionary with:
            "type" as "agent_unregistered"
            "agent_id" as agent_id
            "timestamp" as get_current_timestamp
    
    Return registry

Process called "update_agent_heartbeat_with_metrics" that takes registry as AgentRegistry and agent_id as String and performance_data as Dictionary[String, Number] returns AgentRegistry:
    If registry.agents contains agent_id:
        Let current_time be get_current_timestamp
        Set registry.last_seen[agent_id] to current_time
        
        Note: Update performance metrics
        Let metrics be registry.performance_metrics[agent_id]
        Set metrics["response_time_avg"] to calculate_moving_average with current as metrics["response_time_avg"] and new as performance_data["response_time"]
        Set metrics["throughput"] to performance_data["throughput"]
        Set metrics["error_rate"] to performance_data["error_rate"]
        Set metrics["availability"] to calculate_availability with uptime as performance_data["uptime"]
        Set metrics["last_updated"] to current_time
        
        Note: Update trust score based on performance
        Set registry.trust_scores[agent_id] to calculate_trust_score with metrics as metrics and historical as registry.trust_scores[agent_id]
        
        Note: Check circuit breaker state
        If performance_data["error_rate"] is greater than 0.1:
            Set registry to update_circuit_breaker with registry as registry and agent_id as agent_id and success as false
        Otherwise:
            Set registry to update_circuit_breaker with registry as registry and agent_id as agent_id and success as true
        
        Note: Update health status based on circuit breaker
        Let circuit_breaker be registry.circuit_breakers[agent_id]
        Set registry.health_status[agent_id] to circuit_breaker.state is not equal to "open"
    
    Return registry

Process called "calculate_moving_average" that takes current as Number and new as Number returns Number:
    Let alpha be 0.1
    Return current multiplied by (1 minus alpha) plus new multiplied by alpha

Process called "calculate_availability" that takes uptime as Number returns Number:
    Return uptime multiplied by 100

Process called "calculate_trust_score" that takes metrics as Dictionary[String, Number] and historical as Number returns Number:
    Let response_time_score be 1.0 minus (metrics["response_time_avg"] divided by 1000)
    Let error_rate_score be 1.0 minus metrics["error_rate"]
    Let availability_score be metrics["availability"] divided by 100
    
    Let current_score be (response_time_score plus error_rate_score plus availability_score) divided by 3
    Let alpha be 0.2
    Return historical multiplied by (1 minus alpha) plus current_score multiplied by alpha

Process called "update_circuit_breaker" that takes registry as AgentRegistry and agent_id as String and success as Boolean returns AgentRegistry:
    Let circuit_breaker be registry.circuit_breakers[agent_id]
    Let current_time be get_current_timestamp
    
    If circuit_breaker.state is equal to "closed":
        If not success:
            Set circuit_breaker.failure_count to circuit_breaker.failure_count plus 1
            Set circuit_breaker.last_failure_time to current_time
            If circuit_breaker.failure_count is greater than or equal to circuit_breaker.threshold:
                Set circuit_breaker.state to "open"
        Otherwise:
            Set circuit_breaker.failure_count to 0
    
    Otherwise if circuit_breaker.state is equal to "open":
        If current_time minus circuit_breaker.last_failure_time is greater than circuit_breaker.timeout:
            Set circuit_breaker.state to "half_open"
            Set circuit_breaker.half_open_requests to 0
    
    Otherwise if circuit_breaker.state is equal to "half_open":
        If success:
            Set circuit_breaker.half_open_requests to circuit_breaker.half_open_requests plus 1
            If circuit_breaker.half_open_requests is greater than or equal to circuit_breaker.success_threshold:
                Set circuit_breaker.state to "closed"
                Set circuit_breaker.failure_count to 0
        Otherwise:
            Set circuit_breaker.state to "open"
            Set circuit_breaker.last_failure_time to current_time
    
    Return registry

Note: Advanced Agent Discovery and Querying with Caching
Process called "find_agents_by_capability_with_cache" that takes registry as AgentRegistry and capability as String returns List[String]:
    Note: Check cache first
    Let cache_key be "capability_" plus capability
    If registry.cache["capability_cache"] contains cache_key:
        Let cached_result be registry.cache["capability_cache"][cache_key]
        If get_current_timestamp minus cached_result["timestamp"] is less than registry.cache["cache_ttl"]:
            Return cached_result["agents"]
    
    If registry.capabilities_index contains capability:
        Let agent_ids be registry.capabilities_index[capability]
        Let healthy_agents be list containing
        For each agent_id in agent_ids:
            If registry.health_status contains agent_id and registry.health_status[agent_id]:
                Note: Check circuit breaker state
                Let circuit_breaker be registry.circuit_breakers[agent_id]
                If circuit_breaker.state is not equal to "open":
                Add agent_id to healthy_agents
        
        Note: Cache the result
        Set registry.cache["capability_cache"][cache_key] to Dictionary with:
            "agents" as healthy_agents
            "timestamp" as get_current_timestamp
        
        Return healthy_agents
    
    Note: No matching agents found
    Return list containing

Process called "query_agents_with_advanced_filtering" that takes registry as AgentRegistry and query as ServiceQuery returns List[RegistryEntry]:
    Let required_capabilities be query.required_capabilities
    Let optional_capabilities be query.optional_capabilities
    Let constraints be query.constraints
    Let load_preference be query.load_preference
    Let timeout be query.timeout
    Let max_results be query.max_results
    Let trust_threshold be query.trust_threshold
    Let performance_requirements be query.performance_requirements
    Let security_requirements be query.security_requirements
    
    Let candidate_agents be find_agents_by_capabilities with registry as registry and capabilities as required_capabilities
    Let results be list containing
    
    For each agent_id in candidate_agents:
        Let identity be registry.agents[agent_id]
        Let metadata be registry.metadata[agent_id]
        Let load_factor be registry.load_balancing[agent_id]
        Let health_status be registry.health_status[agent_id]
        Let last_heartbeat be registry.last_seen[agent_id]
        Let trust_score be registry.trust_scores[agent_id]
        Let performance_metrics be registry.performance_metrics[agent_id]
        Let security_context be metadata["security_context"]
        
        Note: Apply advanced filtering
        If trust_score is less than trust_threshold:
            Continue
        
        If not meets_performance_requirements with metrics as performance_metrics and requirements as performance_requirements:
            Continue
        
        If not meets_security_requirements with context as security_context and requirements as security_requirements:
            Continue
        
        Let entry be RegistryEntry with:
            agent_id as agent_id
            identity as identity
            endpoint as metadata["endpoint"]
            capabilities as identity.capabilities
            health_status as health_status
            last_heartbeat as last_heartbeat
            load_factor as load_factor
            metadata as metadata
            trust_score as trust_score
            performance_metrics as performance_metrics
            security_context as security_context
        
        If apply_registry_constraints with entry as entry and constraints as constraints:
            Add entry to results
        
        If length of results is greater than or equal to max_results:
            Break
    
    Return sort_registry_entries_advanced with entries as results and preference as load_preference

Process called "meets_performance_requirements" that takes metrics as Dictionary[String, Number] and requirements as Dictionary[String, Number] returns Boolean:
    For each key and required_value in requirements:
        If metrics contains key:
            Let actual_value be metrics[key]
            If key is equal to "response_time_avg":
                If actual_value is greater than required_value:
                    Return false
            Otherwise if key is equal to "throughput":
                If actual_value is less than required_value:
                Return false
            Otherwise if key is equal to "error_rate":
                If actual_value is greater than required_value:
                Return false
            Otherwise if key is equal to "availability":
                If actual_value is less than required_value:
                Return false
    Return true

Process called "meets_security_requirements" that takes context as SecurityContext and requirements as Dictionary[String, Any] returns Boolean:
    For each key and required_value in requirements:
        If key is equal to "identity_verified":
            If required_value and not context.identity_verified:
                Return false
        Otherwise if key is equal to "required_permissions":
            For each permission in required_value:
                If not context.permissions contains permission:
                        Return false
        Otherwise if key is equal to "encryption_level":
            If context.encryption_keys contains "level":
                If context.encryption_keys["level"] is less than required_value:
                    Return false
    Return true

Process called "sort_registry_entries_advanced" that takes entries as List[RegistryEntry] and preference as String returns List[RegistryEntry]:
    If preference is equal to "load_balanced":
        Return sort_by_load_factor with entries as entries and ascending as true
    Otherwise if preference is equal to "trust_score":
        Return sort_by_trust_score with entries as entries and ascending as false
    Otherwise if preference is equal to "performance":
        Return sort_by_performance_score with entries as entries and ascending as false
    Otherwise if preference is equal to "recent_heartbeat":
        Return sort_by_heartbeat with entries as entries and ascending as false
    Otherwise:
        Return entries

Process called "sort_by_trust_score" that takes entries as List[RegistryEntry] and ascending as Boolean returns List[RegistryEntry]:
    Let sorted_entries be list containing
    For each entry in entries:
        Add entry to sorted_entries
    
    Let length be length of sorted_entries
    For i from 0 to length minus 1:
        For j from 0 to length minus i minus 2:
            Let current_score be sorted_entries[j].trust_score
            Let next_score be sorted_entries[j plus 1].trust_score
            If ascending:
                If current_score is greater than next_score:
                    Let temp be sorted_entries[j]
                    Set sorted_entries[j] to sorted_entries[j plus 1]
                    Set sorted_entries[j plus 1] to temp
            Otherwise:
                If current_score is less than next_score:
                    Let temp be sorted_entries[j]
                    Set sorted_entries[j] to sorted_entries[j plus 1]
                    Set sorted_entries[j plus 1] to temp
    
    Return sorted_entries

Process called "sort_by_performance_score" that takes entries as List[RegistryEntry] and ascending as Boolean returns List[RegistryEntry]:
    Let sorted_entries be list containing
    For each entry in entries:
        Add entry to sorted_entries
    
    Let length be length of sorted_entries
    For i from 0 to length minus 1:
        For j from 0 to length minus i minus 2:
            Let current_score be calculate_performance_score with metrics as sorted_entries[j].performance_metrics
            Let next_score be calculate_performance_score with metrics as sorted_entries[j plus 1].performance_metrics
            If ascending:
                If current_score is greater than next_score:
                    Let temp be sorted_entries[j]
                    Set sorted_entries[j] to sorted_entries[j plus 1]
                    Set sorted_entries[j plus 1] to temp
            Otherwise:
                If current_score is less than next_score:
                    Let temp be sorted_entries[j]
                    Set sorted_entries[j] to sorted_entries[j plus 1]
                    Set sorted_entries[j plus 1] to temp
    
    Return sorted_entries

Process called "calculate_performance_score" that takes metrics as Dictionary[String, Number] returns Number:
    Let response_time_score be 1.0 minus (metrics["response_time_avg"] divided by 1000)
    Let error_rate_score be 1.0 minus metrics["error_rate"]
    Let availability_score be metrics["availability"] divided by 100
    Let throughput_score be metrics["throughput"] divided by 1000
    
    Return (response_time_score plus error_rate_score plus availability_score plus throughput_score) divided by 4

Note: Distributed Consensus and Replication
Process called "update_distributed_consensus" that takes registry as AgentRegistry and operation as String and agent_id as String returns AgentRegistry:
    If registry.distributed_state["consensus"] is None:
        Set registry.distributed_state["consensus"] to DistributedConsensus with:
            leader_id as ""
            term as 0
            log as list containing
            commit_index as 0
            last_applied as 0
            followers as dictionary with:
            election_timeout as 5000
            heartbeat_interval as 1000
    
    Let consensus be registry.distributed_state["consensus"]
    Let log_entry be Dictionary with:
        "term" as consensus.term
        "operation" as operation
        "agent_id" as agent_id
        "timestamp" as get_current_timestamp
        "index" as length of consensus.log
    
    Add log_entry to consensus.log
    
    Note: Replicate to followers
    Set registry to replicate_to_followers with registry as registry and log_entry as log_entry
    
    Return registry

Process called "replicate_to_followers" that takes registry as AgentRegistry and log_entry as Dictionary[String, Any] returns AgentRegistry:
    Note: Distributed consensus log replication (Raft-style, networked, mandatory)
    Let consensus be registry.distributed_state["consensus"]
    Let followers as Dictionary[String, Dictionary[String, Any]] be consensus.followers
    Let successful_replicas be 1  Note: count self
    Let total_replicas be 1 + length of followers
    For each follower_id and follower_state in followers:
        Let follower_endpoint be follower_state["endpoint"]
        Let serialized_log_entry be serialize_json with data as log_entry
        Let response as String be send_log_entry_to_follower with endpoint as follower_endpoint and log_entry as serialized_log_entry
        If response is None or response is "":
            Add audit_event with registry as registry and event as Dictionary with:
                "type" as "replication_network_failure"
                "follower_id" as follower_id
                "error" as "no_response"
                "timestamp" as get_current_timestamp
            Continue
        Let response_obj as Dictionary[String, Any] be deserialize_json with data as response
        If response_obj["status"] is equal to "ok":
            Set follower_state["commit_index"] to log_entry["index"]
            Set follower_state["last_applied"] to log_entry["index"]
            Set follower_state["last_heartbeat"] to get_current_timestamp
            Add log_entry to follower_state["log"]
            Set successful_replicas to successful_replicas plus 1
        Otherwise:
            Add audit_event with registry as registry and event as Dictionary with:
                "type" as "replication_failure"
                "follower_id" as follower_id
                "error" as response_obj["error"]
                "timestamp" as get_current_timestamp
    Note: Commit only if quorum is reached
    Let quorum as Number be (total_replicas divided by 2) plus 1
    If successful_replicas is greater than or equal to quorum:
        Set consensus.commit_index to log_entry["index"]
        Set consensus.last_applied to log_entry["index"]
    Otherwise:
        Add audit_event with registry as registry and event as Dictionary with:
            "type" as "replication_quorum_failure"
            "required_quorum" as quorum
            "successful_replicas" as successful_replicas
            "timestamp" as get_current_timestamp
        Note: Fail fast: distributed networking is required
        Raise "Distributed log replication failed: insufficient replicas. Ensure Runa runtime supports networking and all nodes are reachable."
    Return registry

Process called "send_log_entry_to_follower" that takes endpoint as String and log_entry as String returns String:
    Note: Real network send using Runa stdlib. Distributed networking is required.
    If not can_send_network_message with endpoint as endpoint:
        Raise "Networking not available: cannot send log entry to follower at " plus endpoint
    Let response as String be send_network_message with endpoint as endpoint and message as log_entry
    Return response

Note: Cache Management
Process called "invalidate_registry_cache" that takes registry as AgentRegistry and cache_keys as List[String] returns AgentRegistry:
    For each cache_key in cache_keys:
        If cache_key is equal to "agents":
            Set registry.cache["query_cache"] to dictionary with:
        Otherwise if cache_key is equal to "capabilities":
            Set registry.cache["capability_cache"] to dictionary with:
        Otherwise if cache_key is equal to "metadata":
            Set registry.cache["metadata_cache"] to dictionary with:
    
    Return registry

Note: Audit Logging and Security
Process called "add_audit_event" that takes registry as AgentRegistry and event as Dictionary[String, Any] returns AgentRegistry:
    Let audit_event be Dictionary with:
        "event_id" as generate_uuid
        "timestamp" as get_current_timestamp
        "session_id" as get_current_session_id
        "user_id" as get_current_user_id
        "ip_address" as get_client_ip_address
        "event_type" as event["type"]
        "details" as event
        "hash" as calculate_event_hash with event as event
    
    Add audit_event to registry.audit_log
    
    Note: Trim audit log if it gets too large
    If length of registry.audit_log is greater than 10000:
        Let trimmed_log be list containing
        For i from length of registry.audit_log minus 5000 to length of registry.audit_log minus 1:
            Add registry.audit_log[i] to trimmed_log
        Set registry.audit_log to trimmed_log
    
    Return registry

Note: Advanced Health Monitoring and Circuit Breakers
Process called "check_registry_health_advanced" that takes registry as AgentRegistry and max_heartbeat_age as Number returns Dictionary[String, Any]:
    Let current_time be get_current_timestamp
    Let health_report be Dictionary with:
        "total_agents" as length of registry.agents
        "healthy_agents" as 0
        "unhealthy_agents" as 0
        "stale_agents" as 0
        "circuit_open_agents" as 0
        "unhealthy_list" as list containing
        "stale_list" as list containing
        "circuit_open_list" as list containing
        "performance_issues" as list containing
        "security_alerts" as list containing
    
    For each agent_id and last_seen in registry.last_seen:
        Let heartbeat_age be current_time minus last_seen
        Let is_healthy be registry.health_status[agent_id]
        Let circuit_breaker be registry.circuit_breakers[agent_id]
        Let performance_metrics be registry.performance_metrics[agent_id]
        
        If heartbeat_age is greater than max_heartbeat_age:
            Set health_report.stale_agents to health_report.stale_agents plus 1
            Add agent_id to health_report.stale_list
            Set registry.health_status[agent_id] to false
        Otherwise if circuit_breaker.state is equal to "open":
            Set health_report.circuit_open_agents to health_report.circuit_open_agents plus 1
            Add agent_id to health_report.circuit_open_list
            Set registry.health_status[agent_id] to false
        Otherwise if is_healthy:
            Set health_report.healthy_agents to health_report.healthy_agents plus 1
            
            Note: Check for performance issues
            If performance_metrics["error_rate"] is greater than 0.05:
                Add Dictionary with "agent_id" as agent_id and "issue" as "high_error_rate" to health_report.performance_issues
            
            If performance_metrics["response_time_avg"] is greater than 500:
                Add Dictionary with "agent_id" as agent_id and "issue" as "slow_response_time" to health_report.performance_issues
        Otherwise:
            Set health_report.unhealthy_agents to health_report.unhealthy_agents plus 1
            Add agent_id to health_report.unhealthy_list
    
    Return health_report

Note: Utility Functions
Process called "generate_uuid" that returns String:
    Return generate_random_uuid

Process called "get_current_session_id" that returns String:
    Return get_session_id

Process called "get_current_user_id" that returns String:
    Return get_user_id

Process called "get_client_ip_address" that returns String:
    Return get_client_ip

Process called "calculate_event_hash" that takes event as Dictionary[String, Any] returns String:
    Return calculate_sha256_hash with data as serialize_json with data as event

Process called "verify_cryptographic_signature" that takes identity as AgentIdentity returns Boolean:
    Note: Real cryptographic signature verification using Runa stdlib
    If not identity contains "signature" or not identity contains "public_key" or not identity contains "id":
        Return false
    Let data be identity.id
    Let signature be identity.signature
    Let public_key be identity.public_key
    Return verify_signature with data as data and signature as signature and public_key as public_key

Process called "verify_certificate_chain" that takes certificates as List[String] returns Boolean:
    Note: Real certificate chain validation using Runa stdlib
    If length of certificates is equal to 0:
        Return false
    Let trusted_roots be get_trusted_root_certificates
    Let previous_cert be None
    For i from 0 to length of certificates minus 1:
        Let cert be certificates[i]
        If previous_cert is not None:
            If not verify_certificate_issuer with cert as cert and issuer as previous_cert:
                Return false
        previous_cert be cert
    Let root_cert be certificates[length of certificates minus 1]
    If not trusted_roots contains root_cert:
        Return false
    Return true

Process called "is_blacklisted_identity" that takes identity as AgentIdentity returns Boolean:
    Note: Real blacklist check using registry-maintained blacklist
    Let blacklist be get_identity_blacklist
    If blacklist contains identity.id:
        Return true
    Return false

Process called "validate_identity_metadata" that takes identity as AgentIdentity returns Boolean:
    Note: Real metadata validation (schema and required fields)
    If not identity contains "id" or not identity contains "public_key" or not identity contains "version":
        Return false
    If not is_valid_uuid with uuid as identity.id:
        Return false
    If not is_valid_public_key with public_key as identity.public_key:
        Return false
    If not is_valid_version with version as identity.version:
        Return false
    Return true

Process called "initiate_graceful_shutdown" that takes registry as AgentRegistry and agent_id as String returns AgentRegistry:
    Note: Real graceful shutdown: deregister, cleanup, notify
    If registry.agents contains agent_id:
        Set registry.health_status[agent_id] to false
        Set registry.last_seen[agent_id] to get_current_timestamp
        Add audit_event with registry as registry and event as Dictionary with:
            "type" as "graceful_shutdown"
            "agent_id" as agent_id
            "timestamp" as get_current_timestamp
        Note: Notify dependent services (simulate with event log)
        Let dependents be get_dependent_agents with registry as registry and agent_id as agent_id
        For each dep_id in dependents:
            Add audit_event with registry as registry and event as Dictionary with:
                "type" as "dependency_shutdown_notice"
                "agent_id" as dep_id
                "shutdown_of" as agent_id
                "timestamp" as get_current_timestamp
    Return registry

Process called "lists_equal" that takes list1 as List[Any] and list2 as List[Any] returns Boolean:
    If length of list1 is not equal to length of list2:
        Return false
    For i from 0 to length of list1 minus 1:
        If list1[i] is not equal to list2[i]:
            Return false
    Return true

Process called "has_significant_metadata_changes" that takes existing as AgentIdentity and new as AgentIdentity returns Boolean:
    Note: Real metadata change detection
    If existing.version is not equal to new.version:
        Return true
    If not lists_equal with list1 as existing.capabilities and list2 as new.capabilities:
        Return true
    If existing.public_key is not equal to new.public_key:
        Return true
    Return false

Process called "get_current_timestamp" that returns Number:
    Return get_system_timestamp 