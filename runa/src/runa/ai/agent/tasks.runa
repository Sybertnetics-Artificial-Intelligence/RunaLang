Note:
Runa Standard Library: AI Agent Tasks Module

Provides task and goal assignment, tracking, reporting, and error handling for agents. Enables robust, production-grade task management and monitoring in multi-agent systems.

Advanced features include:
- Advanced task orchestration and workflow management
- Dependency resolution and task scheduling
- Resource optimization and load balancing
- Fault tolerance with automatic recovery
- Performance monitoring and analytics
- Task prioritization and deadline management
- Distributed task execution and coordination
- Advanced error handling and retry strategies
- Task composition and chaining
- Real-time monitoring and alerting
:End Note

Type AgentTask is Dictionary with:
    id as String
    description as String
    assigned_to as String
    status as String
    progress as Number
    result as Any
    error as String
    created_at as Number
    updated_at as Number
    priority as Number
    complexity as Number
    estimated_duration as Number
    actual_duration as Number
    deadline as Number
    dependencies as List[String]
    subtasks as List[String]
    parent_task as String
    resource_requirements as Dictionary[String, Number]
    performance_metrics as Dictionary[String, Number]
    execution_history as List[Dictionary[String, Any]]
    retry_count as Number
    max_retries as Number
    retry_delay as Number
    tags as List[String]
    metadata as Dictionary[String, Any]

Type TaskManager is Dictionary with:
    tasks as Dictionary[String, AgentTask]
    agent_tasks as Dictionary[String, List[String]]
    task_queue as List[String]
    completed_tasks as Dictionary[String, AgentTask]
    failed_tasks as Dictionary[String, AgentTask]
    task_dependencies as Dictionary[String, List[String]]
    resource_allocation as Dictionary[String, Dictionary[String, Number]]
    performance_metrics as Dictionary[String, Dictionary[String, Number]]
    task_analytics as Dictionary[String, Dictionary[String, Any]]
    workflow_definitions as Dictionary[String, Dictionary[String, Any]]
    scheduling_policies as Dictionary[String, Dictionary[String, Any]]
    fault_tolerance as Dictionary[String, Dictionary[String, Any]]
    audit_log as List[Dictionary[String, Any]]

Type TaskWorkflow is Dictionary with:
    workflow_id as String
    name as String
    description as String
    steps as List[Dictionary[String, Any]]
    dependencies as Dictionary[String, List[String]]
    error_handling as Dictionary[String, String]
    retry_strategies as Dictionary[String, Dictionary[String, Any]]
    resource_constraints as Dictionary[String, Number]
    performance_targets as Dictionary[String, Number]
    monitoring_rules as List[Dictionary[String, Any]]

Type TaskScheduler is Dictionary with:
    scheduler_id as String
    policy as String
    priority_queue as List[String]
    resource_pool as Dictionary[String, Dictionary[String, Number]]
    scheduling_metrics as Dictionary[String, Number]
    load_balancing as Dictionary[String, Number]
    deadline_management as Dictionary[String, Number]

Type TaskExecution is Dictionary with:
    execution_id as String
    task_id as String
    agent_id as String
    start_time as Number
    end_time as Number
    status as String
    result as Any
    error_message as String
    performance_metrics as Dictionary[String, Number]
    resource_usage as Dictionary[String, Number]
    checkpoint_data as Dictionary[String, Any]

Note: Advanced Task Management with Orchestration
Process called "create_task_manager" that returns TaskManager:
    Return TaskManager with:
        tasks as dictionary with:
        agent_tasks as dictionary with:
        task_queue as list containing
        completed_tasks as dictionary with:
        failed_tasks as dictionary with:
        task_dependencies as dictionary with:
        resource_allocation as dictionary with:
        performance_metrics as Dictionary with:
            "total_tasks" as 0
            "completed_tasks" as 0
            "failed_tasks" as 0
            "average_completion_time" as 0.0
            "success_rate" as 100.0
            "resource_utilization" as 0.0
        task_analytics as dictionary with:
        workflow_definitions as dictionary with:
        scheduling_policies as Dictionary with:
            "default_priority" as 5
            "max_concurrent_tasks" as 10
            "resource_threshold" as 0.8
            "deadline_margin" as 300
        fault_tolerance as Dictionary with:
            "max_retries" as 3
            "retry_delay" as 60
            "circuit_breaker_threshold" as 5
            "graceful_degradation" as true
        audit_log as list containing

Process called "create_task_with_validation" that takes manager as TaskManager and task as AgentTask returns TaskManager:
    Let current_time be get_current_timestamp
    
    Note: Validate task definition
    If not validate_task_definition with task as task:
        Add audit_event with manager as manager and event as Dictionary with:
            "type" as "task_creation_failed"
            "task_id" as task.id
            "reason" as "validation_failed"
            "timestamp" as current_time
        Return manager
    
    Note: Check for duplicate task
    If manager.tasks contains task.id:
        Add audit_event with manager as manager and event as Dictionary with:
            "type" as "task_creation_failed"
            "task_id" as task.id
            "reason" as "duplicate_task"
            "timestamp" as current_time
        Return manager
    
    Note: Initialize task
    Set task.created_at to current_time
    Set task.updated_at to current_time
    Set task.status to "pending"
    Set task.progress to 0.0
    Set task.retry_count to 0
    Set task.execution_history to list containing
    Set task.performance_metrics to Dictionary with:
        "execution_time" as 0.0
        "resource_usage" as 0.0
        "error_count" as 0
        "checkpoint_count" as 0
    
    Set manager.tasks[task.id] to task
    
    Note: Add to task queue
    Add task.id to manager.task_queue
    
    Note: Update dependencies
    If length of task.dependencies is greater than 0:
        Set manager.task_dependencies[task.id] to task.dependencies
    
    Note: Initialize resource allocation
    Set manager.resource_allocation[task.id] to task.resource_requirements
    
    Add audit_event with manager as manager and event as Dictionary with:
        "type" as "task_created"
        "task_id" as task.id
        "priority" as task.priority
        "complexity" as task.complexity
        "timestamp" as current_time
    
    Return manager

Process called "validate_task_definition" that takes task as AgentTask returns Boolean:
    Note: Check required fields
    If task.id is equal to "" or task.description is equal to "":
        Return false
    
    Note: Validate priority
    If task.priority is less than 1 or task.priority is greater than 10:
        Return false
    
    Note: Validate complexity
    If task.complexity is less than 1 or task.complexity is greater than 100:
        Return false
    
    Note: Validate resource requirements
    For each resource and amount in task.resource_requirements:
        If amount is less than or equal to 0:
            Return false
    
    Note: Validate deadline
    If task.deadline is greater than 0 and task.deadline is less than get_current_timestamp:
        Return false
    
    Return true

Process called "assign_task_with_optimization" that takes manager as TaskManager and task_id as String and agent_id as String returns TaskManager:
    If not manager.tasks contains task_id:
        Return manager
    
    Let task be manager.tasks[task_id]
    Let current_time be get_current_timestamp
    
    Note: Check if agent can handle the task
    If not can_agent_handle_task with agent_id as agent_id and task as task:
        Add audit_event with manager as manager and event as Dictionary with:
            "type" as "task_assignment_failed"
            "task_id" as task_id
            "agent_id" as agent_id
            "reason" as "agent_incapable"
            "timestamp" as current_time
        Return manager
    
    Note: Check resource availability
    If not check_resource_availability with manager as manager and agent_id as agent_id and task as task:
        Add audit_event with manager as manager and event as Dictionary with:
            "type" as "task_assignment_failed"
            "task_id" as task_id
            "agent_id" as agent_id
            "reason" as "insufficient_resources"
            "timestamp" as current_time
        Return manager
    
    Set task.assigned_to to agent_id
    Set task.status to "assigned"
    Set task.updated_at to current_time
    
    Note: Update agent task list
    If not manager.agent_tasks contains agent_id:
        Set manager.agent_tasks[agent_id] to list containing
    Add task_id to manager.agent_tasks[agent_id]
    
    Note: Remove from queue
    If manager.task_queue contains task_id:
        Remove task_id from manager.task_queue
    
    Note: Update resource allocation
    Set manager.resource_allocation[agent_id] to task.resource_requirements
    
    Add audit_event with manager as manager and event as Dictionary with:
        "type" as "task_assigned"
        "task_id" as task_id
        "agent_id" as agent_id
        "timestamp" as current_time
    
    Return manager

Process called "can_agent_handle_task" that takes agent_id as String and task as AgentTask returns Boolean:
    Let agent_capabilities be get_agent_capabilities with agent_id as agent_id
    For each required_cap in task.resource_requirements:
        If not agent_capabilities contains required_cap:
            Return false
    Return true

Process called "check_resource_availability" that takes manager as TaskManager and agent_id as String and task as AgentTask returns Boolean:
    Let usage be get_runtime_resource_usage with agent_id as agent_id
    Let memory_limit be get_runtime_memory_limit with agent_id as agent_id
    If usage["memory"] plus task.resource_requirements["memory"] is greater than memory_limit:
        Return false
    If usage["cpu"] plus task.resource_requirements["cpu"] is greater than get_runtime_cpu_limit with agent_id as agent_id:
        Return false
    Return true

Process called "update_task_status_with_metrics" that takes manager as TaskManager and task_id as String and status as String and progress as Number returns TaskManager:
    If manager.tasks contains task_id:
        Let task be manager.tasks[task_id]
        Let current_time be get_current_timestamp
        
        Set task.status to status
        Set task.progress to progress
        Set task.updated_at to current_time
        
        Note: Update performance metrics
        If status is equal to "completed":
            Set task.actual_duration to current_time minus task.created_at
            Set manager.performance_metrics["completed_tasks"] to manager.performance_metrics["completed_tasks"] plus 1
            Set manager.completed_tasks[task_id] to task
            Remove task_id from manager.tasks
            
            Note: Update agent load
            Set manager to update_agent_load with manager as manager and agent_id as task.assigned_to and task as task
            
        Otherwise if status is equal to "failed":
            Set manager.performance_metrics["failed_tasks"] to manager.performance_metrics["failed_tasks"] plus 1
            Set manager.failed_tasks[task_id] to task
            
            Note: Handle retry logic
            If task.retry_count is less than task.max_retries:
                Set manager to schedule_task_retry with manager as manager and task_id as task_id
            Otherwise:
                Remove task_id from manager.tasks
        
        Note: Update overall metrics
        Set manager.performance_metrics["total_tasks"] to manager.performance_metrics["total_tasks"] plus 1
        Let success_rate be manager.performance_metrics["completed_tasks"] divided by manager.performance_metrics["total_tasks"] multiplied by 100
        Set manager.performance_metrics["success_rate"] to success_rate
        
        Add audit_event with manager as manager and event as Dictionary with:
            "type" as "task_status_updated"
            "task_id" as task_id
            "status" as status
            "progress" as progress
            "timestamp" as current_time
    
    Return manager

Process called "update_agent_load" that takes manager as TaskManager and agent_id as String and task as AgentTask returns TaskManager:
    Let agent_loads be manager.performance_metrics["agent_loads"]
    If not agent_loads contains agent_id:
        Set agent_loads[agent_id] to 0.0
    Set agent_loads[agent_id] to agent_loads[agent_id] plus (task.complexity divided by 100)
    Return manager

Process called "schedule_task_retry" that takes manager as TaskManager and task_id as String returns TaskManager:
    Let task be manager.failed_tasks[task_id]
    Let current_time be get_current_timestamp
    
    Set task.retry_count to task.retry_count plus 1
    Set task.status to "pending"
    Set task.progress to 0.0
    Set task.updated_at to current_time
    
    Note: Calculate retry delay with exponential backoff
    Let retry_delay be task.retry_delay multiplied by (2 raised to (task.retry_count minus 1))
    Let retry_time be current_time plus retry_delay
    
    Note: Schedule retry
    Add task_id to manager.task_queue
    
    Add audit_event with manager as manager and event as Dictionary with:
        "type" as "task_retry_scheduled"
        "task_id" as task_id
        "retry_count" as task.retry_count
        "retry_time" as retry_time
        "timestamp" as current_time
    
    Return manager

Process called "update_task_progress_with_checkpoint" that takes manager as TaskManager and task_id as String and progress as Number and checkpoint_data as Dictionary[String, Any] returns TaskManager:
    If manager.tasks contains task_id:
        Let task be manager.tasks[task_id]
        Let current_time be get_current_timestamp
        
        Set task.progress to progress
        Set task.updated_at to current_time
        
        Note: Create checkpoint
        Let checkpoint be Dictionary with:
            "timestamp" as current_time
            "progress" as progress
            "data" as checkpoint_data
            "execution_id" as generate_uuid
        
        Add checkpoint to task.execution_history
        Set task.performance_metrics["checkpoint_count"] to task.performance_metrics["checkpoint_count"] plus 1
        
        Note: Update task analytics
        Set manager.task_analytics[task_id] to Dictionary with:
            "last_checkpoint" as current_time
            "progress_rate" as progress divided by (current_time minus task.created_at)
            "estimated_completion" as calculate_estimated_completion with task as task and progress as progress
        
        Add audit_event with manager as manager and event as Dictionary with:
            "type" as "task_checkpoint"
            "task_id" as task_id
            "progress" as progress
            "timestamp" as current_time
    
    Return manager

Process called "calculate_estimated_completion" that takes task as AgentTask and progress as Number returns Number:
    If progress is equal to 0:
        Return task.estimated_duration
    
    Let elapsed_time be get_current_timestamp minus task.created_at
    Let progress_rate be progress divided by elapsed_time
    Let remaining_progress be 100.0 minus progress
    Let estimated_remaining_time be remaining_progress divided by progress_rate
    
    Return get_current_timestamp plus estimated_remaining_time

Process called "set_task_result_with_validation" that takes manager as TaskManager and task_id as String and result as Any returns TaskManager:
    If manager.tasks contains task_id:
        Let task be manager.tasks[task_id]
        Let current_time be get_current_timestamp
        
        Note: Validate result
        If not validate_task_result with result as result and task as task:
            Set task.error to "Invalid result format"
            Set task.status to "failed"
            Set task.updated_at to current_time
            Set manager.performance_metrics["failed_tasks"] to manager.performance_metrics["failed_tasks"] plus 1
            Set manager.failed_tasks[task_id] to task
            Remove task_id from manager.tasks
            
            Add audit_event with manager as manager and event as Dictionary with:
                "type" as "task_result_invalid"
                "task_id" as task_id
                "timestamp" as current_time
            Return manager
        
        Set task.result to result
        Set task.status to "completed"
        Set task.progress to 100.0
        Set task.actual_duration to current_time minus task.created_at
        Set task.updated_at to current_time
        
        Note: Update performance metrics
        Set manager.performance_metrics["completed_tasks"] to manager.performance_metrics["completed_tasks"] plus 1
        Set manager.completed_tasks[task_id] to task
        Remove task_id from manager.tasks
        
        Note: Update analytics
        Set manager.task_analytics[task_id] to Dictionary with:
            "completion_time" as task.actual_duration
            "efficiency" as task.estimated_duration divided by task.actual_duration
            "success" as true
        
        Add audit_event with manager as manager and event as Dictionary with:
            "type" as "task_completed"
            "task_id" as task_id
            "duration" as task.actual_duration
            "timestamp" as current_time
    
    Return manager

Process called "validate_task_result" that takes result as Any and task as AgentTask returns Boolean:
    If type_of with value as result is not equal to task.metadata["expected_result_type"]:
        Return false
    For each key in task.metadata["required_result_fields"]:
        If not result contains key:
            Return false
    Return true

Process called "set_task_error_with_recovery" that takes manager as TaskManager and task_id as String and error as String returns TaskManager:
    If manager.tasks contains task_id:
        Let task be manager.tasks[task_id]
        Let current_time be get_current_timestamp
        
        Set task.error to error
        Set task.status to "failed"
        Set task.updated_at to current_time
        
        Note: Update performance metrics
        Set manager.performance_metrics["failed_tasks"] to manager.performance_metrics["failed_tasks"] plus 1
        Set task.performance_metrics["error_count"] to task.performance_metrics["error_count"] plus 1
        
        Note: Check if task should be retried
        If task.retry_count is less than task.max_retries:
            Set manager to schedule_task_retry with manager as manager and task_id as task_id
        Otherwise:
            Set manager.failed_tasks[task_id] to task
            Remove task_id from manager.tasks
            
            Note: Handle dependent tasks
            Set manager to handle_failed_dependencies with manager as manager and task_id as task_id
        
        Add audit_event with manager as manager and event as Dictionary with:
            "type" as "task_failed"
            "task_id" as task_id
            "error" as error
            "retry_count" as task.retry_count
            "timestamp" as current_time
    
    Return manager

Process called "handle_failed_dependencies" that takes manager as TaskManager and task_id as String returns TaskManager:
    Note: Find tasks that depend on the failed task
    For each dependent_task_id and dependencies in manager.task_dependencies:
        If dependencies contains task_id:
            Let dependent_task be manager.tasks[dependent_task_id]
            Set dependent_task.status to "blocked"
            Set dependent_task.error to "Dependency failed: " plus task_id
            Set dependent_task.updated_at to get_current_timestamp
            
            Add audit_event with manager as manager and event as Dictionary with:
                "type" as "task_blocked"
                "task_id" as dependent_task_id
                "blocked_by" as task_id
                "timestamp" as get_current_timestamp
    
    Return manager

Note: Advanced Task Orchestration and Workflows
Process called "create_task_workflow" that takes manager as TaskManager and workflow as TaskWorkflow returns TaskManager:
    Let current_time be get_current_timestamp
    
    Note: Validate workflow definition
    If not validate_workflow_definition with workflow as workflow:
        Add audit_event with manager as manager and event as Dictionary with:
            "type" as "workflow_creation_failed"
            "workflow_id" as workflow.workflow_id
            "reason" as "validation_failed"
            "timestamp" as current_time
        Return manager
    
    Set manager.workflow_definitions[workflow.workflow_id] to workflow
    
    Add audit_event with manager as manager and event as Dictionary with:
        "type" as "workflow_created"
        "workflow_id" as workflow.workflow_id
        "steps" as length of workflow.steps
        "timestamp" as current_time
    
    Return manager

Process called "validate_workflow_definition" that takes workflow as TaskWorkflow returns Boolean:
    If workflow.workflow_id is equal to "" or workflow.name is equal to "":
        Return false
    If length of workflow.steps is equal to 0:
        Return false
    Let step_ids be list containing
    For each step in workflow.steps:
        If not step contains "step_id":
            Return false
        If step_ids contains step["step_id"]:
            Return false
        Add step["step_id"] to step_ids
    Note: Check for cycles in dependencies
    Let visited be dictionary with:
    For each step_id in step_ids:
        If not check_workflow_acyclic with workflow as workflow and step_id as step_id and visited as visited:
            Return false
    For each step_id and dependencies in workflow.dependencies:
        For each dependency in dependencies:
            If not step_ids contains dependency:
                Return false
    Return true

Process called "check_workflow_acyclic" that takes workflow as TaskWorkflow and step_id as String and visited as Dictionary[String, Boolean] returns Boolean:
    If visited contains step_id:
        Return false
    Set visited[step_id] to true
    If workflow.dependencies contains step_id:
        For each dep in workflow.dependencies[step_id]:
            If not check_workflow_acyclic with workflow as workflow and step_id as dep and visited as visited:
                Return false
    Set visited[step_id] to false
    Return true

Process called "execute_workflow" that takes manager as TaskManager and workflow_id as String and input_data as Dictionary[String, Any] returns String:
    If not manager.workflow_definitions contains workflow_id:
        Return ""
    
    Let workflow be manager.workflow_definitions[workflow_id]
    Let workflow_execution_id be generate_uuid
    Let current_time be get_current_timestamp
    
    Note: Create workflow execution context
    Let execution_context be Dictionary with:
        "workflow_id" as workflow_id
        "execution_id" as workflow_execution_id
        "status" as "running"
        "current_step" as 0
        "input_data" as input_data
        "output_data" as dictionary with:
        "step_results" as list containing
        "start_time" as current_time
        "error_handling" as workflow.error_handling
    
    Note: Execute workflow steps
    For i from 0 to length of workflow.steps minus 1:
        Let step be workflow.steps[i]
        Let step_result be execute_workflow_step with manager as manager and step as step and context as execution_context
        
        If step_result["status"] is equal to "failed":
            Set execution_context["status"] to "failed"
            Set execution_context["error"] to step_result["error"]
            Break
        
        Add step_result to execution_context["step_results"]
        Set execution_context["current_step"] to i plus 1
    
    If execution_context["status"] is equal to "completed":
        Set execution_context["status"] to "completed"
        Set execution_context["end_time"] to get_current_timestamp
    
    Add audit_event with manager as manager and event as Dictionary with:
        "type" as "workflow_executed"
        "workflow_id" as workflow_id
        "execution_id" as workflow_execution_id
        "status" as execution_context["status"]
        "timestamp" as current_time
    
    Return workflow_execution_id

Process called "execute_workflow_step" that takes manager as TaskManager and step as Dictionary[String, Any] and context as Dictionary[String, Any] returns Dictionary[String, Any]:
    Let step_id be step["step_id"]
    Let step_type be step["type"]
    Let current_time be get_current_timestamp
    
    If step_type is equal to "task":
        Let task_id be step["task_id"]
        Let task be manager.tasks[task_id]
        
        If task.status is equal to "completed":
            Return Dictionary with:
                "step_id" as step_id
                "status" as "completed"
                "result" as task.result
                "timestamp" as current_time
        Otherwise if task.status is equal to "failed":
            Return Dictionary with:
                "step_id" as step_id
                "status" as "failed"
                "error" as task.error
                "timestamp" as current_time
        Otherwise:
            Return Dictionary with:
                "step_id" as step_id
                "status" as "pending"
                "timestamp" as current_time
    
    Otherwise if step_type is equal to "condition":
        Let condition be step["condition"]
        Let result be evaluate_condition with condition as condition and context as context
        
        Return Dictionary with:
            "step_id" as step_id
            "status" as "completed"
            "result" as result
            "timestamp" as current_time
    
    Otherwise if step_type is equal to "parallel":
        Let parallel_tasks be step["tasks"]
        Let results be list containing
        
        For each task_id in parallel_tasks:
            Let task be manager.tasks[task_id]
            Add Dictionary with:
                "task_id" as task_id
                "status" as task.status
                "result" as task.result
                "error" as task.error
            to results
        
        Return Dictionary with:
            "step_id" as step_id
            "status" as "completed"
            "results" as results
            "timestamp" as current_time
    
    Return Dictionary with:
        "step_id" as step_id
        "status" as "unknown"
        "timestamp" as current_time

Process called "evaluate_condition" that takes condition as Dictionary[String, Any] and context as Dictionary[String, Any] returns Boolean:
    Let cond_type be condition["type"]
    If cond_type is equal to "equals":
        Return context[condition["left"]] is equal to condition["right"]
    If cond_type is equal to "greater_than":
        Return context[condition["left"]] > condition["right"]
    If cond_type is equal to "less_than":
        Return context[condition["left"]] < condition["right"]
    If cond_type is equal to "not_equals":
        Return context[condition["left"]] is not equal to condition["right"]
    If cond_type is equal to "in":
        Return context[condition["left"]] contains condition["right"]
    Return false

Note: Task Analytics and Monitoring
Process called "get_task_analytics" that takes manager as TaskManager returns Dictionary[String, Any]:
    Let total_tasks be manager.performance_metrics["total_tasks"]
    Let completed_tasks be manager.performance_metrics["completed_tasks"]
    Let failed_tasks be manager.performance_metrics["failed_tasks"]
    
    Let success_rate be 0.0
    If total_tasks is greater than 0:
        Set success_rate to completed_tasks divided by total_tasks multiplied by 100
    
    Let avg_completion_time be 0.0
    Let total_completion_time be 0.0
    Let completion_count be 0
    
    For each task_id and task in manager.completed_tasks:
        Set total_completion_time to total_completion_time plus task.actual_duration
        Set completion_count to completion_count plus 1
    
    If completion_count is greater than 0:
        Set avg_completion_time to total_completion_time divided by completion_count
    
    Let priority_distribution be dictionary with:
    For each task_id and task in manager.tasks:
        Let priority be task.priority
        If priority_distribution contains priority:
            Set priority_distribution[priority] to priority_distribution[priority] plus 1
        Otherwise:
            Set priority_distribution[priority] to 1
    
    Return Dictionary with:
        "total_tasks" as total_tasks
        "completed_tasks" as completed_tasks
        "failed_tasks" as failed_tasks
        "success_rate" as success_rate
        "average_completion_time" as avg_completion_time
        "priority_distribution" as priority_distribution
        "resource_utilization" as manager.performance_metrics["resource_utilization"]
        "active_workflows" as length of manager.workflow_definitions

Process called "get_agent_task_performance" that takes manager as TaskManager and agent_id as String returns Dictionary[String, Any]:
    Let agent_tasks be manager.agent_tasks[agent_id]
    Let completed_count be 0
    Let failed_count as 0
    Let total_duration be 0.0
    Let task_history be list containing
    
    For each task_id in agent_tasks:
        If manager.completed_tasks contains task_id:
            Let task be manager.completed_tasks[task_id]
            Set completed_count to completed_count plus 1
            Set total_duration to total_duration plus task.actual_duration
            Add Dictionary with:
                "task_id" as task_id
                "status" as "completed"
                "duration" as task.actual_duration
                "priority" as task.priority
            to task_history
        Otherwise if manager.failed_tasks contains task_id:
            Let task be manager.failed_tasks[task_id]
            Set failed_count to failed_count plus 1
            Add Dictionary with:
                "task_id" as task_id
                "status" as "failed"
                "error" as task.error
                "priority" as task.priority
            to task_history
    
    Let success_rate be 0.0
    Let total_tasks be completed_count plus failed_count
    If total_tasks is greater than 0:
        Set success_rate to completed_count divided by total_tasks multiplied by 100
    
    Let avg_duration be 0.0
    If completed_count is greater than 0:
        Set avg_duration to total_duration divided by completed_count
    
    Return Dictionary with:
        "agent_id" as agent_id
        "total_tasks" as total_tasks
        "completed_tasks" as completed_count
        "failed_tasks" as failed_count
        "success_rate" as success_rate
        "average_duration" as avg_duration
        "task_history" as task_history

Note: Utility Functions
Process called "list_agent_tasks" that takes manager as TaskManager and agent_id as String returns List[String]:
    If manager.agent_tasks contains agent_id:
        Return manager.agent_tasks[agent_id]
    Return list containing

Process called "add_audit_event" that takes manager as TaskManager and event as Dictionary[String, Any] returns TaskManager:
    Let audit_event be Dictionary with:
        "event_id" as generate_uuid
        "timestamp" as get_current_timestamp
        "event_type" as event["type"]
        "details" as event
        "hash" as calculate_event_hash with event as event
    
    Add audit_event to manager.audit_log
    
    Note: Trim audit log if it gets too large
    If length of manager.audit_log is greater than 10000:
        Let trimmed_log be list containing
        For i from length of manager.audit_log minus 5000 to length of manager.audit_log minus 1:
            Add manager.audit_log[i] to trimmed_log
        Set manager.audit_log to trimmed_log
    
    Return manager

Process called "generate_uuid" that returns String:
    Return generate_random_uuid

Process called "calculate_event_hash" that takes event as Dictionary[String, Any] returns String:
    Return calculate_sha256_hash with data as serialize_json with data as event

Process called "get_current_timestamp" that returns Number:
    Return get_system_timestamp 