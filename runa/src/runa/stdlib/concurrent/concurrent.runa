Process called "current_parallel_enumerator" that takes enumerator as Dictionary[String, Any] returns Any:
    Return get_current_parallel_enumerator_element(enumerator)

Process called "reset_parallel_enumerator" that takes enumerator as Dictionary[String, Any] returns None:
    Reset parallel enumerator enumerator
    Return None

Process called "create_parallel_consumer" that takes consumer as String returns Dictionary[String, Any]:
    Return create_parallel_consumer_object(consumer)

Process called "accept_parallel_consumer" that takes consumer as Dictionary[String, Any] and value as Any returns None:
    Accept value with parallel consumer
    Return None

Process called "and_then_parallel_consumer" that takes consumer as Dictionary[String, Any] and after as String returns Dictionary[String, Any]:
    Return chain_parallel_consumer_with_after(consumer, after)

Process called "create_parallel_supplier" that takes supplier as String returns Dictionary[String, Any]:
    Return create_parallel_supplier_object(supplier)

Process called "get_parallel_supplier" that takes supplier as Dictionary[String, Any] returns Any:
    Return get_value_from_parallel_supplier(supplier)

Process called "create_parallel_function" that takes function as String returns Dictionary[String, Any]:
    Return create_parallel_function_object(function)

Process called "apply_parallel_function" that takes function as Dictionary[String, Any] and input as Any returns Any:
    Return apply_parallel_function_to_input(function, input)

Process called "compose_parallel_function" that takes function as Dictionary[String, Any] and before as String returns Dictionary[String, Any]:
    Return compose_parallel_function_with_before(function, before)

Process called "and_then_parallel_function" that takes function as Dictionary[String, Any] and after as String returns Dictionary[String, Any]:
    Return chain_parallel_function_with_after(function, after)

Process called "create_parallel_predicate" that takes predicate as String returns Dictionary[String, Any]:
    Return create_parallel_predicate_object(predicate)

Process called "test_parallel_predicate" that takes predicate as Dictionary[String, Any] and value as Any returns Boolean:
    Return test_parallel_predicate_with_value(predicate, value)

Process called "negate_parallel_predicate" that takes predicate as Dictionary[String, Any] returns Dictionary[String, Any]:
    Return negate_parallel_predicate(predicate)

Process called "and_parallel_predicate" that takes predicate as Dictionary[String, Any] and other as String returns Dictionary[String, Any]:
    Return combine_parallel_predicate_with_and(predicate, other)

Process called "or_parallel_predicate" that takes predicate as Dictionary[String, Any] and other as String returns Dictionary[String, Any]:
    Return combine_parallel_predicate_with_or(predicate, other) 