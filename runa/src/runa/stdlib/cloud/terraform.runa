            "source_address" as source_address,
            "destination_address" as destination_address,
            "error" as result["error"]
    
    Return true

Note: Refresh Terraform state
Process called "terraform_refresh" that takes working_directory as String and options as Dictionary[String, Any] returns Boolean:
    Let parameters be list containing
    
    Note: Add variable file
    If options contains key "var_file":
        Add "-var-file=" with message options["var_file"] to parameters
    
    Note: Add individual variables
    If options contains key "vars":
        For each key and value in options["vars"]:
            Add "-var=" with message key with message "=" with message value to parameters
    
    Note: Add target resources
    If options contains key "targets":
        For each target in options["targets"]:
            Add "-target=" with message target to parameters
    
    Let result be execute_terraform_command with command as "refresh" and parameters as parameters and working_directory as working_directory
    If not result["success"]:
        Throw create_runtime_error with operation as "terraform_refresh" and context as dictionary with:
            "working_directory" as working_directory,
            "error" as result["error"]
    
    Return true

Note: Get Terraform providers information
Process called "terraform_providers" that takes working_directory as String returns List[TerraformProvider]:
    Let parameters be list containing
    Add "-json" to parameters
    
    Let result be execute_terraform_command with command as "providers" and parameters as parameters and working_directory as working_directory
    If not result["success"]:
        Throw create_runtime_error with operation as "terraform_providers" and context as dictionary with:
            "working_directory" as working_directory,
            "error" as result["error"]
    
    Let providers_data be parse_json with json_string as result["output"]
    Let providers = list containing
    
    For each provider_name and provider_info in providers_data:
        Let provider be dictionary with:
            "name" as provider_name,
            "alias" as null,
            "version" as (provider_info["version"] if provider_info contains key "version" otherwise null),
            "configuration" as (provider_info["config"] if provider_info contains key "config" otherwise dictionary containing),
            "required_version" as (provider_info["version_constraint"] if provider_info contains key "version_constraint" otherwise null),
            "source" as (provider_info["source"] if provider_info contains key "source" otherwise null)
        Add provider to providers
    
    Return providers

Note: Format Terraform configuration files
Process called "terraform_fmt" that takes working_directory as String and options as Dictionary[String, Any] returns Dictionary[String, Any]:
    Let parameters be list containing
    
    Note: Add recursive flag
    If options contains key "recursive" and options["recursive"]:
        Add "-recursive" to parameters
    
    Note: Add diff flag
    If options contains key "diff" and options["diff"]:
        Add "-diff" to parameters
    
    Note: Add check flag
    If options contains key "check" and options["check"]:
        Add "-check" to parameters
    
    Note: Add write flag (default true)
    If options contains key "write" and not options["write"]:
        Add "-write=false" to parameters
    
    Let result be execute_terraform_command with command as "fmt" and parameters as parameters and working_directory as working_directory
    If not result["success"]:
        Throw create_runtime_error with operation as "terraform_fmt" and context as dictionary with:
            "working_directory" as working_directory,
            "error" as result["error"]
    
    Return dictionary with:
        "formatted_files" as (split with text as result["output"] and delimiter as "\n" if not (is_empty with collection as result["output"]) otherwise list containing),
        "working_directory" as working_directory

Note: Generate Terraform dependency graph
Process called "terraform_graph" that takes working_directory as String and graph_type as Optional[String] returns String:
    Let parameters be list containing
    
    Note: Add graph type
    If graph_type is not null:
        Add "-type=" with message graph_type to parameters
    
    Let result be execute_terraform_command with command as "graph" and parameters as parameters and working_directory as working_directory
    If not result["success"]:
        Throw create_runtime_error with operation as "terraform_graph" and context as dictionary with:
            "working_directory" as working_directory,
            "graph_type" as graph_type,
            "error" as result["error"]
    
    Return result["output"]

Note: Get Terraform workspace information
Process called "terraform_workspace_list" that takes working_directory as String returns List[String]:
    Let parameters be list containing
    
    Let result be execute_terraform_command with command as "workspace list" and parameters as parameters and working_directory as working_directory
    If not result["success"]:
        Throw create_runtime_error with operation as "terraform_workspace_list" and context as dictionary with:
            "working_directory" as working_directory,
            "error" as result["error"]
    
    Let workspaces be list containing
    Let lines be split with text as result["output"] and delimiter as "\n"
    For each line in lines:
        Let trimmed_line be trim with text as line
        If not (is_empty with collection as trimmed_line):
            Note: Remove asterisk from current workspace
            Let workspace_name be replace with text as trimmed_line and old_substring as "* " and new_substring as ""
            Set workspace_name to trim with text as workspace_name
            Add workspace_name to workspaces
    
    Return workspaces

